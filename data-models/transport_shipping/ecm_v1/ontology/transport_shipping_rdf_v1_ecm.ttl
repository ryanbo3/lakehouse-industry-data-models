ind:workflowId rdf:type rdf:Property ;
    rdfs:label 'Workflow Id' ;
    rdfs:comment 'Foreign key linking to document.document_workflow. Business justification: Contract approval workflows may trigger document workflow creation (approved contract initiates template setup, executed agreement triggers document package creation). Business process: operational ha' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Workflow .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'Precise timestamp when the approval action was recorded. Critical for SOX audit trail and SLA compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedApproverName rdf:type rdf:Property ;
    rdfs:label 'Assigned Approver Name' ;
    rdfs:comment 'Full name of the individual currently assigned to approve the workflow. Denormalized for reporting convenience.' ;
    rdfs:domain ind:ContractApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedApproverRole rdf:type rdf:Property ;
    rdfs:label 'Assigned Approver Role' ;
    rdfs:comment 'Functional role or title of the assigned approver (e.g., Legal Counsel, Finance Director, VP Commercial).' ;
    rdfs:domain ind:ContractApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Full name of the authorized signatory who will execute the contract. Denormalized for audit and reporting.' ;
    rdfs:domain ind:ContractApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Required Flag' ;
    rdfs:comment 'Indicates whether a formal compliance review is required as part of the approval workflow. Triggered by regulatory obligations or contract characteristics.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractValueAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Value Amount' ;
    rdfs:comment 'Total monetary value of the contract undergoing approval. Used for authorization level determination and risk assessment.' ;
    rdfs:domain ind:ContractApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contract Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value amount.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartySignatoryName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Signatory Name' ;
    rdfs:comment 'Full name of the counterparty representative who executed the contract on behalf of the customer, carrier, or vendor.' ;
    rdfs:domain ind:ContractApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'Precise timestamp when the contract execution was recorded. Marks the legal binding moment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the approval workflow was initiated. Marks the start of the approval process.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Precise timestamp when the approval workflow was initiated. Used for SLA tracking and audit trail.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Indicates whether legal counsel review is required. Typically mandatory for new contracts and material amendments.' ;
    rdfs:domain ind:ContractApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether workflow status notification has been sent to relevant stakeholders.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaActualDays rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Days' ;
    rdfs:comment 'Actual number of business days taken to complete the approval workflow. Calculated from initiation to execution.' ;
    rdfs:domain ind:ContractApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether the workflow was completed within the target SLA timeframe. Used for KPI reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Days' ;
    rdfs:comment 'Target number of business days for completing the approval workflow. Used for performance measurement and escalation triggers.' ;
    rdfs:domain ind:ContractApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Date when the workflow was formally submitted for approval. Marks transition from draft to active review.' ;
    rdfs:domain ind:ContractApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Precise timestamp when the workflow was submitted for approval. Used for SLA compliance measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current lifecycle status of the approval workflow. Tracks progression through approval stages. [ENUM-REF-CANDIDATE: draft|submitted|in_review|approved|rejected|returned|cancelled|executed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowType rdf:type rdf:Property ;
    rdfs:label 'Workflow Type' ;
    rdfs:comment 'Type of contract event triggering the approval workflow. Determines the approval path and required reviewers.' ;
    rdfs:domain ind:ContractApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDisputeId rdf:type rdf:Property ;
    rdfs:label 'Contract Dispute Id' ;
    rdfs:comment 'Unique identifier for the contract dispute record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractDispute .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Disputes relate to specific AR items and impact collections, aging, and write-off decisions. Essential for dispute resolution, credit management, and accurate AR reporting in logistics billing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:contractSlaCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Contract Sla Commitment Id' ;
    rdfs:comment 'Reference to the specific SLA commitment that was allegedly breached, if the dispute is SLA-related.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractSlaCommitment .

ind:raisedByContactId rdf:type rdf:Property ;
    rdfs:label 'Raised By Contact Id' ;
    rdfs:comment 'Reference to the specific contact person or representative who raised the dispute.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:relatedShipmentConsignmentId rdf:type rdf:Property ;
    rdfs:label 'Related Shipment Consignment Id' ;
    rdfs:comment 'Reference to the shipment associated with the dispute, if applicable (e.g., for delivery delay or damage claims).' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consignment .

ind:resolutionJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Resolution Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Dispute resolutions trigger adjusting journal entries for revenue/expense corrections. Critical for financial close, audit trail, SOX compliance, and accurate financial statement preparation.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'The date when the dispute was assigned to a resolution specialist or team for investigation.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'The date when the dispute record was formally closed in the system, marking the end of all administrative and follow-up activities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether corrective actions or process improvements are required to prevent recurrence of similar disputes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditNoteIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Note Issued Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether a credit note was issued to the customer or counterparty as part of the dispute resolution.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysToResolution rdf:type rdf:Property ;
    rdfs:label 'Days To Resolution' ;
    rdfs:comment 'The number of calendar days elapsed from the dispute date to the resolution date, used for performance tracking and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Detailed narrative description of the dispute, including the nature of the disagreement, relevant facts, and context provided by the raising party.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the dispute, used in communications and tracking.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispute Timestamp' ;
    rdfs:comment 'The precise date and time when the dispute was formally raised or logged in the system.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpact rdf:type rdf:Property ;
    rdfs:label 'Financial Impact' ;
    rdfs:comment 'The net financial impact to the organization resulting from the dispute resolution, including settlements, penalties, credits, or cost recoveries.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalCaseReference rdf:type rdf:Property ;
    rdfs:label 'Legal Case Reference' ;
    rdfs:comment 'Reference number or identifier for any formal legal case, arbitration proceeding, or court filing associated with the dispute.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Involved Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether legal counsel or attorneys were engaged in the dispute resolution process.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyWaivedAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Waived Amount' ;
    rdfs:comment 'The monetary value of penalties that were waived as part of the dispute resolution.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Waived Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether contractual penalties were waived as part of the dispute resolution or goodwill gesture.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:raisedByParty rdf:type rdf:Property ;
    rdfs:label 'Raised By Party' ;
    rdfs:comment 'The party that initiated the dispute: customer, carrier, vendor, internal (own organization), or Third-Party Logistics (3PL) / Fourth-Party Logistics (4PL) partner.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'The approach or mechanism used to resolve the dispute: negotiation (direct discussion), mediation (third-party facilitated), arbitration (binding third-party decision), litigation (court proceedings), internal review, or mutual agreement.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'The final outcome of the dispute resolution: favor claimant (dispute upheld), favor respondent (dispute rejected), partial settlement, compromise (both parties concede), withdrawn (claimant withdrew), or dismissed (no merit).' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'The precise date and time when the dispute was formally resolved.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of the underlying root cause identified during dispute investigation (e.g., operational error, system failure, communication breakdown, external factor).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence Reference' ;
    rdfs:comment 'Reference to supporting documentation, evidence files, or document management system identifiers (e.g., Proof of Delivery (POD), Electronic Proof of Delivery (ePOD), photos, correspondence) that substantiate the dispute claim.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'The target or expected date by which the dispute should be resolved, based on Service Level Agreement (SLA) or internal Key Performance Indicator (KPI) commitments.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Reference to the master party entity (customer, carrier, vendor, broker, guarantor) participating in this contract.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportShipping .

ind:complianceCertification rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification' ;
    rdfs:comment 'Compliance certifications held by this party relevant to the contract (e.g., C-TPAT, AEO, ISO 28000, IATA certification).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatNumber rdf:type rdf:Property ;
    rdfs:label 'Ctpat Number' ;
    rdfs:comment 'C-TPAT certification number if the party is certified under the U.S. Customs-Trade Partnership Against Terrorism program.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicense rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License' ;
    rdfs:comment 'Customs broker license number if the party is authorized to conduct customs clearance activities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediIdentifier rdf:type rdf:Property ;
    rdfs:label 'Edi Identifier' ;
    rdfs:comment 'EDI identifier or interchange ID for electronic communication with this party (e.g., GS1 GLN, DUNS number).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date on which this party\'s participation in the contract ends or is scheduled to end (format: yyyy-MM-dd). Nullable for open-ended participation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guarantorFlag rdf:type rdf:Property ;
    rdfs:label 'Guarantor Flag' ;
    rdfs:comment 'Indicates whether this party serves as a guarantor for contract obligations (True/False).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The full legal name of the party as registered with governing authorities, used for contract execution and compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum liability amount for this party under the contract terms, if applicable.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the liability cap amount.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'Preferred method for contract-related notifications and communications (email, phone, postal mail, EDI, API).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nvoccLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Nvocc License Number' ;
    rdfs:comment 'NVOCC license number issued by the Federal Maritime Commission if the party operates as a non-vessel operating common carrier.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Responsibility Flag' ;
    rdfs:comment 'Indicates whether this party has payment responsibility under the contract (True/False). Relevant for identifying payers vs. service recipients.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this party is the primary contact for contract administration and communication (True/False).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Registration Jurisdiction' ;
    rdfs:comment 'The country or jurisdiction where the party is legally registered (ISO 3166-1 alpha-3 country code).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official business registration or incorporation number issued by the relevant jurisdiction (e.g., company registration number, tax ID, VAT number).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Standard Carrier Alpha Code for ocean and intermodal carriers, used for shipment identification and EDI transactions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryEmail rdf:type rdf:Property ;
    rdfs:label 'Signatory Email' ;
    rdfs:comment 'Email address of the authorized signatory for contract correspondence and notifications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Full name of the individual authorized to sign the contract on behalf of this party.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryPhone rdf:type rdf:Property ;
    rdfs:label 'Signatory Phone' ;
    rdfs:comment 'Contact phone number of the authorized signatory.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'Job title or position of the authorized signatory (e.g., Chief Executive Officer, Director of Operations, Authorized Representative).' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'The date on which this party signed the contract (format: yyyy-MM-dd).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatureLocation rdf:type rdf:Property ;
    rdfs:label 'Signature Location' ;
    rdfs:comment 'City and country where the contract was signed by this party.' ;
    rdfs:domain ind:ContractParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureMethod rdf:type rdf:Property ;
    rdfs:label 'Signature Method' ;
    rdfs:comment 'The method by which the contract was signed (wet signature, electronic signature, digital signature, notarized).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsFactorId rdf:type rdf:Property ;
    rdfs:label 'Emissions Factor Id' ;
    rdfs:comment 'Foreign key linking to sustainability.emissions_factor. Business justification: Green SLA commitments specify carbon intensity thresholds (gCO2e/tonne-km) requiring designated emission factors for consistent measurement methodology across contract term. Essential for SLA complian' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionsFactor .

ind:serviceCorridorId rdf:type rdf:Property ;
    rdfs:label 'Service Corridor Id' ;
    rdfs:comment 'Foreign key linking to route.service_corridor. Business justification: SLA commitments often apply to entire service corridors (multi-leg routes) rather than individual lanes. Enables corridor-level performance tracking, capacity planning, and compliance reporting agains' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCorridor .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The historical or initial baseline performance value used as a reference point for improvement targets. Nullable if no baseline is established.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Tracking Flag' ;
    rdfs:comment 'Indicates whether this SLA commitment is actively tracked for compliance and reporting (True) or is informational only (False).' ;
    rdfs:domain ind:ContractSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractSlaCommitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Sla Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the SLA commitment: active (in force), inactive (not currently enforced), suspended (temporarily paused), expired (past effective-to date), superseded (replaced by newer commitment), or draft (not yet finalized).' ;
    rdfs:domain ind:ContractSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'The customer segment or industry vertical to which this SLA applies (e.g., enterprise, mid-market, small business, e-commerce, retail, wholesale, government, healthcare, manufacturing). Nullable if SLA applies to all segments. [ENUM-REF-CANDIDATE: enterprise|mid_market|small_business|ecommerce|retail|wholesale|government|healthcare|manufacturing — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Conditions or circumstances under which this SLA commitment does not apply (e.g., force majeure, weather delays, customs holds, peak season surcharges, hazardous materials). Free-text field.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiMetric rdf:type rdf:Property ;
    rdfs:label 'Kpi Metric' ;
    rdfs:comment 'The specific KPI metric being measured: on-time delivery percentage, on-time in-full percentage, transit time in hours, pickup response time in minutes, claims resolution time in days, customer service response time in hours, delivery accuracy percentage, or customs clearance time in hours. [ENUM-REF-CANDIDATE: on_time_delivery_pct|on_time_in_full_pct|transit_time_hours|pickup_response_minutes|claims_resolution_days|service_response_hours|delivery_accuracy_pct|customs_clearance_hours — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often the SLA performance is measured and reported: daily, weekly, monthly, quarterly, annually, per shipment, or continuous real-time monitoring. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|per_shipment|continuous — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The time window over which SLA performance is aggregated for reporting: calendar month, rolling 30 days, calendar quarter, rolling 90 days, calendar year, contract year, weekly, or daily. [ENUM-REF-CANDIDATE: calendar_month|rolling_30_days|calendar_quarter|rolling_90_days|calendar_year|contract_year|weekly|daily — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Specific service tier or product offering within the service mode (e.g., \'Next Day Air\', \'Standard Ground\', \'2-Day Express\', \'Economy Ocean\').' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'The logistics service mode to which this SLA applies: express parcel, freight (air/ocean/road/rail), last-mile delivery, LTL (Less Than Truckload), FTL (Full Truckload), FCL (Full Container Load), or LCL (Less Than Container Load). [ENUM-REF-CANDIDATE: express|freight|last_mile|air|ocean|road|rail|parcel|ltl|ftl|fcl|lcl — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Business identifier or code for the SLA commitment, used for external reference and reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable name or title of the SLA commitment (e.g., \'Express Delivery OTD Target\', \'Freight Transit Time Guarantee\').' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of SLA commitment: OTD (On-Time Delivery), OTIF (On-Time In-Full), transit time guarantee, pickup window, claims resolution time, customer service response time, delivery window, customs clearance time, or proof of delivery turnaround. [ENUM-REF-CANDIDATE: otd|otif|transit_time|pickup_window|claims_resolution|customer_service_response|delivery_window|customs_clearance|proof_of_delivery — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The committed target value for the KPI metric (e.g., 95.0 for 95% OTD, 48.0 for 48-hour transit time).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The minimum acceptable threshold value below which penalties or escalations may apply. Nullable if no threshold is defined.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentMax rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Max' ;
    rdfs:comment 'The maximum shipment volume (in units, weight, or TEU) for which this SLA applies. Nullable if no maximum volume is defined.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentMin rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Min' ;
    rdfs:comment 'The minimum shipment volume (in units, weight, or TEU) required for this SLA to apply. Nullable if no minimum volume is required.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'The unit of measure for volume commitments: shipments, packages, pallets, TEU (Twenty-foot Equivalent Unit), kilograms, pounds, CBM (Cubic Meter), or tons. [ENUM-REF-CANDIDATE: shipments|packages|pallets|teu|kg|lbs|cbm|tons — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Surcharge approval tracking is required for financial controls, audit compliance, and authorization verification in logistics pricing. The approved_by string denormalizes employee identity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:procurementContractId rdf:type rdf:Property ;
    rdfs:label 'Procurement Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.procurement_contract. Business justification: Surcharge schedules (fuel, security, peak season) reference procurement contracts with carriers that define pass-through terms. Critical for surcharge reconciliation, margin protection, and regulatory' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementContract .

ind:supersedesScheduleContractSurchargeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Schedule Contract Surcharge Schedule Id' ;
    rdfs:comment 'Reference to the previous surcharge schedule that this version replaces or supersedes. Null if this is the first version.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractSurchargeSchedule .

ind:adjustmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Adjustment Frequency' ;
    rdfs:comment 'Frequency at which the surcharge rate is reviewed and adjusted. Weekly = every week, biweekly = every two weeks, monthly = every month, quarterly = every quarter, annually = once per year, event_driven = adjusted based on specific triggers or market events.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityCondition rdf:type rdf:Property ;
    rdfs:label 'Applicability Condition' ;
    rdfs:comment 'Business rules or conditions under which this surcharge applies (e.g., specific service types, lanes, origin/destination pairs, shipment characteristics, weight thresholds, or seasonal periods).' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Method used to calculate the surcharge amount. Percentage = percentage of base rate, flat_rate = fixed amount per shipment, per_unit = amount per weight/volume unit, tiered = rate varies by volume brackets, index_based = linked to external index (e.g., fuel price index), formula = custom calculation formula.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingAllowed rdf:type rdf:Property ;
    rdfs:label 'Compounding Allowed' ;
    rdfs:comment 'Indicates whether this surcharge can be compounded with other surcharges (true) or must be applied independently (false).' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Region' ;
    rdfs:comment 'Geographic region or country code to which shipments must be destined for this surcharge to apply. Uses ISO 3166-1 alpha-3 country codes or regional identifiers.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exemption Criteria' ;
    rdfs:comment 'Conditions under which shipments are exempt from this surcharge (e.g., specific customer segments, promotional periods, volume commitments, or contractual waivers).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexReference rdf:type rdf:Property ;
    rdfs:label 'Index Reference' ;
    rdfs:comment 'External index or benchmark used for index-based surcharge calculations (e.g., Platts Bunker Index, DOE Fuel Price Index, market commodity indices). Specifies the source and identifier of the index.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCharge rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge' ;
    rdfs:comment 'Cap value for the surcharge. If the calculated surcharge exceeds this amount, the maximum charge applies instead.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'Floor value for the surcharge. If the calculated surcharge is below this amount, the minimum charge applies instead.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationLeadDays rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Days' ;
    rdfs:comment 'Number of days in advance that customers must be notified before this surcharge takes effect or is adjusted. Null if notification_required is false.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether customers must be notified in advance when this surcharge is applied or adjusted (true) or if notification is not required (false).' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originRegion rdf:type rdf:Property ;
    rdfs:label 'Origin Region' ;
    rdfs:comment 'Geographic region or country code from which shipments must originate for this surcharge to apply. Uses ISO 3166-1 alpha-3 country codes or regional identifiers.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prioritySequence rdf:type rdf:Property ;
    rdfs:label 'Priority Sequence' ;
    rdfs:comment 'Order in which this surcharge should be applied when multiple surcharges are applicable to the same shipment. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method for prorating surcharges when they apply for partial periods. None = no proration, daily = prorated by day, monthly = prorated by month, proportional = prorated based on usage or volume.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Legal or regulatory framework that mandates or governs this surcharge (e.g., IMO regulations for BAF, government-imposed security fees, environmental levies, or customs-related charges).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeRate rdf:type rdf:Property ;
    rdfs:label 'Surcharge Rate' ;
    rdfs:comment 'The rate or percentage value used in surcharge calculation. For percentage-based surcharges, this represents the percentage (e.g., 5.5 for 5.5%). For flat or per-unit rates, this represents the monetary amount.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Max' ;
    rdfs:comment 'Maximum shipment volume (in CBM or cubic feet) for this surcharge to apply. Null indicates no maximum threshold.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Min' ;
    rdfs:comment 'Minimum shipment volume (in CBM or cubic feet) for this surcharge to apply. Null indicates no minimum threshold.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Weight Threshold Max' ;
    rdfs:comment 'Maximum shipment weight (in the unit specified by weight_threshold_unit) for this surcharge to apply. Null indicates no maximum threshold.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Weight Threshold Min' ;
    rdfs:comment 'Minimum shipment weight (in the unit specified by weight_threshold_unit) for this surcharge to apply. Null indicates no minimum threshold.' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Threshold Unit' ;
    rdfs:comment 'Unit of measure for weight thresholds. kg = kilogram, lb = pound, ton = US ton (2000 lbs), metric_ton = metric tonne (1000 kg).' ;
    rdfs:domain ind:ContractSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractVolumeCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Contract Volume Commitment Id' ;
    rdfs:comment 'Unique identifier for the contract volume commitment record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractVolumeCommitment .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Volume commitment creation audit trails are mandatory for contract governance, dispute resolution, and accountability tracking in logistics operations. The created_by string denormalizes employee iden' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualVolume rdf:type rdf:Property ;
    rdfs:label 'Actual Volume' ;
    rdfs:comment 'Actual volume utilized or booked against this commitment during the current measurement period. Updated periodically as shipments are executed.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether this volume commitment automatically renews for the next period upon expiration. True if auto-renewal is enabled, False otherwise.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentCode rdf:type rdf:Property ;
    rdfs:label 'Commitment Code' ;
    rdfs:comment 'Business identifier or code for this volume commitment, used for external reference and reporting.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentNotes rdf:type rdf:Property ;
    rdfs:label 'Commitment Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context, special conditions, or clarifications regarding this volume commitment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentPartyType rdf:type rdf:Property ;
    rdfs:label 'Commitment Party Type' ;
    rdfs:comment 'Type of party to whom this volume commitment applies: customer (shipper/consignee), carrier (transport provider), 3PL (Third-Party Logistics provider), 4PL (Fourth-Party Logistics provider), or vendor.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Commitment Period' ;
    rdfs:comment 'Measurement period for evaluating volume commitment performance: daily, weekly, monthly, quarterly, annual, or over the entire contract term.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the volume commitment: active (in force), suspended (temporarily paused), expired (past validity period), fulfilled (target met), breached (obligation not met), or pending (awaiting activation).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Classification of the volume commitment: minimum volume guarantee (MVG), maximum volume cap, capacity allocation, shipment count commitment, weight-based commitment, TEU (Twenty-foot Equivalent Unit) commitment for ocean freight, or lane-specific allocation. [ENUM-REF-CANDIDATE: minimum_volume_guarantee|maximum_volume_cap|capacity_allocation|shipment_count|weight_based|teu_based|lane_specific — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessIncentiveCurrency rdf:type rdf:Property ;
    rdfs:label 'Excess Incentive Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the excess incentive amount.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessIncentiveRate rdf:type rdf:Property ;
    rdfs:label 'Excess Incentive Rate' ;
    rdfs:comment 'Incentive rate or rebate amount per unit of volume exceeding the target commitment. Rewards customers or carriers for exceeding volume targets.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMeasuredDate rdf:type rdf:Property ;
    rdfs:label 'Last Measured Date' ;
    rdfs:comment 'Date when the actual volume utilization was last calculated and updated for this commitment.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or name of the person who last modified this volume commitment record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumVolume rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume' ;
    rdfs:comment 'Maximum volume or capacity cap that can be utilized during the commitment period. Represents the ceiling limit.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolume rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume' ;
    rdfs:comment 'Minimum volume or capacity that must be utilized or booked during the commitment period to avoid penalties. Represents the floor obligation.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next review or reconciliation of this volume commitment against actual performance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rolloverAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Rollover Allowed Flag' ;
    rdfs:comment 'Indicates whether unused volume from one commitment period can be rolled over to the next period. True if rollover is permitted, False otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rolloverVolume rdf:type rdf:Property ;
    rdfs:label 'Rollover Volume' ;
    rdfs:comment 'Volume carried over from the previous commitment period, if rollover is allowed. Added to the current period\'s commitment.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Service string or route code identifying the specific service routing or network path covered by this commitment. Nullable if not route-specific.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortfallPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Shortfall Penalty Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the shortfall penalty amount.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortfallPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Shortfall Penalty Rate' ;
    rdfs:comment 'Penalty rate or amount per unit of volume shortfall if the minimum commitment is not met. May be a fixed amount or percentage of the shortfall value.' ;
    rdfs:domain ind:ContractVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetVolume rdf:type rdf:Property ;
    rdfs:label 'Target Volume' ;
    rdfs:comment 'Target or expected volume for the commitment period, often used as a benchmark for incentive calculations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of the target or minimum volume that has been utilized, calculated as (actual_volume / target_volume) * 100. Used for performance tracking and incentive calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveClauseId rdf:type rdf:Property ;
    rdfs:label 'Incentive Clause Id' ;
    rdfs:comment 'Unique identifier for the incentive clause within the contract management system. Primary key.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'The method by which the incentive is recognized and settled. Options include accrued (accumulated over time and paid later), paid immediately (applied at transaction time), deferred (held until contract end), credited to account (applied as credit memo).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Applies To Customer Segment' ;
    rdfs:comment 'The customer segment or classification to which this incentive clause applies (e.g., enterprise, SMB, e-commerce, 3PL). Pipe-separated list if multiple segments are eligible. Nullable if applies to all segments.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToLane rdf:type rdf:Property ;
    rdfs:label 'Applies To Lane' ;
    rdfs:comment 'The specific trade lanes or routes to which this incentive clause applies (e.g., USA-EUR, Asia-USA, domestic USA). Pipe-separated list if multiple lanes are eligible. Nullable if applies to all lanes.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToServiceType rdf:type rdf:Property ;
    rdfs:label 'Applies To Service Type' ;
    rdfs:comment 'The specific service types or product lines to which this incentive clause applies (e.g., express parcel, air freight, ocean freight, LTL, FTL, warehousing). Pipe-separated list if multiple service types are eligible. Nullable if applies to all services.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which this incentive clause was approved. Used for audit trail and governance. Nullable if approval is not required or not yet obtained.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capAmount rdf:type rdf:Property ;
    rdfs:label 'Cap Amount' ;
    rdfs:comment 'The maximum total incentive payout or discount amount that can be earned under this clause, regardless of performance. Used to limit financial exposure. Nullable if no cap applies.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capCurrency rdf:type rdf:Property ;
    rdfs:label 'Cap Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the cap amount (e.g., USD, EUR, GBP). Applicable when a monetary cap is defined.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseName rdf:type rdf:Property ;
    rdfs:label 'Clause Name' ;
    rdfs:comment 'Human-readable name or title of the incentive clause (e.g., Volume Rebate Tier 3, On-Time Delivery Bonus, Early Payment Discount).' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseNumber rdf:type rdf:Property ;
    rdfs:label 'Clause Number' ;
    rdfs:comment 'The business-assigned clause number or identifier within the contract document (e.g., Section 5.2, Clause IC-001). Used for legal and operational reference.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeFlag rdf:type rdf:Property ;
    rdfs:label 'Cumulative Flag' ;
    rdfs:comment 'Indicates whether the incentive is cumulative across measurement periods (true) or resets each period (false). For example, a cumulative volume rebate accumulates shipments across the entire contract term, while a non-cumulative rebate resets monthly.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveClauseStatus rdf:type rdf:Property ;
    rdfs:label 'Incentive Clause Status' ;
    rdfs:comment 'Current lifecycle status of the incentive clause. Indicates whether the clause is currently in effect, suspended, expired, or awaiting approval.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Classification of the incentive clause. Defines the nature of the incentive: volume rebate (based on shipment volume), performance bonus (exceeding OTD/OTIF targets), loyalty discount (long-term partnership rewards), early payment incentive (payment term discounts), OTD bonus (On-Time Delivery performance), OTIF bonus (On-Time In-Full performance).' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveValue rdf:type rdf:Property ;
    rdfs:label 'Incentive Value' ;
    rdfs:comment 'The numeric value of the incentive. Interpretation depends on calculation method: for percentage discount, this is the percentage (e.g., 5.00 for 5%); for flat bonus, this is the fixed amount; for tiered rebate, this may be the base rate.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Incentive Value Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for monetary incentive values (e.g., USD, EUR, GBP). Applicable when the incentive is a fixed amount or monetary rebate.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'The time period over which the trigger metric is measured and evaluated (e.g., calendar month, calendar quarter, calendar year, rolling 30 days, rolling 90 days, entire contract term, custom period). Defines the evaluation window for incentive eligibility. [ENUM-REF-CANDIDATE: calendar_month|calendar_quarter|calendar_year|rolling_30_days|rolling_90_days|contract_term|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'The frequency at which the incentive is paid out or applied. Defines the cadence of incentive settlement (e.g., monthly rebate, quarterly bonus, annual loyalty discount, per-shipment discount, upon achievement of milestone, at end of contract term).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retroactiveFlag rdf:type rdf:Property ;
    rdfs:label 'Retroactive Flag' ;
    rdfs:comment 'Indicates whether the incentive applies retroactively to all qualifying transactions once the threshold is met (true) or only to transactions after the threshold is achieved (false). Common in tiered rebate structures.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'The tier or band level for tiered incentive structures (e.g., Tier 1, Tier 2, Tier 3). Used when calculation method is tiered rebate or sliding scale. Nullable for non-tiered incentives.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierMaxValue rdf:type rdf:Property ;
    rdfs:label 'Tier Max Value' ;
    rdfs:comment 'The maximum threshold value for this tier level. Used in tiered rebate structures to define the upper bound of the tier (e.g., Tier 2 ends at 999 TEU). Nullable for open-ended top tiers or non-tiered incentives.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMinValue rdf:type rdf:Property ;
    rdfs:label 'Tier Min Value' ;
    rdfs:comment 'The minimum threshold value for this tier level. Used in tiered rebate structures to define the lower bound of the tier (e.g., Tier 2 starts at 500 TEU). Nullable for non-tiered incentives.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerMetric rdf:type rdf:Property ;
    rdfs:label 'Trigger Metric' ;
    rdfs:comment 'The performance metric or business measure that triggers the incentive (e.g., total shipment volume in TEU, OTD percentage, OTIF percentage, total revenue, payment days). Defines what is being measured to determine incentive eligibility.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerOperator rdf:type rdf:Property ;
    rdfs:label 'Trigger Operator' ;
    rdfs:comment 'The comparison operator used to evaluate whether the trigger threshold has been met (e.g., greater than, greater than or equal, less than, between). Defines the logic for incentive activation.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Unit' ;
    rdfs:comment 'The unit of measure for the trigger threshold value (e.g., TEU, percentage, days, USD, shipments, pallets). Provides context for interpreting the threshold value.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Value' ;
    rdfs:comment 'The numeric threshold value that must be met or exceeded to activate the incentive. For example, 1000 TEU for volume rebate, 95% for OTD target, 30 days for early payment.' ;
    rdfs:domain ind:IncentiveClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerId rdf:type rdf:Property ;
    rdfs:label 'Partner Id' ;
    rdfs:comment 'Foreign key linking to network.network_partner. Business justification: Lane commitments can be fulfilled by 3PL partners or agents in addition to direct carriers. Capacity planning and fulfillment teams require partner attribution to track which entity is responsible for' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:bookingLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Booking Lead Time Hours' ;
    rdfs:comment 'Minimum advance notice in hours required to book capacity on this lane.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityCommitmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Capacity Commitment Quantity' ;
    rdfs:comment 'Contracted capacity allocation for the lane per commitment period (e.g., weekly or monthly volume).' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the capacity commitment (TEU, FEU, kg, ton, CBM, pallet, truckload, flight). [ENUM-REF-CANDIDATE: TEU|FEU|kg|ton|cbm|pallet|truckload|flight — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Specific equipment or container type required for this lane (e.g., 20ft dry, 40ft reefer, flatbed, box truck).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Incentive Threshold Quantity' ;
    rdfs:comment 'Volume threshold that must be exceeded to trigger incentive payments or rebates.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumBookingQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Booking Quantity' ;
    rdfs:comment 'Maximum volume that can be booked per commitment period under this lane commitment.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBookingQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Booking Quantity' ;
    rdfs:comment 'Minimum volume that must be booked per commitment period to meet contractual obligations and avoid penalties.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePerUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Per Unit' ;
    rdfs:comment 'Contracted rate per capacity unit for this lane (e.g., cost per TEU, per kg, per truckload).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rolloverExpiryPeriods rdf:type rdf:Property ;
    rdfs:label 'Rollover Expiry Periods' ;
    rdfs:comment 'Number of commitment periods after which rolled-over capacity expires if not utilized.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rolloverLimitQuantity rdf:type rdf:Property ;
    rdfs:label 'Rollover Limit Quantity' ;
    rdfs:comment 'Maximum quantity of unused capacity that can be rolled over to the next period, if rollover is allowed.' ;
    rdfs:domain ind:LaneCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days' ;
    rdfs:comment 'Standard transit time in days for shipments on this lane from origin to destination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnershipAgreementId rdf:type rdf:Property ;
    rdfs:label 'Partnership Agreement Id' ;
    rdfs:comment 'Primary key for partnership_agreement' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractorSafetyPrequalId rdf:type rdf:Property ;
    rdfs:label 'Contractor Safety Prequal Id' ;
    rdfs:comment 'Foreign key linking to safety.contractor_safety_prequal. Business justification: 3PL partnership agreements require safety prequalification before contract execution. Links partnership to the prequalification record for onboarding compliance verification and ongoing safety perform' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractorSafetyPrequal .

ind:aeoCertified rdf:type rdf:Property ;
    rdfs:label 'Aeo Certified' ;
    rdfs:comment 'Indicates whether the partner holds valid AEO certification recognized by customs authorities for trusted trader status.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiIntegrationRequired rdf:type rdf:Property ;
    rdfs:label 'Api Integration Required' ;
    rdfs:comment 'Indicates whether real-time API integration is required for data exchange, tracking, and system interoperability.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Carbon Reporting Required' ;
    rdfs:comment 'Indicates whether the partner must provide regular reporting on carbon emissions and environmental impact of logistics operations under this agreement.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCertificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications Required' ;
    rdfs:comment 'Comma-separated list of required compliance certifications and authorizations: C-TPAT (Customs-Trade Partnership Against Terrorism), AEO (Authorized Economic Operator), ISO 9001, ISO 28000, IATA certification, customs broker license, or other regulatory credentials.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes confidentiality and non-disclosure provisions protecting proprietary business information, customer data, and operational details.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coveredCountries rdf:type rdf:Property ;
    rdfs:label 'Covered Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3-letter country codes where the partner is authorized to provide services under this agreement.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatCertified rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certified' ;
    rdfs:comment 'Indicates whether the partner holds valid C-TPAT certification for enhanced supply chain security and expedited customs processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataProtectionComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Data Protection Compliance Required' ;
    rdfs:comment 'Indicates whether the partner must comply with data protection regulations including General Data Protection Regulation (GDPR), California Consumer Privacy Act (CCPA), and other privacy laws for handling customer and shipment data.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediIntegrationRequired rdf:type rdf:Property ;
    rdfs:label 'Edi Integration Required' ;
    rdfs:comment 'Indicates whether Electronic Data Interchange connectivity is required for automated document exchange including Advanced Shipping Notices (ASN), invoices, and status updates.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationContactEmail rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Email' ;
    rdfs:comment 'Email address of the escalation contact for critical issues requiring senior management attention.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContactName rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Name' ;
    rdfs:comment 'Name of the escalation contact person at the partner organization for critical issues and executive-level communications.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of geographic regions, countries, or territories covered by this partnership agreement. May include specific trade lanes, ports, or distribution zones.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceModel rdf:type rdf:Property ;
    rdfs:label 'Governance Model' ;
    rdfs:comment 'Framework defining how the partnership is managed, including decision-making authority, escalation procedures, performance reviews, and relationship management structure.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Description of required insurance coverage including cargo insurance, liability insurance, workers compensation, and minimum coverage amounts that the partner must maintain.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalKpiCommitments rdf:type rdf:Property ;
    rdfs:label 'Operational Kpi Commitments' ;
    rdfs:comment 'Summary of key performance indicators and service level commitments including On-Time Delivery (OTD), On-Time In-Full (OTIF), order accuracy, damage rates, and other operational metrics.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Otd Target Percentage' ;
    rdfs:comment 'Target percentage for on-time delivery performance that the partner must achieve, typically 95-99%.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Otif Target Percentage' ;
    rdfs:comment 'Target percentage for on-time and in-full delivery performance combining timeliness and completeness metrics.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerSignatory rdf:type rdf:Property ;
    rdfs:label 'Partner Signatory' ;
    rdfs:comment 'Name and title of the authorized signatory from the partner organization who executed this partnership agreement.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipTier rdf:type rdf:Property ;
    rdfs:label 'Partnership Tier' ;
    rdfs:comment 'Classification of the partnership model: 3PL (Third-Party Logistics provider managing specific operations), 4PL (Fourth-Party Logistics provider managing entire supply chain), 2PL (asset-based carrier), Lead Logistics Provider, or Specialized Service Provider.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Performance Review Frequency' ;
    rdfs:comment 'Frequency at which formal performance reviews and business reviews are conducted to assess KPI achievement and partnership health.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact person for operational communications and escalations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the partner organization responsible for managing this partnership agreement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person for urgent communications and operational coordination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategories rdf:type rdf:Property ;
    rdfs:label 'Service Categories' ;
    rdfs:comment 'Comma-separated list of service categories provided: warehousing, distribution, last-mile delivery, customs brokerage, freight forwarding, cross-docking, value-added services, returns management, inventory management, order fulfillment.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Comprehensive description of the logistics services covered under this partnership, including warehouse operations, last-mile delivery, customs brokerage, freight forwarding, supply chain management, and other specialized services.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the partnership agreement was formally signed by authorized representatives of both parties.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityCommitments rdf:type rdf:Property ;
    rdfs:label 'Sustainability Commitments' ;
    rdfs:comment 'Description of environmental and sustainability commitments including Greenhouse Gas (GHG) emissions reduction targets, Carbon Dioxide Equivalent (CO2e) reporting, use of alternative fuels, and participation in carbon offset programs.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyIntegrationRequirements rdf:type rdf:Property ;
    rdfs:label 'Technology Integration Requirements' ;
    rdfs:comment 'Description of required technology integrations including Warehouse Management System (WMS), Transportation Management System (TMS), Electronic Data Interchange (EDI), Application Programming Interface (API) connections, and real-time visibility platforms.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationForCauseAllowed rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Allowed' ;
    rdfs:comment 'Indicates whether the agreement permits immediate termination for cause due to material breach, regulatory violations, or failure to meet critical SLA commitments.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tmsIntegrationRequired rdf:type rdf:Property ;
    rdfs:label 'Tms Integration Required' ;
    rdfs:comment 'Indicates whether integration with the partners Transportation Management System is required for shipment tracking and freight management.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitionSupportDays rdf:type rdf:Property ;
    rdfs:label 'Transition Support Days' ;
    rdfs:comment 'Number of days the partner must provide transition support and knowledge transfer upon agreement termination to ensure smooth handover to alternative providers.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wmsIntegrationRequired rdf:type rdf:Property ;
    rdfs:label 'Wms Integration Required' ;
    rdfs:comment 'Indicates whether integration with the partners Warehouse Management System is required for inventory visibility and order management.' ;
    rdfs:domain ind:PartnershipAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyClauseId rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Id' ;
    rdfs:comment 'Unique identifier for the penalty or incentive clause within a contract or agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PenaltyClause .

ind:appliesToParty rdf:type rdf:Property ;
    rdfs:label 'Applies To Party' ;
    rdfs:comment 'The party to whom this penalty or incentive clause applies (e.g., customer, carrier, vendor, 3PL, 4PL, customs broker).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether this penalty or incentive is automatically calculated and applied by the system, or requires manual review and application.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clauseCategory rdf:type rdf:Property ;
    rdfs:label 'Clause Category' ;
    rdfs:comment 'Specific category of the penalty or incentive clause (e.g., SLA breach penalty, volume shortfall penalty, late payment penalty, service failure deduction, volume rebate, performance bonus for exceeding OTD/OTIF targets, loyalty discount, early payment incentive).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseDescription rdf:type rdf:Property ;
    rdfs:label 'Clause Description' ;
    rdfs:comment 'Detailed textual description of the penalty or incentive clause, including business rationale, calculation examples, and any special conditions.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseStatus rdf:type rdf:Property ;
    rdfs:label 'Clause Status' ;
    rdfs:comment 'Current lifecycle status of the penalty or incentive clause within the contract.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseType rdf:type rdf:Property ;
    rdfs:label 'Clause Type' ;
    rdfs:comment 'Classification of the clause as a penalty (financial deduction for non-performance) or incentive/rebate (financial reward for exceeding targets).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Cure Period Days' ;
    rdfs:comment 'Number of days allowed to remedy the breach or non-performance before the penalty is applied. Null if no cure period is granted.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Allowed Flag' ;
    rdfs:comment 'Indicates whether the affected party is allowed to dispute the penalty or incentive calculation and trigger the escalation path.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationPath rdf:type rdf:Property ;
    rdfs:label 'Escalation Path' ;
    rdfs:comment 'Defined escalation or dispute resolution process if the penalty or incentive calculation is contested (e.g., escalate to account manager, arbitration, executive review).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentivePercentage rdf:type rdf:Property ;
    rdfs:label 'Incentive Percentage' ;
    rdfs:comment 'Percentage rate applied to calculate the incentive or rebate (e.g., 3.0 for 3.0% volume rebate). Null if calculation is fixed-fee based.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or name of the person who last modified this penalty or incentive clause record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReference rdf:type rdf:Property ;
    rdfs:label 'Legal Reference' ;
    rdfs:comment 'Reference to the specific section, article, or clause number in the legal contract document where this penalty or incentive is formally documented.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLiabilityCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Liability Cap' ;
    rdfs:comment 'Maximum cumulative penalty amount that can be assessed under this clause within a defined period (in contract currency). Protects against unlimited liability exposure.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumPayoutCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Payout Cap' ;
    rdfs:comment 'Maximum cumulative incentive or rebate amount that can be awarded under this clause within a defined period (in contract currency). Limits total incentive exposure.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'Time period over which performance is measured to determine if the clause is triggered (e.g., daily, weekly, monthly, quarterly, annually, per shipment, entire contract term). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|per_shipment|contract_term — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether the affected party must be notified in advance before a penalty is applied or an incentive is awarded.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Penalty Percentage' ;
    rdfs:comment 'Percentage rate applied to calculate the penalty or incentive (e.g., 2.5 for 2.5% of invoice value). Null if calculation is fixed-fee based.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for the threshold value (e.g., percentage, TEU, shipments, days, USD, hours).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCondition rdf:type rdf:Property ;
    rdfs:label 'Trigger Condition' ;
    rdfs:comment 'Detailed description of the condition or event that activates this penalty or incentive clause (e.g., OTD below 95%, volume below 1000 TEU per month, payment received after 60 days).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyEventId rdf:type rdf:Property ;
    rdfs:label 'Penalty Event Id' ;
    rdfs:comment 'Unique identifier for the penalty or incentive event. Primary key for the penalty event transaction.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Reference to the customer order associated with this penalty event, if applicable. Null for carrier or vendor penalties.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:baseAmount rdf:type rdf:Property ;
    rdfs:label 'Base Amount' ;
    rdfs:comment 'The base monetary value used in the penalty or incentive calculation (e.g., shipment value, contract value, invoice amount).' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Amount' ;
    rdfs:comment 'The computed penalty or incentive amount before any adjustments, caps, or approvals.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'The date on which the penalty or incentive event was detected and recorded in the system.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The date on which the triggering event occurred (e.g., the date of SLA breach, the end of the measurement period for volume shortfall).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Human-readable business identifier for the penalty event, used for tracking and reference in communications and billing documents.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External reference number or identifier from the source system or partner system for cross-system reconciliation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalAmount rdf:type rdf:Property ;
    rdfs:label 'Final Amount' ;
    rdfs:comment 'The final approved penalty or incentive amount to be applied to billing, after all adjustments and approvals.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyEventStatus rdf:type rdf:Property ;
    rdfs:label 'Penalty Event Status' ;
    rdfs:comment 'Current lifecycle status of the penalty event in the approval and settlement workflow.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyRate rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate' ;
    rdfs:comment 'The rate or percentage applied to calculate the penalty or incentive amount (e.g., 5% of shipment value, $50 per day).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaMetricCode rdf:type rdf:Property ;
    rdfs:label 'Sla Metric Code' ;
    rdfs:comment 'Code identifying the specific SLA metric that was breached or exceeded (e.g., OTD, OTIF, transit time, damage rate). Null if event is not SLA-related.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCategory rdf:type rdf:Property ;
    rdfs:label 'Trigger Category' ;
    rdfs:comment 'High-level category of the triggering event that caused the penalty or incentive to be applied.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerDescription rdf:type rdf:Property ;
    rdfs:label 'Trigger Description' ;
    rdfs:comment 'Detailed narrative description of the specific event or condition that triggered the penalty or incentive, including relevant context and supporting details.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivedBy rdf:type rdf:Property ;
    rdfs:label 'Waived By' ;
    rdfs:comment 'Name or identifier of the person who authorized the waiver of this penalty event.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Date' ;
    rdfs:comment 'Date on which the penalty was waived.' ;
    rdfs:domain ind:PenaltyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Id' ;
    rdfs:comment 'Unique identifier for the rate schedule. Primary key for this entity.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'The fundamental rate amount per unit as defined by the rate basis. This is the core charge before any surcharges, discounts, or adjustments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationZone rdf:type rdf:Property ;
    rdfs:label 'Destination Zone' ;
    rdfs:comment 'Geographic zone or region code for the destination, used in zone-based pricing structures. May represent postal zones, service areas, or custom-defined geographic segments.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceBreakMax rdf:type rdf:Property ;
    rdfs:label 'Distance Break Max' ;
    rdfs:comment 'Maximum distance threshold for this rate tier in distance-based pricing structures. Defines the upper bound of the distance bracket.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceBreakMin rdf:type rdf:Property ;
    rdfs:label 'Distance Break Min' ;
    rdfs:comment 'Minimum distance threshold for this rate tier in distance-based pricing structures. Rates may vary based on distance brackets.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceUom rdf:type rdf:Property ;
    rdfs:label 'Distance Uom' ;
    rdfs:comment 'Unit of measure for distance-based rate calculations. Common units include kilometers (km), miles (mi), or nautical miles (nmi).' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Rate' ;
    rdfs:comment 'Fuel surcharge rate as a percentage or fixed amount applied to the base rate. Commonly known as Bunker Adjustment Factor (BAF) for ocean freight.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originZone rdf:type rdf:Property ;
    rdfs:label 'Origin Zone' ;
    rdfs:comment 'Geographic zone or region code for the origin, used in zone-based pricing structures. May represent postal zones, service areas, or custom-defined geographic segments.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakSeasonSurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Peak Season Surcharge Applicable' ;
    rdfs:comment 'Indicates whether a peak season surcharge is applicable during high-demand periods (e.g., holiday seasons, Chinese New Year).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakSeasonSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Peak Season Surcharge Rate' ;
    rdfs:comment 'Peak season surcharge rate as a percentage or fixed amount applied during designated peak periods.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'Unit of measure on which the rate is calculated. Common bases include per kilogram, per pound, per Twenty-foot Equivalent Unit (TEU), per Forty-foot Equivalent Unit (FEU), per Cubic Meter (CBM), per shipment, per pallet, per mile, or per kilometer. [ENUM-REF-CANDIDATE: per_kg|per_lb|per_teu|per_feu|per_cbm|per_shipment|per_pallet|per_mile|per_km — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValidityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Rate Validity Period Days' ;
    rdfs:comment 'Number of days for which this rate schedule remains valid from the effective start date. Used for time-bound promotional rates or short-term agreements.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Business identifier for the rate schedule, typically a human-readable code or number used in contract documentation and operational references.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the rate schedule. Indicates whether the schedule is in draft, active and applicable, temporarily suspended, expired past its end date, or terminated early.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the rate schedule structure, indicating the basis for rate calculation such as lane-level, zone-level, weight-based, volume-based, distance-based, or flat rate.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitySurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Security Surcharge Applicable' ;
    rdfs:comment 'Indicates whether a security surcharge is applicable to this rate schedule, often required for air freight and high-security shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securitySurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Security Surcharge Rate' ;
    rdfs:comment 'Security surcharge rate as a percentage or fixed amount applied to the base rate.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeBreakMax rdf:type rdf:Property ;
    rdfs:label 'Volume Break Max' ;
    rdfs:comment 'Maximum volume threshold for this rate tier in volume-based pricing structures. Defines the upper bound of the volume bracket.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeBreakMin rdf:type rdf:Property ;
    rdfs:label 'Volume Break Min' ;
    rdfs:comment 'Minimum volume threshold for this rate tier in volume-based pricing structures. Rates may vary based on volume brackets.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure for volume-based rate calculations. Common units include Cubic Meters (CBM), cubic feet (CFT), m3, or ft3.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightBreakMax rdf:type rdf:Property ;
    rdfs:label 'Weight Break Max' ;
    rdfs:comment 'Maximum weight threshold for this rate tier in weight-based pricing structures. Defines the upper bound of the weight bracket.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMin rdf:type rdf:Property ;
    rdfs:label 'Weight Break Min' ;
    rdfs:comment 'Minimum weight threshold for this rate tier in weight-based pricing structures. Rates may vary based on weight brackets.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUom rdf:type rdf:Property ;
    rdfs:label 'Weight Uom' ;
    rdfs:comment 'Unit of measure for weight-based rate calculations. Common units include kilograms (kg), pounds (lb), short tons, or metric tonnes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalEventId rdf:type rdf:Property ;
    rdfs:label 'Renewal Event Id' ;
    rdfs:comment 'Unique identifier for the contract renewal or termination event. Primary key.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRenewalAgreementId rdf:type rdf:Property ;
    rdfs:label 'Primary Renewal Agreement Id' ;
    rdfs:comment 'Reference to the parent contract or agreement that is being renewed or terminated.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:competitiveBidConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Bid Conducted Flag' ;
    rdfs:comment 'Boolean flag indicating whether a competitive bidding process was conducted before the renewal decision.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractValueChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Value Change Amount' ;
    rdfs:comment 'The change in total contract value as a result of the renewal or renegotiation, expressed in the contract currency.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Representative Name' ;
    rdfs:comment 'The name of the representative from the counterparty organization (customer, carrier, Third-Party Logistics (3PL), Fourth-Party Logistics (4PL), or vendor) involved in the renewal negotiation.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyRepresentativeRole rdf:type rdf:Property ;
    rdfs:label 'Counterparty Representative Role' ;
    rdfs:comment 'The job title or role of the counterparty representative involved in the renewal negotiation.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakerName rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Name' ;
    rdfs:comment 'The name of the individual who authorized the renewal or termination decision on behalf of the organization.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakerRole rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Role' ;
    rdfs:comment 'The job title or role of the individual who authorized the renewal or termination decision.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Incoterms Change Flag' ;
    rdfs:comment 'Boolean flag indicating whether International Commercial Terms (Incoterms) such as Delivered Duty Paid (DDP), Delivered at Place (DAP), Free on Board (FOB), Cost Insurance and Freight (CIF), or Ex Works (EXW) were modified during the renewal.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiatedChangesSummary rdf:type rdf:Property ;
    rdfs:label 'Negotiated Changes Summary' ;
    rdfs:comment 'Summary of key changes negotiated during the renewal process, including rate adjustments, Service Level Agreement (SLA) modifications, volume commitments, and other material terms.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Otd Compliance Percentage' ;
    rdfs:comment 'The On-Time Delivery (OTD) compliance percentage achieved under the prior contract term, used to evaluate performance for renewal decisions.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Otif Compliance Percentage' ;
    rdfs:comment 'The On-Time In-Full (OTIF) compliance percentage achieved under the prior contract term, used to evaluate performance for renewal decisions.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Change Flag' ;
    rdfs:comment 'Boolean flag indicating whether penalty or incentive clauses were modified during the renewal or renegotiation.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorContractPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Prior Contract Performance Rating' ;
    rdfs:comment 'The overall performance rating of the counterparty under the prior contract term, used as input to the renewal decision.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Change Percentage' ;
    rdfs:comment 'The percentage change in contract rates as a result of the renewal or renegotiation. Positive values indicate rate increases, negative values indicate rate decreases.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Approval Date' ;
    rdfs:comment 'The date on which the renewal decision received final internal approval.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Approval Status' ;
    rdfs:comment 'The approval status of the renewal event within the internal approval workflow.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApproverName rdf:type rdf:Property ;
    rdfs:label 'Renewal Approver Name' ;
    rdfs:comment 'The name of the individual who provided final approval for the renewal or termination decision.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Decision Date' ;
    rdfs:comment 'The date on which the renewal or termination decision was made by the authorized party.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Renewal Decision Timestamp' ;
    rdfs:comment 'The precise timestamp when the renewal or termination decision was recorded in the system.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:renewalEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Effective Date' ;
    rdfs:comment 'The date on which the renewed or renegotiated contract terms become effective. Null if terminated.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Expiry Date' ;
    rdfs:comment 'The new expiration date of the renewed or renegotiated contract. Null if terminated.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNotes rdf:type rdf:Property ;
    rdfs:label 'Renewal Notes' ;
    rdfs:comment 'Additional free-text notes and comments regarding the renewal event, capturing context, special circumstances, or follow-up actions required.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'The number of days advance notice provided for the renewal or termination, as specified in the original contract terms.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Date' ;
    rdfs:comment 'The date on which the renewal or termination notification was sent to the counterparty, as required by contract terms.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalOutcome rdf:type rdf:Property ;
    rdfs:label 'Renewal Outcome' ;
    rdfs:comment 'The outcome of the renewal event indicating whether the contract was renewed, renegotiated, terminated, expired, cancelled, or extended.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'The duration of the renewed contract term expressed in months. Null if terminated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Classification of the renewal event based on timing and circumstances (standard renewal at contract end, early renewal, late renewal, emergency renewal, or conditional renewal).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Change Flag' ;
    rdfs:comment 'Boolean flag indicating whether Service Level Agreement (SLA) terms were modified during the renewal or renegotiation.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for contract termination if applicable. Null if the contract was renewed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the reason for termination, providing context beyond the standardized code.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Change Flag' ;
    rdfs:comment 'Boolean flag indicating whether volume commitment terms were modified during the renewal or renegotiation.' ;
    rdfs:domain ind:RenewalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalScheduleId rdf:type rdf:Property ;
    rdfs:label 'Renewal Schedule Id' ;
    rdfs:comment 'Unique identifier for the renewal schedule record. Primary key for the renewal schedule entity.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousRenewalScheduleId rdf:type rdf:Property ;
    rdfs:label 'Previous Renewal Schedule Id' ;
    rdfs:comment 'Reference to the prior renewal schedule record for this agreement, creating a historical chain of renewal events. Null for the first renewal schedule.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RenewalSchedule .

ind:primaryRenewalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Renewal Employee Id' ;
    rdfs:comment 'Reference to the account manager or contract owner responsible for managing the renewal process, conducting reviews, and making recommendations.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRenewalLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Renewal Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the system user who last modified this renewal schedule record. Used for change accountability and audit trail.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRenewalCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Renewal Created By User Employee Id' ;
    rdfs:comment 'Reference to the system user who created this renewal schedule record. Used for accountability and audit trail.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the contract is configured for automatic renewal. True means the contract will renew automatically unless notice of termination is provided within the notice period.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Current Term End Date' ;
    rdfs:comment 'End date of the current contract term. The renewal decision must be executed before this date to ensure continuity or proper termination.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentTermStartDate rdf:type rdf:Property ;
    rdfs:label 'Current Term Start Date' ;
    rdfs:comment 'Start date of the current contract term that this renewal schedule applies to. Used to calculate term duration and renewal timing.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Date' ;
    rdfs:comment 'Date when the customer provided their response to the renewal notification. Null if no response received.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingAdjustmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Pricing Adjustment Percentage' ;
    rdfs:comment 'Percentage change in pricing for the renewed term compared to the current term. Positive values indicate price increase, negative values indicate discount. Used for revenue forecasting and margin analysis.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedRenewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Proposed Renewal Term Months' ;
    rdfs:comment 'Duration in months for the proposed renewal term. May differ from the original term length based on renegotiation or standard renewal practices.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Approval Required' ;
    rdfs:comment 'Indicates whether the renewal requires executive or management approval based on contract value, strategic importance, or policy requirements.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDecisionDeadline rdf:type rdf:Property ;
    rdfs:label 'Renewal Decision Deadline' ;
    rdfs:comment 'Final date by which a renewal decision must be made and communicated to avoid default action (auto-renewal or lapse). Critical milestone for contract management.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Method' ;
    rdfs:comment 'Communication channel used to deliver the renewal notification. Important for audit trail and compliance verification.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Sent Date' ;
    rdfs:comment 'Date when formal renewal notification was sent to the customer or counterparty. Critical for compliance with contractual notice requirements.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalPriority rdf:type rdf:Property ;
    rdfs:label 'Renewal Priority' ;
    rdfs:comment 'Business priority level assigned to this renewal based on strategic importance, revenue impact, or customer relationship value. Used for resource allocation and attention management.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalReviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Review Start Date' ;
    rdfs:comment 'Date when the renewal review process should begin. Calculated based on notice period and internal review requirements to ensure timely decision-making.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current lifecycle status of the renewal schedule. Pending indicates awaiting review, under_review means active evaluation, approved means decision made to renew, renewed indicates successful renewal completion, renegotiated means terms were modified, terminated means contract ended by mutual agreement, expired means contract ended by time, lapsed means renewal deadline passed without action, cancelled means renewal was withdrawn. [ENUM-REF-CANDIDATE: pending|under_review|approved|renewed|renegotiated|terminated|expired|lapsed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTriggerCondition rdf:type rdf:Property ;
    rdfs:label 'Renewal Trigger Condition' ;
    rdfs:comment 'Business condition or performance threshold that triggers renewal evaluation for conditional renewal types. Examples include volume commitments met, SLA compliance achieved, or mutual satisfaction criteria.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Quantitative risk score (0-10 scale) assessing the likelihood of non-renewal or difficult renegotiation. Based on customer satisfaction, payment history, service performance, and market conditions.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Modification Flag' ;
    rdfs:comment 'Indicates whether SLA terms were modified during the renewal process. True means SLA thresholds, penalties, or incentives were changed.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeCommitmentChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Change Percentage' ;
    rdfs:comment 'Percentage change in volume commitments for the renewed term. Positive indicates increased commitment, negative indicates reduced commitment. Critical for capacity planning and revenue forecasting.' ;
    rdfs:domain ind:RenewalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityRateClassId rdf:type rdf:Property ;
    rdfs:label 'Commodity Rate Class Id' ;
    rdfs:comment 'Foreign key linking to pricing.commodity_rate_class. Business justification: Contract pricing teams reference standard commodity classifications when defining service scope restrictions for hazmat handling, special equipment requirements, and rate class validation in multi-com' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityRateClass .

ind:dimWeightRuleId rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Rule Id' ;
    rdfs:comment 'Foreign key linking to pricing.dim_weight_rule. Business justification: Contract operations teams specify which dimensional weight rules apply to each service scope within multi-service agreements to ensure consistent chargeable weight calculations across different servic' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DimWeightRule .

ind:codAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Allowed Flag' ;
    rdfs:comment 'Indicates whether cash on delivery (COD) payment collection is allowed under this service scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceProgram rdf:type rdf:Property ;
    rdfs:label 'Compliance Program' ;
    rdfs:comment 'Applicable compliance or certification program for this service scope (e.g., C-TPAT, AEO, ISO 28000, TAPA).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Container load type for ocean freight services: Full Container Load (FCL), Less than Container Load (LCL), or not applicable for non-containerized services.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Included Flag' ;
    rdfs:comment 'Indicates whether customs brokerage and clearance services are included in this service scope.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dimensionLimitCbm rdf:type rdf:Property ;
    rdfs:label 'Dimension Limit Cbm' ;
    rdfs:comment 'Maximum dimensional limit per shipment or unit under this service scope, measured in cubic meters (CBM).' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epodRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Epod Required Flag' ;
    rdfs:comment 'Indicates whether electronic proof of delivery (ePOD) is required for this service scope.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightType rdf:type rdf:Property ;
    rdfs:label 'Freight Type' ;
    rdfs:comment 'Freight load type for road/rail services: Full Truckload (FTL), Less than Truckload (LTL), or not applicable for non-trucking services.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Included Flag' ;
    rdfs:comment 'Indicates whether cargo insurance is included in this service scope.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Packaging Included Flag' ;
    rdfs:comment 'Indicates whether packaging, crating, or palletization services are included in this service scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceExclusions rdf:type rdf:Property ;
    rdfs:label 'Service Exclusions' ;
    rdfs:comment 'Specific exclusions, restrictions, or limitations applicable to this service scope (e.g., prohibited commodities, excluded geographies, restricted handling).' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Human-readable name of the logistics service included in the contract scope (e.g., Express Parcel Delivery, Air Freight Forwarding, Ocean Full Container Load).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScopeStatus rdf:type rdf:Property ;
    rdfs:label 'Service Scope Status' ;
    rdfs:comment 'Current lifecycle status of this service scope (active, inactive, suspended, pending, expired).' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Service level tier indicating speed, priority, and handling quality (premium, standard, economy, basic).' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Handling Requirements' ;
    rdfs:comment 'Any special handling, packaging, or operational requirements specific to this service scope.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this service scope includes temperature-controlled or refrigerated (reefer) handling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingVisibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Tracking Visibility Level' ;
    rdfs:comment 'Level of shipment tracking and visibility provided under this service scope (real-time, milestone, basic, none).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLane rdf:type rdf:Property ;
    rdfs:label 'Trade Lane' ;
    rdfs:comment 'Specific trade lane or corridor covered by this service (e.g., Asia-Europe, Transpacific, Transatlantic).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehousingIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Warehousing Included Flag' ;
    rdfs:comment 'Indicates whether warehousing, storage, or distribution services are included in this service scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightLimitKg rdf:type rdf:Property ;
    rdfs:label 'Weight Limit Kg' ;
    rdfs:comment 'Maximum weight limit per shipment or unit under this service scope, measured in kilograms.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Sla Performance Id' ;
    rdfs:comment 'Unique identifier for the SLA performance measurement record.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLaneId rdf:type rdf:Property ;
    rdfs:label 'Service Lane Id' ;
    rdfs:comment 'Reference to the specific service lane or route for which this SLA performance is measured (e.g., USA-EUR air express, Asia-USA ocean FCL).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual value achieved during this measurement period (e.g., 92.5 for 92.5% OTD achieved, 9500 for 9,500 TEU delivered).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attainmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Attainment Percentage' ;
    rdfs:comment 'The percentage of target achieved, calculated as (actual_value / target_value) * 100. Values above 100 indicate over-achievement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Indicates whether the SLA was breached (True) or met (False) during this measurement period. True if actual performance fell below the committed threshold.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'The severity level of the SLA breach, if any. none = no breach, minor = slight miss, moderate = noticeable shortfall, major = significant breach, critical = severe breach triggering penalties.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliantShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Compliant Shipment Count' ;
    rdfs:comment 'The number of shipments that met the SLA criteria during this measurement period. Used as the numerator for percentage-based SLA calculations.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Applicable Flag' ;
    rdfs:comment 'Indicates whether a contractual incentive or bonus is applicable for exceeding the SLA target (True) or not (False).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementCategory rdf:type rdf:Property ;
    rdfs:label 'Measurement Category' ;
    rdfs:comment 'High-level category of the measurement: service_level (OTD, OTIF, transit time), volume_attainment (TEU, kg, CBM, shipment count), quality (damage rate, accuracy), compliance (regulatory adherence).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Description of the methodology or calculation logic used to measure this SLA performance (e.g., \'OTD calculated as shipments delivered within committed window / total shipments\', \'OTIF calculated as shipments delivered on-time and in-full / total shipments\').' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The end date of the measurement period for this SLA performance record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The start date of the measurement period for this SLA performance record (e.g., beginning of month, quarter, or custom period).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement Source System' ;
    rdfs:comment 'The system or platform used to capture and calculate this SLA performance measurement (e.g., SAP TM, Oracle TMS, FourKites, internal BI platform).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'The current status of this SLA performance measurement record in its lifecycle (e.g., draft, finalized, under_review, disputed, approved, archived).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'The type of SLA or commitment being measured. OTD = On-Time Delivery, OTIF = On-Time In-Full, transit_time = delivery speed commitment, volume_commitment = shipment count target, weight_commitment = weight volume target, teu_commitment = TEU volume target.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonCompliantShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Non Compliant Shipment Count' ;
    rdfs:comment 'The number of shipments that failed to meet the SLA criteria during this measurement period.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable Flag' ;
    rdfs:comment 'Indicates whether a contractual penalty is applicable for this SLA breach (True) or not (False). Penalties are typically triggered when performance falls below a defined threshold.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentCountInScope rdf:type rdf:Property ;
    rdfs:label 'Shipment Count In Scope' ;
    rdfs:comment 'The total number of shipments included in this SLA performance measurement period. Used as the denominator for percentage-based SLA calculations.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variance rdf:type rdf:Property ;
    rdfs:label 'Variance' ;
    rdfs:comment 'The difference between actual and target values (actual_value - target_value). Negative values indicate shortfall; positive values indicate over-achievement.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeActualsId rdf:type rdf:Property ;
    rdfs:label 'Volume Actuals Id' ;
    rdfs:comment 'Unique identifier for the volume actuals record. Primary key for tracking actual shipped volumes against contracted commitments.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualVolumeShipped rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Shipped' ;
    rdfs:comment 'The actual volume shipped during the measurement period, expressed in the unit of measure specified in volume_unit. This is the primary metric for contract compliance and penalty/incentive calculations.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Free-text explanation for any manual adjustments made to actual or committed volumes. Null if no adjustments were applied. Supports audit and dispute resolution.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The date and time when the volume actuals were calculated and this record was generated. Supports audit trail and data lineage tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:committedVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Volume' ;
    rdfs:comment 'The contracted volume commitment for this measurement period, expressed in the same unit of measure as actual volume. Represents the baseline for attainment calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'The compliance status of this volume actuals record relative to contract terms. Compliant indicates attainment meets or exceeds thresholds, non-compliant triggers penalties, at-risk indicates approaching threshold, grace-period allows temporary shortfall, waived indicates contractual exception.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'The source system or module from which the actual volume data was extracted (e.g., SAP TM, Oracle TMS, Manhattan WMS). Supports data lineage and reconciliation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Triggered Flag' ;
    rdfs:comment 'Indicates whether this volume surplus has triggered a contractual incentive or rebate clause. True if incentive conditions are met, False otherwise.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Triggered Flag' ;
    rdfs:comment 'Indicates whether this volume shortfall has triggered a contractual penalty clause. True if penalty conditions are met, False otherwise.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'The type of measurement period used for volume tracking. Aligns with contract terms and billing cycles.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'The current status of this volume actuals record in its lifecycle. Draft indicates preliminary calculation, final indicates approved and locked, revised indicates correction applied, voided indicates record is no longer valid.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortfallFlag rdf:type rdf:Property ;
    rdfs:label 'Shortfall Flag' ;
    rdfs:comment 'Indicates whether the actual volume shipped fell short of the committed volume for this period. True if actual < committed, False otherwise.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surplusFlag rdf:type rdf:Property ;
    rdfs:label 'Surplus Flag' ;
    rdfs:comment 'Indicates whether the actual volume shipped exceeded the committed volume for this period. True if actual > committed, False otherwise.' ;
    rdfs:domain ind:VolumeActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeVariance rdf:type rdf:Property ;
    rdfs:label 'Volume Variance' ;
    rdfs:comment 'The difference between actual volume shipped and committed volume (actual minus committed). Positive values indicate surplus, negative values indicate shortfall.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each account hierarchy relationship record in the Transport Shipping customer domain. Primary key for the account_hierarchy data product.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Customer Account Id' ;
    rdfs:comment 'Identifier of the child (subsidiary, affiliate, or regional) account in the hierarchy. References the subordinate account linked to the parent for group-level management and revenue roll-up.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:primaryCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Account Id' ;
    rdfs:comment 'Identifier of the parent account in the hierarchy. References the account that sits one level above the child account, enabling enterprise roll-up for consolidated billing and group SLA management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:accountSegment rdf:type rdf:Property ;
    rdfs:label 'Account Segment' ;
    rdfs:comment 'Business segmentation classification of the account hierarchy, reflecting the commercial tier of the enterprise group. Drives account management strategy, service prioritization, and sales coverage in Salesforce CRM.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoStatus rdf:type rdf:Property ;
    rdfs:label 'Aeo Status' ;
    rdfs:comment 'Authorized Economic Operator (AEO) certification status of the enterprise account group. AEO-certified accounts receive expedited customs clearance and reduced inspection rates. Managed in Descartes Customs global trade management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualContractedRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Contracted Revenue' ;
    rdfs:comment 'Total annual contracted revenue committed by the enterprise account group under the master agreement. Used for group-level P&L reporting, EBITDA analysis, and account tier classification in SAP S/4HANA Finance.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:childAccountCount rdf:type rdf:Property ;
    rdfs:label 'Child Account Count' ;
    rdfs:comment 'Number of direct child accounts linked to the parent account at this hierarchy level. Provides a structural summary for account management and hierarchy governance without requiring recursive queries.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether the child account\'s shipment charges and invoices are consolidated into the parent account\'s billing statement. When true, enables group-level invoice generation and payment management in SAP S/4HANA Finance.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfDomicile rdf:type rdf:Property ;
    rdfs:label 'Country Of Domicile' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the parent account\'s legal domicile. Determines applicable trade compliance regulations, customs requirements, and tax jurisdiction for the enterprise group.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditConsolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Consolidation Flag' ;
    rdfs:comment 'Indicates whether the child account\'s credit exposure is pooled with the parent account for group-level credit limit management. When true, credit checks in SAP S/4HANA Finance are evaluated at the parent account level.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmAccountHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Hierarchy Code' ;
    rdfs:comment 'Salesforce CRM system identifier for the account hierarchy record. Enables cross-system traceability between the lakehouse silver layer and the Salesforce CRM source of record for account management and opportunity tracking.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatStatus rdf:type rdf:Property ;
    rdfs:label 'Ctpat Status' ;
    rdfs:comment 'C-TPAT certification status of the enterprise account group for US customs security compliance. Certified accounts benefit from reduced CBP examinations and expedited border processing. Managed in Descartes Customs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyRegion rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Region' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country or region code indicating the primary data privacy jurisdiction applicable to the account hierarchy record. Determines GDPR, CCPA, or other regional data protection obligations for customer data handling.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyCheckDate rdf:type rdf:Property ;
    rdfs:label 'Denied Party Check Date' ;
    rdfs:comment 'Date on which the most recent denied party and sanctions screening was performed for the enterprise account group. Ensures compliance screening currency per regulatory requirements.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deniedPartyCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Denied Party Check Status' ;
    rdfs:comment 'Result of the most recent denied party and sanctions screening check for the enterprise account group. Managed in Descartes Customs denied party screening module. Flagged accounts require compliance review before shipment execution.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which the account hierarchy relationship becomes binding and operationally active. Used to manage time-bound corporate restructuring, mergers, and acquisitions in the customer master.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date on which the account hierarchy relationship ceases to be binding. Nullable for open-ended relationships. Populated upon corporate restructuring, divestiture, or account termination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpCustomerHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Erp Customer Hierarchy Code' ;
    rdfs:comment 'SAP S/4HANA Finance customer hierarchy node identifier for the account group. Enables reconciliation between CRM account structures and ERP financial hierarchies for consolidated billing and revenue recognition.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalAccountManager rdf:type rdf:Property ;
    rdfs:label 'Global Account Manager' ;
    rdfs:comment 'Name of the Transport Shipping global account manager responsible for the enterprise account hierarchy. Sourced from Salesforce CRM account ownership for escalation routing and relationship management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known business identifier for the account hierarchy relationship, used in Salesforce CRM and SAP S/4HANA Finance for cross-system reference and consolidated billing linkage.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of the child account within the corporate hierarchy tree, where level 1 represents the ultimate parent (global account). Enables multi-tier enterprise account navigation and reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Human-readable label for the account hierarchy relationship, typically reflecting the corporate group name (e.g., \'Acme Corp Global Group\'). Used in CRM dashboards and enterprise account reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain from root to child account (e.g., \'/1001/2045/3087\'). Enables efficient tree traversal queries for enterprise account reporting and consolidated billing without recursive joins.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of the account hierarchy relationship. Controls whether the parent-child linkage is operationally active for billing consolidation, SLA management, and enterprise reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classifies the purpose of the hierarchy structure. Corporate hierarchies reflect legal ownership; billing hierarchies drive consolidated invoicing; operational hierarchies manage service delivery; 3PL/4PL hierarchies manage logistics partner structures.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The primary industry sector of the enterprise account group (e.g., Retail, Automotive, Pharmaceutical, Technology, Energy). Used for vertical-specific SLA configuration, compliance requirements, and targeted service offerings in Salesforce CRM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxHierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Max Hierarchy Depth' ;
    rdfs:comment 'Maximum number of levels in the account hierarchy subtree rooted at this relationship node. Used for hierarchy validation, UI rendering optimization, and enterprise account structure governance.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership or equity stake held by the parent account in the child account. Relevant for subsidiary and joint venture relationships. Used for IFRS 10 consolidation threshold determination and financial reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Standard payment terms code applicable to the enterprise account group (e.g., NET30, NET60, COD). Inherited by child accounts when consolidation is active. Sourced from SAP S/4HANA Finance accounts receivable configuration.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Pricing Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child account inherits the contracted pricing, rate agreements, and GRI exemptions negotiated at the parent account level. Drives tariff application in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classifies the nature of the parent-child relationship within the account hierarchy. Drives how billing consolidation, SLA inheritance, and revenue roll-up are applied. [ENUM-REF-CANDIDATE: parent|subsidiary|affiliate|regional_division|branch|joint_venture — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restructureReason rdf:type rdf:Property ;
    rdfs:label 'Restructure Reason' ;
    rdfs:comment 'Business reason for the creation or modification of the account hierarchy relationship. Supports audit trail and change management for corporate restructuring events. [ENUM-REF-CANDIDATE: merger|acquisition|divestiture|reorganization|new_subsidiary|account_migration|other — promote to reference product if additional reasons are needed]' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annual contracted revenue amount. Ensures consistent multi-currency financial reporting across global enterprise accounts.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRollUpFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Roll Up Flag' ;
    rdfs:comment 'Indicates whether the child account\'s revenue is rolled up to the parent account for enterprise-level P&L reporting and EBITDA analysis. Enables group revenue visibility in SAP S/4HANA Finance and CRM dashboards.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child account inherits the SLA entitlements (e.g., OTD targets, OTIF commitments, priority service levels) from the parent account. Drives SLA enforcement and KPI reporting at the group level.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:votingRightsPercentage rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Percentage' ;
    rdfs:comment 'Percentage of voting rights held by the parent account in the child entity. Determines control classification under IFRS 10 (control threshold typically >50%) for financial consolidation and regulatory reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addressBookId rdf:type rdf:Property ;
    rdfs:label 'Address Book Id' ;
    rdfs:comment 'Unique surrogate identifier for each address record in the centralized address book. Primary key for the address_book data product.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkNodeId rdf:type rdf:Property ;
    rdfs:label 'Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Customer addresses map to network nodes for routing and planning. Powers address-to-node geocoding, route optimization, network design, and facility assignment. Essential for translating customer loca' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:addressCode rdf:type rdf:Property ;
    rdfs:label 'Address Code' ;
    rdfs:comment 'Externally-known unique business identifier or short code assigned to this address record, used in shipment booking, EDI transactions, and TMS integrations (e.g., SAP TM location code, Oracle TMS address code). Enables cross-system address referencing.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLabel rdf:type rdf:Property ;
    rdfs:label 'Address Label' ;
    rdfs:comment 'Human-readable display name or alias for this address record (e.g., \'London Heathrow Warehouse\', \'NYC HQ Billing\', \'Shanghai Port CFS\'). Used in shipment booking UIs, ePOD systems, and customer-facing communications to identify addresses without displaying full address details.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line including building number, street name, and any suite or unit designation. This is the first and most critical line of the physical address used on shipping labels, AWBs, BOLs, and customs declarations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as floor number, building name, industrial estate, or complex name. Optional field used when the primary address line is insufficient to uniquely identify the delivery location.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine3 rdf:type rdf:Property ;
    rdfs:label 'Address Line 3' ;
    rdfs:comment 'Tertiary address line for additional location context such as district, neighborhood, or landmark reference. Commonly used in international addresses where additional geographic context is required for customs or last-mile delivery.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressRole rdf:type rdf:Property ;
    rdfs:label 'Address Role' ;
    rdfs:comment 'Functional role this address plays in logistics operations. An address may be classified as an origin pickup location, delivery destination, billing address, return address, warehouse address, or notify party address. A single physical address may have multiple roles across different shipments. [ENUM-REF-CANDIDATE: origin|destination|billing|return|warehouse|notify_party — promote to reference product]' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle state of the address record. Active addresses are available for shipment booking. Pending_validation addresses are awaiting address verification. Deprecated addresses are retained for historical reference but not available for new bookings. Blacklisted addresses are blocked due to compliance or fraud concerns.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the physical address by its operational nature. Drives last-mile delivery rules, customs declaration requirements, and carrier surcharge logic. Residential addresses may attract residential delivery surcharges; port/airport addresses trigger terminal handling charge (THC) logic. [ENUM-REF-CANDIDATE: residential|commercial|warehouse|port|airport|border_crossing|free_trade_zone — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Aeo Certificate Number' ;
    rdfs:comment 'Official AEO certificate number issued by the relevant customs authority (e.g., EU EORI-based AEO number, C-TPAT account number). Required for customs pre-clearance, reduced inspection, and trusted trader benefits. Validated in Descartes Customs during shipment processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality name of the address. Used in route planning, carrier zone determination, customs declarations, and last-mile delivery assignment. Critical for TMS routing and freight rate calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsZone rdf:type rdf:Property ;
    rdfs:label 'Customs Zone' ;
    rdfs:comment 'Customs and trade compliance zone classification for this address. Free Trade Zone (FTZ) and bonded warehouse addresses require special customs handling in Descartes Customs. Special Economic Zone (SEZ) addresses may have preferential duty treatment. Drives customs declaration routing and duty calculation.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsPermitted rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Permitted' ;
    rdfs:comment 'Indicates whether dangerous goods (DG) shipments are permitted at this address. When False, the TMS and booking systems will block DG shipments to/from this address. Governed by IMDG Code for ocean, ICAO Technical Instructions for air, and ADR/RID for road/rail transport.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryWindowClose rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Close' ;
    rdfs:comment 'Latest time of day (HH:MM in 24-hour format) when deliveries or pickups are accepted at this address. Used alongside delivery_window_open to define the acceptable delivery time window for route planning and SLA management.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowOpen rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Open' ;
    rdfs:comment 'Earliest time of day (HH:MM in 24-hour format) when deliveries or pickups are accepted at this address. Used by TMS route optimization to schedule delivery windows and ensure SLA compliance. Critical for warehouse and commercial addresses with restricted receiving hours.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eoriNumber rdf:type rdf:Property ;
    rdfs:label 'Eori Number' ;
    rdfs:comment 'EORI number assigned by EU customs authorities to identify economic operators in customs declarations and trade transactions. Required for all import/export customs filings within the EU. Stored at the address level to support multi-site customers with different EORI registrations per facility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Type of logistics facility at this address when applicable. Drives specialized handling requirements in Manhattan WMS, carrier selection in SAP TM, and customs processing in Descartes. Cold storage facilities require temperature-controlled transport; bonded warehouses require customs bond management. [ENUM-REF-CANDIDATE: distribution_center|cross_dock|cold_storage|bonded_warehouse|cfs|icd|airport_cargo|seaport_terminal — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoded latitude/longitude coordinates. Rooftop indicates exact building-level precision; range_interpolated is street-level; geometric_center is centroid of a postal area; approximate is city/region level; unverified means coordinates have not been validated. Drives confidence in GPS-based routing and geofencing.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeRestriction rdf:type rdf:Property ;
    rdfs:label 'Hs Code Restriction' ;
    rdfs:comment 'Comma-separated list of HS Code prefixes (Harmonized System codes per WCO) that are restricted or prohibited at this address due to local regulations, facility licensing, or trade compliance requirements. Used by Descartes Customs to flag non-compliant shipments during booking.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Indicates whether this address is the customer\'s default billing address for invoice generation and accounts receivable processing in SAP S/4HANA Finance. When True, this address is used for all financial documents unless overridden at the shipment level.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultDestination rdf:type rdf:Property ;
    rdfs:label 'Is Default Destination' ;
    rdfs:comment 'Indicates whether this address is the customer\'s default delivery destination. When True, this address is pre-populated as the destination in shipment booking workflows, supporting frequent lane customers and e-commerce fulfillment automation.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultOrigin rdf:type rdf:Property ;
    rdfs:label 'Is Default Origin' ;
    rdfs:comment 'Indicates whether this address is the customer\'s default pickup/origin location for shipment booking. When True, this address is pre-populated as the origin in shipment booking workflows in SAP TM and Oracle TMS, reducing data entry errors.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isResidential rdf:type rdf:Property ;
    rdfs:label 'Is Residential' ;
    rdfs:comment 'Indicates whether this address is classified as a residential location. Residential addresses trigger carrier-specific residential delivery surcharges (e.g., FedEx, UPS residential fees), require different last-mile delivery protocols, and may affect SLA commitments for D2D (door-to-door) services.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the address in decimal degrees (WGS84 datum), ranging from -90 to +90. Used for GPS-based last-mile routing, geofencing in FourKites real-time visibility, proximity-based warehouse assignment, and route optimization in TMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the address in decimal degrees (WGS84 datum), ranging from -180 to +180. Used alongside latitude for GPS-based routing, geofencing, real-time shipment tracking, and network design optimization in Blue Yonder.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the address. Used for carrier zone mapping, freight rate calculation, last-mile delivery routing, dimensional weight (DIM weight) zone surcharges, and address validation. Format varies by country.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAddressCode rdf:type rdf:Property ;
    rdfs:label 'Source System Address Code' ;
    rdfs:comment 'Native identifier of this address record in the originating operational system (e.g., Salesforce CRM Address ID, SAP TM Location ID, Oracle TMS Address Code). Enables bidirectional synchronization, change data capture (CDC), and cross-system reconciliation during EDI processing.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for special handling or access instructions at this address (e.g., \'Deliver to loading dock B\', \'Call 30 minutes before arrival\', \'Gate code: 1234\', \'No deliveries before 08:00\'). Transmitted to last-mile carriers and drivers via TMS dispatch notes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizedAddress rdf:type rdf:Property ;
    rdfs:label 'Standardized Address' ;
    rdfs:comment 'Full normalized and standardized address string as returned by the address validation provider, conforming to postal authority formatting rules. Used as the canonical address for printing on shipping labels, AWBs, and customs declarations to ensure deliverability.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the address using ISO 3166-2 subdivision codes where applicable. Required for domestic routing, tax jurisdiction determination, and US/Canada customs filings (AMS, ISF).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the address location (e.g., \'America/New_York\', \'Europe/London\', \'Asia/Shanghai\'). Used to correctly interpret delivery windows, calculate ETA/ETD in local time, and schedule last-mile delivery notifications across global operations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationProvider rdf:type rdf:Property ;
    rdfs:label 'Validation Provider' ;
    rdfs:comment 'Name of the third-party address validation service or postal authority database used to validate this address (e.g., USPS, Loqate, SmartyStreets, Google Maps, HERE). Enables audit trail for address quality and supports provider performance benchmarking.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Result of the address standardization and validation process against postal authority databases (e.g., USPS, Royal Mail, Deutsche Post). Validated addresses have been confirmed deliverable. Failed addresses contain errors. Partial addresses are incomplete but usable. Used to enforce address quality gates in shipment booking workflows.' ;
    rdfs:domain ind:AddressBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated against a postal authority or address verification service. Used to determine if re-validation is required based on address data freshness policies.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consigneeProfileId rdf:type rdf:Property ;
    rdfs:label 'Consignee Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the consignee profile record in the Transport Shipping data platform. Primary key for the consignee_profile entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsigneeProfile .

ind:deliveryNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Delivery Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Consignees have delivery location nodes for last-mile routing. Required for delivery scheduling, route optimization, last-mile zone assignment, and delivery promise calculation. Replaces denormalized ' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:ediPartnerId rdf:type rdf:Property ;
    rdfs:label 'Edi Partner Id' ;
    rdfs:comment 'EDI interchange partner identifier (ISA qualifier + ID) for the consignee, enabling automated transmission of ASNs, delivery confirmations, and customs pre-arrival notifications.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:importerTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Importer Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Consignee profiles represent importers/receivers in customs. Required for: import declarations, customs broker assignment, duty assessment, and delivery clearance. Critical for inbound customs operati' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:aeoCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification Number' ;
    rdfs:comment 'AEO certification number issued to the consignee by the relevant customs authority, confirming trusted trader status. Enables expedited customs clearance and reduced inspection rates.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnRequired rdf:type rdf:Property ;
    rdfs:label 'Asn Required' ;
    rdfs:comment 'Indicates whether the consignee requires an Advanced Shipping Notice (ASN) to be transmitted via EDI prior to shipment arrival. When True, ASN generation is triggered in the WMS/TMS integration layer.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consigneeType rdf:type rdf:Property ;
    rdfs:label 'Consignee Type' ;
    rdfs:comment 'Classification of the consignee indicating the nature of the receiving party. Drives SLA entitlements, customs handling rules, and delivery workflows. B2B enterprise and 3PL/4PL partners are recurring; B2C individual may be one-time last-mile recipients. [ENUM-REF-CANDIDATE: b2b_enterprise|b2c_individual|3pl_partner|4pl_partner|government|nvocc|freight_forwarder|broker — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerCode rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Code' ;
    rdfs:comment 'Identifier of the licensed customs broker authorized by the consignee to handle import clearance on their behalf. Used in Descartes Customs for power-of-attorney validation.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ddpAuthorized rdf:type rdf:Property ;
    rdfs:label 'Ddp Authorized' ;
    rdfs:comment 'Indicates whether the consignee has authorized Transport Shipping to arrange DDP (Delivered Duty Paid) shipments on their behalf, where the shipper or carrier pre-pays import duties and taxes. Relevant for cross-border e-commerce fulfillment.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deniedPartyScreenResult rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screen Result' ;
    rdfs:comment 'Outcome of the most recent denied-party screening check. A match_found or blocked result prevents shipment processing until compliance review is completed.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyScreenedAt rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screened At' ;
    rdfs:comment 'Timestamp of the most recent denied-party screening check performed against this consignee in Descartes Customs. Required for trade compliance audit trails under US EAR, OFAC, and EU dual-use regulations.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epodContactEmail rdf:type rdf:Property ;
    rdfs:label 'Epod Contact Email' ;
    rdfs:comment 'Dedicated email address to which electronic proof of delivery (ePOD) documents are transmitted upon successful delivery. May differ from the primary contact email when a separate receiving or logistics team handles POD acknowledgment.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epodContactPhone rdf:type rdf:Property ;
    rdfs:label 'Epod Contact Phone' ;
    rdfs:comment 'Mobile or direct phone number for the ePOD recipient contact, used by drivers and last-mile couriers to confirm delivery and obtain digital signature authorization.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoLatitude rdf:type rdf:Property ;
    rdfs:label 'Geo Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the consignee delivery location in decimal degrees (WGS84). Used by FourKites for geofencing, last-mile ETA prediction, and proof-of-delivery geo-stamping.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoLongitude rdf:type rdf:Property ;
    rdfs:label 'Geo Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the consignee delivery location in decimal degrees (WGS84). Used alongside latitude for geofencing and route optimization in SAP TM and FourKites.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Id Verification Required' ;
    rdfs:comment 'Indicates whether the consignee must present government-issued identification at the time of delivery. Applicable for high-value shipments, controlled goods, or regulatory requirements.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:importLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Import License Number' ;
    rdfs:comment 'Government-issued import license or permit number held by the consignee, required for regulated or controlled goods categories. Validated during customs clearance in Descartes Customs GTM.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsPreference rdf:type rdf:Property ;
    rdfs:label 'Incoterms Preference' ;
    rdfs:comment 'Consignee\'s preferred Incoterms rule governing the transfer of risk and cost responsibility for import shipments. Incoterms 2020 standard. Drives duty and tax liability assignment in customs declarations. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this consignee is a recurring destination party (True) or a one-time recipient such as a B2C last-mile delivery addressee (False). Drives profile retention and SLA assignment logic.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal name of the consignee as it appears on customs declarations, air waybills (AWB), and bills of lading (BOL). Used for trade compliance screening and import documentation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Notification Language Code' ;
    rdfs:comment 'IETF BCP 47 language tag representing the consignee\'s preferred language for shipment notifications, delivery alerts, and ePOD communications (e.g., en-US, fr-FR, zh-CN).' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the consignee\'s preferred billing and invoicing currency for duty, tax, and freight charge settlements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryDays rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Days' ;
    rdfs:comment 'Comma-separated list of preferred delivery days of the week (e.g., MON,TUE,WED,THU,FRI). Used by last-mile scheduling to avoid unattended delivery attempts and reduce failed delivery rates.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Window End' ;
    rdfs:comment 'Consignee-preferred latest time of day (HH:MM, 24-hour format) for delivery attempts. Defines the close of the acceptable delivery window for last-mile scheduling.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Window Start' ;
    rdfs:comment 'Consignee-preferred earliest time of day (HH:MM, 24-hour format) for delivery attempts. Used by last-mile routing engines in Oracle TMS and SAP TM to schedule delivery slots within SLA windows.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCreatedAt rdf:type rdf:Property ;
    rdfs:label 'Profile Created At' ;
    rdfs:comment 'Timestamp when the consignee profile record was first created in the Transport Shipping data platform. Represents the record audit creation event for lineage and compliance tracking.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileUpdatedAt rdf:type rdf:Property ;
    rdfs:label 'Profile Updated At' ;
    rdfs:comment 'Timestamp of the most recent update to the consignee profile record. Used for change data capture (CDC) in the Databricks Silver layer and audit trail compliance.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresAppointment rdf:type rdf:Property ;
    rdfs:label 'Requires Appointment' ;
    rdfs:comment 'Indicates whether the consignee requires a pre-scheduled delivery appointment before a driver can attempt delivery. True triggers appointment scheduling workflow in Oracle TMS.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'External reference identifier from Salesforce CRM linking this consignee profile to the corresponding CRM account record for B2B consignees. Null for one-time B2C recipients.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureRequired rdf:type rdf:Property ;
    rdfs:label 'Signature Required' ;
    rdfs:comment 'Indicates whether a consignee signature is mandatory for proof of delivery (POD). When True, drivers must capture a digital signature via ePOD before completing the delivery event.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'SLA entitlement tier assigned to this consignee profile, determining delivery time commitments, exception handling priority, and OTD/OTIF performance targets. Sourced from Salesforce CRM account entitlements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialDeliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Delivery Instructions' ;
    rdfs:comment 'Free-text field capturing consignee-specific delivery instructions such as dock number, gate access codes, forklift requirements, temperature-controlled unloading bay, or security check-in procedures.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Government-issued tax identification number (TIN, VAT number, EIN, or equivalent) for the consignee. Required for customs declarations, duty invoicing, and trade compliance filings in Descartes Customs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the consignee delivery location (e.g., America/New_York, Europe/London). Used to convert delivery window times to UTC for scheduling in SAP TM and FourKites.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or doing-business-as (DBA) trade name of the consignee, which may differ from the legal name. Used for operational labeling and customer-facing communications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseDockNumber rdf:type rdf:Property ;
    rdfs:label 'Warehouse Dock Number' ;
    rdfs:comment 'Specific dock door or bay number at the consignee\'s receiving facility. Used by drivers and Manhattan WMS for directed unloading and dock scheduling.' ;
    rdfs:domain ind:ConsigneeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the contact\'s managerial or supervisory contact within the same account. Mirrors the Salesforce CRM \'Reports To\' relationship. Enables organizational hierarchy navigation for escalation routing and account planning.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:contactDescription rdf:type rdf:Property ;
    rdfs:label 'Contact Description' ;
    rdfs:comment 'Free-text notes or description about the contact person, capturing additional context such as areas of responsibility, special handling instructions, relationship history, or account-specific notes entered by the account management team in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'Functional role the contact plays in the customer relationship with Transport Shipping. Determines routing of communications, invoices, and service cases. [ENUM-REF-CANDIDATE: billing|operational|escalation|authorized_signatory|procurement|customs|compliance|executive — promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Active contacts receive communications and are eligible for service interactions. Inactive contacts have left the organization or are no longer relevant. Do_not_contact respects opt-out or legal restrictions per GDPR.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact record indicating its priority and purpose within the account relationship. Primary contacts receive all standard communications; emergency contacts are activated for critical shipment exceptions or SLA breaches.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'Source system identifier for the contact record in Salesforce CRM (Contact object ID, e.g., 003XXXXXXXXXXXXXXX). Used for cross-system reconciliation and lineage tracing back to the operational system of record.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date after which the contact\'s personal data must be reviewed for deletion or anonymization in compliance with GDPR Article 17 (Right to Erasure) and the organization\'s data retention policy. Calculated based on the last active engagement date plus the applicable retention period.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department or business unit the contact belongs to within their company (e.g., Logistics, Procurement, Finance, Operations, Supply Chain). Supports targeted communications and service routing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Indicates whether the contact has opted out of phone-based outreach. When true, outbound calls to this contact are suppressed in CRM workflows. Supports GDPR consent management and national do-not-call registry compliance.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact person. Used for shipment notifications, EDI communications, invoice delivery, and CRM-driven customer service case correspondence. Governed under GDPR as personal data.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptOut rdf:type rdf:Property ;
    rdfs:label 'Email Opt Out' ;
    rdfs:comment 'Indicates whether the contact has opted out of marketing and non-transactional email communications. When true, only transactional emails (e.g., shipment confirmations, POD notifications) are permitted. Enforces GDPR Article 7 consent requirements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fax rdf:type rdf:Property ;
    rdfs:label 'Fax' ;
    rdfs:comment 'Fax number for the contact, used in legacy customs documentation, trade compliance filings, and formal freight forwarding communications where fax remains an accepted channel per regulatory requirements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the contact person as recorded in Salesforce CRM. Used for personalized communications, correspondence, and identity verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full display name of the contact person (typically first_name + last_name). Sourced directly from Salesforce CRM Name field. Used as the primary human-readable identity label for the contact across logistics operations, EDI communications, and customer service interactions.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date on which the contact provided or last updated their GDPR data processing consent. Required for audit trail and regulatory compliance demonstration under GDPR Article 7(1).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR data processing consent status for the contact. Tracks whether the contact has given, withdrawn, or not yet provided consent for personal data processing. Mandatory for contacts in EU/EEA jurisdictions. Drives data retention and communication eligibility.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuthorizedSignatory rdf:type rdf:Property ;
    rdfs:label 'Is Authorized Signatory' ;
    rdfs:comment 'Indicates whether this contact is an authorized signatory for shipping contracts, customs declarations, power of attorney for customs brokerage, and trade compliance documents. Critical for Descartes Customs and AEO/C-TPAT compliance validation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBillingContact rdf:type rdf:Property ;
    rdfs:label 'Is Billing Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive invoices, freight charges, and financial communications. Billing contacts receive freight invoices, duty and tax statements, and payment reminders from SAP S/4HANA Finance AR processes.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCustomsContact rdf:type rdf:Property ;
    rdfs:label 'Is Customs Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated point of contact for customs clearance, trade compliance queries, ISF (Importer Security Filing), and AMS (Automated Manifest System) communications. Used by Descartes Customs for routing compliance notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated primary contact for the associated customer account. Only one contact per account should be flagged as primary. Drives default routing for shipment notifications, invoice delivery, and account management communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Professional job title or designation of the contact person within their organization (e.g., Shipping Coordinator, Procurement Manager, Logistics Director, Finance Controller). Used for routing communications to the appropriate decision-maker and for account segmentation analytics.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent logged activity (call, email, meeting, task) associated with this contact in Salesforce CRM. Used to identify dormant contacts, prioritize re-engagement campaigns, and measure account health.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the contact person as recorded in Salesforce CRM. Combined with first_name to form the full display name for communications and reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Original source or channel through which this contact was acquired or entered the CRM system. Used for marketing attribution, sales pipeline analysis, and customer acquisition cost reporting in Salesforce CRM. [ENUM-REF-CANDIDATE: web|referral|trade_show|partner|cold_call|existing_customer|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'LinkedIn profile URL for the contact person. Used by account management and sales teams for relationship intelligence, opportunity tracking, and professional network engagement within Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City component of the contact\'s mailing address. Used in conjunction with mailing_street, mailing_state, mailing_postal_code, and mailing_country for complete address resolution in customs and trade compliance filings.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the contact\'s mailing address country (e.g., USA, GBR, SGP, DEU). Used for cross-border shipping compliance, customs jurisdiction determination, and trade sanctions screening.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal or ZIP code component of the contact\'s mailing address. Used for last-mile delivery zone determination, freight rate calculation, and customs address validation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingState rdf:type rdf:Property ;
    rdfs:label 'Mailing State' ;
    rdfs:comment 'State, province, or region component of the contact\'s mailing address. Required for domestic US shipments (DOT regulations), Canadian customs filings, and other jurisdictions where state-level addressing is mandatory.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStreet rdf:type rdf:Property ;
    rdfs:label 'Mailing Street' ;
    rdfs:comment 'Street address line for the contact\'s mailing address. Used for formal correspondence, customs documentation, and regulatory filings where a physical address is required.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cellular phone number of the contact in E.164 international format. Used for SMS-based shipment tracking alerts, last-mile delivery notifications, and ePOD (Electronic Proof of Delivery) confirmations.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business phone number of the contact in E.164 international format. Used for shipment exception notifications, customs clearance coordination, and direct customer service interactions.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalUserCode rdf:type rdf:Property ;
    rdfs:label 'Portal User Code' ;
    rdfs:comment 'Identifier for the contact\'s user account in the Transport Shipping customer self-service portal. Links the CRM contact to the portal login for shipment tracking, document retrieval, and service case submission. Enables single-sign-on (SSO) correlation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Channel' ;
    rdfs:comment 'The contact\'s preferred communication channel for receiving shipment updates, service notifications, and account communications. Drives automated notification routing in TMS and CRM systems.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Honorific or salutation prefix for the contact person (e.g., Mr., Ms., Dr.). Used in formal correspondence, shipping documentation, and customer communications to ensure professional address.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Email' ;
    rdfs:comment 'Alternate or secondary email address for the contact, used as a fallback for critical shipment alerts, proof of delivery (POD) notifications, or when the primary email is undeliverable.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNotificationEligible rdf:type rdf:Property ;
    rdfs:label 'Shipment Notification Eligible' ;
    rdfs:comment 'Indicates whether this contact is subscribed to receive automated shipment status notifications including ETA updates, departure confirmations, POD (Proof of Delivery) alerts, and exception notifications from FourKites or the TMS.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaNotificationEligible rdf:type rdf:Property ;
    rdfs:label 'Sla Notification Eligible' ;
    rdfs:comment 'Indicates whether this contact is configured to receive SLA breach notifications and KPI performance alerts. When true, the contact is included in automated SLA exception communications from the TMS and FourKites visibility platform.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer credit profile record in the Transport Shipping lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Credit Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Credit limit decisions require assignment to credit analysts for risk assessment and approval workflow. Regulatory requirement for financial controls and audit trail in freight forwarding operations.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger. Business justification: Credit profiles reference specific GL accounts (receivables control accounts) in the ledger for credit limit enforcement and exposure tracking. Credit controllers need to know which ledger account to ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:approvedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Limit' ;
    rdfs:comment 'The formally approved credit limit as of the most recent credit review, which may differ from the currently active credit_limit if a pending change is awaiting activation. Maintains the audit trail of the last approved value.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableCredit rdf:type rdf:Property ;
    rdfs:label 'Available Credit' ;
    rdfs:comment 'Remaining credit headroom calculated as credit_limit minus outstanding_balance minus open_order_exposure. Stored as a business-critical operational field (not a derived KPI) because it is directly consumed by SAP TM shipment release checks and Oracle TMS load authorization gates.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which invoices are issued to this customer. May differ from credit_currency when the customer operates in a different functional currency. Sourced from SAP S/4HANA Finance customer master.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAgencyName rdf:type rdf:Property ;
    rdfs:label 'Credit Agency Name' ;
    rdfs:comment 'Name of the external credit reference agency that provided the credit rating or score (e.g., Dun & Bradstreet, Experian, Equifax, Coface, Euler Hermes). Required for audit trail and credit review documentation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAgencyReference rdf:type rdf:Property ;
    rdfs:label 'Credit Agency Reference' ;
    rdfs:comment 'Unique reference number or DUNS number assigned by the external credit agency for this customer. Used to cross-reference credit bureau reports and validate the source of the credit assessment.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP organizational unit (credit control area code) within which this customer\'s credit limit is managed. Defines the scope of credit monitoring and aligns with the company code structure in SAP S/4HANA Finance.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit, outstanding balance, and exposure amounts are denominated (e.g., USD, EUR, GBP). Aligns with the customer\'s billing currency in SAP S/4HANA Finance.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Calendar date on which the credit hold was most recently applied to this account. Used for aging analysis of holds and SLA tracking for hold resolution.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether this customer account is currently under a credit hold, blocking the release of new shipments and freight orders in SAP TM and Oracle TMS. True = hold active; False = no hold. Operationally critical for shipment gating.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code explaining why the credit hold was applied. Used by finance and operations teams to prioritize resolution actions and communicate with customers. [ENUM-REF-CANDIDATE: overdue_invoices|credit_limit_exceeded|payment_dispute|bankruptcy_risk|manual_hold|compliance_review|other — promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Released Date' ;
    rdfs:comment 'Calendar date on which the most recent credit hold was lifted, allowing shipment release to resume. Null if the hold is still active. Used for hold duration analytics and finance KPI reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditInsuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Flag' ;
    rdfs:comment 'Indicates whether this customer\'s credit exposure is covered by a trade credit insurance policy (e.g., Euler Hermes, Coface, Atradius). True = insured; False = uninsured. Affects net credit risk exposure and provisioning under IFRS 9.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsurancePolicyRef rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Ref' ;
    rdfs:comment 'Reference number of the trade credit insurance policy covering this customer\'s receivables. Populated only when credit_insurance_flag is True. Used for claims processing and insurer reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Approved By' ;
    rdfs:comment 'Name or employee ID of the finance officer or credit manager who formally approved the current credit limit. Required for SOX audit trail and segregation of duties compliance.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Utilization Pct' ;
    rdfs:comment 'Percentage of the approved credit limit currently utilized, calculated as (outstanding_balance + open_order_exposure) / credit_limit × 100. Stored as a business-critical operational field consumed by SAP TM shipment release checks and finance dashboards — not a derived analytics KPI.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External or internal credit rating assigned to the customer, using a standardized rating scale (e.g., S&P/Moody\'s-aligned: AAA through D, or NR for Not Rated). Drives credit limit approval tiers and risk-based pricing decisions. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D|NR — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Numeric credit score assigned by an external credit agency or internal scoring model, typically on a scale of 0–1000 or 300–850 depending on the agency. Used alongside credit_rating for granular risk segmentation and credit limit setting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Pct' ;
    rdfs:comment 'Percentage discount offered to the customer for early payment of invoices within a specified discount period (e.g., 2% if paid within 10 days). Defined in SAP S/4HANA Finance payment terms configuration.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuredCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Insured Credit Limit' ;
    rdfs:comment 'The portion of the total credit limit that is covered by trade credit insurance. May be less than or equal to credit_limit. Used to calculate net uninsured exposure for IFRS 9 provisioning.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recently completed formal credit review for this customer. Used to determine review frequency compliance and trigger overdue review alerts.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openOrderExposure rdf:type rdf:Property ;
    rdfs:label 'Open Order Exposure' ;
    rdfs:comment 'Total value of freight orders and shipments that have been accepted but not yet invoiced, representing committed but unbilled credit exposure. Sourced from SAP TM freight order management and used in real-time credit checks.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total value of invoices that have passed their payment due date and remain unpaid, expressed in the credit currency. Sourced from SAP S/4HANA Finance AR aging. Triggers credit hold workflows when thresholds are breached.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueDays rdf:type rdf:Property ;
    rdfs:label 'Overdue Days' ;
    rdfs:comment 'Number of calendar days the oldest unpaid overdue invoice has been past its due date. Used for collection prioritization, credit hold triggers, and IFRS 9 expected credit loss staging.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentBehaviorCode rdf:type rdf:Property ;
    rdfs:label 'Payment Behavior Code' ;
    rdfs:comment 'Classification of the customer\'s historical payment behavior based on Days Sales Outstanding (DSO) analysis from SAP S/4HANA Finance AR aging reports. Informs credit risk assessment and collection prioritization.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Numeric representation of the standard payment due period in calendar days (e.g., 30, 60, 90). Complements payment_terms_code for analytics, SLA reporting, and Days Sales Outstanding (DSO) calculations in the finance domain.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Number' ;
    rdfs:comment 'Externally-known business identifier for the credit profile, used in correspondence with credit agencies, billing teams, and finance operations. Sourced from SAP S/4HANA Finance customer credit management (FD32).' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the credit profile by customer segment: enterprise B2B accounts, small-to-medium enterprises (SME), individual B2C shippers, Third-Party Logistics (3PL) partners, Fourth-Party Logistics (4PL) partners, or government entities. Drives credit policy rules and approval workflows. [ENUM-REF-CANDIDATE: enterprise|sme|individual|3pl_partner|4pl_partner|government — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Requested Credit Limit' ;
    rdfs:comment 'Credit limit amount requested by the customer or proposed by the sales/account management team (Salesforce CRM opportunity data), pending formal credit review and approval by the finance team.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Frequency in calendar months at which this customer\'s credit profile must be formally reviewed (e.g., 3, 6, 12, 24). Determined by credit risk tier: high-risk accounts reviewed quarterly, standard accounts annually.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Internal risk classification assigned to the customer based on credit score, payment history, and financial exposure. Drives credit limit approval authority levels, review frequency, and shipment release policies.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCreditAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Credit Account Number' ;
    rdfs:comment 'SAP S/4HANA Finance customer credit account number (10-digit SAP debtor number) used in FD32 credit management transactions. The system-of-record identifier for reconciliation with SAP AR and credit management modules.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Cash deposit or bank guarantee amount held by Transport Shipping as collateral against the customer\'s credit exposure. Reduces the net unsecured credit risk. Tracked in SAP S/4HANA Finance.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityType rdf:type rdf:Property ;
    rdfs:label 'Security Type' ;
    rdfs:comment 'Type of financial security or collateral provided by the customer to support their credit facility. Includes cash deposits, bank guarantees, letters of credit (LC), parent company guarantees, or none for unsecured accounts.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Customer Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent customer account record, enabling hierarchical B2B enterprise account structures (e.g., subsidiary accounts rolling up to a global parent). Null for top-level accounts. Supports consolidated billing and group-level SLA management.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:preferredLaneId rdf:type rdf:Property ;
    rdfs:label 'Preferred Lane Id' ;
    rdfs:comment 'Foreign key linking to route.lane. Business justification: Strategic customers negotiate preferred lanes for their shipments. Drives TMS routing decisions, contract-specific lane assignments, and dedicated capacity allocation. Essential for customer-specific ' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:preferredServiceCorridorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Service Corridor Id' ;
    rdfs:comment 'Foreign key linking to route.service_corridor. Business justification: Enterprise customers negotiate corridor-level service agreements for regional trade lanes. Required for corridor capacity reservations, multi-leg service commitments, and strategic account corridor pe' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCorridor .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Normalizes the customer segmentation classification. Currently customer_account has account_segment as a STRING (likely storing segment_code). Adding customer_segment_id FK allows proper referential i' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accountSource rdf:type rdf:Property ;
    rdfs:label 'Account Source' ;
    rdfs:comment 'Channel or method through which the customer account was originally created: Salesforce CRM opportunity conversion, web portal self-registration, EDI partner onboarding, manual entry by operations team, data migration from legacy system, or partner referral.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Commercial segmentation tier assigned to the customer account based on revenue contribution, shipment volume, and strategic value. Determines priority handling, dedicated account management, and access to premium services such as guaranteed capacity and priority customs clearance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Api Integration Enabled' ;
    rdfs:comment 'Indicates whether the customer account has an active API integration for real-time shipment booking, tracking, and rate queries via Transport Shipping\'s logistics platform. API-enabled accounts can connect their ERP or e-commerce systems directly.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit and outstanding balance are denominated (e.g., USD, EUR, GBP). Ensures consistent financial reporting across multi-currency accounts.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'External account identifier sourced from Salesforce CRM Account object. Used to trace the master record back to the system of record and support bi-directional synchronisation with Salesforce.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatMember rdf:type rdf:Property ;
    rdfs:label 'Ctpat Member' ;
    rdfs:comment 'Indicates whether the customer is a validated member of the US Customs-Trade Partnership Against Terrorism (C-TPAT) program. C-TPAT membership enables expedited US Customs and Border Protection processing and reduced examination rates for US-bound shipments.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ddpEligible rdf:type rdf:Property ;
    rdfs:label 'Ddp Eligible' ;
    rdfs:comment 'Indicates whether the customer account is approved for Delivered Duty Paid (DDP) shipments, where Transport Shipping assumes responsibility for import duties and taxes on behalf of the customer. Requires credit approval and customs power of attorney on file.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deniedPartyScreenDate rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screen Date' ;
    rdfs:comment 'Date on which the most recent denied party and sanctions screening was performed for this customer account in Descartes Customs GTM. Used to enforce periodic re-screening compliance and audit trail requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deniedPartyScreened rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screened' ;
    rdfs:comment 'Indicates whether the customer account has passed the most recent denied party and sanctions screening check in Descartes Customs GTM. Must be True before any shipment booking is permitted. Automatically reset to False when screening expires or a watchlist update occurs.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) number uniquely identifying the customer\'s legal business entity globally. Used for credit risk assessment, supplier onboarding, and enterprise account hierarchy resolution.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapable rdf:type rdf:Property ;
    rdfs:label 'Edi Capable' ;
    rdfs:comment 'Indicates whether the customer account is configured for Electronic Data Interchange (EDI) integration for automated shipment booking, Advanced Shipping Notices (ASN), and status updates. EDI-capable accounts bypass manual data entry workflows.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Date' ;
    rdfs:comment 'Date on which the KYC verification was last completed for this customer account. Used to enforce periodic KYC renewal cycles and regulatory audit compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerified rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified' ;
    rdfs:comment 'Indicates whether the customer account has completed Know Your Customer (KYC) identity verification as required by anti-money laundering (AML) regulations and Transport Shipping\'s customer onboarding policy. Required for high-value accounts and cross-border trade.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Shipment Date' ;
    rdfs:comment 'Date of the most recent shipment booked or executed under this customer account. Used for dormancy detection, account health monitoring, and proactive retention outreach by the account management team.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Calendar date on which the customer account was formally activated and approved for shipment booking. Marks the start of the commercial relationship. Used for customer tenure analysis, anniversary-based tier reviews, and SLA effective date calculations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredIncotermsCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Incoterms Code' ;
    rdfs:comment 'Customer\'s default International Commercial Terms (Incoterms 2020) code governing risk and cost transfer in shipments (e.g., DDP, FOB, CIF, EXW). Pre-populated on new shipment bookings and freight orders in SAP TM. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredServiceMode rdf:type rdf:Property ;
    rdfs:label 'Preferred Service Mode' ;
    rdfs:comment 'Customer\'s preferred primary freight transport mode: air (express/freight), ocean (FCL/LCL), road (FTL/LTL), rail, or multimodal. Used by SAP TM for default carrier and route selection and by Blue Yonder for demand forecasting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceOwnerCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Owner Code' ;
    rdfs:comment 'Salesforce CRM User ID of the account owner record. Retained for bi-directional synchronisation and audit traceability back to the Salesforce system of record.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTierCode rdf:type rdf:Property ;
    rdfs:label 'Sla Tier Code' ;
    rdfs:comment 'Code identifying the contracted Service Level Agreement (SLA) tier applicable to this customer account. Determines On-Time Delivery (OTD) targets, exception escalation thresholds, and guaranteed transit time commitments. Linked to the SLA entitlement configuration in SAP TM.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Employer Identification Number (EIN) or Tax Identification Number (TIN) assigned by the national tax authority (e.g., IRS EIN for US entities). Used for financial reporting, 1099/W-9 compliance, and customs importer of record identification.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Operating or \'doing business as\' (DBA) name used commercially by the customer, which may differ from the registered legal name. Used in customer-facing communications and shipment documentation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Customer\'s VAT or GST registration number issued by the relevant tax authority. Required for cross-border invoicing, customs declarations, and EU VAT compliance. Null for B2C customers or entities in non-VAT jurisdictions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagementModel rdf:type rdf:Property ;
    rdfs:label 'Account Management Model' ;
    rdfs:comment 'Defines the assigned account management approach for customers in this segment: STRATEGIC = dedicated named account manager with executive sponsorship; COMMERCIAL = shared account management team; DIGITAL = digital-first with inside sales support; SELF_SERVE = fully automated self-service with no dedicated account manager.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiAccessEligible rdf:type rdf:Property ;
    rdfs:label 'Api Access Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are entitled to direct API (Application Programming Interface) access to Transport Shipping\'s TMS and WMS platforms for automated shipment booking, tracking, and reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialTier rdf:type rdf:Property ;
    rdfs:label 'Commercial Tier' ;
    rdfs:comment 'Commercial tier classification indicating the level of service, pricing, and account management investment assigned to this segment. STRATEGIC = top-tier enterprise accounts with dedicated account teams; PREMIUM = high-value accounts with enhanced SLAs; STANDARD = mid-market accounts; BASIC = transactional accounts; DIGITAL = self-serve digital-only accounts.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Maximum credit exposure in USD extended to customers within this segment. Used by SAP S/4HANA Finance Accounts Receivable for credit control and order release decisions. Confidential financial data.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'External identifier for this segment record in Salesforce CRM (15 or 18-character Salesforce record ID). Used for cross-system reconciliation between the Databricks Silver Layer and the Salesforce CRM source of record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsFacilitationLevel rdf:type rdf:Property ;
    rdfs:label 'Customs Facilitation Level' ;
    rdfs:comment 'Level of customs clearance facilitation entitlement for customers in this segment. AEO_FAST_TRACK applies to segments serving Authorized Economic Operator (AEO) certified customers eligible for expedited customs processing via Descartes Customs.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsEligible rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible to ship dangerous goods (DG) under IATA Dangerous Goods Regulations (DGR) and IMDG Code. When TRUE, additional compliance checks and documentation requirements apply.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dedicatedWarehouseEligible rdf:type rdf:Property ;
    rdfs:label 'Dedicated Warehouse Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment qualify for dedicated warehouse space and labour allocation within Transport Shipping\'s distribution network, as managed by Manhattan WMS.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountTierCode rdf:type rdf:Property ;
    rdfs:label 'Discount Tier Code' ;
    rdfs:comment 'Code referencing the discount tier applicable to this segment, governing base rate reductions, General Rate Increase (GRI) exemptions, Bunker Adjustment Factor (BAF) caps, and Terminal Handling Charge (THC) waivers. Confidential as it reflects commercial negotiation outcomes.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecommerceFulfillmentEligible rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Fulfillment Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are entitled to access e-commerce fulfillment services including last-mile delivery, returns management (RMA), and Advanced Shipping Notice (ASN) processing.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleServiceLines rdf:type rdf:Property ;
    rdfs:label 'Eligible Service Lines' ;
    rdfs:comment 'Comma-separated list of logistics service lines that customers in this segment are eligible to access (e.g., \'EXPRESS_PARCEL,FREIGHT_AIR,FREIGHT_OCEAN,CUSTOMS_BROKERAGE,ECOMMERCE_FULFILLMENT\'). Governs service entitlement and product catalogue access. [ENUM-REF-CANDIDATE: EXPRESS_PARCEL|FREIGHT_AIR|FREIGHT_OCEAN|FREIGHT_ROAD|FREIGHT_RAIL|CUSTOMS_BROKERAGE|WAREHOUSE|ECOMMERCE_FULFILLMENT|LAST_MILE|CONTRACT_LOGISTICS — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Erp Segment Code' ;
    rdfs:comment 'Segment code as recorded in SAP S/4HANA Finance for revenue allocation, cost center assignment, and P&L reporting by customer segment. Enables financial reporting alignment between the data lakehouse and ERP.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoice Frequency' ;
    rdfs:comment 'Frequency at which invoices are generated and issued to customers in this segment. Drives billing cycle configuration in SAP S/4HANA Finance and impacts cash flow planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otd Target Pct' ;
    rdfs:comment 'Contractual On-Time Delivery (OTD) performance target expressed as a percentage (0.00–100.00) for customers in this segment. Used in KPI reporting, SLA compliance monitoring, and carrier performance management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Target Pct' ;
    rdfs:comment 'Contractual On-Time In-Full (OTIF) performance target expressed as a percentage (0.00–100.00) for customers in this segment. Measures both delivery timeliness and order completeness. Used in supply chain performance reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredTransportMode rdf:type rdf:Property ;
    rdfs:label 'Preferred Transport Mode' ;
    rdfs:comment 'Primary transport mode preference for customers in this segment (AIR, OCEAN, ROAD, RAIL, or MULTIMODAL). Used in SAP TM carrier selection and route planning to pre-configure default routing for segment accounts.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModelCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Code' ;
    rdfs:comment 'Code identifying the pricing model applied to customers in this segment (e.g., CONTRACTED_RATE, SPOT_RATE, VOLUME_DISCOUNT, TARIFF_PUBLISHED). Drives charge calculation in SAP TM and Oracle TMS. Confidential as it reflects commercial pricing strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTradeLane rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Lane' ;
    rdfs:comment 'Primary trade lane or corridor associated with this segment (e.g., \'ASIA_PACIFIC_TO_EUROPE\', \'TRANSPACIFIC\', \'INTRA_EUROPE\'). Used for network capacity planning and freight forwarding rate management.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realTimeVisibilityEligible rdf:type rdf:Property ;
    rdfs:label 'Real Time Visibility Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are entitled to real-time shipment tracking and predictive ETA services via FourKites. Typically reserved for STRATEGIC and PREMIUM commercial tiers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueBandMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Max Usd' ;
    rdfs:comment 'Maximum annualised revenue threshold in USD defining the upper boundary of this segment\'s revenue band. NULL indicates an open-ended upper bound (e.g., for the highest-tier segment). Used alongside revenue_band_min_usd for segment qualification.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBandMinUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Min Usd' ;
    rdfs:comment 'Minimum annualised revenue threshold in USD that a customer account must meet to qualify for this segment. Used in segment assignment logic and periodic segment review cycles. Expressed in USD for global comparability.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCriteria rdf:type rdf:Property ;
    rdfs:label 'Review Criteria' ;
    rdfs:comment 'Narrative description of the criteria used during the segment review cycle to determine whether a customer account should be upgraded, downgraded, or retained in this segment (e.g., revenue performance, shipment volume, strategic partnership status).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'Frequency at which customer accounts assigned to this segment are reviewed for re-segmentation based on updated revenue, volume, and strategic criteria. Drives the account management review calendar in Salesforce CRM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the customer segment (e.g., ENT-GOLD, SME-SILVER, B2C-STANDARD). Used as the business key across CRM, TMS, and billing systems. Sourced from Salesforce CRM account segmentation module.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment\'s commercial profile, target customer characteristics, and strategic intent. Used for onboarding account managers and informing pricing strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment (e.g., \'Enterprise Gold\', \'SME Silver\', \'B2C Standard\'). Used in reporting dashboards, account management workflows, and commercial strategy documents.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment definition: ACTIVE = in use for customer assignment and pricing; INACTIVE = suspended from new customer assignments; DRAFT = under review and not yet published; DEPRECATED = retired segment retained for historical reporting only.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Broad classification of the segment by customer relationship type: B2B (business-to-business enterprise accounts), B2C (individual consumer shippers), 3PL (Third-Party Logistics partners), 4PL (Fourth-Party Logistics orchestrators), GOVERNMENT (public sector entities), or INTERNAL (intra-company accounts).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentVolumeBandMax rdf:type rdf:Property ;
    rdfs:label 'Shipment Volume Band Max' ;
    rdfs:comment 'Maximum annualised shipment volume (number of shipments) defining the upper boundary of this segment\'s volume band. NULL indicates open-ended upper bound for the highest-volume segment tier.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentVolumeBandMin rdf:type rdf:Property ;
    rdfs:label 'Shipment Volume Band Min' ;
    rdfs:comment 'Minimum annualised shipment volume (number of shipments) threshold for segment qualification. Complements revenue thresholds for volume-based segmentation used in logistics pricing and SLA assignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityReportingEligible rdf:type rdf:Property ;
    rdfs:label 'Sustainability Reporting Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are entitled to receive Carbon Dioxide Equivalent (CO2e) and Greenhouse Gas (GHG) emissions reporting for their shipments. Supports customer ESG compliance and EU ETS reporting obligations.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerVolumeCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Volume Commitment Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer volume commitment record in the Transport Shipping lakehouse silver layer.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Volume commitments drive revenue budgets and must be reconciled against budget targets for variance analysis and incentive/penalty calculations. Logistics companies use volume commitments to forecast ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:crmOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Id' ;
    rdfs:comment 'Salesforce CRM Opportunity record ID that originated or is associated with this volume commitment. Enables traceability from sales pipeline to operational commitment.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:accruedIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Incentive Amount' ;
    rdfs:comment 'Rebate or incentive amount accrued to date in the current measurement period based on current volume over-performance. Used for financial provisioning in SAP S/4HANA Finance. Expressed in currency_code.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accruedPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Penalty Amount' ;
    rdfs:comment 'Financial penalty amount accrued to date in the current measurement period based on current volume shortfall. Used for financial provisioning in SAP S/4HANA Finance. Expressed in currency_code.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualVolumeToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Volume To Date' ;
    rdfs:comment 'Cumulative actual volume shipped by the customer within the current measurement period as of the last data refresh. Expressed in volume_unit. Sourced from Oracle TMS shipment execution records.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Pct' ;
    rdfs:comment 'Volume attainment percentage below which a performance alert is triggered for proactive account management intervention. Typically set above the penalty threshold to allow corrective action.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenew rdf:type rdf:Property ;
    rdfs:label 'Auto Renew' ;
    rdfs:comment 'Indicates whether this volume commitment automatically renews for the next period upon expiry without requiring a new negotiation cycle.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentName rdf:type rdf:Property ;
    rdfs:label 'Commitment Name' ;
    rdfs:comment 'Descriptive name for the volume commitment agreement, e.g., \'FY2025 Asia-Pacific Ocean FCL Annual Commitment\'. Used for display and reporting purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Number' ;
    rdfs:comment 'Externally-known business identifier for this volume commitment, used in customer communications, invoices, and operational reporting. Sourced from SAP TM freight agreement numbering.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveApplicable rdf:type rdf:Property ;
    rdfs:label 'Incentive Applicable' ;
    rdfs:comment 'Indicates whether a financial incentive or rebate clause is active for this commitment when the customer meets or exceeds the target volume.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveRatePct rdf:type rdf:Property ;
    rdfs:label 'Incentive Rate Pct' ;
    rdfs:comment 'Rebate or discount rate applied to the qualifying volume to calculate the incentive amount. Expressed as a percentage of the contracted rate per unit.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Incentive Threshold Pct' ;
    rdfs:comment 'Minimum volume attainment percentage at or above which the incentive or rebate clause is triggered. For example, 100.00 means incentives apply when the customer meets 100% of committed volume.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Shipment load type classification for this commitment. FCL (Full Container Load), LCL (Less Than Container Load), FTL (Full Truckload), LTL (Less Than Truckload), parcel, or bulk. Determines how committed volume is measured and rated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable' ;
    rdfs:comment 'Indicates whether a financial penalty clause is active for this commitment when the customer fails to meet the committed volume threshold.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Amount' ;
    rdfs:comment 'Maximum financial penalty amount that can be charged to the customer in a single measurement period, regardless of the shortfall volume. Expressed in currency_code.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Pct' ;
    rdfs:comment 'Rate applied to the shortfall volume to calculate the financial penalty amount. Expressed as a percentage of the contracted rate per unit.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Penalty Threshold Pct' ;
    rdfs:comment 'Minimum volume attainment percentage below which the penalty clause is triggered. For example, 80.00 means penalties apply if the customer ships less than 80% of committed volume.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceAlertTriggered rdf:type rdf:Property ;
    rdfs:label 'Performance Alert Triggered' ;
    rdfs:comment 'Indicates whether a volume under-performance alert has been triggered for this commitment in the current measurement period, prompting account manager intervention.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Frequency at which the volume commitment performance is formally reviewed with the customer. May differ from measurement_period_type (e.g., measured monthly but reviewed quarterly).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverShortfallApplicable rdf:type rdf:Property ;
    rdfs:label 'Rollover Shortfall Applicable' ;
    rdfs:comment 'Indicates whether any volume shortfall from the current measurement period can be carried forward and offset against the next period\'s commitment before penalties are assessed.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeAttainmentPct rdf:type rdf:Property ;
    rdfs:label 'Volume Attainment Pct' ;
    rdfs:comment 'Percentage of committed volume achieved to date within the measurement period (actual_volume_to_date / committed_volume * 100). Used for performance dashboards and penalty/incentive trigger evaluation.' ;
    rdfs:domain ind:CustomerVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecommerceSellerId rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Seller Id' ;
    rdfs:comment 'Unique surrogate identifier for the e-commerce seller profile within Transport Shipping\'s fulfillment platform. Primary key for this entity. Role: MASTER_PARTY.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcommerceSeller .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'Reference to the Transport Shipping employee responsible for managing the seller relationship, sourced from Workday HCM. Used for account ownership reporting and escalation routing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryEcommercePreferredFulfillmentCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Ecommerce Preferred Fulfillment Center Id' ;
    rdfs:comment 'Reference to the seller\'s primary preferred fulfillment center for inventory storage and order processing. Used by Manhattan WMS for default inbound routing and order assignment.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Center .

ind:routeDeliveryZoneId rdf:type rdf:Property ;
    rdfs:label 'Route Delivery Zone Id' ;
    rdfs:comment 'Foreign key linking to route.route_delivery_zone. Business justification: E-commerce sellers have defined serviceable delivery zones for coverage management. Powers seller coverage area validation, zone-based service eligibility checks, delivery promise calculation, and mar' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RouteDeliveryZone .

ind:shipperProfileId rdf:type rdf:Property ;
    rdfs:label 'Shipper Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.shipper_profile. Business justification: Ecommerce sellers are operational shippers requiring link to shipper_profile for shipment origination, pickup coordination, customs documentation, and service preferences. Critical for e-commerce fulf' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipperProfile .

ind:apiIntegrationType rdf:type rdf:Property ;
    rdfs:label 'Api Integration Type' ;
    rdfs:comment 'Method by which the seller\'s marketplace platform is integrated with Transport Shipping\'s order management and fulfillment systems for automated order ingestion and status updates.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgDailyOrderVolume rdf:type rdf:Property ;
    rdfs:label 'Avg Daily Order Volume' ;
    rdfs:comment 'Seller-declared or contractually agreed average number of orders processed per day. Used for fulfillment center capacity allocation, labor planning, and SLA configuration. Not a calculated metric — this is the agreed baseline figure from the seller\'s onboarding profile.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cod Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for COD collection and remittance to the seller. Determines the currency in which COD amounts are collected from consignees and settled.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codEnabled rdf:type rdf:Property ;
    rdfs:label 'Cod Enabled' ;
    rdfs:comment 'Indicates whether Cash on Delivery (COD) payment collection is enabled for this seller\'s shipments. Activates COD settlement workflows and remittance reporting in the finance system.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codSettlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Cod Settlement Frequency' ;
    rdfs:comment 'Frequency at which collected Cash on Delivery (COD) amounts are remitted to the seller. Drives the COD settlement batch schedule in SAP S/4HANA Finance accounts payable.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSellerCode rdf:type rdf:Property ;
    rdfs:label 'Crm Seller Code' ;
    rdfs:comment 'External identifier for this seller record as maintained in Salesforce CRM, used for cross-system reconciliation between the data lakehouse and the CRM system of record.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Border Enabled' ;
    rdfs:comment 'Indicates whether the seller is configured for cross-border shipping services, enabling customs brokerage workflows in Descartes Customs and international carrier selection in SAP TM.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Registration Number' ;
    rdfs:comment 'Seller\'s customs registration or importer/exporter code as issued by the relevant customs authority. Required for cross-border shipment declarations processed through Descartes Customs.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:d2dServiceEnabled rdf:type rdf:Property ;
    rdfs:label 'D2d Service Enabled' ;
    rdfs:comment 'Indicates whether the seller has Door-to-Door (D2D) end-to-end fulfillment service configured, covering pickup from seller\'s origin through last-mile delivery to end consumer.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epodRequired rdf:type rdf:Property ;
    rdfs:label 'Epod Required' ;
    rdfs:comment 'Indicates whether Electronic Proof of Delivery (ePOD) capture is mandatory for all outbound deliveries for this seller. Drives last-mile delivery driver workflow configuration in FourKites.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the seller is certified to ship hazardous materials, enabling dangerous goods handling workflows compliant with IMDG Code and ICAO Technical Instructions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsCodeDefault rdf:type rdf:Property ;
    rdfs:label 'Hs Code Default' ;
    rdfs:comment 'Default Harmonized System (HS) Code representing the seller\'s primary product category for customs tariff classification. Used as a fallback in Descartes Customs when SKU-level HS codes are not available.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Method' ;
    rdfs:comment 'Inventory rotation method applied to the seller\'s stock in the fulfillment center. First In First Out (FIFO) and First Expired First Out (FEFO) are most common for e-commerce fulfillment in Manhattan WMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplacePlatform rdf:type rdf:Property ;
    rdfs:label 'Marketplace Platform' ;
    rdfs:comment 'Primary e-commerce marketplace or platform through which the seller operates and from which orders are ingested into Transport Shipping\'s fulfillment system via API or EDI integration. [ENUM-REF-CANDIDATE: shopify|amazon|ebay|woocommerce|magento|tiktok_shop|lazada|zalando|other — promote to reference product]' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplaceSellerCode rdf:type rdf:Property ;
    rdfs:label 'Marketplace Seller Code' ;
    rdfs:comment 'The seller\'s unique identifier as assigned by their primary marketplace platform (e.g., Amazon Seller ID, Shopify Shop ID). Used for API-based order ingestion and reconciliation.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offboardingDate rdf:type rdf:Property ;
    rdfs:label 'Offboarding Date' ;
    rdfs:comment 'Date on which the e-commerce seller was offboarded or their account was closed. Null for active sellers. Used for churn analysis and contract closure reporting.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peakDailyOrderVolume rdf:type rdf:Property ;
    rdfs:label 'Peak Daily Order Volume' ;
    rdfs:comment 'Seller-declared maximum daily order volume during peak periods (e.g., promotional events, holiday seasons). Used for surge capacity planning and contingency fulfillment resource allocation.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnRatePct rdf:type rdf:Property ;
    rdfs:label 'Return Rate Pct' ;
    rdfs:comment 'Seller-declared or contractually agreed return rate expressed as a percentage of total orders. Drives Return Merchandise Authorization (RMA) processing capacity allocation and reverse logistics planning at fulfillment centers.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellerCode rdf:type rdf:Property ;
    rdfs:label 'Seller Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the seller for use in operational systems including the Warehouse Management System (WMS), Transportation Management System (TMS), and Electronic Data Interchange (EDI) integrations.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerName rdf:type rdf:Property ;
    rdfs:label 'Seller Name' ;
    rdfs:comment 'Legal or registered trading name of the e-commerce seller as used on marketplace platforms and fulfillment agreements. Serves as the primary human-readable identity label for the seller.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerStatus rdf:type rdf:Property ;
    rdfs:label 'Seller Status' ;
    rdfs:comment 'Current lifecycle status of the e-commerce seller account. Drives operational eligibility for order intake, fulfillment center assignment, and last-mile delivery service activation.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerType rdf:type rdf:Property ;
    rdfs:label 'Seller Type' ;
    rdfs:comment 'Classification of the seller by their business model and relationship type with Transport Shipping. Determines applicable service configurations, pricing tiers, and fulfillment workflows. [ENUM-REF-CANDIDATE: marketplace_seller|direct_brand|dropshipper|3pl_client|4pl_client|cross_border — promote to reference product]' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCatalogSize rdf:type rdf:Property ;
    rdfs:label 'Sku Catalog Size' ;
    rdfs:comment 'Total number of active Stock Keeping Units (SKUs) in the seller\'s product catalog managed within Transport Shipping\'s fulfillment network. Used for warehouse slotting optimization in Manhattan WMS and capacity planning.' ;
    rdfs:domain ind:EcommerceSeller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kycVerificationId rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Id' ;
    rdfs:comment 'Unique surrogate identifier for each KYC/AML verification record within the customer domain. Primary key for this entity.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: KYC/AML verification must be performed by designated compliance officers per regulatory requirements (AML, trade compliance). Tracks accountability for denied party screening and risk assessment decis' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:verifiedTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Verified Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: KYC verification validates trade party identities for customs compliance. Required for: denied party screening, AEO/CTPAT eligibility determination, beneficial ownership verification, and ensuring cus' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:adverseMediaFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Flag' ;
    rdfs:comment 'Indicates whether adverse media or negative news coverage was identified for the verified entity during the KYC/AML screening process, triggering additional compliance review.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adverseMediaNotes rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Notes' ;
    rdfs:comment 'Free-text notes summarising adverse media findings identified during KYC screening. Captured by the compliance analyst for audit and escalation purposes.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerName rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Name' ;
    rdfs:comment 'Full legal name of the ultimate beneficial owner (UBO) of the corporate entity, as identified during KYC/AML due diligence. Required under FATF Recommendation 24 for corporate transparency.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerOwnershipPct rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Ownership Pct' ;
    rdfs:comment 'Percentage ownership stake held by the identified beneficial owner in the verified corporate entity. Typically a threshold of 25% or more triggers UBO disclosure requirements.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for compliance analyst notes, observations, or qualifications related to this KYC/AML verification record. Supports audit trail and regulatory review.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Eligible Flag' ;
    rdfs:comment 'Indicates whether the customer is cleared for cross-border shipment processing based on the outcome of KYC/AML and denied party screening. A false value blocks international shipment creation.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deniedPartyResult rdf:type rdf:Property ;
    rdfs:label 'Denied Party Result' ;
    rdfs:comment 'Outcome of the denied party screening check against C-TPAT, AEO, OFAC, and other watchlists. A \'match\' or \'potential_match\' result blocks cross-border shipment processing until resolved.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Date' ;
    rdfs:comment 'Expiry date of the supporting identity or business document submitted for KYC verification. Triggers document renewal alerts when approaching expiry.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'Document Issuing Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the authority that issued the supporting KYC document. Used for cross-border trade compliance and sanctions jurisdiction analysis.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enhancedDueDiligenceFlag rdf:type rdf:Property ;
    rdfs:label 'Enhanced Due Diligence Flag' ;
    rdfs:comment 'Indicates whether Enhanced Due Diligence (EDD) procedures were applied to this KYC verification, typically triggered by high-risk classification, PEP status, or sanctions proximity.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code identifying the regulatory jurisdiction under which this KYC/AML verification was conducted. Determines applicable compliance frameworks and reporting obligations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicallyExposedPersonFlag rdf:type rdf:Property ;
    rdfs:label 'Politically Exposed Person Flag' ;
    rdfs:comment 'Indicates whether the verified individual or beneficial owner has been identified as a Politically Exposed Person (PEP), requiring enhanced due diligence under FATF guidelines.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk classification assigned to the customer based on the outcome of KYC/AML screening. Drives enhanced due diligence (EDD) requirements, shipment restrictions, and account review frequency.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numeric risk score (typically 0–100) assigned by the screening system or compliance analyst, reflecting the aggregate risk profile of the customer based on KYC/AML findings.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'The date on which the KYC/AML screening or verification check was performed. Used to determine currency of compliance and trigger renewal workflows.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningProvider rdf:type rdf:Property ;
    rdfs:label 'Screening Provider' ;
    rdfs:comment 'Name of the third-party screening or KYC/AML service provider used to conduct the verification (e.g., Descartes Denied Party Screening, Refinitiv World-Check, Dow Jones Risk & Compliance).' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningProviderReference rdf:type rdf:Property ;
    rdfs:label 'Screening Provider Reference' ;
    rdfs:comment 'Unique reference or case number assigned by the third-party screening provider for this verification event. Used for audit trail and dispute resolution with the provider.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Identifier of the originating record in the source system (e.g., Descartes Customs case ID or Salesforce CRM record ID) for lineage tracing and reconciliation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued Tax Identification Number (TIN) or equivalent fiscal identifier of the verified entity. Required for customs declarations, trade finance, and cross-border compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeFinanceEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Finance Eligible Flag' ;
    rdfs:comment 'Indicates whether the customer has passed KYC/AML requirements and is eligible for trade finance services including letters of credit, documentary collections, and supply chain finance.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Number' ;
    rdfs:comment 'Externally-known business reference number assigned to this KYC/AML verification case, used for correspondence with compliance teams, regulators, and third-party screening providers.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current lifecycle status of the KYC/AML verification record. Drives eligibility for cross-border shipping, trade finance, and onboarding workflows.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationType rdf:type rdf:Property ;
    rdfs:label 'Verification Type' ;
    rdfs:comment 'Category of KYC/AML verification performed. Distinguishes between identity verification of individuals, business registration checks for corporate entities, sanctions screening against watchlists, Anti-Money Laundering (AML) checks, beneficial ownership verification, and credit checks. [ENUM-REF-CANDIDATE: identity|business_registration|sanctions_screening|aml_check|beneficial_owner|credit_check|trade_compliance|pep_screening — promote to reference product]' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedEntityName rdf:type rdf:Property ;
    rdfs:label 'Verified Entity Name' ;
    rdfs:comment 'Legal name of the individual or business entity as verified during the KYC process. May differ from the trading name on the customer account. Classified as restricted PII.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedEntityType rdf:type rdf:Property ;
    rdfs:label 'Verified Entity Type' ;
    rdfs:comment 'Classification of the entity subject to KYC verification. Determines the applicable verification procedures, document requirements, and regulatory obligations.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistSource rdf:type rdf:Property ;
    rdfs:label 'Watchlist Source' ;
    rdfs:comment 'Name or identifier of the watchlist or denied party database against which the screening was performed (e.g., OFAC SDN, EU Consolidated List, UN Sanctions, BIS Entity List, C-TPAT). Multiple sources may be concatenated.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadId rdf:type rdf:Property ;
    rdfs:label 'Lead Id' ;
    rdfs:comment 'Unique surrogate identifier for the prospective customer lead record in the Transport Shipping data platform. Primary key for the lead entity.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedSdrEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sdr Employee Id' ;
    rdfs:comment 'Internal employee identifier of the Sales Development Representative (SDR) assigned to work and qualify this lead. Used for workload balancing, performance tracking, and commission attribution.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:convertedOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Converted Opportunity Id' ;
    rdfs:comment 'Salesforce CRM Opportunity object ID created upon lead conversion. Enables traceability from top-of-funnel lead to mid-funnel opportunity for pipeline attribution and revenue forecasting.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:referralNetworkPartnerId rdf:type rdf:Property ;
    rdfs:label 'Referral Network Partner Id' ;
    rdfs:comment 'Foreign key linking to network.network_partner. Business justification: Lead source attribution for partner referrals enables commission tracking, partner ROI analysis, and lead quality assessment by referral source. Replaces denormalized referral_partner_name with struct' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Identifier of the marketing campaign that generated or influenced this lead. Used for campaign attribution, marketing ROI analysis, and multi-touch attribution modelling.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Calendar date on which the lead was converted to an opportunity or customer account. Null if not yet converted. Used for conversion velocity analysis and sales cycle benchmarking.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmLeadCode rdf:type rdf:Property ;
    rdfs:label 'Crm Lead Code' ;
    rdfs:comment 'External lead identifier sourced from Salesforce CRM (Lead object ID, e.g., 00Q...). Used for cross-system reconciliation between the lakehouse and Salesforce CRM.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates whether the lead contact has opted out of or must be excluded from all sales and marketing communications. True = do not contact. Mandatory for GDPR and CAN-SPAM compliance.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedAnnualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue Usd' ;
    rdfs:comment 'Estimated annual logistics spend or revenue opportunity associated with the lead, expressed in US Dollars. Used for deal sizing, prioritisation, and pipeline value reporting. Currency is standardised to USD for global comparability.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMonthlyShipments rdf:type rdf:Property ;
    rdfs:label 'Estimated Monthly Shipments' ;
    rdfs:comment 'Prospect\'s self-reported or SDR-estimated number of shipments per month. Used for revenue potential sizing, capacity planning discussions, and lead qualification scoring.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTeuVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Teu Volume' ;
    rdfs:comment 'Prospect\'s estimated annual ocean freight volume expressed in Twenty-foot Equivalent Units (TEUs). Relevant for ocean freight forwarding leads; used for capacity planning and rate negotiation preparation.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprConsentGiven rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Given' ;
    rdfs:comment 'Indicates whether the lead contact has provided explicit GDPR consent for Transport Shipping to process their personal data for sales and marketing purposes. True = consent given. Required for EU/EEA leads under GDPR Article 6.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConverted rdf:type rdf:Property ;
    rdfs:label 'Is Converted' ;
    rdfs:comment 'Indicates whether the lead has been successfully converted to a Salesforce opportunity or a Transport Shipping customer account. True = converted; False = not yet converted.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadStatus rdf:type rdf:Property ;
    rdfs:label 'Lead Status' ;
    rdfs:comment 'Current stage of the lead in the top-of-funnel commercial pipeline. Drives workflow routing, SDR task assignment, and pipeline reporting. Values: new (just created), working (SDR actively engaging), nurturing (long-term follow-up), qualified (meets ICP criteria), unqualified (disqualified), converted (promoted to opportunity or account).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadType rdf:type rdf:Property ;
    rdfs:label 'Lead Type' ;
    rdfs:comment 'Categorical classification of the lead by business model and relationship type. Distinguishes B2B enterprise accounts, small-to-medium enterprises (SMEs), individual B2C shippers, and third-party logistics (3PL) or fourth-party logistics (4PL) partner prospects.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowupDate rdf:type rdf:Property ;
    rdfs:label 'Next Followup Date' ;
    rdfs:comment 'Scheduled date for the next SDR follow-up action on this lead. Used for task management, pipeline cadence enforcement, and SDR productivity reporting.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationMethod rdf:type rdf:Property ;
    rdfs:label 'Qualification Method' ;
    rdfs:comment 'Methodology used to qualify and score the lead (e.g., BANT — Budget, Authority, Need, Timeline; MEDDIC; SPIN; manual SDR assessment; AI-assisted scoring). Provides context for interpreting the qualification score.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScore rdf:type rdf:Property ;
    rdfs:label 'Qualification Score' ;
    rdfs:comment 'Numeric score (typically 0–100) assigned to the lead based on qualification criteria such as budget, authority, need, and timeline (BANT). Drives prioritisation of SDR effort and pipeline forecasting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresCustomsBrokerage rdf:type rdf:Property ;
    rdfs:label 'Requires Customs Brokerage' ;
    rdfs:comment 'Indicates whether the prospect requires customs brokerage and trade compliance services as part of their logistics solution. True = customs brokerage required. Informs cross-sell opportunity identification and Descartes Customs onboarding pre-qualification.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresWarehousing rdf:type rdf:Property ;
    rdfs:label 'Requires Warehousing' ;
    rdfs:comment 'Indicates whether the prospect requires warehousing and distribution services (e.g., contract warehousing, distribution centre management). True = warehousing required. Informs cross-sell opportunity identification and Manhattan WMS capacity planning.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Code' ;
    rdfs:comment 'Code identifying the geographic or segment-based sales territory to which this lead is assigned. Supports territory-based pipeline reporting, quota management, and SDR routing.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceInterest rdf:type rdf:Property ;
    rdfs:label 'Service Interest' ;
    rdfs:comment 'Primary logistics service category the lead has expressed interest in. Drives routing to the appropriate product sales specialist and informs service-level proposal preparation. [ENUM-REF-CANDIDATE: express_parcel|freight_forwarding|supply_chain_mgmt|customs_brokerage|warehouse_distribution|ecommerce_fulfillment|last_mile|contract_logistics|cross_border — promote to reference product]' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTierInterest rdf:type rdf:Property ;
    rdfs:label 'Sla Tier Interest' ;
    rdfs:comment 'Prospect\'s indicated interest in a specific Service Level Agreement (SLA) tier. Used to align commercial proposals with the appropriate service tier and pricing band during the qualification process.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportModeInterest rdf:type rdf:Property ;
    rdfs:label 'Transport Mode Interest' ;
    rdfs:comment 'Preferred or required freight transport mode indicated by the lead. Informs freight forwarding product alignment (air freight, ocean freight, road, rail, or multimodal) and capacity planning discussions.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unqualifiedReason rdf:type rdf:Property ;
    rdfs:label 'Unqualified Reason' ;
    rdfs:comment 'Reason code explaining why the lead was marked as unqualified. Populated when lead_status = \'unqualified\'. Used for pipeline quality analysis and SDR coaching. [ENUM-REF-CANDIDATE: no_budget|no_authority|no_need|wrong_geography|competitor_selected|no_response|duplicate — promote to reference product]' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Id' ;
    rdfs:comment 'Unique system-generated identifier for the customer onboarding record. Primary key for the onboarding data product.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Onboarding processes require tracking primary customer contact for implementation coordination, training scheduling, system provisioning, and go-live communication. Essential for customer onboarding w' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:salesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Id' ;
    rdfs:comment 'External identifier from Salesforce CRM linking this onboarding record to the originating sales opportunity that triggered the onboarding process.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:actualGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Actual Go Live Date' ;
    rdfs:comment 'The actual date on which the customer was activated and went live on Transport Shipping systems. Compared against target_go_live_date to measure onboarding cycle time adherence and SLA compliance.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amlStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Status' ;
    rdfs:comment 'Status of the Anti-Money Laundering (AML) screening check performed during onboarding. Includes sanctions list screening, denied party checks, and financial crime risk assessment. A flagged or rejected status blocks account activation.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Api Integration Status' ;
    rdfs:comment 'Status of the API integration setup for customers using direct API connectivity to Transport Shipping platforms for booking, tracking, and rate queries. Distinct from EDI for customers using REST/SOAP API channels.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Checklist Completion Pct' ;
    rdfs:comment 'Percentage of onboarding checklist items that have been completed. Provides a single numeric indicator of overall onboarding progress for dashboards and SLA monitoring. Calculated from checklist item statuses in the onboarding checklist sub-entity.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedChecklistItems rdf:type rdf:Property ;
    rdfs:label 'Completed Checklist Items' ;
    rdfs:comment 'Number of onboarding checklist items that have been marked as completed. Used alongside total_checklist_items to track onboarding progress and identify bottlenecks.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Assessment Status' ;
    rdfs:comment 'Status of the credit risk assessment conducted during customer onboarding. Determines credit terms, payment conditions, and credit limit to be assigned. Conditionally approved may indicate a reduced credit limit or requirement for prepayment.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRegistrationRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Registration Required' ;
    rdfs:comment 'Indicates whether the customer requires customs brokerage registration and trade compliance setup as part of onboarding. Triggers Descartes Customs configuration, HS code profile setup, and AEO/C-TPAT compliance checks.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsSetupStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Setup Status' ;
    rdfs:comment 'Status of the customs and trade compliance configuration in Descartes Customs for the customer. Includes denied party screening profile, tariff classification preferences, and import/export license registration.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataConsentDate rdf:type rdf:Property ;
    rdfs:label 'Data Consent Date' ;
    rdfs:comment 'The date on which the customer provided explicit consent for data processing. Required for GDPR compliance audit trail and consent management.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataProcessingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Processing Consent' ;
    rdfs:comment 'Indicates whether the customer has provided explicit consent for processing of their personal and business data in accordance with GDPR and applicable data protection regulations. Must be TRUE before account activation.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediSetupStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Setup Status' ;
    rdfs:comment 'Status of the Electronic Data Interchange (EDI) integration setup for the customer. EDI enables automated exchange of shipment orders, ASNs, invoices, and status messages between the customer\'s systems and Transport Shipping platforms.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'The date on which the customer onboarding process was formally initiated, typically coinciding with account creation or CRM opportunity conversion. Used as the start anchor for SLA and cycle time calculations.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycAmlCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Aml Completed Date' ;
    rdfs:comment 'The date on which both the Know Your Customer (KYC) and Anti-Money Laundering (AML) verification processes were successfully completed and approved for this customer onboarding.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current status of the Know Your Customer (KYC) identity verification process for the customer. Mandatory regulatory due diligence step before account activation. Tracks progression from pending submission through review, approval, or rejection.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the assigned onboarding manager. Retained for operational reference and reporting without requiring a join to the HR system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHoldReason rdf:type rdf:Property ;
    rdfs:label 'On Hold Reason' ;
    rdfs:comment 'Reason code explaining why the onboarding process has been placed on hold. Used for exception management, escalation tracking, and reporting on onboarding bottlenecks. [ENUM-REF-CANDIDATE: kyc_aml_pending|credit_review|document_missing|customer_unresponsive|system_issue|legal_review|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Overall lifecycle status of the onboarding record, distinct from the granular stage. Indicates whether the onboarding is actively progressing, completed, paused, or terminated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text field capturing regulatory due diligence observations, compliance exceptions, or special conditions noted during the onboarding process. Supports audit trail requirements under C-TPAT, AEO, and GDPR accountability obligations.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the end-to-end customer onboarding lifecycle. Tracks progression from initial account creation through KYC/AML, credit assessment, system provisioning, training, and final activation. [ENUM-REF-CANDIDATE: initiated|kyc_aml_review|credit_assessment|system_provisioning|training|go_live_pending|active|on_hold|cancelled — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Target Go Live Date' ;
    rdfs:comment 'The planned date by which the customer is expected to be fully activated and operationally live on Transport Shipping systems. Used for SLA tracking and resource planning.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tmsProvisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Tms Provisioning Status' ;
    rdfs:comment 'Status of the customer account provisioning in the Transportation Management System (TMS — SAP TM or Oracle TMS). Tracks whether the customer has been set up for shipment booking, freight order management, and rate access.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChecklistItems rdf:type rdf:Property ;
    rdfs:label 'Total Checklist Items' ;
    rdfs:comment 'Total number of onboarding checklist items assigned to this customer onboarding record. Used as the denominator for checklist completion percentage and for workload tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Training Completed Date' ;
    rdfs:comment 'The date on which the customer completed all required onboarding training modules. Used to confirm readiness for go-live and to satisfy compliance documentation requirements.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Status of the customer training program completion during onboarding. Training covers platform usage, booking procedures, compliance requirements, and service-specific processes. Waived status applies for experienced customers or self-serve digital onboarding.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsProvisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Wms Provisioning Status' ;
    rdfs:comment 'Status of the customer account provisioning in the Warehouse Management System (WMS — Manhattan WMS). Applicable for customers requiring warehousing, distribution, or e-commerce fulfillment services.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Unique surrogate identifier for the sales opportunity record in the Transport Shipping data lakehouse. Primary key for the opportunity entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:quotedCarrierId rdf:type rdf:Property ;
    rdfs:label 'Quoted Carrier Id' ;
    rdfs:comment 'Foreign key linking to network.carrier. Business justification: Sales RFP process requires tracking which carriers were quoted in each opportunity for win/loss analysis, rate benchmarking, and carrier performance correlation with deal closure. Essential for sales ' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:spotQuoteId rdf:type rdf:Property ;
    rdfs:label 'Spot Quote Id' ;
    rdfs:comment 'Foreign key linking to pricing.spot_quote. Business justification: Sales opportunities track spot quotes issued to prospects. Essential for quote-to-close analysis, win/loss reporting, and converting quoted rates to contract rates. Enables sales pipeline visibility i' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpotQuote .

ind:targetLaneId rdf:type rdf:Property ;
    rdfs:label 'Target Lane Id' ;
    rdfs:comment 'Foreign key linking to route.lane. Business justification: Sales opportunities target specific lane business for revenue forecasting. Enables lane-level pipeline analysis, competitive lane assessment, new lane business development tracking, and capacity plann' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'The actual date on which the opportunity was closed, either as a won deal or a lost deal. Populated upon stage transition to Closed Won or Closed Lost. Used for sales cycle duration analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Close Probability Pct' ;
    rdfs:comment 'Estimated probability (0.00–100.00%) that this opportunity will be successfully closed and converted to an active account. Drives weighted pipeline calculations and revenue forecasting models.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the primary competing logistics provider identified during the sales process. Supports competitive intelligence analysis, win/loss reporting, and strategic positioning decisions.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorStrength rdf:type rdf:Property ;
    rdfs:label 'Competitor Strength' ;
    rdfs:comment 'Sales team\'s assessment of the primary competitor\'s relative strength in this opportunity. Informs deal strategy, pricing decisions, and escalation requirements.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Anticipated or confirmed date on which the customer contract or service agreement resulting from this opportunity is expected to become effective. Supports revenue recognition scheduling per IFRS 15.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmOpportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the opportunity as assigned by Salesforce CRM (e.g., OPP-2024-00123). Used for cross-system reference and customer-facing communications.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Crm Source System' ;
    rdfs:comment 'Identifies the source CRM system from which this opportunity record was ingested into the data lakehouse. Supports data lineage tracking and multi-system reconciliation.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerageRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Required' ;
    rdfs:comment 'Indicates whether customs brokerage and trade compliance services are required as part of the proposed solution for this opportunity. Triggers engagement of the customs and trade compliance team.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecommerceFulfillmentRequired rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Fulfillment Required' ;
    rdfs:comment 'Indicates whether the opportunity includes e-commerce fulfillment services such as last-mile delivery, returns management (RMA), or direct-to-consumer (D2D) distribution.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedAnnualRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue' ;
    rdfs:comment 'Projected annual revenue value (in the deal currency) expected from this opportunity if successfully closed. Used for pipeline valuation, quota attainment tracking, and revenue forecasting. Represents the gross base amount of the deal.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualShipmentVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Shipment Volume' ;
    rdfs:comment 'Projected number of shipments or consignments per year expected under this opportunity. Supports capacity planning, network design, and operational readiness assessments.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedAnnualTeu rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Teu' ;
    rdfs:comment 'Projected annual ocean freight volume expressed in Twenty-foot Equivalent Units (TEU). Applicable for opportunities involving Full Container Load (FCL) or Less than Container Load (LCL) ocean freight services.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Weight Kg' ;
    rdfs:comment 'Projected total chargeable weight in kilograms per year associated with this opportunity. Used for freight capacity planning and rate negotiation with carriers.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executiveSponsor rdf:type rdf:Property ;
    rdfs:label 'Executive Sponsor' ;
    rdfs:comment 'Name or identifier of the Transport Shipping executive sponsor assigned to support the pursuit of this strategic opportunity. Relevant for large enterprise deals requiring C-level engagement.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Target date by which the sales team expects to close (win or lose) this opportunity. Used for pipeline aging analysis, quarterly forecasting, and sales cycle benchmarking.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Sales forecast classification indicating the sales team\'s confidence level in the opportunity\'s inclusion in the current period revenue forecast. Drives executive pipeline reviews and financial planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Required' ;
    rdfs:comment 'Indicates whether the opportunity involves the transport of hazardous materials or dangerous goods, requiring compliance with IMDG Code (ocean), ICAO Technical Instructions (air), or ADR (road) regulations.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrategic rdf:type rdf:Property ;
    rdfs:label 'Is Strategic' ;
    rdfs:comment 'Indicates whether this opportunity has been designated as strategically important, requiring executive sponsorship, dedicated pursuit resources, or special pricing authority.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Categorized reason why the opportunity was lost, populated upon transition to Closed Lost stage. Supports win/loss analysis and sales process improvement. [ENUM-REF-CANDIDATE: Price|Service Capability|Relationship|Competitor|No Decision|Timing|Compliance — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Free-text description of the immediate next action required to advance this opportunity through the sales pipeline (e.g., \'Schedule executive briefing\', \'Submit RFQ response by 2025-03-15\'). Supports sales activity management.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStepDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Step Due Date' ;
    rdfs:comment 'Target date by which the next sales action (as described in next_step) must be completed. Used for sales activity tracking and pipeline hygiene enforcement.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Human-readable descriptive name of the sales opportunity, typically combining the account name and the service scope (e.g., \'Acme Corp – Asia-Pacific Freight Forwarding 2025\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity by its commercial nature: new logo acquisition, renewal of an existing contract, upsell of additional volume or service tier, cross-sell of a complementary service line, or win-back of a churned account.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryServiceLine rdf:type rdf:Property ;
    rdfs:label 'Primary Service Line' ;
    rdfs:comment 'The dominant or anchor service line that represents the largest share of estimated revenue within this opportunity. Used for pipeline segmentation and sales team routing. [ENUM-REF-CANDIDATE: Express Parcel|Air Freight|Ocean Freight|Road Freight|Rail Freight|Customs Brokerage|Warehouse|E-Commerce Fulfillment|Last-Mile|Contract Logistics — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Submitted Date' ;
    rdfs:comment 'Date on which the formal commercial proposal or Rate Quotation (RFQ response) was submitted to the prospect. Used for sales cycle analysis and proposal-to-close conversion tracking.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfqReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Reference Number' ;
    rdfs:comment 'External reference number of the customer\'s Request for Quotation (RFQ) or tender document associated with this opportunity. Enables cross-referencing with procurement and pricing systems.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The sales channel through which this opportunity is being pursued (e.g., Direct field sales, Partner/agent network, Digital self-serve, Inside sales). Supports channel performance analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRegion rdf:type rdf:Property ;
    rdfs:label 'Sales Region' ;
    rdfs:comment 'Geographic sales territory or region to which this opportunity is assigned (e.g., \'APAC\', \'EMEA\', \'Americas\'). Used for regional pipeline reporting and quota management.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLinesInScope rdf:type rdf:Property ;
    rdfs:label 'Service Lines In Scope' ;
    rdfs:comment 'Comma-separated list of Transport Shipping service lines included in this opportunity (e.g., \'Express Parcel Delivery, Freight Forwarding – Air, E-Commerce Fulfillment\'). Captures the breadth of services being sold to support product mix analysis and capacity planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTierRequested rdf:type rdf:Property ;
    rdfs:label 'Sla Tier Requested' ;
    rdfs:comment 'The Service Level Agreement (SLA) tier requested by the prospect as part of the commercial proposal. Determines the On-Time Delivery (OTD) and On-Time In-Full (OTIF) commitments to be included in the contract.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stage Changed Timestamp' ;
    rdfs:comment 'Timestamp when the opportunity stage was last updated. Used to calculate stage duration, identify stalled opportunities, and measure sales velocity across pipeline stages.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureControlledRequired rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Required' ;
    rdfs:comment 'Indicates whether the opportunity requires temperature-controlled or cold chain logistics services. Triggers specialized equipment, facility, and compliance requirements in the solution design.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Partner Relationship Id' ;
    rdfs:comment 'Unique surrogate identifier for the logistics partner relationship record in the Transport Shipping data platform. Primary key for this entity.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Partner Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Partners (customs brokers, freight forwarders) are trade parties. Required for: customs broker assignment, power of attorney validation, broker license verification, and tracking broker performance on' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:apiConnectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Api Connectivity Status' ;
    rdfs:comment 'Current status of the API (Application Programming Interface) integration between Transport Shipping\'s TMS/WMS platforms and the partner\'s systems. Enables real-time shipment status, booking, and track-and-trace data exchange via FourKites or direct API.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedServiceScope rdf:type rdf:Property ;
    rdfs:label 'Authorized Service Scope' ;
    rdfs:comment 'Comma-delimited list of logistics service modes and activities the partner is authorized to perform on behalf of the customer. Examples include air freight, ocean FCL (Full Container Load), ocean LCL (Less Than Container Load), road FTL (Full Truckload), road LTL (Less Than Truckload), customs brokerage, last-mile delivery, and warehousing. Governs multi-party shipment orchestration rules.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'The externally-known contract or master service agreement number governing this partner relationship. Links to the contract and agreement domain for full contractual terms, rate schedules, and liability clauses. Used in SAP S/4HANA Finance for revenue recognition and cost allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingPermissionLevel rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Permission Level' ;
    rdfs:comment 'Governs the level of Transport Shipping customer and shipment data the partner is authorized to access and receive. None = no data shared; shipment_status = track-and-trace only; full_visibility = complete shipment and inventory data; restricted = custom scope defined in data sharing agreement. Enforces GDPR data minimization principles.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediConnectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Connectivity Status' ;
    rdfs:comment 'Current status of the EDI (Electronic Data Interchange) integration channel between Transport Shipping and the partner. Active indicates live message exchange; pending_setup indicates configuration in progress; testing indicates UAT phase; inactive indicates EDI is not in use.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediPartnerQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Partner Qualifier' ;
    rdfs:comment 'Two-digit EDI interchange qualifier code identifying the partner\'s ID type in EDI X12 or UN/EDIFACT message headers (e.g., 01 = DUNS, 08 = UCC, ZZ = mutually defined). Required for AMS (Automated Manifest System) and ISF (Importer Security Filing) submissions.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageRegions rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Regions' ;
    rdfs:comment 'Comma-delimited list of ISO 3166-1 alpha-3 country codes or regional zone identifiers representing the geographic territories where the partner is authorized to operate under this relationship. Drives lane-level partner assignment in SAP TM route planning.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the partner\'s cargo and liability insurance certificate. Required for high-value shipment authorization and claims processing. Validated against minimum coverage thresholds defined in the master service agreement.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the partner within Transport Shipping\'s TMS (Transportation Management System) and WMS (Warehouse Management System). Used in EDI (Electronic Data Interchange) message routing and SAP TM carrier/partner master.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLegalName rdf:type rdf:Property ;
    rdfs:label 'Partner Legal Name' ;
    rdfs:comment 'Full registered legal name of the third-party logistics partner organization as recorded in official trade and customs documentation. Used for AWB (Air Waybill), BOL (Bill of Lading), and customs declaration filings.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerRole rdf:type rdf:Property ;
    rdfs:label 'Partner Role' ;
    rdfs:comment 'Operational role the partner plays within the customer\'s logistics network. Subcontractor performs services under the customer\'s brand; agent acts on behalf of the customer; co_loader shares freight capacity; principal is the primary contracting party; associate is a non-binding collaborative partner.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTradingName rdf:type rdf:Property ;
    rdfs:label 'Partner Trading Name' ;
    rdfs:comment 'Commercial or brand name under which the partner operates, which may differ from the legal name. Used in operational communications, shipment documentation, and customer-facing reporting.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the logistics partner by operational role. 3PL (Third-Party Logistics) provides outsourced logistics services; 4PL (Fourth-Party Logistics) manages the entire supply chain; NVOCC (Non-Vessel Operating Common Carrier) issues house bills of lading; freight_broker arranges carrier capacity; customs_broker handles trade compliance; co_loader shares container capacity. [ENUM-REF-CANDIDATE: 3PL|4PL|NVOCC|freight_broker|customs_broker|co_loader — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Composite performance score for the partner on a 0.00–5.00 scale, derived from KPI (Key Performance Indicator) measurements including OTD (On-Time Delivery), OTIF (On-Time In-Full), claims ratio, and SLA compliance. Updated periodically from operational data. Used for carrier/partner selection scoring in SAP TM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review conducted for this partner relationship. Used to schedule periodic KPI assessments and SLA compliance audits per contractual obligations.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipNumber rdf:type rdf:Property ;
    rdfs:label 'Relationship Number' ;
    rdfs:comment 'Externally-known business identifier for the partner relationship, used in EDI communications, contract references, and partner-facing correspondence. Sourced from Salesforce CRM or SAP TM partner master.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle state of the partner relationship. Active indicates the partnership is operational; suspended indicates temporary halt pending resolution; terminated indicates the relationship has ended; pending indicates onboarding in progress; under_review indicates compliance or performance review is underway.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceRelationshipCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Relationship Code' ;
    rdfs:comment 'Salesforce CRM record identifier for this partner relationship, enabling bi-directional synchronization between the data lakehouse silver layer and the CRM system of record for opportunity tracking and service case management.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportModesAuthorized rdf:type rdf:Property ;
    rdfs:label 'Transport Modes Authorized' ;
    rdfs:comment 'Pipe-delimited set of transport modes the partner is authorized to handle under this relationship. Aligns with IATA (air), IMO (ocean), and DOT (road/rail) regulatory frameworks. Used in SAP TM carrier selection and Oracle TMS load optimization.' ;
    rdfs:domain ind:PartnerRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCaseId rdf:type rdf:Property ;
    rdfs:label 'Service Case Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer service case record in the Transport Shipping lakehouse. Primary key for the service_case data product.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCase .

ind:assignedAgentId rdf:type rdf:Property ;
    rdfs:label 'Assigned Agent Id' ;
    rdfs:comment 'Reference to the customer service agent or workforce member currently assigned to resolve this case.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:environmentalIncidentId rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.environmental_incident. Business justification: Service cases involving environmental damage (spills during delivery, contamination, hazardous waste mishandling) must reference the environmental incident for regulatory notification, remediation cos' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalIncident .

ind:escalationManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Escalation Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Escalated service cases require senior manager assignment for resolution authority and customer relationship management. Critical for SLA breach recovery and customer retention. Role-prefixed to disti' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedDocumentTransportDocumentId rdf:type rdf:Property ;
    rdfs:label 'Related Document Transport Document Id' ;
    rdfs:comment 'Foreign key linking to document.transport_document. Business justification: Service cases frequently require reference to specific transport documents (AWB, BOL, commercial invoice) that are disputed, missing, or need correction. Customer service agents must retrieve and revi' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportDocument .

ind:caseCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Created Timestamp' ;
    rdfs:comment 'The date and time when the service case record was first created in Salesforce CRM. This is the principal business event timestamp representing when the customer interaction was formally logged. Used as the baseline for all SLA (Service Level Agreement) calculations.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseDescription rdf:type rdf:Property ;
    rdfs:label 'Case Description' ;
    rdfs:comment 'Full narrative description of the customer\'s issue, complaint, or inquiry as captured at case creation. May include shipment details, service failure context, or customer-provided evidence.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible, human-readable case reference number assigned by Salesforce CRM at case creation. Used in all customer-facing communications and SLA tracking. Format: CS- followed by 8–12 digits.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Reference Number' ;
    rdfs:comment 'The externally visible claim reference number from the claims domain, populated when claims_initiated is True. Provides a soft cross-reference to the cargo claim record without enforcing a hard FK at this stage. Distinct from service_case_id — the claim domain manages financial liability.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsInitiated rdf:type rdf:Property ;
    rdfs:label 'Claims Initiated' ;
    rdfs:comment 'Indicates whether this service case has triggered the initiation of a formal cargo claim in the claims domain. True when the case type is claims_initiation and a claim record has been created. Provides the handoff signal between customer service workflow and financial liability management.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when the service case was formally closed after customer confirmation or automatic closure policy. Distinct from resolved_timestamp — a case may be resolved but remain open pending customer acknowledgement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerFeedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback Notes' ;
    rdfs:comment 'Free-text verbatim feedback provided by the customer as part of the post-case satisfaction survey. Complements the numeric CSAT score with qualitative insight for service improvement analysis.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Customer satisfaction rating provided by the customer upon case closure, typically on a 1–5 scale. Sourced from Salesforce CRM post-case survey. Key KPI (Key Performance Indicator) for service quality measurement and agent performance management.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'The date and time when the most recent escalation event was triggered for this case. Null if the case has never been escalated. Used for escalation response time analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'The date and time when the first substantive agent response was sent to the customer after case creation. Used to calculate SLA (Service Level Agreement) first-response compliance and OTD (On-Time Delivery) of service commitments.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isEscalated rdf:type rdf:Property ;
    rdfs:label 'Is Escalated' ;
    rdfs:comment 'Indicates whether this service case has been formally escalated to a senior agent, team lead, or management tier at any point in its lifecycle. True if any escalation event has occurred.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReopenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reopened Timestamp' ;
    rdfs:comment 'The date and time when the case was most recently reopened after a prior resolution or closure. Null if the case has never been reopened. Used alongside reopen_count for resolution quality analytics.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originChannel rdf:type rdf:Property ;
    rdfs:label 'Origin Channel' ;
    rdfs:comment 'The communication channel through which the customer submitted this service case. Used for channel analytics, staffing optimization, and omnichannel service reporting. EDI (Electronic Data Interchange) channel applies to B2B automated case submissions.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podReceived rdf:type rdf:Property ;
    rdfs:label 'Pod Received' ;
    rdfs:comment 'Indicates whether the requested Proof of Delivery (POD) or Electronic Proof of Delivery (ePOD) document has been successfully retrieved and attached to this case. Used to track case resolution blockers.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podRequired rdf:type rdf:Property ;
    rdfs:label 'Pod Required' ;
    rdfs:comment 'Indicates whether a Proof of Delivery (POD) or Electronic Proof of Delivery (ePOD) document has been requested as part of resolving this service case. Common for delivery dispute and non-receipt inquiry cases.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reopenCount rdf:type rdf:Property ;
    rdfs:label 'Reopen Count' ;
    rdfs:comment 'Number of times this service case has been reopened after being marked as resolved or closed. A non-zero value indicates resolution quality issues. Used for first-contact resolution (FCR) KPI (Key Performance Indicator) reporting.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standardized code describing the action taken to resolve the service case. Distinct from root cause — this captures what was done, not why it happened. Used for resolution effectiveness analytics and SLA compliance reporting. [ENUM-REF-CANDIDATE: reshipped|refunded|credited|apology_issued|information_provided|escalated_to_claim|no_action_required|other — promote to reference product]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'The date and time when the service case was first marked as resolved. Used to calculate total resolution time, SLA (Service Level Agreement) resolution compliance, and agent productivity metrics.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaFirstResponseBreached rdf:type rdf:Property ;
    rdfs:label 'Sla First Response Breached' ;
    rdfs:comment 'Indicates whether the first response SLA (Service Level Agreement) target was breached for this case. True if the first_response_timestamp exceeded the sla_response_target_hours from case creation. Key KPI (Key Performance Indicator) for customer service quality reporting.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResolutionBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Breached' ;
    rdfs:comment 'Indicates whether the resolution SLA (Service Level Agreement) target was breached for this case. True if the resolved_timestamp exceeded the sla_resolution_target_hours from case creation. Drives escalation workflows and executive service quality dashboards.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResolutionTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Target Hours' ;
    rdfs:comment 'The contracted or policy-defined maximum number of hours within which the case must be fully resolved, as defined by the applicable SLA (Service Level Agreement) for this account segment and priority combination.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Target Hours' ;
    rdfs:comment 'The contracted or policy-defined maximum number of hours within which the first agent response must be delivered to the customer, as defined by the applicable SLA (Service Level Agreement) for this account segment and priority combination.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCaseCode rdf:type rdf:Property ;
    rdfs:label 'Source System Case Code' ;
    rdfs:comment 'The native case identifier from Salesforce CRM (e.g., Salesforce Case ID / 18-character Salesforce record ID). Retained for lineage traceability, reconciliation with the source system, and EDI (Electronic Data Interchange) integration cross-referencing.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Short, descriptive title of the service case as entered by the customer or agent. Used for case list views, search, and initial triage. Typically 255 characters or fewer.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Customer-facing parcel or shipment tracking number associated with this service case. Used for last-mile delivery inquiries, POD (Proof of Delivery) disputes, and express parcel service failures.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePreferenceId rdf:type rdf:Property ;
    rdfs:label 'Service Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer service preference record. Primary key for the service_preference data product within the customer domain.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredCarbonOffsetProgramId rdf:type rdf:Property ;
    rdfs:label 'Preferred Carbon Offset Program Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_offset_program. Business justification: Customers with sustainability preferences select preferred carbon offset programs (forestry vs. renewable energy projects) for their shipments, driving offset procurement, certificate issuance, and gr' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonOffsetProgram .

ind:primaryServicePreferredCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Preferred Carrier Id' ;
    rdfs:comment 'Reference to the customer\'s preferred carrier for shipment execution. Used in SAP TM carrier selection and Oracle TMS freight audit to prioritize carrier assignment when capacity and rates are comparable.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:awbTypePreference rdf:type rdf:Property ;
    rdfs:label 'Awb Type Preference' ;
    rdfs:comment 'Customer\'s preference for Air Waybill (AWB) type on air freight shipments. \'HAWB\' (House Air Waybill) is issued by the freight forwarder; \'MAWB\' (Master Air Waybill) is issued by the airline; \'either\' allows system-driven selection. Impacts IATA cargo documentation and customs filing.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blTypePreference rdf:type rdf:Property ;
    rdfs:label 'Bl Type Preference' ;
    rdfs:comment 'Customer\'s preference for Bill of Lading (BOL) type on ocean freight shipments. \'HBL\' (House Bill of Lading) is issued by the NVOCC or freight forwarder; \'MBL\' (Master Bill of Lading) is issued by the ocean carrier. Impacts FMC compliance and customs filing in Descartes Customs.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eOffsetPreference rdf:type rdf:Property ;
    rdfs:label 'Co2e Offset Preference' ;
    rdfs:comment 'Customer\'s preference for carbon offset participation. \'none\' means no offset; \'voluntary\' means the customer opts into voluntary carbon offset programs; \'mandatory\' means offset is contractually required. Supports CORSIA compliance and sustainability reporting.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codMaxAmount rdf:type rdf:Property ;
    rdfs:label 'Cod Max Amount' ;
    rdfs:comment 'Maximum monetary value authorized for COD collection per shipment for this customer. Enforced during last-mile delivery dispatch to manage cash handling risk. Expressed in the customer\'s default currency.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerLoadPreference rdf:type rdf:Property ;
    rdfs:label 'Container Load Preference' ;
    rdfs:comment 'Customer\'s preference for ocean freight container loading. \'FCL\' (Full Container Load) provides exclusive use of a container; \'LCL\' (Less Than Container Load) consolidates cargo with other shippers. Drives container booking logic in SAP TM and Oracle TMS load optimization.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearancePreference rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Preference' ;
    rdfs:comment 'Indicates how the customer prefers customs clearance to be managed. \'self_clearance\' means the customer handles their own customs filings; \'broker_managed\' means a third-party customs broker is used; \'transport_managed\' means Transport Shipping handles clearance as part of the service. Drives workflow routing in Descartes Customs.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueRequired rdf:type rdf:Property ;
    rdfs:label 'Declared Value Required' ;
    rdfs:comment 'Indicates whether the customer is required to declare the cargo value on all shipments. When true, shipment booking validation enforces declared value entry, which is used for customs valuation in Descartes Customs and insurance calculation.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Default Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the customer\'s preferred billing and invoicing currency for freight charges. Used in SAP S/4HANA Finance revenue recognition and SAP TM charge calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultIncoterms rdf:type rdf:Property ;
    rdfs:label 'Default Incoterms' ;
    rdfs:comment 'Customer\'s default International Commercial Terms (Incoterms) governing risk and cost transfer for shipments. Applied automatically during shipment booking in SAP TM. Aligns with ICC Incoterms 2020 rules and WTO trade compliance requirements. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimWeightMethod rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Method' ;
    rdfs:comment 'Method used to calculate dimensional weight (DIM weight) for rating and billing purposes. Determines whether IATA volumetric divisor, carrier-specific divisor, or IMDG rules apply. Impacts freight charge calculation in SAP TM.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatEnabled rdf:type rdf:Property ;
    rdfs:label 'Hazmat Enabled' ;
    rdfs:comment 'Indicates whether this customer is authorized to ship hazardous materials (hazmat) under IMDG Code (ocean), IATA Dangerous Goods Regulations (air), or DOT regulations (road). When true, hazmat documentation and compliance checks are triggered in Descartes Customs.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Required' ;
    rdfs:comment 'Indicates whether the customer requires cargo insurance to be arranged by Transport Shipping for their shipments by default. When true, insurance coverage is automatically included in shipment booking and charge calculation in SAP TM.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelFormat rdf:type rdf:Property ;
    rdfs:label 'Label Format' ;
    rdfs:comment 'Customer\'s preferred shipping label output format for parcel and freight labels. ZPL (Zebra Programming Language) is standard for thermal printers; PDF for laser printing; EPL for legacy Eltron printers; PNG for digital/web display. Configured in Oracle TMS shipment execution.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'Customer\'s preferred channel for shipment status notifications and alerts. Drives automated notification dispatch in FourKites real-time visibility platform and Salesforce CRM service communications. EDI applies to B2B enterprise customers using EDIFACT or X12 messaging.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEvents rdf:type rdf:Property ;
    rdfs:label 'Notification Events' ;
    rdfs:comment 'Comma-separated list of shipment lifecycle events that trigger customer notifications (e.g., \'booked,picked_up,in_transit,customs_cleared,out_for_delivery,delivered,exception\'). Configures FourKites exception management and Salesforce CRM service case alerts.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceCode rdf:type rdf:Property ;
    rdfs:label 'Preference Code' ;
    rdfs:comment 'Externally-known business identifier for this service preference profile, used in EDI integrations, API calls, and customer-facing communications. Sourced from Salesforce CRM customer preference records.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceName rdf:type rdf:Property ;
    rdfs:label 'Preference Name' ;
    rdfs:comment 'Human-readable label for this service preference profile, enabling customers and operations staff to distinguish between multiple preference sets (e.g., \'Standard B2B Freight\', \'E-Commerce Express\').' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle state of the service preference record. \'active\' means preferences are applied to new shipment bookings; \'inactive\' means preferences are archived; \'pending\' means awaiting customer or operations approval; \'suspended\' means temporarily disabled.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Classification of the preference profile indicating its scope and application context. \'default\' applies to all shipments unless overridden; \'override\' supersedes defaults for specific lanes or periods; \'seasonal\' applies during defined date windows; \'project\' is tied to a specific contract or project.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDestinationCountry rdf:type rdf:Property ;
    rdfs:label 'Preferred Destination Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the customer\'s default shipment destination country. Used in SAP TM route planning and Descartes Customs trade compliance screening for import declarations and HS code validation.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredOriginCountry rdf:type rdf:Property ;
    rdfs:label 'Preferred Origin Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the customer\'s default shipment origin country. Used in SAP TM route planning and Descartes Customs trade compliance screening for export declarations.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPackagingType rdf:type rdf:Property ;
    rdfs:label 'Preferred Packaging Type' ;
    rdfs:comment 'Customer\'s default packaging format for shipments, used to pre-populate booking forms and drive warehouse packing instructions in Manhattan WMS. Supports slotting optimization and labor management.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Preferred Service Level' ;
    rdfs:comment 'Customer\'s preferred shipment service level tier governing transit time and cost trade-off. Maps to SLA entitlements and carrier product codes in SAP TM charge calculation and Oracle TMS load optimization.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadLoadPreference rdf:type rdf:Property ;
    rdfs:label 'Road Load Preference' ;
    rdfs:comment 'Customer\'s preference for road freight load type. \'FTL\' (Full Truckload) provides exclusive truck capacity; \'LTL\' (Less Than Truckload) consolidates with other shipments. Used in SAP TM route planning and Oracle TMS load optimization.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCodes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Codes' ;
    rdfs:comment 'Comma-separated list of special handling instruction codes applicable to this customer\'s shipments by default (e.g., \'FRAGILE,TEMP_CTRL,HAZMAT,PERISHABLE,HIGH_VALUE,OVERSIZED\'). Drives warehouse handling procedures in Manhattan WMS and carrier booking requirements in SAP TM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityReportingEnabled rdf:type rdf:Property ;
    rdfs:label 'Sustainability Reporting Enabled' ;
    rdfs:comment 'Indicates whether the customer has opted into carbon emissions reporting for their shipments. When true, GHG (Greenhouse Gas) and CO2e (Carbon Dioxide Equivalent) data is calculated and included in customer sustainability reports, aligned with EU ETS and CORSIA requirements.' ;
    rdfs:domain ind:ServicePreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tempMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temp Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature in degrees Celsius for temperature-controlled shipments. Used to configure cold chain monitoring alerts in FourKites and warehouse environment controls in Manhattan WMS. Applicable only when temperature_controlled is true.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temp Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature in degrees Celsius for temperature-controlled shipments. Used to configure cold chain monitoring alerts in FourKites and warehouse environment controls in Manhattan WMS. Applicable only when temperature_controlled is true.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether this customer\'s shipments require temperature-controlled handling and transport by default. When true, cold chain equipment and monitoring requirements are applied during booking in SAP TM and warehouse slotting in Manhattan WMS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultOriginNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Default Origin Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Shippers have default origin nodes for pickup operations. Essential for pickup scheduling, origin facility assignment, route planning, and network capacity management. Replaces denormalized address fi' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:exporterTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Exporter Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Shipper profiles represent exporters in customs context. Required for: export declarations, AEO/CTPAT certification validation, denied party screening, and origin determination. Essential for outbound' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:preferredCarrierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Id' ;
    rdfs:comment 'Foreign key linking to network.carrier. Business justification: Shipper-level default carrier preference drives automated carrier selection in booking systems, rate shopping prioritization, and capacity allocation. Replaces denormalized preferred_carrier_code with' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:aeoCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification Expiry' ;
    rdfs:comment 'Expiry date of the shipper\'s AEO certification. Used to trigger renewal alerts and to validate AEO status at the time of shipment booking in Descartes Customs.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctpatCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certification Expiry' ;
    rdfs:comment 'Expiry date of the shipper\'s C-TPAT certification. Monitored to ensure continuous compliance eligibility for US cross-border shipments.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctpatCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certification Number' ;
    rdfs:comment 'US Customs and Border Protection-issued C-TPAT certification number for the shipper. Indicates the shipper has met supply chain security standards, enabling expedited customs processing and reduced inspection rates.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultPackagingType rdf:type rdf:Property ;
    rdfs:label 'Default Packaging Type' ;
    rdfs:comment 'Shipper\'s default packaging type used for shipment booking and warehouse operations. Drives packaging material selection, DIM weight calculation, and stacking rules in Manhattan WMS and SAP TM.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certification Expiry' ;
    rdfs:comment 'Expiry date of the shipper\'s hazmat handling certification. Shipments tendered after this date will be blocked from hazmat routing until recertification is confirmed.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certification Number' ;
    rdfs:comment 'Regulatory certification or registration number authorizing the shipper to tender dangerous goods. Required for IMDG (ocean) and IATA DGR (air) hazmat shipments. Validated in Descartes Customs during shipment booking.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataShipperCode rdf:type rdf:Property ;
    rdfs:label 'Iata Shipper Code' ;
    rdfs:comment 'IATA-assigned shipper identification code used in air freight documentation including House Air Waybills (HAWB) and Master Air Waybills (MAWB). Required for IATA-regulated air cargo bookings.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCodEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Cod Enabled' ;
    rdfs:comment 'Indicates whether Cash on Delivery (COD) is enabled for shipments from this shipper. When true, COD collection instructions are appended to delivery orders and ePOD workflows.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFragileHandlingRequired rdf:type rdf:Property ;
    rdfs:label 'Is Fragile Handling Required' ;
    rdfs:comment 'Indicates whether shipments from this shipper require fragile handling by default. Triggers special handling instructions on freight orders and warehouse pick/pack operations in Manhattan WMS.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatAuthorized rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Authorized' ;
    rdfs:comment 'Indicates whether the shipper is authorized to tender hazardous materials shipments. When true, hazmat-specific handling, documentation, and carrier routing rules are applied. Validated against IMDG Code for ocean and IATA DGR for air shipments.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether this shipper regularly tenders temperature-controlled (cold chain) shipments. When true, temperature-controlled handling, equipment, and carrier capabilities are applied by default in SAP TM routing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationEmail rdf:type rdf:Property ;
    rdfs:label 'Notification Email' ;
    rdfs:comment 'Primary email address for shipment status notifications, booking confirmations, and exception alerts. Used when notification_channel is set to email. Subject to GDPR consent management.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPhone rdf:type rdf:Property ;
    rdfs:label 'Notification Phone' ;
    rdfs:comment 'Mobile phone number for SMS-based shipment notifications and alerts. Used when notification_channel is set to sms. Must be in E.164 international format.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLoadType rdf:type rdf:Property ;
    rdfs:label 'Preferred Load Type' ;
    rdfs:comment 'Shipper\'s default load consolidation preference. FTL (Full Truckload) and LTL (Less Than Truckload) apply to road freight; FCL (Full Container Load) and LCL (Less Than Container Load) apply to ocean freight. Used in load optimization in Oracle TMS.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileEffectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Profile Effective From' ;
    rdfs:comment 'Date from which this shipper profile becomes operationally active and eligible for shipment booking. Supports time-bounded profile management and contract-aligned activation.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileEffectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Profile Effective Until' ;
    rdfs:comment 'Date after which this shipper profile is no longer operationally active. Null indicates an open-ended profile with no planned expiry. Used to enforce time-bounded shipper authorizations.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the shipper profile. Active profiles are eligible for shipment booking. Suspended profiles are temporarily blocked. Blacklisted profiles are permanently barred due to compliance violations or fraud. Drives booking eligibility checks in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Number' ;
    rdfs:comment 'SAP S/4HANA Finance and SAP TM customer master number for the shipper. Used for freight charge calculation, accounts receivable posting, and revenue recognition. Enables reconciliation between TMS and ERP financial records.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text field capturing any additional special handling requirements for shipments from this shipper that are not covered by structured flags (e.g., \'Do not stack\', \'Keep upright\', \'Requires liftgate at delivery\'). Appended to freight orders in SAP TM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature in degrees Celsius for temperature-controlled shipments from this shipper. Used alongside the minimum to define the acceptable cold chain envelope for carrier and equipment selection.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature in degrees Celsius for temperature-controlled shipments from this shipper. Used to specify cold chain equipment requirements and validate carrier capabilities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:webhookEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Webhook Endpoint Url' ;
    rdfs:comment 'HTTPS endpoint URL registered by the shipper to receive real-time shipment event push notifications via webhook. Used when notification_channel is set to webhook. Must use HTTPS for security compliance.' ;
    rdfs:domain ind:ShipperProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Sla Entitlement Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer-specific SLA entitlement record in the silver layer lakehouse.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaEntitlement .

ind:reportingContactId rdf:type rdf:Property ;
    rdfs:label 'Reporting Contact Id' ;
    rdfs:comment 'Reference to the primary customer contact who receives SLA performance reports and is the designated recipient for escalation notifications under this entitlement.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether this SLA entitlement automatically renews at the end of the effective period without requiring explicit renegotiation. When True, the entitlement rolls over under the same terms unless terminated.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimsResolutionSlaDays rdf:type rdf:Property ;
    rdfs:label 'Claims Resolution Sla Days' ;
    rdfs:comment 'Maximum number of calendar days within which a cargo claim must be acknowledged, investigated, and resolved under this SLA entitlement. Drives claims team prioritization and escalation triggers.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crmEntitlementCode rdf:type rdf:Property ;
    rdfs:label 'Crm Entitlement Code' ;
    rdfs:comment 'Source system identifier for this SLA entitlement record in Salesforce CRM. Enables traceability and reconciliation between the lakehouse silver layer and the operational CRM system of record.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Time Window End' ;
    rdfs:comment 'Latest time of day (HH:MM, 24-hour local time) by which delivery must be completed to be considered on-time under this SLA entitlement. Defines the close of the delivery window for time-definite commitments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Time Window Start' ;
    rdfs:comment 'Earliest time of day (HH:MM, 24-hour local time) within which delivery must be attempted to be considered on-time under this SLA entitlement. Used for time-definite delivery commitments (e.g., AM delivery windows).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementName rdf:type rdf:Property ;
    rdfs:label 'Entitlement Name' ;
    rdfs:comment 'Descriptive business name for this SLA entitlement, e.g., \'Gold Express OTD Commitment — APAC Lane\'. Used in customer-facing documents and CRM dashboards.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementNumber rdf:type rdf:Property ;
    rdfs:label 'Entitlement Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for this SLA entitlement, used in customer communications, CRM service cases, and operational reporting. Format: SLA- followed by alphanumeric characters.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle state of the SLA entitlement. \'active\' means the entitlement is in force; \'suspended\' means temporarily paused (e.g., force majeure); \'expired\' means the effective period has lapsed; \'pending_activation\' means approved but not yet in effect; \'terminated\' means cancelled before natural expiry; \'draft\' means under negotiation.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Hours' ;
    rdfs:comment 'Number of hours after a shipment misses its committed delivery time before an automatic escalation is triggered to the account management or operations team. Enables proactive exception management for high-value customers.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gracePeriodHours rdf:type rdf:Property ;
    rdfs:label 'Grace Period Hours' ;
    rdfs:comment 'Number of hours beyond the committed delivery time that are tolerated before a shipment is classified as a late delivery for SLA measurement purposes. Accounts for minor operational variances and is agreed upon at contract negotiation.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveClauseApplicable rdf:type rdf:Property ;
    rdfs:label 'Incentive Clause Applicable' ;
    rdfs:comment 'Indicates whether a financial incentive or rebate clause is in effect for over-performance against the SLA targets. When True, the incentive_rate_pct field defines the reward structure.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this SLA entitlement was last formally reviewed with the customer in a business review meeting. Used to track review cadence compliance and trigger upcoming review scheduling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minVolumeShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Min Volume Shipment Count' ;
    rdfs:comment 'Minimum number of shipments the customer commits to tender per measurement period to qualify for the SLA entitlement terms. Failure to meet this threshold may trigger tier renegotiation or penalty clauses.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minVolumeTeu rdf:type rdf:Property ;
    rdfs:label 'Min Volume Teu' ;
    rdfs:comment 'Minimum volume in Twenty-Foot Equivalent Units (TEU) the customer commits to tender per measurement period. Applicable to ocean freight FCL/LCL services. TEU is the standard unit of container capacity measurement per IMO and FMC conventions.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minVolumeWeightKg rdf:type rdf:Property ;
    rdfs:label 'Min Volume Weight Kg' ;
    rdfs:comment 'Minimum chargeable weight in kilograms the customer commits to tender per measurement period. Applicable primarily to air freight and express services where weight-based volume commitments are standard.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Applicable' ;
    rdfs:comment 'Indicates whether a financial penalty clause is in effect for under-performance against the SLA targets. When True, the penalty_rate_pct and penalty_cap_amount fields define the financial exposure.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickupCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Pickup Cutoff Time' ;
    rdfs:comment 'Latest time of day (HH:MM, 24-hour local time) by which a shipment must be tendered for pickup to qualify for same-day transit under this SLA entitlement. Shipments tendered after this time are counted against the next business day for OTD measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transitTimeGuaranteeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Guarantee Days' ;
    rdfs:comment 'Maximum number of calendar days from shipment pickup to delivery guaranteed under this SLA entitlement. Defines the transit time window used to evaluate OTD compliance. Expressed in whole days; fractional-day commitments use transit_time_guarantee_hours.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitTimeGuaranteeHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Guarantee Hours' ;
    rdfs:comment 'Maximum number of hours from shipment pickup to delivery guaranteed under this SLA entitlement. Used for express and time-definite services where day-level granularity is insufficient (e.g., next-day AM, same-day delivery). Takes precedence over transit_time_guarantee_days when both are populated.' ;
    rdfs:domain ind:SlaEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amsFilingId rdf:type rdf:Property ;
    rdfs:label 'Ams Filing Id' ;
    rdfs:comment 'Unique identifier for the AMS filing record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmsFiling .

ind:filedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Filed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: AMS filings submitted by licensed customs brokers (employees). CBP regulatory requirement for manifest data. Critical for tracking individual broker performance and regulatory compliance.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:portOfUnladingNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Port Of Unlading Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: AMS advance manifest submissions must specify unlading port for CBP security screening. Required for manifest compliance validation and arrival port coordination. Replaces denormalized port_of_unladin' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:shipperSupplierId rdf:type rdf:Property ;
    rdfs:label 'Shipper Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: AMS cargo manifest filings identify shipper (often supplier) for CBP advance screening. Carriers reference supplier master for accurate shipper details in manifest submissions, enabling denied party s' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'The actual date when the conveyance arrived at the US port of unlading. Updated after arrival occurs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number tracking amendments to the original AMS filing. Zero for original filing, incremented for each amendment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amsTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Ams Transaction Number' ;
    rdfs:comment 'The unique transaction number assigned by US Customs and Border Protection (CBP) upon successful AMS filing submission. This is the official CBP reference for the manifest filing.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondNumber rdf:type rdf:Property ;
    rdfs:label 'Bond Number' ;
    rdfs:comment 'The customs bond number guaranteeing payment of duties and compliance with CBP regulations.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondType rdf:type rdf:Property ;
    rdfs:label 'Bond Type' ;
    rdfs:comment 'The type of customs bond covering this shipment. Single transaction bond or continuous bond for regular importers.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerFilerCode rdf:type rdf:Property ;
    rdfs:label 'Broker Filer Code' ;
    rdfs:comment 'The CBP-assigned filer code identifying the licensed customs broker who submitted this AMS filing on behalf of the importer.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbpHoldIndicator rdf:type rdf:Property ;
    rdfs:label 'Cbp Hold Indicator' ;
    rdfs:comment 'Boolean flag indicating whether CBP has placed a hold on this shipment for inspection or further review. True if hold is active.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consigneeAddress rdf:type rdf:Property ;
    rdfs:label 'Consignee Address' ;
    rdfs:comment 'The full US address of the consignee. Required for AMS filing and delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCount rdf:type rdf:Property ;
    rdfs:label 'Container Count' ;
    rdfs:comment 'The number of containers (TEU/FEU) associated with this AMS filing for ocean shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conveyanceName rdf:type rdf:Property ;
    rdfs:label 'Conveyance Name' ;
    rdfs:comment 'The name or identifier of the conveyance (truck, rail car, barge) for rail and truck AMS filings.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'The three-letter ISO country code identifying where the goods were manufactured or produced. Used for duty assessment and trade compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'The estimated date when the conveyance is expected to arrive at the US port of unlading. Critical for AMS filing timing requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examLocation rdf:type rdf:Property ;
    rdfs:label 'Exam Location' ;
    rdfs:comment 'The facility or terminal where the CBP examination will take place or has taken place.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examType rdf:type rdf:Property ;
    rdfs:label 'Exam Type' ;
    rdfs:comment 'The type of physical examination ordered by CBP. VACIS = Vehicle and Cargo Inspection System (non-intrusive imaging), CET = Container Examination Team (physical inspection), tailgate = partial inspection, intensive = full unload and inspection.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the AMS filing. Tracks progression from draft through submission, acceptance, or rejection by CBP.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filing Timestamp' ;
    rdfs:comment 'The date and time when the AMS filing was submitted to US CBP. This is the official filing timestamp for compliance purposes.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'The transport mode for which this AMS filing was submitted. Ocean filings use AMS Ocean, air filings use AMS Air, and rail/truck use ABI (Automated Broker Interface).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightNumber rdf:type rdf:Property ;
    rdfs:label 'Flight Number' ;
    rdfs:comment 'The airline flight number for air shipments. Identifies the specific flight carrying the cargo.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfNumber rdf:type rdf:Property ;
    rdfs:label 'Isf Number' ;
    rdfs:comment 'The ISF (10+2) filing number associated with this ocean shipment. ISF must be filed 24 hours before vessel loading.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifyPartyName rdf:type rdf:Property ;
    rdfs:label 'Notify Party Name' ;
    rdfs:comment 'The name of the party to be notified upon arrival of the cargo. Often the consignee or their customs broker.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pieceCount rdf:type rdf:Property ;
    rdfs:label 'Piece Count' ;
    rdfs:comment 'The total number of pieces or packages in the shipment covered by this AMS filing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portOfLadingCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Lading Code' ;
    rdfs:comment 'The five-character UN/LOCODE identifying the foreign port where the cargo was loaded onto the conveyance.' ;
    rdfs:domain ind:AmsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselImoNumber rdf:type rdf:Property ;
    rdfs:label 'Vessel Imo Number' ;
    rdfs:comment 'The seven-digit IMO ship identification number, a unique permanent identifier for the vessel.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselName rdf:type rdf:Property ;
    rdfs:label 'Vessel Name' ;
    rdfs:comment 'The name of the ocean vessel carrying the cargo. Required for ocean AMS filings.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Number' ;
    rdfs:comment 'The carrier-assigned voyage or trip number for ocean shipments. Identifies the specific sailing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Id' ;
    rdfs:comment 'Unique identifier for the certificate of origin record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfOrigin .

ind:originDeterminationId rdf:type rdf:Property ;
    rdfs:label 'Origin Determination Id' ;
    rdfs:comment 'Foreign key linking to customs.origin_determination. Business justification: A certificate of origin is supported by an origin determination that establishes the country of origin through rules of origin analysis. Linking certificate to its supporting origin determination prov' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OriginDetermination .

ind:tradeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_agreement. Business justification: Certificates of origin are issued under specific trade agreements to claim preferential tariff treatment. The certificate has trade_agreement_code as a denormalized string. Adding FK to trade_agreemen' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAgreement .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: COO verification performed by trade compliance officers (employees). Regulatory requirement for preferential tariff claims. Tracks who verified the certificate authenticity and origin criteria.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate number assigned by the issuing authority or system. This is the externally-known business identifier for the certificate.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the certificate. Draft indicates preparation; issued means certificate is active; endorsed means validated by authority; revoked means certificate has been invalidated; expired means validity period has passed; pending approval means awaiting authority review.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of certificate of origin. Preferential certificates support duty reduction under trade agreements; non-preferential certificates confirm origin without tariff benefits; GSP Form A for Generalized System of Preferences; EUR.1 for EU trade; USMCA for United States-Mexico-Canada Agreement; RCEP for Regional Comprehensive Economic Partnership.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Consignee Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country where the consignee is located.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Consignee Identifier' ;
    rdfs:comment 'Unique business identifier for the consignee, such as tax ID, EORI number, or customs registration number.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementDate rdf:type rdf:Property ;
    rdfs:label 'Endorsement Date' ;
    rdfs:comment 'Date when the certificate was endorsed or validated by the issuing authority. Nullable if not yet endorsed.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endorsementOfficialName rdf:type rdf:Property ;
    rdfs:label 'Endorsement Official Name' ;
    rdfs:comment 'Name of the official or authorized signatory who endorsed the certificate. Nullable if not yet endorsed.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Export Declaration Number' ;
    rdfs:comment 'Reference number of the export customs declaration to which this certificate is linked.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Description' ;
    rdfs:comment 'Detailed description of the goods covered by this certificate, including product name, specifications, and characteristics sufficient for customs identification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Identifier' ;
    rdfs:comment 'Unique identifier or registration number of the issuing body, such as chamber registration number or customs authority code.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyName rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Name' ;
    rdfs:comment 'Full legal name of the organization or authority that issued the certificate of origin.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyType rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Type' ;
    rdfs:comment 'Type of organization or authority that issued the certificate. Chamber of commerce for trade association issuance; customs authority for government-issued certificates; exporter self-certification for approved exporter programs; authorized body for designated third-party certifiers.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the certificate was issued.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCriterion rdf:type rdf:Property ;
    rdfs:label 'Origin Criterion' ;
    rdfs:comment 'Specific rule or criterion under which the goods qualify for origin status, such as wholly obtained, substantial transformation, regional value content percentage, or change in tariff classification. Format and content vary by trade agreement.' ;
    rdfs:domain ind:CertificateOfOrigin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageTypeCode rdf:type rdf:Property ;
    rdfs:label 'Package Type Code' ;
    rdfs:comment 'UN/CEFACT Recommendation 21 code indicating the type of packaging, such as CT (carton), PX (pallet), DR (drum), BX (box).' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional notes, comments, or special instructions related to the certificate of origin, such as back-to-back certificate references, third-country invoicing details, or clarifications on origin criteria.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date when the certificate was revoked by the issuing authority. Nullable if certificate has not been revoked.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation or reason for certificate revocation, such as fraudulent information, incorrect origin determination, or exporter request. Nullable if certificate has not been revoked.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of all goods covered by this certificate, including packaging, measured in kilograms.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Kg' ;
    rdfs:comment 'Total net weight of all goods covered by this certificate, excluding packaging, measured in kilograms.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceAuditId rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Id' ;
    rdfs:comment 'Unique identifier for the compliance audit record. Primary key for the compliance audit entity.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance audits performed by qualified internal or external auditors (employees). Regulatory and internal control requirement. Tracks auditor qualifications and independence. Auditor_name is denorma' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceProgramId rdf:type rdf:Property ;
    rdfs:label 'Compliance Program Id' ;
    rdfs:comment 'Foreign key linking to customs.compliance_program. Business justification: Compliance audits are conducted against specific compliance programs (C-TPAT, AEO, etc.). The audit has program_certification_impacted and compliance_program_code strings but no proper FK. Adding FK e' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceProgram .

ind:financeAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Finance Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to finance.audit_finding. Business justification: Customs compliance audits may identify financial control deficiencies (e.g., duty calculation errors, SOX controls). Essential for integrated audit management, remediation tracking, and regulatory rep' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceAuditFinding .

ind:auditCostAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting the compliance audit, including auditor fees, travel expenses, and internal resource costs. Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost amount, such as USD, EUR, or GBP.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The principal date when the compliance audit was conducted or fieldwork commenced. Represents the business event timestamp for the audit activity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'The date when the audit fieldwork or assessment activities were completed. Used for tracking audit duration and closure timelines.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditMethodology rdf:type rdf:Property ;
    rdfs:label 'Audit Methodology' ;
    rdfs:comment 'Description of the audit methodology or framework applied, such as risk-based sampling, full population review, process walkthrough, or specific regulatory audit protocol. Defines the approach used to conduct the assessment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the compliance audit for tracking and reporting purposes. Used in communications with customs authorities and internal stakeholders.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period End Date' ;
    rdfs:comment 'The ending date of the time period being audited. Defines the end of the lookback window for transactions, declarations, and compliance activities under review.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Period Start Date' ;
    rdfs:comment 'The beginning date of the time period being audited. Defines the start of the lookback window for transactions, declarations, and compliance activities under review.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditReportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the formal audit report document containing detailed findings, evidence, and recommendations. Links to document management system or repository.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope including specific customs processes, declarations, shipment lanes, time periods, or compliance programs being audited. Defines the boundaries and focus areas of the audit engagement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Start Date' ;
    rdfs:comment 'The date when the audit fieldwork or assessment activities officially began. Used for tracking audit duration and scheduling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on the conducting party and scope. Internal audits are self-assessments, external audits are conducted by third parties or regulatory bodies such as CBP (Customs and Border Protection), AEO (Authorized Economic Operator), C-TPAT (Customs-Trade Partnership Against Terrorism), or WCO (World Customs Organization).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorCertification rdf:type rdf:Property ;
    rdfs:label 'Auditor Certification' ;
    rdfs:comment 'Professional certifications or qualifications held by the lead auditor, such as Certified Customs Specialist (CCS), Licensed Customs Broker, ISO 19011 Lead Auditor, or other relevant trade compliance credentials.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Name of the organization or entity that the auditor represents. May be internal department name, external consulting firm, or regulatory authority such as CBP, AEO certification body, or customs administration.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRating rdf:type rdf:Property ;
    rdfs:label 'Compliance Rating' ;
    rdfs:comment 'Overall compliance rating assigned to the audited entity or process based on the audit findings. Excellent indicates no significant findings, satisfactory indicates minor findings only, needs_improvement indicates major findings requiring corrective action, unsatisfactory indicates critical findings, and non_compliant indicates severe violations requiring immediate remediation.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which all corrective actions must be completed and verified. Used for tracking compliance with audit remediation timelines and regulatory requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Reference' ;
    rdfs:comment 'Reference identifier or document number for the corrective action plan developed in response to audit findings. Links the audit to the remediation activities and follow-up tracking.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Total number of critical severity findings identified during the audit. Critical findings represent major compliance violations with significant regulatory risk, potential penalties, or program suspension implications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityLocation rdf:type rdf:Property ;
    rdfs:label 'Facility Location' ;
    rdfs:comment 'Name or identifier of the specific facility, warehouse, or operational location where the audit was conducted. Used for site-specific compliance tracking.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'Scheduled or actual date for the follow-up audit to verify corrective action implementation. Null if no follow-up audit is required.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required' ;
    rdfs:comment 'Boolean indicator of whether a follow-up audit is required to verify implementation of corrective actions. True indicates follow-up audit is mandatory, false indicates no follow-up required.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Total number of major severity findings identified during the audit. Major findings represent significant compliance gaps that require corrective action but do not pose immediate program suspension risk.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Total number of minor severity findings identified during the audit. Minor findings represent opportunities for improvement or minor procedural deviations that do not pose significant compliance risk.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:populationSize rdf:type rdf:Property ;
    rdfs:label 'Population Size' ;
    rdfs:comment 'Total number of transactions, declarations, or records in the population from which the audit sample was drawn. Used for calculating sampling rates and extrapolating findings.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programCertificationImpacted rdf:type rdf:Property ;
    rdfs:label 'Program Certification Impacted' ;
    rdfs:comment 'Name of the trade compliance program or certification whose status may be impacted by the audit findings, such as C-TPAT, AEO, or other trusted trader programs. Used to track program-specific compliance obligations.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of transactions, declarations, or records sampled and reviewed during the audit. Used for statistical analysis and audit scope documentation.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of all findings identified during the audit across all severity levels. Represents the aggregate count of critical, major, and minor findings.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Participant Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Compliance program memberships (C-TPAT, AEO, etc.) are held by trade parties. The compliance_program product appears to be an association entity tracking trade party participation in compliance progra' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:programManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: AEO/C-TPAT programs require designated program managers (employees). Regulatory requirement for certification maintenance. Tracks accountability for compliance obligations. Contact_person_name is deno' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Annual Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the program requires submission of annual compliance reports, self-assessments, or status updates.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date when Transport Shipping or its client submitted the initial application for program membership.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Required interval in months between compliance audits or validation visits as mandated by the program.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorityContactEmail rdf:type rdf:Property ;
    rdfs:label 'Authority Contact Email' ;
    rdfs:comment 'Email address of the assigned contact person at the certifying authority.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityContactName rdf:type rdf:Property ;
    rdfs:label 'Authority Contact Name' ;
    rdfs:comment 'Name of the assigned contact person or account manager at the certifying authority.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityContactPhone rdf:type rdf:Property ;
    rdfs:label 'Authority Contact Phone' ;
    rdfs:comment 'Phone number of the assigned contact person at the certifying authority.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Authority Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the certifying authority\'s jurisdiction (e.g., USA, GBR, DEU, CHN).' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingAuthority rdf:type rdf:Property ;
    rdfs:label 'Certifying Authority' ;
    rdfs:comment 'Name of the government agency, customs authority, or international body that issues and governs the program (e.g., US Customs and Border Protection, European Commission, ISO).' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationsDescription rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligations Description' ;
    rdfs:comment 'Detailed narrative description of all compliance requirements, obligations, and commitments that must be maintained to retain program membership.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Person Email' ;
    rdfs:comment 'Email address of the primary internal contact person responsible for this program.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Person Phone' ;
    rdfs:comment 'Phone number of the primary internal contact person responsible for this program.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedAccountManagerFlag rdf:type rdf:Property ;
    rdfs:label 'Dedicated Account Manager Flag' ;
    rdfs:comment 'Indicates whether the program provides access to a dedicated customs account manager or liaison officer.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expeditedReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Expedited Release Flag' ;
    rdfs:comment 'Indicates whether the program membership provides access to expedited customs clearance or release procedures.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent compliance audit, validation visit, or review conducted by the certifying authority.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSelfAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Self Assessment Date' ;
    rdfs:comment 'Date when the most recent internal compliance self-assessment or security profile review was completed.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the compliance program membership or certification. [ENUM-REF-CANDIDATE: active|pending|suspended|revoked|expired|withdrawn|under_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Level or tier of membership within the program (e.g., Tier 1, Tier 2, Tier 3 for C-TPAT; Full AEO, AEO-C, AEO-S for EU AEO). Empty if program has no tier structure.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mutualRecognitionCountries rdf:type rdf:Property ;
    rdfs:label 'Mutual Recognition Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this program membership is recognized through mutual recognition agreements (MRAs).' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next compliance audit, validation visit, or periodic review.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participantType rdf:type rdf:Property ;
    rdfs:label 'Participant Type' ;
    rdfs:comment 'Role or capacity in which Transport Shipping or its client participates in the compliance program. [ENUM-REF-CANDIDATE: importer|exporter|carrier|broker|warehouse|manufacturer|consolidator|forwarder — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityProcessingFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Processing Flag' ;
    rdfs:comment 'Indicates whether shipments under this program receive priority processing during customs clearance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programBenefitsDescription rdf:type rdf:Property ;
    rdfs:label 'Program Benefits Description' ;
    rdfs:comment 'Detailed narrative description of all benefits, privileges, and advantages conferred by this program membership.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Official name of the trade compliance or trusted trader program (e.g., C-TPAT, AEO, ISO 28000, FAST, PIP).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the compliance program by its primary focus area (trusted trader, security, quality, environmental, customs partnership).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Program Website Url' ;
    rdfs:comment 'Official website URL of the compliance program for reference and documentation access.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reducedExaminationRateFlag rdf:type rdf:Property ;
    rdfs:label 'Reduced Examination Rate Flag' ;
    rdfs:comment 'Indicates whether the program membership grants eligibility for reduced physical or documentary examination rates at customs.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Date by which renewal application or recertification must be submitted to maintain continuous membership.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:securityCriteriaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Security Criteria Met Flag' ;
    rdfs:comment 'Indicates whether all mandatory security criteria and minimum security requirements of the program are currently met.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Explanation of the reason for suspension if membership status is suspended. Null if not suspended.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Broker Assignment Id' ;
    rdfs:comment 'Unique identifier for the customs broker assignment record. Primary key for this entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrokerAssignment .

ind:assignedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Broker assignments made by operations managers (employees). Critical for workload management, SLA tracking, and performance monitoring. Tracks who assigned the broker to the shipment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedPortNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Port Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Customs brokers are licensed to operate at specific ports/nodes. Required for broker jurisdiction enforcement, service coverage planning, and assignment validation. Replaces denormalized assigned_port' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:brokerAgentId rdf:type rdf:Property ;
    rdfs:label 'Broker Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Customs broker assignments must link to the agent entity for operational coordination, performance tracking (filing accuracy, release times), and network management. Role prefix distinguishes from bro' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:brokerTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Broker Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Customs broker is a trade party entity. Adding broker_trade_party_id FK to trade_party.trade_party_id normalizes the broker reference. Cardinality: N:1 (many assignments can use the same broker). Remo' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this broker assignment is currently active. True for active assignments, false for completed or cancelled assignments. Used for filtering current workload.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualFilingDate rdf:type rdf:Property ;
    rdfs:label 'Actual Filing Date' ;
    rdfs:comment 'Actual date when the customs declaration was filed with the customs authority. Used for SLA compliance measurement and audit trails.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'Actual date when the shipment was released by customs authority. Critical milestone for supply chain visibility and performance measurement.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeoCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Aeo Certified Flag' ;
    rdfs:comment 'Indicates whether the broker holds AEO certification, which provides expedited customs processing and reduced inspection rates. True if certified, false otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedCountryCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the country where customs clearance is being performed. Determines applicable customs regulations and procedures.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when the customs broker was assigned to handle this shipment or declaration. Marks the start of broker responsibility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text field for capturing special instructions, exceptions, or contextual information relevant to this broker assignment. Used for operational communication.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Priority level for this broker assignment. Influences processing sequence and resource allocation for time-sensitive shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current status of the broker assignment in the customs clearance workflow. Tracks progression from assignment through final release or cancellation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Precise date and time when the broker assignment was created in the system. Used for audit trails and SLA tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Type of customs procedure the broker is handling. Determines applicable regulations, documentation requirements, and processing workflows.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageReleaseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Average Release Time Hours' ;
    rdfs:comment 'Average time in hours from declaration filing to customs release for shipments handled by this broker. Performance metric for broker efficiency.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Email' ;
    rdfs:comment 'Primary email address for communicating with the assigned customs broker. Used for document exchange and status updates.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Phone' ;
    rdfs:comment 'Primary phone number for reaching the assigned customs broker. Critical for urgent communications and issue resolution.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Broker Fee Amount' ;
    rdfs:comment 'Total fee charged by the customs broker for handling this declaration. Excludes government duties and taxes.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Broker Fee Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the broker fee amount. Supports multi-currency brokerage operations.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerageOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Brokerage Office Code' ;
    rdfs:comment 'Internal code identifying the specific brokerage office or branch handling this assignment. Supports multi-location brokerage operations and workload distribution.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerageOfficeLocation rdf:type rdf:Property ;
    rdfs:label 'Brokerage Office Location' ;
    rdfs:comment 'City and country location of the brokerage office handling this assignment. Enables geographic analysis of broker utilization.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certified Flag' ;
    rdfs:comment 'Indicates whether the broker is C-TPAT certified for enhanced supply chain security. True if certified, false otherwise. Applicable for US customs operations.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Customs Office Code' ;
    rdfs:comment 'Official code of the customs authority office where the declaration will be filed. Used for routing submissions to the correct government office.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFilingDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Filing Date' ;
    rdfs:comment 'Projected date when the customs declaration will be filed by the broker. Used for planning and customer communication.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Release Date' ;
    rdfs:comment 'Projected date when customs clearance and release will be completed. Used for downstream logistics planning and customer expectations.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicates whether this assignment encountered exceptions requiring special handling (e.g., inspection, document discrepancies, regulatory holds). True if exceptions exist, false otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Description of the exception or issue encountered during customs processing. Populated only when exception_flag is true. Used for root cause analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Filing Accuracy Rate' ;
    rdfs:comment 'Percentage of declarations filed by this broker that were accepted without errors or rejections. Key performance indicator for broker quality. Expressed as percentage (0.00 to 100.00).' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poaEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Poa Effective Date' ;
    rdfs:comment 'Date when the power of attorney authorization becomes effective. Used to validate broker authority at time of filing.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Poa Expiry Date' ;
    rdfs:comment 'Date when the power of attorney authorization expires. Nullable for indefinite authorizations. Critical for compliance validation.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:powerOfAttorneyReference rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney Reference' ;
    rdfs:comment 'Reference number of the legal power of attorney document authorizing the broker to act on behalf of the importer or exporter. Required for regulatory compliance.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousBrokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Broker License Number' ;
    rdfs:comment 'License number of the previous broker if this assignment was reassigned. Nullable for initial assignments. Supports audit trails and handoff tracking.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reassignmentCount rdf:type rdf:Property ;
    rdfs:label 'Reassignment Count' ;
    rdfs:comment 'Number of times this declaration has been reassigned to a different broker. High values may indicate complexity or resource constraints.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Contractual service level tier governing response times, filing deadlines, and support availability for this broker assignment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeclarationsHandled rdf:type rdf:Property ;
    rdfs:label 'Total Declarations Handled' ;
    rdfs:comment 'Cumulative count of customs declarations this broker has processed. Used for workload balancing and performance trending.' ;
    rdfs:domain ind:BrokerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsEventId rdf:type rdf:Property ;
    rdfs:label 'Customs Event Id' ;
    rdfs:comment 'Unique identifier for the customs event record. Primary key.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Recorded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customs events recorded by operations staff (employees). Audit trail requirement for status changes, holds, releases. Tracks who performed the action for accountability and dispute resolution.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order of amendments to the customs declaration. Used to track the version history when this event represents an amendment.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealIndicator rdf:type rdf:Property ;
    rdfs:label 'Appeal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this event represents an appeal or dispute of a previous customs decision. True if this is an appeal event, false otherwise.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Result of the appeal process, if applicable. Indicates whether the appeal was approved, denied, partially approved, or is still pending.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceProgramCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Program Code' ;
    rdfs:comment 'Code identifying any trade compliance program applicable to this customs event, such as C-TPAT, AEO, or other trusted trader programs. Affects processing priority and examination rates.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Customs Authority Code' ;
    rdfs:comment 'Standardized code identifying the customs authority or agency that triggered or recorded this event. Typically an ISO country code or agency-specific identifier.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Reference number of any supporting document associated with this customs event, such as a certificate, permit, or inspection report.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed textual description of the customs event. Provides human-readable context about what occurred, including any specific instructions or notes from the customs authority.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'The originating system or channel that generated this customs event. Indicates whether the event was received via customs authority EDI, Descartes GTM system, manual broker entry, or other integration channel. [ENUM-REF-CANDIDATE: CUSTOMS_EDI|DESCARTES_GTM|MANUAL_ENTRY|AMS|ISF|BROKER_PORTAL|API — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationType rdf:type rdf:Property ;
    rdfs:label 'Examination Type' ;
    rdfs:comment 'Type of customs examination conducted during this event, if applicable. Indicates whether the event involved physical inspection, document review, x-ray scanning, canine inspection, or no examination.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdIndicator rdf:type rdf:Property ;
    rdfs:label 'Hold Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this event resulted in a customs hold or detention of the shipment. True if the shipment was placed on hold, false otherwise.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Release Timestamp' ;
    rdfs:comment 'Date and time when a customs hold was released, if applicable. Null if no hold was placed or if the hold remains active.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationSentIndicator rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Indicator' ;
    rdfs:comment 'Boolean flag indicating whether an automated notification was sent to relevant parties (importer, broker, customer) about this customs event. True if notification was sent, false otherwise.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyIndicator rdf:type rdf:Property ;
    rdfs:label 'Penalty Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this event resulted in a penalty, fine, or sanction being assessed. True if a penalty was applied, false otherwise.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousDeclarationStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Declaration Status' ;
    rdfs:comment 'The status of the customs declaration immediately before this event occurred. Enables state transition tracking and audit trail reconstruction. [ENUM-REF-CANDIDATE: DRAFT|SUBMITTED|ACCEPTED|UNDER_EXAMINATION|RELEASED|REJECTED|AMENDED|CLOSED — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Identifier' ;
    rdfs:comment 'Unique identifier for the responsible party, such as a customs officer badge number, broker license number, or employee ID.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultingDeclarationStatus rdf:type rdf:Property ;
    rdfs:label 'Resulting Declaration Status' ;
    rdfs:comment 'The new status of the customs declaration after this event was processed. Captures the state transition outcome. [ENUM-REF-CANDIDATE: DRAFT|SUBMITTED|ACCEPTED|UNDER_EXAMINATION|RELEASED|REJECTED|AMENDED|CLOSED — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceIndicator rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this customs event was completed within the defined SLA timeframe. True if compliant, false if SLA was breached.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Timestamp' ;
    rdfs:comment 'The target date and time by which this customs event should have been completed according to service level agreements or regulatory requirements. Used for SLA measurement and performance tracking.' ;
    rdfs:domain ind:CustomsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Standardized code representing the type of customs lifecycle event. Defines the nature of the milestone (e.g., submission, acceptance, examination notification, release, amendment, rejection, appeal, closure). [ENUM-REF-CANDIDATE: SUBMISSION|ACCEPTANCE|EXAMINATION|RELEASE|AMENDMENT|REJECTION|APPEAL|CLOSURE|HOLD|CLEARANCE — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualId rdf:type rdf:Property ;
    rdfs:label 'Accrual Id' ;
    rdfs:comment 'Foreign key linking to finance.accrual. Business justification: Customs holds trigger financial accruals for potential penalties, additional duties, or storage costs. Required for financial risk provisioning, period-end close, and contingent liability reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Accrual .

ind:portOfEntryNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Customs holds are placed at specific examination locations/ports. Required for hold resolution workflow by facility, resource allocation, and examination capacity planning. Replaces denormalized port_' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:triggeringHseIncidentId rdf:type rdf:Property ;
    rdfs:label 'Triggering Hse Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.hse_incident. Business justification: Customs holds are frequently triggered by HSE incidents discovered during inspection (DG leakage, contamination, hazmat misdeclaration). Real business process: hold reason documentation, incident inve' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HseIncident .

ind:wasteRecordId rdf:type rdf:Property ;
    rdfs:label 'Waste Record Id' ;
    rdfs:comment 'Foreign key linking to sustainability.waste_record. Business justification: Customs holds on rejected, expired, or non-compliant goods result in disposal events that must be tracked as hazardous or non-hazardous waste. Real process: Waste disposal compliance and ESG waste div' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteRecord .

ind:actualReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Release Timestamp' ;
    rdfs:comment 'Date and time when the customs hold was actually lifted and the shipment was released. Null if hold is still active.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:additionalDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Additional Duty Amount' ;
    rdfs:comment 'Additional customs duty amount assessed as a result of the examination, in the currency specified by additional_duty_currency_code.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:additionalDutyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Additional Duty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the additional duty amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoCertifiedIndicator rdf:type rdf:Property ;
    rdfs:label 'Aeo Certified Indicator' ;
    rdfs:comment 'Flag indicating whether the shipper or consignee holds Authorized Economic Operator (AEO) certification, which may expedite hold resolution. True if certified, False otherwise.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cTpatCertifiedIndicator rdf:type rdf:Property ;
    rdfs:label 'C Tpat Certified Indicator' ;
    rdfs:comment 'Flag indicating whether the shipper or consignee holds C-TPAT certification, which may expedite hold resolution. True if certified, False otherwise.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfExaminationCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Examination Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the examination took place (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSentIndicator rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Indicator' ;
    rdfs:comment 'Flag indicating whether the customer was notified about the customs hold. True if notification was sent, False otherwise.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Date and time when the customer was notified about the customs hold.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the hold in hours, calculated from hold placed timestamp to actual release timestamp. Used for Service Level Agreement (SLA) impact analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinationFindings rdf:type rdf:Property ;
    rdfs:label 'Examination Findings' ;
    rdfs:comment 'Detailed narrative of the examination findings, including any discrepancies, violations, or compliance issues discovered during the inspection.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationLocation rdf:type rdf:Property ;
    rdfs:label 'Examination Location' ;
    rdfs:comment 'Physical location where the examination was conducted (e.g., port facility, Container Freight Station (CFS), bonded warehouse, Inland Container Depot (ICD)).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationResultCode rdf:type rdf:Property ;
    rdfs:label 'Examination Result Code' ;
    rdfs:comment 'Outcome of the customs examination. CLEARED = no issues found, DISCREPANCY_FOUND = documentation or commodity discrepancies identified, VIOLATION_DETECTED = regulatory violation discovered, ADDITIONAL_DUTY_ASSESSED = additional duties or taxes levied, SEIZURE = goods seized, PENALTY_ISSUED = monetary penalty imposed.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationTypeCode rdf:type rdf:Property ;
    rdfs:label 'Examination Type Code' ;
    rdfs:comment 'Type of physical or documentary examination conducted. VACIS = Vehicle and Cargo Inspection System (non-intrusive imaging), CET = Container Examination Team (physical inspection), INTENSIVE = full intensive examination, TAILGATE = tailgate inspection, DOCUMENT_ONLY = documentary review only, NO_EXAM = hold released without examination.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Release Date' ;
    rdfs:comment 'Anticipated date when the hold is expected to be resolved and the shipment released, based on examination schedule and processing timelines.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number assigned to this customs hold by the issuing authority or internal system.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the customs hold. ACTIVE = hold is in effect, PENDING_RELEASE = awaiting clearance, RELEASED = hold has been lifted, ESCALATED = requires higher-level review, CANCELLED = hold was cancelled or withdrawn.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Code' ;
    rdfs:comment 'Code identifying the customs authority or regulatory agency that placed the hold (e.g., CBP, USDA, FDA, port authority, internal compliance team).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Full name of the customs authority or regulatory agency that issued the hold.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOfficerBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Officer Badge Number' ;
    rdfs:comment 'Badge or identification number of the customs officer who placed the hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Issuing Officer Name' ;
    rdfs:comment 'Name of the customs officer or inspector who placed the hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Placed Timestamp' ;
    rdfs:comment 'Date and time when the customs hold was officially placed on the shipment. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionActionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Code' ;
    rdfs:comment 'Code representing the action taken to resolve the hold (e.g., documentation provided, duty paid, goods returned, goods destroyed, appeal filed).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Code' ;
    rdfs:comment 'Code identifying which party is responsible for resolving the hold. SHIPPER = shipper responsible, CONSIGNEE = consignee responsible, BROKER = customs broker responsible, CARRIER = carrier responsible, INTERNAL = internal compliance team responsible.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachIndicator rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Indicator' ;
    rdfs:comment 'Flag indicating whether the hold caused a breach of the shipment Service Level Agreement (SLA) for on-time delivery. True if SLA was breached, False otherwise.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalFinancialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Total Financial Impact Amount' ;
    rdfs:comment 'Total financial impact of the hold including additional duties, penalties, storage fees, and other charges, in the currency specified by total_financial_impact_currency_code.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFinancialImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Total Financial Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total financial impact amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationId rdf:type rdf:Property ;
    rdfs:label 'Valuation Id' ;
    rdfs:comment 'Unique identifier for the customs valuation determination record. Primary key.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:declarationLineId rdf:type rdf:Property ;
    rdfs:label 'Declaration Line Id' ;
    rdfs:comment 'Reference to the specific declaration line item being valued. Valuation is performed at the line level for each imported good.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeclarationLine .

ind:valuationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Valuation Employee Id' ;
    rdfs:comment 'Identifier of the user or system that created this valuation determination record.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:valuationLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Valuation Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system that last modified this valuation determination record.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentsAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustments Amount' ;
    rdfs:comment 'Net adjustments made by customs authority to the declared valuation. Positive for additions, negative for reductions. Reflects customs examination findings.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assistsValueAmount rdf:type rdf:Property ;
    rdfs:label 'Assists Value Amount' ;
    rdfs:comment 'Value of goods and services supplied by the buyer free of charge or at reduced cost for use in production and sale for export of the imported goods (materials, tools, dies, molds, engineering, development work). Must be added to transaction value per Article 8.1(b).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Incoterms basis used for customs valuation: CIF (Cost Insurance Freight), FOB (Free On Board), DAP (Delivered At Place), DDP (Delivered Duty Paid), EXW (Ex Works), FCA (Free Carrier). Determines which costs are included in dutiable value.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cifValueAmount rdf:type rdf:Property ;
    rdfs:label 'Cif Value Amount' ;
    rdfs:comment 'Total CIF (Cost, Insurance, Freight) value: transaction value plus freight, insurance, and loading charges to the port of importation. Standard basis for customs valuation in many jurisdictions.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionsBrokerageAmount rdf:type rdf:Property ;
    rdfs:label 'Commissions Brokerage Amount' ;
    rdfs:comment 'Buying commissions and brokerage fees (except buying commissions) included in the transaction value. Selling commissions are not added per Article 8.1(a).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Automated or analyst-assigned confidence score (0-100) indicating the reliability and completeness of the valuation determination. Higher scores indicate greater confidence in the declared values and method.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsQueryRaisedIndicator rdf:type rdf:Property ;
    rdfs:label 'Customs Query Raised Indicator' ;
    rdfs:comment 'Indicates whether the customs authority raised a query or requested additional documentation regarding this valuation determination.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsValueAcceptedAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Value Accepted Amount' ;
    rdfs:comment 'Final customs value accepted by the customs authority for duty calculation purposes. This is the definitive dutiable value base after all adjustments, additions, and deductions.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredTransactionValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Transaction Value Amount' ;
    rdfs:comment 'The price actually paid or payable for the imported goods when sold for export to the country of importation, as declared by the importer. This is the starting point for Method 1 (Transaction Value) valuation.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Deductions Amount' ;
    rdfs:comment 'Total value of allowable deductions from the declared transaction value (e.g., post-importation costs, construction/installation charges incurred after importation). Reduces the customs value base.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateSource rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Source' ;
    rdfs:comment 'Authority or system that provided the exchange rate (e.g., Central Bank, Customs Authority Official Rate, Commercial Bank Rate).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fobValueAmount rdf:type rdf:Property ;
    rdfs:label 'Fob Value Amount' ;
    rdfs:comment 'FOB (Free On Board) value: transaction value at the point of export, excluding international freight and insurance. Used as alternative valuation basis in some jurisdictions.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charges Amount' ;
    rdfs:comment 'Cost of transportation of the imported goods to the port or place of importation. Added to transaction value to determine customs value under CIF (Cost, Insurance, Freight) basis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Charges Amount' ;
    rdfs:comment 'Cost of insurance for the imported goods during international transport. Added to transaction value to determine customs value under CIF basis.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadingHandlingChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Loading Handling Charges Amount' ;
    rdfs:comment 'Costs associated with loading, unloading, and handling the goods up to the place of importation. Included in customs value calculation per Article 8.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodCode rdf:type rdf:Property ;
    rdfs:label 'Method Code' ;
    rdfs:comment 'The WCO Customs Valuation Agreement method applied: METHOD_1 (Transaction Value - Article 1), METHOD_2 (Identical Goods - Article 2), METHOD_3 (Similar Goods - Article 3), METHOD_4 (Deductive Value - Article 5), METHOD_5 (Computed Value - Article 6), METHOD_6 (Fallback - Article 7). [ENUM-REF-CANDIDATE: METHOD_1|METHOD_2|METHOD_3|METHOD_4|METHOD_5|METHOD_6 — promote to reference product]' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingCostsAmount rdf:type rdf:Property ;
    rdfs:label 'Packing Costs Amount' ;
    rdfs:comment 'Cost of containers and packing materials, whether for labor or materials, treated as part of the imported goods. Included in customs value per Article 8.1(a).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proceedsResaleAmount rdf:type rdf:Property ;
    rdfs:label 'Proceeds Resale Amount' ;
    rdfs:comment 'Value of any part of the proceeds of subsequent resale, disposal, or use of the imported goods that accrues directly or indirectly to the seller. Must be added to transaction value per Article 8.1(d).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queryResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Query Resolution Date' ;
    rdfs:comment 'Date on which any customs query regarding this valuation was resolved and the valuation was finalized.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipBuyerSellerIndicator rdf:type rdf:Property ;
    rdfs:label 'Relationship Buyer Seller Indicator' ;
    rdfs:comment 'Indicates whether a relationship exists between the buyer and seller that might influence the transaction value. If true, customs may examine whether the relationship influenced the price.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resaleDisposalRestrictionIndicator rdf:type rdf:Property ;
    rdfs:label 'Resale Disposal Restriction Indicator' ;
    rdfs:comment 'Indicates whether the buyer\'s resale, disposal, or use of the goods is restricted (other than restrictions imposed by law, geographic limitations, or restrictions that do not substantially affect value). May affect acceptability of transaction value.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Flag' ;
    rdfs:comment 'Indicates whether this valuation has been flagged for risk review due to unusual values, method selection, or discrepancies with historical data.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltiesLicenseFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Royalties License Fees Amount' ;
    rdfs:comment 'Royalties and license fees related to the imported goods that the buyer must pay as a condition of sale, directly or indirectly. Must be added to transaction value per Article 8.1(c).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rulingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Ruling Expiry Date' ;
    rdfs:comment 'Date on which the advance valuation ruling expires and is no longer valid for customs valuation purposes.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rulingIssueDate rdf:type rdf:Property ;
    rdfs:label 'Ruling Issue Date' ;
    rdfs:comment 'Date on which the advance valuation ruling was issued by the customs authority.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rulingIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Ruling Issuing Authority' ;
    rdfs:comment 'Name of the customs authority or office that issued the advance valuation ruling.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingReference rdf:type rdf:Property ;
    rdfs:label 'Ruling Reference' ;
    rdfs:comment 'Reference number of any advance valuation ruling or binding valuation decision issued by the customs authority for this commodity or transaction type.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleConditionRestrictionsIndicator rdf:type rdf:Property ;
    rdfs:label 'Sale Condition Restrictions Indicator' ;
    rdfs:comment 'Indicates whether the sale or price is subject to conditions or considerations for which a value cannot be determined. If true, transaction value method may not be acceptable.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportingDocumentsReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents Reference' ;
    rdfs:comment 'Reference identifiers or file paths to supporting documentation for this valuation (invoices, contracts, price lists, technical specifications, test reports, certificates).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'Date on which the customs valuation was determined. Typically the date of importation or the date the goods are entered for customs purposes. Determines applicable exchange rates and tariff schedules.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current lifecycle status of the valuation determination: draft (prepared but not submitted), submitted (sent to customs), accepted (approved by customs authority), adjusted (modified by customs), rejected (not accepted), under_review (pending customs examination).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationId rdf:type rdf:Property ;
    rdfs:label 'Declaration Id' ;
    rdfs:comment 'Unique identifier for the customs declaration record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Declaration .

ind:exporterSupplierId rdf:type rdf:Property ;
    rdfs:label 'Exporter Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Customs declarations require supplier/exporter master data for denied party screening, origin verification, and duty assessment. Brokers link declarations to supplier records for compliance validation' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:filingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Filing Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customs declarations must be filed by licensed customs brokers (employees). Critical for regulatory compliance, audit trail, and CBP accountability requirements. Tracks who submitted the declaration.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Reason for amending the declaration after initial submission (e.g., corrected HS code, updated value, additional documentation). Null if declaration was not amended.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Number' ;
    rdfs:comment 'Reference number of the certificate of origin document supporting preferential duty treatment or country-of-origin claims. Null if not applicable.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfDestination rdf:type rdf:Property ;
    rdfs:label 'Country Of Destination' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the final destination country where the goods will be consumed or used.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfExport rdf:type rdf:Property ;
    rdfs:label 'Country Of Export' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country from which the goods are being exported.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsAuthority rdf:type rdf:Property ;
    rdfs:label 'Customs Authority' ;
    rdfs:comment 'Name of the national customs authority or agency to which the declaration was filed (e.g., US CBP, UK HMRC, EU Member State Customs).' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Customs Procedure Code' ;
    rdfs:comment 'Code indicating the customs procedure or regime applied to the goods (e.g., free circulation, temporary admission, inward processing, customs warehousing).' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Declarant Identifier' ;
    rdfs:comment 'Official identifier of the declarant assigned by customs authority (e.g., customs broker license number, SCAC code, or national business registration number).' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarantName rdf:type rdf:Property ;
    rdfs:label 'Declarant Name' ;
    rdfs:comment 'Legal name of the party (customs broker, freight forwarder, or direct importer/exporter) filing the declaration with customs authorities.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'Official customs declaration number assigned by the national customs authority upon submission. This is the externally-known business identifier used for tracking and reference.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the customs declaration: draft (being prepared), submitted (filed with customs), under_review (customs examination in progress), released (cleared for movement), rejected (not accepted by customs), cancelled (withdrawn), or amended (modified after submission). [ENUM-REF-CANDIDATE: draft|submitted|under_review|released|rejected|cancelled|amended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Type of customs declaration indicating the nature of the cross-border movement: import (goods entering), export (goods leaving), transit (goods passing through), re-export (previously imported goods leaving), temporary admission (goods entering temporarily), or inward processing (goods for processing then re-export).' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screening Status' ;
    rdfs:comment 'Result of screening all parties (importer, exporter, consignee, shipper) against denied party lists (OFAC, BIS, EU sanctions, etc.): cleared (no matches), flagged (potential match requiring review), pending (screening in progress), or not_screened.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyTaxCurrency rdf:type rdf:Property ;
    rdfs:label 'Duty Tax Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for duty and tax amounts (typically the currency of the importing country).' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date when the customs declaration was officially submitted to the customs authority.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Ftz Entry Number' ;
    rdfs:comment 'Entry number assigned when goods are admitted into a Free Trade Zone or Foreign Trade Zone. Null if goods are not entering an FTZ.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether customs authority has flagged this declaration for physical inspection or examination of goods.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Type of customs inspection conducted or required: none, document review only, x-ray scan, physical examination, full examination, or random sample. Null if inspection_required is false.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfExit rdf:type rdf:Property ;
    rdfs:label 'Port Of Exit' ;
    rdfs:comment 'Name or code of the port, airport, or border crossing where goods exit the country of export.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Precise date and time when customs authority released the goods, including timezone. Null if not yet released.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalDeclaredValue rdf:type rdf:Property ;
    rdfs:label 'Total Declared Value' ;
    rdfs:comment 'Total customs value of all goods declared on this declaration, used as the basis for duty and tax calculation.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Total Duty Amount' ;
    rdfs:comment 'Total customs duty assessed on the declared goods. Null if not yet calculated or if duty-free.' ;
    rdfs:domain ind:Declaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeAgreement rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement' ;
    rdfs:comment 'Name or code of the preferential trade agreement under which reduced or zero duty rates are claimed (e.g., USMCA, EU-UK TCA, CPTPP). Null if no preference claimed.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsClassificationId rdf:type rdf:Property ;
    rdfs:label 'Hs Classification Id' ;
    rdfs:comment 'Foreign key linking to customs.hs_classification. Business justification: Each declaration line declares goods under a specific HS classification. Linking to hs_classification provides traceability to the classification decision. Not removing hs_code as it\'s a point-in-time' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HsClassification .

ind:licensePermitId rdf:type rdf:Property ;
    rdfs:label 'License Permit Id' ;
    rdfs:comment 'Foreign key linking to customs.license_permit. Business justification: Declaration lines for controlled goods reference a license/permit. Currently has license_number as denormalized string. Adding FK to license_permit normalizes this and enables tracking of license util' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicensePermit .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line. Business justification: Customs declaration lines map to PO line items for item-level duty tracking and compliance audit. Brokers trace declaration lines to PO lines for valuation verification, HS code validation, and transf' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:shipmentPackageId rdf:type rdf:Property ;
    rdfs:label 'Shipment Package Id' ;
    rdfs:comment 'Foreign key linking to shipment.shipment_package. Business justification: Multi-SKU shipments require line-level mapping between customs declaration lines and physical packages for inspection, examination, and selective release. Enables package-level customs status tracking' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentPackage .

ind:antidumpingCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Antidumping Case Number' ;
    rdfs:comment 'Reference number of the antidumping or countervailing duty investigation or order. Null if not subject to trade remedy measures.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antidumpingIndicator rdf:type rdf:Property ;
    rdfs:label 'Antidumping Indicator' ;
    rdfs:comment 'Indicates whether this line item is subject to antidumping or countervailing duties. True if subject to trade remedy measures, false otherwise.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Commercial brand or trademark name of the goods. Used for intellectual property enforcement and product identification.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsValueAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Value Amount' ;
    rdfs:comment 'Declared customs value of the goods for duty calculation purposes. Represents the transaction value or adjusted value per WCO Valuation Agreement (GATT Article VII).' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Customs Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the customs value amount. Indicates the currency in which the goods value is declared.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsIndicator rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Indicator' ;
    rdfs:comment 'Indicates whether this line item contains dangerous goods requiring special handling and documentation per IMDG Code or IATA Dangerous Goods Regulations. True if dangerous goods, false otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Calculated customs duty amount payable on this line item. Computed as customs value multiplied by duty rate, subject to any preferential treatment or exemptions.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Percent' ;
    rdfs:comment 'Applicable customs duty rate expressed as a percentage of the customs value. Determined by HS code classification and country of origin.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exciseTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Excise Tax Amount' ;
    rdfs:comment 'Calculated excise tax amount payable on this line item for goods subject to special excise duties (e.g., alcohol, tobacco, fuel). Zero if not applicable.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftzIndicator rdf:type rdf:Property ;
    rdfs:label 'Ftz Indicator' ;
    rdfs:comment 'Indicates whether this line item is admitted into a free trade zone or bonded warehouse with duty suspension. True if FTZ admission, false otherwise.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerAddress rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Address' ;
    rdfs:comment 'Full address of the manufacturer or producer of the goods. Required for origin verification and product safety traceability.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the manufacturer or producer of the goods. Required for certain product categories and origin verification purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer\'s model number or part number for the goods. Used for product identification and classification verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'Weight of the goods excluding all packaging materials, expressed in kilograms. Used for duty calculation and statistical purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferenceIndicator rdf:type rdf:Property ;
    rdfs:label 'Preference Indicator' ;
    rdfs:comment 'Indicates whether preferential tariff treatment is claimed for this line item under a free trade agreement or trade preference program. True if preference is claimed, false otherwise.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceProgramCode rdf:type rdf:Property ;
    rdfs:label 'Preference Program Code' ;
    rdfs:comment 'Code identifying the specific trade agreement or preference program under which preferential treatment is claimed. Examples include USMCA, EU-GSP, CPTPP. Null if no preference is claimed.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedRestrictedIndicator rdf:type rdf:Property ;
    rdfs:label 'Prohibited Restricted Indicator' ;
    rdfs:comment 'Indicates whether this line item contains goods subject to import prohibitions or restrictions (e.g., endangered species, hazardous materials, dual-use goods). True if restricted, false otherwise.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaIndicator rdf:type rdf:Property ;
    rdfs:label 'Quota Indicator' ;
    rdfs:comment 'Indicates whether this line item is subject to a tariff rate quota or quantitative import restriction. True if quota applies, false otherwise.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Number' ;
    rdfs:comment 'Reference number of the quota allocation or license under which this line item is imported. Null if no quota applies.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number or identification number for serialized goods. Required for high-value items, controlled goods, and warranty tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalValueAmount rdf:type rdf:Property ;
    rdfs:label 'Statistical Value Amount' ;
    rdfs:comment 'Value of the goods for trade statistics purposes, typically converted to the importing country\'s currency. Used for balance of payments and trade flow analysis.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Statistical Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the statistical value amount. Typically the local currency of the importing country.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationMethodCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Method Code' ;
    rdfs:comment 'Code indicating the WCO valuation method used to determine customs value. Values: 1=Transaction Value, 2=Identical Goods, 3=Similar Goods, 4=Deductive Value, 5=Computed Value, 6=Fall-back Method.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatAmount rdf:type rdf:Property ;
    rdfs:label 'Vat Amount' ;
    rdfs:comment 'Calculated value-added tax or goods and services tax amount payable on this line item. Computed based on the taxable base (customs value plus duty) and applicable VAT rate.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vatRatePercent rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percent' ;
    rdfs:comment 'Applicable value-added tax or goods and services tax rate expressed as a percentage. Applied to the sum of customs value and duty amount.' ;
    rdfs:domain ind:DeclarationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deniedPartyScreeningId rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screening Id' ;
    rdfs:comment 'Unique identifier for the denied party screening record. Primary key.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screenedTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Screened Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: The denied_party_screening table has denormalized party attributes (name, address, city, state, postal_code, country_code, tax_number) that correspond to trade_party master data. Linking to trade_part' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:analystReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Outcome' ;
    rdfs:comment 'Outcome of the compliance analyst review for potential or confirmed matches (approved, rejected, escalated, pending review).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Required Flag' ;
    rdfs:comment 'Indicates whether manual analyst review is required for this screening result (true for potential matches, false for clear results).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analystReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Timestamp' ;
    rdfs:comment 'Date and time when the compliance analyst completed their review of the screening result.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:falsePositiveFlag rdf:type rdf:Property ;
    rdfs:label 'False Positive Flag' ;
    rdfs:comment 'Indicates whether the match was determined to be a false positive after analyst review.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score (0.00 to 100.00) indicating the strength of the match between the screened party and denied party list entries.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Result of the screening check indicating whether the party matched any denied party list (clear, potential match, confirmed match, false positive).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedEntityCode rdf:type rdf:Property ;
    rdfs:label 'Matched Entity Code' ;
    rdfs:comment 'Unique identifier of the matched entity on the denied party list (e.g., OFAC SDN number).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedEntityName rdf:type rdf:Property ;
    rdfs:label 'Matched Entity Name' ;
    rdfs:comment 'Name of the denied party entity from the sanctions list that matched the screened party.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedEntityProgram rdf:type rdf:Property ;
    rdfs:label 'Matched Entity Program' ;
    rdfs:comment 'Sanctions program or regulatory program associated with the matched denied party (e.g., Iran Sanctions, Counter-Terrorism, Narcotics Trafficking).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListName rdf:type rdf:Property ;
    rdfs:label 'Matched List Name' ;
    rdfs:comment 'Name of the specific denied party list where a match was found (e.g., OFAC SDN, BIS Entity List).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Detailed justification provided by the compliance analyst for overriding a potential or confirmed match and approving the shipment.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether the shipment is placed on regulatory hold due to denied party screening results, preventing further processing until cleared.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Screening Engine Version' ;
    rdfs:comment 'Version number of the denied party screening engine used to perform this check.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningListSources rdf:type rdf:Property ;
    rdfs:label 'Screening List Sources' ;
    rdfs:comment 'Comma-separated list of denied party and restricted entity lists checked during this screening (OFAC SDN, BIS Entity List, EU Consolidated List, UN Sanctions, C-TPAT denied parties, HMT Sanctions, DFAT Sanctions, etc.).' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningNotes rdf:type rdf:Property ;
    rdfs:label 'Screening Notes' ;
    rdfs:comment 'Additional notes or comments recorded during the screening process or analyst review.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this screening transaction, used for audit trail and compliance reporting.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningRuleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Screening Rule Set Version' ;
    rdfs:comment 'Version number of the screening rule set and list data used during this check.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Run Timestamp' ;
    rdfs:comment 'Date and time when the denied party screening check was executed. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current lifecycle status of the screening check workflow.' ;
    rdfs:domain ind:DeniedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Dg Declaration Id' ;
    rdfs:comment 'Unique identifier for the dangerous goods declaration record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DgDeclaration .

ind:certifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: DG declarations certified by IATA-certified dangerous goods specialists (employees). IATA/ICAO regulatory requirement. Tracks certification authority and ensures only qualified personnel handle danger' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certifyingDgCertificationId rdf:type rdf:Property ;
    rdfs:label 'Certifying Dg Certification Id' ;
    rdfs:comment 'Foreign key linking to safety.dg_certification. Business justification: IATA/IMDG regulations require DG declarations to be prepared or reviewed by certified dangerous goods personnel. Logistics operators must validate certification status before accepting DG shipments. R' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DgCertification .

ind:competentAuthorityApproval rdf:type rdf:Property ;
    rdfs:label 'Competent Authority Approval' ;
    rdfs:comment 'Approval number issued by the competent authority for dangerous goods requiring special authorization.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the person or organization to contact in case of emergency involving the dangerous goods.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment '24-hour emergency telephone number for immediate response in case of incident involving the dangerous goods.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptedQuantityIndicator rdf:type rdf:Property ;
    rdfs:label 'Excepted Quantity Indicator' ;
    rdfs:comment 'Indicates whether the dangerous goods are shipped in excepted quantities, subject to minimal regulatory requirements.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReference rdf:type rdf:Property ;
    rdfs:label 'Exemption Reference' ;
    rdfs:comment 'Reference number of any regulatory exemption or special approval granted for the transport of these dangerous goods.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flashPointCelsius rdf:type rdf:Property ;
    rdfs:label 'Flash Point Celsius' ;
    rdfs:comment 'Lowest temperature at which the dangerous goods give off sufficient vapor to form an ignitable mixture with air, measured in degrees Celsius.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossQuantity rdf:type rdf:Property ;
    rdfs:label 'Gross Quantity' ;
    rdfs:comment 'Gross quantity of the dangerous goods including packaging, expressed in the unit of measure specified.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'Primary hazard class of the dangerous goods (1=Explosives, 2=Gases, 3=Flammable Liquids, 4=Flammable Solids, 5=Oxidizing Substances, 6=Toxic Substances, 7=Radioactive Material, 8=Corrosive Substances, 9=Miscellaneous). [ENUM-REF-CANDIDATE: 1|2|3|4|5|6|7|8|9 — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDivision rdf:type rdf:Property ;
    rdfs:label 'Hazard Division' ;
    rdfs:comment 'Subdivision within the hazard class providing more specific categorization of the dangerous goods (e.g., 1.1, 1.2, 2.1, 2.2).' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitedQuantityIndicator rdf:type rdf:Property ;
    rdfs:label 'Limited Quantity Indicator' ;
    rdfs:comment 'Indicates whether the dangerous goods are shipped in limited quantities, allowing for relaxed packaging and labeling requirements.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marinePollutantIndicator rdf:type rdf:Property ;
    rdfs:label 'Marine Pollutant Indicator' ;
    rdfs:comment 'Indicates whether the dangerous goods are classified as a marine pollutant under IMDG Code.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netQuantity rdf:type rdf:Property ;
    rdfs:label 'Net Quantity' ;
    rdfs:comment 'Net quantity of the dangerous goods excluding packaging, expressed in the unit of measure specified.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingInstruction rdf:type rdf:Property ;
    rdfs:label 'Packaging Instruction' ;
    rdfs:comment 'Specific packaging instruction number from the applicable dangerous goods regulation (e.g., P001, IBC01, LP01).' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingTypeCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Type Code' ;
    rdfs:comment 'Code identifying the type of packaging used for the dangerous goods (e.g., drum, box, cylinder).' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'Degree of danger presented by the substance (I=Great Danger, II=Medium Danger, III=Minor Danger).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:properShippingName rdf:type rdf:Property ;
    rdfs:label 'Proper Shipping Name' ;
    rdfs:comment 'Official name of the dangerous goods as specified in the UN Model Regulations, used for identification and documentation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the net and gross quantities (e.g., kilograms, liters).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Status indicating whether the dangerous goods declaration meets all applicable regulatory requirements for the transport mode and jurisdictions involved.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationGroup rdf:type rdf:Property ;
    rdfs:label 'Segregation Group' ;
    rdfs:comment 'Segregation group code indicating compatibility and stowage requirements for the dangerous goods in relation to other cargo.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperAddress rdf:type rdf:Property ;
    rdfs:label 'Shipper Address' ;
    rdfs:comment 'Full address of the shipper or consignor of the dangerous goods.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Shipper Certification Date' ;
    rdfs:comment 'Date on which the shipper certified the dangerous goods declaration.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipperCertificationSignature rdf:type rdf:Property ;
    rdfs:label 'Shipper Certification Signature' ;
    rdfs:comment 'Name or digital signature of the authorized person who certified the dangerous goods declaration on behalf of the shipper.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperCertificationStatement rdf:type rdf:Property ;
    rdfs:label 'Shipper Certification Statement' ;
    rdfs:comment 'Certification statement signed by the shipper declaring that the dangerous goods are properly classified, packaged, marked, and labeled, and in proper condition for transport.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'Name of the shipper or consignor responsible for the dangerous goods shipment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Unique identifier of this dangerous goods declaration in the source operational system.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProvisionCodes rdf:type rdf:Property ;
    rdfs:label 'Special Provision Codes' ;
    rdfs:comment 'Comma-separated list of special provision codes applicable to the dangerous goods, indicating exceptions or additional requirements.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stowageCategory rdf:type rdf:Property ;
    rdfs:label 'Stowage Category' ;
    rdfs:comment 'Stowage category for ocean transport indicating where the dangerous goods may be stowed on the vessel (A=on deck or under deck, B=on deck only, C=away from living quarters, D=on deck only away from living quarters, E=on deck only in open cargo space).' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsidiaryHazard rdf:type rdf:Property ;
    rdfs:label 'Subsidiary Hazard' ;
    rdfs:comment 'Secondary hazard class or division if the dangerous goods present more than one type of hazard.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalName rdf:type rdf:Property ;
    rdfs:label 'Technical Name' ;
    rdfs:comment 'Chemical or technical name of the dangerous goods, required when the proper shipping name is a generic or N.O.S. (Not Otherwise Specified) entry.' ;
    rdfs:domain ind:DgDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawbackClaimId rdf:type rdf:Property ;
    rdfs:label 'Drawback Claim Id' ;
    rdfs:comment 'Unique identifier for the duty drawback claim record. Primary key.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimantTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Claimant Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Claimant in drawback claim is a trade party. Adding claimant_trade_party_id FK to trade_party.trade_party_id normalizes the claimant reference. Cardinality: N:1 (many drawback claims can have the same' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:exportConsignmentId rdf:type rdf:Property ;
    rdfs:label 'Export Consignment Id' ;
    rdfs:comment 'Foreign key linking to shipment.consignment. Business justification: Drawback claims recover duties on exported goods. Claims require proof of export via consignment documentation. Linking claim to export consignment enables automated duty recovery, audit trail, and cl' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consignment .

ind:importDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Import Declaration Id' ;
    rdfs:comment 'Foreign key linking to customs.declaration. Business justification: Drawback claims reference the original import declaration to prove duty was paid. Adding import_declaration_id FK to declaration.declaration_id establishes this relationship. Cardinality: N:1 (many dr' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Declaration .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Drawback claims prepared by licensed customs brokers (employees). CBP regulatory requirement for duty recovery. Tracks individual accountability for claim accuracy and supporting documentation.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceleratedPaymentIndicator rdf:type rdf:Property ;
    rdfs:label 'Accelerated Payment Indicator' ;
    rdfs:comment 'Flag indicating whether the claim qualifies for accelerated payment processing under CBP\'s accelerated drawback program.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of times the drawback claim has been amended or resubmitted after initial filing.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedDrawbackAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Drawback Amount' ;
    rdfs:comment 'Final drawback amount approved by customs authority for payment after review and validation.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Broker License Number' ;
    rdfs:comment 'Official license number of the customs broker authorized to file drawback claims.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerName rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Name' ;
    rdfs:comment 'Name of the licensed customs broker or agent who prepared and filed the drawback claim on behalf of the claimant.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialDate rdf:type rdf:Property ;
    rdfs:label 'Denial Date' ;
    rdfs:comment 'Date the customs authority officially denied the drawback claim.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Explanation provided by customs authority if the drawback claim was denied, including regulatory citation and corrective action required.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionDate rdf:type rdf:Property ;
    rdfs:label 'Destruction Date' ;
    rdfs:comment 'Date the goods were destroyed under customs supervision if destruction method was used instead of export.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destructionIndicator rdf:type rdf:Property ;
    rdfs:label 'Destruction Indicator' ;
    rdfs:comment 'Flag indicating whether the goods were destroyed under customs supervision rather than exported, qualifying for drawback under destruction provisions.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drawbackAmountClaimed rdf:type rdf:Property ;
    rdfs:label 'Drawback Amount Claimed' ;
    rdfs:comment 'Total drawback amount being claimed for recovery, calculated per drawback regulations (typically 99% of duty paid).' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawbackType rdf:type rdf:Property ;
    rdfs:label 'Drawback Type' ;
    rdfs:comment 'Type of drawback claim being filed: manufacturing drawback (goods used in manufacturing exported products), unused merchandise drawback (imported goods exported without use), rejected merchandise drawback (defective goods returned/destroyed), or substitution drawback variants.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Paid Amount' ;
    rdfs:comment 'Total amount of customs duty originally paid on the imported goods at time of import entry.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exportedCommodityDescription rdf:type rdf:Property ;
    rdfs:label 'Exported Commodity Description' ;
    rdfs:comment 'Detailed description of the exported goods or manufactured articles qualifying for drawback.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportedHsCode rdf:type rdf:Property ;
    rdfs:label 'Exported Hs Code' ;
    rdfs:comment 'HS tariff classification code for the exported merchandise at time of export.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importedCommodityDescription rdf:type rdf:Property ;
    rdfs:label 'Imported Commodity Description' ;
    rdfs:comment 'Detailed description of the imported goods on which duty was originally paid.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importedHsCode rdf:type rdf:Property ;
    rdfs:label 'Imported Hs Code' ;
    rdfs:comment 'HS tariff classification code for the imported merchandise at time of import entry.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or correction to the drawback claim.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Process Description' ;
    rdfs:comment 'Description of the manufacturing process applied to imported goods to create the exported article (required for manufacturing drawback claims).' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityExported rdf:type rdf:Property ;
    rdfs:label 'Quantity Exported' ;
    rdfs:comment 'Quantity of goods exported or destroyed that qualifies for drawback recovery.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityImported rdf:type rdf:Property ;
    rdfs:label 'Quantity Imported' ;
    rdfs:comment 'Quantity of goods originally imported on which duty was paid.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewOfficerName rdf:type rdf:Property ;
    rdfs:label 'Review Officer Name' ;
    rdfs:comment 'Name of the customs officer assigned to review and validate the drawback claim.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionIndicator rdf:type rdf:Property ;
    rdfs:label 'Substitution Indicator' ;
    rdfs:comment 'Flag indicating whether this is a substitution drawback claim where commercially interchangeable merchandise was substituted for the imported goods.' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportingDocumentsSubmitted rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents Submitted' ;
    rdfs:comment 'List or summary of supporting documentation submitted with the claim (import entry, export documentation, manufacturing records, certificates of delivery, etc.).' ;
    rdfs:domain ind:DrawbackClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Duty Assessment Id' ;
    rdfs:comment 'Unique identifier for the duty assessment record. Primary key for the duty assessment transaction.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DutyAssessment .

ind:assessedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Duty assessments performed by customs officers or licensed brokers (employees). Regulatory requirement for accountability, audit trail, and dispute resolution. Tracks who calculated and approved the a' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originalAssessmentDutyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Original Assessment Duty Assessment Id' ;
    rdfs:comment 'Reference to the original duty assessment record if this is an adjusted or corrected assessment. Creates audit trail for assessment changes. Null for original assessments.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DutyAssessment .

ind:pricingChargeCodeId rdf:type rdf:Property ;
    rdfs:label 'Pricing Charge Code Id' ;
    rdfs:comment 'Foreign key linking to pricing.charge_code. Business justification: Duty assessments generate billable charges that must map to pricing charge codes for invoicing and revenue recognition. Required for integrating customs duty costs into customer billing and financial ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChargeCode .

ind:tradePartyId rdf:type rdf:Property ;
    rdfs:label 'Trade Party Id' ;
    rdfs:comment 'Reference to the party legally responsible for paying the assessed duties and taxes. The importer of record as declared on the customs entry.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:antiDumpingDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Anti Dumping Duty Amount' ;
    rdfs:comment 'Anti-dumping duty assessed when goods are imported at below fair market value. Additional duty imposed to protect domestic industry from unfair trade practices.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the duty assessment was calculated and issued by the customs authority or broker system. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method by which the duty assessment was calculated. Automated = system-calculated; Manual = customs officer review; Hybrid = system with officer override; Post_audit = retrospective assessment after release.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the duty assessment. Externally visible reference number used in customs documentation and payment processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assessment Source System' ;
    rdfs:comment 'Name of the system that generated the duty assessment calculation. Typically the customs broker GTM system or customs authority automated system.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the duty assessment. Estimated = preliminary calculation; Assessed = official customs authority calculation; Final = confirmed and payable; Disputed = under review or appeal; Adjusted = modified after initial assessment; Cancelled = voided assessment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'Precise date and time when the duty assessment calculation was executed. Used for audit trail and calculation sequencing.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'Incoterms basis used for duty calculation. CIF = Cost Insurance Freight; FOB = Free on Board; DDP = Delivered Duty Paid; DAP = Delivered at Place; EXW = Ex Works; FCA = Free Carrier. Determines which costs are included in the customs value.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countervailingDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Countervailing Duty Amount' ;
    rdfs:comment 'Countervailing duty assessed to offset foreign government subsidies. Additional duty imposed when imported goods benefit from subsidies in the country of origin.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Duty Amount' ;
    rdfs:comment 'Total customs duty assessed on the imported or exported goods. Standard ad valorem or specific duty based on HS Code classification and tariff schedule.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFiledDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Filed Date' ;
    rdfs:comment 'Date when a formal dispute or protest was filed with the customs authority regarding this assessment. Null if no dispute filed.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Type of customs entry for which duty is assessed. Consumption = immediate release for domestic use; Warehouse = bonded storage; Temporary = temporary import; FTZ = Free Trade Zone; Carnet = temporary admission under ATA Carnet.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'Date for which the exchange rate was published and applied. Typically the date of export, entry filing, or customs authority determination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:harborMaintenanceFee rdf:type rdf:Property ;
    rdfs:label 'Harbor Maintenance Fee' ;
    rdfs:comment 'Fee assessed on cargo loaded or unloaded at US ports. Used to fund harbor maintenance and dredging operations.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:importExportIndicator rdf:type rdf:Property ;
    rdfs:label 'Import Export Indicator' ;
    rdfs:comment 'Indicates whether this duty assessment is for an import or export transaction. Most assessments are for imports; some jurisdictions assess export duties.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseProcessingFee rdf:type rdf:Property ;
    rdfs:label 'Merchandise Processing Fee' ;
    rdfs:comment 'Fee charged by customs authority for processing the import entry. Administrative charge for customs clearance services.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Other Fees Amount' ;
    rdfs:comment 'Sum of miscellaneous customs-related fees not captured in standard categories. May include inspection fees, storage fees, or special handling charges.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which the assessed duties and taxes must be paid to the customs authority. Failure to pay by this date may result in penalties, interest, or cargo holds.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portOfEntryCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Code' ;
    rdfs:comment 'Code identifying the customs port or border crossing where the goods entered the country and duty was assessed. UN/LOCODE or national port code.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferentialDutyRate rdf:type rdf:Property ;
    rdfs:label 'Preferential Duty Rate' ;
    rdfs:comment 'Reduced duty rate percentage applied under a preferential tariff program or free trade agreement. Lower than the standard Most Favored Nation (MFN) rate.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferentialTariffProgram rdf:type rdf:Property ;
    rdfs:label 'Preferential Tariff Program' ;
    rdfs:comment 'Free trade agreement or preferential tariff program applied to reduce or eliminate duty. Examples: USMCA, EU-UK TCA, CPTPP, GSP. Empty if no preference claimed.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Code' ;
    rdfs:comment 'Harmonized System classification code used to determine applicable duty rates. Six to ten digit code identifying the product category for tariff purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDutyTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Duty Tax Amount' ;
    rdfs:comment 'Total liability including all duties, taxes, and fees assessed on this customs entry. Sum of customs duty, anti-dumping duty, countervailing duty, VAT, excise tax, and all fees.' ;
    rdfs:domain ind:DutyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftzAdmissionId rdf:type rdf:Property ;
    rdfs:label 'Ftz Admission Id' ;
    rdfs:comment 'Unique identifier for the FTZ admission record. Primary key for the ftz_admission product.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtzAdmission .

ind:admittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Admitted By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FTZ admissions processed by licensed customs brokers (employees). CBP regulatory requirement. Tracks individual accountability for admission accuracy and compliance with FTZ regulations.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:admissionDate rdf:type rdf:Property ;
    rdfs:label 'Admission Date' ;
    rdfs:comment 'The date on which the merchandise was formally admitted into the FTZ. This is the principal business event timestamp for the admission transaction.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:admissionNumber rdf:type rdf:Property ;
    rdfs:label 'Admission Number' ;
    rdfs:comment 'The official admission number assigned by CBP for this FTZ entry. This is the externally-known business identifier for the admission transaction.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admissionStatus rdf:type rdf:Property ;
    rdfs:label 'Admission Status' ;
    rdfs:comment 'Current lifecycle status of the FTZ admission. Tracks the admission from initial filing through final disposition.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admissionType rdf:type rdf:Property ;
    rdfs:label 'Admission Type' ;
    rdfs:comment 'Classification of the admission based on the origin and status of the merchandise. Determines duty treatment and compliance requirements.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Declared Value Usd' ;
    rdfs:comment 'The declared customs value of the merchandise in US Dollars. Used for duty calculation and inventory accounting within the FTZ.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDutyAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Duty Amount Usd' ;
    rdfs:comment 'Estimated customs duty that would be owed if the merchandise were entered for consumption. Used for duty deferral accounting and financial planning.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingMethod rdf:type rdf:Property ;
    rdfs:label 'Filing Method' ;
    rdfs:comment 'The method by which the FTZ admission was filed with CBP. ACE is the preferred electronic filing system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzOperatorName rdf:type rdf:Property ;
    rdfs:label 'Ftz Operator Name' ;
    rdfs:comment 'Name of the entity operating the FTZ facility where the merchandise is admitted.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzZoneNumber rdf:type rdf:Property ;
    rdfs:label 'Ftz Zone Number' ;
    rdfs:comment 'The designated FTZ zone number where the merchandise is being admitted. Format follows CBP zone numbering convention.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturer or importer lot number for traceability and quality control purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseDescription rdf:type rdf:Property ;
    rdfs:label 'Merchandise Description' ;
    rdfs:comment 'Detailed textual description of the goods being admitted into the FTZ. Must be sufficient for CBP classification and valuation purposes.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProgramIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Program Indicator' ;
    rdfs:comment 'Indicates if the admission is subject to special compliance programs or regulatory oversight beyond standard CBP requirements.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Specific warehouse or storage location within the FTZ where the merchandise is stored. Used for inventory tracking.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date on which the merchandise was withdrawn from the FTZ for consumption, export, or destruction. Null if still in zone.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalType rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Type' ;
    rdfs:comment 'The manner in which the merchandise was withdrawn from the FTZ. Determines final duty treatment and compliance obligations.' ;
    rdfs:domain ind:FtzAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzInventoryId rdf:type rdf:Property ;
    rdfs:label 'Ftz Inventory Id' ;
    rdfs:comment 'Unique identifier for the FTZ inventory record. Primary key for tracking goods held within Foreign Trade Zone facilities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtzInventory .

ind:ftzSiteNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Ftz Site Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: FTZ zones are physical locations in the logistics network. Required for inventory visibility by node, zone-to-zone transfer planning, and network capacity management. Replaces denormalized ftz_site_lo' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:inventoryManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inventory Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FTZ inventory requires designated inventory managers (employees). CBP regulatory requirement for zone accountability. Tracks who is responsible for inventory accuracy and cycle counts.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ownerTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Owner Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: FTZ inventory is owned by a trade party (importer, manufacturer, etc.). Adding owner_trade_party_id FK to trade_party.trade_party_id normalizes the owner reference. Cardinality: N:1 (many inventory re' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:packagingSustainabilityId rdf:type rdf:Property ;
    rdfs:label 'Packaging Sustainability Id' ;
    rdfs:comment 'Foreign key linking to sustainability.packaging_sustainability. Business justification: Free Trade Zone inventory operations track packaging materials for Extended Producer Responsibility (EPR) compliance and circular economy reporting. Real process: Warehouse-level packaging waste track' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingSustainability .

ind:cbpBondNumber rdf:type rdf:Property ;
    rdfs:label 'Cbp Bond Number' ;
    rdfs:comment 'CBP continuous bond number covering the FTZ operator and goods. Required for FTZ operations to guarantee duty payment and compliance.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsValueUsd rdf:type rdf:Property ;
    rdfs:label 'Customs Value Usd' ;
    rdfs:comment 'Declared customs value of the inventory in US dollars. Used for duty calculation and financial reporting. Based on transaction value or WTO valuation methods.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Variance Quantity' ;
    rdfs:comment 'Difference between system quantity and physical count during last cycle count. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exportDate rdf:type rdf:Property ;
    rdfs:label 'Export Date' ;
    rdfs:comment 'Date when goods were exported from the FTZ to a foreign destination. Exports from FTZ are not subject to US customs duties.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportDestinationCountry rdf:type rdf:Property ;
    rdfs:label 'Export Destination Country' ;
    rdfs:comment 'Three-letter ISO country code representing the final destination country for exported goods. Used for export compliance and trade statistics.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzZoneType rdf:type rdf:Property ;
    rdfs:label 'Ftz Zone Type' ;
    rdfs:comment 'Classification of the FTZ facility: general purpose (multi-user), subzone (single-user dedicated), or usage-driven (hybrid model).' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether the inventory contains hazardous materials requiring special handling, storage, and compliance with IMDG or IATA dangerous goods regulations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Usd' ;
    rdfs:comment 'Declared insurance value of the inventory in US dollars. Used for cargo insurance coverage and claims processing.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory cycle count for this lot. Used for inventory accuracy monitoring and audit compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manipulationDescription rdf:type rdf:Property ;
    rdfs:label 'Manipulation Description' ;
    rdfs:comment 'Detailed description of manufacturing, assembly, repackaging, or other manipulation activities performed on the goods within the FTZ.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manipulationStatus rdf:type rdf:Property ;
    rdfs:label 'Manipulation Status' ;
    rdfs:comment 'Current status of any manufacturing, processing, or manipulation activities performed on the goods within the FTZ. FTZ regulations permit certain value-added activities.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current quantity of the commodity physically present in the FTZ facility. Updated in real-time as goods are admitted, manipulated, or removed.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Internal stock keeping unit identifier for the commodity held in the FTZ. Used for inventory tracking and warehouse management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Specific warehouse location within the FTZ facility (e.g., aisle, rack, bin) where the inventory is physically stored. Used for warehouse management and cycle counting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledIndicator rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Indicator' ;
    rdfs:comment 'Flag indicating whether the inventory requires temperature-controlled storage (refrigerated or frozen). Critical for cold chain management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRangeCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Celsius' ;
    rdfs:comment 'Required storage temperature range in Celsius (e.g., 2-8°C for pharmaceuticals, -18°C for frozen goods). Used for cold chain compliance.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneLotNumber rdf:type rdf:Property ;
    rdfs:label 'Zone Lot Number' ;
    rdfs:comment 'Internal lot or batch number assigned by the FTZ operator for inventory tracking and First In First Out (FIFO) or Last In First Out (LIFO) management.' ;
    rdfs:domain ind:FtzInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current disposition of the inventory: in-zone (still in FTZ), transferred (moved to another FTZ), exported (left US), consumed (used in manufacturing), destroyed, or entered commerce (duty paid and released to US market).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classifierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Classifier Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: HS classification performed by licensed customs brokers or trade compliance specialists (employees). Required for binding rulings, audit trail, and regulatory compliance. Classifier_name is denormaliz' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bindingRulingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Binding Ruling Expiry Date' ;
    rdfs:comment 'The date on which the binding tariff ruling expires and is no longer valid for use. Nullable if the ruling has no expiration or is valid indefinitely.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bindingRulingIndicator rdf:type rdf:Property ;
    rdfs:label 'Binding Ruling Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this classification is based on a binding tariff ruling issued by a customs authority. Binding rulings provide legal certainty and protection from reclassification penalties.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bindingRulingIssueDate rdf:type rdf:Property ;
    rdfs:label 'Binding Ruling Issue Date' ;
    rdfs:comment 'The date on which the binding tariff ruling was officially issued by the customs authority. Determines the start of the ruling validity period.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bindingRulingIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Binding Ruling Issuing Authority' ;
    rdfs:comment 'The name of the customs authority or government agency that issued the binding tariff ruling. Examples include US CBP, HMRC, EU Commission.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bindingRulingReference rdf:type rdf:Property ;
    rdfs:label 'Binding Ruling Reference' ;
    rdfs:comment 'The official reference number or identifier of the binding tariff ruling issued by the customs authority. Used to cite the ruling in customs declarations and audits.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Classification Confidence Score' ;
    rdfs:comment 'A numerical score (0-100) representing the confidence level in the assigned HS Code classification. Used for automated classifications to flag low-confidence assignments for manual review.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classificationDate rdf:type rdf:Property ;
    rdfs:label 'Classification Date' ;
    rdfs:comment 'The date on which the HS Code classification was assigned or approved. Used to determine applicability of tariff rates and trade regulations in effect at that time.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationMethod rdf:type rdf:Property ;
    rdfs:label 'Classification Method' ;
    rdfs:comment 'The method by which the HS Code classification was determined. Automated indicates system-driven classification; manual indicates customs broker review; binding ruling indicates official customs authority determination; third party ruling indicates external consultant classification; customer declared indicates shipper-provided classification.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationNotes rdf:type rdf:Property ;
    rdfs:label 'Classification Notes' ;
    rdfs:comment 'Free-text notes and comments from the classifier explaining the rationale for the HS Code assignment, including references to tariff schedule notes, explanatory notes, or ruling precedents.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Current lifecycle status of the HS classification record. Tracks whether the classification is in draft, under review, approved for use, rejected, expired, or superseded by a newer classification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classifierLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Classifier License Number' ;
    rdfs:comment 'Professional license or certification number of the customs broker who performed the classification. Required for regulatory compliance and audit purposes in jurisdictions that mandate licensed brokers.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfClassification rdf:type rdf:Property ;
    rdfs:label 'Country Of Classification' ;
    rdfs:comment 'The 3-letter ISO country code indicating the jurisdiction for which this HS classification applies. HS codes may vary by country at the 8-digit and 10-digit levels.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Percentage' ;
    rdfs:comment 'The applicable customs duty rate as a percentage of the goods value, based on the assigned HS Code and destination country. Used for landed cost calculation and duty estimation.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exciseTaxApplicableIndicator rdf:type rdf:Property ;
    rdfs:label 'Excise Tax Applicable Indicator' ;
    rdfs:comment 'Boolean flag indicating whether excise taxes apply to the classified goods in addition to customs duties. Common for alcohol, tobacco, fuel, and luxury goods.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportControlClassificationNumber rdf:type rdf:Property ;
    rdfs:label 'Export Control Classification Number' ;
    rdfs:comment 'The ECCN assigned to the goods for export control purposes. Used to determine whether an export license is required under dual-use or military export regulations.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode10Digit rdf:type rdf:Property ;
    rdfs:label 'Hs Code 10 Digit' ;
    rdfs:comment 'The 10-digit national tariff code used by specific countries (e.g., USA HTS code). Provides the most granular level of commodity classification for duty and tax calculation.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode6Digit rdf:type rdf:Property ;
    rdfs:label 'Hs Code 6 Digit' ;
    rdfs:comment 'The 6-digit HS Code as defined by the World Customs Organization (WCO). This is the internationally standardized classification code used globally for customs tariff purposes.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode8Digit rdf:type rdf:Property ;
    rdfs:label 'Hs Code 8 Digit' ;
    rdfs:comment 'The 8-digit HS Code used in the European Union Combined Nomenclature (CN). Extends the 6-digit WCO code with two additional digits for EU-specific classification.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importLicenseRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Import License Required Indicator' ;
    rdfs:comment 'Boolean flag indicating whether an import license or permit is required for the classified goods in the destination country. Used to trigger license application workflows.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferentialDutyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Preferential Duty Rate Percentage' ;
    rdfs:comment 'The reduced duty rate applicable under a Free Trade Agreement (FTA) or preferential trade program. Nullable if no preferential treatment applies.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'The high-level product category or commodity group to which the classified goods belong. Used for reporting and analytics on classification patterns by product type.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'The customer or internal SKU code for the specific product or commodity to which this HS classification applies. Links the classification to inventory and order management systems.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Record Version Number' ;
    rdfs:comment 'Sequential version number incremented each time the classification record is modified. Used for optimistic locking and change history tracking.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictedGoodsIndicator rdf:type rdf:Property ;
    rdfs:label 'Restricted Goods Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the classified goods are subject to import or export restrictions, embargoes, or sanctions. Triggers compliance screening and approval workflows.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Review Required Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this classification requires periodic review or re-validation. Set to true for complex classifications, borderline cases, or when tariff schedules are updated.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vatRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percentage' ;
    rdfs:comment 'The applicable VAT or Goods and Services Tax (GST) rate as a percentage, based on the HS Code and destination country. Used for total landed cost calculation.' ;
    rdfs:domain ind:HsClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Incoterms Assignment Id' ;
    rdfs:comment 'Unique identifier for the Incoterms assignment record. Primary key for this entity.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incotermsChargeAllocationId rdf:type rdf:Property ;
    rdfs:label 'Incoterms Charge Allocation Id' ;
    rdfs:comment 'Foreign key linking to pricing.incoterms_charge_allocation. Business justification: Incoterms assignments must reference charge allocation rules to determine cost responsibility (seller vs buyer) for freight, insurance, customs, and handling charges. Core pricing logic for internatio' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IncotermsChargeAllocation .

ind:primaryIncotermsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Incoterms Employee Id' ;
    rdfs:comment 'Identifier of the user or system that created this Incoterms assignment. Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tradeTransactionId rdf:type rdf:Property ;
    rdfs:label 'Trade Transaction Id' ;
    rdfs:comment 'Reference to the broader trade transaction or commercial invoice to which this Incoterms assignment applies. Supports cross-border trade compliance tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeTransaction .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'The date and time when this Incoterms assignment was created in the system. Provides audit trail for compliance and dispute resolution.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Business-readable unique identifier for the Incoterms assignment. Used for external communication and audit trail purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'Indicates the source document or process from which this Incoterms assignment was derived. Supports audit trail and data lineage tracking.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerCostResponsibility rdf:type rdf:Property ;
    rdfs:label 'Buyer Cost Responsibility' ;
    rdfs:comment 'Detailed enumeration of costs that the buyer is responsible for under the assigned Incoterms rule. Complements seller cost responsibility to provide full cost allocation picture.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerPartyName rdf:type rdf:Property ;
    rdfs:label 'Buyer Party Name' ;
    rdfs:comment 'Name of the buyer party in the transaction governed by this Incoterms assignment. Provides business context for liability and cost allocation.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityType rdf:type rdf:Property ;
    rdfs:label 'Commodity Type' ;
    rdfs:comment 'General classification of the commodity being shipped under this Incoterms assignment. Certain commodities may have preferred or restricted Incoterms rules.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costResponsibilityBoundary rdf:type rdf:Property ;
    rdfs:label 'Cost Responsibility Boundary' ;
    rdfs:comment 'Description of the point up to which the seller bears transportation and logistics costs. Defines the financial split between buyer and seller for freight, handling, and related charges.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyBasisCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Duty Basis Calculation Method' ;
    rdfs:comment 'Indicates the valuation basis used for customs duty calculation. CIF-based Incoterms include cost, insurance, and freight in the customs value; FOB-based rules include only the goods value. Critical for accurate duty and tax assessment.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportCustomsClearanceParty rdf:type rdf:Property ;
    rdfs:label 'Export Customs Clearance Party' ;
    rdfs:comment 'Indicates which party is responsible for completing export customs clearance formalities and paying export duties and taxes. Under most Incoterms rules, the seller handles export clearance.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importCustomsClearanceParty rdf:type rdf:Property ;
    rdfs:label 'Import Customs Clearance Party' ;
    rdfs:comment 'Indicates which party is responsible for completing import customs clearance formalities and paying import duties and taxes. Only under DDP does the seller handle import clearance; under all other rules, the buyer is responsible.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsRuleCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Rule Code' ;
    rdfs:comment 'The three-letter code representing the specific Incoterms rule assigned to the transaction. Defines the allocation of costs, risks, and responsibilities between buyer and seller. Examples: EXW (Ex Works), FOB (Free on Board), CIF (Cost Insurance and Freight), DDP (Delivered Duty Paid). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsRuleName rdf:type rdf:Property ;
    rdfs:label 'Incoterms Rule Name' ;
    rdfs:comment 'The full descriptive name of the Incoterms rule. Provides human-readable context for the rule code (e.g., \'Free on Board\', \'Delivered Duty Paid\').' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsVersion rdf:type rdf:Property ;
    rdfs:label 'Incoterms Version' ;
    rdfs:comment 'The version year of the Incoterms rules being applied. Determines which rule set and interpretations govern the transaction. Most common versions are 2020 and 2010.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageLevel rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Level' ;
    rdfs:comment 'The minimum insurance coverage level required under the Incoterms rule. For CIP, Institute Cargo Clauses (A) or equivalent is required; for CIF, Institute Cargo Clauses (C) or equivalent minimum coverage applies.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceObligationParty rdf:type rdf:Property ;
    rdfs:label 'Insurance Obligation Party' ;
    rdfs:comment 'Indicates which party (seller or buyer) is obligated to procure cargo insurance under the assigned Incoterms rule. For CIP and CIF, the seller must insure; for most other rules, insurance is optional or buyer\'s responsibility.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namedPlace rdf:type rdf:Property ;
    rdfs:label 'Named Place' ;
    rdfs:comment 'The specific location or port designated in the Incoterms rule where risk and cost transfer occurs. This is the critical point that defines obligations (e.g., \'Port of Shanghai\', \'Warehouse in Hamburg\', \'Customer facility in Chicago\').' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namedPlaceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Named Place Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the country where the named place is located. Supports geographic analysis and customs compliance.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namedPlaceType rdf:type rdf:Property ;
    rdfs:label 'Named Place Type' ;
    rdfs:comment 'Classification of the named place location type. Indicates whether the named place is a seaport, airport, inland terminal, warehouse, or customer facility.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTransferPoint rdf:type rdf:Property ;
    rdfs:label 'Risk Transfer Point' ;
    rdfs:comment 'Detailed description of the exact point at which risk transfers from seller to buyer under the assigned Incoterms rule. Critical for liability determination and insurance coverage decisions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerCostResponsibility rdf:type rdf:Property ;
    rdfs:label 'Seller Cost Responsibility' ;
    rdfs:comment 'Detailed enumeration of costs that the seller is responsible for under the assigned Incoterms rule. May include export packing, loading, main carriage, insurance, unloading, and import duties depending on the rule.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerPartyName rdf:type rdf:Property ;
    rdfs:label 'Seller Party Name' ;
    rdfs:comment 'Name of the seller party in the transaction governed by this Incoterms assignment. Provides business context for liability and cost allocation.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportModeApplicability rdf:type rdf:Property ;
    rdfs:label 'Transport Mode Applicability' ;
    rdfs:comment 'Indicates whether the assigned Incoterms rule can be used for any mode of transport or is restricted to sea and inland waterway transport only. Rules like FOB, CFR, CIF, FAS are sea/waterway only; rules like EXW, FCA, CPT, CIP, DAP, DPU, DDP apply to any mode.' ;
    rdfs:domain ind:IncotermsAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfFilingId rdf:type rdf:Property ;
    rdfs:label 'Isf Filing Id' ;
    rdfs:comment 'Unique identifier for the ISF filing record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsfFiling .

ind:manufacturerSupplierId rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: ISF 10+2 filings require manufacturer/supplier details for CBP compliance. Customs brokers pull supplier master data (name, address, country) from procurement systems for accurate ISF submission and i' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:buyerAddress rdf:type rdf:Property ;
    rdfs:label 'Buyer Address' ;
    rdfs:comment 'Full address of the buyer, including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the last known entity to whom the goods are sold or agreed to be sold. If the goods are to be imported otherwise than in pursuance of a purchase, the name of the owner. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbpRejectionReason rdf:type rdf:Property ;
    rdfs:label 'Cbp Rejection Reason' ;
    rdfs:comment 'Detailed reason provided by CBP for rejecting the ISF filing. May include error codes, missing data elements, or compliance violations.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbpResponseDate rdf:type rdf:Property ;
    rdfs:label 'Cbp Response Date' ;
    rdfs:comment 'Date and time when CBP responded to the ISF filing with acceptance, rejection, or request for amendment.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cbpResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Cbp Response Status' ;
    rdfs:comment 'Status of CBP\'s response to the ISF filing. Accepted indicates the filing meets all requirements. Rejected indicates the filing contains errors or missing data. Amendment required indicates CBP requires corrections. Pending review indicates CBP has not yet completed their review.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatorAddress rdf:type rdf:Property ;
    rdfs:label 'Consolidator Address' ;
    rdfs:comment 'Full address of the consolidator, including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatorName rdf:type rdf:Property ;
    rdfs:label 'Consolidator Name' ;
    rdfs:comment 'Name of the party who stuffed the container or arranged for the stuffing of the container. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerStuffingLocation rdf:type rdf:Property ;
    rdfs:label 'Container Stuffing Location' ;
    rdfs:comment 'Physical location where the container was stuffed (loaded). Must include the name and address of the facility. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License Number' ;
    rdfs:comment 'CBP-issued license number of the customs broker who filed the ISF.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htsusCode rdf:type rdf:Property ;
    rdfs:label 'Htsus Code' ;
    rdfs:comment 'The 6-digit or 10-digit Harmonized Tariff Schedule classification code for the commodity. Used to determine duty rates and trade compliance requirements. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Isf Transaction Number' ;
    rdfs:comment 'Unique transaction number assigned by US Customs and Border Protection (CBP) upon successful ISF submission. This is the official CBP reference number for the filing.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyReason rdf:type rdf:Property ;
    rdfs:label 'Penalty Reason' ;
    rdfs:comment 'Detailed explanation of why a penalty was assessed by CBP. May include late filing, inaccurate data, missing data elements, or failure to update.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Risk Flag' ;
    rdfs:comment 'Indicates whether this ISF filing is at risk of CBP penalties due to late filing, inaccurate data, or non-compliance. True indicates penalty risk exists. False indicates no known penalty risk.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portOfLading rdf:type rdf:Property ;
    rdfs:label 'Port Of Lading' ;
    rdfs:comment 'Foreign port where the cargo was laden aboard the vessel. Represented as a 5-character UN/LOCODE.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerAddress rdf:type rdf:Property ;
    rdfs:label 'Seller Address' ;
    rdfs:comment 'Full address of the seller, including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPartyAddress rdf:type rdf:Property ;
    rdfs:label 'Ship To Party Address' ;
    rdfs:comment 'Full address of the ship-to party, including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPartyName rdf:type rdf:Property ;
    rdfs:label 'Ship To Party Name' ;
    rdfs:comment 'Name of the first deliver-to party scheduled to physically receive the goods after the goods have been released from customs custody. This is one of the 10 required data elements for ISF-10.' ;
    rdfs:domain ind:IsfFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Applicant Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Applicant for license/permit is a trade party. Adding applicant_trade_party_id FK to trade_party.trade_party_id normalizes the applicant reference. Cardinality: N:1 (many license/permit applications c' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:authorizedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Authorized Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Import/export licenses specify authorized suppliers or beneficiaries for controlled goods. Compliance teams validate shipments against licensed supplier lists, requiring supplier master linkage for li' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Import licenses for capital equipment link to asset capitalization. Essential for capex tracking, asset acquisition compliance, and audit trail linking import permits to capitalized assets.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:authorizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Authorized Quantity' ;
    rdfs:comment 'Maximum quantity of goods authorized for import or export under this license or permit. Measured in the unit specified in authorized_unit_of_measure.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Authorized Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the authorized quantity (e.g., kilograms, pieces, liters, cubic meters). Aligns with customs declaration unit standards.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Authorized Value Amount' ;
    rdfs:comment 'Maximum monetary value of goods authorized for import or export under this license or permit. Expressed in the currency specified in authorized_value_currency_code.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Authorized Value Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the authorized value amount.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseDescription rdf:type rdf:Property ;
    rdfs:label 'End Use Description' ;
    rdfs:comment 'Description of the intended end use or purpose of the goods covered by this license. Required for certain controlled items and dual-use export authorizations to ensure compliance with end-use restrictions.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUserName rdf:type rdf:Property ;
    rdfs:label 'End User Name' ;
    rdfs:comment 'Legal name of the final end user or consignee of the goods covered by this license. Required for export control compliance and denied party screening.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Official license or permit number issued by the regulatory authority. This is the externally-known unique identifier used for customs declarations and trade compliance filings.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle status of the license or permit. Indicates whether the authorization is valid and available for use in customs declarations.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the license or permit based on regulatory purpose. Determines the type of authorization granted for controlled, restricted, or regulated goods movement.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Previous License Number' ;
    rdfs:comment 'License number of the previous authorization if this is a renewal. Provides audit trail and continuity for renewed licenses.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Order Number' ;
    rdfs:comment 'Official quota order number or tariff rate quota (TRQ) reference assigned by the customs authority. Used to track utilization against quota limits.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'Available balance of quantity that can still be utilized under this license or permit. Calculated as authorized_quantity minus utilized_quantity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingValueAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Value Amount' ;
    rdfs:comment 'Available balance of monetary value that can still be utilized under this license or permit. Calculated as authorized_value_amount minus utilized_value_amount.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalIndicator rdf:type rdf:Property ;
    rdfs:label 'Renewal Indicator' ;
    rdfs:comment 'Flag indicating whether this license or permit is a renewal of a previously expired authorization. True if renewal, false if original issuance.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date on which the license or permit was suspended by the issuing authority. Indicates when the authorization was temporarily invalidated due to compliance issues or regulatory action.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:utilizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Utilized Quantity' ;
    rdfs:comment 'Cumulative quantity of goods that have been imported or exported against this license or permit to date. Measured in the same unit as authorized_quantity.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Utilized Value Amount' ;
    rdfs:comment 'Cumulative monetary value of goods that have been imported or exported against this license or permit to date. Expressed in the same currency as authorized_value_amount.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Name or identifier of the supervisor or manager who approved the origin determination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationMethod rdf:type rdf:Property ;
    rdfs:label 'Determination Method' ;
    rdfs:comment 'The method used to determine country of origin: wholly obtained (goods entirely produced in one country), substantial transformation (goods undergo significant processing), tariff shift (change in HS classification), value added content (percentage of value added in origin country), change in tariff classification, or regional value content (for trade agreement purposes).' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinedByUser rdf:type rdf:Property ;
    rdfs:label 'Determined By User' ;
    rdfs:comment 'Name or identifier of the customs specialist or trade compliance officer who made the origin determination.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutySavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Savings Amount' ;
    rdfs:comment 'Estimated or actual duty savings realized by claiming preferential origin under the trade agreement.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutySavingsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Duty Savings Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the duty savings amount.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exporterIdentifier rdf:type rdf:Property ;
    rdfs:label 'Exporter Identifier' ;
    rdfs:comment 'Tax ID, customs registration number, or other official identifier of the exporter.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exporterName rdf:type rdf:Property ;
    rdfs:label 'Exporter Name' ;
    rdfs:comment 'Name of the exporting party who prepared or provided the origin documentation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 code of the country where the issuing authority is located.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Materials Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for materials values.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonOriginatingMaterialsValue rdf:type rdf:Property ;
    rdfs:label 'Non Originating Materials Value' ;
    rdfs:comment 'Total value of non-originating materials used in production, relevant for regional value content calculations.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCriterionMet rdf:type rdf:Property ;
    rdfs:label 'Origin Criterion Met' ;
    rdfs:comment 'Specific origin criterion satisfied under the applicable trade agreement (e.g., Criterion A: wholly obtained, Criterion B: produced exclusively from originating materials, Criterion C: tariff shift rule met).' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingMaterialsValue rdf:type rdf:Property ;
    rdfs:label 'Originating Materials Value' ;
    rdfs:comment 'Total value of originating materials used in production, relevant for regional value content calculations.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferentialTariffRatePercent rdf:type rdf:Property ;
    rdfs:label 'Preferential Tariff Rate Percent' ;
    rdfs:comment 'The preferential duty rate (as percentage) claimed under the applicable trade agreement based on this origin determination.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionLocation rdf:type rdf:Property ;
    rdfs:label 'Production Location' ;
    rdfs:comment 'Specific facility, plant, or location where the goods were produced or substantially transformed.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalValueContentPercent rdf:type rdf:Property ;
    rdfs:label 'Regional Value Content Percent' ;
    rdfs:comment 'Percentage of regional value content calculated for trade agreement compliance, representing the proportion of value added within the trade agreement region.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rvcCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Rvc Calculation Method' ;
    rdfs:comment 'Method used to calculate regional value content: transaction value (based on sale price), net cost (based on production costs), build-up (sum of originating materials and costs), or build-down (subtract non-originating materials from total value).' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTariffRatePercent rdf:type rdf:Property ;
    rdfs:label 'Standard Tariff Rate Percent' ;
    rdfs:comment 'The standard (Most Favored Nation) duty rate that would apply without preferential origin, for comparison purposes.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingDocumentType rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Type' ;
    rdfs:comment 'Type of documentation supporting the origin determination: certificate of origin (traditional paper certificate), EUR.1 (EU preferential certificate), Form A (GSP certificate), REX declaration (Registered Exporter system), USMCA certification, manufacturer affidavit, supplier declaration, or origin declaration on commercial invoice. [ENUM-REF-CANDIDATE: certificate_of_origin|eur1|form_a|rex_declaration|usmca_certification|manufacturer_affidavit|supplier_declaration|origin_declaration — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffShiftRuleMet rdf:type rdf:Property ;
    rdfs:label 'Tariff Shift Rule Met' ;
    rdfs:comment 'Description of the specific tariff shift rule satisfied (e.g., change from any other chapter, change from any other heading, change from any other subheading).' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the customs authority verified or audited this origin determination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Reference Number' ;
    rdfs:comment 'Reference number assigned by customs authority during verification or audit of the origin determination.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByCustomsAuthority rdf:type rdf:Property ;
    rdfs:label 'Verified By Customs Authority' ;
    rdfs:comment 'Indicates whether this origin determination has been verified or audited by the destination country customs authority.' ;
    rdfs:domain ind:OriginDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rulingRequestId rdf:type rdf:Property ;
    rdfs:label 'Ruling Request Id' ;
    rdfs:comment 'Unique identifier for the customs ruling request record.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestingPartyTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Requesting party in ruling request is a trade party. Adding requesting_party_trade_party_id FK to trade_party.trade_party_id normalizes the requesting party reference. Cardinality: N:1 (many ruling re' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:submittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Submitted By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Ruling requests submitted by licensed customs brokers or trade compliance specialists (employees). Regulatory requirement for binding rulings. Tracks who prepared and submitted the request.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appealDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision Date' ;
    rdfs:comment 'Date the appeal authority issued a final decision on the appeal, if applicable. Null if no appeal decision has been rendered.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFilingDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filing Date' ;
    rdfs:comment 'Date an appeal was filed against the ruling decision, if applicable. Null if no appeal has been filed.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedHsCode rdf:type rdf:Property ;
    rdfs:label 'Approved Hs Code' ;
    rdfs:comment 'The official HS Code determined and approved by the customs authority in the ruling decision. This becomes the binding classification for future declarations involving the same commodity.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bindingIndicator rdf:type rdf:Property ;
    rdfs:label 'Binding Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the ruling is legally binding on the customs authority for future declarations involving the same commodity and circumstances.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:importerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Importer Identifier' ;
    rdfs:comment 'Official customs identifier for the importer of record such as Importer Number, EORI, or Tax ID.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerName rdf:type rdf:Property ;
    rdfs:label 'Importer Name' ;
    rdfs:comment 'Name of the importer of record who will use the ruling for customs declarations. May differ from the requesting party if a broker or consultant submitted on behalf of the importer.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedHsCode rdf:type rdf:Property ;
    rdfs:label 'Proposed Hs Code' ;
    rdfs:comment 'The HS Code proposed by the requesting party for tariff classification of the commodity. This is the applicant\'s suggested classification subject to customs authority review and approval.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicAvailabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Public Availability Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the ruling is publicly available in the customs authority\'s ruling database or if it is confidential to the requesting party.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rulingAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Ruling Authority Code' ;
    rdfs:comment 'Code identifying the customs authority responsible for issuing the ruling. Examples include CBP (US Customs and Border Protection), HMRC (UK), EU member state customs authorities, or other national customs agencies.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Ruling Authority Name' ;
    rdfs:comment 'Full name of the customs authority or agency that issued or is reviewing the ruling request.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Ruling Decision Date' ;
    rdfs:comment 'Date the customs authority issued the final ruling decision. Marks the official determination and start of the ruling\'s validity period.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rulingNumber rdf:type rdf:Property ;
    rdfs:label 'Ruling Number' ;
    rdfs:comment 'Official ruling number issued by the customs authority upon approval. Serves as the external reference identifier for the binding or advance ruling decision.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingOutcome rdf:type rdf:Property ;
    rdfs:label 'Ruling Outcome' ;
    rdfs:comment 'Final decision outcome of the ruling request. Indicates whether the customs authority approved the request as submitted, approved with modifications to the proposed classification or determination, denied the request, or if the applicant withdrew it.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingRationale rdf:type rdf:Property ;
    rdfs:label 'Ruling Rationale' ;
    rdfs:comment 'Detailed explanation provided by the customs authority for the ruling decision, including legal basis, classification reasoning, and interpretation of applicable regulations.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingStatus rdf:type rdf:Property ;
    rdfs:label 'Ruling Status' ;
    rdfs:comment 'Current lifecycle status of the ruling request. Tracks progression from initial draft through submission, authority review, final decision, and post-decision states including expiration and appeals. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|denied|withdrawn|expired|appealed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingType rdf:type rdf:Property ;
    rdfs:label 'Ruling Type' ;
    rdfs:comment 'Type of ruling requested from the customs authority. Classification rulings determine HS Code assignment, valuation rulings establish customs value methodology, origin rulings confirm country of origin for preferential treatment, marking rulings clarify labeling requirements, binding rulings provide legal certainty, and advance rulings are issued before importation.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date the ruling request was officially submitted to the customs authority. Marks the start of the formal review process and is used to calculate processing timelines and expiration dates.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise timestamp when the ruling request was submitted to the customs authority, including time zone information. Used for audit trails and compliance verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supportingDocumentation rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation' ;
    rdfs:comment 'List or description of supporting documents submitted with the ruling request such as product samples, technical drawings, certificates of origin, manufacturing process descriptions, or laboratory test results.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecifications rdf:type rdf:Property ;
    rdfs:label 'Technical Specifications' ;
    rdfs:comment 'Detailed technical specifications of the commodity including materials, dimensions, composition, functionality, and other characteristics relevant to classification or origin determination.' ;
    rdfs:domain ind:RulingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Validity Period Months' ;
    rdfs:comment 'Number of months the ruling remains valid from the effective date. Standard validity periods vary by jurisdiction and ruling type.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingTariffId rdf:type rdf:Property ;
    rdfs:label 'Pricing Tariff Id' ;
    rdfs:comment 'Foreign key linking to pricing.tariff. Business justification: Customs tariff rates reference pricing tariff structures for duty-inclusive freight quotes and landed cost calculations. Enables integrated quoting where freight and duty costs are presented together ' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tariff .

ind:supersededByTariffRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tariff Rate Id' ;
    rdfs:comment 'Reference to the tariff_rate_id that replaces this record when status is superseded. Enables rate history tracking.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TariffRate .

ind:antiDumpingDutyRate rdf:type rdf:Property ;
    rdfs:label 'Anti Dumping Duty Rate' ;
    rdfs:comment 'Additional duty imposed on imports sold below fair market value to protect domestic industry. Expressed as a percentage or specific amount per unit.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countervailingDutyRate rdf:type rdf:Property ;
    rdfs:label 'Countervailing Duty Rate' ;
    rdfs:comment 'Additional duty imposed to offset foreign government subsidies that distort trade. Expressed as a percentage or specific amount per unit.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Duty Calculation Method' ;
    rdfs:comment 'Method used to calculate the duty: ad valorem (percentage of value), specific (fixed amount per unit), compound (combination), or mixed.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exciseDutyRate rdf:type rdf:Property ;
    rdfs:label 'Excise Duty Rate' ;
    rdfs:comment 'Special tax levied on specific goods such as alcohol, tobacco, fuel, or luxury items. Expressed as a percentage or specific amount per unit.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exportingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Exporting Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the origin country from which goods are being exported.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gstRate rdf:type rdf:Property ;
    rdfs:label 'Gst Rate' ;
    rdfs:comment 'The goods and services tax rate applicable in jurisdictions using GST instead of VAT. Expressed as a percentage.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:importingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Importing Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the destination country where goods are being imported.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when this tariff rate was last verified against official customs authority publications to ensure accuracy.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mfnDutyRate rdf:type rdf:Property ;
    rdfs:label 'Mfn Duty Rate' ;
    rdfs:comment 'The standard duty rate applied to imports from WTO member countries in the absence of a preferential trade agreement. Expressed as a percentage or specific rate.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCriteria rdf:type rdf:Property ;
    rdfs:label 'Origin Criteria' ;
    rdfs:comment 'Rules of origin requirements that must be met to qualify for preferential duty rates under the trade agreement (e.g., regional value content, tariff shift, specific process).' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationReference rdf:type rdf:Property ;
    rdfs:label 'Publication Reference' ;
    rdfs:comment 'Official document reference, gazette number, or regulation identifier where this tariff rate was published.' ;
    rdfs:domain ind:Customs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSourceAuthority rdf:type rdf:Property ;
    rdfs:label 'Rate Source Authority' ;
    rdfs:comment 'The official government or regulatory body that published this tariff rate (e.g., US Customs and Border Protection, HMRC, European Commission DG TAXUD).' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the tariff rate type for operational and reporting purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalPeriod rdf:type rdf:Property ;
    rdfs:label 'Seasonal Period' ;
    rdfs:comment 'Description of the seasonal period when this rate applies (e.g., January-March, Summer, Harvest Season). Populated when seasonal_rate_flag is true.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalRateFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Rate Flag' ;
    rdfs:comment 'Indicates whether this tariff rate varies by season or time of year (common for agricultural products).' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Specific Duty Amount' ;
    rdfs:comment 'Fixed duty amount per unit of measure when specific or compound duty calculation method applies.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suspensionFlag rdf:type rdf:Property ;
    rdfs:label 'Suspension Flag' ;
    rdfs:comment 'Indicates whether duty collection is temporarily suspended for this HS code and country pair (autonomous suspension).' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffQuotaFlag rdf:type rdf:Property ;
    rdfs:label 'Tariff Quota Flag' ;
    rdfs:comment 'Indicates whether this rate is subject to a tariff rate quota (TRQ) limiting the quantity eligible for preferential rates.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffRateStatus rdf:type rdf:Property ;
    rdfs:label 'Tariff Rate Status' ;
    rdfs:comment 'Current lifecycle status of the tariff rate record in the system.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRate rdf:type rdf:Property ;
    rdfs:label 'Vat Rate' ;
    rdfs:comment 'The value-added tax or goods and services tax rate applicable to the imported goods in the destination country. Expressed as a percentage.' ;
    rdfs:domain ind:TariffRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialAgreementId rdf:type rdf:Property ;
    rdfs:label 'Commercial Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Commercial service agreements often reference trade agreements (USMCA, EU FTAs) to validate preferential rate eligibility, origin compliance requirements, and duty drawback programs. Linking trade agr' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:administeringAuthority rdf:type rdf:Property ;
    rdfs:label 'Administering Authority' ;
    rdfs:comment 'Name of the international body, secretariat, or national agency responsible for administering and monitoring compliance with the trade agreement (e.g., WTO Secretariat, European Commission DG Trade, USTR).' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementCode rdf:type rdf:Property ;
    rdfs:label 'Agreement Code' ;
    rdfs:comment 'Standardized short code or abbreviation for the trade agreement (e.g., USMCA, CPTPP, EU-UK_TCA). Used for system lookups and operational references.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Authority Website Url' ;
    rdfs:comment 'Official website URL of the administering authority where the full text of the agreement, tariff schedules, and implementation guidance are published.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginFormat rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Format' ;
    rdfs:comment 'Standardized format or form type required for the Certificate of Origin under this agreement (e.g., Form A for GSP, EUR.1 for EU agreements, self-certification for USMCA).' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginRequired rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Required' ;
    rdfs:comment 'Indicates whether a formal Certificate of Origin document must be presented to customs authorities to claim preferential duty rates under this agreement. True = COO required; False = self-certification or no certification required.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulationRules rdf:type rdf:Property ;
    rdfs:label 'Cumulation Rules' ;
    rdfs:comment 'Type of origin cumulation permitted under the agreement. Bilateral = materials from partner country count as originating; Diagonal = materials from multiple FTA partners cumulate; Full = all processing in partner countries cumulates; None = no cumulation allowed.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the source system or database from which this trade agreement record was ingested (e.g., Descartes Customs GTM, WTO RTA Database, internal trade compliance repository).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalTradeProvisions rdf:type rdf:Property ;
    rdfs:label 'Digital Trade Provisions' ;
    rdfs:comment 'Indicates whether the agreement includes provisions on e-commerce, cross-border data flows, digital services, and prohibition of data localization requirements. True = digital trade provisions included; False = no digital trade provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Summary of the dispute settlement procedures established by the agreement for resolving conflicts between member countries regarding interpretation or implementation (e.g., arbitration panels, joint committees).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalProvisions rdf:type rdf:Property ;
    rdfs:label 'Environmental Provisions' ;
    rdfs:comment 'Indicates whether the agreement includes commitments on environmental protection, sustainable development, and enforcement of environmental laws. True = environmental provisions included; False = no environmental provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governmentProcurementProvisions rdf:type rdf:Property ;
    rdfs:label 'Government Procurement Provisions' ;
    rdfs:comment 'Indicates whether the agreement opens government procurement markets to suppliers from member countries on a non-discriminatory basis. True = procurement provisions included; False = no procurement provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intellectualPropertyProvisions rdf:type rdf:Property ;
    rdfs:label 'Intellectual Property Provisions' ;
    rdfs:comment 'Indicates whether the agreement includes chapters or provisions on intellectual property rights protection, enforcement, and cooperation. True = IP provisions included; False = no IP provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investmentProvisions rdf:type rdf:Property ;
    rdfs:label 'Investment Provisions' ;
    rdfs:comment 'Indicates whether the agreement includes provisions on foreign direct investment protection, investor-state dispute settlement, and national treatment for investors. True = investment provisions included; False = no investment provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborStandardsProvisions rdf:type rdf:Property ;
    rdfs:label 'Labor Standards Provisions' ;
    rdfs:comment 'Indicates whether the agreement includes enforceable labor rights and working conditions standards aligned with International Labour Organization (ILO) conventions. True = labor provisions included; False = no labor provisions.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mutualRecognitionAgreements rdf:type rdf:Property ;
    rdfs:label 'Mutual Recognition Agreements' ;
    rdfs:comment 'Description of any mutual recognition agreements for conformity assessment, product standards, professional qualifications, or Authorized Economic Operator (AEO) programs included in or linked to the trade agreement.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participatingCountries rdf:type rdf:Property ;
    rdfs:label 'Participating Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing all member countries or customs territories party to the agreement (e.g., USA,CAN,MEX for USMCA).' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCoverageScope rdf:type rdf:Property ;
    rdfs:label 'Product Coverage Scope' ;
    rdfs:comment 'Defines the breadth of goods and services covered by the trade agreement. All Goods = comprehensive coverage; Industrial Goods Only = excludes agriculture; Agricultural Excluded = industrial focus; Services Included = covers trade in services; Limited Product List = specific HS Codes only.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaProvisions rdf:type rdf:Property ;
    rdfs:label 'Quota Provisions' ;
    rdfs:comment 'Description of any tariff-rate quotas (TRQs) or quantitative restrictions included in the agreement. Specifies product categories subject to quota limits and the preferential in-quota duty rates.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleYears rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Years' ;
    rdfs:comment 'Number of years between scheduled reviews or renegotiations of the trade agreement by member countries. Used to track when agreement terms may be updated or modernized.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rulesOfOriginCriteria rdf:type rdf:Property ;
    rdfs:label 'Rules Of Origin Criteria' ;
    rdfs:comment 'Summary of the origin determination rules required to qualify for preferential treatment under this agreement (e.g., change in tariff classification, regional value content percentage, specific processing requirements). Full rules are maintained in tariff_rate product.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeguardMeasures rdf:type rdf:Property ;
    rdfs:label 'Safeguard Measures' ;
    rdfs:comment 'Summary of bilateral safeguard provisions that allow temporary suspension or modification of preferential treatment if imports cause or threaten serious injury to domestic industry.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Agreement Code' ;
    rdfs:comment 'Agreement code of the successor trade agreement that replaced this agreement, if applicable. Used to maintain historical lineage when agreements are renegotiated or replaced (e.g., NAFTA superseded by USMCA).' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffEliminationSchedule rdf:type rdf:Property ;
    rdfs:label 'Tariff Elimination Schedule' ;
    rdfs:comment 'Classification of the duty reduction timeline under the agreement. Immediate = zero duty on entry into force; Staged = phased reduction over specified years; Partial = some products excluded; Product Specific = varies by HS Code.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the trade agreement. In Force = active and applicable; Under Negotiation = being drafted; Signed Not Ratified = awaiting legislative approval; Suspended = temporarily inactive; Terminated = ended by parties; Expired = reached end date.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeFacilitationProvisions rdf:type rdf:Property ;
    rdfs:label 'Trade Facilitation Provisions' ;
    rdfs:comment 'Description of customs procedures simplification, advance rulings, single window systems, and other trade facilitation commitments included in the agreement to reduce border clearance times and costs.' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wtoNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Wto Notification Number' ;
    rdfs:comment 'WTO Regional Trade Agreement notification number assigned when the agreement was notified to the WTO under GATT Article XXIV or GATS Article V (e.g., WT/REG123/N/1).' ;
    rdfs:domain ind:TradeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: KYC verification performed by compliance officers (employees). AML/CTF regulatory requirement. Tracks who verified the trade party for denied party screening and risk assessment.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'The official registration number assigned by the national business registry or companies house in the country of establishment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbpImporterNumber rdf:type rdf:Property ;
    rdfs:label 'Cbp Importer Number' ;
    rdfs:comment 'The unique identifier assigned by US Customs and Border Protection to importers of record conducting business in the United States. Required for ISF and AMS filings.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfEstablishment rdf:type rdf:Property ;
    rdfs:label 'Country Of Establishment' ;
    rdfs:comment 'The country where the trade party is legally registered and established, represented as ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatSviNumber rdf:type rdf:Property ;
    rdfs:label 'Ctpat Svi Number' ;
    rdfs:comment 'The unique identifier assigned to C-TPAT certified members following successful supply chain security validation.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzOperatorNumber rdf:type rdf:Property ;
    rdfs:label 'Ftz Operator Number' ;
    rdfs:comment 'The authorization number for parties approved to operate or use Free Trade Zone facilities for customs-privileged storage and processing.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Status' ;
    rdfs:comment 'Status of the Know Your Customer due diligence verification process for this trade party, ensuring compliance with anti-money laundering and trade compliance requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Last Screening Date' ;
    rdfs:comment 'The date when the trade party was last screened against denied party and sanctions lists.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'The date of the most recent customs declaration or trade transaction involving this party.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'The 20-character ISO 17442 standard identifier for legal entities participating in financial transactions. Used for regulatory reporting and entity verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScreeningDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Screening Due Date' ;
    rdfs:comment 'The date by which the next periodic denied party screening must be completed to maintain compliance.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'The preferred currency for invoicing and payment transactions with this trade party, represented as ISO 4217 three-letter currency code.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'The risk level assigned to this trade party based on compliance history, denied party screening results, geographic risk factors, and transaction patterns.' ;
    rdfs:domain ind:TradeParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateId rdf:type rdf:Property ;
    rdfs:label 'Certificate Id' ;
    rdfs:comment 'Unique identifier for the certificate record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certificate .

ind:consigneeId rdf:type rdf:Property ;
    rdfs:label 'Consignee Id' ;
    rdfs:comment 'Identifier of the consignee or importer associated with this certificate.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consignee .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of supporting documents or attachments associated with this certificate (e.g., test reports, inspection photos, lab results).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Method used to authenticate and verify the legitimacy of the certificate (e.g., digital signature, physical seal, QR code, blockchain).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalUsed rdf:type rdf:Property ;
    rdfs:label 'Chemical Used' ;
    rdfs:comment 'Name of the chemical or substance used in the treatment process (e.g., methyl bromide for fumigation).' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationLevel rdf:type rdf:Property ;
    rdfs:label 'Concentration Level' ;
    rdfs:comment 'Concentration level or dosage of the chemical used in the treatment, including unit of measure.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignature rdf:type rdf:Property ;
    rdfs:label 'Digital Signature' ;
    rdfs:comment 'Cryptographic digital signature or hash used to verify the authenticity and integrity of the electronic certificate.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date when the physical inspection or assessment was conducted by the issuing authority prior to certificate issuance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector License Number' ;
    rdfs:comment 'Professional license or certification number of the inspector who validated the certificate requirements.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the authorized inspector or surveyor who conducted the inspection and validated the certificate requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Days' ;
    rdfs:comment 'Number of days between required renewals for certificates that require periodic renewal.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this certificate requires periodic renewal (True) or is a one-time issuance (False).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Date' ;
    rdfs:comment 'Date when the treatment (fumigation, heat treatment, etc.) was applied to the goods.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentDurationHours rdf:type rdf:Property ;
    rdfs:label 'Treatment Duration Hours' ;
    rdfs:comment 'Duration of the treatment process in hours, as required for compliance documentation.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentType rdf:type rdf:Property ;
    rdfs:label 'Treatment Type' ;
    rdfs:comment 'Type of treatment applied to the goods (e.g., fumigation, heat treatment, irradiation) as documented in the certificate. Applicable to phytosanitary and fumigation certificates.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationUrl rdf:type rdf:Property ;
    rdfs:label 'Verification Url' ;
    rdfs:comment 'Web URL where the certificate can be verified online with the issuing authority.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionRecordId rdf:type rdf:Property ;
    rdfs:label 'Destruction Record Id' ;
    rdfs:comment 'Unique identifier for the document destruction record. Primary key.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSubjectRequestId rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Id' ;
    rdfs:comment 'Reference to the data subject access or erasure request that triggered this destruction, if applicable.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Request .

ind:primaryDestructionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Destruction Employee Id' ;
    rdfs:comment 'Reference to the employee or officer who authorized the destruction event, ensuring accountability and audit trail.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:retentionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Id' ;
    rdfs:comment 'Reference to the document retention policy that governed the retention period and triggered this destruction event.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionPolicy .

ind:tertiaryDestructionLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Destruction Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user or system account that last modified this destruction record.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizingOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Authorizing Officer Email' ;
    rdfs:comment 'Email address of the authorizing officer for notification and audit trail purposes.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Authorizing Officer Name' ;
    rdfs:comment 'Full name of the officer who authorized the destruction, captured for regulatory audit and compliance verification.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonFootprintKgCo2e rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Kg Co2e' ;
    rdfs:comment 'Estimated carbon emissions in kilograms of CO2 equivalent associated with the destruction and disposal process, used for GHG reporting.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Flag' ;
    rdfs:comment 'Indicates whether a formal compliance certification was issued for this destruction event, required for certain regulated document types.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSubjectRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Flag' ;
    rdfs:comment 'Indicates whether this destruction was triggered by a data subject request under GDPR right to erasure (Article 17) or similar privacy regulation.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destructionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Destruction Certificate Number' ;
    rdfs:comment 'Externally-known unique certificate number issued upon completion of document destruction, used for regulatory audit trail and compliance verification.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Destruction Cost Amount' ;
    rdfs:comment 'Total cost incurred for the destruction service, including vendor fees, labor, and disposal costs.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destructionCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Destruction Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the destruction cost amount.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionLocation rdf:type rdf:Property ;
    rdfs:label 'Destruction Location' ;
    rdfs:comment 'Physical location or facility where the destruction was performed, including address or facility code.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destruction Location Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the jurisdiction where destruction occurred, critical for cross-border compliance.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionMethod rdf:type rdf:Property ;
    rdfs:label 'Destruction Method' ;
    rdfs:comment 'The method used to destroy the documents. Secure shred for paper, digital purge for electronic records, incineration for sensitive materials, degaussing for magnetic media, overwrite for digital storage.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionReason rdf:type rdf:Property ;
    rdfs:label 'Destruction Reason' ;
    rdfs:comment 'The business or regulatory reason that triggered the destruction event.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionStatus rdf:type rdf:Property ;
    rdfs:label 'Destruction Status' ;
    rdfs:comment 'Current lifecycle status of the destruction event. Tracks progression from scheduling through completion and verification.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Destruction Timestamp' ;
    rdfs:comment 'Precise timestamp when the destruction process was completed, including time zone information for cross-border compliance.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destructionVendorName rdf:type rdf:Property ;
    rdfs:label 'Destruction Vendor Name' ;
    rdfs:comment 'Name of the destruction vendor or service provider, captured for audit and vendor management purposes.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalStorageSizeGb rdf:type rdf:Property ;
    rdfs:label 'Digital Storage Size Gb' ;
    rdfs:comment 'Total storage size in gigabytes of digital documents purged, used for IT capacity planning and compliance verification.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of individual documents or records destroyed in this destruction event.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentTypeDestroyed rdf:type rdf:Property ;
    rdfs:label 'Document Type Destroyed' ;
    rdfs:comment 'The category or type of documents that were destroyed in this event (e.g., Air Waybill, Bill of Lading, Customs Declaration, Invoice, Proof of Delivery).' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVolumeKg rdf:type rdf:Property ;
    rdfs:label 'Document Volume Kg' ;
    rdfs:comment 'Total weight in kilograms of physical documents destroyed, used for destruction vendor billing and environmental reporting.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalDisposalMethod rdf:type rdf:Property ;
    rdfs:label 'Environmental Disposal Method' ;
    rdfs:comment 'The environmentally-compliant disposal method used for physical document remnants after destruction, supporting sustainability reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Clearance Date' ;
    rdfs:comment 'The date on which the final legal hold was released, authorizing the documents for destruction.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalHoldClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Clearance Flag' ;
    rdfs:comment 'Indicates whether all legal holds on the documents were cleared prior to destruction. True if cleared, False if any hold remains.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'The date on which the retention period expired, making the documents eligible for destruction.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'The number of years the documents were retained before destruction, as mandated by the applicable retention policy.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Timestamp when the destruction was verified and confirmed as complete, distinct from the destruction execution timestamp.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Name of the individual who witnessed the destruction process, providing additional verification for high-sensitivity documents.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessRole rdf:type rdf:Property ;
    rdfs:label 'Witness Role' ;
    rdfs:comment 'Job title or role of the witness who verified the destruction process.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureId rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Id' ;
    rdfs:comment 'Unique identifier for the digital signature record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalSignature .

ind:biometricDataCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Data Captured Flag' ;
    rdfs:comment 'Indicates whether biometric data (fingerprint, facial recognition, signature dynamics) was captured as part of the signature process for enhanced authentication.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biometricDataType rdf:type rdf:Property ;
    rdfs:label 'Biometric Data Type' ;
    rdfs:comment 'Type of biometric data captured during the signature process, if applicable (fingerprint, facial recognition, signature dynamics).' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateAuthority rdf:type rdf:Property ;
    rdfs:label 'Certificate Authority' ;
    rdfs:comment 'Name of the trusted certificate authority or trust service provider that issued the digital certificate used for the signature (e.g., DigiCert, GlobalSign, national CA).' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Serial Number' ;
    rdfs:comment 'Unique serial number of the digital certificate used to create the signature, enabling certificate validation and revocation checking.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Accepted Flag' ;
    rdfs:comment 'Indicates whether the signatory explicitly accepted the consent statement or terms and conditions before applying the signature.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentStatement rdf:type rdf:Property ;
    rdfs:label 'Consent Statement' ;
    rdfs:comment 'Text of the consent or acknowledgment statement presented to the signatory at the time of signing (e.g., \'I acknowledge receipt of goods in good condition\').' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Document Version Number' ;
    rdfs:comment 'Version identifier of the document at the time of signature application, ensuring signature is tied to a specific immutable version.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Hash Algorithm' ;
    rdfs:comment 'Cryptographic hash algorithm used to generate the signature hash (SHA-256, SHA-512, etc.), critical for security and compliance validation.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the device or network from which the signature was applied, used for audit trail and fraud detection.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Legal Jurisdiction' ;
    rdfs:comment 'Country or legal jurisdiction under which the digital signature is considered legally binding (ISO 3166 country code or jurisdiction name).' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalValidityFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Validity Flag' ;
    rdfs:comment 'Indicates whether the signature meets the legal requirements for enforceability in the applicable jurisdiction at the time of signing.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether the digital signature meets all applicable regulatory requirements for the document type and jurisdiction (eIDAS, ESIGN, customs regulations).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatoryRole rdf:type rdf:Property ;
    rdfs:label 'Signatory Role' ;
    rdfs:comment 'Business role or capacity in which the signatory applied the signature (driver for POD, customs officer for clearance, customer for acceptance). [ENUM-REF-CANDIDATE: driver|warehouse_manager|customs_officer|customer_representative|freight_forwarder|carrier_agent|authorized_signatory|consignee|shipper — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureHash rdf:type rdf:Property ;
    rdfs:label 'Signature Hash' ;
    rdfs:comment 'Cryptographic hash value of the signed document content, ensuring document integrity and detecting any post-signature tampering.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Signature Image Url' ;
    rdfs:comment 'URL or storage path to the visual image of the captured signature (handwritten signature image, scanned signature), stored in secure document repository.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signaturePurpose rdf:type rdf:Property ;
    rdfs:label 'Signature Purpose' ;
    rdfs:comment 'Business purpose or intent of the signature (proof of delivery, customs clearance, contract acceptance, goods receipt acknowledgment). [ENUM-REF-CANDIDATE: proof_of_delivery|customs_clearance|contract_acceptance|goods_receipt|damage_acknowledgment|authorization|approval|witness — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Signature Reference Number' ;
    rdfs:comment 'Externally-known unique reference number or transaction ID for this digital signature event, used for audit trails and legal verification.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureStatus rdf:type rdf:Property ;
    rdfs:label 'Signature Status' ;
    rdfs:comment 'Current validation status of the digital signature indicating whether it remains legally valid and cryptographically intact.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'Precise date and time when the digital signature was applied to the document, in UTC. Critical for legal validity and audit compliance.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureType rdf:type rdf:Property ;
    rdfs:label 'Signature Type' ;
    rdfs:comment 'Legal classification of the electronic signature per eIDAS or equivalent framework: qualified (highest assurance), advanced (medium assurance), or simple (basic).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Signing Device Code' ;
    rdfs:comment 'Unique identifier of the device used to capture the signature (device serial number, IMEI, MAC address), used for audit and fraud detection.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDeviceType rdf:type rdf:Property ;
    rdfs:label 'Signing Device Type' ;
    rdfs:comment 'Type of device or platform used to capture the signature (mobile device, tablet, handheld ePOD scanner, biometric pad, web browser). [ENUM-REF-CANDIDATE: mobile_device|tablet|desktop|handheld_scanner|biometric_pad|web_browser|kiosk — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingLocationAddress rdf:type rdf:Property ;
    rdfs:label 'Signing Location Address' ;
    rdfs:comment 'Physical address or location description where the signature was captured (delivery address, warehouse location, customs office).' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Signing Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate where the signature was captured, supporting proof of delivery and location-based compliance verification.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signingLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Signing Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate where the signature was captured, supporting proof of delivery and location-based compliance verification.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signingPlatform rdf:type rdf:Property ;
    rdfs:label 'Signing Platform' ;
    rdfs:comment 'Name of the software platform or application used to apply the signature (DocuSign, Adobe Sign, proprietary TMS/WMS module, mobile app name).' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timestampAuthority rdf:type rdf:Property ;
    rdfs:label 'Timestamp Authority' ;
    rdfs:comment 'Name of the trusted timestamp authority (TSA) that provided the cryptographic timestamp for the signature, ensuring non-repudiation of signing time.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timestampToken rdf:type rdf:Property ;
    rdfs:label 'Timestamp Token' ;
    rdfs:comment 'Cryptographic timestamp token issued by the timestamp authority, binding the signature to a specific point in time for legal and audit purposes.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationResult rdf:type rdf:Property ;
    rdfs:label 'Verification Result' ;
    rdfs:comment 'Outcome of the most recent signature verification check, indicating whether the signature remains cryptographically valid and legally binding.' ;
    rdfs:domain ind:DigitalSignature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessLogId rdf:type rdf:Property ;
    rdfs:label 'Access Log Id' ;
    rdfs:comment 'Unique identifier for the document access log entry. Primary key for the document access log product.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessChannel rdf:type rdf:Property ;
    rdfs:label 'Access Channel' ;
    rdfs:comment 'Channel or interface through which the document was accessed. Identifies whether access was via user-facing portal, programmatic API, or internal system integration.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Access Duration Seconds' ;
    rdfs:comment 'Duration in seconds that the document was actively accessed or viewed. Measured from initial access to session close or timeout. Null for instantaneous operations like download.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Access Expiry Timestamp' ;
    rdfs:comment 'Date and time when the granted access permission expires. Applicable for temporary access grants or time-limited document sharing. Null for permanent access rights.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessGrantedBy rdf:type rdf:Property ;
    rdfs:label 'Access Granted By' ;
    rdfs:comment 'Name or identifier of the person or system that granted access permissions to the accessor. Populated for documents requiring explicit approval or temporary access grants.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessLocationCity rdf:type rdf:Property ;
    rdfs:label 'Access Location City' ;
    rdfs:comment 'City from which the document was accessed. Derived from IP address geolocation. Used for regional access pattern analysis and compliance with data residency requirements.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Access Location Country' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic location from which the document was accessed. Derived from IP address geolocation or user profile.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessOutcome rdf:type rdf:Property ;
    rdfs:label 'Access Outcome' ;
    rdfs:comment 'Result of the access attempt. Success indicates document was accessed as requested; denied indicates insufficient permissions; failed indicates technical error; partial indicates incomplete retrieval.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessPurpose rdf:type rdf:Property ;
    rdfs:label 'Access Purpose' ;
    rdfs:comment 'Business reason or purpose for accessing the document. May be user-provided or system-inferred. Examples include customs inspection, customer inquiry, audit review, operational reference.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Access Timestamp' ;
    rdfs:comment 'Precise date and time when the document access event occurred. Recorded in UTC for global consistency across time zones.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessType rdf:type rdf:Property ;
    rdfs:label 'Access Type' ;
    rdfs:comment 'Type of access operation performed on the document. Distinguishes between read-only operations (view, download) and modification operations (edit, delete). [ENUM-REF-CANDIDATE: view|download|print|share|edit|delete|api_retrieval — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessorEmail rdf:type rdf:Property ;
    rdfs:label 'Accessor Email' ;
    rdfs:comment 'Email address of the user who accessed the document. Used for audit notifications and compliance investigations.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessorName rdf:type rdf:Property ;
    rdfs:label 'Accessor Name' ;
    rdfs:comment 'Full name of the person or system that accessed the document. Captured for audit trail and compliance reporting.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiClientCode rdf:type rdf:Property ;
    rdfs:label 'Api Client Code' ;
    rdfs:comment 'Unique identifier of the API client application that retrieved the document. Populated only for api_retrieval access type. Used for API usage monitoring and third-party integration auditing.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Classification level of the document that was accessed. Reflects the sensitivity of the document content at the time of access. Used for security monitoring and compliance reporting.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Device Identifier' ;
    rdfs:comment 'Unique identifier of the device used to access the document. May be device UUID, MAC address, or browser fingerprint depending on access channel.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version number or identifier of the document that was accessed. Critical for audit trails when documents undergo revisions.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Download Size Bytes' ;
    rdfs:comment 'Size of the document file in bytes that was downloaded. Populated only for download and api_retrieval access types. Used for bandwidth analysis and storage auditing.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentSeverity rdf:type rdf:Property ;
    rdfs:label 'Incident Severity' ;
    rdfs:comment 'Severity level of the security incident if security_incident_flag is true. Null for non-incident access events. Used for prioritizing security response and compliance escalation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationUnit rdf:type rdf:Property ;
    rdfs:label 'Organization Unit' ;
    rdfs:comment 'Business unit, department, or division of the accessor. Examples include Customs Brokerage, Freight Operations, Customer Service, Finance, Legal. Used for internal access pattern analysis.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageCountAccessed rdf:type rdf:Property ;
    rdfs:label 'Page Count Accessed' ;
    rdfs:comment 'Number of pages viewed or accessed within a multi-page document. Applicable for PDF, Word, and other paginated document formats. Null for non-paginated documents.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Indicates whether this access event is subject to regulatory reporting or audit requirements. True for documents accessed under customs inspection, trade compliance review, or regulatory investigation.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Hold Flag' ;
    rdfs:comment 'Indicates whether this access log entry is under legal hold or extended retention due to litigation, investigation, or regulatory inquiry. When true, the log entry cannot be purged per standard retention policy.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Security Incident Flag' ;
    rdfs:comment 'Indicates whether this access event was flagged as a potential security incident. True for suspicious access patterns, unauthorized access attempts, or anomalous behavior detected by security monitoring systems.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionCode rdf:type rdf:Property ;
    rdfs:label 'Session Code' ;
    rdfs:comment 'Unique identifier for the user session during which the document was accessed. Enables correlation of multiple access events within a single user session.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shareRecipientEmail rdf:type rdf:Property ;
    rdfs:label 'Share Recipient Email' ;
    rdfs:comment 'Email address of the recipient when the document was shared via the share access type. Populated only for share operations. Used for tracking document distribution and external sharing compliance.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userRole rdf:type rdf:Property ;
    rdfs:label 'User Role' ;
    rdfs:comment 'Role or permission level of the user at the time of access. Examples include Administrator, Customs Officer, Customer Service Representative, External Partner, Customer. Used for role-based access control (RBAC) auditing.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Unique identifier for the document amendment record. Primary key for the document amendment entity.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Amendment Created By User Employee Id' ;
    rdfs:comment 'Reference to the system user who created the amendment record. Supports audit trail and accountability requirements.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Amendment Employee Id' ;
    rdfs:comment 'Reference to the organization or individual authorized to approve the amendment. Typically the document issuer or regulatory authority.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Amendment Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the system user who last updated the amendment record. Tracks responsibility for changes throughout the amendment lifecycle.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requestingPartyId rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Id' ;
    rdfs:comment 'Reference to the organization or individual who initiated the amendment request. May be shipper, consignee, carrier, freight forwarder, or customs broker.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractParty .

ind:supersededAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Amendment Id' ;
    rdfs:comment 'Reference to a previous amendment that this amendment replaces or supersedes. Maintains amendment lineage for complex correction scenarios.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:amendedFieldName rdf:type rdf:Property ;
    rdfs:label 'Amended Field Name' ;
    rdfs:comment 'Name of the specific document field or data element being amended. Identifies the exact attribute on the original document that requires correction or update.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendedValue rdf:type rdf:Property ;
    rdfs:label 'Amended Value' ;
    rdfs:comment 'The new corrected or updated value for the amended field. Represents the target state after amendment approval and implementation.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current state of the amendment request in its approval workflow. Tracks progression from submission through review, approval, and implementation.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Name' ;
    rdfs:comment 'Name of the organization or individual who approved or rejected the amendment. Captured for compliance and audit trail.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when the amendment was fully implemented and all affected systems and parties were notified. Represents the end of the amendment lifecycle.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Customs entry or declaration number if the amendment relates to customs documentation. Required for post-clearance amendments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Monetary value of the financial impact resulting from the amendment. Positive values indicate additional charges, negative values indicate refunds or credits.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial impact amount. Ensures proper currency handling in multi-currency operations.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Flag' ;
    rdfs:comment 'Indicates whether the amendment has financial implications requiring billing adjustments, refunds, or additional charges. Triggers downstream financial reconciliation processes.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when amendment notifications were dispatched to affected parties. Used for audit trail and SLA compliance tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalValue rdf:type rdf:Property ;
    rdfs:label 'Original Value' ;
    rdfs:comment 'The original value of the field before amendment. Preserved for audit trail and regulatory compliance to demonstrate what was changed.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number assigned by the regulatory authority for the amendment filing. Used to track compliance with post-clearance amendment requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether the amendment must be filed with a regulatory authority. True for customs amendments, dangerous goods corrections, and trade compliance updates.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the amendment request was formally submitted. Represents the business event timestamp for initiating the amendment process.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Precise date and time when the amendment request was submitted to the system. Used for audit trail and SLA tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestingPartyName rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Name' ;
    rdfs:comment 'Name of the organization or individual who submitted the amendment request. Captured for audit and communication purposes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingPartyRole rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Role' ;
    rdfs:comment 'Business role of the party requesting the amendment in the context of the original document. Determines authorization level and approval requirements. [ENUM-REF-CANDIDATE: shipper|consignee|carrier|freight_forwarder|customs_broker|notify_party|agent — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Sequential version number for amendments to the same document. Tracks multiple amendment iterations and ensures proper version control.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver User Employee Id' ;
    rdfs:comment 'Reference to the user who approved the compliance check outcome or authorized document release despite warnings. Links to employee record for accountability and audit trail.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryComplianceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Employee Id' ;
    rdfs:comment 'Reference to the user who performed or initiated the compliance check. Applicable for manual or hybrid checks. Links to employee or contractor record for accountability and audit purposes.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryComplianceModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Compliance Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the compliance check record. Links to employee or system account for change tracking and audit purposes.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Minutes' ;
    rdfs:comment 'Actual time in minutes taken to complete the compliance check, measured from check initiation to outcome recording. Used for SLA compliance reporting and process improvement analysis.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Completion Timestamp' ;
    rdfs:comment 'Date and time when the compliance check was finalized and outcome recorded. May differ from execution timestamp for manual checks or multi-stage validations.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Execution Timestamp' ;
    rdfs:comment 'Date and time when the compliance check was executed. Represents the moment the validation logic was run against the document. Critical for audit trails and regulatory reporting.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkMethod rdf:type rdf:Property ;
    rdfs:label 'Check Method' ;
    rdfs:comment 'Mechanism by which the compliance check was performed. Automated indicates system-driven validation rules; manual indicates human review; hybrid indicates combination of automated pre-screening followed by manual verification.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkOutcome rdf:type rdf:Property ;
    rdfs:label 'Check Outcome' ;
    rdfs:comment 'Result of the compliance validation. Pass indicates full compliance with no issues; fail indicates critical violations preventing document release; warning indicates minor issues requiring attention but not blocking release; conditional_pass indicates compliance subject to remediation of specified items.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkPriority rdf:type rdf:Property ;
    rdfs:label 'Check Priority' ;
    rdfs:comment 'Priority assigned to the compliance check based on shipment urgency, customer SLA, or regulatory deadline. Urgent checks are processed immediately; high priority within hours; normal within standard SLA; low as capacity permits.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Check Reference Number' ;
    rdfs:comment 'Business-readable unique reference number assigned to this compliance check for tracking and audit purposes. Used in communications with regulatory authorities and internal quality teams.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkStatus rdf:type rdf:Property ;
    rdfs:label 'Check Status' ;
    rdfs:comment 'Current lifecycle status of the compliance check execution. Tracks whether the check is pending initiation, actively running, successfully completed, cancelled before completion, or failed due to system error.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkType rdf:type rdf:Property ;
    rdfs:label 'Check Type' ;
    rdfs:comment 'Category of compliance validation performed. Defines the nature of the check: completeness (all required fields present), data accuracy (values within valid ranges), regulatory format (structure matches authority requirements), signature validity (digital signature verification), expiry validation (document within validity period), HS code validation (tariff classification correctness), party screening (denied party check), or dangerous goods (IMDG/IATA compliance). [ENUM-REF-CANDIDATE: completeness|data_accuracy|regulatory_format|signature_validity|expiry_validation|hs_code_validation|party_screening|dangerous_goods — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkerName rdf:type rdf:Property ;
    rdfs:label 'Checker Name' ;
    rdfs:comment 'Name of the individual or system component that executed the compliance check. For manual checks, the full name of the compliance officer or customs specialist. For automated checks, the name of the validation service or module.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkerRole rdf:type rdf:Property ;
    rdfs:label 'Checker Role' ;
    rdfs:comment 'Functional role or job title of the person who performed the check. Examples: Customs Compliance Officer, Trade Compliance Specialist, Quality Assurance Analyst, Dangerous Goods Specialist. Provides context for the level of expertise applied.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkerSystemName rdf:type rdf:Property ;
    rdfs:label 'Checker System Name' ;
    rdfs:comment 'Name of the automated system or software module that performed the compliance validation. Examples: Descartes Customs Validation Engine, SAP TM Compliance Module, Internal Document QA Service. Used for system audit and troubleshooting.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkerType rdf:type rdf:Property ;
    rdfs:label 'Checker Type' ;
    rdfs:comment 'Category of entity that performed the compliance check. System indicates automated validation engine; user indicates manual review by internal staff; third_party indicates external compliance service provider or customs broker.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Standardized error code assigned to the compliance failure. Enables categorization and trending of common compliance issues. May align with regulatory authority error code schemes or internal quality management codes.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorSeverity rdf:type rdf:Property ;
    rdfs:label 'Error Severity' ;
    rdfs:comment 'Severity classification of the compliance issue. Critical errors block document submission; high errors require immediate remediation; medium errors should be addressed before release; low errors are minor quality issues; informational items are advisory only.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedValidationRules rdf:type rdf:Property ;
    rdfs:label 'Failed Validation Rules' ;
    rdfs:comment 'Comma-separated list or structured text of specific validation rule identifiers that failed during this check. Provides detailed breakdown of which compliance criteria were not met. Used for remediation guidance and root cause analysis.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Detailed explanation of why the compliance check failed or generated warnings. Includes specific field names, missing data elements, format violations, or regulatory requirement breaches. Used by document preparers to understand and correct issues.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Explanation provided when a compliance check failure is overridden and the document is released despite not passing all validations. Requires management authorization and is subject to audit review. Documents business justification for exception.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Specific corrective action recommended to resolve the compliance issue. Provides guidance to document preparers on how to fix the identified problems. May include field-level instructions or references to regulatory guidance.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDeadline rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline' ;
    rdfs:comment 'Date and time by which remediation must be completed to meet shipment or regulatory filing deadlines. Calculated based on shipment ETD, customs filing cutoff, or other time-sensitive milestones.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether corrective action is required before the document can be submitted to regulatory authorities or released to counterparties. True if document must be corrected and re-checked; false if check outcome allows proceeding.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times the compliance check was retried due to system errors, timeouts, or inconclusive results. Tracks reliability of automated validation processes and identifies problematic documents or rule sets.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Minutes' ;
    rdfs:comment 'Target time in minutes within which the compliance check should be completed, based on service level agreements or operational standards. Used to measure check processing performance and identify delays.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationRuleSetCode rdf:type rdf:Property ;
    rdfs:label 'Validation Rule Set Code' ;
    rdfs:comment 'Identifier of the specific rule set or validation profile applied during this check. Links to the configuration of business rules, field validations, and compliance criteria used. Enables traceability of which version of rules was applied.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Validation Rule Version' ;
    rdfs:comment 'Version number of the validation rule set applied. Critical for audit trails when rule sets are updated to reflect regulatory changes. Ensures reproducibility of compliance decisions.' ;
    rdfs:domain ind:ComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionId rdf:type rdf:Property ;
    rdfs:label 'Distribution Id' ;
    rdfs:comment 'Unique identifier for the document distribution record. Primary key.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRecipientPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Recipient Party Id' ;
    rdfs:comment 'Reference to the primary recipient party (typically the consignee or main customer). Used for prioritization and primary contact tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:acknowledgementReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Received Count' ;
    rdfs:comment 'Number of recipients who have acknowledged receipt of the document. Used to track compliance with acknowledgement requirements.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required Flag' ;
    rdfs:comment 'Indicates whether recipients are required to acknowledge receipt of the document. Supports compliance with IATA e-freight and customs requirements for confirmed delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualDeliveryCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Completion Timestamp' ;
    rdfs:comment 'Timestamp when distribution was completed to all recipients (or marked as final after max retries). Used to calculate actual delivery time and SLA compliance.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:apiTransmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Api Transmission Flag' ;
    rdfs:comment 'Indicates whether any recipient in this distribution received the document via API integration. Supports digital integration monitoring and system-to-system delivery tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelSummary rdf:type rdf:Property ;
    rdfs:label 'Channel Summary' ;
    rdfs:comment 'Summary of distribution channels used in this batch (e.g., EDI, email, portal, API, physical). Provides quick overview of delivery methods without querying detail records.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'The regulatory framework or standard this distribution must comply with (e.g., IATA e-freight, AMS, ISF, EU ICS). Supports compliance reporting and audit trail.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Applied Flag' ;
    rdfs:comment 'Indicates whether the distributed document includes a digital signature for authenticity and non-repudiation. Required for certain trade documents and e-freight compliance.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Date' ;
    rdfs:comment 'The timestamp when the document distribution was initiated and sent to recipients. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the document distribution process. Tracks whether the distribution to all recipients has been initiated, is in progress, completed successfully, partially failed, fully failed, or cancelled.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailTransmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Email Transmission Flag' ;
    rdfs:comment 'Indicates whether any recipient in this distribution received the document via email. Used for channel analytics and delivery method tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Encryption Applied Flag' ;
    rdfs:comment 'Indicates whether the document was encrypted during transmission. Supports data security compliance and confidential document handling.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Consolidated error message summarizing any failures encountered during distribution. Used for troubleshooting and root cause analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Failed Delivery Count' ;
    rdfs:comment 'Number of recipients for whom document delivery failed. Triggers retry logic and exception handling workflows.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Acknowledgement Timestamp' ;
    rdfs:comment 'Timestamp when the first recipient acknowledged receipt. Used for SLA tracking and time-to-acknowledgement analytics.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:initiatedBySystem rdf:type rdf:Property ;
    rdfs:label 'Initiated By System' ;
    rdfs:comment 'Name of the system or automated process that initiated the distribution (e.g., SAP TM, Oracle TMS, automated workflow). Used when distribution is triggered by system events rather than manual user action.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Acknowledgement Timestamp' ;
    rdfs:comment 'Timestamp when the last recipient acknowledged receipt. Marks completion of the full acknowledgement cycle.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastRetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Retry Timestamp' ;
    rdfs:comment 'Timestamp of the most recent retry attempt for failed deliveries. Used to schedule next retry and track retry intervals.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRetryAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Retry Attempts' ;
    rdfs:comment 'Maximum number of retry attempts configured for this distribution. After exceeding this threshold, failed deliveries are escalated for manual intervention.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRetryScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Retry Scheduled Timestamp' ;
    rdfs:comment 'Timestamp when the next retry attempt is scheduled for failed deliveries. Supports automated retry orchestration.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pendingDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Pending Delivery Count' ;
    rdfs:comment 'Number of recipients for whom document delivery is still in progress or queued. Used for real-time distribution monitoring.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalTransmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Physical Transmission Flag' ;
    rdfs:comment 'Indicates whether any recipient in this distribution received a physical printed copy. Supports legacy process tracking and regulatory compliance where physical documents are required.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portalTransmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Portal Transmission Flag' ;
    rdfs:comment 'Indicates whether any recipient in this distribution accessed the document via customer portal or web interface. Supports self-service analytics.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientCount rdf:type rdf:Property ;
    rdfs:label 'Recipient Count' ;
    rdfs:comment 'Total number of recipients in this distribution. Used for progress tracking and completion validation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientPartyList rdf:type rdf:Property ;
    rdfs:label 'Recipient Party List' ;
    rdfs:comment 'Comma-separated list of recipient party identifiers or names (e.g., shipper, consignee, airline, customs broker, freight forwarder). Provides quick visibility into all parties receiving the document.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDeliveryMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Minutes' ;
    rdfs:comment 'Target time in minutes for completing document distribution to all recipients. Used for SLA compliance monitoring and performance analytics.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successfulDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Successful Delivery Count' ;
    rdfs:comment 'Number of recipients who successfully received the document. Used to calculate distribution success rate and identify partial failures.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentExceptionId rdf:type rdf:Property ;
    rdfs:label 'Document Exception Id' ;
    rdfs:comment 'Unique identifier for the document exception record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentException .

ind:responsiblePartyId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Id' ;
    rdfs:comment 'Reference to the customer, carrier, or partner entity responsible for addressing and resolving the document exception.' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:complianceViolationCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Code' ;
    rdfs:comment 'Regulatory or compliance violation code associated with the document exception, if applicable.' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionPoint rdf:type rdf:Property ;
    rdfs:label 'Detection Point' ;
    rdfs:comment 'Stage in the logistics lifecycle where the document exception was identified (document upload, customs clearance, cargo release, quality review, audit, carrier acceptance, destination delivery). [ENUM-REF-CANDIDATE: document_upload|customs_clearance|cargo_release|quality_review|audit|carrier_acceptance|destination_delivery — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the document exception was first detected in the system, capturing the real-world event time of discovery.' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicator whether the exception requires escalation to management or specialized teams for resolution (true/false).' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed narrative description of the document exception, including specific discrepancies, missing information, or non-conformance details.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the document exception indicating its resolution state (open, in progress, pending review, resolved, closed, escalated).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Classification of the document exception identifying the nature of the non-conformance (missing document, expired certificate, data mismatch, unauthorized amendment, signature failure, incomplete data).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDocumentType rdf:type rdf:Property ;
    rdfs:label 'Expected Document Type' ;
    rdfs:comment 'Type of document that was expected but missing or incorrect, used for missing document exceptions.' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedValue rdf:type rdf:Property ;
    rdfs:label 'Expected Value' ;
    rdfs:comment 'Expected data value or content that should have been present in the document, used for data mismatch exceptions.' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldName rdf:type rdf:Property ;
    rdfs:label 'Field Name' ;
    rdfs:comment 'Specific document field or data element where the exception was identified, enabling precise error location.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicator whether the document exception has regulatory compliance implications requiring special handling (true/false).' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolvedByUserName rdf:type rdf:Property ;
    rdfs:label 'Resolved By User Name' ;
    rdfs:comment 'Name of the internal user or employee who resolved the document exception, for audit trail purposes.' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact Email' ;
    rdfs:comment 'Email address of the responsible party contact for exception resolution communication and follow-up.' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact Phone' ;
    rdfs:comment 'Phone number of the responsible party contact for urgent exception resolution communication.' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business impact severity classification of the document exception indicating urgency and priority for resolution (critical, high, medium, low).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDelayHours rdf:type rdf:Property ;
    rdfs:label 'Shipment Delay Hours' ;
    rdfs:comment 'Number of hours the shipment was delayed due to the document exception, impacting service level agreement performance.' ;
    rdfs:domain ind:DocumentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuanceId rdf:type rdf:Property ;
    rdfs:label 'Issuance Id' ;
    rdfs:comment 'Unique identifier for the document issuance event. Primary key for the document issuance record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Issuance .

ind:digitalSignatureCertificateId rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Certificate Id' ;
    rdfs:comment 'Identifier of the digital certificate used to sign the document, if digital signature was applied.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certificate .

ind:issuingEntityTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Issuing Entity Trade Party Id' ;
    rdfs:comment 'Reference to the Transport Shipping office, branch, agent, or organizational unit that issued the document.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:originalIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Original Issuance Id' ;
    rdfs:comment 'Reference to the original document issuance record if this is a duplicate, copy, amendment, or reissue. Null for original issuances.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Issuance .

ind:typeId rdf:type rdf:Property ;
    rdfs:label 'Type Id' ;
    rdfs:comment 'FK to document.document_type' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Type .

ind:acknowledgementReference rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Reference' ;
    rdfs:comment 'Reference number or confirmation code provided by the recipient or delivery system confirming successful receipt.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Status' ;
    rdfs:comment 'Status indicating whether the recipient has acknowledged receipt of the issued document. Tracks delivery confirmation and recipient acceptance.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the recipient acknowledged receipt of the document. Null if not yet acknowledged.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Business reason or explanation for why this document issuance was cancelled, if applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when this document issuance was cancelled, if applicable. Null if not cancelled.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'SHA-256 cryptographic hash of the issued document file for integrity verification and tamper detection.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceValidationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Validation Timestamp' ;
    rdfs:comment 'Date and time when regulatory compliance validation was performed for this issuance.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'Channel or method through which the document was delivered to the recipient. Email (electronic mail), EDI (Electronic Data Interchange), portal (web portal), API (Application Programming Interface), physical (printed/courier), fax (facsimile).' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethodDetail rdf:type rdf:Property ;
    rdfs:label 'Delivery Method Detail' ;
    rdfs:comment 'Additional technical details about the delivery method, such as EDI message type, API endpoint, courier service name, or portal URL.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureApplied rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Applied' ;
    rdfs:comment 'Boolean flag indicating whether a digital signature was applied to the document for authentication and non-repudiation purposes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentStoragePath rdf:type rdf:Property ;
    rdfs:label 'Document Storage Path' ;
    rdfs:comment 'File system path or cloud storage location where the issued document is stored. Confidential for security purposes.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the issued document file in bytes. Used for storage management and transmission monitoring.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuanceStatus rdf:type rdf:Property ;
    rdfs:label 'Issuance Status' ;
    rdfs:comment 'Current lifecycle status of the document issuance. Tracks whether the issuance is pending, successfully issued, acknowledged by recipient, rejected, cancelled, or expired.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issuance Timestamp' ;
    rdfs:comment 'Date and time when the document was officially issued to the recipient party. Represents the authoritative issuance event time in the business process.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:issuingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Issuing System Code' ;
    rdfs:comment 'Code identifying the operational system or channel that generated the issuance. SAP_TM (SAP Transportation Management), ORACLE_TMS (Oracle TMS), DESCARTES (Descartes Customs), MANUAL (manual issuance), EDI (Electronic Data Interchange), API (Application Programming Interface).' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Transmission Timestamp' ;
    rdfs:comment 'Date and time of the most recent transmission attempt, whether successful or failed.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Purpose or reason for this specific issuance event. Original (first issuance), duplicate (additional copy), copy (informational copy), amendment (revised version), correction (error correction), reissue (replacement).' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientContactName rdf:type rdf:Property ;
    rdfs:label 'Recipient Contact Name' ;
    rdfs:comment 'Full name of the individual contact person at the recipient organization who received the document.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Recipient Email Address' ;
    rdfs:comment 'Email address to which the document was sent if delivered electronically via email channel.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPartyType rdf:type rdf:Property ;
    rdfs:label 'Recipient Party Type' ;
    rdfs:comment 'Classification of the recipient party role in the logistics transaction. Identifies whether the recipient is the shipper, consignee, customs broker, carrier, freight forwarder, or agent.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days this document issuance record must be retained per regulatory and business retention policies.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Transmission Attempt Count' ;
    rdfs:comment 'Number of attempts made to transmit the document to the recipient. Used for tracking delivery reliability and troubleshooting.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Transmission Error Message' ;
    rdfs:comment 'Technical error message or description if the document transmission failed. Used for troubleshooting and support.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Transmission Status' ;
    rdfs:comment 'Technical status of the document transmission process. Tracks whether the document is queued for delivery, currently being transmitted, successfully transmitted, failed, or retrying after failure.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentPackageId rdf:type rdf:Property ;
    rdfs:label 'Document Package Id' ;
    rdfs:comment 'Unique identifier for the document package. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentPackage .

ind:primaryDocumentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Document Employee Id' ;
    rdfs:comment 'Reference to the user or employee who reviewed or approved the document package.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:archiveDate rdf:type rdf:Property ;
    rdfs:label 'Archive Date' ;
    rdfs:comment 'Date when the document package was archived.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archiveFlag rdf:type rdf:Property ;
    rdfs:label 'Archive Flag' ;
    rdfs:comment 'Indicates whether the document package has been archived and is no longer actively used.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completenessStatus rdf:type rdf:Property ;
    rdfs:label 'Completeness Status' ;
    rdfs:comment 'Indicator of whether all required documents in the package are present and validated.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Current status of the compliance review process for the document package.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'Precise timestamp when the document package record was first created in the system.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Number' ;
    rdfs:comment 'Official customs entry or declaration number assigned by customs authorities for clearance processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Flag' ;
    rdfs:comment 'Indicates whether the document package includes digitally signed documents for authenticity and non-repudiation.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionFlag rdf:type rdf:Property ;
    rdfs:label 'Encryption Flag' ;
    rdfs:comment 'Indicates whether the documents in the package are encrypted for security and confidentiality.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mawbNumber rdf:type rdf:Property ;
    rdfs:label 'Mawb Number' ;
    rdfs:comment 'Master Air Waybill number for consolidated air freight shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mblNumber rdf:type rdf:Property ;
    rdfs:label 'Mbl Number' ;
    rdfs:comment 'Master Bill of Lading number for consolidated ocean freight shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Missing Document Count' ;
    rdfs:comment 'Number of required documents that are still missing from the package.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:missingDocumentList rdf:type rdf:Property ;
    rdfs:label 'Missing Document List' ;
    rdfs:comment 'Comma-separated list of document types or names that are required but not yet received.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the document package indicating its readiness and approval state.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the document package based on the business transaction it supports (e.g., shipment, freight order, customs declaration).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Received Document Count' ;
    rdfs:comment 'Number of documents currently received and attached to this package.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Required Document Count' ;
    rdfs:comment 'Total number of documents required for this package based on the business transaction type and regulatory requirements.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Submission Ready Flag' ;
    rdfs:comment 'Boolean indicator showing whether the document package is complete and ready for submission to authorities or release for cargo operations.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the document package was initially created in the system.' ;
    rdfs:domain ind:DocumentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestId rdf:type rdf:Property ;
    rdfs:label 'Request Id' ;
    rdfs:comment 'Unique identifier for the document request. Primary key for the document request entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Request .

ind:requestFulfilledDocumentTransportDocumentId rdf:type rdf:Property ;
    rdfs:label 'Request Fulfilled Document Transport Document Id' ;
    rdfs:comment 'Identifier of the document that was generated or retrieved to fulfill this request, linking the request to the resulting document record.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportDocument .

ind:requestTransportDocumentId rdf:type rdf:Property ;
    rdfs:label 'Request Transport Document Id' ;
    rdfs:comment 'Identifier of the original document for which reissuance, correction, or duplicate is being requested, if applicable.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportDocument .

ind:assignedToDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned To Department' ;
    rdfs:comment 'Name or code of the internal department or business unit responsible for processing the document request, such as customer service, operations, trade compliance, or documentation team.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Charge Applicable Flag' ;
    rdfs:comment 'Boolean indicator of whether a fee or charge is applicable for fulfilling this document request. True indicates a charge applies, False indicates no charge.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Charge Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the charge amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Physical or electronic address to which the fulfilled document should be delivered, if applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Timestamp' ;
    rdfs:comment 'Date and time when the document request was successfully fulfilled and the document was delivered or made available to the requesting party.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Start Timestamp' ;
    rdfs:comment 'Date and time when processing of the document request was initiated by the assigned user or team.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Free-text explanation provided by the requesting party describing the reason or business justification for the document request.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Boolean indicator of whether the document request is driven by a regulatory or compliance requirement from customs, trade authorities, or other governing bodies. True indicates regulatory requirement, False indicates voluntary or operational request.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejection Timestamp' ;
    rdfs:comment 'Date and time when the document request was rejected and the requesting party was notified.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the document request indicating its processing state.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the document request indicating whether it is for new issuance, reissuance, retrieval, correction, certification, or duplicate copy.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDocumentType rdf:type rdf:Property ;
    rdfs:label 'Requested Document Type' ;
    rdfs:comment 'Type of document being requested. Common types include Air Waybill (AWB), Bill of Lading (BOL), House Air Waybill (HAWB), Master Air Waybill (MAWB), Master Bill of Lading (MBL), House Bill of Lading (HBL), Certificate of Origin (COO), packing list, commercial invoice, customs declaration, insurance certificate, inspection certificate, phytosanitary certificate, dangerous goods declaration, electronic Proof of Delivery (ePOD), CMR (road), CIM (rail), or other. [ENUM-REF-CANDIDATE: AWB|BOL|HAWB|MAWB|MBL|HBL|COO|packing_list|commercial_invoice|customs_declaration|insurance_certificate|inspection_certificate|phytosanitary_certificate|dangerous_goods_declaration|ePOD|CMR|CIM|other — 18 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingPartyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Contact Email' ;
    rdfs:comment 'Primary email address of the requesting party for communication regarding the document request.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingPartyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Contact Phone' ;
    rdfs:comment 'Primary phone number of the requesting party for communication regarding the document request.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingPartyType rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Type' ;
    rdfs:comment 'Classification of the party submitting the document request, such as customer, carrier, customs authority, internal operations team, freight forwarder, broker, consignee, shipper, regulatory authority, insurance company, surveyor, or other. [ENUM-REF-CANDIDATE: customer|carrier|customs_authority|internal_operations|freight_forwarder|broker|consignee|shipper|regulatory_authority|insurance_company|surveyor|other — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredByDate rdf:type rdf:Property ;
    rdfs:label 'Required By Date' ;
    rdfs:comment 'Target date by which the requesting party requires the document to be fulfilled. Used for planning and SLA tracking.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target number of hours within which the document request should be fulfilled according to the applicable Service Level Agreement (SLA) based on urgency level and request type.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Priority level assigned to the document request indicating the speed of fulfillment required. Routine for non-time-sensitive requests, standard for normal processing, urgent for expedited handling, critical for immediate attention.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageId rdf:type rdf:Property ;
    rdfs:label 'Storage Id' ;
    rdfs:comment 'Unique identifier for the document storage configuration record. Primary key.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionId rdf:type rdf:Property ;
    rdfs:label 'Version Id' ;
    rdfs:comment 'Unique identifier for this specific version of the document within the storage system. Null if versioning is not enabled.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:accessControlPolicy rdf:type rdf:Property ;
    rdfs:label 'Access Control Policy' ;
    rdfs:comment 'Name or identifier of the access control policy governing who can read, write, or delete this document. May reference IAM policies, ACLs, or RBAC rules.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupFrequency rdf:type rdf:Property ;
    rdfs:label 'Backup Frequency' ;
    rdfs:comment 'Frequency at which the document is backed up to secondary storage. Critical for disaster recovery planning and Recovery Point Objective (RPO) compliance.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Checksum Algorithm' ;
    rdfs:comment 'Algorithm used to generate the checksum value. SHA-256 or SHA-512 recommended for security-critical documents.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumValue rdf:type rdf:Property ;
    rdfs:label 'Checksum Value' ;
    rdfs:comment 'Hash or checksum of the document content used to verify data integrity and detect corruption or tampering. Typically MD5, SHA-256, or SHA-512.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classTransitionDate rdf:type rdf:Property ;
    rdfs:label 'Class Transition Date' ;
    rdfs:comment 'Date when the document is scheduled to transition to a different storage tier (e.g., from hot to warm, or warm to archive) based on lifecycle policies.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compressionFormat rdf:type rdf:Property ;
    rdfs:label 'Compression Format' ;
    rdfs:comment 'Compression algorithm applied to the document to reduce storage footprint and transfer bandwidth. None indicates uncompressed storage. [ENUM-REF-CANDIDATE: none|gzip|zip|bzip2|lz4|snappy|zstd — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerGbUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gb Usd' ;
    rdfs:comment 'Unit cost of storage per gigabyte per month in USD for this storage tier and provider. Used for cost allocation and chargeback to business units.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataResidencyCompliant rdf:type rdf:Property ;
    rdfs:label 'Data Residency Compliant' ;
    rdfs:comment 'Indicates whether the document storage location complies with data residency and sovereignty requirements for the document\'s jurisdiction. True when compliant.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Encryption Algorithm' ;
    rdfs:comment 'Cryptographic algorithm used to encrypt the document (e.g., AES-256, RSA-2048). Required for security audits and compliance verification.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionKeyReference rdf:type rdf:Property ;
    rdfs:label 'Encryption Key Reference' ;
    rdfs:comment 'Reference to the encryption key used to secure the document. May point to a key management service (KMS) key ID. Highly sensitive.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionStatus rdf:type rdf:Property ;
    rdfs:label 'Encryption Status' ;
    rdfs:comment 'Indicates whether the document is encrypted at rest, in transit, both, or unencrypted. Critical for security compliance and data protection audits.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Accessed Timestamp' ;
    rdfs:comment 'Timestamp when the document was last retrieved or accessed from storage. Used for lifecycle tiering decisions and access pattern analysis.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastBackupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Backup Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful backup of this document. Used to monitor backup health and compliance with backup policies.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether the document is under legal hold and must not be deleted or modified regardless of retention policy. True when litigation, audit, or investigation is active.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage infrastructure where the document is physically or digitally stored. Determines retrieval protocols and access patterns.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mimeType rdf:type rdf:Property ;
    rdfs:label 'Mime Type' ;
    rdfs:comment 'MIME type of the stored document (e.g., application/pdf, image/jpeg, application/xml). Used for content type validation and rendering.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Full path, URI, or object key identifying the exact location of the document within the storage system. May include bucket name, folder hierarchy, or file system path.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provider rdf:type rdf:Property ;
    rdfs:label 'Provider' ;
    rdfs:comment 'Cloud or infrastructure provider hosting the document storage. Critical for vendor management, cost allocation, and disaster recovery planning.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region or data center location where the document is physically stored. Required for data sovereignty compliance, GDPR territorial scope, and cross-border data transfer regulations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationStatus rdf:type rdf:Property ;
    rdfs:label 'Replication Status' ;
    rdfs:comment 'Current status of document replication to secondary or disaster recovery storage locations. Critical for business continuity and data durability.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationTargetRegion rdf:type rdf:Property ;
    rdfs:label 'Replication Target Region' ;
    rdfs:comment 'Geographic region where the document replica is stored for disaster recovery or data redundancy. Null if not replicated.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionClass rdf:type rdf:Property ;
    rdfs:label 'Retention Class' ;
    rdfs:comment 'Retention policy classification determining how long the document must be retained before eligible for deletion. Aligned with legal, regulatory, and business retention schedules.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrievalSlaSeconds rdf:type rdf:Property ;
    rdfs:label 'Retrieval Sla Seconds' ;
    rdfs:comment 'Maximum time in seconds guaranteed for document retrieval from this storage tier. Hot tier typically seconds, archive tier may be hours.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageStatus rdf:type rdf:Property ;
    rdfs:label 'Storage Status' ;
    rdfs:comment 'Current lifecycle status of the document in storage. Active for operational documents, archived for long-term retention, pending_deletion for documents awaiting purge.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTier rdf:type rdf:Property ;
    rdfs:label 'Storage Tier' ;
    rdfs:comment 'Performance and cost tier of the storage layer. Hot for frequently accessed documents, archive for long-term retention. Drives retrieval SLA and storage cost.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versioningEnabled rdf:type rdf:Property ;
    rdfs:label 'Versioning Enabled' ;
    rdfs:comment 'Indicates whether version control is enabled for this document storage location. When true, all updates create new versions rather than overwriting.' ;
    rdfs:domain ind:Storage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorTemplateId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Template Id' ;
    rdfs:comment 'Reference to the previous version of this template in the version history chain. Nullable for initial versions.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:applicableMode rdf:type rdf:Property ;
    rdfs:label 'Applicable Mode' ;
    rdfs:comment 'Transport mode(s) for which this template is applicable (air, ocean, road, rail, multimodal, parcel).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivalRequired rdf:type rdf:Property ;
    rdfs:label 'Archival Required' ;
    rdfs:comment 'Indicates whether documents generated from this template must be archived in long-term storage after active use (True/False).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled' ;
    rdfs:comment 'Indicates whether documents generated from this template maintain a full audit trail of all changes and access (True/False).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Description of changes made in this version compared to the predecessor version. Used for version control and audit trail.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Required' ;
    rdfs:comment 'Indicates whether documents generated from this template require digital signature for legal validity (True/False).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentSubtype rdf:type rdf:Property ;
    rdfs:label 'Document Subtype' ;
    rdfs:comment 'Detailed subtype classification within the document type category (e.g., MAWB, HAWB, MBL, HBL, Packing List, Certificate of Origin, Dangerous Goods Declaration). [ENUM-REF-CANDIDATE: MAWB|HAWB|MBL|HBL|Packing_List|Certificate_of_Origin|Dangerous_Goods_Declaration|Commercial_Invoice|Customs_Declaration|AMS_Filing|ISF_Filing|ePOD|Delivery_Receipt — promote to reference product]' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Document Type Category' ;
    rdfs:comment 'High-level classification of the document template by business purpose (transport document, trade document, customs document, compliance certificate, proof of delivery, commercial invoice).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediMessageType rdf:type rdf:Property ;
    rdfs:label 'Edi Message Type' ;
    rdfs:comment 'EDI message type code if the template generates EDI documents (e.g., IFTMIN, IFTMBC, CUSCAR, CUSRES). Nullable for non-EDI templates.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileHash rdf:type rdf:Property ;
    rdfs:label 'File Hash' ;
    rdfs:comment 'SHA-256 hash of the template file content for integrity verification and change detection.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Storage location or URI of the physical template file in the document management system or content repository.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionScope rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Scope' ;
    rdfs:comment 'Geographic or regulatory jurisdiction scope for which this template is designed (e.g., USA, EU, APAC, Global, specific country ISO codes). Pipe-separated list for multiple jurisdictions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Date when this template was last used to generate a document. Used to identify inactive templates for retirement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:layoutFormat rdf:type rdf:Property ;
    rdfs:label 'Layout Format' ;
    rdfs:comment 'Primary output format for documents generated from this template (PDF, XML, EDI, JSON, HTML, DOCX).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFieldDefinitions rdf:type rdf:Property ;
    rdfs:label 'Mandatory Field Definitions' ;
    rdfs:comment 'JSON or structured text defining the mandatory fields required in documents generated from this template, including field names, data types, and validation rules.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multilingualSupport rdf:type rdf:Property ;
    rdfs:label 'Multilingual Support' ;
    rdfs:comment 'Indicates whether this template supports multiple languages or has localized variants (True/False).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionalFieldDefinitions rdf:type rdf:Property ;
    rdfs:label 'Optional Field Definitions' ;
    rdfs:comment 'JSON or structured text defining the optional fields that may be included in documents generated from this template.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Business unit, department, or role responsible for maintaining and approving changes to this template (e.g., Customs Compliance, Air Freight Operations, Legal Department).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageSizeStandard rdf:type rdf:Property ;
    rdfs:label 'Page Size Standard' ;
    rdfs:comment 'Standard page size for documents generated from this template (A4, Letter, Legal, A3, Custom).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printLayoutOrientation rdf:type rdf:Property ;
    rdfs:label 'Print Layout Orientation' ;
    rdfs:comment 'Page orientation for printed documents generated from this template (portrait, landscape).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Specific regulation, resolution, or legal reference that defines the requirements for this template (e.g., IATA Resolution 600b, IMO FAL Convention Annex 6, EU Regulation 952/2013).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger Event' ;
    rdfs:comment 'Business event that triggers the start of the retention period (document creation, shipment completion, customs clearance, contract expiry, claim settlement).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureStandard rdf:type rdf:Property ;
    rdfs:label 'Signature Standard' ;
    rdfs:comment 'Digital signature standard or technology used for documents generated from this template (PKI, eIDAS, ESIGN, DocuSign, AdobeSign, None).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique business identifier code for the document template used across systems (e.g., AWB_STD_V3, BOL_OCEAN_FCL, POD_EXPRESS).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the document template (e.g., Standard Air Waybill, Ocean Bill of Lading, Electronic Proof of Delivery).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateStatus rdf:type rdf:Property ;
    rdfs:label 'Template Status' ;
    rdfs:comment 'Current lifecycle status of the template (draft, pending approval, active, deprecated, retired, suspended).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Version Effective Date' ;
    rdfs:comment 'Date from which this template version becomes active and available for document generation.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Version Expiry Date' ;
    rdfs:comment 'Date after which this template version is no longer valid for new document generation. Nullable for templates without planned expiration.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:watermarkRequired rdf:type rdf:Property ;
    rdfs:label 'Watermark Required' ;
    rdfs:comment 'Indicates whether documents generated from this template must include a watermark (e.g., DRAFT, CONFIDENTIAL, COPY) (True/False).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:watermarkText rdf:type rdf:Property ;
    rdfs:label 'Watermark Text' ;
    rdfs:comment 'Text to be displayed as watermark on documents generated from this template. Nullable if watermark is not required.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xmlSchemaVersion rdf:type rdf:Property ;
    rdfs:label 'Xml Schema Version' ;
    rdfs:comment 'Version of the XML schema used for XML-based templates (e.g., Cargo-XML 3.0, Cargo-IMP 1.2). Nullable for non-XML templates.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlLevel rdf:type rdf:Property ;
    rdfs:label 'Access Control Level' ;
    rdfs:comment 'Default access control classification for documents of this type. Determines who can view, edit, or share the document. Values: public (no restrictions), internal (company employees only), confidential (authorized personnel only), restricted (highly sensitive, need-to-know basis).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether a complete audit trail of all access, modifications, and transmissions must be maintained for this document type. True if audit logging is mandatory for compliance and governance, false otherwise.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsDeclarationType rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Type' ;
    rdfs:comment 'The customs declaration type code if this document is used for customs clearance (e.g., IM for import, EX for export, T1 for transit, ATA for carnet). Null if not a customs document.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultLanguage rdf:type rdf:Property ;
    rdfs:label 'Default Language' ;
    rdfs:comment 'The default language for this document type, specified as a two-letter ISO 639-1 language code (e.g., en for English, es for Spanish, fr for French, de for German, zh for Chinese).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionRequired rdf:type rdf:Property ;
    rdfs:label 'Encryption Required' ;
    rdfs:comment 'Indicates whether encryption is required for documents of this type during storage and transmission. True if encryption is mandatory for data protection and compliance, false otherwise.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileFormatAllowed rdf:type rdf:Property ;
    rdfs:label 'File Format Allowed' ;
    rdfs:comment 'Comma-separated list of file formats permitted for this document type (e.g., PDF, XML, JSON, EDIFACT, CSV, TIFF, JPEG). Used to enforce format standards during document upload and validation.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuancePartyType rdf:type rdf:Property ;
    rdfs:label 'Issuance Party Type' ;
    rdfs:comment 'The type of party authorized or responsible for issuing this document type. Values: carrier (transport operator), shipper (sender), consignee (receiver), authority (government/regulatory body), broker (customs broker), forwarder (freight forwarder), warehouse (warehouse operator), internal (internal company document). [ENUM-REF-CANDIDATE: carrier|shipper|consignee|authority|broker|forwarder|warehouse|internal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldEligible rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Eligible' ;
    rdfs:comment 'Indicates whether documents of this type are eligible for legal hold (preservation order) in case of litigation, investigation, or regulatory inquiry. True if legal hold can be applied, false otherwise.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxFileSizeMb rdf:type rdf:Property ;
    rdfs:label 'Max File Size Mb' ;
    rdfs:comment 'Maximum allowed file size in megabytes for documents of this type. Used to enforce storage and transmission limits. Null indicates no size restriction.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredFieldsSchemaReference rdf:type rdf:Property ;
    rdfs:label 'Required Fields Schema Reference' ;
    rdfs:comment 'Reference to the schema definition or template that specifies the mandatory data fields for this document type. May reference an internal schema registry, EDI message standard (e.g., EDIFACT, X12), or regulatory specification.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionTrigger rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger' ;
    rdfs:comment 'The event that triggers the start of the retention period countdown. Values: creation_date (document creation), completion_date (transaction completion), expiry_date (document expiry), last_activity_date (last modification or access), fiscal_year_end (end of fiscal year).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing finer granularity within the category (e.g., within transport: waybill, manifest, delivery receipt; within trade: invoice, packing list, certificate of origin).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateAvailable rdf:type rdf:Property ;
    rdfs:label 'Template Available' ;
    rdfs:comment 'Indicates whether a standardized template is available for this document type. True if a template exists in the document management system, false otherwise.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateReference rdf:type rdf:Property ;
    rdfs:label 'Template Reference' ;
    rdfs:comment 'Reference identifier or URI pointing to the document template in the template repository or document management system. Null if no template is available.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeCategory rdf:type rdf:Property ;
    rdfs:label 'Type Category' ;
    rdfs:comment 'High-level classification of the document type into functional categories: transport (shipping documents), trade (commercial documents), compliance (regulatory filings), certificate (official certifications), financial (invoices and payment documents), operational (internal process documents).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeDescription rdf:type rdf:Property ;
    rdfs:label 'Type Description' ;
    rdfs:comment 'Detailed description of the document type, its purpose, usage context, and any special handling instructions or business rules.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeName rdf:type rdf:Property ;
    rdfs:label 'Type Name' ;
    rdfs:comment 'Full descriptive name of the document type (e.g., Air Waybill, Bill of Lading, Commercial Invoice, Certificate of Origin).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeStatus rdf:type rdf:Property ;
    rdfs:label 'Type Status' ;
    rdfs:comment 'Current lifecycle status of the document type definition. Values: active (currently in use), inactive (temporarily disabled), deprecated (phased out, legacy only), draft (under development), under_review (pending approval).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Additional operational notes, guidelines, or best practices for using this document type. May include references to training materials, process documentation, or system-specific instructions.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Version Control Enabled' ;
    rdfs:comment 'Indicates whether version control and change tracking is enabled for this document type. True if versioning is required to maintain audit trail of document revisions, false otherwise.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Reference to the employee or user who approved this document version for publication or use.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedCustomsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Related Customs Declaration Id' ;
    rdfs:comment 'Reference to the customs declaration this document version supports. Applicable for customs and trade compliance documents.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Declaration .

ind:supersededVersionId rdf:type rdf:Property ;
    rdfs:label 'Superseded Version Id' ;
    rdfs:comment 'Reference to the previous document version that this version replaces or supersedes. Null for the first version. Enables version chain traversal.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:versionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Version Employee Id' ;
    rdfs:comment 'Reference to the employee or user who created or authored this document version.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:versionModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Version Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this document version record. Audit trail field for accountability.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the person who approved this document version. Captured for audit trail and compliance verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Full name of the person who created or authored this document version. Captured for audit trail and accountability.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for creating this version. Used for categorizing version changes for compliance and audit purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceClassification rdf:type rdf:Property ;
    rdfs:label 'Compliance Classification' ;
    rdfs:comment 'The regulatory or compliance domain this document version supports. Used to apply appropriate retention and handling rules. [ENUM-REF-CANDIDATE: customs|trade|safety|environmental|financial|contractual|operational — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentArtifactUri rdf:type rdf:Property ;
    rdfs:label 'Document Artifact Uri' ;
    rdfs:comment 'The storage location URI or path reference to the physical document artifact (PDF, DOCX, XML, etc.) for this version. Points to the binary file in the document repository.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Document Size Bytes' ;
    rdfs:comment 'The file size of the document artifact in bytes. Used for storage management and transmission planning.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMasterVersion rdf:type rdf:Property ;
    rdfs:label 'Is Master Version' ;
    rdfs:comment 'Indicates whether this version is designated as the master or authoritative version of the document. True if master, false otherwise.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:versionDate rdf:type rdf:Property ;
    rdfs:label 'Version Date' ;
    rdfs:comment 'The date this version was created or published. Represents the business event timestamp for this version iteration.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessUnitId rdf:type rdf:Property ;
    rdfs:label 'Business Unit Id' ;
    rdfs:comment 'Reference to the business unit or division that owns and manages this workflow configuration.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportShipping .

ind:parentWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Parent Workflow Id' ;
    rdfs:comment 'Reference to the parent workflow if this configuration was cloned from a template or is a version of another workflow. Null for original workflows.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Workflow .

ind:workflowApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Workflow Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved this workflow configuration for production use.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workflowEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Workflow Employee Id' ;
    rdfs:comment 'Reference to the user who created this workflow configuration.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workflowLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Workflow Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this workflow configuration.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoApprovalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Approval Enabled' ;
    rdfs:comment 'Indicates whether automatic approval is enabled for documents meeting predefined threshold criteria without manual intervention.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoApprovalThreshold rdf:type rdf:Property ;
    rdfs:label 'Auto Approval Threshold' ;
    rdfs:comment 'Business rule or criteria defining when documents can be auto-approved (e.g., \'shipment value < 1000 USD\', \'non-hazardous goods only\', \'domestic shipments within same country\').' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationEnabled rdf:type rdf:Property ;
    rdfs:label 'Escalation Enabled' ;
    rdfs:comment 'Indicates whether automatic escalation rules are enabled for this workflow when Service Level Agreement (SLA) thresholds are breached.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationHierarchy rdf:type rdf:Property ;
    rdfs:label 'Escalation Hierarchy' ;
    rdfs:comment 'Comma-separated list of role codes or user groups defining the escalation path in order (e.g., \'SUPERVISOR,MANAGER,DIRECTOR,VP_OPERATIONS\').' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRule rdf:type rdf:Property ;
    rdfs:label 'Escalation Rule' ;
    rdfs:comment 'Business rule defining escalation logic when SLA is breached (e.g., \'escalate to manager after 24 hours\', \'notify senior compliance officer if not approved within 48 hours\').' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Template' ;
    rdfs:comment 'Indicates whether this workflow configuration serves as a template that can be cloned to create new workflows (True) or is a production workflow instance (False).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxRevisionCycles rdf:type rdf:Property ;
    rdfs:label 'Max Revision Cycles' ;
    rdfs:comment 'Maximum number of revision cycles allowed before the document must be either approved or rejected to prevent infinite loops.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumApprovers rdf:type rdf:Property ;
    rdfs:label 'Minimum Approvers' ;
    rdfs:comment 'Minimum number of approvers required to authorize the document before it can proceed to the next stage or be issued.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationChannels rdf:type rdf:Property ;
    rdfs:label 'Notification Channels' ;
    rdfs:comment 'Comma-separated list of notification channels used to alert approvers and stakeholders (e.g., \'email,sms,push\').' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled' ;
    rdfs:comment 'Indicates whether automatic notifications are sent to approvers and stakeholders at each workflow stage transition.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parallelApprovalAllowed rdf:type rdf:Property ;
    rdfs:label 'Parallel Approval Allowed' ;
    rdfs:comment 'Indicates whether multiple approvers can review and approve simultaneously (True) or approvals must be sequential (False).' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionAllowed rdf:type rdf:Property ;
    rdfs:label 'Rejection Allowed' ;
    rdfs:comment 'Indicates whether approvers are allowed to reject documents in this workflow (True) or can only approve or request revisions (False).' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredApproverRoles rdf:type rdf:Property ;
    rdfs:label 'Required Approver Roles' ;
    rdfs:comment 'Comma-separated list of role codes or role names that are required to approve documents in this workflow (e.g., \'CUSTOMS_OFFICER,COMPLIANCE_MANAGER,OPERATIONS_SUPERVISOR\').' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresMultiPartyApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Multi Party Approval' ;
    rdfs:comment 'Indicates whether this workflow requires approval from multiple parties or roles before document issuance (True) or can be approved by a single party (False).' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionAllowed rdf:type rdf:Property ;
    rdfs:label 'Revision Allowed' ;
    rdfs:comment 'Indicates whether documents can be sent back for revision during the workflow (True) or must be approved or rejected without revision cycles (False).' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDurationHours rdf:type rdf:Property ;
    rdfs:label 'Sla Duration Hours' ;
    rdfs:comment 'Total Service Level Agreement duration in hours for the entire workflow from initiation to final approval and issuance.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageSequence rdf:type rdf:Property ;
    rdfs:label 'Stage Sequence' ;
    rdfs:comment 'Ordered list of workflow stages that documents must pass through (e.g., \'draft,review,approve,issue\' or \'submit,customs_review,compliance_check,release\'). Comma-separated stage codes in execution order.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageSlaConfig rdf:type rdf:Property ;
    rdfs:label 'Stage Sla Config' ;
    rdfs:comment 'JSON or structured string defining SLA duration for each workflow stage (e.g., \'draft:4h,review:8h,approve:12h,issue:2h\') to enable stage-level monitoring.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStages rdf:type rdf:Property ;
    rdfs:label 'Total Stages' ;
    rdfs:comment 'Total number of stages in the workflow sequence for quick reference and validation.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowCode rdf:type rdf:Property ;
    rdfs:label 'Workflow Code' ;
    rdfs:comment 'Unique business code for the workflow configuration used for system integration and reference (e.g., \'DG_DECL_APPR\', \'CUST_ENTRY_REV\').' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowDescription rdf:type rdf:Property ;
    rdfs:label 'Workflow Description' ;
    rdfs:comment 'Detailed business description of the workflow purpose, scope, and applicability including when and why this workflow should be triggered.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowName rdf:type rdf:Property ;
    rdfs:label 'Workflow Name' ;
    rdfs:comment 'Business name of the workflow configuration (e.g., \'Dangerous Goods Declaration Approval\', \'Customs Entry Review\', \'Letter of Credit Authorization\').' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldId rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Id' ;
    rdfs:comment 'Unique identifier for the legal hold record. Primary key.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgmentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Received Date' ;
    rdfs:comment 'Date when custodian acknowledgment of the legal hold was received.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required' ;
    rdfs:comment 'Indicates whether custodians are required to formally acknowledge receipt and understanding of the legal hold order.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Affected Document Count' ;
    rdfs:comment 'Estimated or actual count of documents subject to this legal hold order.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessUnitScope rdf:type rdf:Property ;
    rdfs:label 'Business Unit Scope' ;
    rdfs:comment 'Business units, divisions, or departments whose documents are subject to the legal hold.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseName rdf:type rdf:Property ;
    rdfs:label 'Case Name' ;
    rdfs:comment 'Descriptive name or title of the litigation, investigation, or audit matter that triggered the legal hold.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianDepartment rdf:type rdf:Property ;
    rdfs:label 'Custodian Department' ;
    rdfs:comment 'Department or business unit to which the legal hold custodian belongs.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianEmail rdf:type rdf:Property ;
    rdfs:label 'Custodian Email' ;
    rdfs:comment 'Email address of the custodian responsible for the legal hold for communication and compliance tracking.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianName rdf:type rdf:Property ;
    rdfs:label 'Custodian Name' ;
    rdfs:comment 'Name of the individual or role responsible for ensuring compliance with the legal hold order and preserving affected documents.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Date Range End' ;
    rdfs:comment 'End date of the document creation or transaction date range covered by the legal hold. Null indicates open-ended scope.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Date Range Start' ;
    rdfs:comment 'Start date of the document creation or transaction date range covered by the legal hold.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentTypesCovered rdf:type rdf:Property ;
    rdfs:label 'Document Types Covered' ;
    rdfs:comment 'Comma-separated list or description of document types subject to the legal hold (e.g., AWB, BOL, customs declarations, contracts, emails, invoices).' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdActualEndDate rdf:type rdf:Property ;
    rdfs:label 'Hold Actual End Date' ;
    rdfs:comment 'Actual date when the legal hold was officially released and normal retention policies resumed.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdExpectedEndDate rdf:type rdf:Property ;
    rdfs:label 'Hold Expected End Date' ;
    rdfs:comment 'Anticipated or scheduled date when the legal hold is expected to be released, subject to case resolution or regulatory closure.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdPriority rdf:type rdf:Property ;
    rdfs:label 'Hold Priority' ;
    rdfs:comment 'Priority level assigned to the legal hold indicating urgency and compliance criticality.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the legal hold order for tracking and communication purposes.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Scope Description' ;
    rdfs:comment 'Detailed description of the scope of the legal hold including document types, subject matter, business units, geographic regions, and date ranges covered.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStartDate rdf:type rdf:Property ;
    rdfs:label 'Hold Start Date' ;
    rdfs:comment 'Date when the legal hold order became effective and document retention suspension began.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the legal hold based on the triggering event or authority requirement.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityContact rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Contact' ;
    rdfs:comment 'Contact email or phone number of the issuing authority for hold-related inquiries and communications.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Notes' ;
    rdfs:comment 'Detailed notes describing any non-compliance issues, remediation actions taken, or risks identified during compliance reviews.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date when legal hold notification was sent to custodians and affected parties.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overrideRetentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Override Retention Policy' ;
    rdfs:comment 'Indicates whether this legal hold overrides normal document retention and destruction schedules for affected documents.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseAuthorization rdf:type rdf:Property ;
    rdfs:label 'Release Authorization' ;
    rdfs:comment 'Name and title of the legal counsel or authority who authorized the release of the legal hold.' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizationRecordId rdf:type rdf:Property ;
    rdfs:label 'Notarization Record Id' ;
    rdfs:comment 'Unique identifier for the notarization record. Primary key for the notarization_record product.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalCertificateId rdf:type rdf:Property ;
    rdfs:label 'Digital Certificate Id' ;
    rdfs:comment 'Unique identifier of the digital certificate used for electronic notarization. Links to the digital signature or certificate authority system.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certificate .

ind:primaryNotarizationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Notarization Employee Id' ;
    rdfs:comment 'User ID of the system user who created this notarization record. Used for audit trail purposes.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:apostilleIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Apostille Issuing Authority' ;
    rdfs:comment 'Name of the competent authority designated by the country to issue apostilles under the Hague Convention (typically Secretary of State, Ministry of Foreign Affairs, or designated court).' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apostilleNumber rdf:type rdf:Property ;
    rdfs:label 'Apostille Number' ;
    rdfs:comment 'Unique apostille certificate number assigned by the competent authority under the Hague Convention. Only applicable when notarization_type is apostille.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfNotarization rdf:type rdf:Property ;
    rdfs:label 'Country Of Notarization' ;
    rdfs:comment 'Three-letter ISO country code of the country where the notarization was performed. Critical for determining applicable legal framework and cross-border recognition.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalCertificateApplied rdf:type rdf:Property ;
    rdfs:label 'Digital Certificate Applied' ;
    rdfs:comment 'Indicates whether a digital certificate or electronic seal was applied to the notarization record in addition to or instead of a physical stamp or seal.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hagueConventionApplicable rdf:type rdf:Property ;
    rdfs:label 'Hague Convention Applicable' ;
    rdfs:comment 'Indicates whether the Hague Convention Abolishing the Requirement of Legalisation for Foreign Public Documents applies between the country of notarization and the destination country. True if apostille is sufficient; false if consular legalization is required.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalizationChain rdf:type rdf:Property ;
    rdfs:label 'Legalization Chain' ;
    rdfs:comment 'Sequence of authentication steps performed for consular legalization (e.g., notary > county clerk > secretary of state > embassy > ministry of foreign affairs). Applicable for non-Hague Convention countries.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizationDate rdf:type rdf:Property ;
    rdfs:label 'Notarization Date' ;
    rdfs:comment 'Date on which the notarization act was performed and the document was officially certified by the notarizing authority. This is the principal business event timestamp for the notarization.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notarizationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Notarization Fee Amount' ;
    rdfs:comment 'Fee charged by the notarizing authority for performing the notarization or authentication service.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notarizationFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Notarization Fee Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the notarization fee amount.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizationLocationAddress rdf:type rdf:Property ;
    rdfs:label 'Notarization Location Address' ;
    rdfs:comment 'Full street address of the location where the notarization was performed. May be a notary office, consulate, embassy, or chamber of commerce.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizationLocationCity rdf:type rdf:Property ;
    rdfs:label 'Notarization Location City' ;
    rdfs:comment 'City or municipality where the notarization act was performed.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Notarization Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned by the notarizing authority to this notarization act. Used for verification and audit purposes.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizationStatus rdf:type rdf:Property ;
    rdfs:label 'Notarization Status' ;
    rdfs:comment 'Current lifecycle status of the notarization record. Tracks the notarization process from initiation through completion or rejection.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notarization Timestamp' ;
    rdfs:comment 'Precise timestamp when the notarization act was completed, including time zone. Used for legal timestamping and audit trail purposes.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notarizationType rdf:type rdf:Property ;
    rdfs:label 'Notarization Type' ;
    rdfs:comment 'Type of notarization or authentication applied to the document. Notarial act is a domestic notarization; apostille is for Hague Convention countries; consular legalization is for non-Hague countries; chamber authentication is by chamber of commerce; embassy certification and ministry attestation are diplomatic authentication methods.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizingAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Notarizing Authority Code' ;
    rdfs:comment 'Standardized code or registration number identifying the notarizing authority within its jurisdiction. Used for verification and lookup purposes.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Notarizing Authority Name' ;
    rdfs:comment 'Full legal name of the authority, notary public, consulate, embassy, or chamber of commerce that performed the notarization or authentication.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notaryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Notary Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction (state, province, or country) in which the notary is authorized to perform notarial acts.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notaryLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Notary License Number' ;
    rdfs:comment 'License or commission number of the notary public who performed the notarization. Used for verification of notary credentials.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notaryName rdf:type rdf:Property ;
    rdfs:label 'Notary Name' ;
    rdfs:comment 'Full name of the individual notary public or authorized officer who performed the notarization act.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purposeOfNotarization rdf:type rdf:Property ;
    rdfs:label 'Purpose Of Notarization' ;
    rdfs:comment 'Business reason or legal requirement for the notarization. Examples include customs clearance, import/export compliance, legal proceedings, or contractual requirements.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealImageUrl rdf:type rdf:Property ;
    rdfs:label 'Seal Image Url' ;
    rdfs:comment 'Storage location or URL of the digital image of the notary seal or apostille stamp impression.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealImpressionCaptured rdf:type rdf:Property ;
    rdfs:label 'Seal Impression Captured' ;
    rdfs:comment 'Indicates whether a digital image of the notary seal or apostille stamp impression was captured and stored with the record.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Validity Period Days' ;
    rdfs:comment 'Number of days for which the notarization is considered valid for its intended purpose. Varies by document type, destination country, and regulatory requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationCode rdf:type rdf:Property ;
    rdfs:label 'Verification Code' ;
    rdfs:comment 'Unique code or token that can be used to verify the authenticity of the notarization through the verification_url or with the issuing authority.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses who signed the notarization document. Typically 0, 1, or 2 depending on jurisdiction and document type.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessRequired rdf:type rdf:Property ;
    rdfs:label 'Witness Required' ;
    rdfs:comment 'Indicates whether witness signatures were required for this notarization act under the applicable legal framework.' ;
    rdfs:domain ind:NotarizationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByPolicyRetentionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Retention Policy Id' ;
    rdfs:comment 'Reference to the retention policy that replaces this policy when status is \'superseded\'. Null if policy is active or not superseded.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionPolicy .

ind:appliesToDigital rdf:type rdf:Property ;
    rdfs:label 'Applies To Digital' ;
    rdfs:comment 'Indicates whether this retention policy applies to digital/electronic documents. True if policy governs electronic records.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToPhysical rdf:type rdf:Property ;
    rdfs:label 'Applies To Physical' ;
    rdfs:comment 'Indicates whether this retention policy applies to physical/paper documents. True if policy governs hard-copy records.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automatedPurgeEnabled rdf:type rdf:Property ;
    rdfs:label 'Automated Purge Enabled' ;
    rdfs:comment 'Indicates whether automated document purge/destruction is enabled for this policy. True if system can automatically delete documents at end of retention period (subject to legal hold checks).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessOwner rdf:type rdf:Property ;
    rdfs:label 'Business Owner' ;
    rdfs:comment 'Business unit or department responsible for maintaining and enforcing this retention policy (e.g., \'Legal Department\', \'Compliance\', \'Finance\', \'Operations\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Destruction Authorization Required' ;
    rdfs:comment 'Indicates whether formal authorization (e.g., legal counsel approval, compliance officer sign-off) is required before document destruction. True if authorization is mandatory.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exception Criteria' ;
    rdfs:comment 'Conditions under which documents may be retained longer or shorter than the standard policy (e.g., \'Retain indefinitely if involved in litigation\', \'Early destruction allowed with legal counsel approval\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic or legal jurisdiction where this policy applies (e.g., \'USA\', \'GBR\', \'DEU\', \'European Union\', \'Global\'). Use ISO 3166-1 alpha-3 country codes where applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCitation rdf:type rdf:Property ;
    rdfs:label 'Legal Citation' ;
    rdfs:comment 'Specific legal statute, regulation, or standard reference mandating the retention requirement (e.g., \'19 CFR 163.4\', \'IATA Resolution 600a\', \'SOX Section 802\', \'GDPR Article 5(1)(e)\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Override Allowed' ;
    rdfs:comment 'Indicates whether this retention policy can be overridden by a legal hold (litigation hold, regulatory investigation). False means documents must be retained indefinitely if legal hold is active.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Maximum Retention Years' ;
    rdfs:comment 'Maximum number of years the document may be retained before mandatory destruction, if applicable. Null if no maximum is defined. Used for privacy compliance (e.g., GDPR data minimization).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Retention Years' ;
    rdfs:comment 'Minimum number of years the document must be retained from the trigger date (e.g., 7.00 years for IATA air waybills, 5.00 years for US customs records). Supports fractional years for precise compliance.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationBeforeDestructionDays rdf:type rdf:Property ;
    rdfs:label 'Notification Before Destruction Days' ;
    rdfs:comment 'Number of days before scheduled destruction that stakeholders should be notified (e.g., 30 days advance notice). Allows final review before permanent deletion.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the retention policy for system reference and integration (e.g., \'AWB-7Y-IATA\', \'BOL-5Y-FMC\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed narrative description of the retention policy, including business rationale, regulatory drivers, scope, and special handling instructions.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Business-friendly name of the retention policy (e.g., \'Air Waybill 7-Year Retention\', \'Customs Declaration EU Retention\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyClassification rdf:type rdf:Property ;
    rdfs:label 'Privacy Classification' ;
    rdfs:comment 'Data classification level of documents governed by this policy. Determines access controls and destruction rigor (e.g., restricted for documents containing PII, confidential for business-sensitive records).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationRequirement rdf:type rdf:Property ;
    rdfs:label 'Storage Location Requirement' ;
    rdfs:comment 'Mandated or preferred storage location type for documents under this policy (e.g., on_premise for regulated records, cloud for operational documents, secure_archive for long-term retention).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDocumentId rdf:type rdf:Property ;
    rdfs:label 'Trade Document Id' ;
    rdfs:comment 'Unique identifier for the trade document record. Primary key for the trade document entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeDocument .

ind:previousVersionTradeDocumentId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Trade Document Id' ;
    rdfs:comment 'Foreign key reference to the previous version of this trade document. Enables version history tracking and change audit.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeDocument .

ind:archivalDate rdf:type rdf:Property ;
    rdfs:label 'Archival Date' ;
    rdfs:comment 'Date when this trade document was moved to archival storage. Nullable for active documents.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authenticationStatus rdf:type rdf:Property ;
    rdfs:label 'Authentication Status' ;
    rdfs:comment 'Current status of the document authentication process. Indicates whether the document has been successfully verified by the required authority.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the declared value amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exporterTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Exporter Tax Number' ;
    rdfs:comment 'Tax identification number or business registration number of the exporter. Used for customs clearance and trade compliance verification.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Importer Tax Number' ;
    rdfs:comment 'Tax identification number or business registration number of the importer. Required for customs clearance and duty assessment.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'International Commercial Terms code defining the responsibilities, costs, and risks between buyer and seller. Follows ICC Incoterms 2020 standard. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Amount' ;
    rdfs:comment 'Insurance coverage amount for goods documented in this trade document. Nullable if no insurance is declared.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:letterOfCreditNumber rdf:type rdf:Property ;
    rdfs:label 'Letter Of Credit Number' ;
    rdfs:comment 'Letter of credit reference number if this trade document is part of a documentary credit transaction. Nullable for non-LC shipments.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPackageCount rdf:type rdf:Property ;
    rdfs:label 'Total Package Count' ;
    rdfs:comment 'Total number of packages, cartons, pallets, or shipping units documented in this trade document.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cbm' ;
    rdfs:comment 'Total volume of goods documented in this trade document, measured in cubic meters. Used for freight rating and capacity planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentDocumentTransportDocumentId rdf:type rdf:Property ;
    rdfs:label 'Parent Document Transport Document Id' ;
    rdfs:comment 'Reference to the parent transport document if this is a house document under a master document (e.g., HAWB under MAWB, HBL under MBL). Nullable for master documents.' ;
    rdfs:domain ind:TransportDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportDocument .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'The location or port where the shipment is destined (e.g., airport code, seaport name, city). Recorded as stated on the transport document.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'The reference number assigned by the regulatory authority upon successful filing (e.g., AMS filing number, ENS MRN). Nullable if not yet filed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightChargesPrepaid rdf:type rdf:Property ;
    rdfs:label 'Freight Charges Prepaid' ;
    rdfs:comment 'Indicates whether freight charges are prepaid (true) or collect (false). Determines payment responsibility.' ;
    rdfs:domain ind:TransportDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingPartyCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Party Code' ;
    rdfs:comment 'The standardized code or identifier for the issuing party (e.g., IATA airline code, SCAC code for ocean carriers).' ;
    rdfs:domain ind:TransportDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingPartyName rdf:type rdf:Property ;
    rdfs:label 'Issuing Party Name' ;
    rdfs:comment 'The name of the organization or entity that issued the transport document (e.g., carrier, freight forwarder, NVOCC).' ;
    rdfs:domain ind:TransportDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPackages rdf:type rdf:Property ;
    rdfs:label 'Number Of Packages' ;
    rdfs:comment 'The total count of packages, pieces, or handling units covered by this transport document.' ;
    rdfs:domain ind:TransportDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'The location or port where the shipment originates (e.g., airport code, seaport name, city). Recorded as stated on the transport document.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'The seal number applied to the container or shipment for security and tamper-evidence. Nullable if no seal is applied.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'The total gross weight of the shipment in kilograms as declared on the transport document.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workflowTaskId rdf:type rdf:Property ;
    rdfs:label 'Workflow Task Id' ;
    rdfs:comment 'Unique identifier for the workflow task. Primary key for the workflow task entity.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Reference to the organizational role assigned to complete this task. Used for role-based task routing when specific user assignment is not required.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the work group or team assigned to complete this task. Enables shared task pools for collaborative processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryWorkflowEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workflow Employee Id' ;
    rdfs:comment 'Reference to the individual user assigned to complete this task. Null if assigned to a role or group rather than a specific person.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryWorkflowDelegatedFromUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Workflow Delegated From User Employee Id' ;
    rdfs:comment 'Reference to the original assignee who delegated this task. Null if task was not delegated.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWorkflowEscalatedToUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Workflow Escalated To User Employee Id' ;
    rdfs:comment 'Reference to the user to whom the task was escalated. Typically a manager or senior approver with override authority.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:conditionalRoutingExpression rdf:type rdf:Property ;
    rdfs:label 'Conditional Routing Expression' ;
    rdfs:comment 'Business rule expression that determines the next workflow step based on this task\'s outcome. Enables dynamic workflow routing logic.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionComments rdf:type rdf:Property ;
    rdfs:label 'Decision Comments' ;
    rdfs:comment 'Free-text comments or justification provided by the assignee explaining their decision. Captures business rationale for audit and compliance purposes.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Delegation Allowed Flag' ;
    rdfs:comment 'Indicates whether the assignee is permitted to delegate this task to another user. False for tasks requiring specific authority or certification.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delegationReason rdf:type rdf:Property ;
    rdfs:label 'Delegation Reason' ;
    rdfs:comment 'Free-text explanation provided by the delegating user for why the task was delegated. Supports audit trail and workload management analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delegation Timestamp' ;
    rdfs:comment 'Date and time when the task was delegated to the current assignee. Null if task was not delegated.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:digitalSignatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Required Flag' ;
    rdfs:comment 'Indicates whether the task requires a legally binding digital signature upon completion. True for regulatory-critical approvals.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Due Timestamp' ;
    rdfs:comment 'Precise date and time when the task must be completed. Provides hour-level SLA enforcement for time-critical document approvals.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalated Timestamp' ;
    rdfs:comment 'Date and time when the task was most recently escalated. Null if task has never been escalated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReminderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Timestamp' ;
    rdfs:comment 'Date and time when the most recent reminder notification was sent to the assignee. Null if no reminders have been sent.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outcomeDecision rdf:type rdf:Property ;
    rdfs:label 'Outcome Decision' ;
    rdfs:comment 'Final decision or action taken by the assignee upon task completion. Determines the next routing step in the workflow.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parallelTaskGroupCode rdf:type rdf:Property ;
    rdfs:label 'Parallel Task Group Code' ;
    rdfs:comment 'Identifier grouping tasks that execute in parallel within the workflow. All tasks in the same group must complete before workflow proceeds to next stage.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the category of rejection when outcome_decision is rejected. Enables structured analysis of rejection patterns. [ENUM-REF-CANDIDATE: incomplete_information|regulatory_noncompliance|incorrect_classification|missing_signatures|expired_documents|unauthorized_requester|policy_violation — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderSentCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Count' ;
    rdfs:comment 'Number of automated reminder notifications sent to the assignee for this task. Used to track engagement and escalation triggers.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this task within the workflow instance. Determines the execution order and routing logic for sequential approval processes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaElapsedHours rdf:type rdf:Property ;
    rdfs:label 'Sla Elapsed Hours' ;
    rdfs:comment 'Actual business hours elapsed from assignment to completion or current time if still open. Used for SLA compliance reporting.' ;
    rdfs:domain ind:WorkflowTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Started Timestamp' ;
    rdfs:comment 'Date and time when the assignee began actively working on the task. Distinguishes assignment time from actual work commencement for productivity analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Human-readable business identifier for the workflow task. Format: WFT-XXXXXXXXXX where X is a digit. Used for operational tracking and user communication.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle state of the workflow task. Tracks progression from assignment through completion or termination. [ENUM-REF-CANDIDATE: pending|assigned|in_progress|completed|escalated|cancelled|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the action required for this task. Determines the business logic and user interface presented to the assignee.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Foreign key linking to finance.payment_run. Business justification: accounts_payable has payment_reference_number (STRING) and payment_date but no FK to payment_run. When AP invoices are paid via automated payment run, they should reference the payment_run entity for ' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:primaryAccountsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Accounts Employee Id' ;
    rdfs:comment 'Identifier of the user who created this accounts payable record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditTrailEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled Flag' ;
    rdfs:comment 'Indicates whether detailed audit logging is enabled for this payable record. Required for regulatory compliance and internal controls.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The reference date from which payment terms are calculated. Typically the invoice date or goods receipt date depending on payment term configuration.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The goods receipt document number confirming delivery of goods or services. Used for three-way matching and accrual accounting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this payable is an intercompany transaction between legal entities within Transport Shipping. Used for consolidation elimination.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Gross Amount' ;
    rdfs:comment 'The total invoice amount before any deductions, discounts, or adjustments. Represents the full vendor claim.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Date' ;
    rdfs:comment 'The date the invoice was received by Transport Shipping. Used for internal processing SLA tracking and audit trails.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payableCategory rdf:type rdf:Property ;
    rdfs:label 'Payable Category' ;
    rdfs:comment 'The business category of the payable. Classifies vendor invoices by service type for spend analysis and vendor management. [ENUM-REF-CANDIDATE: carrier|3pl_4pl|fuel|customs_duty|warehouse|equipment|intercompany|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Code indicating if payment is blocked and the reason for the block (e.g., dispute, missing documentation, approval pending, quality issue). Empty if no block exists.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Detailed explanation of why the payment is blocked. Provides context for resolution and audit purposes.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodCode rdf:type rdf:Property ;
    rdfs:label 'Payment Method Code' ;
    rdfs:comment 'The method by which payment will be made to the vendor (e.g., wire transfer, ACH, check, electronic funds transfer).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Indicates whether this payable is subject to SOX financial controls and requires enhanced audit trail and approval workflow.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'The tax jurisdiction code for this transaction. Used for multi-jurisdictional tax reporting and compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitExposure rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Exposure' ;
    rdfs:comment 'The portion of the customer\'s credit limit consumed by this receivable. Used for credit risk management and order release decisions.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total gross amount of the receivable before any discounts, taxes, or adjustments. Includes all freight charges, express delivery fees, customs brokerage fees, warehousing charges, and e-commerce fulfillment fees.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'The date when the last dunning notice was sent to the customer. Used to track collection activity and determine next dunning action.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'The local currency code of the company code for statutory reporting. Used for currency translation and consolidation per IFRS requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net amount due from the customer after all discounts and adjustments. This is the amount expected to be collected and used for cash flow forecasting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'The current outstanding balance on this receivable after partial payments or credits have been applied. Zero when fully paid.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Flag indicating whether this receivable is blocked for payment processing due to disputes, compliance holds, or manual review requirements. True when blocked.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivableStatus rdf:type rdf:Property ;
    rdfs:label 'Receivable Status' ;
    rdfs:comment 'Current lifecycle status of the receivable: open for unpaid, partially_paid for partial payment received, fully_paid when settled, written_off for bad debt, disputed for customer disputes, under_collection for legal collection process.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'Flag indicating whether this receivable has been written off as bad debt. True when deemed uncollectible and removed from active receivables.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accrualApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Accrual Approved By User Employee Id' ;
    rdfs:comment 'User ID of the approver who authorized the accrual posting. Null if not yet approved.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Accrual Created By User Employee Id' ;
    rdfs:comment 'User ID of the person who created the accrual record.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Accrual Employee Id' ;
    rdfs:comment 'User ID of the finance team member responsible for creating and managing this accrual entry.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Accrual Last Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified the accrual record.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:internalOrderId rdf:type rdf:Property ;
    rdfs:label 'Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Accruals can be posted against internal orders for project-specific cost recognition. Common in transport shipping for accruing costs on ongoing projects.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:leaseContractId rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Id' ;
    rdfs:comment 'Reference to the lease contract for IFRS 16 lease liability accruals (e.g., warehouse, vehicle, equipment leases).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseContract .

ind:accrualDescription rdf:type rdf:Property ;
    rdfs:label 'Accrual Description' ;
    rdfs:comment 'Free-text description providing business context for the accrual entry, including reason, calculation basis, and supporting details.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualNumber rdf:type rdf:Property ;
    rdfs:label 'Accrual Number' ;
    rdfs:comment 'Business-facing unique document number for the accrual entry, used for audit trails and external references.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle status of the accrual entry: draft (not yet posted), posted (active in GL), reversed (unwound), cancelled, or adjusted (modified after posting).' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualType rdf:type rdf:Property ;
    rdfs:label 'Accrual Type' ;
    rdfs:comment 'Classification of the accrual by business function: freight revenue accrual, carrier cost accrual, customs duty accrual, fuel surcharge accrual, lease accrual per IFRS 16, or warehouse expense accrual.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area for cost-of-sales accounting and functional P&L reporting (e.g., operations, sales, administration).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number linking the accrual to source documents such as AWB, BOL, purchase order, or customs entry.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalPostingDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Posting Date' ;
    rdfs:comment 'Actual date on which the accrual reversal was posted to the general ledger. Null if not yet reversed.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetDepreciationId rdf:type rdf:Property ;
    rdfs:label 'Asset Depreciation Id' ;
    rdfs:comment 'Unique identifier for the asset depreciation posting record.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capexProjectId rdf:type rdf:Property ;
    rdfs:label 'Capex Project Id' ;
    rdfs:comment 'Reference to the CAPEX project that funded the asset acquisition (warehouse expansion, fleet modernization, IT infrastructure upgrade).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexProject .

ind:primaryAssetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Employee Id' ;
    rdfs:comment 'Twelve-character user ID of the system user or batch job that created the depreciation posting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total accumulated depreciation for the asset after this posting, representing cumulative depreciation since acquisition.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetAcquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Asset Acquisition Date' ;
    rdfs:comment 'Original acquisition or capitalization date of the asset being depreciated.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetAcquisitionValue rdf:type rdf:Property ;
    rdfs:label 'Asset Acquisition Value' ;
    rdfs:comment 'Original acquisition or capitalized cost of the asset in the asset\'s local currency.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Eight-digit asset class code categorizing the type of fixed asset (vehicles, buildings, machinery, IT equipment, leasehold improvements).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Depreciation Amount' ;
    rdfs:comment 'Periodic depreciation expense amount posted for this run in the asset\'s local currency.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'Two-digit code identifying the depreciation area (01=book depreciation, 10=tax depreciation, 15=IFRS 16 lease depreciation, 20=group consolidation, 30=cost accounting).' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'Four-character code defining the depreciation calculation method (straight-line, declining balance, units of production, IFRS 16 lease).' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationRunDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Date' ;
    rdfs:comment 'Date when the depreciation calculation batch was executed.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAccountAccumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Gl Account Accumulated Depreciation' ;
    rdfs:comment 'Ten-digit GL account number for posting the accumulated depreciation (credit side of the journal entry, contra-asset account).' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountDepreciationExpense rdf:type rdf:Property ;
    rdfs:label 'Gl Account Depreciation Expense' ;
    rdfs:comment 'Ten-digit GL account number for posting the depreciation expense (debit side of the journal entry).' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseIndicator rdf:type rdf:Property ;
    rdfs:label 'Lease Indicator' ;
    rdfs:comment 'Flag indicating whether this depreciation relates to a leased asset under IFRS 16 (true=leased asset, false=owned asset).' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Net book value of the asset after this depreciation posting (acquisition value minus accumulated depreciation).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current status of the depreciation posting in the general ledger (posted=successfully posted, pending=awaiting approval, reversed=reversed posting, error=posting failed).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this depreciation posting is a reversal of a previous posting (true=reversal, false=original posting).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for reversal if reversal_indicator is true (01=correction, 02=asset transfer, 03=asset retirement, 04=revaluation, 05=period adjustment).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Remaining useful life of the asset in years at the time of this depreciation posting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialControlId rdf:type rdf:Property ;
    rdfs:label 'Financial Control Id' ;
    rdfs:comment 'Unique identifier of the specific internal control that failed or is deficient, referencing the organization\'s control framework documentation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialControl .

ind:previousFindingFinanceAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Finance Audit Finding Id' ;
    rdfs:comment 'Identifier of the previous audit finding if this is a repeat finding, linking to the original occurrence.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceAuditFinding .

ind:primaryFinanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Finance Employee Id' ;
    rdfs:comment 'Identifier of the employee or manager responsible for executing the remediation plan and ensuring the finding is resolved.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryFinanceLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Finance Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the audit finding record.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryFinanceCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Finance Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created the audit finding record in the system.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedProcessArea rdf:type rdf:Property ;
    rdfs:label 'Affected Process Area' ;
    rdfs:comment 'Business process or functional area affected by the audit finding (e.g., Revenue Recognition, Accounts Payable, Freight Billing, Customs Compliance, Payroll Processing, Fixed Asset Management).' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the auditor or audit firm that identified the finding (e.g., internal auditor name or external audit firm name).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorType rdf:type rdf:Property ;
    rdfs:label 'Auditor Type' ;
    rdfs:comment 'Classification of the auditor who identified the finding. Internal auditors are employees; external auditors are independent third-party firms; regulatory auditors are government or industry body representatives.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Name or description of the internal control that is deficient or failed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlObjective rdf:type rdf:Property ;
    rdfs:label 'Control Objective' ;
    rdfs:comment 'The intended purpose or objective of the control that was not achieved, describing what the control was designed to prevent or detect.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Disclosure Required Flag' ;
    rdfs:comment 'Indicates whether the finding must be disclosed in external financial reporting or regulatory filings (e.g., material weakness disclosure in 10-K). True if disclosure required; false otherwise.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Externally-known unique business identifier for the audit finding, typically formatted as audit-type prefix, year, and sequence number (e.g., SOX-2024-00123, INT-2024-00045).' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the audit finding. Open indicates newly identified; in remediation indicates corrective action underway; pending validation indicates awaiting auditor verification; closed indicates resolved and verified; deferred indicates postponed remediation; accepted risk indicates management has formally accepted the risk without remediation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date when the audit finding was first identified and documented by the auditor.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactRating rdf:type rdf:Property ;
    rdfs:label 'Impact Rating' ;
    rdfs:comment 'Assessment of the potential financial or operational impact if the control deficiency is exploited or results in an error.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Assessment of the likelihood that the control deficiency will result in a material misstatement or loss.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Management\'s formal response to the audit finding, including agreement or disagreement with the finding and planned corrective actions.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendation rdf:type rdf:Property ;
    rdfs:label 'Recommendation' ;
    rdfs:comment 'Auditor\'s recommended corrective action or remediation steps to address the finding and strengthen the control environment.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completed Date' ;
    rdfs:comment 'Actual date when remediation activities were completed and the control deficiency was addressed.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which the remediation plan must be completed and the finding resolved.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationOwnerName rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner Name' ;
    rdfs:comment 'Full name of the employee or manager responsible for remediation.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Detailed plan outlining the specific actions, milestones, and resources required to remediate the finding and restore effective control.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this finding is a repeat of a previously identified and supposedly remediated issue. True if repeat; false if new finding.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the audit finding was formally reported to management or audit committee.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Analysis of the underlying root cause(s) of the control deficiency, identifying systemic issues, process gaps, resource constraints, or other factors that led to the finding.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date when the auditor or internal control team validated that the remediation was effective and the finding can be closed.' ;
    rdfs:domain ind:FinanceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Unique identifier for the bank account record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:houseBankId rdf:type rdf:Property ;
    rdfs:label 'House Bank Id' ;
    rdfs:comment 'Internal identifier for the house bank configuration in the ERP system, linking this account to payment processing and cash management workflows.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HouseBank .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this bank account record.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'The legal name of the entity or person who holds the bank account, typically the company legal entity name.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Account Number Masked' ;
    rdfs:comment 'Partially masked account number for display purposes, showing only last 4 digits (e.g., ****1234).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'Detailed description of the specific business purpose or use case for this bank account within Transport Shipping operations.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceAmount rdf:type rdf:Property ;
    rdfs:label 'Balance Amount' ;
    rdfs:comment 'The current available balance in the bank account as of the last reconciliation or statement date, in the account currency.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line 1' ;
    rdfs:comment 'First line of the bank branch physical address.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line 2' ;
    rdfs:comment 'Second line of the bank branch physical address.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'The name of the specific bank branch where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCity rdf:type rdf:Property ;
    rdfs:label 'Bank City' ;
    rdfs:comment 'City where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCode rdf:type rdf:Property ;
    rdfs:label 'Bank Code' ;
    rdfs:comment 'The unique identifier code for the bank, format varies by country (e.g., routing number in US, sort code in UK, bank code in Germany).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'The legal name of the financial institution holding the account.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankPostalCode rdf:type rdf:Property ;
    rdfs:label 'Bank Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the bank branch location.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStateProvince rdf:type rdf:Property ;
    rdfs:label 'Bank State Province' ;
    rdfs:comment 'State or province where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCode rdf:type rdf:Property ;
    rdfs:label 'Branch Code' ;
    rdfs:comment 'The code identifying the specific branch of the bank.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Carrier Payment Flag' ;
    rdfs:comment 'Indicates whether this account is designated for making payments to freight carriers and transportation providers.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashPoolGroup rdf:type rdf:Property ;
    rdfs:label 'Cash Pool Group' ;
    rdfs:comment 'Identifier for the cash pooling arrangement this account belongs to, used for centralized treasury and liquidity management across multiple accounts or entities.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionMethodEnabled rdf:type rdf:Property ;
    rdfs:label 'Collection Method Enabled' ;
    rdfs:comment 'Primary collection method supported by this bank account for incoming payments (wire, ACH, SEPA, lockbox, EFT, direct debit).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCollectionFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Collection Flag' ;
    rdfs:comment 'Indicates whether this account is designated for receiving customer payments and collections.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'The internationally standardized bank account number used for cross-border payments, particularly in Europe and other SEPA regions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransferFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transfer Flag' ;
    rdfs:comment 'Indicates whether this account is used for intercompany fund transfers between Transport Shipping legal entities.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percentage' ;
    rdfs:comment 'The annual interest rate applied to the account balance, expressed as a decimal percentage (e.g., 0.0250 for 2.5%).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date of the most recent bank reconciliation performed for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Amount' ;
    rdfs:comment 'The minimum balance required to be maintained in the account per bank agreement or internal treasury policy.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit Amount' ;
    rdfs:comment 'The maximum overdraft or credit facility limit available on this account, if applicable.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodEnabled rdf:type rdf:Property ;
    rdfs:label 'Payment Method Enabled' ;
    rdfs:comment 'Primary payment method supported by this bank account for outgoing payments (wire transfer, ACH, SEPA, check, EFT, RTGS).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Required Flag' ;
    rdfs:comment 'Indicates whether this account requires regular bank reconciliation processes to match bank statements with internal records.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swiftBicCode rdf:type rdf:Property ;
    rdfs:label 'Swift Bic Code' ;
    rdfs:comment 'The unique identification code for the bank used in international wire transfers and SWIFT messaging. Format: 8 or 11 alphanumeric characters.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this bank account record became active and valid for use in operations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this bank account record is valid. Null indicates the account is currently active with no planned end date.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankStatementId rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Id' ;
    rdfs:comment 'Reference to the parent bank statement header containing this line item. Links to the overall statement document received from the bank.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankStatement .

ind:primaryBankEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Bank Employee Id' ;
    rdfs:comment 'User ID of the person or system process that created the record. Required for SOX compliance and audit trail.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bankTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Bank Transaction Code' ;
    rdfs:comment 'Bank-specific code identifying the type of transaction (e.g., wire transfer, check, direct debit, card payment). Used for automated transaction classification.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Account Number' ;
    rdfs:comment 'Bank account number of the counterparty. Used for payment verification and fraud detection. Business-confidential financial information.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyBankCode rdf:type rdf:Property ;
    rdfs:label 'Counterparty Bank Code' ;
    rdfs:comment 'Bank identifier code (BIC/SWIFT) for the counterparty\'s financial institution. Used for international payment tracking and reconciliation.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Name of the external party involved in the transaction (customer, vendor, or other entity). Used for matching against Accounts Payable (AP) and Accounts Receivable (AR) records.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerReference rdf:type rdf:Property ;
    rdfs:label 'Customer Reference' ;
    rdfs:comment 'Customer account number or identifier extracted from payment reference. Used for matching receipts to customer accounts in AR.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the transaction is a debit (outflow) or credit (inflow) to the bank account. Essential for cash flow analysis and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Code identifying the reason for reconciliation exception or manual review. Enables root cause analysis of reconciliation issues.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference Number' ;
    rdfs:comment 'Invoice number extracted from payment reference or remittance advice. Used for automated AR/AP reconciliation and clearing.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line number within the bank statement. Used for ordering and referencing individual transactions within the statement.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manualReconciliationFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Reconciliation Flag' ;
    rdfs:comment 'Indicates whether the transaction required manual intervention for reconciliation. Used for process improvement and automation gap analysis.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statementText rdf:type rdf:Property ;
    rdfs:label 'Statement Text' ;
    rdfs:comment 'Descriptive text provided by the bank on the statement line. Contains additional transaction details for manual review and reconciliation.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Monetary amount of the bank transaction in the statement currency. Represents the actual cash movement recorded by the bank.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the transaction amount. Identifies the currency in which the bank recorded the transaction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'Date when the transaction was executed by the bank. This is the actual processing date recorded by the financial institution.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Business classification of the transaction type. Standardized categorization for reporting and reconciliation purposes. [ENUM-REF-CANDIDATE: payment|receipt|transfer|fee|interest|adjustment|reversal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorReference rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference' ;
    rdfs:comment 'Vendor account number or identifier extracted from payment reference. Used for matching payments to vendor accounts in AP.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Budget Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user or executive who approved this budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Budget Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this budget record. Audit trail field.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Budget Employee Id' ;
    rdfs:comment 'Reference to the employee or manager responsible for this budget. The budget holder has authority to approve expenditures against this budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Budget Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this budget record. Audit trail field.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:availableAmount rdf:type rdf:Property ;
    rdfs:label 'Available Amount' ;
    rdfs:comment 'The remaining budget available for allocation or spending. Calculated as approved_amount minus allocated_amount minus consumed_amount.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level categorization of the budget by functional area or spend category. [ENUM-REF-CANDIDATE: personnel|fleet|facility|technology|marketing|operations|administrative — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Externally-known unique business identifier for the budget. Used for cross-system reference and reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget record indicating approval and activation state.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of budget as Capital Expenditure (CAPEX) for fleet/facility investments or Operating Expenditure (OPEX) for operational costs.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumedAmount rdf:type rdf:Property ;
    rdfs:label 'Consumed Amount' ;
    rdfs:comment 'The actual expenditure or consumption against this budget to date. Used for variance analysis and budget control.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlMethod rdf:type rdf:Property ;
    rdfs:label 'Control Method' ;
    rdfs:comment 'The enforcement method for budget overruns: advisory (no restriction), warning (alert but allow), or blocking (prevent overspend).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Impact Flag' ;
    rdfs:comment 'Indicates whether this budget line impacts EBITDA calculation for financial reporting and performance measurement.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Indicates whether this budget is locked for changes. Locked budgets cannot be modified without special authorization.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningScenario rdf:type rdf:Property ;
    rdfs:label 'Planning Scenario' ;
    rdfs:comment 'The planning scenario or assumption set used for this budget (e.g., base case, optimistic growth, pessimistic downturn).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage' ;
    rdfs:comment 'The allowable percentage variance from the approved budget before control actions are triggered. Expressed as a percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique identifier for the budget line item. Primary key for the budget line product.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentItemId rdf:type rdf:Property ;
    rdfs:label 'Commitment Item Id' ;
    rdfs:comment 'Reference to the commitment item or budget category used in public sector or fund-based budgeting, enabling compliance with governmental accounting standards.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommitmentItem .

ind:costElementId rdf:type rdf:Property ;
    rdfs:label 'Cost Element Id' ;
    rdfs:comment 'Reference to the cost element (primary or secondary) that classifies the nature of the expense or revenue for this budget line.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostElement .

ind:fundId rdf:type rdf:Property ;
    rdfs:label 'Fund Id' ;
    rdfs:comment 'Reference to the fund or financial source from which this budget line is financed, enabling fund-based budget management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fund .

ind:primaryBudgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Employee Id' ;
    rdfs:comment 'Reference to the employee or manager responsible for managing and controlling this budget line, enabling accountability and budget ownership.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Reference to the project or capital investment program to which this budget line is allocated, enabling project-based CAPEX tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:quaternaryBudgetLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Budget Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this budget line record, enabling accountability and audit trail.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryBudgetCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Budget Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this budget line record, enabling accountability and audit trail.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Reference to the WBS element within a project hierarchy, enabling granular tracking of budget allocations for complex capital projects.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The allocated budget amount for this line item in the specified period and currency, representing the planned expenditure or revenue target.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'The geographic region or market to which this budget line applies, enabling regional budget analysis and variance tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The budget amount converted to the group reporting currency, enabling enterprise-wide consolidation and EBITDA tracking.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential ordering number of this line item within the parent budget, enabling consistent display and drill-down analysis.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'The budgeted price per unit of measure, enabling calculation of total budget amount from quantity and unit price.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountClass rdf:type rdf:Property ;
    rdfs:label 'Account Class' ;
    rdfs:comment 'Functional classification indicating the operational role of the account: primary (standard posting), reconciliation (clearing and control), statistical (non-value tracking), or intercompany (inter-entity transactions).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Hierarchical grouping code that clusters related GL accounts together for reporting and analysis purposes. Used to aggregate accounts into meaningful financial statement line items.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortName rdf:type rdf:Property ;
    rdfs:label 'Account Short Name' ;
    rdfs:comment 'Abbreviated name or label for the GL account used in condensed reports and user interfaces where space is limited.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required Flag' ;
    rdfs:comment 'Indicates whether a complete audit trail of all changes and postings must be maintained for this account. Essential for regulatory compliance and forensic accounting requirements.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'Classification of balance sheet accounts into current (short-term) or non-current (long-term) categories for assets and liabilities, or equity. Not applicable for P&L accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetControlFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Flag' ;
    rdfs:comment 'Indicates whether budget availability checking is enforced for this account. When true, postings are validated against approved budget allocations before commitment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashFlowClassification rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Classification' ;
    rdfs:comment 'Classification of the account for cash flow statement reporting: operating activities, investing activities, financing activities, or not applicable for non-cash accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account' ;
    rdfs:comment 'The corresponding account code in the group consolidation chart of accounts. Maps local entity accounts to standardized group reporting accounts for consolidated financial statements.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Control Account Flag' ;
    rdfs:comment 'Indicates whether this account serves as a control or summary account that aggregates balances from detail accounts. Control accounts typically do not allow direct postings.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Element Flag' ;
    rdfs:comment 'Indicates whether this GL account is also defined as a cost element in the controlling module, enabling cost center and internal order postings for management accounting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Defines the currency management approach for this account: local (company code currency only), group (consolidated reporting currency), transaction (foreign currency allowed), or multiple (multi-currency management).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'Configuration key that controls which fields are required, optional, or suppressed when posting to this account. Enforces data quality and compliance requirements at the transaction level.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Item' ;
    rdfs:comment 'The specific line item on the financial statement (balance sheet, income statement, cash flow statement) where this account\'s balance is reported. Maps GL accounts to external reporting presentation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Classification of the account by business function or operational area (e.g., sales, operations, administration, logistics) for segment reporting and functional cost analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapClassification rdf:type rdf:Property ;
    rdfs:label 'Gaap Classification' ;
    rdfs:comment 'GAAP classification code or category for this account, supporting dual reporting requirements where both IFRS and local GAAP reporting are required.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsClassification rdf:type rdf:Property ;
    rdfs:label 'Ifrs Classification' ;
    rdfs:comment 'Detailed IFRS classification code or category for this account, ensuring compliance with international financial reporting standards and enabling IFRS-compliant financial statement generation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Indicates whether this account is used for intercompany transactions and the direction: none (not intercompany), payable (amounts owed to related entities), receivable (amounts due from related entities), or both.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Flag' ;
    rdfs:comment 'Indicates whether individual line item details (journal entries) are stored and displayable for this account. Essential for accounts requiring detailed transaction audit trails.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Flag' ;
    rdfs:comment 'Indicates whether this account uses open item management for tracking and clearing individual transactions (e.g., invoices, payments). Critical for accounts receivable, accounts payable, and clearing accounts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'Defines the granularity at which budget planning and forecasting is performed for this account (e.g., annual, quarterly, monthly). Supports CAPEX and OPEX budgeting processes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Boolean indicator specifying whether direct journal entry postings are permitted to this account. False indicates a control or summary account that only receives automatic postings.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossClassification rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Classification' ;
    rdfs:comment 'Detailed classification of revenue and expense accounts within the income statement structure, including operating revenue, cost of goods sold, operating expenses, and non-operating items.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this is a reconciliation account that serves as a control account for subsidiary ledgers (e.g., accounts receivable, accounts payable, inventory). Reconciliation accounts are automatically updated from sub-ledger transactions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retainedEarningsAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account Flag' ;
    rdfs:comment 'Indicates whether this is the designated retained earnings account that receives the net profit or loss transfer during year-end closing processes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Default sort key used for organizing and displaying line items within this account (e.g., by posting date, document number, reference). Enhances usability in transaction review and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Relevant Flag' ;
    rdfs:comment 'Indicates whether postings to this account are subject to tax calculation and reporting. Used to identify accounts that require tax code assignment during transaction entry.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'Configuration key defining posting and clearing tolerances for this account, including maximum amounts, payment differences, and exchange rate variances permitted during transaction processing.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaId rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Id' ;
    rdfs:comment 'Identifier of the controlling area to which this company code is assigned. The controlling area is the organizational unit for cost accounting, profit center accounting, and internal management reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControllingArea .

ind:creditControlAreaId rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area Id' ;
    rdfs:comment 'Identifier of the credit control area responsible for managing customer credit limits and credit risk for this company code.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditControlArea .

ind:parentCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Parent Company Code Id' ;
    rdfs:comment 'Reference to the parent company code in the corporate hierarchy. Used for consolidation and intercompany eliminations in group financial reporting. Null if this is a top-level entity.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:primaryCompanyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Company Employee Id' ;
    rdfs:comment 'User ID of the system user who created this company code record. Part of audit trail for accountability and compliance.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:companyCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Company Code Status' ;
    rdfs:comment 'Current operational status of the company code within the enterprise financial system. Active company codes can post transactions; inactive codes are closed for new postings.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyNameShort rdf:type rdf:Property ;
    rdfs:label 'Company Name Short' ;
    rdfs:comment 'Abbreviated or short name of the company for internal reporting and display purposes.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Code identifying the consolidation group or reporting entity to which this company code belongs for group financial statement preparation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary contact email address for financial and legal correspondence related to this company code. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Two-character code defining the fiscal year structure for this company code (e.g., calendar year, April-March, custom periods). Determines posting periods and financial reporting cycles.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this company code prepares financial statements in accordance with IFRS. True if IFRS applies; False if local GAAP or other standards apply.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyBillingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Billing Enabled Flag' ;
    rdfs:comment 'Boolean flag indicating whether intercompany billing and settlements are enabled for this company code. True if intercompany transactions are processed; False otherwise.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityType rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Type' ;
    rdfs:comment 'Classification of the legal structure of the company code (e.g., corporation, LLC, partnership, branch, subsidiary). Determines tax treatment and regulatory obligations.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the company code headquarters or registered office. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Block Flag' ;
    rdfs:comment 'Boolean flag indicating whether new financial postings are blocked for this company code. True if posting is blocked (e.g., during period-end close or audit); False if posting is allowed.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the individual responsible for financial management and reporting for this company code. Personal contact information classified as restricted PII.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the individual responsible for financial management and reporting for this company code (e.g., Chief Financial Officer, Finance Director). Business reference, not direct PII.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for the cost allocation record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:originalAllocationCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Cost Allocation Id' ;
    rdfs:comment 'Foreign key to the original cost allocation record if this is a reversal. Null for original postings.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:primaryCostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Employee Id' ;
    rdfs:comment 'User ID of the person or system account that created or executed the allocation cycle.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySenderCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Sender Cost Center Id' ;
    rdfs:comment 'Foreign key to the cost center from which costs are being allocated (the source of the shared cost).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:receiverProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Receiver Profit Center Id' ;
    rdfs:comment 'Foreign key to the profit center receiving the allocated cost. Null if receiver is a cost center. Used for P&L reporting by service line.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:tertiaryCostLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Cost Last Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person or system account that last modified this allocation record.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationBasisQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Quantity' ;
    rdfs:comment 'The quantity of the allocation basis used for this receiver (e.g., 5.0 FTE, 1200 TEU, 850.5 CBM). Used to calculate proportional share.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasisType rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Type' ;
    rdfs:comment 'The basis or driver used to allocate costs: FTE (Full-Time Equivalent) headcount, shipment volume, TEU (Twenty-foot Equivalent Unit), CBM (Cubic Meter), revenue, square footage, or fixed percentage. [ENUM-REF-CANDIDATE: fte_headcount|shipment_volume|teu|cbm|revenue|square_footage|fixed_percentage — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationBasisUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Unit' ;
    rdfs:comment 'Unit of measure for the allocation basis quantity (e.g., FTE, TEU, CBM, USD, SQM).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of total sender cost allocated to this receiver, calculated based on allocation basis. Sum of all receivers in a cycle should equal 100%.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationReferenceText rdf:type rdf:Property ;
    rdfs:label 'Allocation Reference Text' ;
    rdfs:comment 'Free-text reference or description providing additional context for the allocation (e.g., \'Q1 IT shared services allocation\', \'Warehouse rent distribution\').' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRuleCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Code' ;
    rdfs:comment 'Code identifying the allocation rule or assessment method applied (e.g., distribution key, statistical key figure, activity type). Defines how costs are distributed.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Timestamp' ;
    rdfs:comment 'Timestamp when the allocation cycle was executed and this record was created. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'Controlling area in which the allocation is executed. Organizational unit for cost accounting in SAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Identifier of the parent cost center in the cost center hierarchy. Enables roll-up reporting and hierarchical cost aggregation. Null for top-level cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The primary activity type performed by this cost center for activity-based costing. Examples include machine hours, labor hours, shipment volume, or handling units. Used for internal cost allocation and activity driver analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'The total approved budget amount for this cost center for the current fiscal year, expressed in the cost center\'s currency. Used for budget vs actual variance analysis and cost control.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetPeriod rdf:type rdf:Property ;
    rdfs:label 'Budget Period' ;
    rdfs:comment 'The budgeting cycle period for this cost center. Annual indicates yearly budget planning. Quarterly indicates budget set every quarter. Monthly indicates monthly budget allocation. Determines the frequency of budget vs actual variance reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'The version identifier of the current budget plan. Enables tracking of budget revisions, forecasts, and what-if scenarios. Examples include original budget, revised budget, forecast.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used to allocate costs from this cost center to other cost objects or profit centers. Direct indicates costs are directly assigned. Activity-based uses activity drivers. Proportional uses percentage splits. Driver-based uses volume or usage metrics. Fixed percentage uses predetermined allocation keys.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Functional category of the cost center for management reporting and cost allocation. Production includes operational hubs and sorting centers. Service includes customer support and claims processing. Administrative includes back-office functions. Sales includes business development and account management. Distribution includes warehouses and last-mile delivery. Research and development includes innovation and process improvement. Quality assurance includes compliance and audit. Maintenance includes fleet and facility upkeep. [ENUM-REF-CANDIDATE: production|service|administrative|sales|distribution|research_development|quality_assurance|maintenance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed textual description of the cost center\'s purpose, scope, and responsibilities. Provides additional context beyond the cost center name for reporting and documentation purposes.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group' ;
    rdfs:comment 'Grouping classification for aggregating cost centers in management reports. Examples include regional groupings, functional groupings, or business line groupings.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full descriptive name of the cost center, identifying the organizational unit or function to which costs are assigned.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active indicates the cost center is operational and accepting cost postings. Inactive indicates temporary suspension. Blocked prevents new postings. Pending closure indicates scheduled deactivation. Closed indicates the cost center is no longer in use and historical only.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by its primary business function. Logistics operations include hubs and sorting facilities, warehouse includes distribution centers, fleet includes vehicle operations, corporate includes headquarters functions, sales includes customer-facing units, administration includes back-office support, support includes IT and HR, revenue-generating includes units with direct revenue attribution, cost-absorbing includes pure cost units. [ENUM-REF-CANDIDATE: logistics_operations|warehouse|fleet|corporate|sales|administration|support|revenue_generating|cost_absorbing — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'The primary cost element group associated with this cost center, defining the types of costs that can be posted. Examples include personnel costs, material costs, services, depreciation, or external services.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The department code to which this cost center belongs within the organizational structure. Used for departmental reporting and organizational hierarchy navigation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'The division code representing the highest-level organizational unit to which this cost center belongs. Used for divisional P&L reporting and strategic business unit analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteCount rdf:type rdf:Property ;
    rdfs:label 'Fte Count' ;
    rdfs:comment 'The number of full-time equivalent employees assigned to this cost center. Used for productivity analysis, cost per FTE calculations, and workforce planning. Decimal values accommodate part-time and fractional allocations.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOverhead rdf:type rdf:Property ;
    rdfs:label 'Is Overhead' ;
    rdfs:comment 'Boolean flag indicating whether this cost center represents overhead costs that must be allocated to other cost objects. True for administrative, support, and shared service cost centers. False for direct operational cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Boolean flag indicating whether this cost center directly generates revenue. True for cost centers with direct customer billing or revenue attribution. False for pure cost centers. Used for profitability analysis and contribution margin reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'The physical location or site code where this cost center operates. Used for geographic cost analysis and facility-based reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Group' ;
    rdfs:comment 'The planning group to which this cost center belongs for budget planning and forecasting processes. Enables collaborative planning across related cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Regional classification code for the cost center, used for regional management reporting and performance analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyRateId rdf:type rdf:Property ;
    rdfs:label 'Currency Rate Id' ;
    rdfs:comment 'Unique identifier for the currency exchange rate record. Primary key.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCurrencyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Currency Employee Id' ;
    rdfs:comment 'Reference to the user who approved this exchange rate for use. Null if approval is not required or rate is pending approval. Supports SOX compliance and audit trail requirements.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCurrencyLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Currency Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this exchange rate record. For automated updates, this may reference a system service account. Supports audit trail and change tracking.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:effectiveRateWithSpread rdf:type rdf:Property ;
    rdfs:label 'Effective Rate With Spread' ;
    rdfs:comment 'The final exchange rate after applying the rate_spread_percentage to the base rate_value. This is the rate used for customer billing and revenue recognition when spreads are applied. Null if no spread is applicable.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Classification of the exchange rate indicating its purpose and calculation method. Spot rates are real-time market rates, average rates are period averages, closing rates are end-of-period rates, budget rates are planning rates, forecast rates are projected rates, and historical rates are archived past rates.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'From Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the base currency in the exchange rate pair (e.g., USD, EUR, GBP). The currency being converted from.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgeContractReference rdf:type rdf:Property ;
    rdfs:label 'Hedge Contract Reference' ;
    rdfs:comment 'External reference number or identifier of the foreign exchange hedging contract or forward contract from which this rate is derived. Null if hedging_rate_flag is false. Supports hedge accounting and IFRS 9 compliance.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgingRateFlag rdf:type rdf:Property ;
    rdfs:label 'Hedging Rate Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this exchange rate is derived from a foreign exchange hedging contract or forward contract. True indicates hedged rate, false indicates spot or market rate.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyRateFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Rate Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this exchange rate is used for intercompany settlements and transfer pricing between Transport Shipping legal entities. True indicates intercompany use, false indicates external customer/vendor use.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inverseRateValue rdf:type rdf:Property ;
    rdfs:label 'Inverse Rate Value' ;
    rdfs:comment 'The reciprocal exchange rate value (1 / rate_value) representing the reverse currency pair conversion. If USD to EUR is 0.85, the inverse EUR to USD is 1.176471. Stored for performance optimization in bidirectional conversions.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateDeterminationMethod rdf:type rdf:Property ;
    rdfs:label 'Rate Determination Method' ;
    rdfs:comment 'The method by which the exchange rate was determined. Market rates are from external sources, fixed rates are contractually agreed, negotiated rates are customer-specific, and regulatory rates are mandated by government authorities.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'The authoritative source from which the exchange rate was obtained. ECB (European Central Bank), Reuters, Bloomberg, OANDA, and XE are external market data providers. Manual indicates rates entered by finance staff. System indicates rates calculated or derived by internal systems. [ENUM-REF-CANDIDATE: ECB|Reuters|Bloomberg|OANDA|XE|Manual|System — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSourceReference rdf:type rdf:Property ;
    rdfs:label 'Rate Source Reference' ;
    rdfs:comment 'External reference identifier or transaction ID from the rate source system, enabling traceability and audit of the rate origin. May contain feed IDs, API transaction references, or manual entry batch numbers.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSpreadPercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Spread Percentage' ;
    rdfs:comment 'The percentage markup or spread applied to the base market rate for internal pricing or margin calculation. Used when Transport Shipping applies a margin to customer-facing currency conversions. Null indicates no spread applied.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the exchange rate record. Active rates are in use, inactive rates are disabled, superseded rates have been replaced by newer rates, pending rates await approval, and expired rates are past their valid_to_date.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUpdateFrequency rdf:type rdf:Property ;
    rdfs:label 'Rate Update Frequency' ;
    rdfs:comment 'The frequency at which this exchange rate type is refreshed or updated from the rate source. Real-time rates update continuously, daily rates update once per business day, and on-demand rates are manually triggered. [ENUM-REF-CANDIDATE: real-time|daily|weekly|monthly|quarterly|annual|on-demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'The numerical exchange rate value representing how many units of the to_currency are equivalent to one unit of the from_currency. For example, if USD to EUR rate is 0.85, then 1 USD = 0.85 EUR. Precision of 6 decimal places supports accurate currency conversion.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateVolatilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Rate Volatility Indicator' ;
    rdfs:comment 'Classification of the currency pairs historical volatility level. Low volatility indicates stable currency pairs (e.g., USD/EUR), high volatility indicates emerging market or commodity-linked currencies. Used for risk management and hedging decisions.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'To Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the quote currency in the exchange rate pair (e.g., USD, EUR, GBP). The currency being converted to.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryFinancialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Financial Employee Id' ;
    rdfs:comment 'Reference to the employee or role responsible for the design, implementation, and ongoing effectiveness of this control.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationSystemName rdf:type rdf:Property ;
    rdfs:label 'Application System Name' ;
    rdfs:comment 'Name of the IT application or ERP module where the automated control is configured and executed (e.g., SAP S/4HANA Finance, Oracle Financials).' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensatingControlFlag rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Flag' ;
    rdfs:comment 'Indicates whether this control serves as a compensating control to mitigate risk when a primary control cannot be implemented or has failed.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlCategory rdf:type rdf:Property ;
    rdfs:label 'Control Category' ;
    rdfs:comment 'Hierarchical classification of the control: entity-level (company-wide governance), transaction-level (specific process controls), IT general controls, or IT application controls.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlCode rdf:type rdf:Property ;
    rdfs:label 'Control Code' ;
    rdfs:comment 'Unique business identifier code for the financial control following organizational control numbering convention (e.g., FIN-001, REV-1234).' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Control Deficiency Count' ;
    rdfs:comment 'Number of deficiencies or exceptions identified during the most recent testing period, used to track control performance trends.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Detailed narrative description of the control activity, including what is performed, how it is performed, and what evidence is generated.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEvidenceType rdf:type rdf:Property ;
    rdfs:label 'Control Evidence Type' ;
    rdfs:comment 'Type of evidence generated or retained to demonstrate control execution, such as system reports, approval signatures, reconciliation documents, or audit logs.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrequency rdf:type rdf:Property ;
    rdfs:label 'Control Frequency' ;
    rdfs:comment 'How often the control is executed or performed, ranging from continuous monitoring to periodic execution aligned with business cycles. [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|annually|event-driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNature rdf:type rdf:Property ;
    rdfs:label 'Control Nature' ;
    rdfs:comment 'Indicates whether the control is executed automatically by system (automated), performed by personnel (manual), or a combination of both (hybrid).' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPerformerRole rdf:type rdf:Property ;
    rdfs:label 'Control Performer Role' ;
    rdfs:comment 'The job role or position responsible for executing the control activity (may differ from control owner).' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlProcedure rdf:type rdf:Property ;
    rdfs:label 'Control Procedure' ;
    rdfs:comment 'Step-by-step procedure or work instruction for executing the control, including system transactions, approval workflows, and documentation requirements.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlReviewerRole rdf:type rdf:Property ;
    rdfs:label 'Control Reviewer Role' ;
    rdfs:comment 'The job role or position responsible for reviewing and approving the control execution results, ensuring segregation of duties.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of the control indicating whether it is actively enforced, temporarily suspended, under review for changes, or retired from use.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the control based on its nature: preventive (stops errors before they occur), detective (identifies errors after occurrence), corrective (fixes identified errors), or directive (guides behavior).' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Design Effectiveness Rating' ;
    rdfs:comment 'Assessment of whether the control is properly designed to address the identified risk and achieve the control objective if executed as designed.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsControlFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs Control Flag' ;
    rdfs:comment 'Indicates whether this control is specifically designed to ensure compliance with IFRS accounting standards and disclosure requirements.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyControlFlag rdf:type rdf:Property ;
    rdfs:label 'Key Control Flag' ;
    rdfs:comment 'Indicates whether this control is designated as a key control that directly addresses a significant risk to financial reporting accuracy.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'The most recent date when the control was formally tested for design and operating effectiveness by internal audit or external auditors.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTestResult rdf:type rdf:Property ;
    rdfs:label 'Last Test Result' ;
    rdfs:comment 'Outcome of the most recent control testing, indicating whether the control passed without exceptions, passed with minor exceptions, or failed to operate effectively.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'Scheduled date for the next control testing cycle based on control frequency, risk rating, and audit plan requirements.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Operating Effectiveness Rating' ;
    rdfs:comment 'Assessment of how effectively the control is operating based on testing results, indicating whether it is achieving its control objective consistently.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The specific financial process or sub-process that this control governs, such as revenue recognition, accounts payable, accounts receivable, fixed assets, financial close, payroll, or treasury operations.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationOfDutiesFlag rdf:type rdf:Property ;
    rdfs:label 'Segregation Of Duties Flag' ;
    rdfs:comment 'Indicates whether this control enforces segregation of duties principles by ensuring incompatible functions are performed by different individuals.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'System Generated Flag' ;
    rdfs:comment 'Indicates whether the control is automatically executed and enforced by the ERP or financial system without manual intervention.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'How often the control must be formally tested for effectiveness by internal audit or compliance teams, driven by risk rating and regulatory requirements.' ;
    rdfs:domain ind:FinancialControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPeriodCloseId rdf:type rdf:Property ;
    rdfs:label 'Financial Period Close Id' ;
    rdfs:comment 'Unique identifier for the financial period close record.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockingIssue rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue' ;
    rdfs:comment 'Description of any issue or exception that is preventing the close task from being completed on schedule. Null if no blocking issues exist.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingIssueSeverity rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue Severity' ;
    rdfs:comment 'The severity level of the blocking issue: low (minor delay expected), medium (moderate impact), high (significant delay), or critical (close cannot proceed).' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Certification Timestamp' ;
    rdfs:comment 'The date and time when the financial period close was certified and approved by authorized finance leadership.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Completion Timestamp' ;
    rdfs:comment 'The date and time when the financial period close process was marked as completed. Null if not yet completed.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Start Timestamp' ;
    rdfs:comment 'The date and time when the financial period close process was initiated.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Current status of the financial period close process: not started, in progress, blocked (awaiting resolution), completed (all tasks done), or certified (approved by finance leadership).' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeTaskType rdf:type rdf:Property ;
    rdfs:label 'Close Task Type' ;
    rdfs:comment 'The specific type of close task being tracked: accruals posting, depreciation run, intercompany reconciliation, foreign currency revaluation, tax provision calculation, or inventory valuation adjustment.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeType rdf:type rdf:Property ;
    rdfs:label 'Close Type' ;
    rdfs:comment 'The type of financial close being performed: month-end, quarter-end, year-end, or special close for ad-hoc reporting requirements.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Required Flag' ;
    rdfs:comment 'Indicates whether this close requires consolidation of financial data across multiple legal entities or business units (True) or is a standalone entity close (False).' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ebitdaReportingSegment rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reporting Segment' ;
    rdfs:comment 'The business segment or service line for which EBITDA is being calculated and reported as part of this close.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether intercompany transactions and balances need to be eliminated as part of this close (True) or not (False).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lock Timestamp' ;
    rdfs:comment 'The date and time when the financial period was locked to prevent further postings. Null if period is not locked.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Planned Close Date' ;
    rdfs:comment 'The target date by which the financial period close process is scheduled to be completed.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'The name or identifier of the finance team responsible for executing this close task (e.g., General Accounting, Cost Accounting, Tax, Treasury).' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which variances between planned and actual close results must be investigated and documented.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'The percentage threshold above which variances between planned and actual close results must be investigated and documented.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialStatementId rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Id' ;
    rdfs:comment 'Unique identifier for the financial statement record. Primary key for the financial statement entity.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorStatementFinancialStatementId rdf:type rdf:Property ;
    rdfs:label 'Prior Statement Financial Statement Id' ;
    rdfs:comment 'Reference to the previous version of this financial statement if this is a restatement or superseding version. Links to the financial_statement_id of the superseded statement.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialStatement .

ind:quaternaryFinancialCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Financial Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this financial statement record in the system. Audit trail field for SOX compliance.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryFinancialLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Financial Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this financial statement record. Audit trail field for SOX compliance.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryFinancialReviewedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Financial Reviewed By User Employee Id' ;
    rdfs:comment 'Reference to the user or manager who reviewed this financial statement before approval.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditOpinionDate rdf:type rdf:Property ;
    rdfs:label 'Audit Opinion Date' ;
    rdfs:comment 'Date on which the external auditor issued their audit opinion on this financial statement. Represents the auditor sign-off date.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Reference number or document identifier for the external auditor\'s audit report corresponding to this financial statement.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comparativePeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Comparative Period Flag' ;
    rdfs:comment 'Indicates whether this financial statement includes comparative figures from prior periods as required by IFRS IAS 1.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationScope rdf:type rdf:Property ;
    rdfs:label 'Consolidation Scope' ;
    rdfs:comment 'Scope of consolidation for this financial statement. Legal entity represents a single company code; consolidated group represents parent and all subsidiaries; business unit or segment represents a sub-group for management reporting.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the published financial statement document (PDF, XBRL, or other format) stored in the document management system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorName rdf:type rdf:Property ;
    rdfs:label 'External Auditor Name' ;
    rdfs:comment 'Name of the external audit firm that audited this financial statement (e.g., Deloitte, PwC, EY, KPMG). Required for audited statements under SOX and IFRS.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notesReference rdf:type rdf:Property ;
    rdfs:label 'Notes Reference' ;
    rdfs:comment 'Reference or link to the accompanying notes to financial statements that provide detailed disclosures and explanations.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Presentation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for presentation purposes if different from the functional currency. Used when statements are translated for group consolidation.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date on which this financial statement was officially published or released to external stakeholders, regulators, or the public.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Flag' ;
    rdfs:comment 'Indicates whether this financial statement is filed with regulatory authorities (e.g., SEC, local securities commissions, tax authorities).' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the financial reporting period covered by this statement. Defines the close of the period for which financial performance or position is reported.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the financial reporting period covered by this statement. Defines the beginning of the period for which financial performance or position is reported.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingStandard rdf:type rdf:Property ;
    rdfs:label 'Reporting Standard' ;
    rdfs:comment 'Accounting standard framework under which this financial statement is prepared. IFRS (International Financial Reporting Standards) is the global standard; US GAAP applies to US entities; local GAAP and statutory standards apply per jurisdiction.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restatementFlag rdf:type rdf:Property ;
    rdfs:label 'Restatement Flag' ;
    rdfs:comment 'Indicates whether this financial statement is a restatement of a previously published statement due to error correction or accounting policy change.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restatementReason rdf:type rdf:Property ;
    rdfs:label 'Restatement Reason' ;
    rdfs:comment 'Explanation of the reason for restatement if restatement_flag is true. Describes the nature of the error or accounting policy change that necessitated the restatement.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Flag' ;
    rdfs:comment 'Indicates whether this financial statement includes segment reporting disclosures as required by IFRS 8 for operating segments.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the financial statement, used for reference in audit trails, regulatory filings, and external communications.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the financial statement. Draft indicates work in progress; preliminary indicates management review; final indicates approved for publication; published indicates externally released; restated indicates corrected after initial publication; superseded indicates replaced by a newer version.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementType rdf:type rdf:Property ;
    rdfs:label 'Statement Type' ;
    rdfs:comment 'Type of financial statement being published. Income statement (Profit and Loss / P&L) shows revenue and expenses; balance sheet shows assets, liabilities, and equity; cash flow statement shows cash inflows and outflows; statement of changes in equity shows movements in equity accounts; notes provide supplementary disclosures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xbrlInstanceDocument rdf:type rdf:Property ;
    rdfs:label 'Xbrl Instance Document' ;
    rdfs:comment 'Reference to the XBRL instance document for this financial statement, used for structured regulatory filings.' ;
    rdfs:domain ind:FinancialStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFiscalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fiscal Employee Id' ;
    rdfs:comment 'Reference to the user responsible for executing the period-end close for this fiscal period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryFiscalLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Fiscal Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this fiscal period record.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:apPostingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Ap Posting Allowed Flag' ;
    rdfs:comment 'Flag indicating whether Accounts Payable postings are allowed in this period (true) or blocked (false).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arPostingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Ar Posting Allowed Flag' ;
    rdfs:comment 'Flag indicating whether Accounts Receivable postings are allowed in this period (true) or blocked (false).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetPostingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Asset Posting Allowed Flag' ;
    rdfs:comment 'Flag indicating whether Fixed Asset postings are allowed in this period (true) or blocked (false).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The calendar month number (1-12) corresponding to this fiscal period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year in which the period falls, used for cross-referencing when fiscal year differs from calendar year.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Period Flag' ;
    rdfs:comment 'Flag indicating whether this period is used for group consolidation reporting (true) or not (false).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenterPostingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Posting Allowed Flag' ;
    rdfs:comment 'Flag indicating whether Cost Center postings are allowed in this period (true) or blocked (false).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Number' ;
    rdfs:comment 'The sequential period number within the fiscal year (e.g., 1 for January, 12 for December, 13+ for special periods).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glPostingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Allowed Flag' ;
    rdfs:comment 'Flag indicating whether General Ledger postings are allowed in this period (true) or blocked (false).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:halfYear rdf:type rdf:Property ;
    rdfs:label 'Half Year' ;
    rdfs:comment 'The fiscal half-year number (1 or 2) to which this period belongs within the fiscal year.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ifrsReportingPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs Reporting Period Flag' ;
    rdfs:comment 'Flag indicating whether this period is used for IFRS financial reporting (true) or not (false).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfDays rdf:type rdf:Property ;
    rdfs:label 'Number Of Days' ;
    rdfs:comment 'Total number of calendar days in this fiscal period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfWorkingDays rdf:type rdf:Property ;
    rdfs:label 'Number Of Working Days' ;
    rdfs:comment 'Total number of business working days in this fiscal period, excluding weekends and holidays.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodDescription rdf:type rdf:Property ;
    rdfs:label 'Period Description' ;
    rdfs:comment 'Detailed description of the fiscal period, including any special characteristics or usage notes (e.g., \'Year-end adjustment period for accruals\').' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndCloseCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period End Close Completed Timestamp' ;
    rdfs:comment 'Timestamp when the period-end closing process was completed.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodEndCloseStatus rdf:type rdf:Property ;
    rdfs:label 'Period End Close Status' ;
    rdfs:comment 'Status of the period-end closing process: not_started, in_progress (closing activities underway), completed (all closing tasks done), verified (closing reviewed and approved).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndCloseVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period End Close Verified Timestamp' ;
    rdfs:comment 'Timestamp when the period-end closing was verified and approved by finance management.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The last calendar date of the fiscal period (inclusive).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodLockIndicator rdf:type rdf:Property ;
    rdfs:label 'Period Lock Indicator' ;
    rdfs:comment 'Flag indicating whether the period is locked for all postings (true) or can be reopened (false). Locked periods cannot be reopened without special authorization.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name of the fiscal period (e.g., \'January 2024\', \'Q1 FY2024\', \'Special Period 1\').' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The first calendar date of the fiscal period (inclusive).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current posting status of the fiscal period: not_opened (future period), open (accepting postings), closed (period-end close completed), locked (permanently closed for audit).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingCloseDate rdf:type rdf:Property ;
    rdfs:label 'Posting Close Date' ;
    rdfs:comment 'The date when the period was closed for posting transactions.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingOpenDate rdf:type rdf:Property ;
    rdfs:label 'Posting Open Date' ;
    rdfs:comment 'The date when the period was opened for posting transactions.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarter rdf:type rdf:Property ;
    rdfs:label 'Quarter' ;
    rdfs:comment 'The fiscal quarter number (1-4) to which this period belongs within the fiscal year.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxReportingPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period Flag' ;
    rdfs:comment 'Flag indicating whether this period is a tax reporting period requiring statutory tax filings (true) or not (false).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryFixedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fixed Employee Id' ;
    rdfs:comment 'Identifier of the employee or manager responsible for the custody and management of this asset. Used for accountability and asset stewardship.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryFixedLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Fixed Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this fixed asset record. Used for audit trail and accountability.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accumulatedDepreciationGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation Gl Account Code' ;
    rdfs:comment 'General ledger account code for the accumulated depreciation contra-asset account. Used for balance sheet reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or historical cost of the asset including all costs necessary to bring the asset to its intended use (purchase price, delivery, installation, testing). Basis for depreciation calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the asset was acquired or purchased by Transport Shipping. Marks the start of the asset\'s lifecycle and is used for depreciation calculation start date.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'Classification code that categorizes the asset by type (e.g., vehicles, aircraft, vessels, warehouse facilities, material handling equipment, IT infrastructure). Determines depreciation rules, useful life defaults, and GL account assignments.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassName rdf:type rdf:Property ;
    rdfs:label 'Asset Class Name' ;
    rdfs:comment 'Human-readable name of the asset class (e.g., Delivery Vehicles, Cargo Aircraft, Container Ships, Warehouse Buildings, Forklifts, Servers).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed textual description of the fixed asset including make, model, specifications, and distinguishing characteristics. Used for identification and inventory purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocationCode rdf:type rdf:Property ;
    rdfs:label 'Asset Location Code' ;
    rdfs:comment 'Code identifying the physical location where the asset is deployed (e.g., warehouse facility code, airport code, depot code, office location code). Used for asset tracking and inventory management.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocationName rdf:type rdf:Property ;
    rdfs:label 'Asset Location Name' ;
    rdfs:comment 'Human-readable name of the physical location where the asset is deployed (e.g., Chicago Distribution Center, Frankfurt Airport Hub, Singapore Port Terminal).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique business identifier for the fixed asset. Used for asset tracking, reporting, and audit trails. Typically assigned by the Asset Accounting module.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Determines whether depreciation is active and whether the asset is available for operational use.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'Sub-asset identifier used when a main asset has multiple components tracked separately (e.g., engine, avionics, landing gear for an aircraft). Enables component-level depreciation and maintenance tracking.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexCategory rdf:type rdf:Property ;
    rdfs:label 'Capex Category' ;
    rdfs:comment 'Classification of the capital expenditure type for budgeting and strategic planning purposes. Distinguishes between growth investments, maintenance, and regulatory compliance.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date when the asset was placed in service and capitalized on the balance sheet. Depreciation begins from this date. May differ from acquisition date for assets under construction.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Gl Account Code' ;
    rdfs:comment 'General ledger account code to which depreciation expense is posted. Used for P&L reporting of depreciation charges.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to allocate the cost of the asset over its useful life. Straight-line is most common for IFRS compliance; declining balance may be used for tax purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the asset was disposed of, sold, scrapped, or retired from service. Marks the end of the asset\'s lifecycle and triggers gain/loss calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method by which the asset was disposed of. Determines accounting treatment for gain/loss recognition and tax implications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Amount received from the sale or disposal of the asset. Used to calculate gain or loss on disposal (proceeds minus net book value at disposal).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator' ;
    rdfs:comment 'Flag indicating whether the asset has been tested for impairment and an impairment loss has been recognized. Required under IFRS IAS 36 when carrying value exceeds recoverable amount.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLossAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss Amount' ;
    rdfs:comment 'Amount of impairment loss recognized when the asset\'s recoverable amount falls below its carrying value. Reduces net book value and is recognized as an expense.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eliminationJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Elimination Journal Entry Id' ;
    rdfs:comment 'Reference to the consolidation elimination journal entry that offsets this intercompany settlement in the group\'s consolidated financial statements.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:nettingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Netting Agreement Id' ;
    rdfs:comment 'Reference to the master netting agreement contract that governs the terms and conditions for offsetting intercompany balances between the sender and receiver entities.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:primaryIntercompanyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Intercompany Employee Id' ;
    rdfs:comment 'Reference to the user who approved the intercompany settlement transaction for posting. Null if not yet approved or approval not required.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryIntercompanySenderCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Intercompany Sender Company Code Id' ;
    rdfs:comment 'Reference to the legal entity or subsidiary that is the sender (debtor) in the intercompany settlement transaction.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:primaryIntercompanySenderCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Intercompany Sender Cost Center Id' ;
    rdfs:comment 'Reference to the cost center within the sender entity that incurred the cost being settled intercompany.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:primaryIntercompanySenderProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Intercompany Sender Profit Center Id' ;
    rdfs:comment 'Reference to the profit center within the sender company code that originated the intercompany charge or service.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:tertiaryIntercompanyLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Intercompany Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this intercompany settlement record in the system.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Indicates whether this intercompany settlement requires elimination entries for consolidated financial reporting under IFRS 10. True if elimination is required.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glAccountReceiver rdf:type rdf:Property ;
    rdfs:label 'Gl Account Receiver' ;
    rdfs:comment 'The general ledger account code in the receiver company code\'s chart of accounts to which the intercompany payable is posted.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountSender rdf:type rdf:Property ;
    rdfs:label 'Gl Account Sender' ;
    rdfs:comment 'The general ledger account code in the sender company code\'s chart of accounts to which the intercompany receivable is posted.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the corporate group\'s consolidated reporting currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'The calculated interest amount for intercompany loan settlements, based on principal, rate, and period.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The annual interest rate percentage applied to intercompany loan settlements. Expressed as a decimal (e.g., 0.0350 for 3.5%).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingRunReference rdf:type rdf:Property ;
    rdfs:label 'Netting Run Reference' ;
    rdfs:comment 'Reference identifier for the intercompany netting run batch that processed this settlement. Used to group settlements that were netted together.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The document number of the reversal transaction that cancelled this intercompany settlement. Null if not reversed.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Classification of the shared service or resource being settled intercompany. Aligns with Transport Shipping\'s shared service center structure. [ENUM-REF-CANDIDATE: fleet_services|warehouse_services|it_services|hr_services|finance_services|procurement_services|legal_services|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Document Number' ;
    rdfs:comment 'Externally-known unique document number for the intercompany settlement, typically generated by SAP S/4HANA Finance. Used for audit trails and cross-system reconciliation.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The OECD-compliant transfer pricing methodology applied to determine the arm\'s length price for this intercompany transaction.' ;
    rdfs:domain ind:IntercompanySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryInternalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Internal Employee Id' ;
    rdfs:comment 'Reference to the employee or manager responsible for this internal order and its budget execution.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryInternalLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Internal Last Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified this internal order record.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Total actual costs posted to this internal order to date. Updated in real-time as costs are incurred.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetUnderConstructionNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Under Construction Number' ;
    rdfs:comment 'Asset number for CAPEX orders where costs are accumulated before capitalization as a fixed asset.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Available Budget Amount' ;
    rdfs:comment 'Remaining budget available for spending. Calculated as budget minus actual minus committed costs.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetControlActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Active Flag' ;
    rdfs:comment 'Indicates whether budget availability checking is enforced for this internal order. When true, postings exceeding budget are blocked.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capexFlag rdf:type rdf:Property ;
    rdfs:label 'Capex Flag' ;
    rdfs:comment 'Indicates whether this internal order tracks capital expenditure that will be capitalized as an asset.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'Total committed costs (purchase orders, reservations) against this internal order that have not yet been invoiced.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Final Settlement Date' ;
    rdfs:comment 'Date when the internal order costs were finally settled to receiving cost objects and the order was closed.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opexFlag rdf:type rdf:Property ;
    rdfs:label 'Opex Flag' ;
    rdfs:comment 'Indicates whether this internal order tracks operating expenditure that will be expensed in the current period.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderCategory rdf:type rdf:Property ;
    rdfs:label 'Order Category' ;
    rdfs:comment 'High-level categorization of the internal order for financial reporting and cost allocation purposes.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDescription rdf:type rdf:Property ;
    rdfs:label 'Order Description' ;
    rdfs:comment 'Detailed business description of the internal order purpose, scope, and objectives.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderEndDate rdf:type rdf:Property ;
    rdfs:label 'Order End Date' ;
    rdfs:comment 'Planned or actual end date of the internal order activities. After this date, the order should be settled and closed.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the internal order used in SAP and external reporting. Externally-known unique code for tracking and reference.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderShortText rdf:type rdf:Property ;
    rdfs:label 'Order Short Text' ;
    rdfs:comment 'Brief descriptive text for the internal order used in reports and transaction displays.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStartDate rdf:type rdf:Property ;
    rdfs:label 'Order Start Date' ;
    rdfs:comment 'Planned or actual start date of the internal order activities. Defines the beginning of the cost collection period.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the internal order. Controls whether costs can be posted and whether settlement is allowed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the internal order indicating its business purpose. Determines cost tracking rules and settlement behavior.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningIntegratedFlag rdf:type rdf:Property ;
    rdfs:label 'Planning Integrated Flag' ;
    rdfs:comment 'Indicates whether this internal order is integrated with SAP planning and budgeting processes.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementReceiverReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Receiver Reference' ;
    rdfs:comment 'Identifier of the specific cost object (asset number, cost center code, GL account) that receives settled costs.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReceiverType rdf:type rdf:Property ;
    rdfs:label 'Settlement Receiver Type' ;
    rdfs:comment 'Type of cost object that receives settled costs from this internal order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRuleType rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule Type' ;
    rdfs:comment 'Method used to settle costs from this internal order to receiving cost objects such as assets, cost centers, or general ledger accounts.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Statistical Order Flag' ;
    rdfs:comment 'Indicates whether this is a statistical internal order used for informational tracking only without actual cost postings.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Technical Completion Date' ;
    rdfs:comment 'Date when the internal order was marked as technically complete. No further primary costs should be posted after this date.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryJournalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Employee Id' ;
    rdfs:comment 'Reference to the user who posted this journal entry. Critical for SOX audit trails and segregation of duties controls.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Reference' ;
    rdfs:comment 'Additional reference field for grouping and sorting journal entries. Often used for payment reference, project number, or internal tracking codes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'The debit amount posted in the document currency. Represents increases to asset and expense accounts or decreases to liability, equity, and revenue accounts.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The timestamp when this journal entry record was first created in the system. Used for audit trail and data lineage tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:localCurrencyCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Credit Amount' ;
    rdfs:comment 'The credit amount converted to the company code local currency for consolidated financial reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Debit Amount' ;
    rdfs:comment 'The debit amount converted to the company code local currency for consolidated financial reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manualEntryFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Entry Flag' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry was manually created by a user (True) or automatically generated by system integration (False). Used for audit risk assessment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit SAP posting key that controls the type of posting (debit/credit) and the account type (GL, customer, vendor, asset). Determines field status and processing rules.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Classification of the source document type (AWB=Air Waybill, BOL=Bill of Lading, INV=Invoice, PO=Purchase Order, CON=Contract, PAY=Payment, ADJ=Adjustment, ACR=Accrual, DEP=Depreciation, REV=Reversal). [ENUM-REF-CANDIDATE: AWB|BOL|INV|PO|CON|PAY|ADJ|ACR|DEP|REV — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The accounting document number of the original entry that this journal entry reverses. Null if this is not a reversal posting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textDescription rdf:type rdf:Property ;
    rdfs:label 'Text Description' ;
    rdfs:comment 'Free-text description providing business context and explanation for the journal entry. Used for audit trails and user understanding.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Code identifying the intercompany trading partner for intercompany transactions and eliminations. Used for consolidated financial statements.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for this table.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJournalChartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Chart Of Accounts Id' ;
    rdfs:comment 'Reference to the general ledger account to which this line item is posted. Determines the financial statement classification and reporting category.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:tradingPartnerId rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Id' ;
    rdfs:comment 'Reference to the intercompany trading partner for intercompany transactions. Used for intercompany reconciliation and elimination entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:amountInDocumentCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount In Document Currency' ;
    rdfs:comment 'The transaction amount in the original document currency. This is the amount as recorded in the source transaction before any currency conversion.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountInGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount In Group Currency' ;
    rdfs:comment 'The transaction amount converted to the group reporting currency. Used for consolidated financial statements and enterprise-wide reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountInLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount In Local Currency' ;
    rdfs:comment 'The transaction amount converted to the local currency of the company code. Used for local statutory reporting and P&L consolidation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Document Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the document currency. Represents the currency in which the original transaction was denominated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Descriptive text providing additional context or explanation for this journal entry line. Used for audit trail and user understanding.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey1 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 1' ;
    rdfs:comment 'First reference key field for additional classification or grouping. Often used for project codes, contract numbers, or custom business identifiers.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey2 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 2' ;
    rdfs:comment 'Second reference key field for additional classification or grouping. Provides flexibility for custom business dimensions.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDescriptionLong rdf:type rdf:Property ;
    rdfs:label 'Account Description Long' ;
    rdfs:comment 'Extended free-text description providing detailed explanation of the account\'s purpose, usage guidelines, and posting rules. Supports user training, audit documentation, and chart of accounts governance. Complements the short account_name with comprehensive business context.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'Secondary or legacy account number used for migration, external reporting, or integration with non-SAP systems. Maintains cross-reference to previous chart of accounts structures or statutory reporting account codes. Facilitates data migration, historical comparisons, and regulatory filings.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedForPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked For Posting Flag' ;
    rdfs:comment 'Temporary block indicator that prevents all postings to this account regardless of user authorization. True when account is under investigation, audit review, or pending correction; false for normal operations. Provides emergency control to freeze account activity during exception handling or compliance reviews.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessAreaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Business Area Required Flag' ;
    rdfs:comment 'Indicates whether a business area (division/segment) assignment is mandatory when posting to this account. True for accounts requiring cross-company-code segment reporting; false for accounts not subject to divisional analysis. Supports matrix reporting and segment disclosure per IFRS 8.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashFlowCategory rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Category' ;
    rdfs:comment 'Classification for cash flow statement presentation per IFRS IAS 7. Determines whether cash movements in this account are reported as operating activities (e.g., freight revenue, fuel expense), investing activities (e.g., CAPEX, asset disposals), or financing activities (e.g., debt, equity). Not_applicable for non-cash accounts.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Number' ;
    rdfs:comment 'The mapped account number in the group chart of accounts used for corporate consolidation and group reporting. Enables translation from local entity chart of accounts to standardized group reporting structure. Critical for multi-entity consolidation, intercompany eliminations, and group financial statements.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required Flag' ;
    rdfs:comment 'Indicates whether a cost center assignment is mandatory when posting to this account. True for expense accounts requiring departmental cost tracking; false for revenue and balance sheet accounts. Enforces cost center accounting discipline and enables OPEX analysis by organizational unit, function, or location.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classification for cost accounting integration. Primary cost elements represent direct postings from financial accounting (e.g., fuel, labor); secondary cost elements represent internal allocations and assessments; revenue elements track income; not_applicable for non-cost accounts. Critical for cost center accounting and profitability analysis.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReportingCode rdf:type rdf:Property ;
    rdfs:label 'External Reporting Code' ;
    rdfs:comment 'Standardized code for mapping this account to external regulatory reporting frameworks such as XBRL taxonomy tags, statutory chart of accounts, or industry-specific reporting templates. Examples: IFRS taxonomy element IDs, GAAP codification references, IMO financial reporting codes. Critical for automated regulatory filing and compliance reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementPosition rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Position' ;
    rdfs:comment 'The specific line item or section code where this account appears on published financial statements. Maps GL accounts to IFRS/GAAP disclosure requirements and standardized financial statement templates. Examples: \'BS.CA.010\' (Balance Sheet, Current Assets, line 010), \'PL.REV.100\' (P&L, Revenue, line 100).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyClearingFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Flag' ;
    rdfs:comment 'Indicates whether this account is used for intercompany transactions and settlements between legal entities within the group. True for intercompany receivables, payables, and clearing accounts that require elimination in consolidated financial statements. Critical for intercompany reconciliation and consolidation controls.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markedForDeletionFlag rdf:type rdf:Property ;
    rdfs:label 'Marked For Deletion Flag' ;
    rdfs:comment 'Indicates the account is scheduled for archival and removal from the active chart of accounts. True for obsolete accounts with zero balance and no open items; false for active accounts. Supports chart of accounts maintenance and master data governance. Accounts marked for deletion cannot accept new postings.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Flag' ;
    rdfs:comment 'Indicates whether a profit center assignment is mandatory when posting to this account. True for revenue and expense accounts requiring segment profitability tracking; false for balance sheet accounts or centralized accounts. Enforces management accounting discipline and enables P&L reporting by business unit, service line, or geographic region.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilityReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Reporting Flag' ;
    rdfs:comment 'Indicates whether this account is relevant for environmental, social, and governance (ESG) reporting and sustainability disclosures. True for accounts tracking GHG emissions costs, carbon offset purchases, renewable energy investments, sustainability-linked financing, and environmental compliance expenses. Supports EU ETS, CORSIA, and voluntary ESG frameworks.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax treatment classification for this account. Determines automatic tax code derivation, VAT reporting category, and tax jurisdiction applicability. Examples: \'INPUT_VAT\', \'OUTPUT_VAT\', \'NON_TAXABLE\', \'EXEMPT\', \'REVERSE_CHARGE\'. Critical for customs brokerage, cross-border shipping, and multi-jurisdiction tax compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProposalId rdf:type rdf:Property ;
    rdfs:label 'Payment Proposal Id' ;
    rdfs:comment 'Reference to the payment proposal that was approved and executed as this payment run. Links to the pre-run selection and approval process.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentProposal .

ind:quaternaryPaymentLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Payment Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this payment run record. Part of the audit trail for financial controls.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPaymentCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Payment Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this payment run record. Part of the audit trail for financial controls.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bankConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Confirmation Number' ;
    rdfs:comment 'The confirmation or reference number provided by the bank upon successful receipt and processing of the payment file.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceCount rdf:type rdf:Property ;
    rdfs:label 'Invoice Count' ;
    rdfs:comment 'The total number of vendor invoices cleared and paid in this payment run execution.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Disbursement Amount' ;
    rdfs:comment 'The net amount actually disbursed to vendors after discounts, withholding taxes, and other adjustments. Represents the actual cash outflow.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Block Override Flag' ;
    rdfs:comment 'Indicates whether payment blocks on individual invoices were manually overridden to include them in this payment run. True if overrides were applied.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentFileName rdf:type rdf:Property ;
    rdfs:label 'Payment File Name' ;
    rdfs:comment 'The name of the electronic payment file (e.g., ACH file, wire transfer file) generated for bank transmission. Used for reconciliation and troubleshooting.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFileTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment File Transmission Timestamp' ;
    rdfs:comment 'The date and time when the payment file was transmitted to the bank for processing.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentRunDate rdf:type rdf:Property ;
    rdfs:label 'Payment Run Date' ;
    rdfs:comment 'The date on which the payment run was executed. Represents the business event timestamp for the disbursement batch.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentRunNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Run Number' ;
    rdfs:comment 'Business identifier for the payment run execution. Externally visible reference number used in SAP payment program and vendor communications.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRunStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Run Status' ;
    rdfs:comment 'Current lifecycle status of the payment run execution. Tracks progression from scheduling through completion or failure.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRunType rdf:type rdf:Property ;
    rdfs:label 'Payment Run Type' ;
    rdfs:comment 'Classification of the payment run based on its purpose and processing priority. REGULAR (standard scheduled run), URGENT (expedited processing), MANUAL (ad-hoc run), SCHEDULED (automated recurring), INTERCOMPANY (internal settlements).' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Posting Document Number' ;
    rdfs:comment 'The financial document number generated in the general ledger when this payment run was posted. Used for GL reconciliation and audit trail.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Amount' ;
    rdfs:comment 'The aggregate gross amount of all payments disbursed in this payment run, before any adjustments or fees.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWithholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Withholding Tax Amount' ;
    rdfs:comment 'The aggregate amount of withholding tax deducted from vendor payments in this run, as required by tax regulations.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCount rdf:type rdf:Property ;
    rdfs:label 'Vendor Count' ;
    rdfs:comment 'The total number of unique vendors receiving payments in this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Reference to the parent profit center in the profit center hierarchy for roll-up reporting and consolidation. Null for top-level profit centers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:primaryConsolidationProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Consolidation Profit Center Id' ;
    rdfs:comment 'Reference to the consolidation profit center used for group-level financial consolidation and elimination entries.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:capexBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Amount' ;
    rdfs:comment 'Annual capital expenditure budget allocated to this profit center for asset investments and infrastructure projects.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Ebitda Target Amount' ;
    rdfs:comment 'Annual EBITDA target for this profit center in local currency for profitability measurement and management incentive tracking.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Billing Flag' ;
    rdfs:comment 'Flag indicating whether this profit center participates in intercompany billing and transfer pricing (true) or not (false).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opexBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Opex Budget Amount' ;
    rdfs:comment 'Annual operating expenditure budget for this profit center covering operational costs and recurring expenses.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed description of the profit center\'s business scope, service offerings, and operational focus.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Full business name of the profit center (e.g., Express Parcel Delivery, Freight Forwarding Air, Contract Logistics EMEA).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center indicating whether it is operational, suspended, or closed.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by organizational structure type (service line, business unit, geographic region, product line, cost center, investment center).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Amount' ;
    rdfs:comment 'Annual revenue target for this profit center in local currency for performance measurement.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aeoStatusRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Aeo Status Required Flag' ;
    rdfs:comment 'Indicates whether Authorized Economic Operator (AEO) status is required to benefit from simplified procedures or reduced rates under this tax account. True if AEO status is required, False otherwise.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deferredPaymentAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Deferred Payment Allowed Flag' ;
    rdfs:comment 'Indicates whether deferred payment of tax is allowed under this tax account (e.g., customs duty deferment). True if deferred payment is allowed, False otherwise.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsCodeApplicability rdf:type rdf:Property ;
    rdfs:label 'Hs Code Applicability' ;
    rdfs:comment 'Harmonized System (HS) code or code range to which this tax account applies, relevant for customs duty tax accounts. Used for tariff classification and customs brokerage.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermApplicability rdf:type rdf:Property ;
    rdfs:label 'Incoterm Applicability' ;
    rdfs:comment 'Incoterms rule(s) under which this tax account is applicable (e.g., DDP, DAP, FOB, CIF, EXW). Relevant for determining tax liability in cross-border shipments.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoverableFlag rdf:type rdf:Property ;
    rdfs:label 'Recoverable Flag' ;
    rdfs:comment 'Indicates whether tax paid under this tax account is recoverable (input tax credit). True if recoverable, False if non-recoverable.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reverseChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Flag' ;
    rdfs:comment 'Indicates whether this tax account is subject to reverse charge mechanism where the recipient (not the supplier) is liable for VAT/GST. True if reverse charge applies, False otherwise.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:selfAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Self Assessment Flag' ;
    rdfs:comment 'Indicates whether this tax account requires self-assessment by Transport Shipping rather than being assessed by the tax authority. True if self-assessment applies, False otherwise.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAccountCode rdf:type rdf:Property ;
    rdfs:label 'Tax Account Code' ;
    rdfs:comment 'Unique business identifier for the tax account used in SAP S/4HANA Finance tax configuration and external reporting. Externally-known code for this tax account.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAccountDescription rdf:type rdf:Property ;
    rdfs:label 'Tax Account Description' ;
    rdfs:comment 'Detailed description of the tax account purpose, scope, and applicability within Transport Shipping operations.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAccountName rdf:type rdf:Property ;
    rdfs:label 'Tax Account Name' ;
    rdfs:comment 'Human-readable name of the tax account for display and reporting purposes.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Account Status' ;
    rdfs:comment 'Current lifecycle status of the tax account: active (in use), inactive (not currently used), suspended (temporarily halted), pending approval (awaiting activation), or closed (permanently retired).' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Identifier' ;
    rdfs:comment 'Official identifier or registration number assigned by the tax authority for this tax account or tax registration.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the tax authority or regulatory body responsible for this tax account (e.g., HM Revenue & Customs, IRS, local customs authority).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFilingMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Filing Method' ;
    rdfs:comment 'Method by which tax returns and filings are submitted to the tax authority: electronic portal, paper submission, Electronic Data Interchange (EDI), or Application Programming Interface (API).' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPointRule rdf:type rdf:Property ;
    rdfs:label 'Tax Point Rule' ;
    rdfs:comment 'Rule determining the tax point (time of supply) for this tax account: invoice date, delivery date, payment date, or service completion date. Defines when tax liability arises.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Frequency' ;
    rdfs:comment 'Frequency at which tax filings and reports must be submitted to the tax authority for this tax account (monthly, quarterly, annually, semi-annually, or on-demand).' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Rate' ;
    rdfs:comment 'Withholding tax rate percentage applicable to this tax account for payments to non-resident suppliers or contractors. Expressed as a percentage (e.g., 15.00 for 15%). Null if not a withholding tax account.' ;
    rdfs:domain ind:TaxAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxFilingId rdf:type rdf:Property ;
    rdfs:label 'Tax Filing Id' ;
    rdfs:comment 'Unique identifier for the tax filing record. Primary key for the tax filing entity.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalFilingTaxFilingId rdf:type rdf:Property ;
    rdfs:label 'Original Filing Tax Filing Id' ;
    rdfs:comment 'Reference to the original tax filing record that this filing amends or corrects. Null if this is an original filing.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxFiling .

ind:primaryTaxEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tax Employee Id' ;
    rdfs:comment 'Reference to the user who created this tax filing record. Part of the audit trail for SOX compliance and internal controls.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this filing is an amended or corrected version of a previously submitted filing. True if this is an amendment, false if original filing.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditRiskScore rdf:type rdf:Property ;
    rdfs:label 'Audit Risk Score' ;
    rdfs:comment 'An internal risk assessment score indicating the likelihood that this filing may be selected for audit by the tax authority. Higher scores indicate higher risk.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'The confirmation or acknowledgment number provided by the tax authority upon successful receipt of the filing. Used for proof of submission.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Date' ;
    rdfs:comment 'The statutory deadline by which the tax filing must be submitted to the tax authority to avoid penalties or interest charges.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period End Date' ;
    rdfs:comment 'The last date of the tax period covered by this filing. Defines the end of the reporting period for which tax obligations are calculated.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period Start Date' ;
    rdfs:comment 'The first date of the tax period covered by this filing. Defines the beginning of the reporting period for which tax obligations are calculated.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preparerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Preparer Contact Email' ;
    rdfs:comment 'The email address of the tax filing preparer for correspondence and audit inquiries.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'The name of the individual or firm responsible for preparing the tax filing. May be an internal tax accountant or external tax advisor.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Count' ;
    rdfs:comment 'The number of supporting documents, schedules, or attachments submitted with this tax filing (e.g., invoices, receipts, reconciliation reports).' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The gross taxable base or revenue amount upon which the tax liability is calculated, before application of tax rates and adjustments.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetAcquisitionId rdf:type rdf:Property ;
    rdfs:label 'Asset Acquisition Id' ;
    rdfs:comment 'Unique identifier for the asset acquisition record. Primary key for the asset acquisition data product.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquisitionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Asset purchases and leases are governed by acquisition contracts. Finance and fleet management link assets to governing purchase/lease agreements for depreciation schedules, payment tracking, lease li' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:primaryAssetSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Supplier Id' ;
    rdfs:comment 'Reference to the supplier or vendor from whom the asset was purchased. Links to procurement domain supplier master data.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:acquisitionApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Approval Date' ;
    rdfs:comment 'The date on which the acquisition was approved by the appropriate authority (e.g., CAPEX committee, CFO). Used for governance and audit trails.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acquisitionNotes rdf:type rdf:Property ;
    rdfs:label 'Acquisition Notes' ;
    rdfs:comment 'Free-text notes or comments related to the acquisition transaction. Captures special terms, conditions, or contextual information.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Acquisition Number' ;
    rdfs:comment 'Business-facing unique reference number for the acquisition transaction. Used for tracking and reporting purposes across finance and procurement systems.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Acquisition Status' ;
    rdfs:comment 'Current lifecycle status of the acquisition transaction. Tracks progression from planning through completion or cancellation.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionType rdf:type rdf:Property ;
    rdfs:label 'Acquisition Type' ;
    rdfs:comment 'Classification of the acquisition method. Determines accounting treatment under IFRS 16 and impacts CAPEX vs OPEX classification.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexBudgetCode rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Code' ;
    rdfs:comment 'The budget code or cost center code to which this CAPEX acquisition is allocated. Links to finance domain budget and cost center master data.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The scheduled end date of the lease or hire purchase contract. Null for outright purchases. Used to calculate lease term and residual value obligations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Depreciation Rate Percent' ;
    rdfs:comment 'The annual depreciation rate expressed as a percentage. Used in conjunction with depreciation_method to calculate periodic depreciation expense.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downPayment rdf:type rdf:Property ;
    rdfs:label 'Down Payment' ;
    rdfs:comment 'The initial down payment or deposit made at the time of acquisition. Reduces the financed amount or lease liability.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingInstitution rdf:type rdf:Property ;
    rdfs:label 'Financing Institution' ;
    rdfs:comment 'The name of the bank or financial institution providing financing for the acquisition. Applicable for financed purchases and leases.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gainLossOnDisposal rdf:type rdf:Property ;
    rdfs:label 'Gain Loss On Disposal' ;
    rdfs:comment 'The calculated gain or loss on asset disposal, computed as disposal_proceeds minus net_book_value at disposal date. Impacts P&L reporting.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrs16LeaseLiability rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Lease Liability' ;
    rdfs:comment 'The calculated lease liability under IFRS 16, representing the present value of future lease payments. Recorded on the balance sheet for finance and operating leases.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrs16RightOfUseAsset rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Right Of Use Asset' ;
    rdfs:comment 'The calculated right-of-use asset value under IFRS 16 for lease accounting. Represents the lessee\'s right to use the leased asset over the lease term.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRatePercent rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percent' ;
    rdfs:comment 'The annual interest rate applied to the lease or financing agreement. Used for lease liability calculation under IFRS 16.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseValue rdf:type rdf:Property ;
    rdfs:label 'Lease Value' ;
    rdfs:comment 'The total value of the lease agreement, including all lease payments over the lease term. Used for IFRS 16 right-of-use asset and lease liability calculation.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyLeasePayment rdf:type rdf:Property ;
    rdfs:label 'Monthly Lease Payment' ;
    rdfs:comment 'The recurring monthly payment amount for leased assets. Used for OPEX tracking and cash flow forecasting.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchasePrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Price' ;
    rdfs:comment 'The total purchase price paid for the asset in the case of outright purchase. Represents the CAPEX investment and forms the basis for fixed asset capitalization.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'The estimated value of the asset at the end of its useful life or lease term. Used for depreciation calculation and lease accounting under IFRS 16.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxDepreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Depreciation Method' ;
    rdfs:comment 'The depreciation method used for tax reporting purposes, which may differ from the book depreciation method. Used for tax compliance and deferred tax calculation.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyEndDate rdf:type rdf:Property ;
    rdfs:label 'Warranty End Date' ;
    rdfs:comment 'The date on which the manufacturer or supplier warranty coverage expires. Triggers transition to self-funded maintenance.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'The date on which the manufacturer or supplier warranty coverage begins. Used for maintenance planning and cost management.' ;
    rdfs:domain ind:AssetAcquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Asset Assignment Id' ;
    rdfs:comment 'Unique identifier for the asset assignment record. Primary key for the asset assignment transaction.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetAssignment .

ind:assignmentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Assignment Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Each asset assignment incurs direct costs (fuel, tolls, driver labor) that must be allocated to a cost center for activity-based costing, route profitability analysis, and operational budget control.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:destinationDepotId rdf:type rdf:Property ;
    rdfs:label 'Destination Depot Id' ;
    rdfs:comment 'Reference to the depot, terminal, or facility where the assignment is scheduled to end. The ending location for the asset assignment. Null for open-ended assignments such as depot standby. Links to warehouse or facility master data.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:originDepotId rdf:type rdf:Property ;
    rdfs:label 'Origin Depot Id' ;
    rdfs:comment 'Reference to the depot, terminal, or facility where the assignment originates. The starting location for the asset assignment. Links to warehouse or facility master data.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to safety.risk_assessment. Business justification: High-risk asset assignments (hazmat transport, cross-border operations, oversized loads) require pre-assignment risk assessments for route approval, driver qualification verification, and emergency re' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:tripId rdf:type rdf:Property ;
    rdfs:label 'Trip Id' ;
    rdfs:comment 'Foreign key linking to fleet.trip. Business justification: Asset assignments represent the allocation of a transport asset to an operational run. Linking to trip provides the trip-level context. fleet_driver_assignment already has trip_id; asset_assignment sh' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trip .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when the asset assignment ended. Captured from GPS telematics, RFID tag reads, or manual check-out. Used for On-Time In-Full (OTIF) performance measurement and variance analysis against planned end. Null for in-progress assignments.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when the asset assignment began. Captured from GPS telematics, RFID tag reads, or manual check-in. Used for On-Time Departure (OTD) performance measurement and variance analysis against planned start.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentCostAmount rdf:type rdf:Property ;
    rdfs:label 'Assignment Cost Amount' ;
    rdfs:comment 'Total operational cost incurred for this assignment including fuel, driver wages, tolls, and maintenance. Used for OPEX tracking, profitability analysis, and cost-per-kilometer KPI calculation. Captured in the companys base currency.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentDurationHours rdf:type rdf:Property ;
    rdfs:label 'Assignment Duration Hours' ;
    rdfs:comment 'Planned or actual duration of the assignment in hours. Used for fleet utilization KPI calculation, driver hours-of-service compliance, and asset availability forecasting. Calculated from start and end datetimes.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2EmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Co2 Emissions Kg' ;
    rdfs:comment 'Total greenhouse gas emissions in kilograms of CO2 equivalent produced during this assignment. Calculated from fuel consumption using emission factors. Used for sustainability reporting, EU Emissions Trading System (EU ETS) compliance, and Carbon Offsetting and Reduction Scheme for International Aviation (CORSIA) reporting.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Status of regulatory compliance checks for this assignment including DOT inspections, ICAO airworthiness, IMO safety checks, and customs pre-clearance. Passed indicates all checks cleared, failed for violations, pending for in-progress checks, not required for exempt assignments, waived for authorized exceptions.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderIndicator rdf:type rdf:Property ;
    rdfs:label 'Cross Border Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the assignment involves crossing international borders requiring customs clearance and trade compliance. True for international assignments, false for domestic.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delayDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Minutes' ;
    rdfs:comment 'Total duration of delays in minutes. Calculated as the difference between planned and actual completion times. Used for Service Level Agreement (SLA) compliance measurement and root cause analysis. Zero if no delay occurred.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for any delay in completing the assignment. Weather for adverse conditions, traffic for congestion, mechanical for breakdowns, customs for clearance delays, loading delay for shipper delays, driver unavailable for crew issues, route change for diversions, accident for incidents, other for miscellaneous, none if no delay occurred. [ENUM-REF-CANDIDATE: weather|traffic|mechanical|customs|loading_delay|driver_unavailable|route_change|accident|other|none — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Planned or actual distance covered during the assignment in kilometers. Used for fuel consumption analysis, maintenance scheduling based on mileage, and route optimization. Captured from GPS telematics or route planning systems.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelConsumedLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumed Liters' ;
    rdfs:comment 'Actual fuel consumed during the assignment in liters. Captured from vehicle telematics, fuel card transactions, or manual fuel logs. Used for OPEX tracking, Carbon Dioxide Equivalent (CO2e) emissions calculation, and fuel efficiency KPIs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Boolean flag indicating whether real-time GPS tracking is enabled for this assignment. True if telematics data is being captured, false otherwise. Used for real-time visibility and predictive ETA calculation.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentReportedIndicator rdf:type rdf:Property ;
    rdfs:label 'Incident Reported Indicator' ;
    rdfs:comment 'Boolean flag indicating whether any incident (accident, breakdown, delay, cargo damage, security breach) was reported during this assignment. True if an incident occurred, false otherwise. Links to incident or claims management systems.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory or safety inspection performed on the asset prior to or during this assignment. Used for compliance tracking and maintenance scheduling. Null if no inspection has been performed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Load Utilization Percentage' ;
    rdfs:comment 'Percentage of the assets maximum capacity utilized during this assignment. Calculated as (actual cargo weight or volume / maximum capacity) * 100. Key performance indicator for fleet efficiency and load optimization.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned End Datetime' ;
    rdfs:comment 'Scheduled date and time when the asset assignment is planned to end. Used for capacity planning and turnaround time calculation. Corresponds to Estimated Time of Arrival (ETA) for route assignments. Null for open-ended assignments.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Datetime' ;
    rdfs:comment 'Scheduled date and time when the asset assignment is planned to begin. Used for capacity planning and resource scheduling. Corresponds to Estimated Time of Departure (ETD) for route assignments.' ;
    rdfs:domain ind:AssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rfidTagCode rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Code' ;
    rdfs:comment 'Unique identifier of the RFID tag attached to the asset for automated tracking and identification. Used for gate-in/gate-out automation, asset location tracking, and inventory management. Null if RFID is not used.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCostRecordId rdf:type rdf:Property ;
    rdfs:label 'Asset Cost Record Id' ;
    rdfs:comment 'Unique identifier for the asset cost record. Primary key for this transactional cost event.' ;
    rdfs:domain ind:AssetCostRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Order Id' ;
    rdfs:comment 'Reference to the maintenance work order that generated this cost, if applicable. Links to maintenance_order in fleet domain.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceOrder .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'The gross monetary value of the cost event before any adjustments, in the specified currency.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'Classification of the operational expenditure type. Maintenance covers repairs and servicing; tyre_replacement for tyre costs; insurance for premiums; toll for road tolls; THC (Terminal Handling Charge) for port/terminal fees; parking for parking fees; cleaning for vehicle cleaning; inspection for regulatory inspections. Fuel costs are tracked separately in fuel_transaction. [ENUM-REF-CANDIDATE: maintenance|tyre_replacement|insurance|toll|thc|parking|cleaning|inspection — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costDate rdf:type rdf:Property ;
    rdfs:label 'Cost Date' ;
    rdfs:comment 'The business date when the cost event occurred or the service was performed. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:AssetCostRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Description' ;
    rdfs:comment 'Detailed textual description of the cost event, service performed, or goods supplied. Provides context for the expenditure.' ;
    rdfs:domain ind:AssetCostRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Record Number' ;
    rdfs:comment 'Externally-known unique business identifier for this cost record, used for tracking and reference in financial systems and vendor communications.' ;
    rdfs:domain ind:AssetCostRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSubcategory rdf:type rdf:Property ;
    rdfs:label 'Cost Subcategory' ;
    rdfs:comment 'Detailed subcategory within the cost category for granular expense tracking (e.g., \'engine_repair\', \'brake_service\', \'hull_insurance\', \'congestion_charge\').' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineHours rdf:type rdf:Property ;
    rdfs:label 'Engine Hours' ;
    rdfs:comment 'The cumulative engine operating hours of the asset at the time the cost was incurred. Relevant for aircraft, vessels, and heavy equipment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Flag' ;
    rdfs:comment 'Indicates whether this cost is covered under insurance and a claim has been filed. True if insurance claim applies, False otherwise.' ;
    rdfs:domain ind:AssetCostRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'The insurance claim reference number if this cost is being recovered under an insurance policy.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerReading rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading' ;
    rdfs:comment 'The odometer or mileage reading of the asset at the time the cost was incurred, in kilometers. Used for cost-per-km analysis.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLocation rdf:type rdf:Property ;
    rdfs:label 'Service Location' ;
    rdfs:comment 'The location (depot, workshop, port, terminal) where the service was performed or the cost was incurred.' ;
    rdfs:domain ind:AssetCostRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Service Location Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the service location (e.g., USA, GBR, CHN).' ;
    rdfs:domain ind:AssetCostRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'The net total cost including all taxes and adjustments, in the specified currency. Represents the final amount paid or accrued.' ;
    rdfs:domain ind:AssetCostRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'The cost per unit of measure, calculated as cost_amount divided by quantity. Used for rate analysis and benchmarking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether this cost is covered under warranty and a claim has been filed. True if warranty claim applies, False otherwise.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Number' ;
    rdfs:comment 'The warranty claim reference number if this cost is being recovered under manufacturer or supplier warranty.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDisposalId rdf:type rdf:Property ;
    rdfs:label 'Asset Disposal Id' ;
    rdfs:comment 'Unique identifier for the asset disposal transaction. Primary key for the asset disposal record.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disposalAgreementId rdf:type rdf:Property ;
    rdfs:label 'Disposal Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Asset disposals may be governed by lease return agreements or sale contracts. Finance tracks disposal proceeds against contract terms, residual value commitments, and early termination penalties. Esse' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:bookValueAtDisposal rdf:type rdf:Property ;
    rdfs:label 'Book Value At Disposal' ;
    rdfs:comment 'The net book value (original cost minus accumulated depreciation) of the asset at the time of disposal. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerRecipientName rdf:type rdf:Property ;
    rdfs:label 'Buyer Recipient Name' ;
    rdfs:comment 'Name of the party acquiring the asset (for sales or trade-ins), receiving the donation, or processing the scrap. Null for write-offs.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerRecipientReference rdf:type rdf:Property ;
    rdfs:label 'Buyer Recipient Reference' ;
    rdfs:comment 'External identifier or account number for the buyer, recipient, or scrap processor. Used for contract and payment tracking.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissioningCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Certificate Number' ;
    rdfs:comment 'Reference number of the official certificate or document confirming regulatory decommissioning and compliance with disposal regulations.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationAuthority rdf:type rdf:Property ;
    rdfs:label 'Deregistration Authority' ;
    rdfs:comment 'Name of the regulatory body or government agency that processed the asset deregistration (e.g., FAA, DVLA, national maritime authority).' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationDate rdf:type rdf:Property ;
    rdfs:label 'Deregistration Date' ;
    rdfs:comment 'Date when the asset was officially deregistered from regulatory authorities (e.g., DOT for vehicles, ICAO for aircraft, IMO for vessels). Required for compliance closure.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalCosts rdf:type rdf:Property ;
    rdfs:label 'Disposal Costs' ;
    rdfs:comment 'Total costs incurred to execute the disposal including transportation, decommissioning, environmental remediation, and administrative fees.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalCountryCode rdf:type rdf:Property ;
    rdfs:label 'Disposal Country Code' ;
    rdfs:comment 'Three-letter ISO 3166 country code where the disposal transaction occurred. Required for cross-border regulatory compliance and tax reporting.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalLocation rdf:type rdf:Property ;
    rdfs:label 'Disposal Location' ;
    rdfs:comment 'Physical location or facility where the disposal transaction took place (e.g., depot, scrap yard, auction house, buyer premises).' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalNotes rdf:type rdf:Property ;
    rdfs:label 'Disposal Notes' ;
    rdfs:comment 'Free-text field for additional comments, special circumstances, or operational details related to the disposal transaction.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Number' ;
    rdfs:comment 'Externally-known business identifier for the disposal transaction. Used for tracking and audit purposes.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalReason rdf:type rdf:Property ;
    rdfs:label 'Disposal Reason' ;
    rdfs:comment 'Business justification for disposing of the asset. May include end of useful life, excessive maintenance costs, fleet optimization, regulatory non-compliance, or accident damage.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalStatus rdf:type rdf:Property ;
    rdfs:label 'Disposal Status' ;
    rdfs:comment 'Current lifecycle status of the disposal transaction. Tracks the disposal workflow from initiation through completion.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalType rdf:type rdf:Property ;
    rdfs:label 'Disposal Type' ;
    rdfs:comment 'Classification of the disposal method. Determines the financial treatment and regulatory requirements for the asset disposal.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Indicates whether the disposal was executed in compliance with environmental regulations including hazardous materials handling, waste disposal, and emissions standards. True if compliant, False if non-compliant or pending verification.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financeJournalEntryReference rdf:type rdf:Property ;
    rdfs:label 'Finance Journal Entry Reference' ;
    rdfs:comment 'Reference number of the general ledger journal entry created to record the disposal transaction, gain/loss, and asset removal from the balance sheet.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialsFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Materials Flag' ;
    rdfs:comment 'Indicates whether the disposed asset contained hazardous materials requiring special handling (e.g., fuel, batteries, refrigerants, asbestos). True if hazardous materials were present.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Reference' ;
    rdfs:comment 'Reference number of any insurance claim associated with the disposal (e.g., for accident damage, theft, or total loss). Null if no insurance claim involved.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netDisposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Net Disposal Proceeds' ;
    rdfs:comment 'Net amount realized from disposal after deducting disposal costs from gross proceeds. Used for gain/loss calculation.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odometerReadingAtDisposal rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading At Disposal' ;
    rdfs:comment 'Final odometer or usage meter reading at the time of disposal. Used for lifecycle analysis and residual value assessment. Applicable to vehicles and mobile equipment.' ;
    rdfs:domain ind:AssetDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetInspectionId rdf:type rdf:Property ;
    rdfs:label 'Asset Inspection Id' ;
    rdfs:comment 'Unique identifier for the asset inspection record. Primary key.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsComplianceProgramId rdf:type rdf:Property ;
    rdfs:label 'Customs Compliance Program Id' ;
    rdfs:comment 'Foreign key linking to customs.compliance_program. Business justification: Asset inspections (security seals, container integrity, GPS functionality) are mandatory for customs compliance programs (C-TPAT, AEO). Inspection certificates must be maintained as evidence of progra' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceProgram .

ind:depotId rdf:type rdf:Property ;
    rdfs:label 'Depot Id' ;
    rdfs:comment 'Foreign key linking to fleet.depot. Business justification: Inspections are often conducted at fleet depots/workshops. Adding depot_id allows tracking which depot performed the inspection. Nullable because inspections can also occur at external regulatory auth' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'The date on which the issued regulatory certificate expires, triggering the need for a subsequent inspection to maintain compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'The date the regulatory certificate or compliance document was officially issued following successful inspection.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Detailed description of corrective actions, repairs, or remediation work required to address identified defects and achieve compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defects Count' ;
    rdfs:comment 'Number of critical or safety-related defects that require immediate corrective action and may result in asset being placed out of service.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectsDescription rdf:type rdf:Property ;
    rdfs:label 'Defects Description' ;
    rdfs:comment 'Detailed narrative description of all defects, non-conformances, and observations identified during the inspection. Includes severity classification and affected components.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Defects Identified Count' ;
    rdfs:comment 'Total number of defects, non-conformances, or discrepancies identified during the inspection. Zero indicates no issues found.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionChecklistReference rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Reference' ;
    rdfs:comment 'Reference identifier for the standardized inspection checklist or procedure document used to conduct this inspection.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCost rdf:type rdf:Property ;
    rdfs:label 'Inspection Cost' ;
    rdfs:comment 'Total cost incurred for conducting the inspection, including labor, materials, third-party fees, and administrative overhead.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Inspection Cost Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the inspection cost amount.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Inspection Document Url' ;
    rdfs:comment 'URL or file path to the digital inspection report, certificate scan, or supporting documentation stored in the document management system.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Inspection End Time' ;
    rdfs:comment 'Precise timestamp when the inspection was completed. Used to calculate inspection duration and resource utilization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'Physical location where the inspection was performed (e.g., depot name, roadside checkpoint, port facility, maintenance hangar).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Inspection Location Country' ;
    rdfs:comment 'Three-letter ISO country code of the jurisdiction where the inspection took place. Critical for determining applicable regulatory framework.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Additional free-text notes, observations, or comments recorded by the inspector that provide context beyond structured fields.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number for this inspection event, often used for regulatory reporting and audit trails.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Overall result of the inspection. Pass indicates full compliance; fail indicates critical defects requiring immediate action; conditional pass indicates minor defects with corrective action required within a specified timeframe.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Time' ;
    rdfs:comment 'Precise timestamp when the inspection commenced. Used for operational tracking and labor cost allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the inspection event. Tracks progression from scheduling through completion or cancellation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspector Authority' ;
    rdfs:comment 'The organization or regulatory body under whose authority the inspection was conducted (e.g., DOT, ICAO, IMO, internal fleet safety team, third-party auditor).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'Official certification or license number of the inspector, required for regulatory inspections to validate inspector qualifications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'The date by which the next scheduled inspection of this type must be conducted to maintain regulatory compliance and operational certification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:odometerReadingAtInspection rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading At Inspection' ;
    rdfs:comment 'Odometer or usage meter reading (kilometers, miles, flight hours, engine hours) recorded at the time of inspection. Used for maintenance interval tracking.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Service Flag' ;
    rdfs:comment 'Indicates whether the asset was placed out of service as a result of this inspection due to critical safety defects or regulatory non-compliance.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfServiceStartDate rdf:type rdf:Property ;
    rdfs:label 'Out Of Service Start Date' ;
    rdfs:comment 'The date the asset was officially placed out of service following the inspection. Null if asset was not taken out of service.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryCertificateIssued rdf:type rdf:Property ;
    rdfs:label 'Regulatory Certificate Issued' ;
    rdfs:comment 'Name or type of regulatory certificate, permit, or compliance document issued as a result of passing this inspection (e.g., DOT Annual Inspection Certificate, ICAO Certificate of Airworthiness, IMO Safety Equipment Certificate).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Due Date' ;
    rdfs:comment 'The date by which the reinspection must be conducted to verify corrective action completion. Null if no reinspection is required.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up reinspection is required to verify that corrective actions have been completed and defects resolved.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetInsuranceId rdf:type rdf:Property ;
    rdfs:label 'Asset Insurance Id' ;
    rdfs:comment 'Unique identifier for the asset insurance policy record. Primary key for the asset insurance master data.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Insurance Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Insurance policies ARE contracts. Risk management links insurance coverage to governing insurance agreement for premium tracking, claims management, coverage verification, and regulatory compliance. E' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:aggregateLimit rdf:type rdf:Property ;
    rdfs:label 'Aggregate Limit' ;
    rdfs:comment 'The maximum total amount the insurer will pay for all claims during the policy period. Once reached, no further claims are covered until renewal.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date when the policy was cancelled, if applicable. Null for active policies.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsHistoryCount rdf:type rdf:Property ;
    rdfs:label 'Claims History Count' ;
    rdfs:comment 'The total number of claims filed against this policy since inception. Used for risk assessment and premium calculation at renewal.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage End Date' ;
    rdfs:comment 'The date when insurance coverage expires. Claims occurring after this date are not covered unless the policy is renewed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageLimit rdf:type rdf:Property ;
    rdfs:label 'Coverage Limit' ;
    rdfs:comment 'The maximum amount the insurer will pay per claim or per policy period. May differ from insured value for liability policies.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Date' ;
    rdfs:comment 'The date when insurance coverage becomes effective. Claims occurring before this date are not covered.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageTerritory rdf:type rdf:Property ;
    rdfs:label 'Coverage Territory' ;
    rdfs:comment 'The geographic scope of coverage. May be global, regional (e.g., Europe, North America), or country-specific. Defines where claims are valid.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsements rdf:type rdf:Property ;
    rdfs:label 'Endorsements' ;
    rdfs:comment 'Additional coverage endorsements or riders attached to the base policy. Examples: hazmat coverage, refrigerated cargo, high-value goods, war risk, terrorism coverage.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetWidePolicyFlag rdf:type rdf:Property ;
    rdfs:label 'Fleet Wide Policy Flag' ;
    rdfs:comment 'Indicates whether this is a blanket policy covering the entire fleet (True) or a policy specific to individual assets (False). Fleet-wide policies have null asset references.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuredValue rdf:type rdf:Property ;
    rdfs:label 'Insured Value' ;
    rdfs:comment 'The declared value of the asset or fleet covered by the policy. This is the maximum amount the insurer will pay for a total loss.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurerCode rdf:type rdf:Property ;
    rdfs:label 'Insurer Code' ;
    rdfs:comment 'Internal or industry-standard code identifying the insurance provider. Used for standardized reporting and system integration.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastClaimDate rdf:type rdf:Property ;
    rdfs:label 'Last Claim Date' ;
    rdfs:comment 'The date of the most recent claim filed under this policy. Used for risk assessment and claims-free discount eligibility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Policy Document Reference' ;
    rdfs:comment 'Reference to the stored policy document (contract, terms and conditions). May be a document management system identifier or file path.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyIssueDate rdf:type rdf:Property ;
    rdfs:label 'Policy Issue Date' ;
    rdfs:comment 'The date when the insurance policy was officially issued by the insurer. May differ from coverage start date.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiumFrequency rdf:type rdf:Property ;
    rdfs:label 'Premium Frequency' ;
    rdfs:comment 'The frequency at which premium payments are made. Annual policies are paid once per year; semi-annual twice per year; quarterly four times per year; monthly twelve times per year.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimsPaid rdf:type rdf:Property ;
    rdfs:label 'Total Claims Paid' ;
    rdfs:comment 'The cumulative amount paid by the insurer for all claims under this policy. Used for loss ratio analysis and renewal pricing.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwriterName rdf:type rdf:Property ;
    rdfs:label 'Underwriter Name' ;
    rdfs:comment 'The name of the underwriter at the insurance company who assessed and approved this policy.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLicenceId rdf:type rdf:Property ;
    rdfs:label 'Asset Licence Id' ;
    rdfs:comment 'Unique identifier for the asset licence record. Primary key.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspection Authority' ;
    rdfs:comment 'Name of the agency or third-party organization authorized to conduct inspections for this licence (e.g., FAA Designated Airworthiness Representative, Port State Control Inspector).' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether a physical inspection or audit by the regulatory authority is required as part of the licence issuance or renewal process. True = inspection required; False = no inspection required.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenceCategory rdf:type rdf:Property ;
    rdfs:label 'Licence Category' ;
    rdfs:comment 'Sub-classification or category code within the licence type (e.g., for vehicle registration: commercial, private, heavy goods; for airworthiness: transport category, restricted category).' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceClass rdf:type rdf:Property ;
    rdfs:label 'Licence Class' ;
    rdfs:comment 'Class designation within the licence category, defining specific operational limits or capabilities (e.g., Class 1 for heavy trucks, Class A for multi-engine aircraft).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Licence Fee Amount' ;
    rdfs:comment 'Total fee paid to the issuing authority for the issuance or renewal of this licence. Excludes taxes and processing charges.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenceFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Licence Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the licence fee amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceNumber rdf:type rdf:Property ;
    rdfs:label 'Licence Number' ;
    rdfs:comment 'The official licence, permit, or certificate number issued by the regulatory authority. This is the externally-known unique identifier for the licence.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceType rdf:type rdf:Property ;
    rdfs:label 'Licence Type' ;
    rdfs:comment 'Classification of the licence or permit. Defines the regulatory purpose and scope of the licence (e.g., vehicle registration for road use, airworthiness certificate for aircraft operation, dangerous goods permit for hazardous cargo transport). [ENUM-REF-CANDIDATE: vehicle_registration|operating_licence|airworthiness_certificate|vessel_class_certificate|dangerous_goods_permit|oversize_overweight_permit|cross_border_transit_permit|emission_certificate|insurance_certificate|roadworthiness_certificate — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalReminderDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Days' ;
    rdfs:comment 'Number of days before expiry_date when automated renewal reminders should be triggered to fleet managers and compliance officers.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validityStatus rdf:type rdf:Property ;
    rdfs:label 'Validity Status' ;
    rdfs:comment 'Current validity state of the licence. Indicates whether the asset is legally compliant to operate under this licence. Valid = currently active and compliant; Expired = past expiry date; Suspended = temporarily invalid; Revoked = permanently cancelled; Pending Renewal = renewal application submitted; Pending Approval = initial application under review.' ;
    rdfs:domain ind:AssetLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetPositionId rdf:type rdf:Property ;
    rdfs:label 'Asset Position Id' ;
    rdfs:comment 'Unique identifier for the asset position record. Primary key.' ;
    rdfs:domain ind:AssetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geofenceZoneId rdf:type rdf:Property ;
    rdfs:label 'Geofence Zone Id' ;
    rdfs:comment 'Reference to the geofence zone the asset is currently within, used for location-based alerts and compliance monitoring.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeofenceZone .

ind:altitudeM rdf:type rdf:Property ;
    rdfs:label 'Altitude M' ;
    rdfs:comment 'Altitude of the asset above sea level in meters, relevant for aircraft and mountainous terrain tracking.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the fleet asset type being tracked. [ENUM-REF-CANDIDATE: truck|trailer|van|aircraft|vessel|container|railcar|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batteryVoltage rdf:type rdf:Property ;
    rdfs:label 'Battery Voltage' ;
    rdfs:comment 'Current battery voltage of the asset or telematics device, used for health monitoring and maintenance alerts.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicator of the quality and reliability of this position record, used to filter or weight data in analytics.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceToNextWaypointKm rdf:type rdf:Property ;
    rdfs:label 'Distance To Next Waypoint Km' ;
    rdfs:comment 'Remaining distance in kilometers from current position to the next waypoint.' ;
    rdfs:domain ind:AssetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etaNextWaypoint rdf:type rdf:Property ;
    rdfs:label 'Eta Next Waypoint' ;
    rdfs:comment 'Predicted arrival date and time at the next waypoint, calculated from current position, speed, and route. Critical for customer notifications and SLA monitoring.' ;
    rdfs:domain ind:AssetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fuelLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Percent' ;
    rdfs:comment 'Current fuel level as a percentage of tank capacity, used for refueling planning and range estimation.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsAccuracyM rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy M' ;
    rdfs:comment 'Accuracy radius of the GPS position fix in meters, indicating the reliability of the location data.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsSatelliteCount rdf:type rdf:Property ;
    rdfs:label 'Gps Satellite Count' ;
    rdfs:comment 'Number of GPS satellites used to calculate the current position, affecting accuracy and reliability.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headingDegrees rdf:type rdf:Property ;
    rdfs:label 'Heading Degrees' ;
    rdfs:comment 'Current compass heading or direction of travel in degrees (0-360), where 0/360 is North, 90 is East, 180 is South, 270 is West.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ignitionState rdf:type rdf:Property ;
    rdfs:label 'Ignition State' ;
    rdfs:comment 'Current state of the vehicle ignition, indicating whether the engine is running.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'Date and time when this position record was ingested into the lakehouse platform, used for data lineage and latency monitoring.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextWaypointName rdf:type rdf:Property ;
    rdfs:label 'Next Waypoint Name' ;
    rdfs:comment 'Name of the next planned stop or destination for operational display.' ;
    rdfs:domain ind:AssetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerKm rdf:type rdf:Property ;
    rdfs:label 'Odometer Km' ;
    rdfs:comment 'Cumulative odometer reading in kilometers at the time of this position capture, used for maintenance scheduling and utilization tracking.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the asset indicating its activity and availability. Critical for fleet visibility and dispatch decisions. [ENUM-REF-CANDIDATE: in-transit|idle|at-depot|in-maintenance|out-of-contact|loading|unloading — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionAgeMinutes rdf:type rdf:Property ;
    rdfs:label 'Position Age Minutes' ;
    rdfs:comment 'Number of minutes elapsed since this position was captured, indicating data freshness for real-time visibility.' ;
    rdfs:domain ind:AssetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Position Timestamp' ;
    rdfs:comment 'The date and time when this position was recorded or last updated. This is the principal business event timestamp representing when the asset was at this location.' ;
    rdfs:domain ind:AssetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:speedKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Kmh' ;
    rdfs:comment 'Current speed of the asset in kilometers per hour at the time of position capture.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:telematicsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Telematics Device Code' ;
    rdfs:comment 'Identifier of the telematics or GPS tracking device that captured this position data.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Current cargo or ambient temperature in Celsius for temperature-controlled assets (reefer containers, refrigerated trucks).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetTypeId rdf:type rdf:Property ;
    rdfs:label 'Asset Type Id' ;
    rdfs:comment 'Unique identifier for the asset type classification record. Primary key.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetType .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level classification of the asset type: road vehicle, aircraft, vessel, rail unit, container, Unit Load Device (ULD), or handling equipment. [ENUM-REF-CANDIDATE: road_vehicle|aircraft|vessel|rail_unit|container|uld|handling_equipment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubcategory rdf:type rdf:Property ;
    rdfs:label 'Asset Subcategory' ;
    rdfs:comment 'Detailed subcategory within the asset category (e.g., rigid truck, articulated truck, cargo aircraft, container ship, flatcar, dry container, reefer container). [ENUM-REF-CANDIDATE: rigid_truck|articulated_truck|van|cargo_aircraft|passenger_aircraft|container_ship|bulk_carrier|tanker|flatcar|boxcar|dry_container|reefer_container|tank_container|flat_rack|open_top|pallet|igloo_uld|forklift|reach_stacker — promote to reference product]' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTypeCode rdf:type rdf:Property ;
    rdfs:label 'Asset Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the asset type (e.g., TRUCK-RIG, CARGO-AC, CONT-20FT). Used as business identifier across systems.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Type Description' ;
    rdfs:comment 'Detailed description of the asset type, including technical specifications, typical use cases, and operational characteristics.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTypeName rdf:type rdf:Property ;
    rdfs:label 'Asset Type Name' ;
    rdfs:comment 'Full descriptive name of the asset type (e.g., Rigid Truck, Cargo Aircraft, Twenty-Foot Container).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Type Status' ;
    rdfs:comment 'Current lifecycle status of this asset type classification: active (in use), inactive (no longer procured but existing assets remain), deprecated (phased out), or under review.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageAcquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Average Acquisition Cost' ;
    rdfs:comment 'Average acquisition cost for this asset type in the base currency, used for budgeting and Capital Expenditure (CAPEX) planning.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Certification Interval Months' ;
    rdfs:comment 'Standard interval in months between required certifications for this asset type (e.g., 60 months for CSC container certification).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the average acquisition cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Dot Classification Code' ;
    rdfs:comment 'US DOT standard classification code for road vehicles and rail units, used for regulatory compliance and safety reporting.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionStandard rdf:type rdf:Property ;
    rdfs:label 'Emission Standard' ;
    rdfs:comment 'Applicable emission standard for this asset type (e.g., Euro 6, EPA Tier 4, ICAO Annex 16). [ENUM-REF-CANDIDATE: euro_3|euro_4|euro_5|euro_6|epa_tier_3|epa_tier_4|icao_annex_16|imo_tier_ii|imo_tier_iii — promote to reference product]' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date on which this asset type classification was retired or deprecated. Null for active asset types.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelTypeStandard rdf:type rdf:Property ;
    rdfs:label 'Fuel Type Standard' ;
    rdfs:comment 'Standard fuel or energy type used by this asset type: diesel, gasoline, electric, hybrid, Liquefied Natural Gas (LNG), Compressed Natural Gas (CNG), hydrogen, or jet fuel. [ENUM-REF-CANDIDATE: diesel|gasoline|electric|hybrid|lng|cng|hydrogen|jet_fuel — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Capable Flag' ;
    rdfs:comment 'Indicates whether this asset type is certified and equipped to transport hazardous materials under IMDG Code or ICAO Technical Instructions.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Iata Classification Code' ;
    rdfs:comment 'IATA standard classification code for aircraft and ULD types, used for air freight operations and regulatory compliance.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Imo Classification Code' ;
    rdfs:comment 'IMO standard classification code for vessel types, used for maritime operations and regulatory compliance.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoContainerCode rdf:type rdf:Property ;
    rdfs:label 'Iso Container Code' ;
    rdfs:comment 'ISO 6346 standard container type code (e.g., 22G1 for 20ft dry container, 45R1 for 40ft reefer).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Days' ;
    rdfs:comment 'Typical scheduled maintenance interval in days for this asset type under normal operating conditions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Hours' ;
    rdfs:comment 'Typical scheduled maintenance interval in operating hours for this asset type (primarily for aircraft and vessels).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceIntervalKm rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Km' ;
    rdfs:comment 'Typical scheduled maintenance interval in kilometers or nautical miles for this asset type.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'Typical ownership model for this asset type: owned (company-owned), leased (operating or finance lease), mixed, or third-party (contracted).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTaggingStandardFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tagging Standard Flag' ;
    rdfs:comment 'Indicates whether this asset type is standardly equipped with RFID tags for automated identification and tracking.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardHeightM rdf:type rdf:Property ;
    rdfs:label 'Standard Height M' ;
    rdfs:comment 'Standard height dimension in meters for this asset type.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardLengthM rdf:type rdf:Property ;
    rdfs:label 'Standard Length M' ;
    rdfs:comment 'Standard length dimension in meters for this asset type.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardPayloadCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Standard Payload Capacity Kg' ;
    rdfs:comment 'Standard maximum payload capacity in kilograms for this asset type under normal operating conditions.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTemperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Standard Temperature Range Max C' ;
    rdfs:comment 'Maximum temperature in Celsius that this asset type can maintain (for temperature-controlled assets).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTemperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Standard Temperature Range Min C' ;
    rdfs:comment 'Minimum temperature in Celsius that this asset type can maintain (for temperature-controlled assets).' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTeuCapacity rdf:type rdf:Property ;
    rdfs:label 'Standard Teu Capacity' ;
    rdfs:comment 'Standard capacity measured in Twenty-foot Equivalent Units (TEU), primarily used for vessels and rail units.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Standard Useful Life Years' ;
    rdfs:comment 'Standard useful life in years for this asset type, used for depreciation and Capital Expenditure (CAPEX) planning.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardVolumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Standard Volume Capacity Cbm' ;
    rdfs:comment 'Standard internal volume capacity in cubic meters (CBM) for cargo storage.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardWidthM rdf:type rdf:Property ;
    rdfs:label 'Standard Width M' ;
    rdfs:comment 'Standard width dimension in meters for this asset type.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:telematicsCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Telematics Capable Flag' ;
    rdfs:comment 'Indicates whether this asset type is typically equipped with GPS telematics and IoT sensor capabilities for real-time tracking.' ;
    rdfs:domain ind:AssetType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetUtilisationId rdf:type rdf:Property ;
    rdfs:label 'Asset Utilisation Id' ;
    rdfs:comment 'Unique identifier for the asset utilisation record. Primary key for this operational snapshot.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedDepotId rdf:type rdf:Property ;
    rdfs:label 'Assigned Depot Id' ;
    rdfs:comment 'Reference to the depot, terminal, or home location where the asset is based during the reporting period.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:actualPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Actual Payload Kg' ;
    rdfs:comment 'Total actual payload weight carried by the asset during the reporting period, measured in kilograms.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceTravelledKm rdf:type rdf:Property ;
    rdfs:label 'Distance Travelled Km' ;
    rdfs:comment 'Total distance travelled by the asset during the reporting period, measured in kilometers. Captured from GPS (Global Positioning System) telematics or odometer readings.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceTravelledMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Travelled Miles' ;
    rdfs:comment 'Total distance travelled by the asset during the reporting period, measured in miles. Provided for regions using imperial units.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEfficiencyLitersPer100km rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Liters Per 100km' ;
    rdfs:comment 'Fuel efficiency metric representing liters consumed per 100 kilometers travelled. Key operational expense (OPEX) and sustainability metric.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEfficiencyMpg rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Mpg' ;
    rdfs:comment 'Fuel efficiency metric representing miles per gallon (MPG). Provided for regions using imperial units.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Load Factor Percent' ;
    rdfs:comment 'Percentage representing the ratio of actual payload to maximum payload capacity. Key performance indicator (KPI) for asset efficiency.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfTrips rdf:type rdf:Property ;
    rdfs:label 'Number Of Trips' ;
    rdfs:comment 'Total count of completed trips or delivery runs performed by the asset during the reporting period.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Percent' ;
    rdfs:comment 'Percentage of trips completed on time during the reporting period. Key service level agreement (SLA) metric for customer satisfaction.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingCost rdf:type rdf:Property ;
    rdfs:label 'Operating Cost' ;
    rdfs:comment 'Total operating expenditure (OPEX) incurred by the asset during the reporting period, including fuel, maintenance, tolls, and driver costs.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payloadCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Payload Capacity Kg' ;
    rdfs:comment 'Maximum payload capacity of the asset in kilograms. Used to calculate load factor.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this utilisation record was first created in the system. Audit trail for data lineage and compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this utilisation record was last modified. Audit trail for data lineage and compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Date' ;
    rdfs:comment 'The date for which this utilisation snapshot is recorded. Represents the business event date for daily or weekly operational reporting.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueGenerated rdf:type rdf:Property ;
    rdfs:label 'Revenue Generated' ;
    rdfs:comment 'Total revenue generated by the asset during the reporting period. Used for profitability and return on investment (ROI) analysis.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incidents Count' ;
    rdfs:comment 'Total number of safety incidents or accidents involving the asset during the reporting period. Critical for risk management and insurance reporting.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telematicsDataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Telematics Data Quality Score' ;
    rdfs:comment 'Quality score (0-100) representing the completeness and accuracy of GPS (Global Positioning System) telematics and Internet of Things (IoT) sensor data captured during the reporting period. Used to assess data reliability for analytics.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAvailableHours rdf:type rdf:Property ;
    rdfs:label 'Total Available Hours' ;
    rdfs:comment 'Total number of hours the asset was available for operational use during the reporting period, excluding scheduled downtime.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBreakdownHours rdf:type rdf:Property ;
    rdfs:label 'Total Breakdown Hours' ;
    rdfs:comment 'Total number of hours the asset was unavailable due to unplanned breakdowns or failures during the reporting period.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Downtime Hours' ;
    rdfs:comment 'Total number of hours the asset was out of service during the reporting period, combining maintenance and breakdown hours.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalIdleHours rdf:type rdf:Property ;
    rdfs:label 'Total Idle Hours' ;
    rdfs:comment 'Total number of hours the asset was idle (available but not in use) during the reporting period.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMaintenanceHours rdf:type rdf:Property ;
    rdfs:label 'Total Maintenance Hours' ;
    rdfs:comment 'Total number of hours the asset was undergoing scheduled or preventive maintenance during the reporting period.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperationalHours rdf:type rdf:Property ;
    rdfs:label 'Total Operational Hours' ;
    rdfs:comment 'Total number of hours the asset was actively in operation (moving, transporting cargo, or performing its primary function) during the reporting period.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilisationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilisation Rate Percent' ;
    rdfs:comment 'Overall utilisation rate calculated as the ratio of operational hours to available hours, expressed as a percentage. Primary KPI for fleet management decisions.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity Cbm' ;
    rdfs:comment 'Maximum volume capacity of the asset in cubic meters (CBM). Used to calculate volume utilisation rate.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUtilisedCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Utilised Cbm' ;
    rdfs:comment 'Total cargo volume utilised during the reporting period, measured in cubic meters (CBM). Relevant for container and warehouse assets.' ;
    rdfs:domain ind:AssetUtilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentDepotId rdf:type rdf:Property ;
    rdfs:label 'Current Depot Id' ;
    rdfs:comment 'Foreign key linking to fleet.depot. Business justification: Containers have a current location (current_location_type, current_location_code). When a container is at a fleet depot, this FK provides a structured link. Nullable because containers can be at ports' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current operational status of the container. Available for booking, in use on a shipment, in transit empty, under repair/maintenance, retired from service, or lost/missing. Critical for inventory management and booking systems.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Physical condition assessment of the container. Grade A (excellent, cargo-worthy), B (good, minor wear), C (fair, requires monitoring), D (poor, repair needed), Scrap (end of life). Determines suitability for cargo types and repair priority.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cscCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Csc Certification Date' ;
    rdfs:comment 'Date the current CSC safety certification was issued. Used to track certification validity and schedule re-inspection.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cscCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Csc Certification Number' ;
    rdfs:comment 'Unique certification number issued under the International Convention for Safe Containers (CSC). Certifies the container meets structural safety standards for international transport.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cscExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Csc Expiry Date' ;
    rdfs:comment 'Expiration date of the CSC safety certification. Containers must be re-inspected and re-certified before this date to remain in service. Non-compliance prevents international movement.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Current accounting book value of the container after depreciation. Updated periodically based on depreciation schedule. Used for financial reporting and asset disposal decisions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentLocationCode rdf:type rdf:Property ;
    rdfs:label 'Current Location Code' ;
    rdfs:comment 'Unique code identifying the specific facility, terminal, depot, or geographic location where the container is currently positioned. May be UN/LOCODE for ports or internal facility codes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Current Location Country' ;
    rdfs:comment 'Three-letter ISO country code of the containers current location. Used for geographic fleet distribution analysis and repositioning planning.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLocationType rdf:type rdf:Property ;
    rdfs:label 'Current Location Type' ;
    rdfs:comment 'Type of facility or mode where the container is currently located. Depot (storage yard), port (marine terminal), vessel (on ship), rail yard, customer site, or in transit between locations.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodGradeCertified rdf:type rdf:Property ;
    rdfs:label 'Food Grade Certified' ;
    rdfs:comment 'Indicates whether the container is certified for transporting food products, meeting hygiene and contamination prevention standards. True if food-grade certified, false otherwise.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Enabled' ;
    rdfs:comment 'Indicates whether the container is equipped with GPS tracking device for real-time location monitoring. True if GPS-enabled, false otherwise.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightFt rdf:type rdf:Property ;
    rdfs:label 'Height Ft' ;
    rdfs:comment 'External height of the container in feet. Standard height is 8.5 feet; high-cube containers are 9.5 feet. Determines stacking compatibility and clearance requirements.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Internal Volume Cbm' ;
    rdfs:comment 'Internal cargo capacity of the container in cubic meters (CBM). Used for volumetric load planning and dimensional weight calculations.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent maintenance or repair work performed on the container. Tracks maintenance history and informs future service intervals.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Timestamp of the most recent movement or position update for the container. Used for tracking, dwell time calculation, and real-time visibility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Lease Agreement Reference' ;
    rdfs:comment 'Reference number or identifier of the lease agreement if the container is leased. Links to contract terms, lessor details, and financial obligations. Null for owned containers.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthFt rdf:type rdf:Property ;
    rdfs:label 'Length Ft' ;
    rdfs:comment 'External length of the container in feet. Standard sizes are 10, 20, 40, 45, 48, or 53 feet. Critical for transport planning, stacking, and terminal slot allocation.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date the container was manufactured. Used to calculate asset age, depreciation, and remaining useful life for maintenance and replacement planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the company that manufactured the container. Used for quality tracking, warranty claims, and supplier performance analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Gross Weight Kg' ;
    rdfs:comment 'Maximum permissible combined weight of the container and its cargo in kilograms. Enforced for safety, regulatory compliance (SOLAS VGM), and transport mode restrictions.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Payload Kg' ;
    rdfs:comment 'Maximum cargo weight the container can carry, calculated as max gross weight minus tare weight. Used for load planning and customer quoting.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerCode rdf:type rdf:Property ;
    rdfs:label 'Owner Code' ;
    rdfs:comment 'Four-letter code identifying the container owner or operator, as registered with the Bureau International des Containers (BIC). First three letters identify the owner; fourth letter is the equipment category (U for freight container).' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the container is owned by the carrier, leased from a lessor, owned by a customer (SOC - Shipper Owned Container), or part of a shared pool arrangement. Impacts cost allocation, maintenance responsibility, and repositioning strategy.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferCapable rdf:type rdf:Property ;
    rdfs:label 'Reefer Capable' ;
    rdfs:comment 'Indicates whether the container has refrigeration capability for temperature-controlled cargo. True for reefer containers, false for dry and other non-refrigerated types.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date the container was retired from active service. Null if the container is still in service. Used for fleet lifecycle management and disposal tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'Empty weight of the container in kilograms, excluding cargo. Used to calculate net cargo weight and verify compliance with gross weight limits.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum temperature the container can maintain in Celsius. Applicable only to refrigerated (reefer) containers. Null for non-reefer units.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum temperature the container can maintain in Celsius. Applicable only to refrigerated (reefer) containers. Null for non-reefer units.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teuSize rdf:type rdf:Property ;
    rdfs:label 'Teu Size' ;
    rdfs:comment 'Container size expressed in TEU (Twenty-foot Equivalent Unit). Standard values: 1.0 for 20ft, 2.0 for 40ft, 2.25 for 45ft. Used for capacity planning and vessel/terminal utilization calculations.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Distance Km' ;
    rdfs:comment 'Cumulative distance the container has traveled in kilometers since acquisition. Used for wear analysis, maintenance scheduling, and asset performance evaluation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTripsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Trips Completed' ;
    rdfs:comment 'Cumulative count of completed shipment trips (loaded movements) the container has performed since acquisition. Used for utilization analysis and lifecycle tracking.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:widthFt rdf:type rdf:Property ;
    rdfs:label 'Width Ft' ;
    rdfs:comment 'External width of the container in feet. Standard width is 8.0 feet; high-cube and specialized containers may be 8.5 feet.' ;
    rdfs:domain ind:ContainerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetDriverAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Fleet Driver Assignment Id' ;
    rdfs:comment 'Unique identifier for the driver assignment record. Primary key.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetDriverAssignment .

ind:destinationLocationFleetDepotId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Fleet Depot Id' ;
    rdfs:comment 'Reference to the ending location for this driver assignment (depot, warehouse, terminal, customer site). Links to the location master.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:fatigueRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to safety.fatigue_risk_assessment. Business justification: Driver assignments exceeding HOS thresholds or involving long-haul routes trigger fatigue risk assessments before dispatch approval. Real-world operational safety decision: assessment outcome determin' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FatigueRiskAssessment .

ind:primaryFleetAssetTransportAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Asset Transport Asset Id' ;
    rdfs:comment 'Reference to the transport asset (vehicle, truck, aircraft, vessel) assigned for this run. Links to the fleet asset master.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportAsset .

ind:primaryFleetDepotId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Depot Id' ;
    rdfs:comment 'Reference to the starting location for this driver assignment (depot, warehouse, terminal). Links to the location master.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:primaryFleetDriverProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Driver Profile Id' ;
    rdfs:comment 'Reference to the driver assigned to this transport run. Links to the driver master profile.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverProfile .

ind:primaryFleetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Employee Id' ;
    rdfs:comment 'Reference to the dispatcher or operations staff member who assigned this driver to the trip. Links to the employee master.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Service Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Driver assignments execute service commitments under customer/carrier agreements. Operations verifies driver qualifications (certifications, endorsements, background checks) match contract requirement' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:shiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Id' ;
    rdfs:comment 'Reference to the operational shift or duty period that this assignment belongs to. Links to the shift schedule master.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSchedule .

ind:tertiaryFleetModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Fleet Modified By User Employee Id' ;
    rdfs:comment 'User ID of the system user who last modified this driver assignment record. Used for audit trail and change accountability.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Datetime' ;
    rdfs:comment 'Actual date and time when the driver departed with the assigned asset. Captured from GPS telematics or driver check-in. Used for on-time departure KPI tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualReturnDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Return Datetime' ;
    rdfs:comment 'Actual date and time when the driver returned and completed the assignment. Captured from GPS telematics or driver check-out. Used for on-time completion KPI tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assignment Outcome' ;
    rdfs:comment 'Final outcome status of the driver assignment. Captures whether the assignment was completed successfully, cancelled, or suspended, and the reason. Used for driver performance evaluation and operational analytics. [ENUM-REF-CANDIDATE: completed_on_time|completed_late|cancelled_by_ops|cancelled_by_driver|suspended_hos|suspended_mechanical|no_show — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFeedbackScore rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback Score' ;
    rdfs:comment 'Customer satisfaction score for this assignment, typically on a scale of 1-5. Captured from customer surveys or delivery feedback. Used for service quality monitoring.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchDatetime rdf:type rdf:Property ;
    rdfs:label 'Dispatch Datetime' ;
    rdfs:comment 'Date and time when the assignment was dispatched to the driver by the operations team. Marks the transition from scheduled to active status.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distanceActualKm rdf:type rdf:Property ;
    rdfs:label 'Distance Actual Km' ;
    rdfs:comment 'Actual total distance traveled during this assignment in kilometers, captured from GPS telematics. Used for fuel consumption analysis and route optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distancePlannedKm rdf:type rdf:Property ;
    rdfs:label 'Distance Planned Km' ;
    rdfs:comment 'Planned total distance for this assignment in kilometers, based on route planning. Used for fuel budgeting and driver scheduling.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverRating rdf:type rdf:Property ;
    rdfs:label 'Driver Rating' ;
    rdfs:comment 'Performance rating assigned to the driver for this assignment, typically on a scale of 1-5. Based on factors such as on-time performance, fuel efficiency, safety, and customer feedback. Used for driver performance management.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drivingHours rdf:type rdf:Property ;
    rdfs:label 'Driving Hours' ;
    rdfs:comment 'Total hours spent actively driving during this assignment. Captured from GPS telematics or electronic logging device (ELD). Used for HOS compliance and driver productivity analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosCounterAtEnd rdf:type rdf:Property ;
    rdfs:label 'Hos Counter At End' ;
    rdfs:comment 'Cumulative hours of service logged by the driver at the end of this assignment. Used for DOT hours-of-service compliance tracking and fatigue management.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosCounterAtStart rdf:type rdf:Property ;
    rdfs:label 'Hos Counter At Start' ;
    rdfs:comment 'Cumulative hours of service logged by the driver at the start of this assignment. Used for DOT hours-of-service compliance tracking and fatigue management.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Hos Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment resulted in a DOT hours-of-service violation. True if violation occurred, False otherwise. Used for compliance monitoring and driver safety management.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hosViolationType rdf:type rdf:Property ;
    rdfs:label 'Hos Violation Type' ;
    rdfs:comment 'Description of the type of HOS violation that occurred (e.g., exceeded 11-hour driving limit, insufficient rest break, exceeded 14-hour on-duty limit). Populated when hos_violation_flag is True.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Datetime' ;
    rdfs:comment 'Scheduled date and time when the driver is expected to depart with the assigned asset. Used for route planning and resource scheduling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedReturnDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Return Datetime' ;
    rdfs:comment 'Scheduled date and time when the driver is expected to return and complete the assignment. Used for shift planning and asset availability forecasting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restBreakHours rdf:type rdf:Property ;
    rdfs:label 'Rest Break Hours' ;
    rdfs:comment 'Total hours spent on mandatory rest breaks during this assignment. Used for DOT compliance verification and fatigue management.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyIncidentDescription rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Description' ;
    rdfs:comment 'Free-text description of the safety incident that occurred during this assignment. Populated when safety_incident_flag is True.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Boolean flag indicating whether a safety incident (accident, near-miss, traffic violation) occurred during this assignment. True if incident occurred, False otherwise. Used for driver safety scoring and risk management.' ;
    rdfs:domain ind:FleetDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverLicenceTypeId rdf:type rdf:Property ;
    rdfs:label 'Driver Licence Type Id' ;
    rdfs:comment 'Unique identifier for the driver licence type record. Primary key.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverLicenceType .

ind:supersededByLicenceTypeDriverLicenceTypeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Licence Type Driver Licence Type Id' ;
    rdfs:comment 'Reference to the licence type that supersedes this one if deprecated. Null if not superseded.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverLicenceType .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current status of this licence type in the system (active, inactive, deprecated, pending).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Background Check Required' ;
    rdfs:comment 'Indicates whether a criminal background check is required to obtain this licence type (True/False).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleTripleTrailerEligible rdf:type rdf:Property ;
    rdfs:label 'Double Triple Trailer Eligible' ;
    rdfs:comment 'Indicates whether this licence type is eligible for double or triple trailer endorsement (True/False).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Flight Hours Required' ;
    rdfs:comment 'Minimum number of flight hours required for aviation licences. Null if not applicable.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatEndorsementEligible rdf:type rdf:Property ;
    rdfs:label 'Hazmat Endorsement Eligible' ;
    rdfs:comment 'Indicates whether this licence type is eligible for hazardous materials endorsement (True/False).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalRecognitionScope rdf:type rdf:Property ;
    rdfs:label 'International Recognition Scope' ;
    rdfs:comment 'Description of international recognition scope (e.g., ICAO member states, EU member states, bilateral agreements). Null if not internationally recognized.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Jurisdiction' ;
    rdfs:comment 'Country or state/province code where this licence type is issued (e.g., USA-CA, GBR, DEU, CAN-ON). Uses ISO 3166-1 alpha-3 country codes with optional subdivision.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceCategoryName rdf:type rdf:Property ;
    rdfs:label 'Licence Category Name' ;
    rdfs:comment 'Full descriptive name of the licence category (e.g., Commercial Driver\'s License Class A, Airline Transport Pilot Licence, Officer of the Watch Unlimited).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Licence Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the licence type within the system (e.g., CDL-A, CDL-B, ATPL, CPL, OOW).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceValidityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Licence Validity Period Years' ;
    rdfs:comment 'Standard validity period in years for this licence type before renewal is required. Null if indefinite or variable.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxVehicleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Vehicle Weight Kg' ;
    rdfs:comment 'Maximum gross vehicle weight in kilograms that this licence type permits the holder to operate. Null if not applicable to the transport mode.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalCertificateClass rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Class' ;
    rdfs:comment 'Class or type of medical certificate required (e.g., Class 1, Class 2, DOT Medical Examiner Certificate). Null if no medical certificate required.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Required' ;
    rdfs:comment 'Indicates whether a valid medical certificate is required to hold this licence type (True/False).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalRenewalIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Medical Renewal Interval Months' ;
    rdfs:comment 'Frequency in months at which the medical certificate must be renewed. Null if no medical certificate required.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumAgeYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Years' ;
    rdfs:comment 'Minimum age in years required to hold this licence type.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCapacityPermitted rdf:type rdf:Property ;
    rdfs:label 'Passenger Capacity Permitted' ;
    rdfs:comment 'Maximum number of passengers the licence holder is permitted to transport. Null if not applicable.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:practicalExamRequired rdf:type rdf:Property ;
    rdfs:label 'Practical Exam Required' ;
    rdfs:comment 'Indicates whether a practical skills examination is required to obtain this licence type (True/False).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reciprocityRecognized rdf:type rdf:Property ;
    rdfs:label 'Reciprocity Recognized' ;
    rdfs:comment 'Indicates whether this licence type is recognized under reciprocity agreements with other jurisdictions (True/False).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Specific regulation, code, or legal reference governing this licence type (e.g., 49 CFR Part 383, ICAO Annex 1, STCW Convention Chapter II).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the regulatory authority governing this licence type (e.g., DOT FMCSA, ICAO, MCA, Transport Canada).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalGracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Grace Period Days' ;
    rdfs:comment 'Number of days after expiry during which the licence can be renewed without re-examination. Null if no grace period.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seaServiceMonthsRequired rdf:type rdf:Property ;
    rdfs:label 'Sea Service Months Required' ;
    rdfs:comment 'Minimum number of months of sea service required for maritime licences. Null if not applicable.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tankerEndorsementEligible rdf:type rdf:Property ;
    rdfs:label 'Tanker Endorsement Eligible' ;
    rdfs:comment 'Indicates whether this licence type is eligible for tanker vehicle endorsement (True/False).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Training Hours Required' ;
    rdfs:comment 'Minimum number of training hours required to qualify for this licence type. Null if not specified.' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleTypesPermitted rdf:type rdf:Property ;
    rdfs:label 'Vehicle Types Permitted' ;
    rdfs:comment 'Comma-separated list of vehicle, aircraft, or vessel types this licence permits operation of (e.g., combination vehicles, tanker trucks, Boeing 737, container vessels).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writtenExamRequired rdf:type rdf:Property ;
    rdfs:label 'Written Exam Required' ;
    rdfs:comment 'Indicates whether a written examination is required to obtain this licence type (True/False).' ;
    rdfs:domain ind:DriverLicenceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Driver Performance Id' ;
    rdfs:comment 'Unique identifier for the driver performance record. Primary key for this periodic operational record capturing driver behavior and performance metrics.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driverSafetyEventId rdf:type rdf:Property ;
    rdfs:label 'Driver Safety Event Id' ;
    rdfs:comment 'Foreign key linking to safety.driver_safety_event. Business justification: Driver performance evaluations aggregate safety events (harsh braking, speeding, seatbelt violations) for coaching, incentive programs, and disciplinary actions. Real-world process: telematics events ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverSafetyEvent .

ind:coachingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Coaching Required Flag' ;
    rdfs:comment 'Indicates whether the drivers performance during this period triggers a requirement for coaching or corrective training. True = coaching needed, False = no coaching required.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Quality score reflecting the completeness and reliability of telematics data for this evaluation period. Lower scores may indicate GPS signal loss, device malfunction, or data gaps.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecoDrivingScore rdf:type rdf:Property ;
    rdfs:label 'Eco Driving Score' ;
    rdfs:comment 'Score reflecting the drivers fuel-efficient and environmentally conscious driving behavior, based on factors such as smooth acceleration, optimal speed, and reduced idling.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period. For single-day records this equals the start date; for multi-day aggregations this captures the period end.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period. For trip-based records this is the trip start date; for daily records this is the calendar date.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current status of the performance evaluation record in the review and approval workflow.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Type' ;
    rdfs:comment 'Granularity of the performance record: trip-level, daily aggregation, weekly summary, or monthly rollup.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueAlertCount rdf:type rdf:Property ;
    rdfs:label 'Fatigue Alert Count' ;
    rdfs:comment 'Number of driver fatigue alerts triggered by telematics or in-cab monitoring systems during the evaluation period.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forwardCollisionWarningCount rdf:type rdf:Property ;
    rdfs:label 'Forward Collision Warning Count' ;
    rdfs:comment 'Number of forward collision warnings issued by ADAS during the evaluation period, indicating potential rear-end collision risk.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelEfficiencyActualKmPerLiter rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Actual Km Per Liter' ;
    rdfs:comment 'Actual fuel efficiency achieved by the driver during the evaluation period, calculated as total distance divided by fuel consumed.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEfficiencyBenchmarkKmPerLiter rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Benchmark Km Per Liter' ;
    rdfs:comment 'Expected or benchmark fuel efficiency for the vehicle type and route conditions, used to compare against actual performance.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEfficiencyVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Variance Percent' ;
    rdfs:comment 'Percentage variance between actual and benchmark fuel efficiency. Positive values indicate better-than-expected performance; negative values indicate underperformance.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geofenceViolationCount rdf:type rdf:Property ;
    rdfs:label 'Geofence Violation Count' ;
    rdfs:comment 'Number of times the driver entered or exited restricted geofenced areas without authorization during the evaluation period.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:harshAccelerationEventsCount rdf:type rdf:Property ;
    rdfs:label 'Harsh Acceleration Events Count' ;
    rdfs:comment 'Number of harsh acceleration events detected by telematics during the evaluation period. Harsh acceleration is typically defined as acceleration exceeding a threshold (e.g., +0.3g).' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:harshBrakingEventsCount rdf:type rdf:Property ;
    rdfs:label 'Harsh Braking Events Count' ;
    rdfs:comment 'Number of harsh braking events detected by telematics during the evaluation period. Harsh braking is typically defined as deceleration exceeding a threshold (e.g., -0.3g).' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hosAvailableDriveTimeHours rdf:type rdf:Property ;
    rdfs:label 'Hos Available Drive Time Hours' ;
    rdfs:comment 'Remaining available driving hours at the end of the evaluation period, based on HOS regulations and the drivers duty cycle.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Hos Compliance Flag' ;
    rdfs:comment 'Indicates whether the driver remained compliant with Hours of Service regulations during the evaluation period. True = compliant, False = violation detected.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:idlingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Idling Time Minutes' ;
    rdfs:comment 'Total time in minutes the vehicle engine was running while stationary (idling). Excessive idling impacts fuel efficiency and emissions.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligible Flag' ;
    rdfs:comment 'Indicates whether the driver qualifies for performance-based incentives or bonuses based on this evaluation periods metrics. True = eligible, False = not eligible.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Reported Flag' ;
    rdfs:comment 'Indicates whether any safety incidents, accidents, or near-misses were reported during the evaluation period. True = incident occurred, False = no incidents.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneDepartureCount rdf:type rdf:Property ;
    rdfs:label 'Lane Departure Count' ;
    rdfs:comment 'Number of unintentional lane departure events detected by advanced driver assistance systems (ADAS) during the evaluation period.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobilePhoneUsageEventsCount rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone Usage Events Count' ;
    rdfs:comment 'Number of mobile phone usage events detected while the vehicle was in motion, where telematics systems support this detection capability.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nightDrivingHours rdf:type rdf:Property ;
    rdfs:label 'Night Driving Hours' ;
    rdfs:comment 'Total hours driven during night-time hours (typically defined as 10 PM to 6 AM), which may carry higher risk and fatigue factors.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Flag' ;
    rdfs:comment 'Indicates whether deliveries during the evaluation period met the scheduled time windows. True = on-time, False = late.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the performance record was reviewed and approved by the supervisor.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routeDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Route Deviation Count' ;
    rdfs:comment 'Number of times the driver deviated from the planned or optimized route during the evaluation period.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'Categorical safety rating derived from the safety score, used for driver coaching and incentive programs.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyScore rdf:type rdf:Property ;
    rdfs:label 'Safety Score' ;
    rdfs:comment 'Composite safety score calculated from weighted factors including harsh events, speeding, HOS compliance, and other safety metrics. Typically scored 0-100, with higher scores indicating safer driving.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatbeltViolationCount rdf:type rdf:Property ;
    rdfs:label 'Seatbelt Violation Count' ;
    rdfs:comment 'Number of instances where the driver operated the vehicle without wearing a seatbelt, detected via telematics sensors.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Speeding Duration Minutes' ;
    rdfs:comment 'Total time in minutes the driver spent exceeding speed limits during the evaluation period.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedingEventsCount rdf:type rdf:Property ;
    rdfs:label 'Speeding Events Count' ;
    rdfs:comment 'Number of speeding violations detected during the evaluation period, where vehicle speed exceeded posted speed limits or company policy thresholds.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDrivingTimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Driving Time Hours' ;
    rdfs:comment 'Total hours the driver spent actively driving (ignition on, vehicle in motion) during the evaluation period.' ;
    rdfs:domain ind:DriverPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Customs Trade Party Id' ;
    rdfs:comment 'Foreign key linking to customs.trade_party. Business justification: Drivers (especially owner-operators or contractors) may be registered as customs trade parties with their own importer/exporter numbers, C-TPAT certifications, or AEO status. Supports driver-level cus' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:homeFleetDepotId rdf:type rdf:Property ;
    rdfs:label 'Home Fleet Depot Id' ;
    rdfs:comment 'FK to fleet.fleet_depot' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date the most recent background check was completed for the driver. Required for C-TPAT, AEO, and other security programs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Result status of the most recent background check. Cleared: passed all checks. Pending: in progress. Failed: did not meet security criteria. Expired: check is outdated and must be renewed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Flag' ;
    rdfs:comment 'Indicates whether the driver has active disciplinary actions or compliance violations on record. True if disciplinary action exists, False otherwise. Used for assignment restrictions and compliance monitoring.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Full legal name of the driver as it appears on their commercial driver license or operating permit.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugTestDate rdf:type rdf:Property ;
    rdfs:label 'Drug Test Date' ;
    rdfs:comment 'Date of the most recent drug and alcohol screening test. Required for DOT-regulated drivers in the United States.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugTestResult rdf:type rdf:Property ;
    rdfs:label 'Drug Test Result' ;
    rdfs:comment 'Result of the most recent drug and alcohol screening test. Negative: passed. Positive: failed. Pending: awaiting results. Refused: driver refused to test.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the driver\'s employment relationship with Transport Shipping. Determines payroll, benefits, liability, and compliance obligations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Gps Device Code' ;
    rdfs:comment 'Identifier of the GPS telematics device currently assigned to the driver for real-time location tracking and route monitoring. Null if no device assigned.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the driver was hired or contracted by Transport Shipping. Used for tenure calculation, anniversary tracking, and retention analytics.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Comma-separated list of languages the driver is proficient in, using ISO 639-1 two-letter codes (e.g., EN, ES, FR, DE). Used for customer-facing delivery roles and cross-border operations.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review for the driver.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseCategories rdf:type rdf:Property ;
    rdfs:label 'License Categories' ;
    rdfs:comment 'Comma-separated list of vehicle categories or endorsements the driver is authorized to operate (e.g., H-Hazmat, N-Tank, P-Passenger, T-Double/Triple Trailers for road; type ratings for aviation; vessel types for maritime).' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date the driver license expires and must be renewed. Critical for compliance monitoring and driver assignment eligibility.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseIssueDate rdf:type rdf:Property ;
    rdfs:label 'License Issue Date' ;
    rdfs:comment 'Date the current driver license was issued by the licensing authority.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'License Issuing Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the authority that issued the driver license.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseIssuingState rdf:type rdf:Property ;
    rdfs:label 'License Issuing State' ;
    rdfs:comment 'State, province, or regional authority within the issuing country that issued the driver license. Applicable for federal jurisdictions like USA, Canada, Australia.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleTypeAuthorization rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Authorization' ;
    rdfs:comment 'Comma-separated list of vehicle types the driver is authorized and trained to operate (e.g., tractor_trailer, straight_truck, cargo_van, aircraft, vessel). Derived from license class, endorsements, and internal training records.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of professional driving experience in commercial transport operations. Used for risk assessment, insurance rating, and assignment to high-value or complex routes.' ;
    rdfs:domain ind:DriverProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the depot was officially commissioned and began operational service for fleet management activities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Container Capacity Teu' ;
    rdfs:comment 'Maximum container storage capacity expressed in TEU (Twenty-foot Equivalent Units), applicable for container yards and ICDs.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coveredAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Covered Area Sqm' ;
    rdfs:comment 'Total covered or indoor area of the depot measured in square meters, including maintenance workshops, warehouses, and covered parking structures.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsBondedFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Facility Flag' ;
    rdfs:comment 'Indicates whether this depot is a customs-bonded facility authorized to store goods under customs supervision without immediate duty payment. Applicable for ICDs and container yards handling international freight.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the depot was or is planned to be decommissioned and removed from active operational service.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depotCode rdf:type rdf:Property ;
    rdfs:label 'Depot Code' ;
    rdfs:comment 'Unique business identifier code for the depot used across operational systems and documentation. Typically a short alphanumeric code assigned by the business.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotName rdf:type rdf:Property ;
    rdfs:label 'Depot Name' ;
    rdfs:comment 'Full business name of the fleet depot, vehicle yard, maintenance workshop, or staging area.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotType rdf:type rdf:Property ;
    rdfs:label 'Depot Type' ;
    rdfs:comment 'Classification of the depot based on its primary operational function. Vehicle depot for fleet parking and assignment, maintenance workshop for repairs and servicing, fuel station for refueling operations, container yard for container storage, inland container depot (ICD) for customs clearance and container handling, or staging area for temporary asset holding.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricChargingStations rdf:type rdf:Property ;
    rdfs:label 'Electric Charging Stations' ;
    rdfs:comment 'Number of electric vehicle charging stations available at this depot for electric and hybrid fleet assets.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Environmental management system certification held by the depot (e.g., ISO 14001, LEED certification) demonstrating compliance with sustainability and environmental protection standards.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzDesignation rdf:type rdf:Property ;
    rdfs:label 'Ftz Designation' ;
    rdfs:comment 'Free Trade Zone designation or license number if this depot operates within or as an FTZ, allowing duty-deferred or duty-exempt storage and processing of goods.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTypesAvailable rdf:type rdf:Property ;
    rdfs:label 'Fuel Types Available' ;
    rdfs:comment 'Comma-separated list of fuel types available at this depot for refueling operations (e.g., diesel, petrol, CNG, LNG, electric charging).' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the depot is certified and equipped to handle, store, and process hazardous materials in compliance with IMDG, IATA Dangerous Goods, and DOT regulations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date when the current lease agreement for this depot expires, applicable only for leased facilities. Used for lease renewal planning and CAPEX forecasting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceBays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Bays' ;
    rdfs:comment 'Number of maintenance bays or service stations available at this depot for vehicle and equipment servicing and repairs.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managingBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Managing Business Unit' ;
    rdfs:comment 'Name or code of the business unit, division, or department responsible for managing and operating this depot.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operates247Flag rdf:type rdf:Property ;
    rdfs:label 'Operates 24 7 Flag' ;
    rdfs:comment 'Indicates whether the depot operates continuously 24 hours a day, 7 days a week. True for round-the-clock operations, False for limited operating hours.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Daily end time of depot operations in HH:MM format (24-hour clock). Used for scheduling asset assignments and maintenance activities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Daily start time of depot operations in HH:MM format (24-hour clock). Used for scheduling asset assignments and maintenance activities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Classification of physical security measures and access controls implemented at the depot. Relevant for high-value asset storage and compliance with C-TPAT and AEO security requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Total Area Sqm' ;
    rdfs:comment 'Total land area of the depot facility measured in square meters, including parking areas, buildings, maintenance bays, and storage yards.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCapacity rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity' ;
    rdfs:comment 'Maximum number of vehicles (trucks, vans, cars) that can be parked or stored at this depot simultaneously.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Unique identifier for the fleet incident record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:insuranceClaimId rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Id' ;
    rdfs:comment 'Reference to the insurance claim filed for this incident (if applicable). Links to the claim domain for processing.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CargoClaim .

ind:assetDamageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Asset Damage Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the asset damage estimated cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDamageEstimatedCost rdf:type rdf:Property ;
    rdfs:label 'Asset Damage Estimated Cost' ;
    rdfs:comment 'Estimated cost of damage to the transport asset (vehicle, aircraft, vessel, container) in the incident currency. Includes repair or replacement costs.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoDamageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cargo Damage Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cargo damage estimated cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoDamageEstimatedCost rdf:type rdf:Property ;
    rdfs:label 'Cargo Damage Estimated Cost' ;
    rdfs:comment 'Estimated cost of damage to cargo or goods in the incident currency. Used for cargo claim processing.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoDamageFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Damage Flag' ;
    rdfs:comment 'Indicates whether cargo or goods being transported were damaged in the incident. True if cargo damaged, False otherwise.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:datetime rdf:type rdf:Property ;
    rdfs:label 'Datetime' ;
    rdfs:comment 'The date and time when the incident occurred in the field. This is the real-world event timestamp, distinct from when the incident was reported or recorded in the system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dotReportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Dot Report Submitted Date' ;
    rdfs:comment 'Date when the DOT accident report was submitted to the regulatory authority (if applicable).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Reportable Flag' ;
    rdfs:comment 'Indicates whether this incident meets the US Department of Transportation (DOT) criteria for mandatory accident reporting. True if DOT reportable, False otherwise.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatalityCount rdf:type rdf:Property ;
    rdfs:label 'Fatality Count' ;
    rdfs:comment 'Total number of fatalities resulting from the incident.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-visible unique incident reference number used for tracking and reporting. Format: INC-XXXXXXXXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the incident record. Reported: initial notification received. Under_investigation: active investigation in progress. Pending_review: investigation complete, awaiting management review. Closed: incident resolved and closed. Reopened: closed incident reopened for additional investigation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the incident: accident (collision or crash), near_miss (potential accident avoided), breakdown (mechanical failure), cargo_damage (damage to goods), security_incident (unauthorized access or threat), theft (asset or cargo stolen).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuriesReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Injuries Reported Flag' ;
    rdfs:comment 'Indicates whether any injuries (to driver, passengers, or third parties) were reported as a result of the incident. True if injuries reported, False otherwise.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:injuryCount rdf:type rdf:Property ;
    rdfs:label 'Injury Count' ;
    rdfs:comment 'Total number of individuals injured in the incident, including driver, passengers, and third parties.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationAssignedTo rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned To' ;
    rdfs:comment 'Name or identifier of the safety officer, manager, or team assigned to investigate this incident.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Date when the incident investigation was completed and findings documented.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationAddress rdf:type rdf:Property ;
    rdfs:label 'Location Address' ;
    rdfs:comment 'Human-readable street address or location description where the incident occurred. May include route number, mile marker, or landmark.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCity rdf:type rdf:Property ;
    rdfs:label 'Location City' ;
    rdfs:comment 'City or municipality where the incident occurred.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Location Country Code' ;
    rdfs:comment 'Three-letter ISO country code where the incident occurred (e.g., USA, CAN, MEX, GBR, DEU).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationLatitude rdf:type rdf:Property ;
    rdfs:label 'Location Latitude' ;
    rdfs:comment 'GPS (Global Positioning System) latitude coordinate of the incident location in decimal degrees. Range: -90 to +90.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationLongitude rdf:type rdf:Property ;
    rdfs:label 'Location Longitude' ;
    rdfs:comment 'GPS (Global Positioning System) longitude coordinate of the incident location in decimal degrees. Range: -180 to +180.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Location Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the incident location.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Location State Province' ;
    rdfs:comment 'State, province, or administrative region where the incident occurred.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policeDepartment rdf:type rdf:Property ;
    rdfs:label 'Police Department' ;
    rdfs:comment 'Name of the law enforcement agency or police department that responded to the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policeReportFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Police Report Filed Flag' ;
    rdfs:comment 'Indicates whether a police report was filed for this incident. True if police report filed, False otherwise.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policeReportNumber rdf:type rdf:Property ;
    rdfs:label 'Police Report Number' ;
    rdfs:comment 'Official police report or case number assigned by law enforcement agency (if applicable).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDatetime rdf:type rdf:Property ;
    rdfs:label 'Reported Datetime' ;
    rdfs:comment 'The date and time when the incident was first reported to the fleet management system or control center.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause analysis findings and contributing factors to the incident.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the incident based on impact to personnel, asset, cargo, and operations. Minor: no injuries, minimal damage. Moderate: minor injuries, moderate damage. Major: serious injuries, significant damage. Critical: fatalities or catastrophic damage.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyContact rdf:type rdf:Property ;
    rdfs:label 'Third Party Contact' ;
    rdfs:comment 'Contact phone number or email address for the third party involved in the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyInsuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Third Party Insurance Provider' ;
    rdfs:comment 'Name of the insurance company covering the third party involved in the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Involved Flag' ;
    rdfs:comment 'Indicates whether a third party (another vehicle, pedestrian, property owner, or external entity) was involved in the incident. True if third party involved, False otherwise.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyName rdf:type rdf:Property ;
    rdfs:label 'Third Party Name' ;
    rdfs:comment 'Name of the third party individual or organization involved in the incident (if applicable).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Third Party Policy Number' ;
    rdfs:comment 'Insurance policy number of the third party involved in the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fuel Transaction Id' ;
    rdfs:comment 'Unique identifier for the fuel transaction record. Primary key.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelAgreementId rdf:type rdf:Property ;
    rdfs:label 'Fuel Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Fuel purchases may be governed by fuel supply agreements with negotiated rates and volume commitments. Procurement validates transaction pricing against contracted fuel rates, surcharge schedules, and' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:fuelIndexId rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Id' ;
    rdfs:comment 'Foreign key linking to pricing.fuel_index. Business justification: Fuel surcharge billing reconciliation requires linking actual fuel transactions to the published fuel index used for customer surcharge calculation. Finance teams reconcile fuel costs against index-ba' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FuelIndex .

ind:co2eEmissionFactor rdf:type rdf:Property ;
    rdfs:label 'Co2e Emission Factor' ;
    rdfs:comment 'CO2e emission factor applied to calculate greenhouse gas emissions from this fuel consumption. Expressed in kg CO2e per unit of fuel. Used for sustainability reporting under EU ETS and CORSIA.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Co2e Emissions Kg' ;
    rdfs:comment 'Total CO2e emissions generated by this fuel transaction, calculated as quantity multiplied by emission factor. Feeds sustainability domain for GHG reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelCardNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Card Number' ;
    rdfs:comment 'Fuel card or fleet card number used for the transaction. Masked or tokenized for security. Used for reconciliation with supplier invoices.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCardProvider rdf:type rdf:Property ;
    rdfs:label 'Fuel Card Provider' ;
    rdfs:comment 'Name of the fuel card provider or fleet card issuer (e.g., Shell Fleet, BP Fuel Card, WEX).' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEfficiency rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency' ;
    rdfs:comment 'Calculated fuel efficiency for this transaction (e.g., km per litre, miles per gallon). Derived from odometer change and fuel quantity. Used for fleet performance KPIs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelGrade rdf:type rdf:Property ;
    rdfs:label 'Fuel Grade' ;
    rdfs:comment 'Grade or quality specification of the fuel (e.g., premium, regular, ultra-low sulfur diesel). Used for asset maintenance and performance tracking.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelStationCode rdf:type rdf:Property ;
    rdfs:label 'Fuel Station Code' ;
    rdfs:comment 'Reference to the fuel station, depot, or charging station where the transaction occurred. Links to location or supplier facility master data.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelStationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Fuel Station Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the fuel station is located. Used for tax and regulatory compliance reporting.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelStationLocation rdf:type rdf:Property ;
    rdfs:label 'Fuel Station Location' ;
    rdfs:comment 'Geographic location description of the fuel station (city, region, or address). Used for route analysis and cost allocation.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelStationName rdf:type rdf:Property ;
    rdfs:label 'Fuel Station Name' ;
    rdfs:comment 'Name of the fuel station, depot, or charging facility where the transaction took place.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Type of fuel or energy consumed. Includes diesel, petrol (gasoline), LNG (Liquefied Natural Gas), CNG (Compressed Natural Gas), SAF (Sustainable Aviation Fuel), electric charge, hydrogen, or biodiesel. Critical for sustainability and emissions reporting. [ENUM-REF-CANDIDATE: diesel|petrol|lng|cng|saf|electric|hydrogen|biodiesel — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'General ledger account code for fuel expense posting. Used for financial accounting and P&L reporting.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyRefuel rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Refuel' ;
    rdfs:comment 'Flag indicating whether this was an emergency or unplanned refueling event outside of normal depot operations. Used for exception analysis.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Reconciled' ;
    rdfs:comment 'Flag indicating whether this transaction has been reconciled with supplier invoices and financial records.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerUnit rdf:type rdf:Property ;
    rdfs:label 'Odometer Unit' ;
    rdfs:comment 'Unit of measure for the odometer reading (kilometers, miles, or operating hours for aircraft/vessels).' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Number' ;
    rdfs:comment 'Invoice number issued by the fuel supplier for this transaction. Used for accounts payable reconciliation.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost of the fuel transaction including base fuel cost and any applicable surcharges or taxes. Represents the net amount payable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionDatetime rdf:type rdf:Property ;
    rdfs:label 'Transaction Datetime' ;
    rdfs:comment 'The date and time when the fuel uplift or energy charge event occurred. Principal business event timestamp.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known unique transaction number or receipt number issued by the fuel supplier or fuel card provider.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the fuel transaction. Indicates whether the transaction has been completed, is pending reconciliation, disputed, cancelled, or reversed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardRegisterId rdf:type rdf:Property ;
    rdfs:label 'Hazard Register Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard_register. Business justification: Geofence zones with hazmat restrictions, speed limits, emission standards, or access controls are defined by hazard assessments. Real-world process: hazard register identifies risk (e.g., school zone,' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardRegister .

ind:parentZoneGeofenceZoneId rdf:type rdf:Property ;
    rdfs:label 'Parent Zone Geofence Zone Id' ;
    rdfs:comment 'Reference to a parent geofence zone if this zone is nested within a larger zone. Supports hierarchical zone structures. Null for top-level zones.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeofenceZone .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Level of access control enforced for this zone. Values: unrestricted (open access), authorized_only (requires authorization), permit_required (requires permit or credential), prohibited (no entry allowed).' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableAssetTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Asset Types' ;
    rdfs:comment 'Comma-separated list of transport asset types to which this geofence zone applies. Examples: \'truck\', \'van\', \'container\', \'vessel\', \'aircraft\'. Used to filter zone monitoring by asset category.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryGeometry rdf:type rdf:Property ;
    rdfs:label 'Boundary Geometry' ;
    rdfs:comment 'Geographic boundary definition of the zone stored as GeoJSON polygon coordinates. Contains latitude/longitude coordinate pairs defining the zone perimeter for geospatial matching against GPS telematics data.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerLatitude rdf:type rdf:Property ;
    rdfs:label 'Center Latitude' ;
    rdfs:comment 'Latitude coordinate of the zone\'s geographic center point in decimal degrees. Used for proximity calculations and zone visualization.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerLongitude rdf:type rdf:Property ;
    rdfs:label 'Center Longitude' ;
    rdfs:comment 'Longitude coordinate of the zone\'s geographic center point in decimal degrees. Used for proximity calculations and zone visualization.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cityName rdf:type rdf:Property ;
    rdfs:label 'City Name' ;
    rdfs:comment 'Name of the city or municipality where the zone is located. Used for geographic reporting and operational planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinateSystem rdf:type rdf:Property ;
    rdfs:label 'Coordinate System' ;
    rdfs:comment 'Geographic coordinate reference system used for boundary geometry. Standard values: WGS84 (World Geodetic System 1984 - global standard), NAD83 (North American Datum 1983), ETRS89 (European Terrestrial Reference System 1989).' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curfewEndTime rdf:type rdf:Property ;
    rdfs:label 'Curfew End Time' ;
    rdfs:comment 'Time of day when curfew restrictions end within the zone. Format: HH:MM (24-hour). Null if no curfew applies.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:curfewStartTime rdf:type rdf:Property ;
    rdfs:label 'Curfew Start Time' ;
    rdfs:comment 'Time of day when curfew restrictions begin within the zone. Format: HH:MM (24-hour). Null if no curfew applies.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dwellTimeThresholdMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Threshold Minutes' ;
    rdfs:comment 'Maximum permitted dwell time within the zone in minutes before an alert is triggered. Used for monitoring loading/unloading efficiency and unauthorized stops. Null if no dwell time restriction applies.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emissionStandardRequired rdf:type rdf:Property ;
    rdfs:label 'Emission Standard Required' ;
    rdfs:comment 'Minimum vehicle emission standard required for entry into the zone. Values: EURO_3, EURO_4, EURO_5, EURO_6 (European standards), EPA_2007, EPA_2010 (US EPA standards). Used for low emission zone compliance.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryAlertEnabled rdf:type rdf:Property ;
    rdfs:label 'Entry Alert Enabled' ;
    rdfs:comment 'Indicates whether real-time alerts should be generated when an asset enters this zone. True triggers telematics event notifications for zone entry.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exitAlertEnabled rdf:type rdf:Property ;
    rdfs:label 'Exit Alert Enabled' ;
    rdfs:comment 'Indicates whether real-time alerts should be generated when an asset exits this zone. True triggers telematics event notifications for zone exit.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClassesProhibited rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classes Prohibited' ;
    rdfs:comment 'Comma-separated list of UN hazmat classes prohibited in this zone. Examples: \'1\' (explosives), \'2.1\' (flammable gases), \'7\' (radioactive materials). Null if no hazmat restrictions apply.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Restriction Flag' ;
    rdfs:comment 'Indicates whether transport of hazardous materials is restricted or prohibited within this zone. True means hazmat restrictions apply.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightLimitMeters rdf:type rdf:Property ;
    rdfs:label 'Height Limit Meters' ;
    rdfs:comment 'Maximum vehicle height permitted within the zone in meters. Used for tunnel and bridge clearance compliance. Null if no height restriction applies.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalHours rdf:type rdf:Property ;
    rdfs:label 'Operational Hours' ;
    rdfs:comment 'Operating hours or time windows when the zone restrictions are active. Format: \'Mon-Fri 06:00-22:00\' or \'24/7\'. Used for time-based compliance monitoring.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedLimitKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Limit Kmh' ;
    rdfs:comment 'Maximum permitted speed within the zone in kilometers per hour. Used for speed compliance monitoring and driver safety alerts. Null if no speed restriction applies.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'State or province code within the country where the zone is located. Examples: \'CA\' (California), \'NY\' (New York), \'ON\' (Ontario). Used for regional compliance and reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneAreaSqkm rdf:type rdf:Property ;
    rdfs:label 'Zone Area Sqkm' ;
    rdfs:comment 'Total geographic area covered by the zone in square kilometers. Calculated from boundary geometry for reporting and capacity planning.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Unique business identifier code for the geofence zone used in operational systems and reporting. Alphanumeric code following organizational naming standards.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable name of the geofence zone for display and operational reference. Examples: \'JFK Airport Perimeter\', \'London Low Emission Zone\', \'Port of Rotterdam Customs Area\'.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneRadiusMeters rdf:type rdf:Property ;
    rdfs:label 'Zone Radius Meters' ;
    rdfs:comment 'Approximate radius of the zone in meters from the center point. Used for circular geofence zones or as a reference dimension for polygon zones.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneSubtype rdf:type rdf:Property ;
    rdfs:label 'Zone Subtype' ;
    rdfs:comment 'Secondary classification providing additional granularity for the zone type. Examples: \'ULEZ\' (Ultra Low Emission Zone), \'CAZ\' (Clean Air Zone), \'AEO Facility\', \'Bonded Warehouse\'.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Classification of the geofence zone by operational purpose. Values: depot_perimeter (facility boundary), restricted_area (access-controlled zone), customs_zone (customs inspection area), ftz (Free Trade Zone), low_emission_zone (environmental compliance zone), speed_restriction_zone (speed limit enforcement area). [ENUM-REF-CANDIDATE: depot_perimeter|restricted_area|customs_zone|ftz|low_emission_zone|speed_restriction_zone|curfew_zone|port_authority_zone|hazmat_restricted_zone|weigh_station_zone|border_crossing_zone — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hosLogId rdf:type rdf:Property ;
    rdfs:label 'Hos Log Id' ;
    rdfs:comment 'Unique identifier for the hours-of-service log record. Primary key.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHosDriverProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Hos Driver Profile Id' ;
    rdfs:comment 'Reference to the commercial driver who generated this HOS log entry.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverProfile .

ind:breakComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Break Compliance Flag' ;
    rdfs:comment 'Indicates whether the driver has taken the required 30-minute break within the first 8 hours of driving. True if compliant, False if violation detected.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'The legal name of the motor carrier responsible for this HOS log entry.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierUsdotNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Usdot Number' ;
    rdfs:comment 'The USDOT number assigned to the motor carrier operating the commercial vehicle. Mandatory for all interstate carriers.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Flag' ;
    rdfs:comment 'Indicates whether the driver has certified this log as accurate and complete. True if certified, False if pending certification.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleHours607 rdf:type rdf:Property ;
    rdfs:label 'Cycle Hours 60 7' ;
    rdfs:comment 'Cumulative on-duty hours over the preceding 7 days (rolling 7-day period). Used to enforce the 60-hour/7-day cycle limit for carriers operating every day of the week.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleHours708 rdf:type rdf:Property ;
    rdfs:label 'Cycle Hours 70 8' ;
    rdfs:comment 'Cumulative on-duty hours over the preceding 7 days (rolling 8-day period). Used to enforce the 70-hour/8-day cycle limit for carriers not operating every day of the week.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceDrivenMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Driven Miles' ;
    rdfs:comment 'The total distance driven in miles during the driving duty status segment.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drivingHoursDay rdf:type rdf:Property ;
    rdfs:label 'Driving Hours Day' ;
    rdfs:comment 'Total hours spent in driving status for the current log date. Used to enforce the 11-hour daily driving limit.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyStatus rdf:type rdf:Property ;
    rdfs:label 'Duty Status' ;
    rdfs:comment 'The driver\'s current duty status as defined by FMCSA regulations: off_duty (not working), sleeper_berth (resting in sleeper), driving (operating CMV), on_duty_not_driving (working but not driving).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyStatusDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duty Status Duration Minutes' ;
    rdfs:comment 'The total duration in minutes that the driver remained in this duty status segment.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dutyStatusEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Duty Status End Timestamp' ;
    rdfs:comment 'The precise date and time when the driver exited the current duty status, in yyyy-MM-ddTHH:mm:ss.SSSXXX format. Null if status is still active.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dutyStatusStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Duty Status Start Timestamp' ;
    rdfs:comment 'The precise date and time when the driver entered the current duty status, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:editFlag rdf:type rdf:Property ;
    rdfs:label 'Edit Flag' ;
    rdfs:comment 'Indicates whether this log entry has been edited after initial creation. True if edited, False if original.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:editReason rdf:type rdf:Property ;
    rdfs:label 'Edit Reason' ;
    rdfs:comment 'The reason provided by the driver or dispatcher for editing this log entry, as required by FMCSA regulations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edit Timestamp' ;
    rdfs:comment 'The date and time when this log entry was last edited, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eldDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Eld Device Code' ;
    rdfs:comment 'The unique identifier of the ELD hardware device that captured this log entry. Required for FMCSA ELD mandate compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eldFirmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Eld Firmware Version' ;
    rdfs:comment 'The firmware version of the ELD device at the time this log was recorded. Used for audit and compliance verification.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eldManufacturer rdf:type rdf:Property ;
    rdfs:label 'Eld Manufacturer' ;
    rdfs:comment 'The name of the manufacturer of the ELD device used to record this log.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'The GPS latitude coordinate of the vehicle at the time of this duty status change, in decimal degrees.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'The GPS longitude coordinate of the vehicle at the time of this duty status change, in decimal degrees.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastBreakTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Break Timestamp' ;
    rdfs:comment 'The date and time when the driver last took a qualifying break (off-duty or sleeper berth of at least 30 minutes), in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:logDate rdf:type rdf:Property ;
    rdfs:label 'Log Date' ;
    rdfs:comment 'The calendar date for which this hours-of-service log applies, in yyyy-MM-dd format.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:odometerEnd rdf:type rdf:Property ;
    rdfs:label 'Odometer End' ;
    rdfs:comment 'The vehicle odometer reading in miles at the end of the duty status segment.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:odometerStart rdf:type rdf:Property ;
    rdfs:label 'Odometer Start' ;
    rdfs:comment 'The vehicle odometer reading in miles at the start of the duty status segment.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onDutyHoursDay rdf:type rdf:Property ;
    rdfs:label 'On Duty Hours Day' ;
    rdfs:comment 'Total hours spent on duty (driving + on-duty not driving) for the current log date. Used to enforce the 14-hour on-duty limit.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'The identification number of the trailer being hauled during this duty period, if applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationFlag rdf:type rdf:Property ;
    rdfs:label 'Violation Flag' ;
    rdfs:comment 'Indicates whether any HOS violation occurred during this log period. True if violation detected, False if compliant.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationSeverity rdf:type rdf:Property ;
    rdfs:label 'Violation Severity' ;
    rdfs:comment 'The severity classification of the HOS violation for compliance reporting and enforcement prioritization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'The specific type of HOS violation detected: 11_hour_driving (exceeded 11-hour driving limit), 14_hour_on_duty (exceeded 14-hour on-duty window), 70_hour_8_day (exceeded 70-hour/8-day cycle), 60_hour_7_day (exceeded 60-hour/7-day cycle), 30_min_break (failed to take required break), 10_hour_off_duty (insufficient off-duty time before shift).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule Id' ;
    rdfs:comment 'Foreign key linking to fleet.maintenance_schedule. Business justification: Maintenance orders can be auto-generated from maintenance schedules (maintenance_schedule has auto_generate_order_flag). This FK tracks which preventive maintenance schedule triggered the work order. ' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceSchedule .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_permit. Business justification: Maintenance activities involving hot work (welding, cutting), confined space entry (tank cleaning), or lockout/tagout require safety permits before work authorization. Real-world compliance workflow: ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:primaryMaintenanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Employee Id' ;
    rdfs:comment 'Reference to the primary technician or mechanic assigned to perform the maintenance work, used for accountability, quality tracking, and workforce management.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryMaintenanceModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Maintenance Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this maintenance order record, used for accountability and audit purposes.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryMaintenanceCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Maintenance Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this maintenance order record, used for accountability and audit purposes.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'The actual date and time when maintenance work was finished and the asset was released back to operational status, used for downtime calculation and SLA compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'The actual date and time when maintenance work physically commenced, used for labor tracking and performance analysis against scheduled start.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'Total number of hours the asset was out of service due to this maintenance activity, calculated from the time the asset was taken offline until it was returned to operational status, used for availability KPIs and operational impact analysis.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalServiceCost rdf:type rdf:Property ;
    rdfs:label 'External Service Cost' ;
    rdfs:comment 'Cost charged by external vendors or service providers for maintenance work, applicable when maintenance is outsourced, representing third-party service fees in maintenance OPEX.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faultCode rdf:type rdf:Property ;
    rdfs:label 'Fault Code' ;
    rdfs:comment 'Standardized diagnostic trouble code or fault identifier from the asset\'s onboard diagnostic system or maintenance taxonomy, used for root cause analysis and trend identification.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultDescription rdf:type rdf:Property ;
    rdfs:label 'Fault Description' ;
    rdfs:comment 'Detailed narrative description of the fault, defect, or maintenance requirement that triggered this work order, including symptoms, error codes, and operator observations.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Certificate Number' ;
    rdfs:comment 'Official certificate or approval number issued by the regulatory authority upon successful completion of a statutory inspection, used for compliance documentation and audit trail.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Expiry Date' ;
    rdfs:comment 'Date when the regulatory inspection certificate expires and the asset requires re-inspection to maintain compliance and operational authorization.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Total cost of labor for this maintenance order, calculated from labor hours and applicable labor rates (internal or vendor), representing the direct labor component of maintenance OPEX.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total number of labor hours expended on this maintenance order, including technician time for diagnosis, repair, testing, and documentation, used for cost calculation and productivity analysis.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceCategory rdf:type rdf:Property ;
    rdfs:label 'Maintenance Category' ;
    rdfs:comment 'Technical category of the maintenance work, indicating the system or component area being serviced (e.g., mechanical, electrical, hydraulic, structural, avionics, engine, transmission, brakes, tires, body, interior, safety systems). [ENUM-REF-CANDIDATE: mechanical|electrical|hydraulic|structural|avionics|engine|transmission|brakes|tires|body|interior|safety_systems — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Order Status' ;
    rdfs:comment 'Current lifecycle state of the maintenance order: draft (being prepared), scheduled (approved and planned), in_progress (work underway), on_hold (temporarily suspended), completed (work finished and asset released), cancelled (order voided).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceProviderType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Provider Type' ;
    rdfs:comment 'Classification of the entity performing the maintenance work: internal_workshop (company-owned facility), external_vendor (third-party service provider), oem_service_center (original equipment manufacturer facility), authorized_dealer (franchised service location).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Classification of the maintenance work order by its nature: preventive (scheduled routine maintenance), corrective (repair of known defect), statutory_inspection (regulatory compliance inspection such as DOT annual inspection or ICAO airworthiness check), or breakdown (emergency unplanned repair).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsCost rdf:type rdf:Property ;
    rdfs:label 'Parts Cost' ;
    rdfs:comment 'Total cost of parts and materials consumed in this maintenance order, representing the direct material component of maintenance OPEX.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsReplacedList rdf:type rdf:Property ;
    rdfs:label 'Parts Replaced List' ;
    rdfs:comment 'Comma-separated or structured list of part numbers and descriptions for components replaced during the maintenance activity, used for inventory management and warranty tracking.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMaintenanceStatus rdf:type rdf:Property ;
    rdfs:label 'Post Maintenance Status' ;
    rdfs:comment 'Operational status of the asset immediately following completion of maintenance work: operational (fully serviceable), limited_service (operational with restrictions), out_of_service (not cleared for use), pending_inspection (awaiting final certification), scrapped (asset retired).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Type' ;
    rdfs:comment 'Type of regulatory or statutory inspection performed as part of this maintenance order: dot_annual (DOT annual vehicle inspection), icao_airworthiness (ICAO airworthiness check), maritime_survey (vessel classification survey), emissions_test (environmental compliance test), safety_certification (safety system certification), none (not a regulatory inspection).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Date' ;
    rdfs:comment 'The planned date when maintenance work is expected to be completed and the asset returned to service, used for operational planning and customer commitments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'The planned date when maintenance work is scheduled to begin, used for resource planning and asset availability forecasting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Total Maintenance Cost' ;
    rdfs:comment 'Total cost of the maintenance order including parts, labor, external services, and any other direct costs, representing the complete OPEX impact of this maintenance event for financial reporting and asset lifecycle costing.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally-known unique business identifier for the maintenance work order, used for tracking and reference across systems and with external vendors.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPerformedDescription rdf:type rdf:Property ;
    rdfs:label 'Work Performed Description' ;
    rdfs:comment 'Detailed narrative of the actual maintenance work performed, including procedures followed, parts replaced, adjustments made, and test results, completed upon work order closure.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceFacilityId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Facility Id' ;
    rdfs:comment 'Reference to the maintenance facility, depot, or service center where this maintenance is scheduled to be performed.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:autoGenerateOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generate Order Flag' ;
    rdfs:comment 'Indicates whether the system should automatically generate a maintenance work order when the schedule trigger conditions are met (True) or require manual creation (False).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceMandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Mandatory Flag' ;
    rdfs:comment 'Indicates whether this maintenance schedule is mandated by regulatory compliance requirements (True) or is discretionary preventive maintenance (False).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Downtime Required Flag' ;
    rdfs:comment 'Indicates whether the asset must be taken out of service (True) or can remain operational during maintenance (False).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated total cost in base currency for completing this scheduled maintenance service, including labor and parts.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Estimated time in hours required to complete this maintenance service.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intervalUnit rdf:type rdf:Property ;
    rdfs:label 'Interval Unit' ;
    rdfs:comment 'Unit of measure for the maintenance interval value (miles, kilometers, engine hours, calendar days, operating cycles).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervalValue rdf:type rdf:Property ;
    rdfs:label 'Interval Value' ;
    rdfs:comment 'Numeric value of the maintenance interval (e.g., 5000 for 5000 miles, 100 for 100 engine hours, 365 for 365 days).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Last Completed Date' ;
    rdfs:comment 'The date when this maintenance service was last completed for the asset.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCompletedHours rdf:type rdf:Property ;
    rdfs:label 'Last Completed Hours' ;
    rdfs:comment 'The engine hour meter reading when this maintenance service was last completed. Null if not applicable.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCompletedMileage rdf:type rdf:Property ;
    rdfs:label 'Last Completed Mileage' ;
    rdfs:comment 'The odometer mileage reading when this maintenance service was last completed. Null if not applicable.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Number of days advance notice required before the scheduled maintenance due date to allow for planning, parts procurement, and resource allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'The calendar date by which the next scheduled maintenance service must be completed. Null if trigger basis is not calendar-based.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDueHours rdf:type rdf:Property ;
    rdfs:label 'Next Due Hours' ;
    rdfs:comment 'The engine hour meter reading at which the next scheduled maintenance service is due. Null if trigger basis is not engine hours or flight hours.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDueMileage rdf:type rdf:Property ;
    rdfs:label 'Next Due Mileage' ;
    rdfs:comment 'The odometer mileage reading at which the next scheduled maintenance service is due. Null if trigger basis is not mileage.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Required Flag' ;
    rdfs:comment 'Indicates whether replacement parts or consumables are required for this maintenance service (True) or if it is inspection/labor only (False).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Effective Date' ;
    rdfs:comment 'The date from which this maintenance schedule becomes active and applicable to the asset.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Expiry Date' ;
    rdfs:comment 'The date on which this maintenance schedule is no longer applicable (e.g., asset retirement, schedule superseded by new regulation). Null for open-ended schedules.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:toleranceAfterDays rdf:type rdf:Property ;
    rdfs:label 'Tolerance After Days' ;
    rdfs:comment 'Number of days after the due date that the maintenance service may be performed late before the asset is considered non-compliant or overdue.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceBeforeDays rdf:type rdf:Property ;
    rdfs:label 'Tolerance Before Days' ;
    rdfs:comment 'Number of days before the due date that the maintenance service may be performed early without resetting the schedule interval.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerBasis rdf:type rdf:Property ;
    rdfs:label 'Trigger Basis' ;
    rdfs:comment 'The measurement basis that triggers this maintenance service (mileage interval, engine hours, calendar days, flight hours, operating cycles).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Reefer Monitoring Id' ;
    rdfs:comment 'Unique identifier for the reefer monitoring record. Primary key for the reefer monitoring transactional event.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Actual Temperature C' ;
    rdfs:comment 'Actual measured temperature in Celsius at the primary sensor location. Primary metric for cold-chain compliance verification.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Flag' ;
    rdfs:comment 'Indicates whether any alarm condition has been triggered. Primary indicator for exception management and immediate response requirements.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alarmSeverity rdf:type rdf:Property ;
    rdfs:label 'Alarm Severity' ;
    rdfs:comment 'Severity level of the alarm condition. Determines escalation procedures and response time requirements.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmType rdf:type rdf:Property ;
    rdfs:label 'Alarm Type' ;
    rdfs:comment 'Classification of the alarm condition that was triggered. Enables prioritized response and root cause analysis.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ambientTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature C' ;
    rdfs:comment 'External environmental temperature outside the reefer unit. Used to assess refrigeration load and equipment performance under varying conditions.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Battery Level Percent' ;
    rdfs:comment 'Remaining battery charge percentage for battery-powered monitoring devices. Critical for ensuring continuous monitoring capability.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoType rdf:type rdf:Property ;
    rdfs:label 'Cargo Type' ;
    rdfs:comment 'Classification of cargo being transported. Different cargo types have different temperature tolerance requirements and compliance standards.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2LevelPpm rdf:type rdf:Property ;
    rdfs:label 'Co2 Level Ppm' ;
    rdfs:comment 'Carbon dioxide concentration in parts per million. Used for modified atmosphere containers transporting fresh produce and perishables.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationMethod rdf:type rdf:Property ;
    rdfs:label 'Communication Method' ;
    rdfs:comment 'Method by which the monitoring data was transmitted from the reefer unit to the central system.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressorRunningFlag rdf:type rdf:Property ;
    rdfs:label 'Compressor Running Flag' ;
    rdfs:comment 'Indicates whether the refrigeration compressor is currently running. Used for equipment performance analysis and energy consumption tracking.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defrostCycleActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Defrost Cycle Active Flag' ;
    rdfs:comment 'Indicates whether the unit is currently in a defrost cycle. Defrost cycles temporarily raise temperature and must be tracked for compliance.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doorOpenFlag rdf:type rdf:Property ;
    rdfs:label 'Door Open Flag' ;
    rdfs:comment 'Indicates whether the reefer unit door is currently open. Door openings cause temperature fluctuations and must be tracked.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excursionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Excursion Duration Minutes' ;
    rdfs:comment 'Cumulative duration in minutes that temperature has been outside acceptable range. Used to determine cargo viability and insurance claims.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:humidityPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Percent' ;
    rdfs:comment 'Relative humidity percentage inside the reefer unit. Critical for perishable goods that require specific moisture levels.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringTimestamp rdf:type rdf:Property ;
    rdfs:label 'Monitoring Timestamp' ;
    rdfs:comment 'Date and time when the temperature and environmental readings were captured by the monitoring system. Critical for cold-chain compliance audit trails.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:o2LevelPercent rdf:type rdf:Property ;
    rdfs:label 'O2 Level Percent' ;
    rdfs:comment 'Oxygen concentration percentage. Monitored in controlled atmosphere containers to extend shelf life of fresh produce.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerSourceStatus rdf:type rdf:Property ;
    rdfs:label 'Power Source Status' ;
    rdfs:comment 'Current power source supplying the refrigeration unit. Critical for identifying power interruptions that could compromise cargo.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerVoltage rdf:type rdf:Property ;
    rdfs:label 'Power Voltage' ;
    rdfs:comment 'Electrical voltage being supplied to the reefer unit. Used for power quality monitoring and equipment diagnostics.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRegime rdf:type rdf:Property ;
    rdfs:label 'Regulatory Regime' ;
    rdfs:comment 'Applicable regulatory framework governing this cold-chain shipment. Determines compliance thresholds and documentation requirements.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAirTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Return Air Temperature C' ;
    rdfs:comment 'Temperature of air returning from the cargo space to the refrigeration unit. Indicates cargo heat load and circulation effectiveness.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensorCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Code' ;
    rdfs:comment 'Unique identifier of the physical sensor device that captured this reading. Enables sensor-level diagnostics and calibration tracking.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setpointTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Setpoint Temperature C' ;
    rdfs:comment 'Target temperature in Celsius that the reefer unit is configured to maintain. Defined by shipper requirements and cargo specifications.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipperNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Shipper Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the shipper has been notified of an alarm or exception condition. Tracks compliance with customer notification Service Level Agreements (SLAs).' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyAirTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Supply Air Temperature C' ;
    rdfs:comment 'Temperature of air being supplied into the cargo space by the refrigeration unit. Used for advanced diagnostics and airflow analysis.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureDeviationC rdf:type rdf:Property ;
    rdfs:label 'Temperature Deviation C' ;
    rdfs:comment 'Calculated difference between setpoint and actual temperature. Positive values indicate warmer than setpoint, negative indicates colder.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidScanId rdf:type rdf:Property ;
    rdfs:label 'Rfid Scan Id' ;
    rdfs:comment 'Unique identifier for the RFID scan event record.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:antennaCode rdf:type rdf:Property ;
    rdfs:label 'Antenna Code' ;
    rdfs:comment 'Identifier of the specific antenna on the reader device that captured the scan. Used for precise location tracking within the scan zone.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyVerified rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Verified' ;
    rdfs:comment 'Boolean indicator of whether the chain of custody was verified and validated at this scan point. Used for high-value or regulated cargo.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing status of the RFID scan record in the data pipeline. Tracks the lifecycle of the scan event from capture to integration.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readCount rdf:type rdf:Property ;
    rdfs:label 'Read Count' ;
    rdfs:comment 'Number of times the RFID tag was read during this scan event. Multiple reads may occur as the asset passes through the reader field.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readerDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Reader Device Code' ;
    rdfs:comment 'Unique identifier of the RFID reader device that captured the scan. Used for device tracking, maintenance, and audit purposes.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanDirection rdf:type rdf:Property ;
    rdfs:label 'Scan Direction' ;
    rdfs:comment 'Direction of asset movement at the time of scan. Indicates whether the asset is entering (inbound), leaving (outbound), or being transferred internally within the facility.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanEventType rdf:type rdf:Property ;
    rdfs:label 'Scan Event Type' ;
    rdfs:comment 'Type of business event that triggered the RFID scan. Categorizes the purpose and context of the scan within the logistics workflow. [ENUM-REF-CANDIDATE: gate_entry|gate_exit|dock_arrival|dock_departure|checkpoint_pass|inventory_count|exception_scan — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanLocationName rdf:type rdf:Property ;
    rdfs:label 'Scan Location Name' ;
    rdfs:comment 'Human-readable name of the facility or checkpoint where the RFID scan occurred.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanLocationType rdf:type rdf:Property ;
    rdfs:label 'Scan Location Type' ;
    rdfs:comment 'Type of facility or checkpoint where the RFID scan occurred. Categorizes the scanning location within the logistics network. [ENUM-REF-CANDIDATE: depot|warehouse|port|gate|checkpoint|dock_door|terminal|hub|cross_dock|customs — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Scan Source System' ;
    rdfs:comment 'Name or identifier of the source system that generated the RFID scan record (e.g., WMS, TMS, gate automation system, IoT platform).' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanStatus rdf:type rdf:Property ;
    rdfs:label 'Scan Status' ;
    rdfs:comment 'Status of the RFID scan operation. Indicates whether the scan was successfully captured and processed or encountered issues.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scan Timestamp' ;
    rdfs:comment 'Date and time when the RFID tag was scanned by the reader device. Represents the real-world event time of the scan occurrence.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scanZone rdf:type rdf:Property ;
    rdfs:label 'Scan Zone' ;
    rdfs:comment 'Specific zone, gate number, dock door, or checkpoint identifier within the facility where the scan occurred (e.g., Gate 5, Dock Door 12, Zone A).' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Signal Strength Dbm' ;
    rdfs:comment 'Radio frequency signal strength measured in decibels-milliwatts (dBm) at the time of scan. Used for quality assessment and reader optimization.' ;
    rdfs:domain ind:RfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Ambient temperature in Celsius recorded by the RFID reader or associated sensor at the time of scan. Used for cold chain monitoring and environmental compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:telematicsEventId rdf:type rdf:Property ;
    rdfs:label 'Telematics Event Id' ;
    rdfs:comment 'Unique identifier for the telematics event record. Primary key for the telematics event stream.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TelematicsEvent .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'Unique identifier of the onboard telematics device (GPS/IoT unit) that generated this event. May be IMEI, MAC address, or vendor-specific serial number.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosticTroubleCode rdf:type rdf:Property ;
    rdfs:label 'Diagnostic Trouble Code' ;
    rdfs:comment 'Standardized engine diagnostic trouble code reported by the onboard diagnostics system. Used for predictive maintenance and fleet health monitoring.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineRpm rdf:type rdf:Property ;
    rdfs:label 'Engine Rpm' ;
    rdfs:comment 'Engine speed in revolutions per minute at the time of the event. Used for fuel efficiency analysis and engine health monitoring.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geofenceEventType rdf:type rdf:Property ;
    rdfs:label 'Geofence Event Type' ;
    rdfs:comment 'Indicates whether the event represents entry into or exit from a geofence zone. Used for automated proof of delivery and dwell time analysis.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harshAccelerationFlag rdf:type rdf:Property ;
    rdfs:label 'Harsh Acceleration Flag' ;
    rdfs:comment 'Boolean indicator (True/False) that a harsh acceleration event was detected based on acceleration threshold. Used for driver behavior scoring and fuel efficiency analysis.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:harshBrakingFlag rdf:type rdf:Property ;
    rdfs:label 'Harsh Braking Flag' ;
    rdfs:comment 'Boolean indicator (True/False) that a harsh braking event was detected based on deceleration threshold. Used for driver behavior scoring and safety analysis.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Type of network connection used by the telematics device to transmit the event. Impacts data latency and coverage in remote areas.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payloadJson rdf:type rdf:Property ;
    rdfs:label 'Payload Json' ;
    rdfs:comment 'Raw JSON payload from the telematics device containing additional vendor-specific sensor data and metadata not parsed into structured fields. Retained for audit and advanced analytics.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStrength rdf:type rdf:Property ;
    rdfs:label 'Signal Strength' ;
    rdfs:comment 'Network signal strength indicator (typically in dBm or percentage). Used to assess connectivity quality and predict data transmission reliability.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureSetpointC rdf:type rdf:Property ;
    rdfs:label 'Temperature Setpoint C' ;
    rdfs:comment 'Target temperature setting for refrigerated units in degrees Celsius. Used to detect temperature excursions and compliance violations.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tollRecordId rdf:type rdf:Property ;
    rdfs:label 'Toll Record Id' ;
    rdfs:comment 'Unique identifier for the toll transaction record. Primary key.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tollAgreementId rdf:type rdf:Property ;
    rdfs:label 'Toll Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Toll costs may be governed by toll service provider agreements or customer contracts specifying toll reimbursement terms. Finance allocates toll costs to correct contract for billing recovery and vali' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:axleCount rdf:type rdf:Property ;
    rdfs:label 'Axle Count' ;
    rdfs:comment 'Number of axles on the vehicle as recorded by the toll system, which may affect the toll rate for heavy vehicles.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:directionOfTravel rdf:type rdf:Property ;
    rdfs:label 'Direction Of Travel' ;
    rdfs:comment 'Direction of travel through the toll point, relevant for directional tolls and route analysis.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Additional surcharge applied to the toll, such as peak-hour surcharge, heavy vehicle surcharge, or environmental levy.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tollAmount rdf:type rdf:Property ;
    rdfs:label 'Toll Amount' ;
    rdfs:comment 'Base toll charge amount before any adjustments, discounts, or surcharges.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tollCity rdf:type rdf:Property ;
    rdfs:label 'Toll City' ;
    rdfs:comment 'City or municipality where the toll was incurred, particularly relevant for urban congestion charges.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollCountryCode rdf:type rdf:Property ;
    rdfs:label 'Toll Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the toll was incurred, supporting multi-country fleet operations and tax reporting.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Toll Invoice Number' ;
    rdfs:comment 'Invoice number issued by the toll operator for account-based or post-paid toll transactions, used for accounts payable reconciliation.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollLocationCode rdf:type rdf:Property ;
    rdfs:label 'Toll Location Code' ;
    rdfs:comment 'Standardized code or identifier for the toll location used for reporting and cost analysis by route segment.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollLocationName rdf:type rdf:Property ;
    rdfs:label 'Toll Location Name' ;
    rdfs:comment 'Name of the specific toll location, road segment, bridge, tunnel, port gate, or congestion zone where the charge was incurred.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollLocationType rdf:type rdf:Property ;
    rdfs:label 'Toll Location Type' ;
    rdfs:comment 'Classification of the toll point: road toll, bridge toll, tunnel toll, port access charge, congestion charge zone, or border crossing fee.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Toll Operator Code' ;
    rdfs:comment 'Standardized code or identifier for the toll operator used for accounts payable processing and vendor reconciliation.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollOperatorName rdf:type rdf:Property ;
    rdfs:label 'Toll Operator Name' ;
    rdfs:comment 'Name of the toll authority, road operator, port authority, or congestion charge agency that levied the charge.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollPlazaLane rdf:type rdf:Property ;
    rdfs:label 'Toll Plaza Lane' ;
    rdfs:comment 'Specific lane number or identifier at the toll plaza where the transaction occurred, used for audit and dispute resolution.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollStateProvince rdf:type rdf:Property ;
    rdfs:label 'Toll State Province' ;
    rdfs:comment 'State, province, or administrative region where the toll was incurred, used for regional cost analysis and compliance reporting.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Toll Transaction Number' ;
    rdfs:comment 'External transaction identifier provided by the toll operator or payment system for reconciliation and audit purposes.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTollAmount rdf:type rdf:Property ;
    rdfs:label 'Total Toll Amount' ;
    rdfs:comment 'Net total toll charge including base toll, surcharges, discounts, and taxes. This is the final amount payable to the toll operator.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the toll transaction occurred, recorded in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). This is the principal business event time for the toll charge.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transponderCode rdf:type rdf:Property ;
    rdfs:label 'Transponder Code' ;
    rdfs:comment 'Unique identifier of the electronic toll collection transponder or RFID tag used for automatic toll payment.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleClass rdf:type rdf:Property ;
    rdfs:label 'Vehicle Class' ;
    rdfs:comment 'Toll operator\'s classification of the vehicle (e.g., Class 2, Class 5, heavy goods vehicle) used to determine the toll rate.' ;
    rdfs:domain ind:TollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or designation of the transport asset for operational identification and reporting purposes.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2EmissionRateGPerKm rdf:type rdf:Property ;
    rdfs:label 'Co2 Emission Rate G Per Km' ;
    rdfs:comment 'Carbon dioxide equivalent (CO2e) emission rate in grams per kilometer. Used for greenhouse gas (GHG) reporting and sustainability KPI (Key Performance Indicator) tracking.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentLocation rdf:type rdf:Property ;
    rdfs:label 'Current Location' ;
    rdfs:comment 'Real-time or last known location of the transport asset. Updated via GPS telematics or manual check-in for visibility and tracking.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the transport asset was retired from active service or decommissioned. Marks the end of the asset\'s operational lifecycle.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalValue rdf:type rdf:Property ;
    rdfs:label 'Disposal Value' ;
    rdfs:comment 'Salvage or resale value realized when the transport asset was disposed of. Used for capital expenditure (CAPEX) recovery tracking and financial reporting.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enginePowerKw rdf:type rdf:Property ;
    rdfs:label 'Engine Power Kw' ;
    rdfs:comment 'Engine power output measured in kilowatts. Indicates performance capability and operational efficiency of the transport asset.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineType rdf:type rdf:Property ;
    rdfs:label 'Engine Type' ;
    rdfs:comment 'Engine model or type specification for the transport asset. Used for maintenance planning, parts sourcing, and performance tracking.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCapacityLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Capacity Liters' ;
    rdfs:comment 'Maximum fuel tank capacity in liters. Used for range calculation and refueling planning.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightMeters rdf:type rdf:Property ;
    rdfs:label 'Height Meters' ;
    rdfs:comment 'Physical height of the transport asset in meters. Critical for bridge clearance, tunnel access, and loading dock compatibility.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homeLocation rdf:type rdf:Property ;
    rdfs:label 'Home Location' ;
    rdfs:comment 'Primary base location or home terminal for the transport asset. Used for route planning and operational assignment.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthMeters rdf:type rdf:Property ;
    rdfs:label 'Length Meters' ;
    rdfs:comment 'Physical length of the transport asset in meters. Used for parking allocation, route clearance, and infrastructure compatibility.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Manufacturer\'s model designation or series name for the transport asset. Identifies specific design and capability specifications.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance service on the transport asset. Critical for operational planning and compliance with safety regulations.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationCountry rdf:type rdf:Property ;
    rdfs:label 'Registration Country' ;
    rdfs:comment 'Three-letter ISO country code where the transport asset is registered. Determines applicable regulatory jurisdiction and compliance requirements.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'Date when the current registration or license for the transport asset expires. Used for compliance tracking and renewal scheduling.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'RFID (Radio Frequency Identification) tag identifier attached to the transport asset for automated identification, access control, and yard management.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teuCapacity rdf:type rdf:Property ;
    rdfs:label 'Teu Capacity' ;
    rdfs:comment 'Container capacity measured in TEU (Twenty-foot Equivalent Unit) for vessels and rail units. Standard measure for container shipping capacity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Percentage of time the transport asset is actively deployed in operations versus idle or available time. Key performance indicator (KPI) for fleet efficiency and return on investment (ROI).' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vinSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Vin Serial Number' ;
    rdfs:comment 'Unique vehicle identification number (VIN) for road vehicles or manufacturer serial number for aircraft, vessels, and rail units. Used for registration, insurance, and theft prevention.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthMeters rdf:type rdf:Property ;
    rdfs:label 'Width Meters' ;
    rdfs:comment 'Physical width of the transport asset in meters. Used for route clearance and infrastructure compatibility assessment.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearOfManufacture rdf:type rdf:Property ;
    rdfs:label 'Year Of Manufacture' ;
    rdfs:comment 'Calendar year when the transport asset was manufactured or built. Used for age-based maintenance scheduling and regulatory compliance.' ;
    rdfs:domain ind:TransportAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tyreRecordId rdf:type rdf:Property ;
    rdfs:label 'Tyre Record Id' ;
    rdfs:comment 'Unique identifier for the tyre record. Primary key for the tyre lifecycle tracking entity.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current operational condition of the tyre: serviceable=fit for continued use, worn=approaching replacement threshold, damaged=requires repair or replacement, retreaded=has undergone retreading process, condemned=unsafe and must be disposed.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTreadDepthMm rdf:type rdf:Property ;
    rdfs:label 'Current Tread Depth Mm' ;
    rdfs:comment 'Most recent tread depth measurement in millimeters. Updated during periodic inspections. Legal minimum is typically 1.6mm for passenger vehicles and 1.0mm for commercial vehicles in most jurisdictions.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fitmentDate rdf:type rdf:Property ;
    rdfs:label 'Fitment Date' ;
    rdfs:comment 'Date when the tyre was fitted or installed onto the vehicle. Marks the start of the tyres active service lifecycle on this asset.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitmentOdometerReading rdf:type rdf:Property ;
    rdfs:label 'Fitment Odometer Reading' ;
    rdfs:comment 'Vehicle odometer reading in kilometers at the time of tyre fitment. Used to calculate tyre mileage and wear rate.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialTreadDepthMm rdf:type rdf:Property ;
    rdfs:label 'Initial Tread Depth Mm' ;
    rdfs:comment 'Tread depth in millimeters measured at the time of fitment. For new tyres, typically 16-18mm for commercial vehicles; for retreaded tyres, typically 12-14mm.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRetreadDate rdf:type rdf:Property ;
    rdfs:label 'Last Retread Date' ;
    rdfs:comment 'Date when the tyre was most recently retreaded. Nullable if the tyre has never been retreaded.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRotationDate rdf:type rdf:Property ;
    rdfs:label 'Last Rotation Date' ;
    rdfs:comment 'Date when the tyre was last rotated to a different position on the vehicle.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadIndex rdf:type rdf:Property ;
    rdfs:label 'Load Index' ;
    rdfs:comment 'Numerical code indicating the maximum load capacity the tyre can safely carry at the speed indicated by its speed rating.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Code indicating the physical position of the tyre on the vehicle: FL=Front Left, FR=Front Right, RL1=Rear Left Outer, RL2=Rear Left Inner, RR1=Rear Right Outer, RR2=Rear Right Inner, SPARE=Spare Tyre.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureRatingPsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Rating Psi' ;
    rdfs:comment 'Manufacturer-recommended tyre inflation pressure in pounds per square inch (PSI) for optimal performance and safety.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseCost rdf:type rdf:Property ;
    rdfs:label 'Purchase Cost' ;
    rdfs:comment 'Original purchase cost of the tyre in the specified currency. Used for CAPEX tracking and cost-per-kilometer analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date when the tyre was purchased or acquired by the fleet operator.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:removalDate rdf:type rdf:Property ;
    rdfs:label 'Removal Date' ;
    rdfs:comment 'Date when the tyre was removed from the vehicle. Nullable until removal occurs. Marks the end of the tyres active service lifecycle on this asset.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:removalOdometerReading rdf:type rdf:Property ;
    rdfs:label 'Removal Odometer Reading' ;
    rdfs:comment 'Vehicle odometer reading in kilometers at the time of tyre removal. Used to calculate total tyre mileage and cost per kilometer.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retreadCount rdf:type rdf:Property ;
    rdfs:label 'Retread Count' ;
    rdfs:comment 'Number of times this tyre casing has been retreaded. Commercial truck tyres can typically be retreaded 2-3 times if the casing remains structurally sound.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retreadVendor rdf:type rdf:Property ;
    rdfs:label 'Retread Vendor' ;
    rdfs:comment 'Name of the vendor or facility that performed the most recent retreading service.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rotation Sequence Number' ;
    rdfs:comment 'Sequential counter tracking how many times this tyre has been rotated to different positions on the vehicle to promote even wear.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Seasonal classification of the tyre indicating optimal operating temperature range and weather conditions.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeSpecification rdf:type rdf:Property ;
    rdfs:label 'Size Specification' ;
    rdfs:comment 'Standard tyre size designation indicating width, aspect ratio, and rim diameter (e.g., 315/80R22.5 for commercial truck tyres).' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedRating rdf:type rdf:Property ;
    rdfs:label 'Speed Rating' ;
    rdfs:comment 'Letter code indicating the maximum speed capability of the tyre (e.g., J=100 km/h, L=120 km/h for commercial vehicles).' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the supplier or vendor from whom the tyre was purchased.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treadPattern rdf:type rdf:Property ;
    rdfs:label 'Tread Pattern' ;
    rdfs:comment 'Tread pattern type or code indicating the design optimized for specific road conditions and applications (e.g., highway, regional, on/off-road).' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tyreMileageKm rdf:type rdf:Property ;
    rdfs:label 'Tyre Mileage Km' ;
    rdfs:comment 'Total distance in kilometers accumulated by this tyre during its service on the vehicle. Calculated as removal_odometer_reading minus fitment_odometer_reading.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tyreType rdf:type rdf:Property ;
    rdfs:label 'Tyre Type' ;
    rdfs:comment 'Construction type of the tyre indicating internal structure and performance characteristics.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturers warranty coverage for this tyre expires. Nullable if no warranty applies.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:greenShipmentCertificateId rdf:type rdf:Property ;
    rdfs:label 'Green Shipment Certificate Id' ;
    rdfs:comment 'Foreign key linking to sustainability.green_shipment_certificate. Business justification: Air waybills commonly receive green certificates when SAF (Sustainable Aviation Fuel) or carbon offsets are applied, supporting CORSIA compliance and customer green logistics programs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GreenShipmentCertificate .

ind:handlingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Handling Facility Id' ;
    rdfs:comment 'Foreign key linking to warehouse.facility. Business justification: Air cargo AWBs often pass through warehouse facilities for break-bulk, customs clearance, and final-mile staging. Tracking handling_facility_id enables facility-level AWB volume reporting, dwell time ' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:primaryAirCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Air Customer Account Id' ;
    rdfs:comment 'Reference to the shipper (exporter/sender) party account responsible for tendering the cargo. Links to the shipper profile in the customer domain. Represents the PARTY_REFERENCE for this transaction.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time the cargo arrived at the destination airport. Used for OTD (On-Time Delivery) KPI calculation, SLA compliance reporting, and claims assessment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:awbStatus rdf:type rdf:Property ;
    rdfs:label 'Awb Status' ;
    rdfs:comment 'Current lifecycle status of the air waybill. DRAFT: document being prepared; ISSUED: AWB formally issued and accepted by carrier; ACCEPTED: cargo accepted at origin; IN_TRANSIT: cargo in movement; ARRIVED: cargo arrived at destination airport; DELIVERED: cargo delivered to consignee; CANCELLED: AWB voided. [ENUM-REF-CANDIDATE: DRAFT|ISSUED|ACCEPTED|IN_TRANSIT|ARRIVED|DELIVERED|CANCELLED — promote to reference product]' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awbType rdf:type rdf:Property ;
    rdfs:label 'Awb Type' ;
    rdfs:comment 'Indicates whether this record represents a Master Air Waybill (MAWB) issued by the airline, a House Air Waybill (HAWB) issued by the freight forwarder, or a DIRECT AWB for a single-shipper direct airline shipment.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesCollectOrPrepaid rdf:type rdf:Property ;
    rdfs:label 'Charges Collect Or Prepaid' ;
    rdfs:comment 'Indicates whether freight charges are to be paid by the shipper at origin (PREPAID) or by the consignee at destination (COLLECT). Determines billing party and accounts receivable assignment.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueForCarriage rdf:type rdf:Property ;
    rdfs:label 'Declared Value For Carriage' ;
    rdfs:comment 'The value of the shipment declared by the shipper for the purpose of determining the carrier\'s liability in case of loss or damage. May be \'NVD\' (No Value Declared) in which case this field is null. Governs maximum liability per IATA conditions of contract.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueForCustoms rdf:type rdf:Property ;
    rdfs:label 'Declared Value For Customs' ;
    rdfs:comment 'The customs value of the shipment declared by the shipper for import duty and tax assessment at the destination country. Used by Descartes Customs for duty calculation and customs entry filing.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'Destination Airport Code' ;
    rdfs:comment '3-letter IATA airport code for the final destination airport where the cargo is to be delivered to the consignee (e.g., LAX, SIN, LHR). Used for routing, customs filing, and rate determination.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eta rdf:type rdf:Property ;
    rdfs:label 'Eta' ;
    rdfs:comment 'Estimated date and time of arrival of the carrying aircraft at the destination airport. Used for consignee notification, customs pre-arrival filing, and OTD performance measurement. Updated dynamically from FourKites.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:etd rdf:type rdf:Property ;
    rdfs:label 'Etd' ;
    rdfs:comment 'Estimated date and time of departure of the carrying aircraft from the origin airport. Used for shipment tracking, customer notifications, and SLA monitoring via FourKites.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstTransitAirportCode rdf:type rdf:Property ;
    rdfs:label 'First Transit Airport Code' ;
    rdfs:comment '3-letter IATA airport code for the first intermediate transit/transfer point in the routing, if applicable. Null for direct flights. Used for multi-leg routing documentation on the AWB.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightDate rdf:type rdf:Property ;
    rdfs:label 'Flight Date' ;
    rdfs:comment 'Scheduled departure date of the primary carrying flight. Used for booking confirmation, capacity planning, and ETD/ETA calculations.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total base freight charge for the shipment calculated as chargeable weight multiplied by the rate per kg, in the billing currency. Represents the primary revenue line for the air freight service. Used for revenue recognition per IFRS 15.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iataAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Iata Airline Code' ;
    rdfs:comment 'The 3-digit IATA numeric airline prefix code identifying the issuing carrier (e.g., 176 for Emirates, 057 for Lufthansa Cargo). Forms the first segment of the MAWB number and identifies the contracting airline.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Isf Filing Number' ;
    rdfs:comment 'The US Customs and Border Protection Importer Security Filing (ISF, also known as 10+2) reference number. Required for ocean and air cargo imports into the United States for advance security screening.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the air waybill was issued in SAP TM. Provides sub-day precision for operational sequencing and SLA measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originAirportCode rdf:type rdf:Property ;
    rdfs:label 'Origin Airport Code' ;
    rdfs:comment '3-letter IATA airport code for the airport of departure where the cargo is tendered to the airline (e.g., DXB, FRA, JFK). Used for routing, rate determination, and regulatory reporting.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otherChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Other Charges Amount' ;
    rdfs:comment 'Total of all ancillary charges beyond the base freight charge, including fuel surcharges, security surcharges, terminal handling charges (THC), and special handling fees. Aggregated from the charges breakdown for billing purposes.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piecesCount rdf:type rdf:Property ;
    rdfs:label 'Pieces Count' ;
    rdfs:comment 'Total number of individual pieces, packages, or handling units included in this shipment as declared on the AWB. Used for cargo acceptance, loading, and delivery verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Pod Signatory Name' ;
    rdfs:comment 'Name of the individual who signed for receipt of the cargo at delivery, as captured on the electronic or paper proof of delivery (ePOD). Used for delivery confirmation and dispute resolution.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pod Timestamp' ;
    rdfs:comment 'Date and time when the cargo was confirmed as delivered to the consignee and proof of delivery (POD) was captured. Used for OTD measurement, SLA compliance, and triggering final invoice settlement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateClass rdf:type rdf:Property ;
    rdfs:label 'Rate Class' ;
    rdfs:comment 'IATA rate class code indicating the type of rate applied to this shipment (e.g., N=Normal, Q=Quantity, M=Minimum, B=Basic, C=Specific Commodity, E=Express, R=Reduced, S=Surcharge, U=Unit Load Device, X=Express). Determines the applicable tariff structure. [ENUM-REF-CANDIDATE: N|Q|M|B|C|E|R|S|U|X — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerKg rdf:type rdf:Property ;
    rdfs:label 'Rate Per Kg' ;
    rdfs:comment 'The agreed freight rate applied per kilogram of chargeable weight for this shipment, in the billing currency. Commercially sensitive pricing data used for revenue recognition and freight audit.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondTransitAirportCode rdf:type rdf:Property ;
    rdfs:label 'Second Transit Airport Code' ;
    rdfs:comment '3-letter IATA airport code for the second intermediate transit/transfer point in the routing, if applicable. Null for direct or single-transit flights. Supports complex multi-leg air freight routing.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charge Amount' ;
    rdfs:comment 'Grand total of all charges on the AWB including base freight charge and all other charges (surcharges, fees, taxes). Represents the total amount due from the shipper or consignee. Used for invoice generation and accounts receivable.' ;
    rdfs:domain ind:AirWaybill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Date' ;
    rdfs:comment 'Actual date the vessel departed from the port of loading. Used for transit time calculation, carrier performance measurement, and customs export record finalization.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amsFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Ams Filing Number' ;
    rdfs:comment 'US Customs and Border Protection (CBP) Automated Manifest System (AMS) filing reference number. Required for all ocean shipments destined for or transiting through US ports. Must be filed 24 hours prior to vessel loading under the 24-Hour Advance Manifest Rule.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolStatus rdf:type rdf:Property ;
    rdfs:label 'Bol Status' ;
    rdfs:comment 'Current lifecycle state of the bill of lading document. Draft indicates pre-issuance; issued means the original has been released to the shipper; released indicates cargo release authorized; surrendered means original returned to carrier; amended reflects post-issuance corrections; cancelled indicates the BOL is void. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS minimum category.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolType rdf:type rdf:Property ;
    rdfs:label 'Bol Type' ;
    rdfs:comment 'Classification of the bill of lading indicating whether it is a master (MBL), house (HBL), seaway, straight (non-negotiable), to-order (negotiable), or surrendered BOL. Determines negotiability and title transfer rules. [ENUM-REF-CANDIDATE: master|house|seaway|straight|order|surrender — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScac rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac' ;
    rdfs:comment 'Four-letter Standard Carrier Alpha Code (SCAC) identifying the ocean carrier (vessel operating common carrier) that issued the master bill of lading. Used for AMS filing, EDI transactions, and carrier performance tracking.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Base ocean freight charge amount as stated on the bill of lading, before surcharges. Expressed in the currency indicated by freight_currency_code. Used for freight invoice reconciliation, revenue recognition in SAP S/4HANA Finance, and freight audit in Oracle TMS. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET minimum category (base amount component).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the freight charges are denominated (e.g., USD, EUR, CNY). Required for multi-currency freight invoice processing and foreign exchange revaluation in SAP S/4HANA Finance. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET minimum category (currency code component).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Surcharge Amount' ;
    rdfs:comment 'Total surcharge amount applied to the base freight, including Bunker Adjustment Factor (BAF), General Rate Increase (GRI), Terminal Handling Charge (THC), and other accessorial charges. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET minimum category (adjustment component).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Indicates who is responsible for paying the ocean freight charges: prepaid (shipper pays), collect (consignee pays), or third party (a nominated third party pays). Drives accounts receivable and accounts payable processing in SAP S/4HANA Finance.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgClass rdf:type rdf:Property ;
    rdfs:label 'Imdg Class' ;
    rdfs:comment 'IMDG hazard class of the dangerous goods (e.g., Class 1 Explosives, Class 3 Flammable Liquids, Class 6.1 Toxic Substances). Populated only when is_hazardous is true. Drives stowage segregation, emergency procedures, and port authority notifications. [ENUM-REF-CANDIDATE: 1|2|3|4|5|6|7|8|9 — promote to reference product]' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Flag indicating whether the cargo contains dangerous goods as classified under the IMDG Code. When true, additional IMDG declarations, special stowage requirements, and emergency response information are mandatory.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNegotiable rdf:type rdf:Property ;
    rdfs:label 'Is Negotiable' ;
    rdfs:comment 'Flag indicating whether the bill of lading is negotiable (to-order) or non-negotiable (straight/waybill). A negotiable BOL serves as a document of title and can be transferred by endorsement; a non-negotiable BOL cannot be used to transfer title.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalBolCount rdf:type rdf:Property ;
    rdfs:label 'Original Bol Count' ;
    rdfs:comment 'Number of original signed copies of the bill of lading issued to the shipper (typically 3). All originals must be surrendered to the carrier for cargo release when the BOL is negotiable. Used for document control and letter of credit compliance.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placeOfDelivery rdf:type rdf:Property ;
    rdfs:label 'Place Of Delivery' ;
    rdfs:comment 'Final destination where the carrier delivers the cargo to the consignee, which may differ from the port of discharge (e.g., an inland CFS, ICD, or door delivery address). Defines the end of the carrier\'s responsibility under the contract of carriage.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfIssue rdf:type rdf:Property ;
    rdfs:label 'Place Of Issue' ;
    rdfs:comment 'City and country where the bill of lading was issued by the carrier or NVOCC. Required for letter of credit compliance and legal jurisdiction determination in case of disputes.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfReceipt rdf:type rdf:Property ;
    rdfs:label 'Place Of Receipt' ;
    rdfs:comment 'Location where the carrier takes custody of the cargo, which may differ from the port of loading (e.g., an inland container depot (ICD) or container freight station (CFS)). Defines the start of the carrier\'s responsibility under the contract of carriage.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfDischarge rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge' ;
    rdfs:comment 'UN/LOCODE of the port where the cargo is discharged from the ocean vessel. Represents the destination port for the ocean leg. Used for customs import filing, terminal handling charge (THC) calculation, and delivery planning.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoading rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading' ;
    rdfs:comment 'UN/LOCODE of the port where the cargo is loaded onto the ocean vessel. Represents the origin port for the ocean leg of the shipment. Used for freight rate calculation, customs export filing, and carrier scheduling.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperReference rdf:type rdf:Property ;
    rdfs:label 'Shipper Reference' ;
    rdfs:comment 'Shipper\'s own internal reference number or purchase order number associated with this shipment. Printed on the bill of lading for cross-referencing with the shipper\'s ERP or order management system. Facilitates EDI reconciliation.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teuCount rdf:type rdf:Property ;
    rdfs:label 'Teu Count' ;
    rdfs:comment 'Total number of Twenty-foot Equivalent Units (TEUs) represented by the containers on this bill of lading. A 20-foot container = 1 TEU; a 40-foot container = 2 TEUs. Used for vessel capacity utilization, port statistics, and freight revenue reporting.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Total Freight Amount' ;
    rdfs:comment 'Total freight charges payable as stated on the bill of lading, being the sum of the base freight amount and all applicable surcharges. Used for freight invoice generation, letter of credit compliance, and revenue reporting. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET minimum category (net total component).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Booking Network Node Id' ;
    rdfs:comment 'Reference to the network node entity representing the pickup or origin point for this booking (e.g., shipper warehouse, Container Freight Station (CFS), Inland Container Depot (ICD), or airport/seaport terminal).' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:customerCarbonReportId rdf:type rdf:Property ;
    rdfs:label 'Customer Carbon Report Id' ;
    rdfs:comment 'Foreign key linking to sustainability.customer_carbon_report. Business justification: Booking-level carbon estimates feed into customer carbon reports for forward-looking emissions forecasting and proactive carbon management in customer sustainability planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerCarbonReport .

ind:destinationNodeNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Node Network Node Id' ;
    rdfs:comment 'Reference to the network node entity representing the delivery or destination point for this booking (e.g., consignee warehouse, CFS, ICD, or airport/seaport terminal).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:originFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Id' ;
    rdfs:comment 'Foreign key linking to warehouse.facility. Business justification: Bookings for LCL/air cargo often originate from warehouse consolidation facilities (CFS). Tracking origin_facility_id enables facility-level capacity planning, dwell time analysis, and cargo handoff r' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Foreign key linking to freight.freight_quote. Business justification: A booking may be created based on a freight quote. This FK tracks the quote-to-booking lineage. Nullable for direct bookings not based on a quote. No reverse FK exists, no bidirectional violation.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:bookingDate rdf:type rdf:Property ;
    rdfs:label 'Booking Date' ;
    rdfs:comment 'The principal real-world event timestamp recording when the booking request was formally submitted by the shipper or freight forwarder. Distinct from system audit timestamps. Used for SLA measurement and capacity allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle state of the freight booking. Tracks progression from initial submission through carrier confirmation or rejection to execution. \'executed\' indicates a freight order has been raised against this booking.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierBookingRef rdf:type rdf:Property ;
    rdfs:label 'Carrier Booking Ref' ;
    rdfs:comment 'The booking confirmation reference number issued by the carrier upon space reservation acceptance. For ocean shipments this is the carrier\'s booking number; for air it may be the airline\'s booking code. Used for cross-referencing with carrier systems.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoods rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods' ;
    rdfs:comment 'Indicates whether the cargo contains dangerous goods or hazardous materials requiring special handling, documentation, and regulatory compliance. True triggers IMDG Code compliance checks for ocean, ICAO Technical Instructions for air, and ADR for road transport.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedFreightCharge rdf:type rdf:Property ;
    rdfs:label 'Estimated Freight Charge' ;
    rdfs:comment 'Estimated base freight charge for this booking in the billing currency, calculated at time of booking based on applicable rate tariff, chargeable weight, and lane. Excludes surcharges (BAF, GRI, THC). Used for shipper quotation and revenue forecasting.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nvoccArrangement rdf:type rdf:Property ;
    rdfs:label 'Nvocc Arrangement' ;
    rdfs:comment 'Indicates whether this booking is executed under a Non-Vessel Operating Common Carrier (NVOCC) arrangement, where Transport Shipping acts as a carrier to the shipper but contracts with an actual vessel operator. Relevant for FMC tariff filing and House Bill of Lading (HBL) issuance.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known alphanumeric booking reference number assigned at the time of booking submission. Communicated to the shipper and used across EDI, API, and manual channels for tracking and correspondence. Maps to Oracle TMS booking reference field.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date on which the shipper requests cargo to be delivered to the consignee at the destination. Basis for SLA commitment and On-Time Delivery (OTD) performance measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Requested Pickup Date' ;
    rdfs:comment 'The date on which the shipper requests cargo to be collected from the origin location. Used for capacity planning, driver/vehicle scheduling, and SLA commitment calculation.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spaceConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Space Confirmation Date' ;
    rdfs:comment 'Timestamp when the carrier confirmed space reservation for this booking. Null if space has not yet been confirmed. Used for SLA tracking and booking lead-time analytics.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spaceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Space Confirmed' ;
    rdfs:comment 'Indicates whether the carrier has confirmed space reservation for this booking. True when the carrier has issued a booking confirmation; False when the booking is pending carrier acceptance or has been rejected.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightCarrierAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Freight Carrier Assignment Id' ;
    rdfs:comment 'Unique identifier for the carrier assignment record. Primary key.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightCarrierAssignment .

ind:carrierBuyRateId rdf:type rdf:Property ;
    rdfs:label 'Carrier Buy Rate Id' ;
    rdfs:comment 'Foreign key linking to pricing.carrier_buy_rate. Business justification: Carrier assignments use negotiated carrier buy rates for cost calculation and margin analysis. Carrier_buy_rate_id enables actual cost tracking at assignment level, supports margin calculation (sell r' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierBuyRate .

ind:primaryFreightEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Freight Employee Id' ;
    rdfs:comment 'Reference to the user or system account that created this carrier assignment. Links to the workforce or system user entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:carrierBookingReference rdf:type rdf:Property ;
    rdfs:label 'Carrier Booking Reference' ;
    rdfs:comment 'Booking reference number or confirmation code provided by the carrier upon acceptance. Used for tracking and coordination with carrier systems.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierIataCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Iata Code' ;
    rdfs:comment 'IATA two-letter or three-character airline designator code for air carriers. Used for air waybill (AWB) and flight operations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierInstructions rdf:type rdf:Property ;
    rdfs:label 'Carrier Instructions' ;
    rdfs:comment 'Special instructions or requirements specific to this carrier assignment, such as handling requirements, delivery windows, contact information, or operational constraints.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScacCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Code' ;
    rdfs:comment 'Standard Carrier Alpha Code uniquely identifying the carrier in North American freight operations. 2-4 uppercase letters assigned by the National Motor Freight Traffic Association (NMFTA).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'Date when the carrier confirmed acceptance of the freight assignment. Null if not yet confirmed.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Precise timestamp when the carrier confirmed the assignment. Used for Service Level Agreement (SLA) tracking and carrier performance measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsBrokerRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Required' ;
    rdfs:comment 'Boolean flag indicating whether this carrier assignment requires customs brokerage services for cross-border shipments. Integrates with Descartes Customs system.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Estimated date when the carrier will deliver the freight to the destination. Used for customer communication and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Pickup Date' ;
    rdfs:comment 'Estimated date when the carrier will pick up the freight from the origin location. Used for planning and coordination.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isIntermodal rdf:type rdf:Property ;
    rdfs:label 'Is Intermodal' ;
    rdfs:comment 'Boolean flag indicating whether this carrier assignment is part of an intermodal transport chain involving multiple modes (e.g., ocean to rail to road).' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryCarrier rdf:type rdf:Property ;
    rdfs:label 'Is Primary Carrier' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary carrier assignment for the freight order. True if primary, False if backup or secondary carrier.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:masterAwbNumber rdf:type rdf:Property ;
    rdfs:label 'Master Awb Number' ;
    rdfs:comment 'Master Air Waybill number issued by the air carrier for air freight assignments. Format: 3-digit airline code followed by 8-digit serial number.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterBolNumber rdf:type rdf:Property ;
    rdfs:label 'Master Bol Number' ;
    rdfs:comment 'Master Bill of Lading number issued by the ocean carrier or Non-Vessel Operating Common Carrier (NVOCC) for ocean freight assignments.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionCriteria rdf:type rdf:Property ;
    rdfs:label 'Selection Criteria' ;
    rdfs:comment 'Business criteria or rules applied during carrier selection, such as lowest cost, fastest transit, preferred carrier, service level, or capacity availability.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionMethod rdf:type rdf:Property ;
    rdfs:label 'Selection Method' ;
    rdfs:comment 'Method used to select this carrier: manual selection by planner, automated rule-based selection, optimization algorithm, spot market quote, or pre-negotiated contract assignment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCarrierCost rdf:type rdf:Property ;
    rdfs:label 'Total Carrier Cost' ;
    rdfs:comment 'Total cost payable to the carrier including base freight charge, fuel surcharge, and all accessorial charges. Used for freight audit and cost reconciliation.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Tracking Enabled' ;
    rdfs:comment 'Boolean flag indicating whether real-time shipment tracking is enabled for this carrier assignment via integration with FourKites or carrier tracking systems.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleCount rdf:type rdf:Property ;
    rdfs:label 'Vehicle Count' ;
    rdfs:comment 'Number of vehicles (trucks, trailers, railcars) assigned by the carrier for this freight order. Applicable for road and rail transport modes.' ;
    rdfs:domain ind:FreightCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cfsOperationId rdf:type rdf:Property ;
    rdfs:label 'Cfs Operation Id' ;
    rdfs:comment 'Unique identifier for the CFS operation transaction. Primary key for the CFS operation record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CfsOperation .

ind:cfsFacilityId rdf:type rdf:Property ;
    rdfs:label 'Cfs Facility Id' ;
    rdfs:comment 'Reference to the CFS facility where the operation is performed. Identifies the physical location handling the cargo.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:consolidationId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Id' ;
    rdfs:comment 'Foreign key linking to freight.consolidation. Business justification: CFS (Container Freight Station) operations handle LCL cargo for consolidations (stuffing, destuffing, tally, storage). Many CFS operations for one consolidation. Nullable when CFS operation is for ind' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consolidation .

ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Employee identifier of the CFS operator who performed the cargo handling. Links operation to workforce management records.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to warehouse.storage_location. Business justification: CFS operations place cargo in specific warehouse storage locations during consolidation/deconsolidation. Tracking storage_location_id enables location-level cargo traceability, storage utilization ana' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:cargoConditionOnReceipt rdf:type rdf:Property ;
    rdfs:label 'Cargo Condition On Receipt' ;
    rdfs:comment 'Physical condition assessment of cargo when received at the CFS facility. Documents any pre-existing damage or discrepancies for liability purposes.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cargo Receipt Timestamp' ;
    rdfs:comment 'Date and time when cargo was received at the CFS facility. Establishes custody transfer and storage period start for demurrage calculation.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerCutoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Container Cutoff Timestamp' ;
    rdfs:comment 'Deadline by which the container must be stuffed and ready for pickup or vessel loading. Critical for export consolidation scheduling and carrier coordination.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Inspection Required' ;
    rdfs:comment 'Indicates whether the cargo is flagged for customs examination at the CFS facility. Affects operation timing and coordination with customs authorities.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsInspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customs Inspection Timestamp' ;
    rdfs:comment 'Date and time when customs inspection was performed at the CFS facility. Records compliance with customs clearance requirements.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customs Release Timestamp' ;
    rdfs:comment 'Date and time when cargo was released by customs authorities for further handling or delivery. Marks clearance for onward movement.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:demurrageAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Demurrage Accrued Amount' ;
    rdfs:comment 'Total demurrage charges accrued for cargo storage beyond the free period. Calculated based on storage duration and applicable daily rates.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demurrageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Demurrage Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for demurrage charges. Specifies the currency in which storage fees are denominated.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Detailed description of any discrepancies or exceptions noted during the CFS operation. Documents issues for claims, investigations, and corrective action.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyNoted rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Noted' ;
    rdfs:comment 'Indicates whether any discrepancies were identified during the CFS operation (e.g., piece count mismatch, damage, missing items). Triggers exception handling workflow.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentUsed rdf:type rdf:Property ;
    rdfs:label 'Equipment Used' ;
    rdfs:comment 'Description of material handling equipment used during the CFS operation (e.g., forklift, pallet jack, crane). Supports equipment utilization tracking and maintenance scheduling.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeStorageDays rdf:type rdf:Property ;
    rdfs:label 'Free Storage Days' ;
    rdfs:comment 'Number of days of complimentary storage allowed before demurrage charges begin to accrue. Typically defined by carrier or CFS facility terms.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlingChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Handling Charge Amount' ;
    rdfs:comment 'CFS handling fee charged for stuffing, destuffing, or other cargo handling services. Separate from demurrage and transportation charges.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingChargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Handling Charge Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for CFS handling charges. Specifies the currency in which handling fees are denominated.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardousCargo rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Cargo' ;
    rdfs:comment 'Indicates whether the cargo handled in this operation is classified as dangerous goods requiring special handling, labeling, and documentation per IMDG or IATA DGR.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation End Timestamp' ;
    rdfs:comment 'Date and time when the CFS operation was completed. Records the actual completion of all cargo handling activities.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'Business identifier for the CFS operation. Human-readable reference number used for tracking and communication.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation Start Timestamp' ;
    rdfs:comment 'Date and time when the CFS operation commenced. Records the actual start of physical cargo handling activities.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the CFS operation. Tracks the operational workflow state from scheduling through completion.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'Type of CFS operation being performed. Stuffing is loading cargo into containers for export; destuffing is unloading containers for import; cross-docking is direct transfer without storage; consolidation combines multiple LCL shipments; deconsolidation separates consolidated cargo; transloading transfers cargo between transport modes.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Name of the individual or team responsible for executing the CFS operation. Used for accountability and quality tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Documentation Url' ;
    rdfs:comment 'URL or file path to photographic evidence captured during the CFS operation. Used for damage claims, condition verification, and audit trails.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageEndDate rdf:type rdf:Property ;
    rdfs:label 'Storage End Date' ;
    rdfs:comment 'Date when cargo storage period ends at the CFS facility. Marks the end of storage liability and demurrage accrual.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageStartDate rdf:type rdf:Property ;
    rdfs:label 'Storage Start Date' ;
    rdfs:comment 'Date when cargo storage period begins at the CFS facility. Used to calculate storage duration and demurrage charges.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tallyPieceCount rdf:type rdf:Property ;
    rdfs:label 'Tally Piece Count' ;
    rdfs:comment 'Verified count of individual pieces or packages handled in this CFS operation. Used for reconciliation against shipping documents and cargo manifests.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Celsius' ;
    rdfs:comment 'Required storage and transport temperature for temperature-sensitive cargo, measured in degrees Celsius. Applicable for reefer and pharmaceutical shipments.' ;
    rdfs:domain ind:CfsOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationCarrierId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Carrier Id' ;
    rdfs:comment 'Identifier of the ocean carrier, airline, or surface carrier assigned to transport the consolidation. For NVOCC operations, this is the underlying vessel or flight operator.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:consolidationNvoccOperatorCarrierId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Nvocc Operator Carrier Id' ;
    rdfs:comment 'Identifier of the NVOCC or freight forwarder operating the consolidation. For direct carrier consolidations, this may be null.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:destinationCfsFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Cfs Facility Id' ;
    rdfs:comment 'Identifier of the destination CFS or ICD facility where the consolidation will be deconsolidated and cargo distributed. Links to warehouse or facility master data.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:originCfsFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Cfs Facility Id' ;
    rdfs:comment 'Identifier of the origin CFS or ICD facility where cargo is received and consolidated. Links to warehouse or facility master data.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:originHubGatewayId rdf:type rdf:Property ;
    rdfs:label 'Origin Hub Gateway Id' ;
    rdfs:comment 'Foreign key linking to network.hub_gateway. Business justification: Consolidations are built at specific hub/gateway facilities (CFS, container terminals, air cargo terminals). Operations track which hub handled consolidation for dwell time analysis, handling cost all' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HubGateway .

ind:safProcurementId rdf:type rdf:Property ;
    rdfs:label 'Saf Procurement Id' ;
    rdfs:comment 'Foreign key linking to sustainability.saf_procurement. Business justification: SAF (Sustainable Aviation Fuel) procurement is allocated to specific air consolidations for CORSIA compliance, customer green product delivery, and book-and-claim certificate tracking in aviation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafProcurement .

ind:actualArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Datetime' ;
    rdfs:comment 'Actual arrival date and time when the carrier arrived at the destination port.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cargoCutoffDatetime rdf:type rdf:Property ;
    rdfs:label 'Cargo Cutoff Datetime' ;
    rdfs:comment 'Latest date and time by which cargo must be received at the origin CFS facility to be included in this consolidation.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consolidationStatus rdf:type rdf:Property ;
    rdfs:label 'Consolidation Status' ;
    rdfs:comment 'Current lifecycle status of the consolidation from planning through deconsolidation at destination. [ENUM-REF-CANDIDATE: planned|booking_open|cargo_receiving|closed|departed|in_transit|arrived|deconsolidated — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationType rdf:type rdf:Property ;
    rdfs:label 'Consolidation Type' ;
    rdfs:comment 'Type of consolidation based on transport mode. Ocean LCL (Less Than Container Load) groups multiple shippers cargo into a single FCL container. Air groupage consolidates shipments into a single ULD (Unit Load Device). Road and rail groupage combine multiple LTL shipments.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerSizeType rdf:type rdf:Property ;
    rdfs:label 'Container Size Type' ;
    rdfs:comment 'ISO container size and type code for ocean consolidations. 20GP = 20-foot General Purpose, 40GP = 40-foot General Purpose, 40HC = 40-foot High Cube, 45HC = 45-foot High Cube. Null for non-containerized modes.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsDangerousGoods rdf:type rdf:Property ;
    rdfs:label 'Contains Dangerous Goods' ;
    rdfs:comment 'Indicates whether the consolidation contains any dangerous goods (hazardous materials) requiring special handling and documentation per IMDG or IATA DGR.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Contains Temperature Controlled' ;
    rdfs:comment 'Indicates whether the consolidation contains temperature-sensitive cargo requiring reefer container or climate-controlled handling.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deconsolidationCompleteDatetime rdf:type rdf:Property ;
    rdfs:label 'Deconsolidation Complete Datetime' ;
    rdfs:comment 'Date and time when all cargo was deconsolidated and available for onward delivery or pickup.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deconsolidationStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Deconsolidation Start Datetime' ;
    rdfs:comment 'Date and time when deconsolidation operations began at the destination CFS facility.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Datetime' ;
    rdfs:comment 'Estimated arrival date and time at the destination port. Updated based on carrier tracking and real-time visibility data.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightChargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for freight charges (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Datetime' ;
    rdfs:comment 'Scheduled departure date and time of the carrier vessel, flight, or vehicle transporting the consolidation from origin port.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalChargeableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Chargeable Weight Kg' ;
    rdfs:comment 'Total chargeable weight for the consolidation, calculated as the greater of gross weight or volumetric weight (volume * dimensional weight factor). Used for freight charge calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFreightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Freight Charge Amount' ;
    rdfs:comment 'Total freight charges for the consolidation, including base ocean or air freight, BAF (Bunker Adjustment Factor), GRI (General Rate Increase), THC (Terminal Handling Charge), and other surcharges.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPieceCount rdf:type rdf:Property ;
    rdfs:label 'Total Piece Count' ;
    rdfs:comment 'Total number of individual pieces or packages across all shipments in the consolidation.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Total Shipment Count' ;
    rdfs:comment 'Number of individual shipper shipments (house shipments) consolidated into this master consolidation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uldNumber rdf:type rdf:Property ;
    rdfs:label 'Uld Number' ;
    rdfs:comment 'IATA ULD identifier for air groupage consolidations. Format: 3-letter ULD type code + 5-digit serial + 2-letter owner code. Null for non-air consolidations.' ;
    rdfs:domain ind:Consolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightChargeId rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Id' ;
    rdfs:comment 'Unique identifier for the freight charge line item. Primary key for this entity.' ;
    rdfs:domain ind:FreightCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightLegId rdf:type rdf:Property ;
    rdfs:label 'Freight Leg Id' ;
    rdfs:comment 'Foreign key linking to freight.freight_leg. Business justification: Freight charges are often leg-specific (e.g., per-leg freight charge, BAF, GRI, THC, handling charges at interchange points). Many charges for one leg. Nullable when charge is at order or shipment lev' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightLeg .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'The unique code identifying the carrier or service provider to whom this charge is payable or from whom the charge originates. Used for carrier settlement and cost allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCode rdf:type rdf:Property ;
    rdfs:label 'Charge Code' ;
    rdfs:comment 'Standardized code identifying the type of charge. Used for charge classification and billing automation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeStatus rdf:type rdf:Property ;
    rdfs:label 'Charge Status' ;
    rdfs:comment 'The current lifecycle status of this charge. Tracks whether the charge is pending approval, approved for billing, already invoiced, paid, under dispute, waived, or cancelled. [ENUM-REF-CANDIDATE: pending|approved|invoiced|paid|disputed|waived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of the freight charge component. Identifies whether this is a base freight rate or a specific surcharge type such as Bunker Adjustment Factor (BAF), General Rate Increase (GRI), Terminal Handling Charge (THC), fuel surcharge, peak season surcharge, port congestion surcharge, documentation fee, or other mode-specific and service-specific charges. [ENUM-REF-CANDIDATE: base_freight|BAF|GRI|THC|fuel_surcharge|peak_season_surcharge|port_congestion_surcharge|documentation_fee|customs_clearance_fee|handling_charge|storage_charge|demurrage|detention|chassis_fee|inland_haulage|security_surcharge|war_risk_surcharge|currency_adjustment_factor|low_sulfur_surcharge|emergency_bunker_surcharge|container_service_charge — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Boolean flag indicating whether this charge should be included in customer invoicing. True if the charge is billable to the customer, false if it is an internal cost or non-billable item.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Boolean flag indicating whether this charge is subject to tax (VAT, GST, sales tax). Used to determine if tax calculation should be applied during invoicing.' ;
    rdfs:domain ind:FreightCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax classification code applicable to this charge. Used by the financial system to determine the correct tax rate and treatment. Null if the charge is not taxable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightExceptionId rdf:type rdf:Property ;
    rdfs:label 'Freight Exception Id' ;
    rdfs:comment 'Unique identifier for the freight exception record. Primary key.' ;
    rdfs:domain ind:FreightException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Links exception to responsible employee for resolution. Core exception management workflow requires clear ownership assignment. Enables workload balancing, SLA tracking, and performance measurement. R' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgedBy rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By' ;
    rdfs:comment 'Name or identifier of the person or system that acknowledged the exception.' ;
    rdfs:domain ind:FreightException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the exception was acknowledged by operations team or responsible party.' ;
    rdfs:domain ind:FreightException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:awbOrBolNumber rdf:type rdf:Property ;
    rdfs:label 'Awb Or Bol Number' ;
    rdfs:comment 'Transport document number associated with the exception. AWB for air shipments, BOL for ocean/road shipments.' ;
    rdfs:domain ind:FreightException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Claim Filed Flag' ;
    rdfs:comment 'Indicates whether a cargo claim was filed as a result of this exception. True if claim filed, false otherwise.' ;
    rdfs:domain ind:FreightException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationChannel rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Channel' ;
    rdfs:comment 'Communication channel used to notify customer of the exception. Includes email, SMS, customer portal, phone, and EDI.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Indicates whether the customer has been notified of the exception. True if notification sent, false otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delayDurationHours rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Hours' ;
    rdfs:comment 'Total delay caused by the exception, measured in hours. Calculated as difference between original ETA and revised ETA.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the exception was first detected or reported. Primary business event timestamp for this transaction.' ;
    rdfs:domain ind:FreightException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionLocation rdf:type rdf:Property ;
    rdfs:label 'Detection Location' ;
    rdfs:comment 'Geographic location or facility where the exception was detected. May be port, airport, warehouse, or in-transit location.' ;
    rdfs:domain ind:FreightException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Origin or channel through which the exception was identified. Includes system automated alerts, carrier notifications, customer reports, warehouse scans, customs alerts, manual inspections, IoT sensors, and GPS tracking. [ENUM-REF-CANDIDATE: system_automated|carrier_notification|customer_report|warehouse_scan|customs_alert|manual_inspection|iot_sensor|gps_tracking — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCategory rdf:type rdf:Property ;
    rdfs:label 'Exception Category' ;
    rdfs:comment 'High-level grouping of exception types for reporting and analysis. Categories include operational, carrier, customs, documentation, cargo, infrastructure, and force majeure. [ENUM-REF-CANDIDATE: operational|carrier|customs|documentation|cargo|infrastructure|force_majeure — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Business-facing unique identifier for the exception, used in customer communications and tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightExceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Freight Exception Description' ;
    rdfs:comment 'Detailed narrative description of the exception event, including circumstances, impact, and any immediate actions taken.' ;
    rdfs:domain ind:FreightException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedLegSequence rdf:type rdf:Property ;
    rdfs:label 'Impacted Leg Sequence' ;
    rdfs:comment 'Sequence number of the freight order leg affected by this exception. Null if exception impacts entire order.' ;
    rdfs:domain ind:FreightException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preventableFlag rdf:type rdf:Property ;
    rdfs:label 'Preventable Flag' ;
    rdfs:comment 'Indicates whether the exception was preventable through better processes, controls, or carrier selection. Used for continuous improvement analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this exception is a repeat occurrence on the same freight order or lane. True if recurring issue, false if first occurrence.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedEta rdf:type rdf:Property ;
    rdfs:label 'Revised Eta' ;
    rdfs:comment 'Updated estimated arrival time following the exception event. Communicated to customer as part of exception management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Detailed explanation of the underlying cause of the exception. Captured during investigation and resolution process.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Date' ;
    rdfs:comment 'Original committed delivery date per customer SLA. Used to calculate breach impact.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originNodeNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Node Network Node Id' ;
    rdfs:comment 'Reference to the origin location for this leg. Can be a port, airport, warehouse, Container Freight Station (CFS), Inland Container Depot (ICD), or other network node.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:primaryFreightNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Freight Network Node Id' ;
    rdfs:comment 'Reference to the network node where the intermodal transfer occurs. Typically a Container Freight Station (CFS), Inland Container Depot (ICD), or intermodal terminal.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:transferFacilityId rdf:type rdf:Property ;
    rdfs:label 'Transfer Facility Id' ;
    rdfs:comment 'Foreign key linking to warehouse.facility. Business justification: Freight legs with intermodal transfers (e.g., ocean-to-rail, air-to-truck) occur at warehouse facilities (CFS, cross-dock terminals). Tracking transfer_facility_id enables transfer dwell time analysis' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual departure date and time when the freight left the origin location for this leg. Used for performance tracking and On-Time Delivery (OTD) calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transit Time Hours' ;
    rdfs:comment 'Actual transit time for this leg in hours. Calculated as the difference between actual arrival and actual departure timestamps. Used for On-Time Delivery (OTD) performance measurement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bafAmount rdf:type rdf:Property ;
    rdfs:label 'Baf Amount' ;
    rdfs:comment 'Bunker Adjustment Factor surcharge for this leg. Fuel-related surcharge applied to ocean freight to account for fluctuating fuel costs.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLocationType rdf:type rdf:Property ;
    rdfs:label 'Destination Location Type' ;
    rdfs:comment 'Type of facility at the destination of this leg. Classifies the ending point as port, airport, warehouse, Container Freight Station (CFS), Inland Container Depot (ICD), terminal, or depot. [ENUM-REF-CANDIDATE: port|airport|warehouse|CFS|ICD|terminal|depot — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeHours rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Hours' ;
    rdfs:comment 'Duration in hours that freight remains at the destination location before moving to the next leg. Critical for intermodal transfer efficiency and Service Level Agreement (SLA) monitoring.' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargesCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Charges Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the freight charges amount. Indicates the currency in which base freight fees are denominated.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griAmount rdf:type rdf:Property ;
    rdfs:label 'Gri Amount' ;
    rdfs:comment 'General Rate Increase surcharge for this leg. Carrier-imposed rate adjustment applied to base freight charges, typically for ocean freight.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Handling Charges Amount' ;
    rdfs:comment 'Total handling charges incurred at the destination of this leg. Includes Terminal Handling Charge (THC), Container Freight Station (CFS) charges, and other transfer-related fees.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingChargesCurrency rdf:type rdf:Property ;
    rdfs:label 'Handling Charges Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the handling charges amount. Indicates the currency in which handling fees are denominated.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Indicates whether this leg carries hazardous materials requiring special handling and compliance with International Maritime Dangerous Goods (IMDG) Code or ICAO Technical Instructions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIntermodalTransfer rdf:type rdf:Property ;
    rdfs:label 'Is Intermodal Transfer' ;
    rdfs:comment 'Indicates whether this leg involves an intermodal transfer (change of transport mode) at the destination. True if freight transitions between air/ocean/road/rail at the end of this leg.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legStatus rdf:type rdf:Property ;
    rdfs:label 'Leg Status' ;
    rdfs:comment 'Current operational status of this freight leg in its lifecycle. Tracks progression from planning through execution to completion.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationType rdf:type rdf:Property ;
    rdfs:label 'Origin Location Type' ;
    rdfs:comment 'Type of facility at the origin of this leg. Classifies the starting point as port, airport, warehouse, Container Freight Station (CFS), Inland Container Depot (ICD), terminal, or depot. [ENUM-REF-CANDIDATE: port|airport|warehouse|CFS|ICD|terminal|depot — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Timestamp' ;
    rdfs:comment 'Planned arrival date and time for this leg at the destination location. Represents the Estimated Time of Arrival (ETA) used for planning and customer communication.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned departure date and time for this leg from the origin location. Represents the Estimated Time of Departure (ETD) used for planning and customer communication.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:thcAmount rdf:type rdf:Property ;
    rdfs:label 'Thc Amount' ;
    rdfs:comment 'Terminal Handling Charge for this leg. Fee charged for handling containers at the origin or destination terminal.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLegChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Leg Charges Amount' ;
    rdfs:comment 'Total charges for this leg including base freight, surcharges (BAF, GRI, THC), and handling charges. Represents the complete cost of this transport segment.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLegChargesCurrency rdf:type rdf:Property ;
    rdfs:label 'Total Leg Charges Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total leg charges amount. Indicates the currency in which total leg costs are denominated.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Type of intermodal transfer occurring at the destination of this leg. Specifies the mode transition (e.g., ocean to road, air to road, rail to road) or none if no transfer. [ENUM-REF-CANDIDATE: ocean_to_road|ocean_to_rail|air_to_road|road_to_ocean|road_to_rail|rail_to_road|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Freight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Hours' ;
    rdfs:comment 'Planned transit time for this leg in hours. Calculated as the difference between scheduled arrival and scheduled departure timestamps.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Transport Document Number' ;
    rdfs:comment 'Reference number of the transport document for this leg. Can be an Air Waybill (AWB), Bill of Lading (BOL), House Air Waybill (HAWB), Master Air Waybill (MAWB), House Bill of Lading (HBL), or Master Bill of Lading (MBL) depending on mode.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportDocumentType rdf:type rdf:Property ;
    rdfs:label 'Transport Document Type' ;
    rdfs:comment 'Type of transport document issued for this leg. Identifies whether it is an Air Waybill (AWB), Bill of Lading (BOL), House/Master variants, or road/rail consignment note. [ENUM-REF-CANDIDATE: AWB|BOL|HAWB|MAWB|HBL|MBL|CMR|CIM — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Flight Number' ;
    rdfs:comment 'Voyage number (for ocean) or flight number (for air) for this leg. Identifies the specific sailing or flight carrying the freight.' ;
    rdfs:domain ind:FreightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Unique identifier for the freight milestone event record. Primary key.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Timestamp' ;
    rdfs:comment 'Actual date and time when the milestone event occurred, as confirmed by carrier, warehouse, customs, or tracking system.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsClearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Number' ;
    rdfs:comment 'Customs declaration or clearance reference number if this milestone is related to customs processing.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Timestamp' ;
    rdfs:comment 'Current estimated date and time for this milestone event, updated dynamically based on real-time tracking data from FourKites and carrier feeds. Represents predictive ETA.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Standardized code representing the type of exception if is_exception is true (e.g., DELAY_WEATHER, CUSTOMS_HOLD, MISSED_CUTOFF, DAMAGED_CARGO).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Critical Milestone' ;
    rdfs:comment 'Indicates whether this milestone is considered critical for SLA compliance and customer notifications (e.g., vessel departure, customs clearance, delivery).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isException rdf:type rdf:Property ;
    rdfs:label 'Is Exception' ;
    rdfs:comment 'Indicates whether this milestone represents an exception or deviation from the planned schedule (e.g., delay, missed connection, customs hold).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name of the location where the milestone event occurred (e.g., Port of Los Angeles, Singapore Changi Airport, Memphis Distribution Center).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Category' ;
    rdfs:comment 'High-level category grouping for the milestone event to support analytics and reporting segmentation. [ENUM-REF-CANDIDATE: booking|origin|transit|customs|destination|delivery|exception — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Standardized code representing the milestone event type (e.g., BKG_CONF, CARGO_RCV, CUST_CLR, VSL_DEP, VSL_ARR, POD_RCV). Aligns with industry EDI standards and internal TMS milestone taxonomy.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name or description of the milestone event (e.g., Booking Confirmed, Cargo Received at Origin, Customs Cleared, Vessel Departed, Vessel Arrived, Proof of Delivery Received).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current status of the milestone event in its lifecycle.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Timestamp' ;
    rdfs:comment 'Originally scheduled or planned date and time for this milestone event to occur, based on initial routing and scheduling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:podDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Document Url' ;
    rdfs:comment 'URL or storage path to the electronic proof of delivery document (ePOD) or scanned signature.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureName rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Name' ;
    rdfs:comment 'Name of the person who signed for delivery, if applicable and captured.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryReceived rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Received' ;
    rdfs:comment 'Indicates whether proof of delivery documentation has been received for this milestone (applicable to delivery milestones).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Sequential order of this milestone within the freight order lifecycle. Enables chronological sorting and progress tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRecordedCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Recorded Celsius' ;
    rdfs:comment 'Temperature reading recorded at this milestone for temperature-controlled shipments.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Username or identifier of the user or system process that last updated this milestone record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time the freight was delivered to the consignee. Used for POD (Proof of Delivery) confirmation, OTD and OTIF KPI measurement, and SLA compliance reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationPortOrFacility rdf:type rdf:Property ;
    rdfs:label 'Destination Port Or Facility' ;
    rdfs:comment 'UN/LOCODE or internal facility code identifying the specific port, airport, CFS, ICD, or delivery facility at the destination. Used for last-mile planning, customs clearance, and THC calculation.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNvocc rdf:type rdf:Property ;
    rdfs:label 'Is Nvocc' ;
    rdfs:comment 'Indicates whether this freight order is executed under an NVOCC (Non-Vessel Operating Common Carrier) arrangement, where the company acts as a carrier to the shipper but uses another vessel operator. Affects BOL issuance, liability, and FMC filing requirements.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originPortOrFacility rdf:type rdf:Property ;
    rdfs:label 'Origin Port Or Facility' ;
    rdfs:comment 'UN/LOCODE or internal facility code identifying the specific port, airport, CFS (Container Freight Station), ICD (Inland Container Depot), or warehouse from which the freight departs. Used for scheduling, carrier assignment, and THC calculation.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Type of outer packaging used for the freight. Influences stacking rules, handling instructions, and container loading plans. [ENUM-REF-CANDIDATE: pallet|carton|crate|drum|bag|loose|roll|bundle|cylinder — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Industry-standard special handling code indicating specific requirements such as temperature control, fragile, live animals, or oversized cargo. Uses IATA Special Handling Codes (e.g., PER for perishables, AVI for live animals, HEA for heavy cargo). Multiple codes may be concatenated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRequirement rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement' ;
    rdfs:comment 'Temperature control requirement for the shipment. Applicable for pharmaceutical, perishable, and cold-chain freight. Drives equipment selection, carrier qualification, and GDP (Good Distribution Practice) compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Total Order Amount' ;
    rdfs:comment 'Total billable amount for this freight order including base freight charges, all surcharges, and applicable taxes. Represents the net total for invoicing and revenue recognition. Equals freight_charge_amount plus total_surcharge_amount plus applicable taxes.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Surcharge Amount' ;
    rdfs:comment 'Aggregate of all applicable surcharges for this freight order including BAF (Bunker Adjustment Factor), GRI (General Rate Increase), THC (Terminal Handling Charge), fuel surcharge, and security surcharge. Stored as a total to support charge breakdown analysis.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseFreightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Freight Charge Amount' ;
    rdfs:comment 'Base freight charge amount quoted for the transportation service, excluding surcharges and accessorial fees.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierServiceCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Code' ;
    rdfs:comment 'Specific service code or product code from the carrier for the quoted service level.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTransitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Time Days' ;
    rdfs:comment 'Estimated number of days for the freight movement from origin to destination.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Externally-known unique business identifier for the freight quote, used for customer communication and reference.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle status of the freight quote indicating its state in the quotation workflow.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of the quote based on the commercial context: spot rate, contract rate, tender response, or Request for Quotation (RFQ) response.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuotedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Quoted Amount' ;
    rdfs:comment 'Total amount quoted to the customer, including base freight charge, fuel surcharge, accessorial charges, and any applicable fees.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validUntilDate rdf:type rdf:Property ;
    rdfs:label 'Valid Until Date' ;
    rdfs:comment 'End date of the quote validity period, after which the quoted rates are no longer binding.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intermodalTransferId rdf:type rdf:Property ;
    rdfs:label 'Intermodal Transfer Id' ;
    rdfs:comment 'Unique identifier for the intermodal transfer event. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntermodalTransfer .

ind:customsClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required Flag' ;
    rdfs:comment 'Boolean indicator of whether customs clearance is required at this transfer point. True = customs clearance required, False = no customs clearance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'Current status of customs clearance process at the transfer point, if applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Handling Equipment Type' ;
    rdfs:comment 'Type of material handling equipment used to perform the physical transfer of cargo between transport modes.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Boolean indicator of whether the cargo contains hazardous materials requiring special handling during transfer. True = hazmat cargo, False = non-hazmat.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledTransferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Transfer Timestamp' ;
    rdfs:comment 'The planned date and time for the intermodal transfer as per the original schedule or booking.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Seal Verification Status' ;
    rdfs:comment 'Status of seal verification at the transfer point, indicating whether the inbound seal was intact and whether a new seal was applied.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDwellTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Dwell Time Hours' ;
    rdfs:comment 'The maximum allowable dwell time in hours as defined by the service level agreement or operational target for this transfer type.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCharge rdf:type rdf:Property ;
    rdfs:label 'Storage Charge' ;
    rdfs:comment 'Additional charge for cargo storage at the interchange facility if dwell time exceeds free time allowances.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supervisorName rdf:type rdf:Property ;
    rdfs:label 'Supervisor Name' ;
    rdfs:comment 'Name of the on-site supervisor or shift manager who oversaw the transfer operation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransferCost rdf:type rdf:Property ;
    rdfs:label 'Total Transfer Cost' ;
    rdfs:comment 'Total cost of the intermodal transfer including handling charges, THC, storage, and any other applicable fees.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferFacilityType rdf:type rdf:Property ;
    rdfs:label 'Transfer Facility Type' ;
    rdfs:comment 'Classification of the interchange facility type. ICD = Inland Container Depot, CFS = Container Freight Station.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferHandlingCharge rdf:type rdf:Property ;
    rdfs:label 'Transfer Handling Charge' ;
    rdfs:comment 'The monetary charge for the physical handling and transfer of cargo at the interchange facility, excluding other accessorial charges.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Business-facing unique reference number for the intermodal transfer, used for tracking and documentation across systems and partners.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the intermodal transfer operation, tracking progression from scheduled through completion or exception states.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'The actual date and time when the physical transfer of cargo between transport modes occurred at the interchange point.' ;
    rdfs:domain ind:IntermodalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Unique identifier for the load plan record. Primary key.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightManifestId rdf:type rdf:Property ;
    rdfs:label 'Freight Manifest Id' ;
    rdfs:comment 'Foreign key linking to shipment.freight_manifest. Business justification: Load plan is the pre-execution planning artifact; freight manifest is the actual executed load. In real operations, approved load plans are executed as manifests. Enables plan-to-execution traceabilit' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightManifest .

ind:primaryLoadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Load Employee Id' ;
    rdfs:comment 'Identifier of the employee or system user who created or approved the load plan. Links to workforce/user management system.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLoadPlannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Load Planner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLoadCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Actual Load Completion Time' ;
    rdfs:comment 'Actual timestamp when loading operations were completed. Critical for on-time performance tracking and operational efficiency analysis.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLoadStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Load Start Time' ;
    rdfs:comment 'Actual timestamp when loading operations commenced. Used for performance measurement and variance analysis against planned time.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cargoPlacementInstructions rdf:type rdf:Property ;
    rdfs:label 'Cargo Placement Instructions' ;
    rdfs:comment 'Detailed instructions for cargo placement within the transport unit, including stacking rules, orientation requirements, and securing methods.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerOfGravityX rdf:type rdf:Property ;
    rdfs:label 'Center Of Gravity X' ;
    rdfs:comment 'Calculated X-coordinate of the load center of gravity relative to transport unit reference point. Critical for vessel and aircraft stability.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerOfGravityY rdf:type rdf:Property ;
    rdfs:label 'Center Of Gravity Y' ;
    rdfs:comment 'Calculated Y-coordinate of the load center of gravity relative to transport unit reference point. Critical for vessel and aircraft stability.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerOfGravityZ rdf:type rdf:Property ;
    rdfs:label 'Center Of Gravity Z' ;
    rdfs:comment 'Calculated Z-coordinate (vertical) of the load center of gravity relative to transport unit reference point. Critical for vessel and aircraft stability.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containsHazmat rdf:type rdf:Property ;
    rdfs:label 'Contains Hazmat' ;
    rdfs:comment 'Indicates whether the load plan includes hazardous materials requiring special handling and segregation. Triggers additional compliance checks.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'UN hazard class of dangerous goods included in the load plan. Determines segregation requirements and handling procedures. Pipe-separated list if multiple classes present.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatSegregationVerified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Segregation Verified' ;
    rdfs:comment 'Indicates whether hazmat segregation requirements have been verified and approved by qualified personnel. Mandatory for hazmat loads.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadOptimizationMethod rdf:type rdf:Property ;
    rdfs:label 'Load Optimization Method' ;
    rdfs:comment 'Method used to create the load plan. Automated plans use TMS optimization algorithms, manual plans are created by planners, hybrid combines both.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Load Plan Status' ;
    rdfs:comment 'Current lifecycle status of the load plan. Tracks progression from initial planning through execution completion. [ENUM-REF-CANDIDATE: draft|planned|approved|in_progress|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Load Sequence Number' ;
    rdfs:comment 'Sequential order in which cargo items are to be loaded onto the transport unit. Critical for LIFO/FIFO optimization and unloading efficiency.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadingDockBay rdf:type rdf:Property ;
    rdfs:label 'Loading Dock Bay' ;
    rdfs:comment 'Specific dock, bay, or gate number where loading operations are performed. Used for operational coordination and resource allocation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Loading Location Code' ;
    rdfs:comment 'Code identifying the facility or terminal where loading operations take place. May be UN/LOCODE, IATA airport code, or internal facility code.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVolumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Max Volume Capacity Cbm' ;
    rdfs:comment 'Maximum volume capacity of the transport unit in cubic meters. Physical constraint for load planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the transport unit in kilograms. Regulatory limit that must not be exceeded.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedLoadCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Planned Load Completion Time' ;
    rdfs:comment 'Scheduled timestamp when loading operations are expected to be completed. Used for departure scheduling and SLA management.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedLoadDate rdf:type rdf:Property ;
    rdfs:label 'Planned Load Date' ;
    rdfs:comment 'Scheduled date when loading operations are planned to begin. Used for resource planning and scheduling.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedLoadStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Load Start Time' ;
    rdfs:comment 'Precise timestamp when loading operations are scheduled to commence. Critical for dock scheduling and labor planning.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalActualVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Actual Volume Cbm' ;
    rdfs:comment 'Total actual volume of all cargo loaded, measured in cubic meters. Captured post-loading for utilization analysis.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalActualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Actual Weight Kg' ;
    rdfs:comment 'Total actual weight of all cargo loaded, measured in kilograms. Captured post-loading for verification and compliance documentation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Planned Volume Cbm' ;
    rdfs:comment 'Total planned volume of all cargo to be loaded, measured in cubic meters. Used for space utilization and capacity planning.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Planned Weight Kg' ;
    rdfs:comment 'Total planned weight of all cargo to be loaded, measured in kilograms. Used for weight distribution calculations and regulatory compliance.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportUnitType rdf:type rdf:Property ;
    rdfs:label 'Transport Unit Type' ;
    rdfs:comment 'Type of transport unit for which the load plan is created. Determines applicable loading rules and constraints.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Volume Utilization Percentage' ;
    rdfs:comment 'Percentage of volume capacity utilized by the planned load. Key performance indicator for space optimization efficiency.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Utilization Percentage' ;
    rdfs:comment 'Percentage of weight capacity utilized by the planned load. Key performance indicator for load optimization efficiency.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerId rdf:type rdf:Property ;
    rdfs:label 'Center Id' ;
    rdfs:comment 'Primary key for center' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Employee Id' ;
    rdfs:comment 'Employee identifier for the facility manager responsible for the operational management of this fulfillment center.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:mroSupplierId rdf:type rdf:Property ;
    rdfs:label 'Mro Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Fulfillment centers procure MRO supplies, equipment, and consumables from suppliers. Tracks primary supplier relationship for facility operations, enabling spend analysis and supplier performance mana' ;
    rdfs:domain ind:Center ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:operatorTplProviderId rdf:type rdf:Property ;
    rdfs:label 'Operator Tpl Provider Id' ;
    rdfs:comment 'Foreign key linking to network.tpl_provider. Business justification: Fulfillment centers may be operated by 3PL providers. Business process: 3PL facility management, operational oversight, cost center allocation. Role-prefixed as centers may have multiple 3PL relations' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TplProvider .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line for the fulfillment center facility location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for suite, building, or unit information. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualThroughputCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Throughput Capacity Units' ;
    rdfs:comment 'Maximum annual throughput capacity of the fulfillment center measured in units (SKUs) that can be processed per year, representing operational capacity for planning purposes.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Classification of the degree of automation deployed in the fulfillment center operations, ranging from manual labor-intensive to fully robotic systems.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether the fulfillment center operates as a customs bonded warehouse, allowing storage of imported goods before customs duties are paid.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Date when the fulfillment center commenced operational activities and began processing orders.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laborWorkforceSize rdf:type rdf:Property ;
    rdfs:label 'Labor Workforce Size' ;
    rdfs:comment 'Total workforce size at the fulfillment center measured in Full-Time Equivalent (FTE) employees, including permanent and temporary staff.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMileZoneCoverage rdf:type rdf:Property ;
    rdfs:label 'Last Mile Zone Coverage' ;
    rdfs:comment 'Comma-separated list of last-mile delivery zone codes or postal code prefixes that this fulfillment center serves, defining its geographic service area for direct delivery.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDaysPerWeek rdf:type rdf:Property ;
    rdfs:label 'Operating Days Per Week' ;
    rdfs:comment 'Number of days per week the fulfillment center operates, typically ranging from 5 (weekdays only) to 7 (continuous operations).' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:palletPositions rdf:type rdf:Property ;
    rdfs:label 'Pallet Positions' ;
    rdfs:comment 'Total number of pallet storage positions available in the fulfillment center, representing discrete storage locations for palletized inventory.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakDailyOrderCapacity rdf:type rdf:Property ;
    rdfs:label 'Peak Daily Order Capacity' ;
    rdfs:comment 'Maximum number of orders the fulfillment center can process in a single day during peak periods, used for capacity planning and load balancing.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality management certifications held by the fulfillment center (e.g., ISO 9001, Six Sigma), demonstrating adherence to quality standards. [ENUM-REF-CANDIDATE: iso_9001|six_sigma|lean|tqm|gmp|haccp|brc — promote to reference product]' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityCertification rdf:type rdf:Property ;
    rdfs:label 'Security Certification' ;
    rdfs:comment 'Security certifications held by the fulfillment center (e.g., C-TPAT, AEO, ISO 28000), demonstrating compliance with supply chain security standards. [ENUM-REF-CANDIDATE: c_tpat|aeo|iso_28000|tapa_a|tapa_b|tapa_c|pip — promote to reference product]' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Cbm' ;
    rdfs:comment 'Total volumetric storage capacity of the fulfillment center measured in cubic meters (CBM), representing the three-dimensional space available for inventory storage.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Service Types' ;
    rdfs:comment 'Comma-separated list of service types supported by this fulfillment center (e.g., standard_delivery, express_delivery, same_day, next_day, cod, returns_processing). [ENUM-REF-CANDIDATE: standard_delivery|express_delivery|same_day|next_day|two_day|cod|returns_processing|gift_wrapping|kitting — promote to reference product]' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'Environmental and sustainability certifications held by the fulfillment center (e.g., LEED, ISO 14001, carbon neutral), demonstrating commitment to environmental responsibility.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFloorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Total Floor Area Sqm' ;
    rdfs:comment 'Total floor area of the fulfillment center facility measured in square meters, representing the physical footprint available for operations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Wms Instance Code' ;
    rdfs:comment 'Unique instance identifier for the WMS deployment at this facility, used for system integration and data lineage tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Wms System Code' ;
    rdfs:comment 'Identifier for the WMS system instance deployed at this fulfillment center. Used to route integration messages and identify the source system for inventory and order data.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessCode rdf:type rdf:Property ;
    rdfs:label 'Access Code' ;
    rdfs:comment 'Security access code or gate code required to enter the delivery location (e.g., building entry code, gated community code).' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Status of address validation process: validated (confirmed accurate), unvalidated (not yet checked), corrected (modified by validation service), or failed (could not be validated).' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateContactPhone rdf:type rdf:Property ;
    rdfs:label 'Alternate Contact Phone' ;
    rdfs:comment 'Secondary contact phone number for the consignee. Used when primary contact is unavailable or for escalation during delivery attempts.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistFlag rdf:type rdf:Property ;
    rdfs:label 'Blacklist Flag' ;
    rdfs:comment 'Indicates whether this consignee is blacklisted due to fraud, repeated delivery failures, abusive behavior, or security concerns. True if blacklisted, false otherwise.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Business Hours End' ;
    rdfs:comment 'End time of business hours for commercial consignees in HH:MM format (24-hour clock). Used for scheduling delivery attempts during operating hours.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHoursStart rdf:type rdf:Property ;
    rdfs:label 'Business Hours Start' ;
    rdfs:comment 'Start time of business hours for commercial consignees in HH:MM format (24-hour clock). Used for scheduling delivery attempts during operating hours.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Eligible Flag' ;
    rdfs:comment 'Indicates whether this consignee is eligible to receive COD (Cash on Delivery) shipments. True if COD is permitted, false if COD is restricted due to payment history or risk assessment.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codPaymentMethodPreference rdf:type rdf:Property ;
    rdfs:label 'Cod Payment Method Preference' ;
    rdfs:comment 'Preferred payment method for COD (Cash on Delivery) collections: cash, card (credit/debit), mobile_payment (digital wallet), or bank_transfer.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsIdNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Id Number' ;
    rdfs:comment 'Customs-specific identifier for the consignee (e.g., importer of record number, customs registration number). Used for cross-border shipments and customs declarations.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Free-text special instructions for the delivery agent regarding access, location, handling, or recipient preferences (e.g., ring doorbell twice, use side entrance, fragile items).' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPreferenceLeaveAtDoor rdf:type rdf:Property ;
    rdfs:label 'Delivery Preference Leave At Door' ;
    rdfs:comment 'Indicates whether the consignee permits unattended delivery at the door. True if leave-at-door is acceptable, false if recipient presence is required.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPreferenceNeighborDelivery rdf:type rdf:Property ;
    rdfs:label 'Delivery Preference Neighbor Delivery' ;
    rdfs:comment 'Indicates whether the consignee permits delivery to a neighbor if the primary recipient is unavailable. True if neighbor delivery is acceptable.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPreferenceSafePlace rdf:type rdf:Property ;
    rdfs:label 'Delivery Preference Safe Place' ;
    rdfs:comment 'Free-text instructions specifying a safe place to leave the parcel if the consignee is not present (e.g., back porch, garage, with building concierge).' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPreferenceSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Delivery Preference Signature Required' ;
    rdfs:comment 'Indicates whether the consignee requires a signature for delivery confirmation. True if signature is mandatory, false if signature can be waived.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryTimeWindowPreference rdf:type rdf:Property ;
    rdfs:label 'Delivery Time Window Preference' ;
    rdfs:comment 'Preferred time window for delivery attempts: morning (before noon), afternoon (noon to 5pm), evening (after 5pm), business_hours (9am-5pm weekdays), or anytime (no preference).' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedDeliveryHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Failed Delivery History Flag' ;
    rdfs:comment 'Indicates whether this consignee has a history of failed delivery attempts. True if previous deliveries have failed, false otherwise. Used for risk assessment and route planning.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geocodeAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocode Accuracy' ;
    rdfs:comment 'Precision level of the geocoded coordinates: rooftop (exact building), street (street-level), postal_code (postal code centroid), city (city centroid), or region (regional approximation).' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeLatitude rdf:type rdf:Property ;
    rdfs:label 'Geocode Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the delivery address in decimal degrees. Used for route optimization and GPS (Global Positioning System) navigation.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geocodeLongitude rdf:type rdf:Property ;
    rdfs:label 'Geocode Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the delivery address in decimal degrees. Used for route optimization and GPS (Global Positioning System) navigation.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO language code for the consignee\'s preferred communication language (e.g., en, es, fr, de, zh). Used for delivery notifications and customer communications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreferenceEmail rdf:type rdf:Property ;
    rdfs:label 'Notification Preference Email' ;
    rdfs:comment 'Indicates whether the consignee has opted in to receive delivery notifications via email. True if email notifications are enabled.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationPreferencePush rdf:type rdf:Property ;
    rdfs:label 'Notification Preference Push' ;
    rdfs:comment 'Indicates whether the consignee has opted in to receive delivery notifications via mobile app push notifications. True if push notifications are enabled.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationPreferenceSms rdf:type rdf:Property ;
    rdfs:label 'Notification Preference Sms' ;
    rdfs:comment 'Indicates whether the consignee has opted in to receive delivery notifications via SMS text message. True if SMS notifications are enabled.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialCommercialIndicator rdf:type rdf:Property ;
    rdfs:label 'Residential Commercial Indicator' ;
    rdfs:comment 'Classification of the delivery location as residential (home address), commercial (business address), or mixed_use (building with both residential and commercial units). Affects delivery routing and surcharges.' ;
    rdfs:domain ind:Consignee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCodCollectionId rdf:type rdf:Property ;
    rdfs:label 'Billing Cod Collection Id' ;
    rdfs:comment 'Foreign key linking to billing.cod_collection. Business justification: Each delivery attempt where COD is collected must link to billing COD collection record for audit trail. Real business process: COD collection verification, variance investigation, and agent accountab' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodCollection .

ind:deliveryAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Delivery Agent Employee Id' ;
    rdfs:comment 'Reference to the employee (driver, courier) who performed this delivery attempt. Used for performance tracking and accountability.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deliveryDriverProfileId rdf:type rdf:Property ;
    rdfs:label 'Delivery Driver Profile Id' ;
    rdfs:comment 'Foreign key linking to fleet.driver_profile. Business justification: Each delivery attempt is performed by a driver whose profile (license validity, certifications, performance rating, HOS status) must be validated for operational compliance and audit trail. Existing d' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverProfile .

ind:attemptDate rdf:type rdf:Property ;
    rdfs:label 'Attempt Date' ;
    rdfs:comment 'Calendar date on which this delivery attempt occurred. Used for daily delivery performance reporting.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attemptLatitude rdf:type rdf:Property ;
    rdfs:label 'Attempt Latitude' ;
    rdfs:comment 'GPS latitude coordinate captured at the moment of delivery attempt. Used for geolocation verification and route optimization analysis.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attemptLongitude rdf:type rdf:Property ;
    rdfs:label 'Attempt Longitude' ;
    rdfs:comment 'GPS longitude coordinate captured at the moment of delivery attempt. Used for geolocation verification and route optimization analysis.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Sequential number of this delivery attempt for the consignment (1 for first attempt, 2 for second, etc.). Used to track re-delivery attempts.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attemptOutcomeCode rdf:type rdf:Property ;
    rdfs:label 'Attempt Outcome Code' ;
    rdfs:comment 'Standardized code indicating the result of the delivery attempt. Core field for OTD and OTIF KPI calculation. [ENUM-REF-CANDIDATE: delivered|failed|refused|no_access|redirected|damaged|address_incorrect — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Attempt Timestamp' ;
    rdfs:comment 'Precise date and time when the delivery agent arrived at the delivery location and initiated the attempt. Primary business event timestamp for SLA calculation.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codAmount rdf:type rdf:Property ;
    rdfs:label 'Cod Amount' ;
    rdfs:comment 'Amount to be collected from the recipient at delivery. Null if this is not a COD shipment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Collected Flag' ;
    rdfs:comment 'Indicates whether the COD payment was successfully collected from the recipient. True if collected, false if not collected or not applicable.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Cod Payment Method' ;
    rdfs:comment 'Method used by recipient to pay the COD amount (cash, credit card, mobile payment, check). Null if COD was not collected.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line where the delivery attempt was made. May differ from consignment address if redirected.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line (apartment, suite, building) where the delivery attempt was made.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City or municipality where the delivery attempt was made.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the delivery location (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the delivery location. Used for geographic analysis and route optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State, province, or region where the delivery attempt was made.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotLocationCode rdf:type rdf:Property ;
    rdfs:label 'Depot Location Code' ;
    rdfs:comment 'Code identifying the depot or distribution center from which this delivery attempt was dispatched. Used for operational reporting and network analysis.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epodPhotoCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Epod Photo Captured Flag' ;
    rdfs:comment 'Indicates whether a photo of the delivered parcel was captured at the delivery location. True if photo was taken, false otherwise.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epodReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Epod Reference Number' ;
    rdfs:comment 'Unique reference number linking to the electronic proof of delivery record (signature, photo, barcode scan). Null if delivery was not completed.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epodSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Epod Signature Captured Flag' ;
    rdfs:comment 'Indicates whether a digital signature was captured from the recipient at delivery. True if signature was obtained, false otherwise.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Detailed reason code explaining why a delivery attempt failed (e.g., recipient_not_home, business_closed, access_denied, incorrect_address). Null if attempt was successful. [ENUM-REF-CANDIDATE: recipient_not_home|business_closed|access_denied|incorrect_address|security_restriction|weather_delay|vehicle_breakdown — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Description' ;
    rdfs:comment 'Free-text description providing additional context about the delivery failure. Captured by delivery agent for customer service follow-up.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionInstruction rdf:type rdf:Property ;
    rdfs:label 'Next Action Instruction' ;
    rdfs:comment 'Instruction code indicating the next step to be taken following this attempt (e.g., schedule re-attempt, hold at depot, return to sender). Drives workflow automation.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reattemptScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Reattempt Scheduled Date' ;
    rdfs:comment 'Date on which the next delivery re-attempt is scheduled. Null if no re-attempt is planned or if delivery was successful.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recipientContactPhone rdf:type rdf:Property ;
    rdfs:label 'Recipient Contact Phone' ;
    rdfs:comment 'Phone number of the person who received the parcel or was contacted during the delivery attempt. Used for delivery confirmation and follow-up.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Name of the person who received the parcel or who was present at the delivery location during the attempt. May differ from consignee if alternate recipient accepted delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientRelationship rdf:type rdf:Property ;
    rdfs:label 'Recipient Relationship' ;
    rdfs:comment 'Relationship of the actual recipient to the consignee (e.g., consignee themselves, family member, neighbor, building security). Used for delivery authorization validation.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Timestamp' ;
    rdfs:comment 'Contractual target date and time by which delivery must be completed to meet SLA commitments. Used for OTIF and OTD KPI calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeAtLocationMinutes rdf:type rdf:Property ;
    rdfs:label 'Time At Location Minutes' ;
    rdfs:comment 'Duration in minutes that the delivery agent spent at the delivery location during this attempt. Used for productivity analysis and route optimization.' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration Number' ;
    rdfs:comment 'License plate or registration number of the vehicle used for this delivery attempt. Supports fleet tracking and incident investigation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditionCode rdf:type rdf:Property ;
    rdfs:label 'Weather Condition Code' ;
    rdfs:comment 'Weather condition at the time of delivery attempt. Used to analyze weather impact on delivery success rates and SLA performance. [ENUM-REF-CANDIDATE: clear|rain|snow|fog|storm|extreme_heat|extreme_cold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryAttempt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Id' ;
    rdfs:comment 'Unique identifier for the delivery confirmation record. Primary key.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codCollectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cod Collection Timestamp' ;
    rdfs:comment 'The precise date and time when the COD payment was collected from the recipient.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Flag' ;
    rdfs:comment 'Indicates whether this delivery involved a Cash on Delivery payment collection.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Cod Receipt Number' ;
    rdfs:comment 'Unique receipt number issued to the recipient for the COD payment collected.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current status of the delivery confirmation record in its lifecycle.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAgentName rdf:type rdf:Property ;
    rdfs:label 'Delivery Agent Name' ;
    rdfs:comment 'Full name of the delivery agent who completed the delivery, captured for audit and customer service purposes.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLatitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the actual delivery location, captured via GPS at the point of delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLongitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the actual delivery location, captured via GPS at the point of delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes recorded by the delivery agent about the delivery circumstances, conditions, or any issues encountered.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The precise date and time when the parcel was delivered to the recipient, captured at the point of delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epodPhotoImageUrl rdf:type rdf:Property ;
    rdfs:label 'Epod Photo Image Url' ;
    rdfs:comment 'Storage location URL or path to the delivery photo image file showing the parcel at the delivery location.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epodSignatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Epod Signature Image Url' ;
    rdfs:comment 'Storage location URL or path to the digital signature image file captured at delivery.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelCode rdf:type rdf:Property ;
    rdfs:label 'Service Level Code' ;
    rdfs:comment 'Code representing the service level under which the delivery was completed (e.g., express, standard, same-day).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentDeliveryZoneId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Delivery Zone Id' ;
    rdfs:comment 'Unique identifier for the delivery zone record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentDeliveryZone .

ind:hubFulfillmentCenterId rdf:type rdf:Property ;
    rdfs:label 'Hub Fulfillment Center Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.center. Business justification: Delivery zones are served by specific fulfillment centers (hubs). The hub_location_code STRING should be normalized to FK referencing center.fulfillment_center_id. This enables proper zone-to-hub assi' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Center .

ind:laneRateZoneId rdf:type rdf:Property ;
    rdfs:label 'Lane Rate Zone Id' ;
    rdfs:comment 'Foreign key linking to pricing.lane_rate_zone. Business justification: Delivery zones map to pricing rate zones for zone-based tariff application. Business process: zone-based rating applies distance/geography-based pricing to delivery zones for accurate freight costing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaneRateZone .

ind:averageDeliveryAttempts rdf:type rdf:Property ;
    rdfs:label 'Average Delivery Attempts' ;
    rdfs:comment 'Historical average number of delivery attempts required to successfully complete deliveries in this zone. Used for operational planning.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierCoverageLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Coverage Level' ;
    rdfs:comment 'Level of carrier network coverage available in this zone. Affects service availability and delivery reliability.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codServiceAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Service Available Flag' ;
    rdfs:comment 'Indicates whether Cash on Delivery (COD) service is available for deliveries in this zone based on carrier capabilities and risk assessment.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Cutoff Time' ;
    rdfs:comment 'Local time cutoff for same-day or next-day delivery eligibility in this zone. Format HH:MM in 24-hour notation.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expressTransitDays rdf:type rdf:Property ;
    rdfs:label 'Express Transit Days' ;
    rdfs:comment 'Number of business days for express delivery service to this zone from the fulfillment center. Used for expedited SLA promise calculation.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelSurchargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Applicable Flag' ;
    rdfs:comment 'Indicates whether fuel surcharge (Bunker Adjustment Factor - BAF) applies to shipments in this zone.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayDeliveryAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Delivery Available Flag' ;
    rdfs:comment 'Indicates whether delivery service is available on public holidays in this zone.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxParcelDimensionsCm rdf:type rdf:Property ;
    rdfs:label 'Max Parcel Dimensions Cm' ;
    rdfs:comment 'Maximum parcel dimensions (length x width x height) in centimeters that can be delivered to this zone. Format: LxWxH.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxParcelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Parcel Weight Kg' ;
    rdfs:comment 'Maximum parcel weight in kilograms that can be delivered to this zone based on carrier and infrastructure constraints.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDayEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Next Day Eligible Flag' ;
    rdfs:comment 'Indicates whether this zone is eligible for next-day delivery service based on cutoff times and carrier network coverage.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range End' ;
    rdfs:comment 'Ending postal code of the range covered by this delivery zone. Used for zone lookup during order processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range Start' ;
    rdfs:comment 'Starting postal code of the range covered by this delivery zone. Used for zone lookup during order processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Code' ;
    rdfs:comment 'Code identifying the primary carrier assigned to service this delivery zone. Used in carrier selection logic.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteAreaSurchargeFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Area Surcharge Flag' ;
    rdfs:comment 'Indicates whether a remote area surcharge applies to deliveries in this zone due to distance or accessibility constraints.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialSurchargeFlag rdf:type rdf:Property ;
    rdfs:label 'Residential Surcharge Flag' ;
    rdfs:comment 'Indicates whether residential delivery surcharge applies to addresses in this zone.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedGoodsAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Goods Allowed Flag' ;
    rdfs:comment 'Indicates whether restricted or regulated goods (e.g., hazardous materials, alcohol, pharmaceuticals) can be delivered to this zone based on local regulations.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sameDayEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Same Day Eligible Flag' ;
    rdfs:comment 'Indicates whether this zone is eligible for same-day delivery service based on proximity to fulfillment centers and carrier availability.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Carrier Code' ;
    rdfs:comment 'Code identifying the backup carrier for this delivery zone when primary carrier is unavailable or at capacity.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceableFlag rdf:type rdf:Property ;
    rdfs:label 'Serviceable Flag' ;
    rdfs:comment 'Indicates whether this delivery zone is currently serviceable for deliveries. False indicates zone is temporarily or permanently out of service.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Indicates whether recipient signature is required for deliveries in this zone as a default service requirement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardTransitDays rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Days' ;
    rdfs:comment 'Number of business days for standard delivery service to this zone from the fulfillment center. Used for Service Level Agreement (SLA) promise calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeZoneCode rdf:type rdf:Property ;
    rdfs:label 'Time Zone Code' ;
    rdfs:comment 'IANA time zone identifier for this delivery zone. Used for scheduling delivery windows and cutoff time calculations.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weekendDeliveryAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Weekend Delivery Available Flag' ;
    rdfs:comment 'Indicates whether Saturday and Sunday delivery service is available in this zone.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneCentroidLatitude rdf:type rdf:Property ;
    rdfs:label 'Zone Centroid Latitude' ;
    rdfs:comment 'Latitude coordinate of the geographic centroid of the delivery zone. Used for distance calculations and route optimization.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCentroidLongitude rdf:type rdf:Property ;
    rdfs:label 'Zone Centroid Longitude' ;
    rdfs:comment 'Longitude coordinate of the geographic centroid of the delivery zone. Used for distance calculations and route optimization.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zonePriorityRank rdf:type rdf:Property ;
    rdfs:label 'Zone Priority Rank' ;
    rdfs:comment 'Priority ranking of this zone for resource allocation and route sequencing. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:FulfillmentDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchRunId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Run Id' ;
    rdfs:comment 'Unique identifier for the dispatch run. Primary key for this entity representing a scheduled last-mile delivery route or courier trip.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispatchRun .

ind:courierDriverProfileId rdf:type rdf:Property ;
    rdfs:label 'Courier Driver Profile Id' ;
    rdfs:comment 'Foreign key linking to fleet.driver_profile. Business justification: Courier assignment for last-mile dispatch runs requires driver profile validation including license type, HOS compliance status, performance rating, and certification eligibility (hazmat, temperature-' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverProfile .

ind:courierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Courier Employee Id' ;
    rdfs:comment 'The unique identifier of the courier or delivery agent assigned to execute this dispatch run.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Actual Distance Km' ;
    rdfs:comment 'The actual total distance traveled in kilometers during this dispatch run, captured from GPS or vehicle telematics.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'The actual total duration in minutes for this dispatch run, calculated from dispatch timestamp to return timestamp.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualStopCount rdf:type rdf:Property ;
    rdfs:label 'Actual Stop Count' ;
    rdfs:comment 'The actual number of delivery stops completed during this dispatch run, which may differ from planned due to failed deliveries or route changes.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codCollectionCount rdf:type rdf:Property ;
    rdfs:label 'Cod Collection Count' ;
    rdfs:comment 'The number of Cash on Delivery transactions collected during this dispatch run.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchNotes rdf:type rdf:Property ;
    rdfs:label 'Dispatch Notes' ;
    rdfs:comment 'Free-text operational notes or special instructions for this dispatch run, used for communication between dispatch coordinators and couriers.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'The actual date and time when the dispatch run departed from the origin depot or facility, marking the start of the last-mile delivery route.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchType rdf:type rdf:Property ;
    rdfs:label 'Dispatch Type' ;
    rdfs:comment 'The type or service level of this dispatch run, indicating the delivery speed and priority classification.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Status' ;
    rdfs:comment 'The status of EDI manifest transmission to the carrier system, indicating whether the dispatch run manifest has been successfully communicated.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Timestamp' ;
    rdfs:comment 'The date and time when the EDI manifest was transmitted to the carrier system for this dispatch run.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epodCaptureCount rdf:type rdf:Property ;
    rdfs:label 'Epod Capture Count' ;
    rdfs:comment 'The number of electronic proof of delivery records captured during this dispatch run, including signatures and photos.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'The manifest document number generated for carrier handover, listing all parcels loaded onto this dispatch run for last-mile delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Reconciliation Status' ;
    rdfs:comment 'The status of manifest reconciliation indicating whether all parcels loaded have been accounted for through delivery, return, or exception processing.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originDepotCode rdf:type rdf:Property ;
    rdfs:label 'Origin Depot Code' ;
    rdfs:comment 'The facility or depot code from which the dispatch run originates, representing the starting point for the last-mile delivery route.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Planned Distance Km' ;
    rdfs:comment 'The planned total distance in kilometers for this dispatch run based on route optimization.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Minutes' ;
    rdfs:comment 'The planned total duration in minutes for this dispatch run based on route optimization and historical performance.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedStopCount rdf:type rdf:Property ;
    rdfs:label 'Planned Stop Count' ;
    rdfs:comment 'The number of delivery stops planned for this dispatch run based on route optimization and order allocation.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'The date and time when the manifest reconciliation was completed for this dispatch run.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'The actual date and time when the dispatch run returned to the origin depot or facility, marking the completion of the last-mile delivery route.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnedParcelCount rdf:type rdf:Property ;
    rdfs:label 'Returned Parcel Count' ;
    rdfs:comment 'The number of parcels returned to the depot at the end of this dispatch run due to failed delivery attempts or customer refusal.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'The scheduled date for this dispatch run, representing the business day on which the last-mile delivery route is planned to execute.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business-facing unique identifier or manifest number for the dispatch run, used for operational tracking and carrier handover documentation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the dispatch run indicating its operational state in the last-mile delivery workflow.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Time' ;
    rdfs:comment 'The target completion timestamp for this dispatch run based on service level agreements and operational commitments.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalCodAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cod Amount' ;
    rdfs:comment 'The total monetary value of Cash on Delivery payments collected during this dispatch run.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalParcelsDelivered rdf:type rdf:Property ;
    rdfs:label 'Total Parcels Delivered' ;
    rdfs:comment 'The total number of parcels successfully delivered during this dispatch run, representing successful last-mile completions.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalParcelsLoaded rdf:type rdf:Property ;
    rdfs:label 'Total Parcels Loaded' ;
    rdfs:comment 'The total number of parcels loaded onto the vehicle or assigned to the courier for this dispatch run at departure.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Vehicle Utilization Percentage' ;
    rdfs:comment 'The percentage of vehicle capacity utilized by this dispatch run, calculated based on weight, volume, or parcel count constraints.' ;
    rdfs:domain ind:DispatchRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentCarrierAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Carrier Assignment Id' ;
    rdfs:comment 'Unique identifier for the carrier assignment record. Primary key for this entity.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierRateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carrier Rate Agreement Id' ;
    rdfs:comment 'Foreign key linking to procurement.rate_agreement. Business justification: Carrier assignments must reference the applicable rate agreement to apply correct pricing, service levels, and contractual terms. Critical for cost accuracy and contract compliance in carrier selectio' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateAgreement .

ind:parcelManifestId rdf:type rdf:Property ;
    rdfs:label 'Parcel Manifest Id' ;
    rdfs:comment 'Reference to the parcel manifest or carrier manifest document that includes this carrier assignment, used for batch handover and carrier reconciliation. May be null if not yet manifested.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParcelManifest .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for cancellation of the carrier assignment (e.g., order_cancelled, carrier_rejected, capacity_unavailable, customer_change, address_correction). Populated only when assignment is cancelled. [ENUM-REF-CANDIDATE: order_cancelled|carrier_rejected|capacity_unavailable|customer_change|address_correction|service_downgrade|cost_optimization — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Account Number' ;
    rdfs:comment 'The specific carrier account number or contract identifier under which this shipment is being tendered, used for billing reconciliation and rate application.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Timestamp' ;
    rdfs:comment 'The estimated date and time of arrival (ETA) when the carrier is expected to deliver the shipment to the destination, used for SLA tracking and customer communication.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Pickup Timestamp' ;
    rdfs:comment 'The estimated date and time when the carrier is expected to pick up the shipment from the fulfillment center or origin location.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Time Hours' ;
    rdfs:comment 'The estimated transit time in hours from pickup to delivery as quoted by the carrier or calculated by the TMS at the time of assignment.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:integrationReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Integration Reference Code' ;
    rdfs:comment 'External reference identifier from the source system or integration layer, used to trace this record back to the originating transaction in SAP TM, Oracle TMS, or other operational systems.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Label Generated Flag' ;
    rdfs:comment 'Boolean indicator of whether the shipping label has been generated for this carrier assignment, signaling readiness for physical dispatch.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Label Generated Timestamp' ;
    rdfs:comment 'The date and time when the shipping label was generated for this carrier assignment. Null if label has not yet been generated.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:masterTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Master Tracking Number' ;
    rdfs:comment 'The master tracking number or Master Air Waybill (MAWB) / Master Bill of Lading (MBL) number when this shipment is part of a consolidated load. May be null for direct shipments.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Boolean indicator of whether this carrier assignment was a manual override of the system-recommended carrier selection, requiring additional justification and audit.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for manual override of the carrier selection (e.g., customer_request, capacity_constraint, service_failure, cost_exception, regulatory_requirement). Populated only when override_flag is true. [ENUM-REF-CANDIDATE: customer_request|capacity_constraint|service_failure|cost_exception|regulatory_requirement|quality_issue|strategic_partnership — promote to reference product]' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Override Reason Description' ;
    rdfs:comment 'Free-text description providing additional context and justification for the manual override of carrier selection. Populated only when override_flag is true.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Quoted Rate Amount' ;
    rdfs:comment 'The freight rate amount quoted by the carrier for this shipment at the time of assignment, used for cost estimation and freight audit reconciliation.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedRateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quoted Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quoted rate amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionPriorityScore rdf:type rdf:Property ;
    rdfs:label 'Selection Priority Score' ;
    rdfs:comment 'Numerical score calculated by the carrier selection algorithm representing the priority or ranking of this carrier for this shipment, used for optimization and decision audit.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:selectionRuleApplied rdf:type rdf:Property ;
    rdfs:label 'Selection Rule Applied' ;
    rdfs:comment 'The specific carrier selection rule or optimization criterion that was applied to choose this carrier (e.g., lowest_cost, fastest_transit, sla_compliant, preferred_carrier, customer_specified, zone_based).' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether the selected carrier and service level are expected to meet the SLA target delivery timestamp based on estimated transit time.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tenderStatus rdf:type rdf:Property ;
    rdfs:label 'Tender Status' ;
    rdfs:comment 'Status of the carrier tender process indicating whether the shipment has been tendered to the carrier and the carriers response (not tendered, tendered, accepted, rejected).' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tender Timestamp' ;
    rdfs:comment 'The date and time when the shipment was tendered to the carrier via EDI, API, or manual process. Null if not yet tendered.' ;
    rdfs:domain ind:FulfillmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryFulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Fulfillment Order Id' ;
    rdfs:comment 'Reference to the parent fulfillment order that experienced this exception.' ;
    rdfs:domain ind:FulfillmentException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:relatedExceptionFulfillmentExceptionId rdf:type rdf:Property ;
    rdfs:label 'Related Exception Fulfillment Exception Id' ;
    rdfs:comment 'Reference to a related or parent exception record if this exception is linked to or caused by another exception.' ;
    rdfs:domain ind:FulfillmentException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentException .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.rma. Business justification: Fulfillment exceptions can trigger or relate to RMA processes. The rma_number STRING should be normalized to FK referencing rma.rma_id. This enables tracking exceptions that result in returns processi' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:assignedToTeamCode rdf:type rdf:Property ;
    rdfs:label 'Assigned To Team Code' ;
    rdfs:comment 'Code identifying the team or department responsible for resolving this exception, such as customer service, warehouse operations, or carrier management.' ;
    rdfs:domain ind:FulfillmentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Reference Number' ;
    rdfs:comment 'Carrier-provided tracking or reference number associated with the exception event, used for coordination with carrier on resolution.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Breach Flag' ;
    rdfs:comment 'Boolean indicator whether the exception resulted in a regulatory or contractual compliance breach requiring formal reporting or remediation.' ;
    rdfs:domain ind:FulfillmentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFrameworkCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework Code' ;
    rdfs:comment 'Code identifying the regulatory or compliance framework breached by this exception, such as Customs-Trade Partnership Against Terrorism (C-TPAT), Authorized Economic Operator (AEO), or General Data Protection Regulation (GDPR).' ;
    rdfs:domain ind:FulfillmentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedBySource rdf:type rdf:Property ;
    rdfs:label 'Detected By Source' ;
    rdfs:comment 'System or process that detected and raised the exception, such as Warehouse Management System (WMS), Transportation Management System (TMS), carrier scan, customer report, quality inspection, automated validation, or manual audit. [ENUM-REF-CANDIDATE: WMS|TMS|CARRIER_SCAN|CUSTOMER_REPORT|QUALITY_INSPECTION|AUTOMATED_VALIDATION|MANUAL_AUDIT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLocationCode rdf:type rdf:Property ;
    rdfs:label 'Detection Location Code' ;
    rdfs:comment 'Code identifying the physical or logical location where the exception was detected, such as warehouse code, depot code, or carrier facility code.' ;
    rdfs:domain ind:FulfillmentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency Code' ;
    rdfs:comment 'Three-letter International Organization for Standardization (ISO) 4217 currency code for the financial impact amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Raised Timestamp' ;
    rdfs:comment 'Date and time when the exception was first detected and recorded in the system. Primary business event timestamp for this transaction.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recoveryActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recovery Action Required Flag' ;
    rdfs:comment 'Boolean indicator whether recovery actions such as reshipment, replacement, or refund are required to resolve the exception.' ;
    rdfs:domain ind:FulfillmentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionActionTaken rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Taken' ;
    rdfs:comment 'Detailed description of the corrective action or resolution steps taken to address the exception, including any process changes or compensatory measures.' ;
    rdfs:domain ind:FulfillmentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Duration Minutes' ;
    rdfs:comment 'Total time in minutes from exception raised to resolution, used for Key Performance Indicator (KPI) tracking and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:FulfillmentException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Dispatches originate from specific network nodes (depots, hubs). Enables dispatch origin tracking, node-level performance analysis, and depot capacity planning. Standard in last-mile operations manage' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:serviceLevelRateId rdf:type rdf:Property ;
    rdfs:label 'Service Level Rate Id' ;
    rdfs:comment 'Foreign key linking to pricing.service_level_rate. Business justification: Last-mile dispatches are costed using service-level-specific rates for profitability analysis. Business process: last-mile cost allocation assigns delivery costs based on service level for route profi' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceLevelRate .

ind:actualPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Timestamp' ;
    rdfs:comment 'Actual date and time when the delivery agent picked up the consignment from the depot or hub. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Attempt Number' ;
    rdfs:comment 'Sequential count of delivery attempts for this consignment. Increments with each failed delivery attempt. First attempt = 1.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryFailureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Failure Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for delivery failure. Null if delivery was successful. [ENUM-REF-CANDIDATE: recipient_unavailable|address_incorrect|access_denied|refused_by_recipient|damaged_package|weather_delay|vehicle_breakdown — promote to reference product]' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryRouteCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Route Code' ;
    rdfs:comment 'Code identifying the planned delivery route or zone for this dispatch. Used for route optimization and territory management.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchDate rdf:type rdf:Property ;
    rdfs:label 'Dispatch Date' ;
    rdfs:comment 'The calendar date on which the consignment was dispatched for last-mile delivery. Primary business event date for this transaction.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispatchNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Number' ;
    rdfs:comment 'Externally-visible unique dispatch reference number used for tracking and communication. Format: DSP-XXXXXXXXXX.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Sequence Number' ;
    rdfs:comment 'Sequential position of this dispatch within the delivery route. Determines the order in which deliveries should be attempted.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchStatus rdf:type rdf:Property ;
    rdfs:label 'Dispatch Status' ;
    rdfs:comment 'Current lifecycle status of the dispatch. Tracks progression from dispatch through delivery or return. Values: dispatched (assigned to driver), in_transit (en route to delivery area), out_for_delivery (active delivery attempt), delivered (successfully completed), failed (delivery unsuccessful), returned_to_depot (consignment returned).' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Window End' ;
    rdfs:comment 'End of the planned delivery time window communicated to the customer. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDeliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Window Start' ;
    rdfs:comment 'Start of the planned delivery time window communicated to the customer. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnToDepotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return To Depot Timestamp' ;
    rdfs:comment 'Date and time when the consignment was returned to the depot after a failed delivery attempt. Null if not returned. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LastMileDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:warehouseFulfillmentCenterId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Fulfillment Center Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.center. Business justification: Merchants have default fulfillment centers where their inventory is stored and orders are processed. The warehouse_location_code STRING should be normalized to FK referencing center.fulfillment_center' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Center .

ind:apiKeyHash rdf:type rdf:Property ;
    rdfs:label 'Api Key Hash' ;
    rdfs:comment 'Hashed API authentication key for merchants using API integration channel. Stored as hash for security; actual key provided to merchant separately.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDailyOrderVolume rdf:type rdf:Property ;
    rdfs:label 'Average Daily Order Volume' ;
    rdfs:comment 'The merchant\'s average number of fulfillment orders processed per day, used for capacity planning and service tier assignment.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'First line of the merchant\'s registered business address including street number and street name.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'Second line of the merchant\'s business address for additional address details such as suite, floor, or building name.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'City or municipality of the merchant\'s registered business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Business Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the merchant\'s business address country.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the merchant\'s business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStateProvince rdf:type rdf:Property ;
    rdfs:label 'Business State Province' ;
    rdfs:comment 'State, province, or administrative region of the merchant\'s business address.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Enabled Flag' ;
    rdfs:comment 'Indicates whether the merchant is enabled for COD (Cash on Delivery) payment collection at the point of delivery. True if COD is available for this merchant\'s orders.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the credit limit amount.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Required Flag' ;
    rdfs:comment 'Indicates whether the merchant\'s shipments require customs brokerage services for cross-border fulfillment. True if customs broker assignment is mandatory.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Default Service Level' ;
    rdfs:comment 'The default delivery service level applied to merchant orders unless otherwise specified: standard (3-5 days), express (1-2 days), same_day, next_day, economy (5-7 days).' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationChannel rdf:type rdf:Property ;
    rdfs:label 'Integration Channel' ;
    rdfs:comment 'The technical channel through which the merchant integrates with Transport Shipping fulfillment systems: EDI (Electronic Data Interchange), API (Application Programming Interface), portal (web-based), SFTP (Secure File Transfer Protocol), or manual entry.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantCode rdf:type rdf:Property ;
    rdfs:label 'Merchant Code' ;
    rdfs:comment 'Externally-facing unique alphanumeric code assigned to the merchant for identification in fulfillment operations, manifests, and integration channels.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Status' ;
    rdfs:comment 'Current lifecycle status of the merchant relationship: active (operational), inactive (temporarily paused), suspended (compliance hold), onboarding (setup in progress), terminated (contract ended).' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantTier rdf:type rdf:Property ;
    rdfs:label 'Merchant Tier' ;
    rdfs:comment 'Classification of merchant based on business size and volume: enterprise (large corporate), SME (small-medium enterprise), marketplace (multi-vendor platform), startup (emerging business).' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakSeasonMultiplier rdf:type rdf:Property ;
    rdfs:label 'Peak Season Multiplier' ;
    rdfs:comment 'Multiplier factor representing the merchant\'s order volume increase during peak seasons (e.g., 2.5 means 250% of average volume). Used for capacity forecasting.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'The e-commerce platform technology used by the merchant to manage their online store and order processing. [ENUM-REF-CANDIDATE: shopify|magento|woocommerce|custom|sap_commerce|salesforce_commerce|bigcommerce — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnsEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Returns Enabled Flag' ;
    rdfs:comment 'Indicates whether the merchant has returns processing (RMA - Return Merchandise Authorization) enabled through Transport Shipping fulfillment services.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnsPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Returns Policy Code' ;
    rdfs:comment 'Reference code to the merchant\'s returns policy configuration defining return windows, conditions, and processing rules.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaOnTimeDeliveryTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Delivery Target Pct' ;
    rdfs:comment 'Contractual target percentage for on-time delivery performance (e.g., 95.00 means 95% of orders must be delivered on time).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaOrderAccuracyTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Order Accuracy Target Pct' ;
    rdfs:comment 'Contractual target percentage for order accuracy (correct items, quantities, and condition) in fulfillment operations.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantIntegrationId rdf:type rdf:Property ;
    rdfs:label 'Merchant Integration Id' ;
    rdfs:comment 'Unique identifier for the merchant integration configuration record. Primary key.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Integration troubleshooting, escalation routing, and on-call support require identifying the employee who is the technical owner of each merchant integration. Real logistics operations need to page th' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the integration channel was first activated and began processing live transactions.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL or endpoint address for REST/SOAP API integration. Contains the target server address for API calls.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiVersion rdf:type rdf:Property ;
    rdfs:label 'Api Version' ;
    rdfs:comment 'Version identifier of the API specification being used (e.g., v1, v2.1, 2023-Q4). Ensures compatibility between systems.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationCredential rdf:type rdf:Property ;
    rdfs:label 'Authentication Credential' ;
    rdfs:comment 'Encrypted or hashed authentication credential (API key, token, certificate reference) used to authenticate with the merchant platform. Stored securely.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Average Response Time Ms' ;
    rdfs:comment 'Average response time in milliseconds for API calls or message exchanges through this integration channel. Performance metric.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchProcessingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Processing Enabled Flag' ;
    rdfs:comment 'Indicates whether messages are processed in batches rather than individually. Improves throughput for high-volume integrations.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchSizeLimit rdf:type rdf:Property ;
    rdfs:label 'Batch Size Limit' ;
    rdfs:comment 'Maximum number of messages or records that can be included in a single batch transmission. Applicable when batch processing is enabled.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compressionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled Flag' ;
    rdfs:comment 'Indicates whether message payloads are compressed before transmission to reduce bandwidth usage.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeErrorCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Error Count' ;
    rdfs:comment 'Total number of integration errors or failures since activation. Used for reliability metrics and trend analysis.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataEncryptionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Data Encryption Enabled Flag' ;
    rdfs:comment 'Indicates whether data transmitted through this integration channel is encrypted in transit (TLS/SSL).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when the integration channel was deactivated or suspended. Null if currently active.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Qualifier' ;
    rdfs:comment 'EDI interchange ID qualifier code identifying the type of sender/receiver identifier (e.g., ZZ for mutually defined, 01 for DUNS number). Used in ISA segment.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'Comma-separated list of supported EDI transaction set codes (e.g., 204 for Motor Carrier Load Tender, 856 for Advanced Shipping Notice, 997 for Functional Acknowledgment). Applicable only when integration_type is EDI.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCount24h rdf:type rdf:Property ;
    rdfs:label 'Error Count 24h' ;
    rdfs:comment 'Number of integration errors or failed synchronization attempts in the last 24 hours. Used for health monitoring and alerting.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:integrationName rdf:type rdf:Property ;
    rdfs:label 'Integration Name' ;
    rdfs:comment 'Business-friendly name or label for this integration channel, used for identification and reporting purposes.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Current operational status of the integration channel. Determines whether messages are processed or queued.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationType rdf:type rdf:Property ;
    rdfs:label 'Integration Type' ;
    rdfs:comment 'Technical protocol or method used for data exchange with the merchant platform. Determines message format and connectivity requirements.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorCode rdf:type rdf:Property ;
    rdfs:label 'Last Error Code' ;
    rdfs:comment 'Error code or identifier for the most recent integration failure. Used for diagnostics and root cause analysis.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Last Error Message' ;
    rdfs:comment 'Detailed error message or description for the most recent integration failure. Provides context for troubleshooting.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Error Timestamp' ;
    rdfs:comment 'Timestamp when the most recent integration error or failure occurred.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSuccessfulSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Successful Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful data synchronization or message exchange through this integration channel.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSyncAttemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Attempt Timestamp' ;
    rdfs:comment 'Timestamp of the most recent synchronization attempt, regardless of success or failure. Used for monitoring and troubleshooting.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageFormat rdf:type rdf:Property ;
    rdfs:label 'Message Format' ;
    rdfs:comment 'Data serialization format used for message payloads exchanged through this integration channel.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageFormatVersion rdf:type rdf:Property ;
    rdfs:label 'Message Format Version' ;
    rdfs:comment 'Version identifier of the message format specification or schema being used (e.g., 1.0, 4010 for EDI X12).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pollingFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Polling Frequency Minutes' ;
    rdfs:comment 'Interval in minutes at which the system polls or checks the integration endpoint for new messages or data. Null for push-based integrations.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateLimitRequestsPerMinute rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Requests Per Minute' ;
    rdfs:comment 'Maximum number of API requests or message transmissions allowed per minute. Prevents overloading the merchant platform.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retryPolicy rdf:type rdf:Property ;
    rdfs:label 'Retry Policy' ;
    rdfs:comment 'Strategy for retrying failed integration attempts. Defines timing and behavior for automatic retry logic.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpDirectoryPath rdf:type rdf:Property ;
    rdfs:label 'Sftp Directory Path' ;
    rdfs:comment 'Remote directory path on SFTP server where files are exchanged (inbound and outbound).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpHost rdf:type rdf:Property ;
    rdfs:label 'Sftp Host' ;
    rdfs:comment 'SFTP server hostname or IP address for file-based integration. Applicable when integration_type is SFTP.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpPort rdf:type rdf:Property ;
    rdfs:label 'Sftp Port' ;
    rdfs:comment 'TCP port number for SFTP connection. Standard port is 22.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Success Rate Percentage' ;
    rdfs:comment 'Percentage of successful synchronization attempts over a defined measurement period. Key performance indicator for integration reliability.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedTransactionTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Transaction Types' ;
    rdfs:comment 'Comma-separated list of business transaction types supported by this integration (e.g., ORDER_INGEST, ASN_OUTBOUND, SHIPMENT_STATUS, INVENTORY_SYNC, RMA_NOTIFICATION).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeoutThresholdSeconds rdf:type rdf:Property ;
    rdfs:label 'Timeout Threshold Seconds' ;
    rdfs:comment 'Maximum time in seconds to wait for a response from the integration endpoint before timing out and marking the attempt as failed.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:webhookCallbackUrl rdf:type rdf:Property ;
    rdfs:label 'Webhook Callback Url' ;
    rdfs:comment 'URL endpoint on the fulfillment platform that receives push notifications from the merchant system. Applicable when integration_type is WEBHOOK.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Merchant Customer Account Id' ;
    rdfs:comment 'Reference to the merchant or customer account that originated this fulfillment order.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:procurementPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Procurement Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Fulfillment orders for internal logistics supplies (packaging materials, labels, consumables) are procured via purchase orders. Enables supply chain cost allocation and inventory replenishment trackin' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:waveId rdf:type rdf:Property ;
    rdfs:label 'Wave Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.wave. Business justification: Fulfillment orders are released in waves for coordinated pick-pack-ship execution. Adding wave_id FK is critical for linking orders to their wave assignment. This enables wave-based performance tracki' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wave .

ind:allocatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocated Timestamp' ;
    rdfs:comment 'The date and time when inventory was allocated to this order in the Warehouse Management System (WMS).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierServiceProviderCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Provider Code' ;
    rdfs:comment 'The code identifying the carrier or third-party logistics (3PL) provider selected for last-mile delivery.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'The date and time when the order was successfully delivered to the recipient and proof of delivery (POD) was captured.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatched Timestamp' ;
    rdfs:comment 'The date and time when the order was handed over to the carrier or last-mile delivery agent.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentMode rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Mode' ;
    rdfs:comment 'The operational fulfillment method used to execute this order (warehouse pick, dropship, cross-dock, etc.).' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationMessageCode rdf:type rdf:Property ;
    rdfs:label 'Integration Message Code' ;
    rdfs:comment 'The unique identifier of the EDI or API message that transmitted this order, used for omnichannel integration traceability.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantOrderReference rdf:type rdf:Property ;
    rdfs:label 'Merchant Order Reference' ;
    rdfs:comment 'The merchant\'s original order reference number or identifier from their e-commerce platform.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalOrderReference rdf:type rdf:Property ;
    rdfs:label 'Original Order Reference' ;
    rdfs:comment 'For return or exchange orders, the reference to the original fulfillment order being returned or exchanged.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packed Timestamp' ;
    rdfs:comment 'The date and time when the order was packed and ready for dispatch.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picked Timestamp' ;
    rdfs:comment 'The date and time when warehouse picking was completed for this order.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The date promised to the customer for delivery, forming the basis of the Service Level Agreement (SLA).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnFlag rdf:type rdf:Property ;
    rdfs:label 'Return Flag' ;
    rdfs:comment 'Indicates whether this order is a return merchandise authorization (RMA) order (True = return, False = forward shipment).' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'The return merchandise authorization number issued for return orders, linking back to the original order.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaWindowEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Window End Timestamp' ;
    rdfs:comment 'The end of the promised delivery time window for SLA compliance tracking.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaWindowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Window Start Timestamp' ;
    rdfs:comment 'The start of the promised delivery time window for SLA compliance tracking.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The technical channel through which the order was received (EDI, API, web portal, mobile app, manual entry).' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Item Quantity' ;
    rdfs:comment 'The total number of individual items (SKUs) included in this fulfillment order across all order lines.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'The date and time when the order passed validation checks (inventory availability, address verification, payment authorization).' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:valueAmount rdf:type rdf:Property ;
    rdfs:label 'Value Amount' ;
    rdfs:comment 'The total declared value of goods in this fulfillment order, used for insurance and customs purposes.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the order value amount.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryOrderPickerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Picker Employee Id' ;
    rdfs:comment 'Reference to the warehouse employee who picked this line item. Used for labor productivity tracking and quality accountability.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backOrderExpectedDate rdf:type rdf:Property ;
    rdfs:label 'Back Order Expected Date' ;
    rdfs:comment 'Expected date when back-ordered inventory will be available for fulfillment. Used for customer communication and inventory planning.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Back Order Flag' ;
    rdfs:comment 'Indicates whether this line item is on back order due to insufficient inventory. True if the item will be fulfilled in a subsequent shipment.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, shelf, or slot location within the warehouse where the SKU is stored. Used by WMS for pick path optimization and inventory accuracy.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValue rdf:type rdf:Property ;
    rdfs:label 'Declared Value' ;
    rdfs:comment 'Declared monetary value of the line item for insurance, customs declaration, and liability purposes. Used for cargo insurance and claims processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimensionUom rdf:type rdf:Property ;
    rdfs:label 'Dimension Uom' ;
    rdfs:comment 'Unit of measure for length, width, and height dimensions. Common values include CM (centimeter), IN (inch), M (meter), FT (foot).' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftMessage rdf:type rdf:Property ;
    rdfs:label 'Gift Message' ;
    rdfs:comment 'Customer-provided gift message to be included with this line item. Used for personalized fulfillment in e-commerce gift orders.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftWrapFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Wrap Flag' ;
    rdfs:comment 'Indicates whether gift wrapping service was requested for this line item. Triggers special handling instructions during packing operations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the SKU ordered by the customer or merchant. Represents the target fulfillment quantity before any adjustments or substitutions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalSku rdf:type rdf:Property ;
    rdfs:label 'Original Sku' ;
    rdfs:comment 'The originally ordered SKU if this line represents a substitution. Null if no substitution occurred. Used for customer communication and substitution analytics.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when the line item was packed and prepared for shipment. Used for pack productivity analysis and order cycle time measurement.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packedQuantity rdf:type rdf:Property ;
    rdfs:label 'Packed Quantity' ;
    rdfs:comment 'Quantity successfully packed and prepared for shipment. May differ from picked quantity due to quality control rejections or packing errors.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when the line item was picked from warehouse inventory. Used for pick productivity analysis and SLA tracking.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'Actual quantity picked from warehouse inventory for this line. May differ from ordered quantity due to stock availability, damage, or operational constraints.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name or description of the product being fulfilled on this line. Used for pick-pack documentation and customer communication.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure for the ordered quantity. Common values include EA (each), CS (case), PK (pack), BX (box), PL (pallet), KG (kilogram), LB (pound), LT (liter), GL (gallon). [ENUM-REF-CANDIDATE: EA|CS|PK|BX|PL|KG|LB|LT|GL — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for return. Values include DAMAGED, WRONG_ITEM, NOT_NEEDED, DEFECTIVE, SIZE_ISSUE, LATE_DELIVERY. Used for returns analytics and quality improvement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Date and time when the line item was dispatched from the fulfillment center. Used for carrier handoff tracking and delivery ETA calculation.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Final quantity dispatched to the customer. Represents the actual fulfilled quantity for billing and delivery confirmation purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether this line item is a substitution for an out-of-stock SKU. True if a substitute product was picked instead of the originally ordered SKU.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitHeight rdf:type rdf:Property ;
    rdfs:label 'Unit Height' ;
    rdfs:comment 'Height dimension of a single unit of the SKU. Used for dimensional weight calculations and warehouse slotting optimization.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitLength rdf:type rdf:Property ;
    rdfs:label 'Unit Length' ;
    rdfs:comment 'Length dimension of a single unit of the SKU. Used for dimensional weight (DIM weight) calculations and packaging optimization.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitWeight rdf:type rdf:Property ;
    rdfs:label 'Unit Weight' ;
    rdfs:comment 'Weight of a single unit of the SKU. Used for dimensional weight calculations, carrier selection, and freight cost estimation.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitWidth rdf:type rdf:Property ;
    rdfs:label 'Unit Width' ;
    rdfs:comment 'Width dimension of a single unit of the SKU. Used for dimensional weight calculations and carton selection during packing.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Code identifying the warehouse or fulfillment center location where this line item is being processed. Used for inventory allocation and pick routing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskId rdf:type rdf:Property ;
    rdfs:label 'Pack Task Id' ;
    rdfs:comment 'Unique identifier for the warehouse pack task. Primary key.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickTaskId rdf:type rdf:Property ;
    rdfs:label 'Pick Task Id' ;
    rdfs:comment 'Reference to the pick task that supplied items for this pack task.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickTask .

ind:primaryPackerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Packer Employee Id' ;
    rdfs:comment 'Reference to the warehouse employee who performed the packing activity.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Billable Weight Kg' ;
    rdfs:comment 'The greater of actual weight or dimensional weight, used for carrier billing and freight charge calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'Service level selected for delivery (e.g., express, standard, economy, same-day).' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes describing the exception details, resolution actions, or special handling instructions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragileFlag rdf:type rdf:Property ;
    rdfs:label 'Fragile Flag' ;
    rdfs:comment 'Boolean indicator whether the parcel contains fragile items requiring special handling and cushioning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemQuantityPacked rdf:type rdf:Property ;
    rdfs:label 'Item Quantity Packed' ;
    rdfs:comment 'Total number of individual items or Stock Keeping Units packed into this parcel.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Completion Timestamp' ;
    rdfs:comment 'Timestamp when the pack task was completed and the parcel was sealed and labeled.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Pack Duration Seconds' ;
    rdfs:comment 'Total time in seconds taken to complete the pack task, calculated from start to completion timestamp.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packMethod rdf:type rdf:Property ;
    rdfs:label 'Pack Method' ;
    rdfs:comment 'Method used for packing: manual by employee, semi-automated with assistance, fully automated, or robotic.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Timestamp when the packer scanned the first item or initiated the pack task at the pack station.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStationCode rdf:type rdf:Property ;
    rdfs:label 'Pack Station Code' ;
    rdfs:comment 'Identifier of the physical pack station or workstation where the packing activity occurred.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskNumber rdf:type rdf:Property ;
    rdfs:label 'Pack Task Number' ;
    rdfs:comment 'Human-readable business identifier for the pack task, typically system-generated or barcode-scanned.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Task Status' ;
    rdfs:comment 'Current lifecycle status of the pack task in the warehouse management system workflow.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packZoneCode rdf:type rdf:Property ;
    rdfs:label 'Pack Zone Code' ;
    rdfs:comment 'Code identifying the specific packing zone or area within the warehouse.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Code' ;
    rdfs:comment 'Code identifying the type of packaging material used (box, envelope, poly mailer, etc.).' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterialSku rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Sku' ;
    rdfs:comment 'Stock Keeping Unit identifier for the specific packaging material used from inventory.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingSlipIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Included Flag' ;
    rdfs:comment 'Boolean indicator whether a packing slip or invoice document was included in the parcel.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parcelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Parcel Weight Kg' ;
    rdfs:comment 'Actual weight of the packed parcel measured at the pack station in kilograms.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCheckPassedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Passed Flag' ;
    rdfs:comment 'Boolean indicator whether the packed parcel passed the quality inspection criteria.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Performed Flag' ;
    rdfs:comment 'Boolean indicator whether a quality inspection was performed on the packed parcel before dispatch.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnLabelIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Return Label Included Flag' ;
    rdfs:comment 'Boolean indicator whether a prepaid return label was included in the parcel for Return Merchandise Authorization.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippingLabelNumber rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Number' ;
    rdfs:comment 'Tracking number or barcode printed on the shipping label for carrier scanning and tracking.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingLabelPrintedFlag rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Printed Flag' ;
    rdfs:comment 'Boolean indicator whether the shipping label was successfully printed at the pack station.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidFillType rdf:type rdf:Property ;
    rdfs:label 'Void Fill Type' ;
    rdfs:comment 'Type of void fill or cushioning material used to protect items during transit.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingSupplierId rdf:type rdf:Property ;
    rdfs:label 'Packaging Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Tracks packaging material supplier for each parcel. Critical for quality control, cost analysis, and supplier performance evaluation in logistics operations. Enables root cause analysis when packaging' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Actual physical weight of the parcel measured in kilograms. Used for carrier rating and freight charge calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierServiceName rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Name' ;
    rdfs:comment 'Human-readable name of the carrier service (e.g., FedEx Priority Overnight, UPS Ground, DHL Express Worldwide).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'First line of the delivery address (street address, building number). Used for last-mile routing and electronic proof of delivery (ePOD).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line2' ;
    rdfs:comment 'Second line of the delivery address (apartment, suite, floor). Optional field for additional address details.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City or municipality of the delivery address. Used for geographic routing and service area determination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLatitude rdf:type rdf:Property ;
    rdfs:label 'Destination Latitude' ;
    rdfs:comment 'Latitude coordinate of the delivery address. Used for GPS-based route optimization and real-time tracking.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLongitude rdf:type rdf:Property ;
    rdfs:label 'Destination Longitude' ;
    rdfs:comment 'Longitude coordinate of the delivery address. Used for GPS-based route optimization and real-time tracking.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the delivery address. Critical for carrier routing and service level determination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'State, province, or region of the delivery address. Used for tax calculation and regulatory compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Dimensional Weight Kg' ;
    rdfs:comment 'Dimensional weight (DIM weight) calculated based on parcel volume and carrier-specific DIM factor. Used for freight rating when DIM weight exceeds actual weight.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatUnNumber rdf:type rdf:Property ;
    rdfs:label 'Hazmat Un Number' ;
    rdfs:comment 'Four-digit UN number identifying the dangerous goods substance (e.g., UN1203 for gasoline). Required for hazmat compliance and carrier acceptance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Height dimension of the parcel in centimeters. Used to calculate cubic meter (CBM) and dimensional weight (DIM weight).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Length dimension of the parcel in centimeters. Used to calculate cubic meter (CBM) and dimensional weight (DIM weight).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manifestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Timestamp' ;
    rdfs:comment 'Date and time when the parcel was manifested and handed over to the carrier. Used for carrier billing and service level agreement (SLA) tracking.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Code' ;
    rdfs:comment 'Code of the warehouse or fulfillment center where the parcel was packed and dispatched. Used for operational reporting and network optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterial rdf:type rdf:Property ;
    rdfs:label 'Packaging Material' ;
    rdfs:comment 'Primary material used in the packaging. Relevant for sustainability reporting and greenhouse gas (GHG) emissions tracking.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parcelStatus rdf:type rdf:Property ;
    rdfs:label 'Parcel Status' ;
    rdfs:comment 'Current lifecycle status of the parcel in the pick-pack-ship and last-mile delivery workflow. [ENUM-REF-CANDIDATE: packed|manifested|dispatched|in_transit|out_for_delivery|delivered|failed_delivery|returned|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientContactEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Contact Email' ;
    rdfs:comment 'Email address of the recipient for delivery notifications and electronic proof of delivery (ePOD) transmission.' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDeliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Time Window End' ;
    rdfs:comment 'End of the committed delivery time window for time-definite services (e.g., 12:00 PM for morning delivery).' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetDeliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Time Window Start' ;
    rdfs:comment 'Start of the committed delivery time window for time-definite services (e.g., 9:00 AM for morning delivery).' ;
    rdfs:domain ind:Parcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Width dimension of the parcel in centimeters. Used to calculate cubic meter (CBM) and dimensional weight (DIM weight).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Driver Employee Id' ;
    rdfs:comment 'Identifier of the driver or delivery agent assigned to this manifest.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:manifestDriverProfileId rdf:type rdf:Property ;
    rdfs:label 'Manifest Driver Profile Id' ;
    rdfs:comment 'Foreign key linking to fleet.driver_profile. Business justification: Manifest handoff and carrier tender require driver identification with license validation, HOS compliance verification, and certification checks (hazmat, dangerous goods). Existing driver_employee_id ' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DriverProfile .

ind:carrierAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Carrier Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the carrier acknowledged receipt of the manifest via EDI 997 functional acknowledgement or API response.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containsHazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Contains Hazmat Flag' ;
    rdfs:comment 'Indicates whether this manifest contains any parcels with hazardous materials requiring special handling and regulatory compliance.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsHighValueFlag rdf:type rdf:Property ;
    rdfs:label 'Contains High Value Flag' ;
    rdfs:comment 'Indicates whether this manifest contains parcels exceeding the high-value threshold requiring enhanced security and insurance.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationZoneCode rdf:type rdf:Property ;
    rdfs:label 'Destination Zone Code' ;
    rdfs:comment 'Geographic zone, service lane, or last-mile delivery area code to which this manifest is routed. Used for carrier route optimization and zone-based pricing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text notes documenting any discrepancies found during reconciliation (e.g., missing parcels, weight variance, damaged items).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Predicted date and time when the manifest will arrive at the destination zone or carrier hub. May be updated in real-time via carrier tracking systems.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Status' ;
    rdfs:comment 'Current lifecycle status of the manifest. Open: accepting parcels; Closed: no further additions; Dispatched: handed to carrier; In Transit: en route; Delivered: completed; Reconciled: audit complete; Cancelled: voided. [ENUM-REF-CANDIDATE: open|closed|dispatched|in_transit|delivered|reconciled|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestType rdf:type rdf:Property ;
    rdfs:label 'Manifest Type' ;
    rdfs:comment 'Classification of the manifest based on its operational purpose. Outbound: customer deliveries; Inbound: returns; Transfer: inter-facility; Return: RMA; Cross-dock: direct transfer.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Timestamp' ;
    rdfs:comment 'Scheduled date and time for the vehicle or carrier to depart from the origin facility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalDeclaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Declared Value Amount' ;
    rdfs:comment 'Sum of declared values of all parcels in the manifest. Used for insurance coverage and liability determination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalParcelCount rdf:type rdf:Property ;
    rdfs:label 'Total Parcel Count' ;
    rdfs:comment 'Total number of individual parcels included in this manifest. Used for carrier handover verification and freight audit.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumetricWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Volumetric Weight Kg' ;
    rdfs:comment 'Total dimensional weight (DIM weight) of all parcels calculated using carrier-specific volumetric divisor. Used for freight rating when volumetric weight exceeds actual weight.' ;
    rdfs:domain ind:ParcelManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnCarrierId rdf:type rdf:Property ;
    rdfs:label 'Return Carrier Id' ;
    rdfs:comment 'Foreign key linking to network.carrier. Business justification: Returns are shipped via carriers. Business process: reverse logistics carrier selection, return carrier performance tracking, return shipping cost allocation. Role-prefixed to distinguish from potenti' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:returnCustomsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Return Customs Declaration Id' ;
    rdfs:comment 'Foreign key linking to customs.declaration. Business justification: International returns require customs declarations for re-import processing. Supports reverse logistics customs clearance tracking, duty drawback claims, and RMA processing timelines that depend on cu' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Declaration .

ind:returnTransportDocumentId rdf:type rdf:Property ;
    rdfs:label 'Return Transport Document Id' ;
    rdfs:comment 'Foreign key linking to document.transport_document. Business justification: Return shipments require return labels and documentation. Real process: RMA approval triggers return label generation and return shipping documentation for reverse logistics.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportDocument .

ind:rmaInspectedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rma Inspected By Employee Id' ;
    rdfs:comment 'Identifier of the warehouse employee who performed the condition inspection. Used for quality control and accountability.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rmaReceivedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rma Received By Employee Id' ;
    rdfs:comment 'Identifier of the warehouse employee who processed the receipt of the returned merchandise. Used for accountability and audit trails.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:vendorSupplierId rdf:type rdf:Property ;
    rdfs:label 'Vendor Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: RMA processing may involve supplier coordination for defective goods, warranty claims, or vendor returns. Enables vendor return authorization tracking and supplier quality issue escalation.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Actual date when the returned merchandise was physically received at the return processing facility. Nullable if not yet received.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the returned merchandise was scanned into the warehouse management system upon receipt.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conditionAssessmentCode rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment Code' ;
    rdfs:comment 'Assessment of the physical condition of the returned merchandise upon inspection. Determines disposition and restocking eligibility.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAssessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment Notes' ;
    rdfs:comment 'Free-text notes from the warehouse inspector describing the condition of the returned merchandise in detail.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'Instruction for how the returned merchandise should be handled. Determines the next step in the reverse logistics workflow. [ENUM-REF-CANDIDATE: restock|destroy|return_to_merchant|liquidate|donate|repair|quarantine — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Estimated date when the returned merchandise is expected to arrive at the return processing facility or merchant location.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalRmaReference rdf:type rdf:Property ;
    rdfs:label 'External Rma Reference' ;
    rdfs:comment 'External reference number from the merchant or e-commerce platform system. Used for cross-system reconciliation.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the returned merchandise was inspected and condition assessment was completed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:merchantApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Merchant Approved Flag' ;
    rdfs:comment 'Indicates whether the merchant has approved the return request. True if approved, False if rejected or pending.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Refund Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the refund amount. Examples: USD, EUR, GBP.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method by which the refund will be issued to the customer. Typically matches the original payment method.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was successfully processed and funds were released. Nullable if refund not yet processed.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundTriggerStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Trigger Status' ;
    rdfs:comment 'Status of the refund or credit process triggered by this RMA. Tracks whether financial settlement has been initiated and completed.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockedFlag rdf:type rdf:Property ;
    rdfs:label 'Restocked Flag' ;
    rdfs:comment 'Indicates whether the returned merchandise has been restocked into sellable inventory. True if restocked, False otherwise.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Restocked Timestamp' ;
    rdfs:comment 'Date and time when the returned merchandise was restocked into inventory. Nullable if not restocked.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee charged to the customer or merchant for processing the return. Deducted from the refund amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnLabelGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Return Label Generated Flag' ;
    rdfs:comment 'Indicates whether a return shipping label has been generated for the customer. True if label has been created and provided to the customer.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnLabelGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Label Generated Timestamp' ;
    rdfs:comment 'Date and time when the return shipping label was generated. Nullable if label has not yet been created.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnPolicyCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Return Policy Compliant Flag' ;
    rdfs:comment 'Indicates whether the return request complies with the applicable return policy terms. True if compliant, False if exception or policy violation.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Free-text description providing additional details about the reason for the return. Captures customer or merchant comments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Return Service Level' ;
    rdfs:comment 'Service level selected for the return shipment. Determines transit time and cost for the return.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Tracking Number' ;
    rdfs:comment 'Unique tracking number assigned by the return carrier for shipment visibility. Used to monitor return shipment progress.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWarehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Return Warehouse Location Code' ;
    rdfs:comment 'Code identifying the warehouse or return processing center where the merchandise was received. Links to facility master data.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowDays rdf:type rdf:Property ;
    rdfs:label 'Return Window Days' ;
    rdfs:comment 'Number of days from original delivery within which the return was initiated. Used to validate compliance with return policy.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the return authorization. Tracks the return from initial request through final disposition. [ENUM-REF-CANDIDATE: requested|approved|rejected|label_generated|in_transit|received|inspected|completed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetProcessingDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Processing Days' ;
    rdfs:comment 'Target number of days within which the return should be processed from receipt to disposition. Defined by service level agreement.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachId rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Id' ;
    rdfs:comment 'Unique identifier for the SLA breach event record. Primary key.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Resolved By Employee Id' ;
    rdfs:comment 'Reference to the employee who resolved and closed the SLA breach record.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:breachDetectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Detected Timestamp' ;
    rdfs:comment 'Date and time when the SLA breach was first detected by the system or operations team.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Breach Duration Minutes' ;
    rdfs:comment 'The duration of the SLA breach measured in minutes, calculated as the difference between actual completion and promised SLA timestamp.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachNumber rdf:type rdf:Property ;
    rdfs:label 'Breach Number' ;
    rdfs:comment 'Externally visible unique business identifier for the SLA breach event, used for tracking and reporting.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachStatus rdf:type rdf:Property ;
    rdfs:label 'Breach Status' ;
    rdfs:comment 'Current lifecycle status of the SLA breach record: open (newly detected), under-review (investigation in progress), closed (resolved), escalated (sent to management), or disputed (customer challenge).' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachType rdf:type rdf:Property ;
    rdfs:label 'Breach Type' ;
    rdfs:comment 'Classification of the SLA breach by operational stage: OTD (On-Time Delivery), OTIF (On-Time In-Full), pick-SLA, pack-SLA, dispatch-SLA, or delivery-SLA.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Flag' ;
    rdfs:comment 'Indicates whether the customer has been notified of the SLA breach. True if notified, False if not.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Timestamp' ;
    rdfs:comment 'Date and time when the dispute regarding the SLA breach was resolved, if applicable.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promisedSlaTimestamp rdf:type rdf:Property ;
    rdfs:label 'Promised Sla Timestamp' ;
    rdfs:comment 'The contractually committed or customer-promised date and time by which the service level was to be met.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Planner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Wave planning accountability, performance analysis, and operational coordination require tracking which employee planned and released each wave. Real warehouse operations need to identify the planner ' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualParcelsShipped rdf:type rdf:Property ;
    rdfs:label 'Actual Parcels Shipped' ;
    rdfs:comment 'Actual count of parcels successfully packed and manifested from this wave. May differ from expected due to order cancellations or inventory shortages.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedLaborPoolCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Labor Pool Code' ;
    rdfs:comment 'Identifier of the labor pool or team assigned to execute this wave. Links to workforce scheduling and labor management systems.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedZoneCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Zone Code' ;
    rdfs:comment 'Warehouse zone or picking area code where this wave is executed. Used for zone-based wave planning and slotting optimization.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierServiceType rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Type' ;
    rdfs:comment 'Primary carrier service type for orders in this wave (e.g., express, standard, economy). Used for carrier-specific wave grouping and manifest preparation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cutoff Timestamp' ;
    rdfs:comment 'Deadline timestamp by which all orders in this wave must be picked, packed, and ready for dispatch to meet carrier pickup schedules and SLA commitments.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:efficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Efficiency Percent' ;
    rdfs:comment 'Calculated efficiency percentage of wave execution based on planned vs actual cycle time and labor utilization. Used for continuous improvement and wave planning optimization.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manifestGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Generated Timestamp' ;
    rdfs:comment 'Timestamp when the carrier shipping manifest was generated for parcels in this wave. Critical for carrier pickup coordination and EDI transmission.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack End Timestamp' ;
    rdfs:comment 'Actual timestamp when the last packing task in this wave was completed. Used for pack cycle time and throughput KPI calculation.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick End Timestamp' ;
    rdfs:comment 'Actual timestamp when the last pick task in this wave was completed. Used for pick cycle time and throughput KPI calculation.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickMethod rdf:type rdf:Property ;
    rdfs:label 'Pick Method' ;
    rdfs:comment 'Picking methodology applied for this wave: discrete (order-by-order), batch (multiple orders picked together), cluster (cart-based multi-order), zone (zone-to-zone handoff), or wave (coordinated multi-zone).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the first pick task in this wave was started by warehouse staff. Used for labor productivity and cycle time analysis.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled date and time for wave execution to begin. Used for labor planning and capacity scheduling.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortPickCount rdf:type rdf:Property ;
    rdfs:label 'Short Pick Count' ;
    rdfs:comment 'Count of order lines that could not be fully picked due to inventory shortage or location discrepancies. Key metric for inventory accuracy and fulfillment quality.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetShipDate rdf:type rdf:Property ;
    rdfs:label 'Target Ship Date' ;
    rdfs:comment 'Target date by which all parcels in this wave must be shipped to meet customer delivery commitments and SLA windows.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalOrderLines rdf:type rdf:Property ;
    rdfs:label 'Total Order Lines' ;
    rdfs:comment 'Total count of individual order line items (SKUs) across all orders in the wave. Used for pick task volume estimation.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrders rdf:type rdf:Property ;
    rdfs:label 'Total Orders' ;
    rdfs:comment 'Total count of fulfillment orders included in this wave release. Core metric for wave size and labor allocation.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalParcelsExpected rdf:type rdf:Property ;
    rdfs:label 'Total Parcels Expected' ;
    rdfs:comment 'Expected total count of shipping parcels or packages to be generated from this wave. Used for packing station capacity planning and carrier manifest preparation.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total quantity of individual units (eaches) to be picked across all orders in the wave. Key metric for labor productivity and pick rate calculation.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Business-assigned unique wave number or code for tracking and reference within the fulfillment center.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveStatus rdf:type rdf:Property ;
    rdfs:label 'Wave Status' ;
    rdfs:comment 'Current lifecycle status of the wave: planned (scheduled but not released), released (active for picking), in-progress (picking underway), completed (all orders picked and packed), cancelled (wave aborted), or on-hold (temporarily suspended).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveType rdf:type rdf:Property ;
    rdfs:label 'Wave Type' ;
    rdfs:comment 'Classification of the wave strategy: single-order (discrete pick), multi-order (batch pick), batch (grouped orders), zone (zone-based picking), replenishment (inventory replenishment), or cross-dock (direct transfer).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentStatus rdf:type rdf:Property ;
    rdfs:label 'Agent Status' ;
    rdfs:comment 'The current lifecycle status of the agent relationship. Active agents are authorized to conduct business; inactive agents are temporarily not operating; suspended agents have had privileges revoked pending review; pending approval agents are undergoing onboarding; terminated agents have had their relationship permanently ended.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentType rdf:type rdf:Property ;
    rdfs:label 'Agent Type' ;
    rdfs:comment 'Classification of the agent based on their primary operational role in the logistics network. Freight agents represent carriers for cargo booking; GSAs (General Sales Agents) represent airlines for sales and marketing; handling agents provide ground services at airports/ports; customs agents facilitate trade compliance; co-loaders consolidate shipments; ground handling agents provide airport ramp and terminal services.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondAmount rdf:type rdf:Property ;
    rdfs:label 'Bond Amount' ;
    rdfs:comment 'The monetary value of the customs bond or financial guarantee held by the agent, expressed in the agent\'s local currency. Represents the maximum liability coverage for customs duties and taxes.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Bond Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code for the bond amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondingStatus rdf:type rdf:Property ;
    rdfs:label 'Bonding Status' ;
    rdfs:comment 'Indicates whether the agent holds a valid customs bond or financial guarantee required for handling in-bond cargo movements and customs clearance activities. Bonded status is mandatory for customs agents.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionStructureType rdf:type rdf:Property ;
    rdfs:label 'Commission Structure Type' ;
    rdfs:comment 'The method by which the agent earns compensation for services rendered. Percentage commissions are based on shipment value or freight charges; flat fees are fixed per transaction; tiered structures vary by volume thresholds; hybrid combines multiple methods.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiataMember rdf:type rdf:Property ;
    rdfs:label 'Fiata Member' ;
    rdfs:comment 'Indicates whether the agent is a member of FIATA, the global representative body for freight forwarders and logistics providers, which provides industry standards and advocacy.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataAgentCode rdf:type rdf:Property ;
    rdfs:label 'Iata Agent Code' ;
    rdfs:comment 'The unique numeric code assigned by IATA to accredited cargo and passenger sales agents, typically 7 or 8 digits. Required for agents handling air waybills (AWBs) and airline bookings.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code for the insurance coverage amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the agent holds ISO 9001 certification for quality management systems, demonstrating adherence to international standards for process consistency and customer satisfaction.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'The scheduled date for the next periodic audit of the agent\'s operations and compliance status, typically conducted annually or biennially.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nvoccLicensed rdf:type rdf:Property ;
    rdfs:label 'Nvocc Licensed' ;
    rdfs:comment 'Indicates whether the agent holds a valid NVOCC license, allowing them to issue house bills of lading (HBLs) and operate as a carrier without owning vessels.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalScope rdf:type rdf:Property ;
    rdfs:label 'Operational Scope' ;
    rdfs:comment 'The geographic reach of the agent\'s service capabilities. Local agents serve a single city or metro area; regional agents cover multiple cities or provinces; national agents operate across an entire country; international agents have cross-border capabilities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalCarrierRelationships rdf:type rdf:Property ;
    rdfs:label 'Principal Carrier Relationships' ;
    rdfs:comment 'Comma-separated list of carrier names or IATA/SCAC codes for which this agent acts as an authorized representative or sales agent. Defines the agent\'s network affiliations and booking authority.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Standard Commission Rate' ;
    rdfs:comment 'The default commission percentage or flat fee amount applied to transactions handled by the agent, expressed as a percentage (e.g., 5.00 for 5%) or monetary value depending on commission structure type.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportModesSupported rdf:type rdf:Property ;
    rdfs:label 'Transport Modes Supported' ;
    rdfs:comment 'Comma-separated list of transport modes the agent is authorized and equipped to handle (e.g., air, ocean, road, rail, multimodal). Indicates the agent\'s operational versatility across different freight types.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The agent\'s official website address, providing access to service information, contact details, and online booking capabilities.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Agent Appointment Id' ;
    rdfs:comment 'Unique identifier for the agent appointment record. Primary key for the agent appointment entity.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointedAgentId rdf:type rdf:Property ;
    rdfs:label 'Appointed Agent Id' ;
    rdfs:comment 'Identifier of the freight agent or General Sales Agent (GSA) being appointed to act on behalf of the appointing party.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:primaryAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Agent Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the agent appointment. Null if appointment is not yet approved or approval is not tracked.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aeoCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification Flag' ;
    rdfs:comment 'Indicates whether the agent holds Authorized Economic Operator (AEO) certification, demonstrating secure and compliant supply chain practices. True means certified; False means not certified.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appointmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Effective Date' ;
    rdfs:comment 'Date when the agent appointment becomes active and the agent is authorized to begin operations on behalf of the appointing party.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Expiry Date' ;
    rdfs:comment 'Date when the agent appointment expires and the agent authority terminates. Nullable for open-ended appointments subject to termination notice.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Reference Number' ;
    rdfs:comment 'External business reference number for the agent appointment, used in contracts and communications with the appointed agent.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the agent appointment. Active indicates the agent is authorized to operate; suspended indicates temporary halt of authority; terminated indicates permanent revocation; expired indicates natural end of appointment term.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentTermMonths rdf:type rdf:Property ;
    rdfs:label 'Appointment Term Months' ;
    rdfs:comment 'Duration of the appointment term expressed in months. Used for fixed-term appointments. Null for indefinite appointments.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of the agent appointment indicating the nature of the agency relationship. GSA (General Sales Agent) represents full sales authority; freight agent handles specific services; correspondent provides local representation; sub-agent operates under another agent.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedServiceLines rdf:type rdf:Property ;
    rdfs:label 'Authorized Service Lines' ;
    rdfs:comment 'Semicolon-separated list of service lines the agent is authorized to sell or manage. May include express parcel, air freight, ocean freight, road freight, rail freight, customs brokerage, warehousing, last-mile delivery, e-commerce fulfillment.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedTransportModes rdf:type rdf:Property ;
    rdfs:label 'Authorized Transport Modes' ;
    rdfs:comment 'Semicolon-separated list of transport modes the agent is authorized to handle. May include air, ocean, road, rail, multimodal.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionBasis rdf:type rdf:Property ;
    rdfs:label 'Commission Basis' ;
    rdfs:comment 'Basis on which the commission is calculated. Gross revenue includes all charges; net revenue excludes certain pass-through costs; margin is based on profit; per-shipment is fixed fee per transaction; tiered varies by volume thresholds.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Commission Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which commission payments are denominated.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Percentage commission rate paid to the agent on revenue generated within their territory and service scope. Expressed as percentage (e.g., 5.50 for 5.5%).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the formal contract or agreement document governing this agent appointment. May link to document management system.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpatCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certification Flag' ;
    rdfs:comment 'Indicates whether the agent holds C-TPAT certification, a US Customs and Border Protection program for supply chain security. True means certified; False means not certified.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsBrokerLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License Flag' ;
    rdfs:comment 'Indicates whether the agent holds a valid customs broker license, required for handling customs clearance and trade compliance services. True means licensed; False means not licensed.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the agent has exclusive rights to represent the appointing party in the defined territory. True means no other agents may be appointed in the same territory for the same services; False allows multiple agents.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataAccreditationFlag rdf:type rdf:Property ;
    rdfs:label 'Iata Accreditation Flag' ;
    rdfs:comment 'Indicates whether the agent holds valid IATA accreditation, required for handling air freight and issuing Air Waybills (AWB). True means accredited; False means not accredited.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCoverageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the insurance coverage amount is denominated.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Required Flag' ;
    rdfs:comment 'Indicates whether the agent is required to maintain liability insurance coverage as a condition of the appointment. True requires insurance; False does not.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumRevenueCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Revenue Commitment' ;
    rdfs:comment 'Minimum revenue the agent commits to generate during the appointment term. Failure to meet this may trigger penalties or termination. Null if no minimum is specified.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRevenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Minimum Revenue Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the minimum revenue commitment is denominated.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nvoccLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Nvocc License Flag' ;
    rdfs:comment 'Indicates whether the agent holds a valid NVOCC license, required for ocean freight consolidation and issuing House Bills of Lading (HBL). True means licensed; False means not licensed.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'Monetary value of the performance bond or financial guarantee required from the agent, if applicable. Null if no bond is required.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the performance bond amount is denominated.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required Flag' ;
    rdfs:comment 'Indicates whether the agent is required to post a performance bond or financial guarantee as a condition of the appointment. True requires bond; False does not.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Terms under which the appointment may be renewed at expiry. Automatic renews unless terminated; mutual consent requires both parties to agree; appointing party option allows appointing party to renew unilaterally; agent option allows agent to renew; no renewal means appointment ends at expiry.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code defining the geographic territory where the agent is authorized to operate.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRegion rdf:type rdf:Property ;
    rdfs:label 'Territory Region' ;
    rdfs:comment 'Specific region, state, province, or sub-national area within the country where the agent appointment is valid. May include multiple regions separated by semicolons.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Granularity level of the geographic territory covered by the appointment. National covers entire country; regional covers specific provinces/states; city/port/airport/station covers specific locations.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLaneId rdf:type rdf:Property ;
    rdfs:label 'Trade Lane Id' ;
    rdfs:comment 'Reference to the specific trade lane (origin-destination corridor) covered by this blocked space agreement, such as Asia-Europe or Trans-Pacific.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:agreementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Reference Number' ;
    rdfs:comment 'The externally-known business identifier or contract number for this blocked space agreement, used in communications with the carrier and internal stakeholders.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationFrequency rdf:type rdf:Property ;
    rdfs:label 'Allocation Frequency' ;
    rdfs:comment 'The frequency at which the guaranteed capacity is allocated or refreshed (e.g., weekly allocation of 100 TEU, monthly allocation of 50,000 kg).' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Base Rate Per Unit' ;
    rdfs:comment 'The base freight rate per unit of capacity (per TEU, per kg, per CBM) agreed in this blocked space agreement. Subject to surcharges and adjustments.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedSpaceAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Blocked Space Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the blocked space agreement. Draft indicates under negotiation; Active indicates in force; Suspended indicates temporarily paused; Expired indicates past end date; Terminated indicates cancelled before expiry; Pending Renewal indicates approaching expiry with renewal in progress.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Primary unit of measure used to express the guaranteed capacity in this agreement: TEU for ocean containers, kg or CBM for air freight, or pallets for specialized services.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Summary of the force majeure provisions that excuse performance under extraordinary circumstances (e.g., natural disasters, war, strikes, pandemics).' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Capacity Cbm' ;
    rdfs:comment 'Total volume capacity guaranteed to Transport Shipping measured in cubic meters. Applicable to both ocean LCL and air freight agreements.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Capacity Kg' ;
    rdfs:comment 'Total weight capacity guaranteed to Transport Shipping measured in kilograms for air freight agreements. Null for ocean agreements.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Capacity Teu' ;
    rdfs:comment 'Total capacity guaranteed to Transport Shipping measured in TEU (Twenty-foot Equivalent Units) for ocean agreements. Null for air freight agreements.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumUtilizationCommitmentAbsolute rdf:type rdf:Property ;
    rdfs:label 'Minimum Utilization Commitment Absolute' ;
    rdfs:comment 'The minimum absolute quantity of capacity (in the agreement\'s unit of measure) that Transport Shipping commits to utilize. Alternative or complementary to percentage-based commitment.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumUtilizationCommitmentPercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Utilization Commitment Percent' ;
    rdfs:comment 'The minimum percentage of guaranteed capacity that Transport Shipping commits to utilize over the agreement period. Failure to meet this threshold may trigger penalties.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyForUnderutilization rdf:type rdf:Property ;
    rdfs:label 'Penalty For Underutilization' ;
    rdfs:comment 'Description of the financial or operational penalty imposed if Transport Shipping fails to meet the minimum utilization commitment (e.g., payment for unused capacity, rate adjustment, loss of priority).' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the base rate (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverLimitPercent rdf:type rdf:Property ;
    rdfs:label 'Rollover Limit Percent' ;
    rdfs:comment 'Maximum percentage of unused capacity that can be rolled over to the next allocation period, if rollover is allowed. Null if no limit or rollover not allowed.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signedByCarrier rdf:type rdf:Property ;
    rdfs:label 'Signed By Carrier' ;
    rdfs:comment 'Name and title of the carrier authorized signatory who executed this agreement.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedByTransportShipping rdf:type rdf:Property ;
    rdfs:label 'Signed By Transport Shipping' ;
    rdfs:comment 'Name and title of the Transport Shipping authorized signatory who executed this agreement.' ;
    rdfs:domain ind:BlockedSpaceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAllocationId rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation Id' ;
    rdfs:comment 'Unique identifier for the capacity allocation record. Primary key for the capacity allocation entity.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractAgreementId rdf:type rdf:Property ;
    rdfs:label 'Contract Agreement Id' ;
    rdfs:comment 'Reference to the master carrier agreement or partnership contract under which this capacity allocation is governed.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:primaryCapacityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Capacity Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that created the capacity allocation record.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Pallet Positions' ;
    rdfs:comment 'Total pallet position capacity allocated by the carrier or partner for the specified period and trade lane. Applicable to road and rail freight.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Teu' ;
    rdfs:comment 'Total container capacity allocated by the carrier for the specified period and trade lane, measured in TEU. Applicable to ocean freight (FCL shipments).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedCapacityVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Volume Cbm' ;
    rdfs:comment 'Total volume capacity allocated by the carrier or partner for the specified period and trade lane, measured in cubic meters. Applicable to all transport modes.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedCapacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Weight Kg' ;
    rdfs:comment 'Total weight capacity allocated by the carrier or partner for the specified period and trade lane, measured in kilograms. Applicable primarily to air and road freight.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for any financial terms associated with the capacity allocation (e.g., minimum commitment charges, overage fees).' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'The date when the capacity allocation expires or is no longer available for booking. Nullable for open-ended allocations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text field for additional notes, special conditions, or operational instructions related to the capacity allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPeriodType rdf:type rdf:Property ;
    rdfs:label 'Allocation Period Type' ;
    rdfs:comment 'Frequency or granularity of the capacity allocation period: daily, weekly, monthly, quarterly, or annual allocation cycle.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Reference Number' ;
    rdfs:comment 'External business identifier for the capacity allocation, typically provided by the carrier or partner for tracking and reconciliation purposes.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Start Date' ;
    rdfs:comment 'The date when the capacity allocation becomes effective and available for booking.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingCutoffHours rdf:type rdf:Property ;
    rdfs:label 'Booking Cutoff Hours' ;
    rdfs:comment 'Number of hours before departure or shipment date by which bookings must be made to utilize this capacity allocation.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Fill Rate Percent' ;
    rdfs:comment 'Percentage of allocated capacity that has been utilized during the period, calculated as (utilized / allocated) * 100. Key performance indicator for capacity procurement efficiency.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacitySourceType rdf:type rdf:Property ;
    rdfs:label 'Capacity Source Type' ;
    rdfs:comment 'Type of capacity procurement arrangement: blocked space agreement (BSA), allotment, spot market purchase, long-term contract, or ad-hoc allocation.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityRestriction rdf:type rdf:Property ;
    rdfs:label 'Commodity Restriction' ;
    rdfs:comment 'Restrictions on commodity types that can be shipped using this capacity allocation (e.g., general cargo only, no hazardous materials, perishables only). Nullable if no restrictions apply.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Amount' ;
    rdfs:comment 'Minimum financial commitment or guaranteed payment amount for the capacity allocation, regardless of utilization. Nullable if no minimum commitment exists.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Overage Rate Per Unit' ;
    rdfs:comment 'Additional charge per unit (kg, TEU, CBM, pallet) if utilization exceeds the allocated capacity. Nullable if overage is not permitted or not charged.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizedCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Utilized Capacity Pallet Positions' ;
    rdfs:comment 'Actual pallet position capacity utilized or booked against the allocation during the period.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizedCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Utilized Capacity Teu' ;
    rdfs:comment 'Actual container capacity utilized or booked against the allocation during the period, measured in TEU.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizedCapacityVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Utilized Capacity Volume Cbm' ;
    rdfs:comment 'Actual volume capacity utilized or booked against the allocation during the period, measured in cubic meters.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizedCapacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Utilized Capacity Weight Kg' ;
    rdfs:comment 'Actual weight capacity utilized or booked against the allocation during the period, measured in kilograms.' ;
    rdfs:domain ind:CapacityAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfRegistration rdf:type rdf:Property ;
    rdfs:label 'Country Of Registration' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the carrier is legally registered and holds its primary operating license.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerageService rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Service' ;
    rdfs:comment 'Indicates whether the carrier provides in-house customs brokerage services for import/export clearance, or if third-party brokers must be engaged.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediEnabled rdf:type rdf:Property ;
    rdfs:label 'Edi Enabled' ;
    rdfs:comment 'Indicates whether the carrier supports EDI for structured electronic document exchange (e.g., booking confirmations, status updates, invoices).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiataCertified rdf:type rdf:Property ;
    rdfs:label 'Fiata Certified' ;
    rdfs:comment 'Indicates whether the carrier holds FIATA certification, demonstrating compliance with international freight forwarding standards.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialStanding rdf:type rdf:Property ;
    rdfs:label 'Financial Standing' ;
    rdfs:comment 'Assessment of the carrier\'s financial health and creditworthiness based on credit ratings, financial statements, and payment history. Used for risk management and credit limit decisions.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full street address of the carrier\'s corporate headquarters, including street, city, state/province, and postal code.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCertified rdf:type rdf:Property ;
    rdfs:label 'Iata Certified' ;
    rdfs:comment 'Indicates whether the carrier holds valid IATA certification for air cargo operations. Required for participation in IATA cargo agency programs.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCurrency rdf:type rdf:Property ;
    rdfs:label 'Insurance Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the insurance coverage amount.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso28000Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 28000 Certified' ;
    rdfs:comment 'Indicates whether the carrier holds ISO 28000 certification for supply chain security management systems.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingStage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Stage' ;
    rdfs:comment 'Current stage in the carrier onboarding lifecycle, from initial prospect through active operations to potential offboarding.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdPercentage rdf:type rdf:Property ;
    rdfs:label 'Otd Percentage' ;
    rdfs:comment 'Percentage of shipments delivered on or before the committed delivery date over the last 12 months. Key performance indicator for carrier reliability.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredCarrierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Flag' ;
    rdfs:comment 'Indicates whether this carrier has preferred status in Transport Shipping\'s network, receiving priority allocation and preferential rates due to strategic partnership or superior performance.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureControlledCapable rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Capable' ;
    rdfs:comment 'Indicates whether the carrier has temperature-controlled (reefer) capabilities for perishable and pharmaceutical shipments requiring cold chain management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transportModes rdf:type rdf:Property ;
    rdfs:label 'Transport Modes' ;
    rdfs:comment 'Comma-separated list of transport modes the carrier operates: air, ocean, road, rail, multimodal. Indicates the carrier\'s operational capabilities across different freight modes.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierContactId rdf:type rdf:Property ;
    rdfs:label 'Carrier Contact Id' ;
    rdfs:comment 'Unique identifier for the carrier contact record. Primary key.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierProfileId rdf:type rdf:Property ;
    rdfs:label 'Carrier Profile Id' ;
    rdfs:comment 'Reference to the carrier or network partner organization this contact represents.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierProfile .

ind:contactFirstName rdf:type rdf:Property ;
    rdfs:label 'Contact First Name' ;
    rdfs:comment 'Given name of the contact person.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFullName rdf:type rdf:Property ;
    rdfs:label 'Contact Full Name' ;
    rdfs:comment 'Full legal name of the individual contact at the carrier or partner organization.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactLastName rdf:type rdf:Property ;
    rdfs:label 'Contact Last Name' ;
    rdfs:comment 'Family name or surname of the contact person.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Flag' ;
    rdfs:comment 'Indicates whether this contact should be reached for emergency or critical operational issues requiring immediate attention.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the contact, used for document transmission where required by legacy processes or regulatory requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent communication or interaction with this contact.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cellular phone number for the contact, used for urgent or after-hours communication.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Physical office location or branch where the contact is based (e.g., city, country, or facility name).' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method of communication for routine business interactions.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Secondary Email Address' ;
    rdfs:comment 'Alternate email address for the contact, used for backup communication or escalation.' ;
    rdfs:domain ind:CarrierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationAvailable rdf:type rdf:Property ;
    rdfs:label 'Api Integration Available' ;
    rdfs:comment 'Indicates whether the carrier provides API (Application Programming Interface) integration for real-time booking, tracking, and rate queries.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiProtocol rdf:type rdf:Property ;
    rdfs:label 'Api Protocol' ;
    rdfs:comment 'Type of API protocol supported by the carrier: REST, SOAP, GraphQL, proprietary, or none if no API available.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageTransitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Transit Time Days' ;
    rdfs:comment 'Average transit time in days for shipments handled by this carrier profile, calculated from historical data.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonReportingAvailable rdf:type rdf:Property ;
    rdfs:label 'Carbon Reporting Available' ;
    rdfs:comment 'Indicates whether the carrier provides CO2e (Carbon Dioxide Equivalent) emissions reporting for shipments.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimsRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Claims Ratio Percentage' ;
    rdfs:comment 'Historical cargo claims ratio as a percentage of total shipments (0.00 to 100.00). Lower is better.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countriesServed rdf:type rdf:Property ;
    rdfs:label 'Countries Served' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where carrier provides service (e.g., USA, CAN, MEX, GBR, DEU, CHN).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderCapable rdf:type rdf:Property ;
    rdfs:label 'Cross Border Capable' ;
    rdfs:comment 'Indicates whether the carrier handles cross-border international shipments including customs clearance coordination.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsBrokerageIncluded rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Included' ;
    rdfs:comment 'Indicates whether the carrier provides in-house customs brokerage services as part of their offering.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dgClassesHandled rdf:type rdf:Property ;
    rdfs:label 'Dg Classes Handled' ;
    rdfs:comment 'Comma-separated list of UN dangerous goods classes the carrier is certified to handle (e.g., Class 1 Explosives, Class 3 Flammable Liquids, Class 8 Corrosives). Null if not DG certified.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypes rdf:type rdf:Property ;
    rdfs:label 'Equipment Types' ;
    rdfs:comment 'Comma-separated list of equipment types operated: dry_van, reefer, flatbed, tanker, container_20ft, container_40ft, container_40ft_hc, aircraft_freighter, rail_car, barge. [ENUM-REF-CANDIDATE: dry_van|reefer|flatbed|tanker|container_20ft|container_40ft|container_40ft_hc|aircraft_freighter|rail_car|barge|lowboy|chassis — promote to reference product]' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Scope' ;
    rdfs:comment 'Overall geographic reach of the carrier: global (worldwide), regional (multi-country region), national (single country), local (city/metro), or trade-lane-specific (dedicated corridors).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAvailable rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Available' ;
    rdfs:comment 'Indicates whether the carrier offers cargo insurance coverage as part of their service or through a partner.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMileCapable rdf:type rdf:Property ;
    rdfs:label 'Last Mile Capable' ;
    rdfs:comment 'Indicates whether the carrier provides last-mile delivery services to final consignee addresses (residential or commercial).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxInsuranceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Max Insurance Value Usd' ;
    rdfs:comment 'Maximum cargo value in USD that can be insured per shipment. Null if insurance not available.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Internal performance tier classification based on OTD (On-Time Delivery), claims ratio, and service quality: platinum (best), gold, silver, bronze, or standard.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Unique business identifier code for this carrier profile used in operational systems and partner integrations.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Business-friendly name for this carrier operational profile (e.g., \'Global Express Air\', \'Regional LTL Network\').' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertifications rdf:type rdf:Property ;
    rdfs:label 'Quality Certifications' ;
    rdfs:comment 'Comma-separated list of quality and compliance certifications held by the carrier (e.g., ISO 9001, C-TPAT, AEO, TAPA, GDP).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realTimeTrackingAvailable rdf:type rdf:Property ;
    rdfs:label 'Real Time Tracking Available' ;
    rdfs:comment 'Indicates whether the carrier provides real-time GPS or milestone-based shipment tracking visibility.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionsServed rdf:type rdf:Property ;
    rdfs:label 'Regions Served' ;
    rdfs:comment 'Comma-separated list of geographic regions where carrier operates (e.g., North America, Europe, Asia Pacific, Middle East, Latin America, Africa).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityRating rdf:type rdf:Property ;
    rdfs:label 'Security Rating' ;
    rdfs:comment 'Security risk rating assigned to the carrier based on compliance, incident history, and certifications: high (best), medium, low, or not rated.' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypes rdf:type rdf:Property ;
    rdfs:label 'Service Types' ;
    rdfs:comment 'Comma-separated list of service types offered: FTL (Full Truckload), LTL (Less Than Truckload), FCL (Full Container Load), LCL (Less Than Container Load), express, economy, standard, same_day, next_day, deferred. [ENUM-REF-CANDIDATE: ftl|ltl|fcl|lcl|express|economy|standard|same_day|next_day|deferred|white_glove — promote to reference product]' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertified rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified' ;
    rdfs:comment 'Indicates whether the carrier holds sustainability or environmental certifications (e.g., SmartWay, ISO 14001, carbon neutral).' ;
    rdfs:domain ind:CarrierProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingGranularity rdf:type rdf:Property ;
    rdfs:label 'Tracking Granularity' ;
    rdfs:comment 'Level of tracking detail provided: real-time GPS, milestone-based (pickup/in-transit/delivery), daily update, manual, or none.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLanesCovered rdf:type rdf:Property ;
    rdfs:label 'Trade Lanes Covered' ;
    rdfs:comment 'Comma-separated list of major trade lanes or corridors served (e.g., Transpacific, Transatlantic, Asia-Europe, Intra-Asia, US-Mexico).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonNeutralCertified rdf:type rdf:Property ;
    rdfs:label 'Carbon Neutral Certified' ;
    rdfs:comment 'Indicates whether this service is certified as carbon-neutral through offsets or sustainable fuel programs.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsClearanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Included' ;
    rdfs:comment 'Indicates whether customs brokerage and clearance services are included in this service offering.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutoffDayOffset rdf:type rdf:Property ;
    rdfs:label 'Cutoff Day Offset' ;
    rdfs:comment 'The number of days before departure that the cutoff time applies (0 = same day, 1 = one day before, etc.).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cutoffTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time Local' ;
    rdfs:comment 'The local time by which cargo must be delivered to the carrier facility to be accepted for this service (format: HH:MM).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsCapable rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Capable' ;
    rdfs:comment 'Indicates whether this service is certified to handle dangerous goods (DG) or hazardous materials (HAZMAT).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dgClassesSupported rdf:type rdf:Property ;
    rdfs:label 'Dg Classes Supported' ;
    rdfs:comment 'Comma-separated list of UN dangerous goods classes supported by this service (e.g., 1, 2.1, 3, 4.1, 5.1, 6.1, 8, 9).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Documentation Cutoff Time' ;
    rdfs:comment 'The local time by which shipping documentation (AWB, BOL, customs declarations) must be submitted (format: HH:MM).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doorToDoorAvailable rdf:type rdf:Property ;
    rdfs:label 'Door To Door Available' ;
    rdfs:comment 'Indicates whether this service includes door-to-door pickup and delivery, or is port-to-port / terminal-to-terminal only.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentTypesSupported rdf:type rdf:Property ;
    rdfs:label 'Equipment Types Supported' ;
    rdfs:comment 'Comma-separated list of equipment types supported by this service (e.g., 20GP, 40HC, 45HC for ocean; ULD types for air; truck types for road).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightServiceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Flight Service Identifier' ;
    rdfs:comment 'The carrier-assigned flight number or air service identifier (for air freight).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyPerWeek rdf:type rdf:Property ;
    rdfs:label 'Frequency Per Week' ;
    rdfs:comment 'The number of service departures per week. Used for capacity planning and booking availability.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incotermsSupported rdf:type rdf:Property ;
    rdfs:label 'Incoterms Supported' ;
    rdfs:comment 'Comma-separated list of Incoterms (International Commercial Terms) supported by this service (e.g., FOB, CIF, DDP, DAP, EXW).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceAvailable rdf:type rdf:Property ;
    rdfs:label 'Insurance Available' ;
    rdfs:comment 'Indicates whether cargo insurance is available or included with this service.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liveAnimalCapable rdf:type rdf:Property ;
    rdfs:label 'Live Animal Capable' ;
    rdfs:comment 'Indicates whether this service is certified to transport live animals.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oversizedCargoCapable rdf:type rdf:Property ;
    rdfs:label 'Oversized Cargo Capable' ;
    rdfs:comment 'Indicates whether this service can handle oversized or out-of-gauge cargo that exceeds standard equipment dimensions.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perishableCargoCapable rdf:type rdf:Property ;
    rdfs:label 'Perishable Cargo Capable' ;
    rdfs:comment 'Indicates whether this service supports perishable cargo requiring time-sensitive handling.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'The current operational status of this carrier service: active (available for booking), suspended (temporarily unavailable), discontinued (permanently ended), seasonal (operates during specific periods), or planned (future service).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingAvailable rdf:type rdf:Property ;
    rdfs:label 'Tracking Available' ;
    rdfs:comment 'Indicates whether real-time or milestone-based shipment tracking is available for this service.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainServiceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Train Service Identifier' ;
    rdfs:comment 'The carrier-assigned train service number or rail service identifier (for rail freight).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselServiceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Vessel Service Identifier' ;
    rdfs:comment 'The carrier-assigned identifier for the vessel service string (for ocean freight) or vessel rotation code.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentOfficeId rdf:type rdf:Property ;
    rdfs:label 'Correspondent Office Id' ;
    rdfs:comment 'Unique identifier for the correspondent office record. Primary key.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Renewal Date' ;
    rdfs:comment 'The date when the representation agreement with the correspondent office is due for renewal or renegotiation.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'The annual revenue target or quota assigned to the correspondent office for services provided on behalf of Transport Shipping.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsClearanceCapability rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Capability' ;
    rdfs:comment 'Indicates whether the correspondent office has the capability and authorization to perform customs clearance and trade compliance services.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Iata Office Code' ;
    rdfs:comment 'Seven-character IATA office identifier code used for air freight and cargo operations, enabling global interline billing and settlement.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageSupport rdf:type rdf:Property ;
    rdfs:label 'Language Support' ;
    rdfs:comment 'Comma-separated list of languages supported by the correspondent office for customer service and operational communications.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCode rdf:type rdf:Property ;
    rdfs:label 'Office Code' ;
    rdfs:comment 'Internal unique alphanumeric code assigned to the correspondent office for operational reference and system integration.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeEmail rdf:type rdf:Property ;
    rdfs:label 'Office Email' ;
    rdfs:comment 'General email address for the correspondent office for customer inquiries and business communications.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeFax rdf:type rdf:Property ;
    rdfs:label 'Office Fax' ;
    rdfs:comment 'Fax number for the correspondent office, used for document transmission in regions where fax is still operationally relevant.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeName rdf:type rdf:Property ;
    rdfs:label 'Office Name' ;
    rdfs:comment 'The official business name of the correspondent office as it appears in legal and operational documents.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officePhone rdf:type rdf:Property ;
    rdfs:label 'Office Phone' ;
    rdfs:comment 'Main telephone number for the correspondent office for general inquiries and customer service.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeType rdf:type rdf:Property ;
    rdfs:label 'Office Type' ;
    rdfs:comment 'Classification of the correspondent office based on its operational and legal relationship with Transport Shipping. Correspondent offices operate under formal representation agreements and carry the Transport Shipping brand.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours of the correspondent office, typically in format such as \'Mon-Fri 08:00-18:00, Sat 09:00-13:00\'.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or position of the primary contact person at the correspondent office.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representationAgreementType rdf:type rdf:Property ;
    rdfs:label 'Representation Agreement Type' ;
    rdfs:comment 'Type of formal representation agreement governing the correspondent office relationship, defining exclusivity and scope of services.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharingModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Model' ;
    rdfs:comment 'The financial arrangement model defining how revenue is shared between Transport Shipping and the correspondent office for services rendered.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicesOffered rdf:type rdf:Property ;
    rdfs:label 'Services Offered' ;
    rdfs:comment 'Comma-separated list or description of logistics services offered by the correspondent office on behalf of Transport Shipping, such as express delivery, freight forwarding, customs brokerage, warehousing, last-mile delivery.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseFacilityAvailable rdf:type rdf:Property ;
    rdfs:label 'Warehouse Facility Available' ;
    rdfs:comment 'Indicates whether the correspondent office has access to warehouse or distribution facilities for cargo storage and handling.' ;
    rdfs:domain ind:CorrespondentOffice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediConnectionId rdf:type rdf:Property ;
    rdfs:label 'Edi Connection Id' ;
    rdfs:comment 'Unique identifier for the EDI or API integration connection record. Primary key.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEdiEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Edi Employee Id' ;
    rdfs:comment 'Identifier of the user who created this EDI connection record.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:averageDailyMessageVolume rdf:type rdf:Property ;
    rdfs:label 'Average Daily Message Volume' ;
    rdfs:comment 'Average number of messages exchanged per day through this connection, used for capacity planning and performance monitoring.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compressionEnabled rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled' ;
    rdfs:comment 'Indicates whether message compression is enabled to reduce bandwidth usage and improve transmission efficiency.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:connectionHealthStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Health Status' ;
    rdfs:comment 'Current health status of the EDI connection based on recent transmission success rates, latency, and error patterns. Used for proactive monitoring and alerting.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionName rdf:type rdf:Property ;
    rdfs:label 'Connection Name' ;
    rdfs:comment 'Human-readable name or label for the EDI connection, typically including partner name and connection type for easy identification.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Connection Reference Number' ;
    rdfs:comment 'Business-assigned unique reference number or code for this EDI connection, used for operational tracking and support.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Status' ;
    rdfs:comment 'Overall lifecycle status of the EDI connection. Reflects the current operational state from initial setup through active use to eventual termination.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionType rdf:type rdf:Property ;
    rdfs:label 'Connection Type' ;
    rdfs:comment 'Type of electronic integration connection established with the partner. Includes traditional EDI standards (TRADACOMS, EDIFACT, X12) and modern API protocols (REST, SOAP) as well as file transfer methods (SFTP, AS2, FTP). [ENUM-REF-CANDIDATE: EDI_TRADACOMS|EDI_EDIFACT|EDI_X12|API_REST|API_SOAP|SFTP|AS2|FTP|FTPS — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether message encryption is enabled for this connection to protect data in transit.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionProtocol rdf:type rdf:Property ;
    rdfs:label 'Encryption Protocol' ;
    rdfs:comment 'Encryption protocol or standard used to secure messages transmitted through this connection (e.g., TLS 1.2, TLS 1.3, PGP, S/MIME).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointHost rdf:type rdf:Property ;
    rdfs:label 'Endpoint Host' ;
    rdfs:comment 'Hostname or IP address of the partner\'s EDI or API server. Confidential business integration detail.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointPort rdf:type rdf:Property ;
    rdfs:label 'Endpoint Port' ;
    rdfs:comment 'Network port number used for the EDI or API connection (e.g., 443 for HTTPS, 22 for SFTP).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endpointUrl rdf:type rdf:Property ;
    rdfs:label 'Endpoint Url' ;
    rdfs:comment 'The URL or network address of the partner\'s EDI or API endpoint where messages are sent or received. Confidential business integration detail.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeControlReferencePrefix rdf:type rdf:Property ;
    rdfs:label 'Interchange Control Reference Prefix' ;
    rdfs:comment 'Prefix or pattern used for generating unique interchange control numbers in EDI message headers for this connection.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFailedTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failed Transmission Timestamp' ;
    rdfs:comment 'Timestamp of the most recent failed message transmission attempt, used for troubleshooting and alerting.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastHealthCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Health Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent automated health check performed on this connection.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSuccessfulTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Successful Transmission Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful message transmission through this connection, used for health monitoring.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageDirection rdf:type rdf:Property ;
    rdfs:label 'Message Direction' ;
    rdfs:comment 'Indicates whether this connection is used for sending messages to the partner (outbound), receiving messages from the partner (inbound), or both (bidirectional).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageTypesSupported rdf:type rdf:Property ;
    rdfs:label 'Message Types Supported' ;
    rdfs:comment 'Comma-separated list of message types or transaction sets supported by this connection (e.g., IFTMBF booking confirmation, IFTSTA status update, AWB data, manifest, invoice, DESADV despatch advice).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakMessageVolume rdf:type rdf:Property ;
    rdfs:label 'Peak Message Volume' ;
    rdfs:comment 'Maximum number of messages processed in a single day through this connection, representing peak capacity utilization.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionEnvironmentStatus rdf:type rdf:Property ;
    rdfs:label 'Production Environment Status' ;
    rdfs:comment 'Current operational status of the production environment connection. Indicates whether the connection is actively processing live business transactions.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolVersion rdf:type rdf:Property ;
    rdfs:label 'Protocol Version' ;
    rdfs:comment 'Version of the EDI standard or API protocol being used for this connection (e.g., EDIFACT D.96A, X12 4010, REST API v2.1).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverIdentifier rdf:type rdf:Property ;
    rdfs:label 'Receiver Identifier' ;
    rdfs:comment 'EDI receiver identification code or qualifier assigned to the partner for inbound messages (e.g., partner\'s SCAC code, IATA code, GLN, DUNS number).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderIdentifier rdf:type rdf:Property ;
    rdfs:label 'Sender Identifier' ;
    rdfs:comment 'EDI sender identification code or qualifier used by Transport Shipping in outbound messages to this partner (e.g., SCAC code, IATA code, GLN, DUNS number).' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Seconds' ;
    rdfs:comment 'Maximum response time in seconds agreed with the partner for message acknowledgment or processing, as defined in the integration SLA.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Minimum uptime percentage committed for this connection as defined in the integration SLA (e.g., 99.9%).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'Email address of the primary technical contact at the partner organization for EDI support and troubleshooting.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactName rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Name' ;
    rdfs:comment 'Name of the primary technical contact at the partner organization responsible for this EDI connection.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactPhone rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Phone' ;
    rdfs:comment 'Phone number of the primary technical contact at the partner organization for urgent EDI issues.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEnvironmentEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Test Environment Endpoint Url' ;
    rdfs:comment 'The URL or network address of the partner\'s test/sandbox EDI or API endpoint used for integration testing before production go-live.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEnvironmentStatus rdf:type rdf:Property ;
    rdfs:label 'Test Environment Status' ;
    rdfs:comment 'Current status of the test/sandbox environment connection for this partner integration. Indicates whether test connectivity and message exchange have been successfully validated.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeoutSeconds rdf:type rdf:Property ;
    rdfs:label 'Timeout Seconds' ;
    rdfs:comment 'Maximum time in seconds to wait for a response from the partner endpoint before considering the transmission failed.' ;
    rdfs:domain ind:EdiConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gsaAgreementId rdf:type rdf:Property ;
    rdfs:label 'Gsa Agreement Id' ;
    rdfs:comment 'Unique identifier for the GSA agreement record. Primary key.' ;
    rdfs:domain ind:GsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:principalCarrierId rdf:type rdf:Property ;
    rdfs:label 'Principal Carrier Id' ;
    rdfs:comment 'Reference to the carrier or Transport Shipping entity whose capacity the GSA is authorized to sell.' ;
    rdfs:domain ind:GsaAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:authorizedProducts rdf:type rdf:Property ;
    rdfs:label 'Authorized Products' ;
    rdfs:comment 'Specific product codes or service offerings the GSA is permitted to market and sell under this agreement.' ;
    rdfs:domain ind:GsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Commitment Period Months' ;
    rdfs:comment 'Duration in months over which the minimum sales target must be achieved (e.g., 12 for annual target).' ;
    rdfs:domain ind:GsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flatFeePerUnitAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Per Unit Amount' ;
    rdfs:comment 'Fixed commission amount paid per unit (shipment, TEU, kilogram) when commission structure is flat-fee-based.' ;
    rdfs:domain ind:GsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law under which the GSA agreement is interpreted and enforced (e.g., English Law, New York Law).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSubAgentsAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Sub Agents Allowed' ;
    rdfs:comment 'Maximum number of sub-agents the GSA may appoint, if sub-agent authorization is granted. Null if unlimited or not applicable.' ;
    rdfs:domain ind:GsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumSalesTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Sales Target Amount' ;
    rdfs:comment 'Minimum revenue or volume the GSA must achieve within the commitment period to maintain the agreement in good standing.' ;
    rdfs:domain ind:GsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSalesTargetUnit rdf:type rdf:Property ;
    rdfs:label 'Minimum Sales Target Unit' ;
    rdfs:comment 'Unit of measure for the minimum sales target: revenue (monetary value), shipments (count), TEU (container units), weight in kilograms, or volume in cubic meters.' ;
    rdfs:domain ind:GsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of financial or contractual penalties imposed if the GSA fails to meet minimum sales targets or other obligations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingObligations rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligations' ;
    rdfs:comment 'Detailed description of the reports and data the GSA must provide to the principal (e.g., sales volume, customer lists, market intelligence).' ;
    rdfs:domain ind:GsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subAgentAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Sub Agent Authorization Flag' ;
    rdfs:comment 'Indicates whether the GSA is permitted to appoint sub-agents to sell on their behalf within the territory. True if authorized, false otherwise.' ;
    rdfs:domain ind:GsaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the agreement before its natural expiry.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorNetworkPartnerId rdf:type rdf:Property ;
    rdfs:label 'Operator Network Partner Id' ;
    rdfs:comment 'Foreign key linking to network.network_partner. Business justification: When a hub/gateway is operated by a network partner (indicated by operator_type), this should be a formal FK relationship enabling partner-based hub management and performance tracking. Removes operat' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:bondedWarehouseAvailable rdf:type rdf:Property ;
    rdfs:label 'Bonded Warehouse Available' ;
    rdfs:comment 'Indicates whether the hub or gateway includes bonded warehouse facilities for duty-deferred storage of international cargo.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainCapable rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capable' ;
    rdfs:comment 'Indicates whether the hub or gateway has temperature-controlled facilities for handling perishable and pharmaceutical shipments.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsClearanceCapable rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Capable' ;
    rdfs:comment 'Indicates whether the hub or gateway has on-site customs clearance facilities and authorization for import/export processing.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftzStatus rdf:type rdf:Property ;
    rdfs:label 'Ftz Status' ;
    rdfs:comment 'Indicates whether the hub or gateway is located within or operates as a Free Trade Zone with special customs treatment.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handlingCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Handling Capacity Teu' ;
    rdfs:comment 'Maximum container handling capacity of the hub or gateway expressed in TEU per year for ocean and intermodal facilities.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Handling Capacity Tonnes' ;
    rdfs:comment 'Maximum freight handling capacity of the hub or gateway expressed in metric tonnes per year for air and road facilities.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hubCode rdf:type rdf:Property ;
    rdfs:label 'Hub Code' ;
    rdfs:comment 'Unique business code assigned to the hub or gateway facility for operational reference and system integration.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubName rdf:type rdf:Property ;
    rdfs:label 'Hub Name' ;
    rdfs:comment 'Official name of the hub or gateway facility as recognized in operational and commercial documentation.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubType rdf:type rdf:Property ;
    rdfs:label 'Hub Type' ;
    rdfs:comment 'Classification of the hub or gateway by primary transport mode and facility function. ICD = Inland Container Depot, CFS = Container Freight Station.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoCode rdf:type rdf:Property ;
    rdfs:label 'Icao Code' ;
    rdfs:comment 'Four-letter ICAO airport code for air hubs, used in flight planning and air traffic control communications.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operates247 rdf:type rdf:Property ;
    rdfs:label 'Operates 24 7' ;
    rdfs:comment 'Indicates whether the hub or gateway operates continuously 24 hours per day, 7 days per week.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorType rdf:type rdf:Property ;
    rdfs:label 'Operator Type' ;
    rdfs:comment 'Classification of the operational ownership and control model for the hub or gateway facility.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Storage Area Sqm' ;
    rdfs:comment 'Total covered and open storage area available at the hub or gateway facility in square meters.' ;
    rdfs:domain ind:HubGateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tmsPlatform rdf:type rdf:Property ;
    rdfs:label 'Tms Platform' ;
    rdfs:comment 'Name and version of the transportation management system used at the hub or gateway for shipment planning and execution.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unLocode rdf:type rdf:Property ;
    rdfs:label 'Un Locode' ;
    rdfs:comment 'Five-character UN location code identifying the hub or gateway for international trade and transport documentation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsPlatform rdf:type rdf:Property ;
    rdfs:label 'Wms Platform' ;
    rdfs:comment 'Name and version of the warehouse management system deployed at the hub or gateway for inventory and operations management.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCarrierId rdf:type rdf:Property ;
    rdfs:label 'Partner Carrier Id' ;
    rdfs:comment 'Reference to the partner carrier organization with whom this interline agreement is established.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:awbPrefixAllocation rdf:type rdf:Property ;
    rdfs:label 'Awb Prefix Allocation' ;
    rdfs:comment 'IATA-assigned three-digit AWB prefix(es) that may be used under this interline agreement for through-billing. Applicable to air cargo agreements.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataProrateRuleReference rdf:type rdf:Property ;
    rdfs:label 'Iata Prorate Rule Reference' ;
    rdfs:comment 'Reference to specific IATA Resolution 780 prorate rule or tariff provision governing revenue allocation for air cargo interline agreements.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirement rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement' ;
    rdfs:comment 'Type of insurance coverage required or provided under this interline agreement for cargo in transit.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the liability limit amount.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateMethodology rdf:type rdf:Property ;
    rdfs:label 'Prorate Methodology' ;
    rdfs:comment 'Method used to allocate revenue between carriers for through-shipments. IATA standard refers to IATA Resolution 780 prorate rules.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Split Percentage' ;
    rdfs:comment 'Percentage of total revenue allocated to Transport Shipping under this agreement. Remaining percentage goes to partner carrier. Confidential commercial term.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which interline revenue settlements are calculated and exchanged between Transport Shipping and the partner carrier.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Through Billing Enabled' ;
    rdfs:comment 'Indicates whether this agreement permits through-billing, where a single AWB or BOL covers the entire journey across both carriers\' networks.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeCommitmentUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Unit' ;
    rdfs:comment 'Unit of measure for the minimum volume commitment. TEU = Twenty-foot Equivalent Unit, CBM = Cubic Meter.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineProrateId rdf:type rdf:Property ;
    rdfs:label 'Interline Prorate Id' ;
    rdfs:comment 'Unique identifier for the interline prorate transaction record.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerSettlementId rdf:type rdf:Property ;
    rdfs:label 'Partner Settlement Id' ;
    rdfs:comment 'Foreign key linking to network.partner_settlement. Business justification: Interline prorate records are the line-item details that roll up into partner settlements. This link enables settlement reconciliation and tracking of which prorate records have been settled. Removes ' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerSettlement .

ind:billingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Billing Carrier Code' ;
    rdfs:comment 'IATA or SCAC code of the carrier responsible for billing the customer and distributing prorate payments.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The date on which the prorate calculation was performed.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'The HS code of the commodity being shipped, which may influence prorate calculations for specialized cargo.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Destination Carrier Code' ;
    rdfs:comment 'IATA or SCAC code of the carrier operating the destination segment of the interline movement.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Station Code' ;
    rdfs:comment 'IATA three-letter airport or UN/LOCODE station code for the destination of this carrier segment.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this prorate record is currently active or has been superseded by a correction or adjustment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Origin Carrier Code' ;
    rdfs:comment 'IATA or SCAC code of the carrier operating the origin segment of the interline movement.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originStationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Station Code' ;
    rdfs:comment 'IATA three-letter airport or UN/LOCODE station code for the origin of this carrier segment.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateAmount rdf:type rdf:Property ;
    rdfs:label 'Prorate Amount' ;
    rdfs:comment 'The calculated revenue amount allocated to this carrier segment based on the prorate percentage and basis.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorateBasis rdf:type rdf:Property ;
    rdfs:label 'Prorate Basis' ;
    rdfs:comment 'The method used to calculate the revenue split between carriers: weight-based, revenue-based, distance-based, flat rate, negotiated percentage, or mileage-based.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateFactor rdf:type rdf:Property ;
    rdfs:label 'Prorate Factor' ;
    rdfs:comment 'The calculated factor used in the prorate formula, derived from weight, distance, or other basis metrics.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proratePercentage rdf:type rdf:Property ;
    rdfs:label 'Prorate Percentage' ;
    rdfs:comment 'The percentage of total revenue allocated to this carrier segment, expressed as a decimal (e.g., 35.50 for 35.5%).' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Carrier Code' ;
    rdfs:comment 'IATA or SCAC code of the carrier receiving the prorate payment for this segment.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentSequence rdf:type rdf:Property ;
    rdfs:label 'Segment Sequence' ;
    rdfs:comment 'Sequential order of this carrier segment within the multi-carrier interline routing.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Amount' ;
    rdfs:comment 'The total freight revenue for the shipment before prorate split calculation.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageId rdf:type rdf:Property ;
    rdfs:label 'Coverage Id' ;
    rdfs:comment 'Unique identifier for the network coverage record. Primary key.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageAgentId rdf:type rdf:Property ;
    rdfs:label 'Coverage Agent Id' ;
    rdfs:comment 'Agent providing service in this coverage area when carrier is not directly servicing.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:coverageBackupAgentId rdf:type rdf:Property ;
    rdfs:label 'Coverage Backup Agent Id' ;
    rdfs:comment 'Secondary or backup agent available for this coverage area when primary agent is unavailable.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:coverageBackupCarrierId rdf:type rdf:Property ;
    rdfs:label 'Coverage Backup Carrier Id' ;
    rdfs:comment 'Secondary or backup carrier available for this coverage area when primary partner is unavailable or at capacity.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:coverageCarrierId rdf:type rdf:Property ;
    rdfs:label 'Coverage Carrier Id' ;
    rdfs:comment 'Primary carrier or partner providing service in this coverage area.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:coverageTplProviderId rdf:type rdf:Property ;
    rdfs:label 'Coverage Tpl Provider Id' ;
    rdfs:comment 'Foreign key linking to network.tpl_provider. Business justification: Coverage defines geographic service coverage provided by network partners. Currently only carrier and agent are referenced. In logistics, 3PL providers also provide geographic coverage and should be t' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TplProvider .

ind:codAvailable rdf:type rdf:Property ;
    rdfs:label 'Cod Available' ;
    rdfs:comment 'Indicates whether Cash on Delivery payment collection service is available in this coverage area.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageCode rdf:type rdf:Property ;
    rdfs:label 'Coverage Code' ;
    rdfs:comment 'Business identifier code for the coverage area, used for operational reference and partner communication.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current operational status of coverage in this area: active (full service), limited (restricted capacity or service days), suspended (temporarily unavailable), inactive (no longer serviced), or planned (future launch).' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceAvailable rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Available' ;
    rdfs:comment 'Indicates whether customs brokerage and clearance services are available through this partner in this coverage area.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsAccepted rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Accepted' ;
    rdfs:comment 'Indicates whether dangerous goods (hazardous materials) are accepted for transport in this coverage area.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dgClassesAccepted rdf:type rdf:Property ;
    rdfs:label 'Dg Classes Accepted' ;
    rdfs:comment 'Comma-separated list of UN dangerous goods classes accepted (e.g., 1,3,4,5,6,8,9). Empty if dangerous goods not accepted.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:granularity rdf:type rdf:Property ;
    rdfs:label 'Granularity' ;
    rdfs:comment 'Level of geographic precision for this coverage record: country-level, region/state-level, city-level, postal zone-level, or address-level.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDimensionsCm rdf:type rdf:Property ;
    rdfs:label 'Max Dimensions Cm' ;
    rdfs:comment 'Maximum shipment dimensions in centimeters, formatted as LxWxH (e.g., 120x80x100).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Max Transit Time Hours' ;
    rdfs:comment 'Maximum expected transit time in hours from origin to destination within this coverage area, accounting for delays and routing variations.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Max Volume Cbm' ;
    rdfs:comment 'Maximum shipment volume in cubic meters accepted for this coverage area and service type.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum shipment weight in kilograms accepted for this coverage area and service type.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Min Transit Time Hours' ;
    rdfs:comment 'Minimum expected transit time in hours from origin to destination within this coverage area under optimal conditions.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podElectronicAvailable rdf:type rdf:Property ;
    rdfs:label 'Pod Electronic Available' ;
    rdfs:comment 'Indicates whether electronic proof of delivery (digital signature, photo) is available in this coverage area.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalZone rdf:type rdf:Property ;
    rdfs:label 'Postal Zone' ;
    rdfs:comment 'Postal code or postal zone range covered (e.g., 10001-10299, M5H*, SW1A). Supports wildcard patterns for zone ranges.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Partner Flag' ;
    rdfs:comment 'Indicates whether this partner is the primary/preferred provider for this coverage area (true) or a secondary/backup option (false).' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDays rdf:type rdf:Property ;
    rdfs:label 'Service Days' ;
    rdfs:comment 'Days of the week when service is available (e.g., Mon-Fri, Mon-Sat, Daily). Free-text field to accommodate various patterns.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFrequency rdf:type rdf:Property ;
    rdfs:label 'Service Frequency' ;
    rdfs:comment 'Frequency of service availability in this coverage area: daily, weekly, biweekly, monthly, on_demand (as requested), or scheduled (fixed timetable).' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaOtdTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Otd Target Pct' ;
    rdfs:comment 'Target on-time delivery percentage committed by the partner for this coverage area, expressed as a percentage (e.g., 95.00 for 95%).' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Time Hours' ;
    rdfs:comment 'Typical or average transit time in hours used for planning and customer communication.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Expected date when coverage will resume after suspension, if known.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Date when coverage suspension began, if applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temperatureControlledAvailable rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Available' ;
    rdfs:comment 'Indicates whether temperature-controlled (reefer) transport is available in this coverage area.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkEventId rdf:type rdf:Property ;
    rdfs:label 'Network Event Id' ;
    rdfs:comment 'Unique identifier for the network event record. Primary key.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:causingHseIncidentId rdf:type rdf:Property ;
    rdfs:label 'Causing Hse Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.hse_incident. Business justification: Network disruptions caused by safety incidents (facility closures, route suspensions, carrier service interruptions) require linking to the incident for root cause analysis, customer communication, an' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HseIncident .

ind:primaryNetworkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Network Employee Id' ;
    rdfs:comment 'Identifier of the user or system that reported this network event.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedAirports rdf:type rdf:Property ;
    rdfs:label 'Affected Airports' ;
    rdfs:comment 'Comma-separated list of IATA airport codes affected by this network event (e.g., JFK, PVG, AMS).' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedCountries rdf:type rdf:Property ;
    rdfs:label 'Affected Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes for countries impacted by this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPorts rdf:type rdf:Property ;
    rdfs:label 'Affected Ports' ;
    rdfs:comment 'Comma-separated list of port codes or names affected by this network event (e.g., USNYC, CNSHA, NLRTM).' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRegions rdf:type rdf:Property ;
    rdfs:label 'Affected Regions' ;
    rdfs:comment 'Comma-separated list of geographic regions impacted by this network event (e.g., APAC, EMEA, Americas).' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedTradeLanes rdf:type rdf:Property ;
    rdfs:label 'Affected Trade Lanes' ;
    rdfs:comment 'Comma-separated list of trade lanes or shipping routes impacted by this network event (e.g., Asia-Europe, Trans-Pacific, North Atlantic).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedTransportModes rdf:type rdf:Property ;
    rdfs:label 'Affected Transport Modes' ;
    rdfs:comment 'Comma-separated list of transport modes impacted by this event (e.g., air, ocean, road, rail).' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeCarrierEngaged rdf:type rdf:Property ;
    rdfs:label 'Alternative Carrier Engaged' ;
    rdfs:comment 'Indicates whether alternative carriers have been engaged to provide substitute capacity during this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeRoutingAvailable rdf:type rdf:Property ;
    rdfs:label 'Alternative Routing Available' ;
    rdfs:comment 'Indicates whether alternative routing options are available to bypass the affected network segment.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationDatetime rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Datetime' ;
    rdfs:comment 'Date and time when customer notifications were sent regarding this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent' ;
    rdfs:comment 'Indicates whether affected customers have been notified about this network event and its impact on their shipments.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endDatetime rdf:type rdf:Property ;
    rdfs:label 'End Datetime' ;
    rdfs:comment 'Date and time when the network disruption or event was resolved and operations returned to normal. Null if event is ongoing.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationDatetime rdf:type rdf:Property ;
    rdfs:label 'Escalation Datetime' ;
    rdfs:comment 'Date and time when this network event was escalated to higher management levels.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedCapacityLossTeu rdf:type rdf:Property ;
    rdfs:label 'Estimated Capacity Loss Teu' ;
    rdfs:comment 'Estimated loss of container capacity measured in TEU resulting from this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDelayHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Delay Hours' ;
    rdfs:comment 'Estimated average delay in hours to shipments affected by this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedShipmentsAffected rdf:type rdf:Property ;
    rdfs:label 'Estimated Shipments Affected' ;
    rdfs:comment 'Estimated number of active shipments impacted by this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Unique business identifier code assigned to this network event for external reference and tracking.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactEstimatedUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimated Usd' ;
    rdfs:comment 'Estimated financial impact of this network event in USD, including revenue loss, additional costs, and penalties.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Documentation of lessons learned and recommendations for preventing similar network events in the future.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions Taken' ;
    rdfs:comment 'Detailed description of mitigation actions and contingency measures implemented to minimize the impact of this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Operational Impact Description' ;
    rdfs:comment 'Detailed description of the operational impact on service delivery, capacity, transit times, and customer commitments resulting from this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Name of the partner organization affected by the network event, including carriers, agents, or third-party logistics (3PL) providers.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the regulatory authority or governing body notified about this network event (e.g., IMO, IATA, FMC, DOT).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Indicates whether relevant regulatory authorities have been notified about this network event as required by compliance obligations.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed description of how the network event was resolved and operations were restored to normal.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDetails rdf:type rdf:Property ;
    rdfs:label 'Root Cause Details' ;
    rdfs:comment 'Detailed explanation of the root cause analysis findings for this network event.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachCount rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Count' ;
    rdfs:comment 'Number of SLA breaches resulting from this network event across affected customer contracts.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startDatetime rdf:type rdf:Property ;
    rdfs:label 'Start Datetime' ;
    rdfs:comment 'Date and time when the network disruption or event began affecting operations.' ;
    rdfs:domain ind:NetworkEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partnerTierId rdf:type rdf:Property ;
    rdfs:label 'Partner Tier Id' ;
    rdfs:comment 'Foreign key linking to network.partner_tier. Business justification: Partner should reference its current tier classification directly. While partner_performance and partner_sla already reference partner_tier, the partner master itself should carry its current tier for' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerTier .

ind:aeoCertification rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification' ;
    rdfs:comment 'AEO certification number indicating the partner has been certified as a secure and compliant supply chain participant.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondedWarehouseLicense rdf:type rdf:Property ;
    rdfs:label 'Bonded Warehouse License' ;
    rdfs:comment 'License number issued by customs authorities authorizing the partner to operate a bonded warehouse facility.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Date when the current partnership agreement or contract with the partner is scheduled to expire.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctpatCertification rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certification' ;
    rdfs:comment 'C-TPAT certification number indicating the partner has been certified under the US CBP security program.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingCapacity rdf:type rdf:Property ;
    rdfs:label 'Handling Capacity' ;
    rdfs:comment 'Description of the partner\'s handling capacity, such as TEU capacity for container facilities or tonnage capacity for freight stations.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCertification rdf:type rdf:Property ;
    rdfs:label 'Iso Certification' ;
    rdfs:comment 'ISO certification numbers held by the partner, such as ISO 9001 (Quality Management) or ISO 28000 (Supply Chain Security).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkParticipationDate rdf:type rdf:Property ;
    rdfs:label 'Network Participation Date' ;
    rdfs:comment 'Date when the partner was onboarded and began participating in the Transport Shipping logistics network.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerCategory rdf:type rdf:Property ;
    rdfs:label 'Partner Category' ;
    rdfs:comment 'Classification of the partner type within the logistics network. Defines the operational role and service scope of the partner.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Status' ;
    rdfs:comment 'Current lifecycle status of the partner relationship within the network.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceModes rdf:type rdf:Property ;
    rdfs:label 'Service Modes' ;
    rdfs:comment 'Transport modes and service types supported by the partner (e.g., air, ocean, road, rail, multimodal).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerAuditId rdf:type rdf:Property ;
    rdfs:label 'Partner Audit Id' ;
    rdfs:comment 'Unique identifier for the partner audit record. Primary key.' ;
    rdfs:domain ind:PartnerAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_audit. Business justification: Partner audits conducted by safety teams should reference the formal safety audit record to avoid duplicate audit tracking, ensure consistent finding management, and enable consolidated safety reporti' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:auditCriteria rdf:type rdf:Property ;
    rdfs:label 'Audit Criteria' ;
    rdfs:comment 'Standards, regulations, or contractual requirements against which the partner was audited (e.g., ISO 9001, Customs-Trade Partnership Against Terrorism (C-TPAT), Authorized Economic Operator (AEO), International Air Transport Association (IATA) standards, Transport Shipping service level agreements).' ;
    rdfs:domain ind:PartnerAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditOutcome rdf:type rdf:Property ;
    rdfs:label 'Audit Outcome' ;
    rdfs:comment 'Overall outcome of the audit: pass (partner meets all requirements), conditional pass (partner meets requirements subject to completion of minor corrective actions), fail (partner does not meet requirements and major corrective actions are required), or not applicable (audit was informational or advisory only).' ;
    rdfs:domain ind:PartnerAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numerical score or rating assigned to the partner based on audit performance, typically expressed as a percentage or on a defined scale.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the certification granted or renewed as a result of this audit will expire, requiring re-audit.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Certification status resulting from the audit: certified (partner meets certification requirements), provisional (temporary certification pending corrective actions), suspended (certification temporarily withdrawn), revoked (certification permanently withdrawn), or not certified (partner does not meet certification requirements).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference to the partner contract or agreement under which this audit was conducted and against which compliance was assessed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanAgreed rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Agreed' ;
    rdfs:comment 'Indicates whether a corrective action plan has been agreed upon with the partner to address identified non-conformances (True if agreed, False if not agreed or not applicable).' ;
    rdfs:domain ind:PartnerAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilitiesAudited rdf:type rdf:Property ;
    rdfs:label 'Facilities Audited' ;
    rdfs:comment 'List of partner facilities, warehouses, terminals, or offices included in the audit scope.' ;
    rdfs:domain ind:PartnerAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'High-level summary of the audit findings, including key observations, strengths identified, and areas of concern.' ;
    rdfs:domain ind:PartnerAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNonConformances rdf:type rdf:Property ;
    rdfs:label 'Major Non Conformances' ;
    rdfs:comment 'Count of major non-conformances that represent significant deviations from requirements or pose serious risk to operations, compliance, or safety.' ;
    rdfs:domain ind:PartnerAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNonConformances rdf:type rdf:Property ;
    rdfs:label 'Minor Non Conformances' ;
    rdfs:comment 'Count of minor non-conformances that represent less significant deviations or isolated incidents that do not pose immediate risk.' ;
    rdfs:domain ind:PartnerAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonConformancesIdentified rdf:type rdf:Property ;
    rdfs:label 'Non Conformances Identified' ;
    rdfs:comment 'Total count of non-conformances (deviations from standards or requirements) identified during the audit.' ;
    rdfs:domain ind:PartnerAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationsCount rdf:type rdf:Property ;
    rdfs:label 'Observations Count' ;
    rdfs:comment 'Count of audit observations or opportunities for improvement that do not constitute non-conformances but warrant attention.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportModesAudited rdf:type rdf:Property ;
    rdfs:label 'Transport Modes Audited' ;
    rdfs:comment 'Comma-separated list of transport modes covered in the audit scope (air, ocean, road, rail, multimodal).' ;
    rdfs:domain ind:PartnerAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCertificationId rdf:type rdf:Property ;
    rdfs:label 'Partner Certification Id' ;
    rdfs:comment 'Unique identifier for the partner certification record. Primary key.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certification Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the certification certificate or official documentation stored in the document management system.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique certificate or registration number issued by the certifying authority. This is the externally-known identifier for the certification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Level' ;
    rdfs:comment 'The tier, level, or grade of certification achieved, if the certification framework has multiple levels (e.g., AEO has different tiers in some jurisdictions; TAPA has Class A, B, C security levels). Nullable if certification has no levels.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryForCommodityTypes rdf:type rdf:Property ;
    rdfs:label 'Mandatory For Commodity Types' ;
    rdfs:comment 'Comma-separated list of commodity types or HS Code (Harmonized System Code) categories for which this certification is required. Used to ensure only certified partners handle regulated goods (e.g., GDP for pharmaceuticals, IATA for dangerous goods).' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryForTradeLanes rdf:type rdf:Property ;
    rdfs:label 'Mandatory For Trade Lanes' ;
    rdfs:comment 'Comma-separated list of trade lane codes or route identifiers for which this certification is mandatory. Used to enforce compliance rules in partner selection and shipment routing (e.g., US_IMPORT requires C-TPAT, EU_EXPORT requires AEO).' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'The date on which a previously suspended or revoked certification was reinstated to active status. Nullable if never reinstated. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Sent Flag' ;
    rdfs:comment 'Indicates whether a renewal reminder notification has been sent to the partner or internal compliance team. True if notification sent, False otherwise.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the scope of the certification, including covered activities, services, locations, or product categories. For example, ISO 9001 scope may specify freight forwarding services at specific facilities; AEO may cover customs clearance and warehousing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerIncidentId rdf:type rdf:Property ;
    rdfs:label 'Partner Incident Id' ;
    rdfs:comment 'Unique identifier for the partner incident record. Primary key.' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerSlaId rdf:type rdf:Property ;
    rdfs:label 'Partner Sla Id' ;
    rdfs:comment 'Foreign key linking to network.partner_sla. Business justification: Partner incidents often represent SLA breaches (partner_incident already has sla_breach_flag). Linking to the specific SLA that was breached enables proper SLA breach tracking, penalty calculation, an' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerSla .

ind:primaryPartnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Partner Employee Id' ;
    rdfs:comment 'Reference to the internal user or employee who reported and logged this incident.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedIncidentId rdf:type rdf:Property ;
    rdfs:label 'Related Incident Id' ;
    rdfs:comment 'Reference to a previous or related incident record if this is a recurrence or linked issue.' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:resultingHseIncidentId rdf:type rdf:Property ;
    rdfs:label 'Resulting Hse Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.hse_incident. Business justification: Partner incidents that escalate to HSE recordable events must link to the formal incident record for OSHA reporting, regulatory compliance, investigation coordination, and corrective action tracking. ' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HseIncident .

ind:tertiaryPartnerAssignedToUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Partner Assigned To User Employee Id' ;
    rdfs:comment 'Reference to the internal user or case manager currently responsible for managing this incident through resolution.' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedShipmentReferences rdf:type rdf:Property ;
    rdfs:label 'Affected Shipment References' ;
    rdfs:comment 'Comma-separated list of shipment identifiers (AWB, BOL, tracking numbers) that were impacted by this incident. Enables impact quantification.' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Flag' ;
    rdfs:comment 'Indicates whether this partner incident resulted in direct impact to end customers (delays, damage, service failures).' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialImpactEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate Amount' ;
    rdfs:comment 'Estimated financial impact of the incident in the specified currency. Includes direct costs, penalties, and potential revenue loss.' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Reference Number' ;
    rdfs:comment 'Externally visible unique reference number assigned to this incident for tracking and communication purposes.' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerResponse rdf:type rdf:Property ;
    rdfs:label 'Partner Response' ;
    rdfs:comment 'The partners formal response to the incident, including their explanation, acknowledgment, and proposed remediation.' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Partner Response Date' ;
    rdfs:comment 'The date on which the partner provided their formal response to the incident.' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Applied Flag' ;
    rdfs:comment 'Indicates whether a contractual penalty or financial deduction was applied to the partner as a result of this incident.' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference' ;
    rdfs:comment 'Reference number or identifier of the regulatory report filed for this incident, if applicable.' ;
    rdfs:domain ind:PartnerIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether this incident must be reported to regulatory authorities (e.g., safety incidents, dangerous goods violations, customs breaches).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerOnboardingId rdf:type rdf:Property ;
    rdfs:label 'Partner Onboarding Id' ;
    rdfs:comment 'Unique identifier for the partner onboarding record. Primary key for tracking the end-to-end onboarding lifecycle of a network partner from initial qualification through activation.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quaternaryPartnerLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Partner Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this onboarding record. Establishes accountability for changes.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPartnerApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Partner Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who provided final approval for partner activation. Establishes accountability for the approval decision.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualActivationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Activation Date' ;
    rdfs:comment 'Actual date when the partner was activated and began operational activities. Nullable until activation is completed.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Verification Status' ;
    rdfs:comment 'Status of industry certification verification (ISO, AEO, C-TPAT, dangerous goods, etc.). Confirms partner holds required certifications.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Certification Verified Date' ;
    rdfs:comment 'Date when required certifications were verified.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Contract Execution Date' ;
    rdfs:comment 'Date when the partnership contract was formally executed by all parties. Marks legal commitment.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDiligenceCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completed Date' ;
    rdfs:comment 'Date when comprehensive due diligence checks (financial, operational, compliance) were completed and approved.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Integration Status' ;
    rdfs:comment 'Status of EDI connectivity setup and testing. Tracks technical integration for automated data exchange.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Financial Assessment Date' ;
    rdfs:comment 'Date when the financial assessment was completed.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Assessment Status' ;
    rdfs:comment 'Status of the financial viability and creditworthiness assessment. Evaluates partner financial stability and risk.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScopeAuthorized rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope Authorized' ;
    rdfs:comment 'Geographic regions or countries the partner is authorized to operate in. Defines territorial scope of the partnership.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Insurance Verification Status' ;
    rdfs:comment 'Status of insurance coverage verification. Confirms partner has adequate liability, cargo, and other required insurance.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified Date' ;
    rdfs:comment 'Date when insurance coverage was verified and approved.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Check Status' ;
    rdfs:comment 'Status of the Know Your Customer compliance check. Verifies partner identity, ownership structure, and legitimacy.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completed Date' ;
    rdfs:comment 'Date when the KYC compliance check was completed and approved.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingDurationDays rdf:type rdf:Property ;
    rdfs:label 'Onboarding Duration Days' ;
    rdfs:comment 'Total number of calendar days from initiation to activation. Used for process performance measurement and continuous improvement.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Onboarding Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for this onboarding case. Used for tracking and communication with the partner and internal stakeholders.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingType rdf:type rdf:Property ;
    rdfs:label 'Onboarding Type' ;
    rdfs:comment 'Type of onboarding activity. Distinguishes between new partner onboarding, expansion of existing partner capabilities, or reactivation of dormant partnerships.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalReadinessScore rdf:type rdf:Property ;
    rdfs:label 'Operational Readiness Score' ;
    rdfs:comment 'Composite score (0-100) assessing the partner readiness across all onboarding dimensions. Used for go/no-go decision making.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preQualificationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Pre Qualification Completed Date' ;
    rdfs:comment 'Date when the pre-qualification stage was completed. Indicates the partner met initial screening criteria.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'Date when sanctions screening was performed and cleared.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'Status of sanctions and denied party screening. Ensures partner is not on restricted or prohibited lists.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceModesAuthorized rdf:type rdf:Property ;
    rdfs:label 'Service Modes Authorized' ;
    rdfs:comment 'Comma-separated list of transport modes the partner is authorized to operate (air, ocean, road, rail, multimodal). Defines operational scope.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemIntegrationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'System Integration Completed Date' ;
    rdfs:comment 'Date when technical system integration (EDI, API, TMS connectivity) was completed and tested successfully.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetActivationDate rdf:type rdf:Property ;
    rdfs:label 'Target Activation Date' ;
    rdfs:comment 'Planned date for the partner to go live and begin operational activities. Used for project planning and stakeholder communication.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tmsIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Tms Integration Status' ;
    rdfs:comment 'Status of TMS system integration. Tracks connectivity to core transportation management platform for order and shipment processing.' ;
    rdfs:domain ind:PartnerOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Partner Performance Id' ;
    rdfs:comment 'Unique identifier for the partner performance evaluation record. Primary key.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityFulfillmentActualPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Fulfillment Actual Pct' ;
    rdfs:comment 'Actual percentage of requested capacity that the partner was able to fulfill during the evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityFulfillmentTargetPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Fulfillment Target Pct' ;
    rdfs:comment 'Target percentage for capacity fulfillment as per partner agreement.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimsRateActualPct rdf:type rdf:Property ;
    rdfs:label 'Claims Rate Actual Pct' ;
    rdfs:comment 'Actual percentage of shipments resulting in claims (loss, damage, delay) during the evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimsRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Claims Rate Target Pct' ;
    rdfs:comment 'Maximum acceptable claims rate threshold as per partner agreement.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositeScore rdf:type rdf:Property ;
    rdfs:label 'Composite Score' ;
    rdfs:comment 'Weighted composite score aggregating all performance dimensions into a single overall performance rating (0-100 scale).' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageRateActualPct rdf:type rdf:Property ;
    rdfs:label 'Damage Rate Actual Pct' ;
    rdfs:comment 'Actual percentage of shipments with damage incidents during the evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Damage Rate Target Pct' ;
    rdfs:comment 'Maximum acceptable damage rate threshold as per partner agreement.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationAccuracyActualPct rdf:type rdf:Property ;
    rdfs:label 'Documentation Accuracy Actual Pct' ;
    rdfs:comment 'Actual percentage of shipments with accurate and complete documentation (AWB, BOL, customs paperwork) during the evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationAccuracyTargetPct rdf:type rdf:Property ;
    rdfs:label 'Documentation Accuracy Target Pct' ;
    rdfs:comment 'Target percentage for documentation accuracy as per partner agreement.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Completed Date' ;
    rdfs:comment 'Date when the performance evaluation was completed and finalized.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Evaluation Frequency' ;
    rdfs:comment 'Frequency at which this partner performance evaluation is conducted.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdRateActualPct rdf:type rdf:Property ;
    rdfs:label 'Otd Rate Actual Pct' ;
    rdfs:comment 'Actual on-time delivery rate achieved by the partner during the evaluation period, expressed as a percentage.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otdRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otd Rate Target Pct' ;
    rdfs:comment 'Target on-time delivery rate contracted with the partner, expressed as a percentage.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Detailed notes and commentary from the performance review, including strengths, weaknesses, and improvement actions.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalShipmentsEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Shipments Evaluated' ;
    rdfs:comment 'Total number of shipments handled by the partner during the evaluation period that were included in this performance assessment.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeTeu rdf:type rdf:Property ;
    rdfs:label 'Total Volume Teu' ;
    rdfs:comment 'Total volume handled by the partner during the evaluation period, measured in TEU for ocean freight partners.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeComplianceActualPct rdf:type rdf:Property ;
    rdfs:label 'Transit Time Compliance Actual Pct' ;
    rdfs:comment 'Actual percentage of shipments meeting contracted transit time commitments during the evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeComplianceTargetPct rdf:type rdf:Property ;
    rdfs:label 'Transit Time Compliance Target Pct' ;
    rdfs:comment 'Target percentage for transit time compliance as per partner agreement.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'Overall performance trend direction compared to the previous evaluation period.' ;
    rdfs:domain ind:PartnerPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'Actual date on which payment was successfully made to the partner, as confirmed by the payment system.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awbCount rdf:type rdf:Property ;
    rdfs:label 'Awb Count' ;
    rdfs:comment 'Number of air waybills included in this settlement period for interline traffic settlements.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Partner bank account number to which the settlement payment is made. Masked or encrypted for security.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Total amount of deductions applied to the gross settlement, including penalties, chargebacks, claims offsets, and other adjustments.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Settlement Amount' ;
    rdfs:comment 'Total settlement amount before any deductions, adjustments, or withholdings are applied.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Original Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the original transaction currency before any currency conversion was applied.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Payment Date' ;
    rdfs:comment 'Target date on which payment is scheduled to be made to the partner based on payment terms and approval date.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'Payment mechanism used to settle the financial obligation with the partner. CASS refers to IATA Cargo Accounts Settlement System. [ENUM-REF-CANDIDATE: cass|bank_transfer|wire_transfer|ach|netting|offset|check — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period End Date' ;
    rdfs:comment 'End date of the period covered by this settlement (e.g., end of the month or billing cycle).' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this settlement (e.g., beginning of the month or billing cycle).' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for this settlement transaction, used for partner communication and reconciliation.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'SWIFT/BIC code identifying the partner bank for international wire transfers.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Amount' ;
    rdfs:comment 'Amount of tax withheld at source as required by local tax regulations or international tax treaties.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachThreshold rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold' ;
    rdfs:comment 'Performance level at which the SLA is considered breached, triggering penalties or remediation actions.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveClauseReference rdf:type rdf:Property ;
    rdfs:label 'Incentive Clause Reference' ;
    rdfs:comment 'Reference to the contract clause or document section that defines incentives or bonuses for exceeding SLA targets.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Incentive Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the incentive amount.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Days' ;
    rdfs:comment 'Number of days over which performance is aggregated for SLA evaluation (e.g., rolling 30-day average).' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the performance metric (e.g., percentage, hours, days, count).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClauseReference rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Reference' ;
    rdfs:comment 'Reference to the contract clause or document section that defines penalties for SLA breach.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetric rdf:type rdf:Property ;
    rdfs:label 'Performance Metric' ;
    rdfs:comment 'Specific metric or Key Performance Indicator (KPI) being measured under this SLA (e.g., on-time delivery percentage, average transit days, documentation error rate).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Reference Number' ;
    rdfs:comment 'Externally-known unique reference number or code for this partner SLA commitment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current lifecycle status of the partner SLA (e.g., active, suspended, expired, terminated, draft, under review).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningThreshold rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold' ;
    rdfs:comment 'Performance level that triggers a warning notification before a full SLA breach occurs. Allows proactive intervention.' ;
    rdfs:domain ind:PartnerSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerTariffId rdf:type rdf:Property ;
    rdfs:label 'Partner Tariff Id' ;
    rdfs:comment 'Unique identifier for the partner tariff master record.' ;
    rdfs:domain ind:PartnerTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dangerousGoodsApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Applicable Flag' ;
    rdfs:comment 'Indicates whether this tariff applies to shipments containing dangerous goods as classified under IMDG or IATA DGR.' ;
    rdfs:domain ind:PartnerTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationClause rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause' ;
    rdfs:comment 'Description of any rate escalation or adjustment mechanism tied to external indices (e.g., fuel price index, inflation index, GRI).' ;
    rdfs:domain ind:PartnerTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Included Flag' ;
    rdfs:comment 'Indicates whether fuel surcharge (BAF for ocean, FSC for air/road) is included in the base rate or applied separately.' ;
    rdfs:domain ind:PartnerTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securitySurchargeIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Security Surcharge Included Flag' ;
    rdfs:comment 'Indicates whether security-related surcharges are included in the base rate or applied separately.' ;
    rdfs:domain ind:PartnerTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffName rdf:type rdf:Property ;
    rdfs:label 'Tariff Name' ;
    rdfs:comment 'Descriptive name of the tariff structure for business identification and reporting purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tariff Reference Number' ;
    rdfs:comment 'External business identifier for the tariff, typically provided by the partner or assigned during negotiation.' ;
    rdfs:domain ind:PartnerTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffStatus rdf:type rdf:Property ;
    rdfs:label 'Tariff Status' ;
    rdfs:comment 'Current lifecycle status of the tariff master record.' ;
    rdfs:domain ind:PartnerTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffType rdf:type rdf:Property ;
    rdfs:label 'Tariff Type' ;
    rdfs:comment 'Classification of the tariff structure governing the rate agreement type.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Applicable Flag' ;
    rdfs:comment 'Indicates whether this tariff applies to temperature-controlled or refrigerated shipments.' ;
    rdfs:domain ind:PartnerTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminalHandlingIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Terminal Handling Included Flag' ;
    rdfs:comment 'Indicates whether terminal handling charges are included in the base tariff rate or billed separately.' ;
    rdfs:domain ind:PartnerTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeCommitmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Required Flag' ;
    rdfs:comment 'Indicates whether this tariff requires Transport Shipping to commit to a minimum volume or revenue threshold.' ;
    rdfs:domain ind:PartnerTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiIntegrationPriorityFlag rdf:type rdf:Property ;
    rdfs:label 'Api Integration Priority Flag' ;
    rdfs:comment 'Indicates whether partners in this tier receive priority support for API integration projects and technical enablement.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoUpgradeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Upgrade Eligible Flag' ;
    rdfs:comment 'Indicates whether partners in this tier are automatically considered for upgrade to a higher tier when they meet the next tier criteria.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Carbon Reporting Required Flag' ;
    rdfs:comment 'Indicates whether partners must provide regular carbon emissions reporting (CO2e) for their operations to qualify for this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Certification Requirements' ;
    rdfs:comment 'Comma-separated list of required certifications partners must hold to qualify for this tier (e.g., ISO 9001, C-TPAT, AEO, IATA, dangerous goods certifications).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerageCapabilityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Capability Required Flag' ;
    rdfs:comment 'Indicates whether partners must provide customs brokerage services to qualify for this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Certification Required Flag' ;
    rdfs:comment 'Indicates whether partners must hold dangerous goods handling certifications to qualify for this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dedicatedAccountManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Dedicated Account Management Flag' ;
    rdfs:comment 'Indicates whether partners in this tier receive dedicated account management support and a named account manager.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downgradeCriteria rdf:type rdf:Property ;
    rdfs:label 'Downgrade Criteria' ;
    rdfs:comment 'Detailed description of the conditions and performance failures that would trigger a partner downgrade from this tier to a lower tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediIntegrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Integration Required Flag' ;
    rdfs:comment 'Indicates whether partners must support EDI integration for automated data exchange to qualify for this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedPaymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Extended Payment Terms Days' ;
    rdfs:comment 'Number of additional payment term days extended to partners in this tier beyond standard payment terms.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialStabilityRatingMinimum rdf:type rdf:Property ;
    rdfs:label 'Financial Stability Rating Minimum' ;
    rdfs:comment 'Minimum acceptable financial stability or credit rating (e.g., A, B+, C) that partners must hold to qualify for this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageRequirement rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Requirement' ;
    rdfs:comment 'Minimum geographic service coverage scope required for partners to qualify for this tier (global, regional, national, or local).' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageRequirementUsd rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Requirement Usd' ;
    rdfs:comment 'Minimum insurance coverage amount in USD that partners must maintain to qualify for this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingCoBrandingFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Co Branding Flag' ;
    rdfs:comment 'Indicates whether partners in this tier are eligible for co-branded marketing initiatives and joint promotional activities.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumClaimsRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Maximum Claims Ratio Percentage' ;
    rdfs:comment 'Maximum allowable claims ratio percentage (claims value divided by total shipment value) that partners in this tier may have before being downgraded.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumContractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Contract Term Months' ;
    rdfs:comment 'Minimum contract duration in months required for partners to be assigned to this tier classification.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumOtdPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Otd Percentage' ;
    rdfs:comment 'Minimum required on-time delivery performance percentage threshold that partners must maintain to qualify for or remain in this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRevenueThresholdUsd rdf:type rdf:Property ;
    rdfs:label 'Minimum Revenue Threshold Usd' ;
    rdfs:comment 'Minimum annual revenue commitment in USD that partners must generate to qualify for or maintain this tier classification.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Threshold' ;
    rdfs:comment 'Minimum shipment volume threshold required for partners to qualify for this tier, measured in the unit specified by volume_threshold_unit.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferentialRatesFlag rdf:type rdf:Property ;
    rdfs:label 'Preferential Rates Flag' ;
    rdfs:comment 'Indicates whether partners in this tier are eligible for preferential pricing rates and discounts on services.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityCapacityAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Capacity Access Flag' ;
    rdfs:comment 'Indicates whether partners in this tier receive priority access to available capacity during peak periods or capacity constraints.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:probationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Probation Period Months' ;
    rdfs:comment 'Number of months partners must remain in this tier before being eligible for upgrade or subject to downgrade review. Applicable primarily to probationary tiers.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:realTimeTrackingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Real Time Tracking Required Flag' ;
    rdfs:comment 'Indicates whether partners must provide real-time shipment tracking capabilities to qualify for this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilityCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Required Flag' ;
    rdfs:comment 'Indicates whether partners must hold sustainability or environmental certifications (e.g., ISO 14001, carbon neutral certification) to qualify for this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureControlledCapabilityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Capability Required Flag' ;
    rdfs:comment 'Indicates whether partners must have temperature-controlled transport and storage capabilities to qualify for this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierBenefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Tier Benefits Summary' ;
    rdfs:comment 'Comprehensive textual summary of all benefits, privileges, and advantages that partners receive when assigned to this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCategory rdf:type rdf:Property ;
    rdfs:label 'Tier Category' ;
    rdfs:comment 'High-level classification grouping of the tier indicating the nature of the partnership relationship.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the tier classification (e.g., PREF, STRAT, APPR, PROB, SUSP).' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Detailed business description of the tier classification, its purpose, and the characteristics of partners assigned to this tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Full descriptive name of the partner tier (e.g., Preferred, Strategic, Approved, Probationary, Suspended).' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierObligationsSummary rdf:type rdf:Property ;
    rdfs:label 'Tier Obligations Summary' ;
    rdfs:comment 'Comprehensive textual summary of all obligations, commitments, and requirements that partners must fulfill to maintain this tier classification.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the tier classification indicating whether it is actively used for partner assignments.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportModeRequirements rdf:type rdf:Property ;
    rdfs:label 'Transport Mode Requirements' ;
    rdfs:comment 'Comma-separated list of transport modes partners must support to qualify for this tier (e.g., air, ocean, road, rail, multimodal).' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeCriteria rdf:type rdf:Property ;
    rdfs:label 'Upgrade Criteria' ;
    rdfs:comment 'Detailed description of the conditions and performance achievements that would qualify a partner for upgrade from this tier to a higher tier.' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Unit' ;
    rdfs:comment 'Unit of measure for the minimum volume threshold (Twenty-foot Equivalent Unit, shipment count, kilograms, cubic meters, or pallets).' ;
    rdfs:domain ind:PartnerTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tplCapabilityId rdf:type rdf:Property ;
    rdfs:label 'Tpl Capability Id' ;
    rdfs:comment 'Unique identifier for the 3PL/4PL provider capability record. Primary key.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bondedWarehouseCertified rdf:type rdf:Property ;
    rdfs:label 'Bonded Warehouse Certified' ;
    rdfs:comment 'Indicates whether the facility is certified as a bonded warehouse for customs-deferred storage.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capabilityCode rdf:type rdf:Property ;
    rdfs:label 'Capability Code' ;
    rdfs:comment 'Standardized code identifying the type of logistics capability (e.g., AMB_WH, COLD_STOR, BONDED_WH, CROSS_DOCK, KITTING, RET_PROC, CUST_BROK).' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capabilityName rdf:type rdf:Property ;
    rdfs:label 'Capability Name' ;
    rdfs:comment 'Human-readable name of the logistics capability offered (e.g., Ambient Warehousing, Cold Storage, Bonded Warehouse, Cross-Docking, Kitting and Assembly, Returns Processing, Customs Brokerage).' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Capability Status' ;
    rdfs:comment 'Current operational status of this capability at the facility. Active indicates the capability is fully operational and available for partner selection.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capabilityType rdf:type rdf:Property ;
    rdfs:label 'Capability Type' ;
    rdfs:comment 'Primary classification of the logistics service capability. [ENUM-REF-CANDIDATE: warehousing|cold_storage|bonded_warehouse|cross_docking|kitting|returns_processing|customs_brokerage|freight_forwarding|value_added_services|transportation|fulfillment — promote to reference product]' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityCbm rdf:type rdf:Property ;
    rdfs:label 'Capacity Cbm' ;
    rdfs:comment 'Total volumetric storage capacity in cubic meters, used for space planning and utilization analysis.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Capacity Pallet Positions' ;
    rdfs:comment 'Total number of pallet positions available for storage, relevant for warehousing capabilities.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacitySqm rdf:type rdf:Property ;
    rdfs:label 'Capacity Sqm' ;
    rdfs:comment 'Total available floor space capacity in square meters for warehousing or storage capabilities.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerPalletPerMonth rdf:type rdf:Property ;
    rdfs:label 'Cost Per Pallet Per Month' ;
    rdfs:comment 'Standard monthly storage cost per pallet position for warehousing capabilities, used for cost modeling and partner selection.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerUnitHandled rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit Handled' ;
    rdfs:comment 'Standard handling cost per unit (carton, parcel, or SKU) for throughput-based capabilities.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftzCertified rdf:type rdf:Property ;
    rdfs:label 'Ftz Certified' ;
    rdfs:comment 'Indicates whether the facility operates within or is certified as a Free Trade Zone.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iotEnabled rdf:type rdf:Property ;
    rdfs:label 'Iot Enabled' ;
    rdfs:comment 'Indicates whether the facility uses IoT sensors for real-time monitoring and tracking.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled' ;
    rdfs:comment 'Indicates whether the facility uses RFID technology for inventory tracking and visibility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:throughputUnitsPerDay rdf:type rdf:Property ;
    rdfs:label 'Throughput Units Per Day' ;
    rdfs:comment 'Maximum daily processing throughput capacity measured in units (cartons, parcels, or SKUs) that can be handled.' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tmsSystemName rdf:type rdf:Property ;
    rdfs:label 'Tms System Name' ;
    rdfs:comment 'Name of the Transportation Management System operated for this capability (e.g., SAP TM, Oracle TMS, Blue Yonder).' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueAddedServices rdf:type rdf:Property ;
    rdfs:label 'Value Added Services' ;
    rdfs:comment 'Comma-separated list of additional value-added services offered (e.g., labeling, packaging, quality inspection, kitting, assembly, returns management).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsSystemName rdf:type rdf:Property ;
    rdfs:label 'Wms System Name' ;
    rdfs:comment 'Name of the Warehouse Management System operated at this facility (e.g., Manhattan WMS, SAP EWM, Oracle WMS).' ;
    rdfs:domain ind:TplCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCapability rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capability' ;
    rdfs:comment 'Indicates whether the provider has temperature-controlled logistics capabilities for perishable or pharmaceutical goods.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsBrokerageCapability rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Capability' ;
    rdfs:comment 'Indicates whether the provider offers customs brokerage and trade compliance services for cross-border shipments.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionCapability rdf:type rdf:Property ;
    rdfs:label 'Distribution Capability' ;
    rdfs:comment 'Indicates whether the provider offers distribution and order fulfillment services.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediCapability rdf:type rdf:Property ;
    rdfs:label 'Edi Capability' ;
    rdfs:comment 'Indicates whether the provider supports Electronic Data Interchange (EDI) for automated transaction processing and data exchange.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialRating rdf:type rdf:Property ;
    rdfs:label 'Financial Rating' ;
    rdfs:comment 'Credit or financial strength rating assigned to the provider by a recognized rating agency or internal risk assessment. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D|not_rated — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpCertified rdf:type rdf:Property ;
    rdfs:label 'Gdp Certified' ;
    rdfs:comment 'Indicates whether the provider holds Good Distribution Practice (GDP) certification for pharmaceutical and healthcare logistics.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpCertified rdf:type rdf:Property ;
    rdfs:label 'Haccp Certified' ;
    rdfs:comment 'Indicates whether the provider holds HACCP (Hazard Analysis and Critical Control Points) certification for food safety and cold chain management.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the provider\'s headquarters street address including building number and street name.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the provider\'s headquarters location.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the provider\'s headquarters address.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region where the provider\'s headquarters is located.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMileDeliveryCapability rdf:type rdf:Property ;
    rdfs:label 'Last Mile Delivery Capability' ;
    rdfs:comment 'Indicates whether the provider offers last-mile delivery services to end customers or consignees.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Composite performance score (0-100) evaluating the provider\'s operational performance based on KPIs such as on-time delivery, accuracy, and service quality.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredProviderFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Provider Flag' ;
    rdfs:comment 'Indicates whether the provider has been designated as a preferred or strategic partner based on performance, capabilities, and relationship strength.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerCode rdf:type rdf:Property ;
    rdfs:label 'Provider Code' ;
    rdfs:comment 'Externally-known unique business identifier code for the 3PL/4PL provider, used in operational systems and partner communications.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the logistics provider based on service model: 3PL (Third-Party Logistics), 4PL (Fourth-Party Logistics), co-packer, value-added logistics provider, freight forwarder, or NVOCC (Non-Vessel Operating Common Carrier).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reverseLogisticsCapability rdf:type rdf:Property ;
    rdfs:label 'Reverse Logistics Capability' ;
    rdfs:comment 'Indicates whether the provider offers reverse logistics services including returns management and RMA (Return Merchandise Authorization) processing.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalWarehouseSqft rdf:type rdf:Property ;
    rdfs:label 'Total Warehouse Sqft' ;
    rdfs:comment 'Total warehouse and distribution center space in square feet managed by the provider across all facilities.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehousingCapability rdf:type rdf:Property ;
    rdfs:label 'Warehousing Capability' ;
    rdfs:comment 'Indicates whether the provider offers warehousing and storage services as part of their operational capabilities.' ;
    rdfs:domain ind:TplProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessorialChargeStatus rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charge Status' ;
    rdfs:comment 'Current lifecycle status of the accessorial charge definition. Active charges are available for use in rating and billing; inactive or deprecated charges are retained for historical reference only.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableIncoterms rdf:type rdf:Property ;
    rdfs:label 'Applicable Incoterms' ;
    rdfs:comment 'Comma-separated list of Incoterms under which this charge applies (e.g., DDP, DAP, FOB, CIF, EXW, FCA). Determines which party (shipper or consignee) is responsible for the charge. Empty if applicable to all Incoterms.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableModes rdf:type rdf:Property ;
    rdfs:label 'Applicable Modes' ;
    rdfs:comment 'Comma-separated list of transportation modes to which this charge applies (e.g., air, ocean, road, rail, multimodal). Empty if applicable to all modes.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApplyConditions rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Conditions' ;
    rdfs:comment 'Business rules or conditions that trigger automatic application of this charge (e.g., delivery_address_type=residential, package_weight>70kg, requires_signature=true, contains_hazmat=true). Stored as structured text or rule expression.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeBearer rdf:type rdf:Property ;
    rdfs:label 'Charge Bearer' ;
    rdfs:comment 'Party responsible for paying the accessorial charge: shipper (sender), consignee (receiver), third_party (bill-to party), or as_per_incoterm (determined by Incoterms agreement).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeName rdf:type rdf:Property ;
    rdfs:label 'Charge Name' ;
    rdfs:comment 'Human-readable name of the accessorial charge (e.g., Residential Delivery Surcharge, Address Correction Fee, Signature Required Fee, Hazmat Handling Fee).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargePercentage rdf:type rdf:Property ;
    rdfs:label 'Charge Percentage' ;
    rdfs:comment 'Percentage rate applied to base freight charge when calculation_basis is percentage_of_freight. Expressed as a decimal (e.g., 15.00 for 15%). Null for non-percentage charges.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeTier rdf:type rdf:Property ;
    rdfs:label 'Charge Tier' ;
    rdfs:comment 'Service tier or level associated with this accessorial charge, used for tiered pricing structures and service differentiation.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Visibility Flag' ;
    rdfs:comment 'Indicates whether this accessorial charge is visible to customers in quotes, invoices, and online portals (True) or is an internal charge not disclosed to customers (False).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Destination Country Codes' ;
    rdfs:comment 'Comma-separated list of three-letter ISO 3166-1 alpha-3 country codes where this charge applies to shipments destined. Empty if applicable to all destinations.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimWeightApplicable rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Applicable' ;
    rdfs:comment 'Indicates whether this accessorial charge calculation considers dimensional weight in addition to actual weight. Relevant for oversize or low-density shipments.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Eligible Flag' ;
    rdfs:comment 'Indicates whether customers can dispute this accessorial charge through the claims or billing dispute process. True if disputable, False if non-disputable.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClassApplicable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class Applicable' ;
    rdfs:comment 'Comma-separated list of hazmat classes (per IMDG, ICAO, or DOT classifications) to which this charge applies. Empty if not hazmat-specific. Used for dangerous goods handling fees.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Origin Country Codes' ;
    rdfs:comment 'Comma-separated list of three-letter ISO 3166-1 alpha-3 country codes where this charge applies to shipments originating. Empty if applicable to all origins.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedTariffFlag rdf:type rdf:Property ;
    rdfs:label 'Published Tariff Flag' ;
    rdfs:comment 'Indicates whether this accessorial charge is part of the published tariff available to all customers (True) or is a negotiated/contract-specific charge (False).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Accounting classification for revenue recognition purposes. Determines how the charge is recognized in financial statements.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalEndDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal End Date' ;
    rdfs:comment 'End date of the seasonal period during which this charge applies. Null if not seasonal or if seasonal_flag is False.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this accessorial charge is seasonal or temporary (e.g., peak season surcharge, holiday delivery fee). True if seasonal, False if year-round.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalStartDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Start Date' ;
    rdfs:comment 'Start date of the seasonal period during which this charge applies. Null if not seasonal or if seasonal_flag is False.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxableFlag rdf:type rdf:Property ;
    rdfs:label 'Taxable Flag' ;
    rdfs:comment 'Indicates whether the accessorial charge is subject to sales tax, VAT, or GST. True if taxable, False if exempt.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeThresholdApplicable rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Applicable' ;
    rdfs:comment 'Indicates whether volume-based discounts or thresholds apply to this accessorial charge. True if charge amount varies based on shipment volume or customer commitment levels.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waivableFlag rdf:type rdf:Property ;
    rdfs:label 'Waivable Flag' ;
    rdfs:comment 'Indicates whether this accessorial charge can be waived or discounted at the discretion of sales or operations staff. True if waivable, False if mandatory.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Required' ;
    rdfs:comment 'Indicates whether waiving this charge requires managerial or executive approval. True if approval is required, False if staff can waive without escalation.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneApplicable rdf:type rdf:Property ;
    rdfs:label 'Zone Applicable' ;
    rdfs:comment 'Comma-separated list of delivery zones or postal code zones to which this accessorial charge applies (e.g., remote_area, extended_delivery, urban, rural). Empty if not zone-specific.' ;
    rdfs:domain ind:AccessorialCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRateCarrierBuyRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Carrier Buy Rate Id' ;
    rdfs:comment 'Reference to the newer buy rate that replaces this one. Used to maintain rate lineage and history.' ;
    rdfs:domain ind:CarrierBuyRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierBuyRate .

ind:buyRateAmount rdf:type rdf:Property ;
    rdfs:label 'Buy Rate Amount' ;
    rdfs:comment 'The cost amount Transport Shipping pays to the carrier per unit. This is the base buy-side rate before surcharges.' ;
    rdfs:domain ind:CarrierBuyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityGroupCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Group Code' ;
    rdfs:comment 'Code representing the commodity or product group this buy rate applies to (e.g., general cargo, hazmat, perishables, high-value).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griApplicable rdf:type rdf:Property ;
    rdfs:label 'Gri Applicable' ;
    rdfs:comment 'Indicates whether General Rate Increase (GRI) adjustments apply to this buy rate. Common in ocean freight contracts.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginFloorPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Floor Percentage' ;
    rdfs:comment 'Minimum margin percentage that must be maintained when pricing sell-side rates based on this buy rate. Used for margin management and pricing guardrails.' ;
    rdfs:domain ind:CarrierBuyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge Amount' ;
    rdfs:comment 'Maximum charge cap for this buy rate, if applicable. Used for volume-based rate capping agreements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Amount' ;
    rdfs:comment 'Minimum charge the carrier will invoice regardless of shipment size or weight. Floor for cost calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Unique business identifier for this buy rate, used for operational reference and carrier invoice reconciliation.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateName rdf:type rdf:Property ;
    rdfs:label 'Rate Name' ;
    rdfs:comment 'Descriptive name for the buy rate, typically including lane, mode, and service type for easy identification.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thcIncluded rdf:type rdf:Property ;
    rdfs:label 'Thc Included' ;
    rdfs:comment 'Indicates whether Terminal Handling Charges (THC) are included in the buy rate or billed separately by the carrier.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeBreakMaxCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Break Max Cbm' ;
    rdfs:comment 'Maximum volume threshold in cubic meters (CBM) for this rate tier. Null indicates no upper limit.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeBreakMinCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Break Min Cbm' ;
    rdfs:comment 'Minimum volume threshold in cubic meters (CBM) for this rate tier. Used for volumetric pricing.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMaxKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Max Kg' ;
    rdfs:comment 'Maximum weight threshold in kilograms for this rate tier. Null indicates no upper limit.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMinKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Min Kg' ;
    rdfs:comment 'Minimum weight threshold in kilograms for this rate tier. Used for tiered pricing structures.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeCodeId rdf:type rdf:Property ;
    rdfs:label 'Charge Code Id' ;
    rdfs:comment 'Primary key for charge_code' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByChargeCodeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Charge Code Id' ;
    rdfs:comment 'Reference to the newer charge code that replaces this one when this charge is deprecated or superseded. Supports charge code version lineage tracking.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChargeCode .

ind:applicableTransportModes rdf:type rdf:Property ;
    rdfs:label 'Applicable Transport Modes' ;
    rdfs:comment 'Comma-separated list of transport modes to which this charge applies (e.g., air, ocean, road, rail, multimodal).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeSubcategory rdf:type rdf:Property ;
    rdfs:label 'Charge Subcategory' ;
    rdfs:comment 'Granular classification within the charge category (e.g., under surcharge: fuel, currency, security, peak season; under accessorial: liftgate, inside delivery, residential).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAccountCode rdf:type rdf:Property ;
    rdfs:label 'Cost Account Code' ;
    rdfs:comment 'General Ledger (GL) cost account code for expense allocation when this charge represents a pass-through or cost recovery item.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsHsCodeApplicable rdf:type rdf:Property ;
    rdfs:label 'Customs Hs Code Applicable' ;
    rdfs:comment 'Indicates whether this charge requires Harmonized System (HS) code classification for customs declaration and duty calculation purposes.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edifactChargeCode rdf:type rdf:Property ;
    rdfs:label 'Edifact Charge Code' ;
    rdfs:comment 'UN/EDIFACT standard charge code used in electronic data interchange (EDI) messages for freight and logistics (e.g., IFTMIN, IFTMBC, INVOIC).' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatApplicable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Applicable' ;
    rdfs:comment 'Indicates whether this charge applies specifically to hazardous materials (dangerous goods) shipments requiring special handling per IMDG, IATA DGR, or ADR regulations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataChargeCode rdf:type rdf:Property ;
    rdfs:label 'Iata Charge Code' ;
    rdfs:comment 'Two-letter IATA standard charge code used in air waybill (AWB) and cargo-IMP messaging (e.g., MY for miscellaneous charge due carrier, PP for prepaid, CC for collect).' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Account Code' ;
    rdfs:comment 'General Ledger (GL) revenue account code to which this charge type posts. Used for financial reporting and revenue recognition per IFRS 15.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code for this charge type (e.g., standard rate, reduced rate, exempt, zero-rated). Used for automated tax calculation.' ;
    rdfs:domain ind:ChargeCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByClassCommodityRateClassId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Class Commodity Rate Class Id' ;
    rdfs:comment 'Reference to the commodity rate class that replaces this one when it expires or is deprecated. Enables version tracking and migration.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityRateClass .

ind:commodityName rdf:type rdf:Property ;
    rdfs:label 'Commodity Name' ;
    rdfs:comment 'Human-readable name of the commodity type (e.g., Electronics, Apparel, Perishables, Machinery).' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsInspectionLikelihood rdf:type rdf:Property ;
    rdfs:label 'Customs Inspection Likelihood' ;
    rdfs:comment 'Estimated likelihood of customs inspection for this commodity type. Affects transit time estimates and customs clearance planning.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultDimFactor rdf:type rdf:Property ;
    rdfs:label 'Default Dim Factor' ;
    rdfs:comment 'Default dimensional weight divisor for this commodity class. Common values: 5000 for air freight, 6000 for express parcels. Used when commodity-specific DIM rules apply.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:densityClass rdf:type rdf:Property ;
    rdfs:label 'Density Class' ;
    rdfs:comment 'Classification of commodity based on weight-to-volume ratio. Affects dimensional weight calculations and space-based pricing.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Export Controlled Flag' ;
    rdfs:comment 'Indicates whether the commodity is subject to export control regulations requiring special licenses or permits.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightClass rdf:type rdf:Property ;
    rdfs:label 'Freight Class' ;
    rdfs:comment 'National Motor Freight Classification (NMFC) freight class for road freight rating. Classes range from 50 (densest) to 500 (least dense). Used primarily for LTL (Less Than Truckload) pricing.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highValueFlag rdf:type rdf:Property ;
    rdfs:label 'High Value Flag' ;
    rdfs:comment 'Indicates whether the commodity is classified as high-value cargo requiring additional insurance, security measures, and handling surcharges.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highValueThreshold rdf:type rdf:Property ;
    rdfs:label 'High Value Threshold' ;
    rdfs:comment 'Monetary threshold above which the commodity is considered high-value. Expressed in the currency specified in threshold_currency.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the minimum charge override amount.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumChargeOverride rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Override' ;
    rdfs:comment 'Commodity-specific minimum charge that overrides standard tariff minimums. Expressed in the currency specified in minimum_charge_currency.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingRequirements rdf:type rdf:Property ;
    rdfs:label 'Packaging Requirements' ;
    rdfs:comment 'Description of mandatory packaging requirements for this commodity (e.g., UN-certified packaging for hazmat, wooden crates for fragile items).' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perishableFlag rdf:type rdf:Property ;
    rdfs:label 'Perishable Flag' ;
    rdfs:comment 'Indicates whether the commodity is perishable and requires expedited handling and time-sensitive delivery.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prohibitedCountries rdf:type rdf:Property ;
    rdfs:label 'Prohibited Countries' ;
    rdfs:comment 'Comma-separated list of three-letter ISO country codes where this commodity is prohibited from import or export due to regulatory restrictions.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateClassDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Class Description' ;
    rdfs:comment 'Description of the rate class and its pricing treatment characteristics.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to base rates for this commodity class. Values greater than 1.0 indicate premium pricing; less than 1.0 indicate discounted pricing.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedTransportModes rdf:type rdf:Property ;
    rdfs:label 'Restricted Transport Modes' ;
    rdfs:comment 'Comma-separated list of transport modes NOT permitted for this commodity due to regulatory or safety restrictions (e.g., AIR for certain hazmat classes).' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether the commodity can be stacked during transport and warehousing. Affects loading optimization and space utilization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surchargeApplicability rdf:type rdf:Property ;
    rdfs:label 'Surcharge Applicability' ;
    rdfs:comment 'Comma-separated list of surcharge types applicable to this commodity (e.g., HAZMAT, REEFER, HIGH_VALUE, OVERSIZE, SECURITY). Drives accessorial charge calculations.' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMax rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max' ;
    rdfs:comment 'Maximum temperature in Celsius required for temperature-controlled commodities. Applicable only when temperature_controlled_flag is true.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMin rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min' ;
    rdfs:comment 'Minimum temperature in Celsius required for temperature-controlled commodities. Applicable only when temperature_controlled_flag is true.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the high value threshold amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:CommodityRateClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Indicates whether this rate represents a deviation from standard pricing policy (e.g., below-floor approval, emergency rate, special commodity exception).' ;
    rdfs:domain ind:ContractRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationReason rdf:type rdf:Property ;
    rdfs:label 'Deviation Reason' ;
    rdfs:comment 'Business justification for rate deviation, including reason code and narrative explanation (e.g., competitive match, strategic account, volume commitment, market conditions).' ;
    rdfs:domain ind:ContractRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimWeightDivisor rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Divisor' ;
    rdfs:comment 'Divisor used to calculate dimensional weight from volumetric measurements (length x width x height / divisor). Common values: 5000 for air, 6000 for express.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorRate rdf:type rdf:Property ;
    rdfs:label 'Floor Rate' ;
    rdfs:comment 'Minimum allowable rate threshold below which special approval is required. Used for deviation tracking and margin protection.' ;
    rdfs:domain ind:ContractRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Type of shipment covered by this rate: parcel, freight, LTL (Less Than Truckload), FTL (Full Truckload), FCL (Full Container Load), LCL (Less Than Container Load).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRuleDimWeightRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Dim Weight Rule Id' ;
    rdfs:comment 'Reference to the dimensional weight rule that replaces this rule when it expires or is superseded, enabling rule version tracking.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DimWeightRule .

ind:appliesToReturns rdf:type rdf:Property ;
    rdfs:label 'Applies To Returns' ;
    rdfs:comment 'Boolean flag indicating whether this dimensional weight rule applies to return shipments (RMA) or only to forward shipments.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dimFactor rdf:type rdf:Property ;
    rdfs:label 'Dim Factor' ;
    rdfs:comment 'Volumetric divisor used to calculate dimensional weight from package dimensions. Common values: 5000 for air freight (cm³/kg), 6000 for express (cm³/kg), 4000 for premium express. Formula: DIM Weight = (Length × Width × Height) / DIM Factor.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefaultRule rdf:type rdf:Property ;
    rdfs:label 'Is Default Rule' ;
    rdfs:comment 'Boolean flag indicating whether this is the default dimensional weight rule applied when no more specific rule matches the shipment criteria.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthUnit rdf:type rdf:Property ;
    rdfs:label 'Length Unit' ;
    rdfs:comment 'Unit of measure for package length dimension used in the dimensional weight calculation (centimeters, inches, or meters).' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumChargeableWeight rdf:type rdf:Property ;
    rdfs:label 'Maximum Chargeable Weight' ;
    rdfs:comment 'Maximum weight threshold above which the dimensional weight rule does not apply or special handling is required, expressed in the weight unit of measure.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeableWeight rdf:type rdf:Property ;
    rdfs:label 'Minimum Chargeable Weight' ;
    rdfs:comment 'Minimum weight threshold below which the dimensional weight rule does not apply or a floor chargeable weight is enforced, expressed in the weight unit of measure.' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'Method used to round the calculated dimensional weight to determine chargeable weight (round up to next whole unit, round down, round to nearest, or round half up).' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingPrecision rdf:type rdf:Property ;
    rdfs:label 'Rounding Precision' ;
    rdfs:comment 'Precision to which the dimensional weight is rounded (e.g., 0.5 for half-kilogram increments, 1.0 for whole kilogram increments).' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business identifier code for the dimensional weight rule, used for external reference and system integration.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed explanation of the dimensional weight calculation rule, including business context and application scenarios.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Descriptive name of the dimensional weight rule for business user identification and reporting purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the dimensional weight rule indicating whether it is actively applied in pricing calculations.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitSystem rdf:type rdf:Property ;
    rdfs:label 'Unit System' ;
    rdfs:comment 'Measurement system used for dimensional weight calculation: metric (centimeters and kilograms) or imperial (inches and pounds).' ;
    rdfs:domain ind:DimWeightRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for weight used in the dimensional weight calculation and comparison with actual weight (kilograms, pounds, or grams).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumptionRecordId rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Record Id' ;
    rdfs:comment 'Foreign key linking to sustainability.fuel_consumption_record. Business justification: Fuel surcharge indices must correlate with actual fuel consumption records for carbon accounting reconciliation, Scope 1 emissions verification, and fuel efficiency variance analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FuelConsumptionRecord .

ind:adjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Adjustment Factor' ;
    rdfs:comment 'Multiplier or adjustment factor applied to the index value for specific trade lanes, service types, or contractual agreements (e.g., 1.05 for 5% premium on express services).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineIndexValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Index Value' ;
    rdfs:comment 'Reference baseline value used to calculate percentage change or delta for surcharge formulas. Typically set at contract inception or annually.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Index Change Percentage' ;
    rdfs:comment 'Calculated percentage change from the baseline index value. Used directly in BAF and fuel surcharge formulas (e.g., +15.25% triggers tier-based surcharge).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexCode rdf:type rdf:Property ;
    rdfs:label 'Index Code' ;
    rdfs:comment 'Business identifier code for the fuel index (e.g., IATA_JET_FUEL, PLATTS_IFO380, MOPS_DIESEL). Used for external reference and integration with pricing systems.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexCurrency rdf:type rdf:Property ;
    rdfs:label 'Index Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the index value is denominated (e.g., USD, EUR, SGD).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexDate rdf:type rdf:Property ;
    rdfs:label 'Index Date' ;
    rdfs:comment 'The date for which this fuel index value is published. Represents the business event timestamp for the index observation.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexName rdf:type rdf:Property ;
    rdfs:label 'Index Name' ;
    rdfs:comment 'Human-readable name of the fuel index (e.g., IATA Jet Fuel Index - Singapore, Platts Brent Crude).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexPublicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Index Publication Timestamp' ;
    rdfs:comment 'Timestamp when the index was officially published by the source organization. Distinct from index_date (the date the index represents) and created_timestamp (when the record was ingested).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:indexSource rdf:type rdf:Property ;
    rdfs:label 'Index Source' ;
    rdfs:comment 'Source organization or exchange publishing the fuel index. IATA (International Air Transport Association), Platts (S&P Global Platts), MOPS (Mean of Platts Singapore), EIA (US Energy Information Administration), ICE (Intercontinental Exchange), NYMEX (New York Mercantile Exchange). [ENUM-REF-CANDIDATE: iata|platts|mops|eia|ice|nymex|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Index Source Url' ;
    rdfs:comment 'URL or reference link to the official publication source of the fuel index. Supports audit trail and verification.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexStatus rdf:type rdf:Property ;
    rdfs:label 'Index Status' ;
    rdfs:comment 'Current lifecycle status of the fuel index record. Active indices are used for surcharge calculations; superseded indices are replaced by newer values; archived indices are retained for audit; pending verification indices await approval.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexValue rdf:type rdf:Property ;
    rdfs:label 'Index Value' ;
    rdfs:comment 'The published fuel price index value for the index date. Precision supports fractional currency units and per-unit pricing (e.g., USD per gallon, USD per metric ton).' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Publication Frequency' ;
    rdfs:comment 'Frequency at which the index source publishes updates (daily, weekly, monthly, quarterly). Drives automated surcharge recalculation cycles.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeTier rdf:type rdf:Property ;
    rdfs:label 'Surcharge Tier' ;
    rdfs:comment 'Surcharge tier or bracket assigned based on index value or change percentage (e.g., Tier 1, Tier 2, Tier 3). Maps to predefined surcharge rate tables.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Timestamp when the index value was verified. Null if verification_status is unverified.' ;
    rdfs:domain ind:FuelIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:griAnnouncementId rdf:type rdf:Property ;
    rdfs:label 'Gri Announcement Id' ;
    rdfs:comment 'Unique identifier for the GRI announcement record.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByGriGriAnnouncementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Gri Gri Announcement Id' ;
    rdfs:comment 'Reference to a subsequent GRI announcement that replaces or supersedes this one.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GriAnnouncement .

ind:triggeringEnvironmentalIncidentId rdf:type rdf:Property ;
    rdfs:label 'Triggering Environmental Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.environmental_incident. Business justification: Carriers announce GRIs to recover costs from major environmental incidents (fuel spills, hazmat cleanup). Transport operators track which environmental incidents triggered rate increases for customer ' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalIncident .

ind:announcementSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Announcement Source Url' ;
    rdfs:comment 'Web URL or document reference where the original GRI announcement was published.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:announcementStatus rdf:type rdf:Property ;
    rdfs:label 'Announcement Status' ;
    rdfs:comment 'Current lifecycle status of the GRI announcement indicating its acceptance and implementation state.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:announcingPartyType rdf:type rdf:Property ;
    rdfs:label 'Announcing Party Type' ;
    rdfs:comment 'Classification of the entity issuing the GRI announcement.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToContract rdf:type rdf:Property ;
    rdfs:label 'Applies To Contract' ;
    rdfs:comment 'Indicates whether this GRI applies to existing contract pricing or only to spot rates.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToSpot rdf:type rdf:Property ;
    rdfs:label 'Applies To Spot' ;
    rdfs:comment 'Indicates whether this GRI applies to spot quote pricing.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityScope rdf:type rdf:Property ;
    rdfs:label 'Commodity Scope' ;
    rdfs:comment 'Specific commodity types or HS code ranges to which this GRI applies, or ALL for universal application.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date when customers were notified of this GRI and its impact on their pricing.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required' ;
    rdfs:comment 'Indicates whether customer notification workflows must be triggered for this GRI.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSegmentScope rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Scope' ;
    rdfs:comment 'Customer segments or tiers to which this GRI applies, or ALL for universal application.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeScope rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Scope' ;
    rdfs:comment 'Container or equipment types affected by this GRI, such as 20GP, 40HC, reefer, or ALL.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griCurrency rdf:type rdf:Property ;
    rdfs:label 'Gri Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the GRI amount.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griName rdf:type rdf:Property ;
    rdfs:label 'Gri Name' ;
    rdfs:comment 'Human-readable name or title of the GRI announcement for identification purposes.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griPercentage rdf:type rdf:Property ;
    rdfs:label 'Gri Percentage' ;
    rdfs:comment 'Percentage increase applied to base rates when GRI type is percentage.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:griReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Gri Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this GRI announcement by the carrier or trade body.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griType rdf:type rdf:Property ;
    rdfs:label 'Gri Type' ;
    rdfs:comment 'Classification of how the GRI increase is structured and calculated.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Internal assessment of the financial and operational impact of this GRI on the organization\'s freight forwarding margins and customer pricing.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermScope rdf:type rdf:Property ;
    rdfs:label 'Incoterm Scope' ;
    rdfs:comment 'Incoterms to which this GRI applies, such as FOB, CIF, DDP, or ALL.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketJustification rdf:type rdf:Property ;
    rdfs:label 'Market Justification' ;
    rdfs:comment 'Textual explanation provided by the carrier or trade body for the rate increase, such as fuel cost escalation or capacity constraints.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'Date when the GRI announcement was officially published or communicated to the market.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateCardUpdateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Card Update Status' ;
    rdfs:comment 'Status of automated updates to rate_card records triggered by this GRI announcement.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeScheduleUpdateStatus rdf:type rdf:Property ;
    rdfs:label 'Surcharge Schedule Update Status' ;
    rdfs:comment 'Status of automated updates to surcharge_schedule records triggered by this GRI announcement.' ;
    rdfs:domain ind:GriAnnouncement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Description' ;
    rdfs:comment 'Detailed business description of how this charge is allocated under the Incoterms rule, including any special conditions or exceptions.' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeSequence rdf:type rdf:Property ;
    rdfs:label 'Charge Sequence' ;
    rdfs:comment 'Sequence number indicating the order in which charges are applied or displayed within the Incoterms rule.' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costTransferPoint rdf:type rdf:Property ;
    rdfs:label 'Cost Transfer Point' ;
    rdfs:comment 'Physical location or event at which cost responsibility transfers from seller to buyer under this Incoterms rule.' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Responsibility' ;
    rdfs:comment 'Party responsible for customs clearance formalities under this Incoterms rule (seller, buyer, shared, or not applicable).' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionHandlingRule rdf:type rdf:Property ;
    rdfs:label 'Exception Handling Rule' ;
    rdfs:comment 'Instructions for handling exceptions or special cases that deviate from the standard allocation rule.' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsName rdf:type rdf:Property ;
    rdfs:label 'Incoterms Name' ;
    rdfs:comment 'Full descriptive name of the Incoterms rule (e.g., Delivered Duty Paid, Free on Board).' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Insurance Responsibility' ;
    rdfs:comment 'Party responsible for arranging cargo insurance under this Incoterms rule (seller, buyer, optional, or not required).' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillableToCustomer rdf:type rdf:Property ;
    rdfs:label 'Is Billable To Customer' ;
    rdfs:comment 'Indicates whether this charge should appear on the customer invoice (true) or is absorbed by the carrier (false).' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryCharge rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Charge' ;
    rdfs:comment 'Indicates whether this charge is mandatory under the Incoterms rule (true) or optional/negotiable (false).' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionRule rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Rule' ;
    rdfs:comment 'Timing rule for when revenue from this charge category should be recognized (at origin, at destination, over transit period, at delivery, at customs clearance).' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDirection rdf:type rdf:Property ;
    rdfs:label 'Shipment Direction' ;
    rdfs:comment 'Direction of shipment flow for which this allocation applies (export, import, domestic, cross-border).' ;
    rdfs:domain ind:IncotermsChargeAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLaneCode rdf:type rdf:Property ;
    rdfs:label 'Trade Lane Code' ;
    rdfs:comment 'Code identifying the specific trade lane or route corridor (e.g., USEU for US-Europe) for which this allocation rule applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceFromHubKm rdf:type rdf:Property ;
    rdfs:label 'Distance From Hub Km' ;
    rdfs:comment 'Average distance in kilometers from the primary distribution hub or gateway to locations within this zone. Used for distance-based pricing calculations.' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeTradeZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Free Trade Zone Flag' ;
    rdfs:comment 'Indicates whether this zone includes or is adjacent to a Free Trade Zone, which may affect duty and tax calculations in pricing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelSurchargeRegion rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Region' ;
    rdfs:comment 'Code identifying the fuel surcharge region this zone belongs to. Links to fuel index tables for Bunker Adjustment Factor (BAF) and fuel surcharge calculations.' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Restricted Flag' ;
    rdfs:comment 'Indicates whether this zone has restrictions on hazardous materials shipments, affecting service availability and surcharge applicability.' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermDefault rdf:type rdf:Property ;
    rdfs:label 'Incoterm Default' ;
    rdfs:comment 'Default International Commercial Term (Incoterm) applied to shipments in this zone, affecting charge allocation between shipper and consignee (e.g., DDP, DAP, FOB, CIF, EXW).' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodePattern rdf:type rdf:Property ;
    rdfs:label 'Postal Code Pattern' ;
    rdfs:comment 'Regular expression or wildcard pattern defining the postal codes included in this zone (e.g., \'10***\' for all codes starting with 10). Enables efficient postal code to zone resolution.' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteAreaFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Area Flag' ;
    rdfs:comment 'Indicates whether this zone is classified as a remote or extended delivery area, which typically incurs additional surcharges.' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneDescription rdf:type rdf:Property ;
    rdfs:label 'Zone Description' ;
    rdfs:comment 'Detailed textual description of the zone coverage, including specific geographic boundaries, exceptions, and business rules for zone assignment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Zone Hierarchy Level' ;
    rdfs:comment 'Numeric level in the zone hierarchy structure. Level 1 is the broadest (e.g., continent), higher numbers represent finer granularity (e.g., postal code).' ;
    rdfs:domain ind:LaneRateZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingSurchargeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Pricing Surcharge Schedule Id' ;
    rdfs:comment 'Unique identifier for the surcharge schedule record. Primary key.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPricingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pricing Employee Id' ;
    rdfs:comment 'Reference to the user who approved this surcharge schedule. Required for audit trail and compliance with pricing governance policies.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededBySchedulePricingSurchargeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Pricing Surcharge Schedule Id' ;
    rdfs:comment 'Reference to the newer surcharge schedule that replaces this one. Nullable if this is the current active schedule.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingSurchargeSchedule .

ind:tertiaryPricingModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Pricing Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this surcharge schedule record. Required for audit trail.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:triggeringDgIncidentId rdf:type rdf:Property ;
    rdfs:label 'Triggering Dg Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.dg_incident. Business justification: Dangerous goods incidents trigger surcharge schedule revisions (new hazmat handling fees, security surcharges). Logistics operators link surcharge changes to triggering DG incidents for regulatory rep' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DgIncident .

ind:customerSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Code' ;
    rdfs:comment 'Customer segment or tier this surcharge schedule applies to (e.g., ENTERPRISE, SMB, RETAIL). Enables differential pricing by customer class.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPortCode rdf:type rdf:Property ;
    rdfs:label 'Destination Port Code' ;
    rdfs:comment 'Five-letter UN/LOCODE for destination port or airport. Specifies exact terminal where surcharge applies (e.g., USLAX, CNSHA).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegionCode rdf:type rdf:Property ;
    rdfs:label 'Destination Region Code' ;
    rdfs:comment 'Business-defined region code for destination (e.g., APAC, EMEA, AMER). Used when surcharge applies to a broader geographic area.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexBaseValue rdf:type rdf:Property ;
    rdfs:label 'Index Base Value' ;
    rdfs:comment 'Baseline index value used as reference point for indexed surcharge calculations. Changes in index relative to this base drive surcharge adjustments.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexCurrentValue rdf:type rdf:Property ;
    rdfs:label 'Index Current Value' ;
    rdfs:comment 'Current index value at time of schedule creation or last update. Used to calculate indexed surcharge amount.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexReferenceName rdf:type rdf:Property ;
    rdfs:label 'Index Reference Name' ;
    rdfs:comment 'Name of external index this surcharge is linked to (e.g., \'Brent Crude Oil Price\', \'Singapore Bunker Index\'). Used for indexed surcharge types like BAF.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPortCode rdf:type rdf:Property ;
    rdfs:label 'Origin Port Code' ;
    rdfs:comment 'Five-letter UN/LOCODE for origin port or airport. Specifies exact terminal where surcharge applies (e.g., USLAX, CNSHA).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originRegionCode rdf:type rdf:Property ;
    rdfs:label 'Origin Region Code' ;
    rdfs:comment 'Business-defined region code for origin (e.g., APAC, EMEA, AMER). Used when surcharge applies to a broader geographic area.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedFlag rdf:type rdf:Property ;
    rdfs:label 'Published Flag' ;
    rdfs:comment 'Indicates whether this surcharge schedule has been published to customers and external systems. True if published, False if internal-only.' ;
    rdfs:domain ind:PricingSurchargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when this surcharge schedule was published externally. Required for regulatory compliance with advance notice requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'The surcharge rate value. Interpretation depends on rate_type: absolute monetary amount per unit, or percentage multiplier.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Rate Unit Of Measure' ;
    rdfs:comment 'Unit basis for the surcharge rate: per kilogram, per cubic meter (CBM), per Twenty-foot Equivalent Unit (TEU), per shipment, per container, per pallet.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingVolumeCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Pricing Volume Commitment Id' ;
    rdfs:comment 'Unique identifier for the customer volume commitment record. Primary key for the pricing volume commitment entity.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRevenueToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue To Date' ;
    rdfs:comment 'Cumulative actual revenue generated by the customer during the current commitment period, applicable for revenue-based commitments.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Calculated or fixed bonus amount awarded to the customer for exceeding the volume commitment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusClauseApplicable rdf:type rdf:Property ;
    rdfs:label 'Bonus Clause Applicable' ;
    rdfs:comment 'Indicates whether a bonus or incentive clause is in effect for exceeding the committed volume.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Bonus Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for bonus amounts.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusType rdf:type rdf:Property ;
    rdfs:label 'Bonus Type' ;
    rdfs:comment 'Type of bonus or incentive awarded when commitment is exceeded: volume rebate, additional discount, credit note, or future rate reduction.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Commitment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for revenue-based commitments and financial thresholds.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Commitment End Date' ;
    rdfs:comment 'The date when this volume commitment period ends and final reconciliation occurs.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentPeriodType rdf:type rdf:Property ;
    rdfs:label 'Commitment Period Type' ;
    rdfs:comment 'Frequency or duration type of the commitment measurement period (monthly, quarterly, annual).' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Reference Number' ;
    rdfs:comment 'Business-readable unique reference number for this volume commitment, used in customer communications and billing reconciliation.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Start Date' ;
    rdfs:comment 'The date when this volume commitment period begins and measurement starts.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Commitment Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the committed volume: kilograms, TEU (Twenty-foot Equivalent Unit), CBM (Cubic Meter), shipment count, or revenue currency. [ENUM-REF-CANDIDATE: kg|teu|cbm|shipments|revenue_usd|revenue_eur|pallets — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Revenue Amount' ;
    rdfs:comment 'The agreed minimum revenue amount the customer commits to generate during the commitment period, applicable for revenue-based commitments.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedVolumeQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Volume Quantity' ;
    rdfs:comment 'The agreed minimum volume quantity the customer commits to ship during the commitment period. Unit specified in commitment_unit_of_measure.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationRegionScope rdf:type rdf:Property ;
    rdfs:label 'Destination Region Scope' ;
    rdfs:comment 'Destination region(s) to which this commitment applies. Null indicates all destinations.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Last Measurement Date' ;
    rdfs:comment 'Date when the actual volume and variance were last calculated and updated.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Notification Threshold Percentage' ;
    rdfs:comment 'Percentage of commitment achievement at which automated alerts are triggered to notify account managers and customers (e.g., 80% to warn of potential shortfall).' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originRegionScope rdf:type rdf:Property ;
    rdfs:label 'Origin Region Scope' ;
    rdfs:comment 'Origin region(s) to which this commitment applies. Null indicates all origins.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'Type of penalty applied when commitment is not met: fixed fee, percentage of shortfall value, rate adjustment (loss of discount), or rebate forfeiture.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceModeScope rdf:type rdf:Property ;
    rdfs:label 'Service Mode Scope' ;
    rdfs:comment 'Transport mode(s) to which this volume commitment applies: air freight, ocean freight, road, rail, multimodal, or all modes.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdTier rdf:type rdf:Property ;
    rdfs:label 'Threshold Tier' ;
    rdfs:comment 'Tiered threshold level or bracket for this commitment (e.g., bronze, silver, gold) if the contract uses tiered volume commitments with different rates or benefits.' ;
    rdfs:domain ind:PricingVolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLaneScope rdf:type rdf:Property ;
    rdfs:label 'Trade Lane Scope' ;
    rdfs:comment 'Specific trade lane(s) or geographic scope to which this commitment applies (e.g., Asia-Europe, Transpacific, Domestic US). Null indicates all lanes.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between committed volume and actual volume to date (actual minus committed). Negative values indicate shortfall, positive indicate overachievement.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAuditId rdf:type rdf:Property ;
    rdfs:label 'Rate Audit Id' ;
    rdfs:comment 'Unique identifier for the rate audit record. Primary key.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRateEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rate Employee Id' ;
    rdfs:comment 'System identifier of the user who executed the rate change. Links to the user management system for accountability and audit trail.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByAuditRateAuditId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Audit Rate Audit Id' ;
    rdfs:comment 'Reference to the subsequent audit record that supersedes this change. Creates a chain of rate modifications for complete lineage tracking.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateAudit .

ind:approvedByUserName rdf:type rdf:Property ;
    rdfs:label 'Approved By User Name' ;
    rdfs:comment 'Full name of the user who approved the rate change. Human-readable identifier for audit and compliance reporting.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Timestamp' ;
    rdfs:comment 'Date and time when the rate change event was recorded in the audit trail. Represents the exact moment the modification was captured in the system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeEventType rdf:type rdf:Property ;
    rdfs:label 'Change Event Type' ;
    rdfs:comment 'Type of rate modification event being audited. Categorizes the nature of the pricing change for tracking and analysis purposes.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeMagnitude rdf:type rdf:Property ;
    rdfs:label 'Change Magnitude' ;
    rdfs:comment 'Numeric difference between new and previous values for quantitative fields. Calculated as new_value minus previous_value for amounts, rates, and percentages.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changePercentage rdf:type rdf:Property ;
    rdfs:label 'Change Percentage' ;
    rdfs:comment 'Percentage change from previous to new value. Calculated as ((new_value - previous_value) / previous_value) * 100 for rate increases or decreases.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Detailed explanation of why the rate change was made. Free-text field capturing business justification for audit and compliance purposes.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSource rdf:type rdf:Property ;
    rdfs:label 'Change Source' ;
    rdfs:comment 'The mechanism or channel through which the rate change was initiated. Distinguishes between manual updates, automated processes, and external system feeds.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Change Source System' ;
    rdfs:comment 'The name or identifier of the system that originated the rate change. References operational systems such as SAP TM, Oracle TMS, or pricing management platforms.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedByRole rdf:type rdf:Property ;
    rdfs:label 'Changed By Role' ;
    rdfs:comment 'The organizational role or job function of the user who made the change. Examples include Pricing Analyst, Revenue Manager, System Administrator.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedByUserName rdf:type rdf:Property ;
    rdfs:label 'Changed By User Name' ;
    rdfs:comment 'Full name of the user who executed the rate change. Human-readable identifier for audit reports and dispute resolution.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Entity Reference Code' ;
    rdfs:comment 'The unique identifier of the specific pricing entity that was changed. References the primary key of the modified rate card, tariff, surcharge, or contract rate record.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'The type of pricing entity that was modified. Identifies which pricing component was changed in the rate structure. [ENUM-REF-CANDIDATE: rate_card|tariff|surcharge_schedule|contract_rate|spot_quote|accessorial_charge|dim_weight_rule|fuel_index — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldLabel rdf:type rdf:Property ;
    rdfs:label 'Field Label' ;
    rdfs:comment 'Business-friendly label for the modified field. Human-readable description of what was changed for reporting and dispute resolution.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'The value of the field after the change was applied. Stored as string to accommodate various data types across different pricing entities.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousValue rdf:type rdf:Property ;
    rdfs:label 'Previous Value' ;
    rdfs:comment 'The value of the field before the change was applied. Stored as string to accommodate various data types across different pricing entities.' ;
    rdfs:domain ind:RateAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByRateCardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Card Id' ;
    rdfs:comment 'Identifier of the rate card that replaces this one, supporting version control and rate card lifecycle management. Null if this is the current version.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:accessorialChargesIncluded rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges Included' ;
    rdfs:comment 'Indicates whether common accessorial charges (e.g., liftgate, residential delivery, inside delivery, appointment) are included in the base rate or billed separately.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRateMaximum rdf:type rdf:Property ;
    rdfs:label 'Base Rate Maximum' ;
    rdfs:comment 'Maximum base freight rate per unit (as defined by rate_basis) applicable under this rate card. Used for ceiling pricing and rate cap enforcement.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRateMinimum rdf:type rdf:Property ;
    rdfs:label 'Base Rate Minimum' ;
    rdfs:comment 'Minimum base freight rate per unit (as defined by rate_basis) applicable under this rate card. Used for floor pricing and minimum charge calculations.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeType rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Type' ;
    rdfs:comment 'Type of fuel surcharge mechanism: BAF (Bunker Adjustment Factor for ocean), FSC (Fuel Surcharge for air/road), fixed_percentage (static percentage), index_linked (tied to fuel price index).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatSurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Surcharge Applicable' ;
    rdfs:comment 'Indicates whether a surcharge applies for shipments containing dangerous goods or hazardous materials under this rate card.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsDefault rdf:type rdf:Property ;
    rdfs:label 'Incoterms Default' ;
    rdfs:comment 'Default International Commercial Terms (Incoterms 2020) rule applied to shipments under this rate card, defining cost and risk allocation between buyer and seller (e.g., FOB, CIF, DDP, DAP, EXW). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date when this rate card was officially published or released to customers, sales teams, or operational systems.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateCardName rdf:type rdf:Property ;
    rdfs:label 'Rate Card Name' ;
    rdfs:comment 'Human-readable name of the rate card, typically describing the service type, trade lane, or customer segment (e.g., \'Asia-Europe Ocean FCL Q1 2024\', \'Express Air Domestic Standard\').' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Card Number' ;
    rdfs:comment 'Externally-known unique business identifier for the rate card, used in contracts, quotes, and billing references. Format: RC- followed by alphanumeric code.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Card Status' ;
    rdfs:comment 'Current lifecycle state of the rate card: draft (under construction), pending_approval (awaiting authorization), active (in use), suspended (temporarily inactive), expired (past validity), superseded (replaced by newer version), archived (historical record). [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|superseded|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardType rdf:type rdf:Property ;
    rdfs:label 'Rate Card Type' ;
    rdfs:comment 'Classification of the rate card by pricing model: published (standard public rates), contract (customer-specific negotiated rates), spot (one-time market rates), promotional (limited-time discount rates), seasonal (peak/off-peak rates).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightBreakStructure rdf:type rdf:Property ;
    rdfs:label 'Weight Break Structure' ;
    rdfs:comment 'Pricing structure model for weight-based rates: flat (single rate regardless of weight), tiered (discrete weight bands with fixed rates), banded (progressive discounts by weight range), continuous (formula-based).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLineId rdf:type rdf:Property ;
    rdfs:label 'Rate Line Id' ;
    rdfs:comment 'Unique identifier for the rate line item within the rate card structure. Primary key for the rate line entity.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allInRateFlag rdf:type rdf:Property ;
    rdfs:label 'All In Rate Flag' ;
    rdfs:comment 'Indicates whether this rate line represents an all-inclusive rate covering all charges (true) or a component rate requiring additional surcharges and fees (false).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityClass rdf:type rdf:Property ;
    rdfs:label 'Commodity Class' ;
    rdfs:comment 'Classification of goods type or freight class applicable to this rate line. May reference NMFC class codes, IATA commodity codes, or internal classification schemes.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Dim Weight Factor' ;
    rdfs:comment 'Dimensional weight divisor used to calculate chargeable weight from volume. Applied when dimensional weight exceeds actual weight for low-density shipments.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Pct' ;
    rdfs:comment 'Percentage fuel surcharge applied to the base rate. Reflects fluctuations in fuel costs and may be updated periodically based on fuel price indices.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Hazmat Surcharge Pct' ;
    rdfs:comment 'Percentage surcharge applied to the base rate for dangerous goods or hazardous materials shipments. Null if not applicable to this rate line.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential ordering of rate lines within the parent rate card. Used for display and processing order of tiered pricing structures.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatedRateFlag rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate Flag' ;
    rdfs:comment 'Indicates whether this rate line was individually negotiated with a specific customer (true) or represents a standard published tariff rate (false).' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakSeasonSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Peak Season Surcharge Pct' ;
    rdfs:comment 'Percentage surcharge applied during peak shipping seasons or high-demand periods. Null if not applicable to this rate line.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBasisDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Basis Description' ;
    rdfs:comment 'Detailed explanation of how the rate is calculated and applied. Provides context for complex pricing rules, tiered structures, or special conditions.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLineStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Line Status' ;
    rdfs:comment 'Current lifecycle status of the rate line. Indicates whether the rate is available for use in pricing calculations and quote generation.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotRateFlag rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Flag' ;
    rdfs:comment 'Indicates whether this rate line represents a spot market rate (true) subject to immediate market conditions or a contract rate (false) with longer-term stability.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Pct' ;
    rdfs:comment 'Percentage discount applied for high-volume shipments meeting the weight or volume break thresholds. Incentivizes larger shipment consolidation.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateRequestId rdf:type rdf:Property ;
    rdfs:label 'Rate Request Id' ;
    rdfs:comment 'Unique identifier for the rate request record. Primary key.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Rate Amount' ;
    rdfs:comment 'Final rate amount approved by the pricing authority. May differ from the requested rate based on cost analysis, margin requirements, and competitive positioning. Null if request is not yet approved.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Approved Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the approved rate amount. Typically matches the requested currency but may differ based on contract terms or multi-currency agreements.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Detailed explanation of the business rationale for the rate request, including competitive pressures, customer retention, market conditions, volume commitments, or strategic account considerations. Used by pricing analysts and approvers to evaluate the request.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBenchmarkRate rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark Rate' ;
    rdfs:comment 'Market rate or competitor rate used as a reference point for pricing decision. Confidential business intelligence used to assess competitiveness of the requested rate.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Shipment Count' ;
    rdfs:comment 'Projected number of shipments over the contract period or rate validity period. Used for volume commitment pricing and tiered rate structures.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume' ;
    rdfs:comment 'Estimated cubic volume of the shipment in the unit specified by volume_unit. Used for volumetric weight calculation and container/vehicle capacity planning.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedWeight rdf:type rdf:Property ;
    rdfs:label 'Estimated Weight' ;
    rdfs:comment 'Estimated gross weight of the shipment in the unit specified by weight_unit. Used for rate calculation, capacity planning, and dimensional weight (DIM weight) comparison.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Requested Effective Date' ;
    rdfs:comment 'Date from which the requestor wants the new or revised rate to become effective and applicable to shipments.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Requested Rate Amount' ;
    rdfs:comment 'Target rate amount proposed by the requestor for the specified service and trade lane. May be used as a negotiation starting point or benchmark for pricing approval.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Requested Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the requested rate amount. Must align with customer billing currency and contract terms.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Primary email address of the rate request submitter for communication regarding the request status, clarifications, and final rate decision.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the individual or organization submitting the rate request. For internal requests, this is the employee name; for external requests, this is the customer or partner contact name.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorPhone rdf:type rdf:Property ;
    rdfs:label 'Requestor Phone' ;
    rdfs:comment 'Contact phone number of the rate request submitter for urgent communications and clarifications during the review process.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorType rdf:type rdf:Property ;
    rdfs:label 'Requestor Type' ;
    rdfs:comment 'Classification of the party submitting the rate request: internal sales team, direct customer inquiry, operations team for capacity planning, carrier for backhaul rates, broker for spot market, or partner for alliance pricing.' ;
    rdfs:domain ind:RateRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateRuleId rdf:type rdf:Property ;
    rdfs:label 'Rate Rule Id' ;
    rdfs:comment 'Primary key for rate_rule' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentCurrency rdf:type rdf:Property ;
    rdfs:label 'Adjustment Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for flat amount adjustments. Null for percentage and multiplier adjustment types.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Method by which the rule modifies the base rate: flat amount (fixed currency value), percentage (of base rate), tiered (stepped based on volume/weight), or multiplier (factor applied to base).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Adjustment Value' ;
    rdfs:comment 'Numeric value defining the magnitude of the rate adjustment. Interpretation depends on adjustment_type: currency amount for flat, percentage for percentage, multiplier for multiplier.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableIncoterm rdf:type rdf:Property ;
    rdfs:label 'Applicable Incoterm' ;
    rdfs:comment 'Incoterms to which this rule applies, controlling charge allocation between shipper and consignee. Pipe-separated if multiple. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceMode rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Mode' ;
    rdfs:comment 'Transportation mode(s) to which this rule applies. Pipe-separated list if multiple. [ENUM-REF-CANDIDATE: air|ocean|road|rail|intermodal|express_parcel|LTL|FTL|FCL|LCL — promote to reference product]' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTradeLane rdf:type rdf:Property ;
    rdfs:label 'Applicable Trade Lane' ;
    rdfs:comment 'Geographic trade lane or route corridor to which this rule applies (e.g., \'Asia-Europe\', \'Transpacific Eastbound\', \'US Domestic\'). Null if rule is global.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityHsCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Hs Code' ;
    rdfs:comment 'Harmonized System tariff classification code for commodities to which this rule applies. Used for commodity-specific surcharges (e.g., hazardous materials, refrigerated cargo). Null if rule is commodity-agnostic.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundRuleFlag rdf:type rdf:Property ;
    rdfs:label 'Compound Rule Flag' ;
    rdfs:comment 'Indicates whether this rule can be combined with other rules (true) or is mutually exclusive (false). Controls rule stacking behavior in the rating engine.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerTier rdf:type rdf:Property ;
    rdfs:label 'Customer Tier' ;
    rdfs:comment 'Customer segmentation tier to which this rule applies. Used for tier-based discount rules. Null if rule applies to all customers.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRuleCode rdf:type rdf:Property ;
    rdfs:label 'External Rule Code' ;
    rdfs:comment 'Unique identifier for this pricing rule in the source operational system. Used for data lineage and reconciliation with SAP TM or Oracle TMS.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Threshold Value' ;
    rdfs:comment 'Upper bound value beyond which the rule no longer applies or transitions to next tier. Used for tiered pricing structures.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Threshold Value' ;
    rdfs:comment 'Lower bound value that must be met for the rule to apply. Used for volume discounts (minimum TEU, CBM, weight) or minimum charge thresholds.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityOrder rdf:type rdf:Property ;
    rdfs:label 'Priority Order' ;
    rdfs:comment 'Execution sequence number determining the order in which multiple applicable rules are evaluated and applied. Lower numbers execute first. Critical for cascading discount and surcharge logic.' ;
    rdfs:domain ind:RateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the pricing rule defining the category of rate adjustment logic applied. Determines which calculation engine module processes the rule in SAP TM.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'Base rate amount for the service level before surcharges and adjustments. Represents the starting price for the service.' ;
    rdfs:domain ind:ServiceLevelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargePercentage rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Percentage' ;
    rdfs:comment 'Percentage of base rate applied as fuel surcharge (e.g., 15.50 for 15.5%). Null if fuel surcharge is not applicable or calculated separately.' ;
    rdfs:domain ind:ServiceLevelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceIncluded rdf:type rdf:Property ;
    rdfs:label 'Insurance Included' ;
    rdfs:comment 'Indicates whether cargo insurance is included in the service level rate. True if insurance is included, False if insurance is optional or charged separately.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perCbmRate rdf:type rdf:Property ;
    rdfs:label 'Per Cbm Rate' ;
    rdfs:comment 'Rate charged per cubic meter of shipment volume. Used for volume-based pricing calculation.' ;
    rdfs:domain ind:ServiceLevelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perKgRate rdf:type rdf:Property ;
    rdfs:label 'Per Kg Rate' ;
    rdfs:comment 'Rate charged per kilogram of shipment weight. Used for weight-based pricing calculation.' ;
    rdfs:domain ind:ServiceLevelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saturdayDeliveryAvailable rdf:type rdf:Property ;
    rdfs:label 'Saturday Delivery Available' ;
    rdfs:comment 'Indicates whether Saturday delivery is available for this service level. True if available, False otherwise.' ;
    rdfs:domain ind:ServiceLevelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelName rdf:type rdf:Property ;
    rdfs:label 'Service Level Name' ;
    rdfs:comment 'Human-readable name of the service level (e.g., Next Day Air, 2-Day Express, Economy Ground, Priority Overnight, Deferred Delivery).' ;
    rdfs:domain ind:ServiceLevelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCommitmentType rdf:type rdf:Property ;
    rdfs:label 'Sla Commitment Type' ;
    rdfs:comment 'Type of SLA commitment for this service level: guaranteed (money-back guarantee), target (best effort with tracking), best_effort (no commitment).' ;
    rdfs:domain ind:ServiceLevelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Sla Penalty Rate' ;
    rdfs:comment 'Penalty amount or refund rate applied when SLA commitment is not met. Null if no penalty applies.' ;
    rdfs:domain ind:ServiceLevelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaPenaltyType rdf:type rdf:Property ;
    rdfs:label 'Sla Penalty Type' ;
    rdfs:comment 'Type of penalty applied for SLA breach: full_refund (100% refund), partial_refund (percentage refund), credit (account credit), none (no penalty).' ;
    rdfs:domain ind:ServiceLevelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sundayDeliveryAvailable rdf:type rdf:Property ;
    rdfs:label 'Sunday Delivery Available' ;
    rdfs:comment 'Indicates whether Sunday delivery is available for this service level. True if available, False otherwise.' ;
    rdfs:domain ind:ServiceLevelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAgentId rdf:type rdf:Property ;
    rdfs:label 'Issuing Agent Id' ;
    rdfs:comment 'Identifier of the sales agent, pricing analyst, or customer service representative who prepared and issued the spot quote. Used for performance tracking and commission calculation.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:baseFreightRate rdf:type rdf:Property ;
    rdfs:label 'Base Freight Rate' ;
    rdfs:comment 'Core transportation charge per unit (per kg, per TEU, per shipment) before surcharges and accessorial fees. Foundation of the all-in quoted rate.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsClearanceFee rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Fee' ;
    rdfs:comment 'Fee for customs brokerage services including declaration preparation, duty calculation, and regulatory filings (AMS, ISF). Applicable for cross-border shipments.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationFee rdf:type rdf:Property ;
    rdfs:label 'Documentation Fee' ;
    rdfs:comment 'Administrative charge for preparation and processing of shipping documents including AWB (Air Waybill), BOL (Bill of Lading), commercial invoice, packing list, and certificate of origin.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTransitDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Days' ;
    rdfs:comment 'Expected number of calendar days from origin pickup to destination delivery. Used for customer planning and SLA (Service Level Agreement) commitments.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insurancePremium rdf:type rdf:Property ;
    rdfs:label 'Insurance Premium' ;
    rdfs:comment 'Optional cargo insurance premium to cover loss or damage during transit. Typically calculated as a percentage of declared cargo value.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupDate rdf:type rdf:Property ;
    rdfs:label 'Pickup Date' ;
    rdfs:comment 'Requested or scheduled date for cargo pickup at origin. Used for capacity planning and operational scheduling.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteIssuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quote Issued Timestamp' ;
    rdfs:comment 'Date and time when the spot quote was formally issued to the customer. Marks the start of the validity period and SLA (Service Level Agreement) measurement for quote response time.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quoteRequestDate rdf:type rdf:Property ;
    rdfs:label 'Quote Request Date' ;
    rdfs:comment 'Date when the customer or prospect submitted the request for quotation. Used to track response time and quote aging.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteSource rdf:type rdf:Property ;
    rdfs:label 'Quote Source' ;
    rdfs:comment 'Channel or system through which the quote request was received. Used for channel effectiveness analysis and digital transformation tracking.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Quote Valid From Date' ;
    rdfs:comment 'Start date of the quote validity period. The quoted rates are guaranteed from this date.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteValidUntilDate rdf:type rdf:Property ;
    rdfs:label 'Quote Valid Until Date' ;
    rdfs:comment 'Expiration date of the quote validity period. After this date, the quoted rates are no longer guaranteed and the quote status typically transitions to expired.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Sales Office Code' ;
    rdfs:comment 'Code identifying the sales office or branch that issued the quote. Used for regional performance reporting and revenue allocation.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitySurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Security Surcharge Amount' ;
    rdfs:comment 'Charge to cover security screening, compliance programs (C-TPAT, AEO), and regulatory security requirements. Common in air and ocean freight.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalHandlingCharge rdf:type rdf:Property ;
    rdfs:label 'Terminal Handling Charge' ;
    rdfs:comment 'Fee for cargo handling at the origin or destination terminal, including loading, unloading, and container yard operations. Common in ocean freight.' ;
    rdfs:domain ind:SpotQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spotQuoteLineId rdf:type rdf:Property ;
    rdfs:label 'Spot Quote Line Id' ;
    rdfs:comment 'Unique identifier for the spot quote line item. Primary key.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySpotEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Spot Employee Id' ;
    rdfs:comment 'Identifier of the user or system that created this spot quote line record. Supports audit trail and accountability.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:costAllocationParty rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Party' ;
    rdfs:comment 'Party responsible for paying this charge as per the Incoterm and contract terms. Identifies whether the shipper, consignee, carrier, a third party, or shared responsibility applies to this charge line.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includedInAllInRateFlag rdf:type rdf:Property ;
    rdfs:label 'Included In All In Rate Flag' ;
    rdfs:comment 'Boolean flag indicating whether this charge is included in the all-in quoted rate (True) or quoted separately as an additional charge (False). Enables transparency in pricing structure and supports itemized billing reconciliation.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rate Effective Date' ;
    rdfs:comment 'Date from which the rate for this charge line is effective. Supports rate versioning and ensures correct pricing based on quote date.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rate Expiry Date' ;
    rdfs:comment 'Date until which the rate for this charge line is valid. After this date, the rate may change or require re-negotiation. Null if the rate has no expiry.' ;
    rdfs:domain ind:SpotQuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceProviderName rdf:type rdf:Property ;
    rdfs:label 'Service Provider Name' ;
    rdfs:comment 'Name of the service provider or vendor associated with this charge line. Provides human-readable identification of the party delivering the service.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeId rdf:type rdf:Property ;
    rdfs:label 'Surcharge Id' ;
    rdfs:comment 'Primary key for surcharge' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableServiceType rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Type' ;
    rdfs:comment 'Service type(s) to which this surcharge applies. Express includes time-definite delivery; standard includes regular service; economy includes deferred service; freight_forwarding includes forwarding services; contract_logistics includes warehousing and distribution; all indicates universal applicability.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTransportMode rdf:type rdf:Property ;
    rdfs:label 'Applicable Transport Mode' ;
    rdfs:comment 'Transport mode(s) to which this surcharge applies. Air includes air freight; ocean includes FCL/LCL; road includes FTL/LTL; rail includes intermodal rail; multimodal includes combined transport; all indicates surcharge applies across all modes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToDimWeightFlag rdf:type rdf:Property ;
    rdfs:label 'Applies To Dim Weight Flag' ;
    rdfs:comment 'Indicates whether this surcharge is calculated based on dimensional weight (true) or actual weight (false). Relevant for air freight and express parcel surcharges where volumetric weight may exceed actual weight.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToHazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Applies To Hazmat Flag' ;
    rdfs:comment 'Indicates whether this surcharge applies specifically to hazardous materials shipments (true) or to all shipments (false). Hazmat surcharges cover additional handling, documentation, and compliance costs.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToOversizeFlag rdf:type rdf:Property ;
    rdfs:label 'Applies To Oversize Flag' ;
    rdfs:comment 'Indicates whether this surcharge applies to oversize or out-of-gauge shipments (true) or to standard shipments (false). Oversize surcharges cover special handling and equipment requirements.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToTemperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Applies To Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this surcharge applies to temperature-controlled (reefer) shipments (true) or to all shipments (false). Temperature-controlled surcharges cover refrigeration equipment and monitoring costs.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationFormula rdf:type rdf:Property ;
    rdfs:label 'Calculation Formula' ;
    rdfs:comment 'Custom formula or algorithm used when calculation_method is formula_based. May reference fuel index, base freight, weight, volume, or other variables. Null for standard calculation methods.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeAllocationParty rdf:type rdf:Property ;
    rdfs:label 'Charge Allocation Party' ;
    rdfs:comment 'Party responsible for paying the surcharge. Shipper indicates origin party pays; consignee indicates destination party pays; carrier indicates carrier absorbs; third_party indicates a third party (e.g., freight forwarder) pays; negotiable indicates allocation is determined per contract or shipment.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Compounding Allowed Flag' ;
    rdfs:comment 'Indicates whether this surcharge can be compounded with other surcharges (true) or is mutually exclusive (false). Compounding affects total charge calculation when multiple surcharges apply to a single shipment.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flatRateAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Rate Amount' ;
    rdfs:comment 'Fixed surcharge amount when calculation_method is flat_rate. Expressed in the currency specified by currency_code. Null for non-flat-rate surcharges.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelIndexLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Linked Flag' ;
    rdfs:comment 'Indicates whether this surcharge is dynamically linked to a fuel price index (true) or is a static rate (false). Applicable primarily to BAF (Bunker Adjustment Factor) surcharges.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelIndexSource rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Source' ;
    rdfs:comment 'Name of the fuel price index or benchmark used for dynamic calculation (e.g., Platts Brent Crude, US DOE Diesel Price Index, Singapore Bunker Price). Null if fuel_index_linked_flag is false.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBodyReference rdf:type rdf:Property ;
    rdfs:label 'Governing Body Reference' ;
    rdfs:comment 'Reference to the regulatory body, industry association, or standard that governs or mandates this surcharge (e.g., IATA Resolution 600a, FMC Docket Number, IMO MARPOL Annex VI for environmental surcharges). Null for carrier-specific surcharges.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsApplicability rdf:type rdf:Property ;
    rdfs:label 'Incoterms Applicability' ;
    rdfs:comment 'Incoterms rule(s) under which this surcharge applies. Determines which party (shipper or consignee) bears the surcharge cost. EXW=Ex Works, FCA=Free Carrier, CPT=Carriage Paid To, CIP=Carriage and Insurance Paid To, DAP=Delivered at Place, DPU=Delivered at Place Unloaded, DDP=Delivered Duty Paid, FAS=Free Alongside Ship, FOB=Free on Board, CFR=Cost and Freight, CIF=Cost Insurance and Freight. All indicates surcharge applies regardless of Incoterms. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF|all — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perUnitRate rdf:type rdf:Property ;
    rdfs:label 'Per Unit Rate' ;
    rdfs:comment 'Rate applied per unit of measure when calculation_method is per_unit. Unit of measure specified in unit_of_measure field. Null for non-per-unit surcharges.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rate' ;
    rdfs:comment 'Percentage rate applied to base freight when calculation_method is percentage. Expressed as a decimal (e.g., 15.00 for 15%). Null for non-percentage surcharges.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether this surcharge is mandated by a regulatory body (true) or is a carrier-discretionary surcharge (false). Regulatory surcharges include security fees, customs processing fees, environmental levies.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surchargeCategory rdf:type rdf:Property ;
    rdfs:label 'Surcharge Category' ;
    rdfs:comment 'High-level classification of the surcharge type. Fuel includes BAF; rate_adjustment includes GRI; terminal includes THC; seasonal includes peak season; security includes security fees; risk includes war risk and insurance; regulatory includes customs and compliance fees; operational includes handling and storage; accessorial includes special services. [ENUM-REF-CANDIDATE: fuel|rate_adjustment|terminal|seasonal|security|risk|regulatory|operational|accessorial — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeCode rdf:type rdf:Property ;
    rdfs:label 'Surcharge Code' ;
    rdfs:comment 'Unique business identifier for the surcharge type (e.g., BAF, GRI, PSS, SEC, THC, WAR). Used across rate cards, spot quotes, and billing systems.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeDescription rdf:type rdf:Property ;
    rdfs:label 'Surcharge Description' ;
    rdfs:comment 'Detailed business description of the surcharge, including purpose, rationale, and any special conditions or exclusions. Used for customer communication and internal documentation.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeName rdf:type rdf:Property ;
    rdfs:label 'Surcharge Name' ;
    rdfs:comment 'Full descriptive name of the surcharge (e.g., Bunker Adjustment Factor, General Rate Increase, Peak Season Surcharge, Security Surcharge, Terminal Handling Charge, War Risk Surcharge).' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeStatus rdf:type rdf:Property ;
    rdfs:label 'Surcharge Status' ;
    rdfs:comment 'Current lifecycle status of the surcharge definition. Active indicates currently in use; inactive indicates not in use; pending indicates scheduled for future activation; expired indicates past effective_end_date; suspended indicates temporarily disabled.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRateStructure rdf:type rdf:Property ;
    rdfs:label 'Base Rate Structure' ;
    rdfs:comment 'Methodology used to calculate base freight charges (e.g., flat rate per shipment, weight-based per kg, distance-based per km, zone-to-zone matrix, dimensional weight). Defines the pricing model foundation.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityRestrictions rdf:type rdf:Property ;
    rdfs:label 'Commodity Restrictions' ;
    rdfs:comment 'Description of any commodity-specific restrictions or exclusions under this tariff (e.g., \'No perishables\', \'Hazmat Class 1 excluded\', \'Electronics only\'). Nullable if no restrictions apply.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceUnit rdf:type rdf:Property ;
    rdfs:label 'Distance Unit' ;
    rdfs:comment 'Standard unit of measure for distance used in distance-based tariffs (e.g., kilometers, miles, nautical miles). Nullable if tariff is not distance-based.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle status of the tariff. Published tariffs are active and enforceable; filed tariffs are submitted to regulatory bodies; approved tariffs have received regulatory clearance. [ENUM-REF-CANDIDATE: draft|published|filed|approved|suspended|withdrawn|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProductType rdf:type rdf:Property ;
    rdfs:label 'Service Product Type' ;
    rdfs:comment 'Service level or product category this tariff applies to (e.g., express parcel, standard freight, economy ocean). Defines speed, handling, and service commitments. [ENUM-REF-CANDIDATE: express|standard|economy|freight|ltl|ftl|fcl|lcl — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffDescription rdf:type rdf:Property ;
    rdfs:label 'Tariff Description' ;
    rdfs:comment 'Detailed textual description of the tariff scope, coverage, special terms, and conditions. Provides context for tariff application and interpretation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffNumber rdf:type rdf:Property ;
    rdfs:label 'Tariff Number' ;
    rdfs:comment 'Externally published tariff identification number used for regulatory filing and customer reference. Unique business identifier for the tariff schedule.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Id' ;
    rdfs:comment 'Unique identifier for the blanket purchase order. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlanketOrder .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Foreign key linking to procurement.rfq. Business justification: Blanket orders may originate from RFQ sourcing events. The blanket_order table has rfq_reference_number (STRING) which should be replaced with a formal FK to rfq. This establishes the sourcing lineage' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:blanketOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Status' ;
    rdfs:comment 'Current lifecycle state of the blanket order: draft (being prepared), active (available for releases), suspended (temporarily inactive), expired (validity period ended), closed (completed normally), cancelled (terminated early).' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Classification code identifying the spend category or commodity group covered by this blanket order (e.g., fuel, courier services, warehouse consumables, fleet parts).' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'International Commercial Terms defining delivery responsibilities and risk transfer (e.g., FOB, CIF, DDP, DAP, EXW).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Material or service group code for classification and reporting purposes.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumReleaseValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Release Value' ;
    rdfs:comment 'Maximum monetary value allowed for each individual release order against this blanket order. Nullable if no maximum applies.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumReleaseValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Release Value' ;
    rdfs:comment 'Minimum monetary value required for each individual release order against this blanket order. Nullable if no minimum applies.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingCondition rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition' ;
    rdfs:comment 'Pricing structure negotiated in the blanket order: fixed (locked price), variable (market-based), index-linked (tied to commodity index), tiered (volume-based discounts).' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Code identifying the buyer or procurement team responsible for managing this blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Code identifying the organizational unit responsible for this blanket order (e.g., regional procurement center, business unit).' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRequirements rdf:type rdf:Property ;
    rdfs:label 'Quality Requirements' ;
    rdfs:comment 'Quality standards, certifications, or specifications that the supplier must meet for deliveries under this blanket order (e.g., ISO 9001, industry-specific standards).' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseMechanism rdf:type rdf:Property ;
    rdfs:label 'Release Mechanism' ;
    rdfs:comment 'Method by which purchase order releases are generated: manual (buyer-initiated), automatic (system-triggered by inventory levels), scheduled (periodic releases), demand-triggered (consumption-based).' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingValue rdf:type rdf:Property ;
    rdfs:label 'Remaining Value' ;
    rdfs:comment 'Available balance remaining on the blanket order, calculated as total committed value minus total released value.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingPoint rdf:type rdf:Property ;
    rdfs:label 'Shipping Point' ;
    rdfs:comment 'Default origin location or supplier facility from which goods will be shipped for releases under this blanket order.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Sustainability Criteria' ;
    rdfs:comment 'Environmental, social, and governance (ESG) requirements or sustainability commitments included in the blanket order (e.g., carbon footprint targets, ethical sourcing).' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommittedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Committed Quantity' ;
    rdfs:comment 'Maximum total quantity committed under this blanket order for quantity-based agreements. Nullable for value-based agreements.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommittedValue rdf:type rdf:Property ;
    rdfs:label 'Total Committed Value' ;
    rdfs:comment 'Maximum total spend amount committed under this blanket order. Represents the upper financial limit for all releases combined.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReleasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Released Quantity' ;
    rdfs:comment 'Cumulative quantity of all releases issued against this blanket order to date.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReleasedValue rdf:type rdf:Property ;
    rdfs:label 'Total Released Value' ;
    rdfs:comment 'Cumulative value of all purchase order releases issued against this blanket order to date.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Warranty or guarantee terms negotiated with the supplier for goods or services covered by this blanket order.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Unique identifier for the goods receipt record. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:facilityInspectionId rdf:type rdf:Property ;
    rdfs:label 'Facility Inspection Id' ;
    rdfs:comment 'Foreign key linking to safety.facility_inspection. Business justification: Goods receipts of hazardous materials trigger mandatory facility inspections. Links receipt to inspection record for compliance verification, storage authorization, and regulatory documentation in war' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FacilityInspection .

ind:inboundReceiptId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Id' ;
    rdfs:comment 'Foreign key linking to warehouse.inbound_receipt. Business justification: Three-way matching (PO-GR-Invoice) requires linking procurement\'s goods receipt to warehouse\'s physical inbound receipt. Critical for invoice verification, discrepancy resolution, and financial reconc' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceipt .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Reference to the quality inspector or employee who performed the inspection and acceptance decision, if different from the receiver.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Reference to the material, product, or service master record being received. Links to the item catalog for specifications and inventory management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:primaryGoodsReceiverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Receiver Employee Id' ;
    rdfs:comment 'Reference to the employee who physically received and recorded the goods receipt, responsible for verifying quantity and condition.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:receivingLocationId rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Id' ;
    rdfs:comment 'Reference to the warehouse, depot, hub, or facility where the goods were physically received.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'The quantity of goods that passed inspection and were accepted into inventory or for use. Used for three-way match with purchase order and invoice.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Manufacturer or supplier batch/lot number for traceability, quality control, and recall management. Critical for regulated materials and perishables.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Supplier-provided delivery note, packing slip, or dispatch advice number accompanying the shipment. Used for cross-referencing and dispute resolution.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The date on which the goods were originally scheduled to arrive per the purchase order, used to measure supplier on-time delivery performance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Number' ;
    rdfs:comment 'Business-facing unique identifier for the goods receipt, typically system-generated and used in communications with suppliers and internal stakeholders.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchToleranceExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Match Tolerance Exceeded Flag' ;
    rdfs:comment 'Indicates whether the variance between ordered and received quantity exceeds the acceptable tolerance threshold defined in procurement policy, triggering manual review.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Cleared Flag' ;
    rdfs:comment 'Indicates whether the supplier invoice associated with this goods receipt has been paid, completing the procure-to-pay cycle.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt: draft (not yet finalized), pending inspection (awaiting quality check), accepted (fully approved), partially accepted (some items accepted), rejected (failed inspection), or cancelled.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the goods receipt transaction: standard purchase, return to supplier, inter-location transfer, consignment receipt, or service acknowledgment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptValueAmount rdf:type rdf:Property ;
    rdfs:label 'Receipt Value Amount' ;
    rdfs:comment 'Total monetary value of the accepted goods based on purchase order price, used for accrual accounting and inventory valuation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The total quantity of goods physically received, regardless of acceptance status. May differ from ordered quantity due to over-shipment, under-shipment, or partial delivery.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingDock rdf:type rdf:Property ;
    rdfs:label 'Receiving Dock' ;
    rdfs:comment 'Specific dock, bay, or receiving area within the location where the goods were unloaded and inspected.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'The quantity of goods that failed inspection and were rejected, to be returned to supplier or disposed of per quality procedures.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionNotes rdf:type rdf:Property ;
    rdfs:label 'Rejection Notes' ;
    rdfs:comment 'Free-text detailed explanation of the rejection, including specific defects observed, photos taken, and actions required from the supplier.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'RMA number issued by the supplier authorizing the return of rejected goods, used to track the reverse logistics process and credit issuance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match process comparing purchase order, goods receipt, and supplier invoice: matched (all align within tolerance), quantity variance (receipt quantity differs), price variance (invoice price differs), not matched (significant discrepancies), or pending (invoice not yet received).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Id' ;
    rdfs:comment 'Reference to the warehouse, facility, or site where the goods should be delivered or the service performed. Links to the location master.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:itemId rdf:type rdf:Property ;
    rdfs:label 'Item Id' ;
    rdfs:comment 'Reference to the master item or material being procured. Links to the product/service catalog entry.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Item .

ind:primaryPoEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Po Employee Id' ;
    rdfs:comment 'Reference to the procurement professional responsible for managing this line item. Used for workload distribution and performance tracking.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Reference to the originating purchase requisition line that triggered this PO line. Provides traceability from demand to procurement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:requesterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requester Employee Id' ;
    rdfs:comment 'Reference to the employee or business unit that requested this item. Used for chargeback and spend analysis by department.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to warehouse.sku. Business justification: PO lines must reference warehouse SKU master for receipt validation, inventory planning, and putaway routing. Essential for matching ordered items to warehouse inventory records during receiving and q' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'Classification of the item into a procurement commodity category for spend analysis and sourcing strategy. Examples include Fleet Vehicles, Warehouse Equipment, IT Hardware, Professional Services, Fuel, Packaging Materials.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'The cumulative quantity that has been invoiced by the supplier for this line item. Used for invoice matching and payment processing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCapitalExpenditure rdf:type rdf:Property ;
    rdfs:label 'Is Capital Expenditure' ;
    rdfs:comment 'Flag indicating whether this line item represents a capital expenditure (CAPEX) rather than an operating expenditure (OPEX). Determines accounting treatment and approval workflow.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isServices rdf:type rdf:Property ;
    rdfs:label 'Is Services' ;
    rdfs:comment 'Flag indicating whether this line item represents services rather than goods. Affects receipt processing and invoice matching rules.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineNotes rdf:type rdf:Property ;
    rdfs:label 'Line Notes' ;
    rdfs:comment 'Free-text notes or special instructions specific to this line item. May include delivery instructions, quality requirements, or handling notes.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'The total monetary value for this line item, calculated as ordered quantity multiplied by unit price, before taxes and adjustments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierPartNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Part Number' ;
    rdfs:comment 'The suppliers own part number or SKU for the item being procured. Used for supplier catalog matching and order communication.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'The project work breakdown structure element for capital projects or project-based procurement. Used for project cost tracking and CAPEX management.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementApprovalWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Procurement Approval Workflow Id' ;
    rdfs:comment 'Unique identifier for the procurement approval workflow record. Primary key.' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalRuleId rdf:type rdf:Property ;
    rdfs:label 'Approval Rule Id' ;
    rdfs:comment 'Identifier of the approval rule or policy that determined this approval routing (e.g., rule based on amount, category, supplier risk, location).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovalRule .

ind:primaryProcurementDelegatedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Procurement Delegated To Employee Id' ;
    rdfs:comment 'Unique identifier of the employee to whom this approval step was delegated, if applicable.' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'System session identifier for the approval transaction, used for audit trail and troubleshooting.' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovalSession .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Hierarchical level or functional role required for this approval step (manager, director, VP, CFO, procurement head, legal, compliance). [ENUM-REF-CANDIDATE: manager|director|vp|svp|cfo|ceo|procurement_head|legal|compliance — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalMethod rdf:type rdf:Property ;
    rdfs:label 'Approval Method' ;
    rdfs:comment 'Method or channel through which the approval action was submitted (web portal, email, mobile app, API integration, system auto-approval).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRuleName rdf:type rdf:Property ;
    rdfs:label 'Approval Rule Name' ;
    rdfs:comment 'Name or description of the approval rule that triggered this workflow step.' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStepSequence rdf:type rdf:Property ;
    rdfs:label 'Approval Step Sequence' ;
    rdfs:comment 'Sequential order of this approval step in the overall approval routing chain (1 = first approver, 2 = second approver, etc.).' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Amount' ;
    rdfs:comment 'Monetary threshold amount that triggered this approval level (e.g., manager approves up to $10,000, director approves $10,001-$50,000).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalThresholdCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the approval threshold amount.' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverEmail rdf:type rdf:Property ;
    rdfs:label 'Approver Email' ;
    rdfs:comment 'Email address of the approver for notification and audit trail purposes.' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'Business role or job title of the approver assigned to this step (e.g., Procurement Manager, Finance Director, Legal Counsel).' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegatedToName rdf:type rdf:Property ;
    rdfs:label 'Delegated To Name' ;
    rdfs:comment 'Full name of the employee to whom approval was delegated.' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentAmount rdf:type rdf:Property ;
    rdfs:label 'Document Amount' ;
    rdfs:comment 'Total monetary value of the document being approved (e.g., PO total, invoice amount, contract value).' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Document Reference Code' ;
    rdfs:comment 'Reference identifier of the procurement document being approved (e.g., PO number, requisition number, invoice number, contract ID).' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToName rdf:type rdf:Property ;
    rdfs:label 'Escalated To Name' ;
    rdfs:comment 'Full name of the higher-authority employee to whom approval was escalated.' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatoryApproval rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Approval' ;
    rdfs:comment 'Indicates whether this approval step is mandatory (true) or optional/advisory (false).' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isParallelApproval rdf:type rdf:Property ;
    rdfs:label 'Is Parallel Approval' ;
    rdfs:comment 'Indicates whether this approval step runs in parallel with other steps (true) or sequentially (false).' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'Procurement category or commodity classification of the document being approved (e.g., fleet services, warehouse equipment, IT hardware, professional services).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Count' ;
    rdfs:comment 'Number of reminder notifications sent to the approver for this pending approval step.' ;
    rdfs:domain ind:ProcurementApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerPositionId rdf:type rdf:Property ;
    rdfs:label 'Owner Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Contracts owned by positions (not just employees) for succession planning, role-based contract ownership, position-level spend authority tracking. Critical for contract continuity when employees chang' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:procurementContractEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Procurement Contract Employee Id' ;
    rdfs:comment 'Identifier of the internal employee or buyer responsible for managing and administering this contract.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Site Id' ;
    rdfs:comment 'Identifier of the specific supplier site or location associated with this contract for delivery or service provision.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level indicating the sensitivity and confidentiality of the contract information.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the procurement contract, used for reference in communications and documentation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the procurement contract indicating its operational state. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the procurement contract indicating the nature of the agreement (e.g., master supply agreement, service level agreement, carrier contract, maintenance contract).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Value' ;
    rdfs:comment 'Maximum monetary value allowed for a single purchase order under this contract.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum monetary value required for each purchase order under this contract.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementContractCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Contract Category' ;
    rdfs:comment 'High-level procurement category or commodity group to which this contract belongs (e.g., transportation services, IT equipment, facilities maintenance).' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDeliveryDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Days' ;
    rdfs:comment 'Target number of days for delivery as defined in the service level agreement within the contract.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Detailed terms and conditions under which the contract may be terminated by either party.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Descriptive title or name of the procurement contract summarizing its purpose.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total monetary value of the procurement contract over its entire term, representing the maximum committed spend.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Procurement Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the procurement invoice line item. Primary key for this entity.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Id' ;
    rdfs:comment 'Reference to the parent procurement invoice header. Links this line item to its parent invoice document.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierInvoice .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Classification of the invoiced item type. Distinguishes between goods, services, freight, fuel, maintenance, capital equipment, software, and consulting services. [ENUM-REF-CANDIDATE: goods|services|freight|fuel|maintenance|capital_equipment|software|consulting — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed textual description of the goods or services invoiced on this line. May include specifications, model numbers, or service details.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Internal material or service master code. Links to the organization\'s master data catalog for goods or services.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netLineAmount rdf:type rdf:Property ;
    rdfs:label 'Net Line Amount' ;
    rdfs:comment 'Net amount for this invoice line after discounts and taxes. Represents the final payable amount for this line item.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'Difference between invoiced unit price and PO unit price multiplied by invoiced quantity. Positive values indicate invoice price exceeds PO price.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Project or work order code for capital expenditure (CAPEX) or project-specific expense tracking. Used for project accounting and cost allocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between invoiced quantity and goods receipt quantity. Positive values indicate invoice quantity exceeds received quantity.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'End date of the service period for this invoice line. Used for accrual accounting and service period reconciliation.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Start date of the service period for this invoice line. Applicable for recurring services, subscriptions, or time-based billing.' ;
    rdfs:domain ind:ProcurementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percent' ;
    rdfs:comment 'Tax rate percentage applied to this line item. Used for tax calculation and compliance reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxCode rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Code' ;
    rdfs:comment 'Tax code for withholding tax calculation. Determines the applicable withholding tax rate and reporting requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundFreightOrderId rdf:type rdf:Property ;
    rdfs:label 'Inbound Freight Order Id' ;
    rdfs:comment 'Foreign key linking to freight.freight_order. Business justification: Purchase orders for physical goods trigger inbound freight orders. Tracking this link enables freight cost accrual to inventory cost, delivery performance monitoring against PO required dates, and fre' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:issuingLocationId rdf:type rdf:Property ;
    rdfs:label 'Issuing Location Id' ;
    rdfs:comment 'Reference to the facility, warehouse, or office location issuing the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:primaryPurchaseCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Company Code Id' ;
    rdfs:comment 'Reference to the internal business entity (legal entity, subsidiary, operating company) issuing this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:primaryPurchaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Employee Id' ;
    rdfs:comment 'Reference to the procurement professional or employee who created and manages this purchase order.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shipToLocationId rdf:type rdf:Property ;
    rdfs:label 'Ship To Location Id' ;
    rdfs:comment 'Reference to the destination location where goods or services should be delivered.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:acknowledgementReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Received Timestamp' ;
    rdfs:comment 'Date and time when the supplier acknowledged receipt and acceptance of the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the purchase order was cancelled, if applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expenditureType rdf:type rdf:Property ;
    rdfs:label 'Expenditure Type' ;
    rdfs:comment 'Classification of purchase order as Capital Expenditure (CAPEX) for long-term assets or Operating Expenditure (OPEX) for operational costs.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerm rdf:type rdf:Property ;
    rdfs:label 'Freight Term' ;
    rdfs:comment 'Freight payment responsibility: prepaid (supplier pays), collect (buyer pays), third-party (designated carrier), FOB origin, FOB destination.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the purchase order was created and issued. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known unique purchase order number issued to supplier. Business identifier for procurement transactions.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the procurement workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|sent|acknowledged|partially_received|fully_received|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of purchase order type: standard (one-time purchase), blanket (recurring purchases against agreement), planned (scheduled delivery), contract-release (release against master contract), spot (ad-hoc), emergency (urgent procurement).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentToSupplierTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent To Supplier Timestamp' ;
    rdfs:comment 'Date and time when the purchase order was transmitted to the supplier via EDI, email, or portal.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Preferred or required shipping method for delivery (e.g., air freight, ocean freight, ground, courier).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Requisitions tied to positions for budget authority, approval routing by role, position-based spending limits. Essential for role-level requisition analytics, position-specific procurement authority e' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:preferredSupplierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Id' ;
    rdfs:comment 'Identifier of the supplier preferred by the requestor for fulfilling this requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:quaternaryPurchaseLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Purchase Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who last modified the purchase requisition record.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requestor Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPurchaseFinalApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Purchase Final Approver Employee Id' ;
    rdfs:comment 'Identifier of the employee who provided the final approval for the requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Check Status' ;
    rdfs:comment 'Result of the budget availability check performed against the cost center and GL account at requisition submission.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Budget Check Timestamp' ;
    rdfs:comment 'Date and time when the budget availability check was performed.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionOutcome rdf:type rdf:Property ;
    rdfs:label 'Conversion Outcome' ;
    rdfs:comment 'Outcome of the requisition after approval, indicating whether it was converted to a purchase order, routed to a sourcing event, or cancelled.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Amount' ;
    rdfs:comment 'Total estimated cost of the requisition, calculated as quantity requested multiplied by estimated unit price.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit of the item or service being requisitioned, used for budget validation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business rationale and justification provided by the requestor for the purchase requisition.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Quantity of the item or service being requisitioned.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'Date and time when the requisition was rejected by an approver.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requestor needs the goods or services to be delivered.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business-facing unique identifier for the purchase requisition, typically system-generated and used in communications and approvals.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the approval and procurement workflow. [ENUM-REF-CANDIDATE: draft|submitted|pending_approval|approved|rejected|cancelled|converted_to_po — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the purchase requisition based on the nature of goods or services being requested.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Rate Agreement Id' ;
    rdfs:comment 'Primary key for rate_agreement' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatorPositionId rdf:type rdf:Property ;
    rdfs:label 'Negotiator Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Carrier rate agreements negotiated by positions (Procurement Manager, Logistics Director) for position-level authority tracking, role-based rate approval workflows. Essential for freight rate negotiat' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:fuelSurchargeValue rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Value' ;
    rdfs:comment 'Numeric value of the fuel surcharge: fixed amount or percentage, depending on fuel_surcharge_type.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:griClause rdf:type rdf:Property ;
    rdfs:label 'Gri Clause' ;
    rdfs:comment 'Contractual terms governing General Rate Increase (GRI) adjustments: frequency, notice period, cap percentage, and approval process.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneDescription rdf:type rdf:Property ;
    rdfs:label 'Lane Description' ;
    rdfs:comment 'Human-readable description of the origin-destination lane covered by this rate agreement (e.g., \'Shanghai to Los Angeles - West Coast Express\').' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Rate Review Date' ;
    rdfs:comment 'Date of the most recent rate review or adjustment under this agreement.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Rate Review Date' ;
    rdfs:comment 'Scheduled date for the next rate review or renegotiation under this agreement.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the rate agreement: draft (under negotiation), pending approval (awaiting sign-off), active (in force), suspended (temporarily paused), expired (validity ended), terminated (cancelled before expiry).' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Rate Review Frequency' ;
    rdfs:comment 'Scheduled frequency for reviewing and potentially adjusting rates under this agreement: monthly, quarterly, semi-annually, annually, or none (fixed for term).' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Period' ;
    rdfs:comment 'Time period over which the volume commitment must be met: monthly, quarterly, annually, or over the full contract term.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Quantity' ;
    rdfs:comment 'Minimum volume (weight, TEUs, shipments) the buyer commits to ship under this agreement to qualify for the negotiated rates.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Awarded Supplier Id' ;
    rdfs:comment 'Identifier of the supplier who was awarded the business as a result of this RFQ. Null if RFQ is not yet awarded or was cancelled.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:issuingOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Issuing Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: RFQs issued by organizational units for org-level sourcing activity tracking, decentralized procurement operations. Critical for divisional RFQ analytics, org-specific sourcing strategy execution in m' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryRfqEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rfq Employee Id' ;
    rdfs:comment 'Identifier of the procurement professional or buyer responsible for managing this RFQ process.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rfqBuyerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rfq Buyer Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rfqEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rfq Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'The date when the supplier award decision was made and communicated. Null if RFQ is not yet awarded.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Amount' ;
    rdfs:comment 'The total contract value awarded to the winning supplier. Null if RFQ is not yet awarded.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'The facility, warehouse, or site where goods should be delivered or where services should be performed.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Weight Percentage' ;
    rdfs:comment 'The percentage weight assigned to delivery time and reliability in the overall evaluation scoring model.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Spend Amount' ;
    rdfs:comment 'The estimated total monetary value of this procurement, used for budget planning and approval routing. May be shared with suppliers or kept confidential depending on sourcing strategy.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'The criteria and weighting that will be used to evaluate and score supplier quotations. May include price, quality, delivery time, service level, sustainability, financial stability, and past performance.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiRound rdf:type rdf:Property ;
    rdfs:label 'Is Multi Round' ;
    rdfs:comment 'Indicates whether this RFQ involves multiple rounds of bidding (e.g., initial submission followed by best-and-final-offer round). True = multi-round; False = single-round.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReverseAuction rdf:type rdf:Property ;
    rdfs:label 'Is Reverse Auction' ;
    rdfs:comment 'Indicates whether this RFQ includes a reverse auction phase where suppliers can see competitor pricing and submit lower bids in real-time. True = includes reverse auction; False = sealed bid only.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Issuing Business Unit' ;
    rdfs:comment 'The business unit, division, or department within Transport Shipping that is requesting the goods or services and issuing this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingLocation rdf:type rdf:Property ;
    rdfs:label 'Issuing Location' ;
    rdfs:comment 'The geographic location, facility, or site that is the origin of this RFQ request.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Price Weight Percentage' ;
    rdfs:comment 'The percentage weight assigned to price in the overall evaluation scoring model. Typically ranges from 30% to 70% depending on procurement strategy.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Weight Percentage' ;
    rdfs:comment 'The percentage weight assigned to quality criteria in the overall evaluation scoring model.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'The number of suppliers who submitted quotations in response to this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqCategory rdf:type rdf:Property ;
    rdfs:label 'Rfq Category' ;
    rdfs:comment 'Classification of the procurement category for this RFQ. Determines routing, approval workflow, and evaluation criteria. Categories include carrier services (3PL, freight forwarding), fuel (diesel, aviation fuel), warehouse equipment (forklifts, racking), IT (hardware, software, services), facilities (maintenance, construction), fleet vehicles, and professional services. [ENUM-REF-CANDIDATE: carrier_services|fuel|warehouse_equipment|it_hardware|it_software|facilities|fleet_vehicles|professional_services — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqDescription rdf:type rdf:Property ;
    rdfs:label 'Rfq Description' ;
    rdfs:comment 'Detailed description of the goods or services being requested, including specifications, requirements, and scope of work.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Externally-known business identifier for the RFQ, used in communications with suppliers and internal stakeholders. Typically follows format RFQ-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ. Draft = being prepared; Issued/Open = sent to suppliers and accepting responses; Closed = submission deadline passed, under evaluation; Awarded = supplier(s) selected and notified; Cancelled = RFQ withdrawn; Expired = deadline passed with no award. [ENUM-REF-CANDIDATE: draft|issued|open|closed|awarded|cancelled|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingEventType rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Type' ;
    rdfs:comment 'Classification of the sourcing event complexity and strategic importance. Spot = one-time immediate need; Tactical = recurring operational procurement; Strategic = high-value, long-term, complex sourcing.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'The date and time by which suppliers must submit their quotations. No late submissions are typically accepted after this timestamp.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCount rdf:type rdf:Property ;
    rdfs:label 'Supplier Count' ;
    rdfs:comment 'The number of suppliers invited to participate in this RFQ. Influences competition level and response rate.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or doing-business-as name if different from legal name.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds ISO 14001 certification for environmental management systems, relevant for sustainability and emissions reduction initiatives.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorityOwned rdf:type rdf:Property ;
    rdfs:label 'Minority Owned' ;
    rdfs:comment 'Indicates whether the supplier is certified as a minority-owned business enterprise (MBE). Used for diversity and inclusion reporting and supplier diversity programs.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredSupplier rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier' ;
    rdfs:comment 'Indicates whether the supplier has been designated as a preferred or strategic supplier based on performance, pricing, reliability, or strategic partnership agreements. Preferred suppliers receive priority consideration in sourcing decisions.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Risk classification based on financial stability, compliance history, geographic location, criticality to operations, and exposure to sanctions or trade restrictions. Critical tier requires enhanced due diligence and monitoring.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCapabilities rdf:type rdf:Property ;
    rdfs:label 'Service Capabilities' ;
    rdfs:comment 'Comma-separated list of service capabilities the supplier can provide, such as air_freight, ocean_freight, road_transport, rail_transport, warehousing, customs_brokerage, last_mile_delivery, cold_chain, hazmat_handling, cross_border_shipping. Used for carrier and 3PL selection.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusiness rdf:type rdf:Property ;
    rdfs:label 'Small Business' ;
    rdfs:comment 'Indicates whether the supplier is certified as a small business according to the applicable jurisdiction\'s definition (e.g., US SBA size standards). Used for small business procurement programs and reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierCategory rdf:type rdf:Property ;
    rdfs:label 'Supplier Category' ;
    rdfs:comment 'Spend category classification. Direct suppliers provide goods/services directly tied to core logistics operations (carriers, fuel, packaging). Indirect suppliers provide operational support (IT, facilities, office supplies). Capital suppliers provide long-term assets (vehicles, equipment, infrastructure).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Number' ;
    rdfs:comment 'Externally-known unique business identifier for the supplier, typically assigned during onboarding. Used in purchase orders, invoices, and contracts.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Status' ;
    rdfs:comment 'Current lifecycle status of the supplier relationship. Active: approved and transacting. Inactive: approved but not currently transacting. Suspended: temporarily blocked due to performance or compliance issues. Pending approval: onboarding in progress. Blocked: prohibited from new transactions. Terminated: relationship ended.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Primary classification of the supplier based on the goods or services provided. Carrier includes air, ocean, road, rail freight carriers; fuel supplier provides bunker fuel, diesel, jet fuel; IT vendor provides software, hardware, telecom; facility lessor provides warehouse, office, terminal leases; equipment provider supplies vehicles, containers, handling equipment; professional services includes consulting, legal, audit.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'The supplier\'s tax identification number issued by the tax authority in their country of registration. In the US this is the EIN (Employer Identification Number) or SSN for sole proprietors; in the EU this is the VAT number.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:womanOwned rdf:type rdf:Property ;
    rdfs:label 'Woman Owned' ;
    rdfs:comment 'Indicates whether the supplier is certified as a woman-owned business enterprise (WBE). Used for diversity and inclusion reporting and supplier diversity programs.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySupplierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Employee Id' ;
    rdfs:comment 'Reference to the employee who approved this invoice for payment. Null if invoice is not yet approved or approval is not required.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySupplierModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Supplier Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this invoice record. Used for audit trail and change accountability.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:documentReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Document Reference Url' ;
    rdfs:comment 'URL or file path to the original invoice document (PDF, image, EDI file). Used for document retrieval and audit purposes.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the invoice purpose or contents. Provides business context for the invoice.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchExceptionAmount rdf:type rdf:Property ;
    rdfs:label 'Match Exception Amount' ;
    rdfs:comment 'Monetary value of the discrepancy identified in three-way match. Null if no exception or exception is non-monetary.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchExceptionResolution rdf:type rdf:Property ;
    rdfs:label 'Match Exception Resolution' ;
    rdfs:comment 'Description of how the match exception was resolved. Examples: supplier credit issued, PO amended, goods receipt corrected, management override. Null if exception is unresolved.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchExceptionType rdf:type rdf:Property ;
    rdfs:label 'Match Exception Type' ;
    rdfs:comment 'Type of discrepancy identified during three-way match. Examples: price variance, quantity variance, tax variance, missing PO, missing goods receipt. Null if no exception. [ENUM-REF-CANDIDATE: price_variance|quantity_variance|tax_variance|missing_po|missing_gr|duplicate_invoice|unauthorized_charge — promote to reference product]' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date the invoice was received by the organization. Used for processing SLA tracking and aging analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Channel through which the supplier submitted the invoice. EDI for Electronic Data Interchange, email for scanned/PDF invoices, portal for supplier self-service, paper for physical mail, API for system-to-system integration.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Tax jurisdiction or authority under which tax is calculated and remitted. Examples: US-CA (California), GB-VAT (UK VAT), EU-VAT. Critical for tax compliance and reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Performance Id' ;
    rdfs:comment 'Unique identifier for the supplier performance evaluation record. Primary key.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Responsible Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Supplier performance evaluated by responsible organizational units. Enables divisional supplier scorecards, org-specific vendor management KPIs, regional supplier performance tracking in decentralized' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:correctiveActionCount rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Count' ;
    rdfs:comment 'Total number of corrective action requests issued to the supplier for performance or quality issues during the evaluation period.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of quality defects, rejections, or non-conformances identified in goods or services received from the supplier during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationCycleType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Cycle Type' ;
    rdfs:comment 'The frequency or type of evaluation cycle (monthly, quarterly, annual, or ad-hoc).' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text notes and comments from the evaluator providing qualitative context, observations, and recommendations regarding supplier performance.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorEmail rdf:type rdf:Property ;
    rdfs:label 'Evaluator Email' ;
    rdfs:comment 'Email address of the evaluator for follow-up and audit trail purposes.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Name of the procurement professional or team responsible for conducting and approving this performance evaluation.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementAreas rdf:type rdf:Property ;
    rdfs:label 'Improvement Areas' ;
    rdfs:comment 'Specific areas where the supplier needs to improve performance, documented for supplier development and corrective action planning.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage of invoices submitted by the supplier that matched purchase orders and receipts without discrepancies, requiring no corrections.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDiscrepancyCount rdf:type rdf:Property ;
    rdfs:label 'Invoice Discrepancy Count' ;
    rdfs:comment 'Total number of invoices that contained errors, mismatches, or discrepancies requiring correction during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lateDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Late Delivery Count' ;
    rdfs:comment 'Total number of deliveries that arrived after the promised delivery date or time window during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otdRate rdf:type rdf:Property ;
    rdfs:label 'Otd Rate' ;
    rdfs:comment 'Percentage of deliveries that met the promised delivery date or time window during the evaluation period. Key performance indicator for supplier reliability.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Numeric composite score (0-100) representing the weighted average of all performance metrics for the evaluation period.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScorecardGrade rdf:type rdf:Property ;
    rdfs:label 'Overall Scorecard Grade' ;
    rdfs:comment 'Composite letter grade summarizing the suppliers overall performance across all evaluation dimensions (OTD, quality, invoice accuracy, SLA compliance, responsiveness, sustainability).' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Boolean indicator whether the supplier has been designated as a preferred supplier based on this evaluation, qualifying for priority consideration in sourcing decisions.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedToSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Published To Supplier Flag' ;
    rdfs:comment 'Boolean indicator whether this performance evaluation has been shared with the supplier for transparency and supplier development purposes.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate' ;
    rdfs:comment 'Percentage of received goods or services that passed quality inspection without defects or rejections during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalRecommendation rdf:type rdf:Property ;
    rdfs:label 'Renewal Recommendation' ;
    rdfs:comment 'Recommendation for contract renewal or continuation based on the performance evaluation results.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Score measuring the suppliers timeliness and effectiveness in responding to inquiries, requests for quotation, change orders, and issue resolution.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Score' ;
    rdfs:comment 'Overall score representing the suppliers adherence to contractual service level agreements across all defined metrics during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strengths rdf:type rdf:Property ;
    rdfs:label 'Strengths' ;
    rdfs:comment 'Documented strengths and positive performance attributes of the supplier during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierTier rdf:type rdf:Property ;
    rdfs:label 'Supplier Tier' ;
    rdfs:comment 'Tiering classification assigned to the supplier based on performance results (preferred, approved, conditional, probation, disqualified). Drives sourcing decisions and contract renewals.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Sustainability Rating' ;
    rdfs:comment 'Letter grade rating the suppliers environmental and social sustainability practices, including carbon footprint, ethical sourcing, and compliance with environmental regulations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of all purchase orders issued to the supplier during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPurchaseOrders rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Orders' ;
    rdfs:comment 'Total number of purchase orders issued to the supplier during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Id' ;
    rdfs:comment 'Unique identifier for the supplier qualification record. Primary key.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dgCertificationId rdf:type rdf:Property ;
    rdfs:label 'Dg Certification Id' ;
    rdfs:comment 'Foreign key linking to safety.dg_certification. Business justification: Suppliers handling dangerous goods must hold valid DG certifications. Links supplier qualification to specific DG certification records for regulatory compliance verification (IATA, IMDG, ADR) in tran' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DgCertification .

ind:aeoCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Aeo Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the AEO certification. Must be monitored to maintain customs compliance and trade facilitation benefits.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeoCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification Status' ;
    rdfs:comment 'Status of Authorized Economic Operator certification, a customs compliance program that provides trade facilitation benefits. Critical for international freight forwarders and customs brokers.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Composite numerical score from the qualification assessment, typically on a 0-100 scale. Aggregates performance across multiple evaluation criteria including quality, delivery, financial health, and compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctpatCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the C-TPAT certification. Critical for maintaining supply chain security compliance for US-bound shipments.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctpatCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Ctpat Certification Status' ;
    rdfs:comment 'Status of C-TPAT certification, a US Customs and Border Protection voluntary supply chain security program. Provides benefits for US import operations.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screening Date' ;
    rdfs:comment 'Date when the most recent denied party screening was performed. Must be refreshed periodically per trade compliance policies.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDiligenceCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completed Flag' ;
    rdfs:comment 'Indicates whether comprehensive due diligence checks (financial, legal, operational, reputational) have been completed for this qualification event. True when all required checks are finalized.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDiligenceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completion Date' ;
    rdfs:comment 'Date when all due diligence activities were completed. Marks readiness for final qualification decision.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:euSanctionsScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Eu Sanctions Screening Result' ;
    rdfs:comment 'Result of screening against European Union consolidated sanctions lists. Critical for suppliers involved in EU trade lanes.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialHealthScore rdf:type rdf:Property ;
    rdfs:label 'Financial Health Score' ;
    rdfs:comment 'Quantitative assessment of supplier financial stability derived from credit reports, financial statements, and payment history. Scale 0-100 where higher indicates stronger financial position.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCertificateStatus rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Status' ;
    rdfs:comment 'Status of supplier liability insurance certificate. Valid indicates current coverage meeting minimum requirements; insufficient coverage indicates policy limits below contract thresholds.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the supplier ISO certification. Triggers re-certification requirements and compliance monitoring.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isoCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Status' ;
    rdfs:comment 'Status of supplier ISO certifications (e.g., ISO 9001 Quality Management, ISO 14001 Environmental Management, ISO 28000 Supply Chain Security). Indicates whether valid certifications are on file.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Ofac Screening Result' ;
    rdfs:comment 'Specific result of screening against US OFAC sanctions lists. Pass indicates no match; fail indicates positive match requiring immediate action; review required indicates potential match needing manual investigation.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Completion Date' ;
    rdfs:comment 'Date when the qualification process was finalized with a decision (approved or rejected). Null if still in progress.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date when the qualification approval expires and re-qualification is required. Critical for compliance monitoring and supplier lifecycle management.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text field capturing assessor observations, special conditions, remediation requirements, or other contextual information relevant to the qualification decision. Used for audit trails and future reference.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the qualification event. Externally visible reference number used in communications and audit trails.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStartDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Start Date' ;
    rdfs:comment 'Date when the qualification process was initiated. Marks the beginning of the assessment lifecycle.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current lifecycle state of the qualification: pending (awaiting initiation), in progress (under review), approved (passed all checks), rejected (failed qualification), suspended (temporarily halted), or expired (validity period ended).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Category of qualification event: initial onboarding for new suppliers, periodic review for scheduled reassessments, re-qualification after suspension, ad-hoc audit triggered by incidents, compliance verification for regulatory changes, or risk assessment for high-value contracts.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQuoteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Quote Id' ;
    rdfs:comment 'Unique identifier for the supplier quote record. Primary key.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardStatus rdf:type rdf:Property ;
    rdfs:label 'Award Status' ;
    rdfs:comment 'Indicates whether this quote was awarded a purchase order or contract.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDutyEstimate rdf:type rdf:Property ;
    rdfs:label 'Customs Duty Estimate' ;
    rdfs:comment 'Estimated customs duties or tariffs applicable to the quoted goods, if included by the supplier.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'Composite score assigned during quote evaluation based on price, quality, delivery, and other criteria.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCharges rdf:type rdf:Property ;
    rdfs:label 'Freight Charges' ;
    rdfs:comment 'Freight or shipping charges included in or added to the quote.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingCharges rdf:type rdf:Property ;
    rdfs:label 'Handling Charges' ;
    rdfs:comment 'Handling or packaging charges specified in the quote.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCharges rdf:type rdf:Property ;
    rdfs:label 'Insurance Charges' ;
    rdfs:comment 'Insurance charges included in the quote for shipment coverage.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum order quantity the supplier can fulfill under this quote.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum order quantity required by the supplier for this quote to be valid.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Reference Number' ;
    rdfs:comment 'External reference number assigned by the supplier to this quotation. Used for supplier correspondence and tracking.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rank rdf:type rdf:Property ;
    rdfs:label 'Rank' ;
    rdfs:comment 'Ranking of this quote relative to other quotes received for the same RFQ, with 1 being the best.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAmountIncludingTax rdf:type rdf:Property ;
    rdfs:label 'Total Amount Including Tax' ;
    rdfs:comment 'Grand total of the quote including all taxes and charges.' ;
    rdfs:domain ind:SupplierQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankBranchCode rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Code' ;
    rdfs:comment 'Branch code or routing number for the supplier site\'s bank account, used for electronic funds transfer.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonTitle rdf:type rdf:Property ;
    rdfs:label 'Contact Person Title' ;
    rdfs:comment 'Job title or role of the primary contact person at the supplier site (e.g., Site Manager, Procurement Coordinator, Operations Director).' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimarySite rdf:type rdf:Property ;
    rdfs:label 'Is Primary Site' ;
    rdfs:comment 'Flag indicating whether this is the primary or default site for the supplier. True if this is the main operational site; false for secondary or regional sites.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemitToSite rdf:type rdf:Property ;
    rdfs:label 'Is Remit To Site' ;
    rdfs:comment 'Flag indicating whether this site is designated as a remit-to address for payment processing. True if payments should be sent to this site\'s bank account.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for payments to this supplier site (e.g., USD, EUR, GBP, CNY). Site-level currency may differ from supplier-level default.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the site, used in procurement documents and purchase orders.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name or label for the supplier site (e.g., \'Regional Hub - Chicago\', \'Fuel Depot - Rotterdam\', \'Equipment Warehouse - Singapore\').' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle status of the supplier site. Active sites are available for procurement transactions; inactive or suspended sites are temporarily unavailable; closed sites are permanently retired.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the site\'s operational purpose: remit-to (payment address), ship-from (origin for goods), order-from (procurement contact point), bill-to (invoicing address), service-location (on-site service delivery), or warehouse (storage facility).' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierLaneAllocationId rdf:type rdf:Property ;
    rdfs:label 'Carrier Lane Allocation Id' ;
    rdfs:comment 'Unique identifier for the carrier lane allocation record. Primary key.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Code' ;
    rdfs:comment 'Business identifier for this carrier lane allocation, used in SAP TM carrier selection engine and tendering processes.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonEmissionFactorKgCo2e rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Factor Kg Co2e' ;
    rdfs:comment 'Carbon emission factor in kilograms of CO2 equivalent per unit (per TEU-km, per ton-km, or per shipment) for this carrier on this lane. Used for GHG (Greenhouse Gas) reporting and sustainability analytics.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Certification Level' ;
    rdfs:comment 'Certification or partnership level of the carrier: standard, preferred, strategic, AEO (Authorized Economic Operator), C-TPAT (Customs-Trade Partnership Against Terrorism), or other industry certifications.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedCapacityVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Contracted Capacity Volume Cbm' ;
    rdfs:comment 'Contracted volume capacity in cubic meters (CBM) for freight. Used for dimensional capacity planning.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedCapacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Contracted Capacity Weight Kg' ;
    rdfs:comment 'Contracted weight capacity in kilograms for air, road, or rail freight. Used for capacity management and load optimization.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Contracted cost per unit (per TEU, per kg, per CBM, or per shipment) for this carrier on this lane. Used for freight cost calculation and carrier selection optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsBonded rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded' ;
    rdfs:comment 'Indicates whether this carrier operates under customs bond for in-transit goods, enabling duty-deferred cross-border movements.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutoffTime rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time' ;
    rdfs:comment 'Daily cutoff time (HH:MM format, 24-hour) for booking this carrier on this lane. Bookings after cutoff are processed next business day.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazmatCapable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Capable' ;
    rdfs:comment 'Indicates whether this carrier is certified and capable of transporting hazardous materials (HAZMAT) on this lane per IMDG Code or ICAO Technical Instructions.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumVolumeLimit rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume Limit' ;
    rdfs:comment 'Maximum volume limit (in applicable unit: TEU, kg, CBM) that can be allocated to this carrier on this lane per capacity constraints or contract terms.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaOnTimeDeliveryPct rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Delivery Pct' ;
    rdfs:comment 'Service Level Agreement target for on-time delivery percentage (OTD) for this carrier on this lane, expressed as a decimal (e.g., 95.00 for 95%).' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visibilityEnabled rdf:type rdf:Property ;
    rdfs:label 'Visibility Enabled' ;
    rdfs:comment 'Indicates whether real-time shipment visibility is enabled for this carrier on this lane via FourKites or other visibility platforms.' ;
    rdfs:domain ind:CarrierLaneAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierScheduleId rdf:type rdf:Property ;
    rdfs:label 'Carrier Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for the carrier schedule record in the Transport Shipping lakehouse Silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierSchedule .

ind:crewLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Crew Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Vessel/flight schedules require crew lead assignment for labor planning, certification compliance verification (IATA DG, customs broker licenses), shift scheduling, and operational accountability. Cri' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCarrierNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Network Node Id' ;
    rdfs:comment 'Reference to the network node (port, airport, hub, depot, ICD, CFS) from which this schedule departs. Supports hub-and-spoke topology and FourKites real-time visibility integration.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:allianceCode rdf:type rdf:Property ;
    rdfs:label 'Alliance Code' ;
    rdfs:comment 'Code identifying the ocean carrier alliance (e.g., \'2M\', \'THE Alliance\', \'Ocean Alliance\') or air cargo alliance to which this schedule belongs. Used for slot-sharing and co-loading capacity management in Blue Yonder and Oracle TMS.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Arrival Days Of Week' ;
    rdfs:comment 'Comma-separated list of ISO weekday numbers (1=Monday through 7=Sunday) on which this schedule arrives at the destination node. May differ from departure days for multi-day transits. Used for ETA calculation and last-mile delivery zone scheduling.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalTime rdf:type rdf:Property ;
    rdfs:label 'Arrival Time' ;
    rdfs:comment 'Scheduled local arrival time at the destination node in HH:mm (24-hour) format. Combined with arrival_days_of_week to determine the Estimated Time of Arrival (ETA) for delivery planning and SLA entitlement matching.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arrivalTimezone rdf:type rdf:Property ;
    rdfs:label 'Arrival Timezone' ;
    rdfs:comment 'IANA timezone identifier for the destination node (e.g., \'Europe/Rotterdam\', \'Asia/Tokyo\'). Required to convert local arrival time to UTC for cross-border ETA management and FourKites real-time visibility integration.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityTeu rdf:type rdf:Property ;
    rdfs:label 'Capacity Teu' ;
    rdfs:comment 'Maximum container capacity of this schedule expressed in Twenty-foot Equivalent Units (TEU). Applicable for ocean FCL/LCL services. Null for non-ocean modes. Used for load optimization in Oracle TMS and capacity planning in Blue Yonder.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume Cbm' ;
    rdfs:comment 'Maximum volumetric capacity in Cubic Meters (CBM) for this schedule. Used alongside DIM Weight (Dimensional Weight) calculations for air freight and LTL/LCL load optimization in Oracle TMS.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum payload weight capacity in kilograms for this schedule. Applicable across all transport modes (air, ocean, road, rail). Used for load optimization in Oracle TMS and freight order management in SAP TM.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutoffHoursBeforeDeparture rdf:type rdf:Property ;
    rdfs:label 'Cutoff Hours Before Departure' ;
    rdfs:comment 'Cargo receipt deadline expressed as the number of hours before scheduled departure by which cargo must be tendered to the carrier at the origin node. Used by SAP TM for freight order management and Oracle TMS for shipment execution planning.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departureDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Departure Days Of Week' ;
    rdfs:comment 'Comma-separated list of ISO weekday numbers (1=Monday through 7=Sunday) on which this schedule departs (e.g., \'1,3,5\' for Mon/Wed/Fri). Used by SAP TM for departure planning and Blue Yonder for network optimization.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureTime rdf:type rdf:Property ;
    rdfs:label 'Departure Time' ;
    rdfs:comment 'Scheduled local departure time at the origin node in HH:mm (24-hour) format. Combined with departure_days_of_week to determine the Estimated Time of Departure (ETD) for shipment planning in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departureTimezone rdf:type rdf:Property ;
    rdfs:label 'Departure Timezone' ;
    rdfs:comment 'IANA timezone identifier for the origin node (e.g., \'America/New_York\', \'Asia/Shanghai\'). Required to convert local departure time to UTC for cross-border schedule coordination and FourKites predictive ETA calculation.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docCutoffHoursBeforeDeparture rdf:type rdf:Property ;
    rdfs:label 'Doc Cutoff Hours Before Departure' ;
    rdfs:comment 'Deadline for submission of shipping documents (AWB, BOL, customs declarations) expressed as hours before scheduled departure. Required for Descartes Customs AMS/ISF filing compliance and carrier EDI submission.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediSourceCode rdf:type rdf:Property ;
    rdfs:label 'Edi Source Code' ;
    rdfs:comment 'Identifier of the EDI feed or carrier data exchange channel from which this schedule record was sourced (e.g., EDIFACT IFTMCS, ANSI X12 204, carrier API). Used for data lineage, reconciliation, and Silver layer ingestion audit in the Databricks lakehouse.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDirectService rdf:type rdf:Property ;
    rdfs:label 'Is Direct Service' ;
    rdfs:comment 'Indicates whether this schedule operates as a direct (non-stop) service between origin and destination nodes (True) or involves intermediate port calls / transshipment stops (False). Used for transit time accuracy and customer SLA commitments.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ref rdf:type rdf:Property ;
    rdfs:label 'Ref' ;
    rdfs:comment 'Carrier\'s own internal reference or booking system identifier for this schedule, as received via EDI. Enables round-trip reconciliation with the carrier\'s system and supports freight audit in Oracle TMS.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Monotonically incrementing version number for this carrier schedule record, incremented each time the carrier publishes an updated schedule via EDI. Supports schedule change management and historical comparison in the Silver layer.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transshipmentPortCode rdf:type rdf:Property ;
    rdfs:label 'Transshipment Port Code' ;
    rdfs:comment 'UN/LOCODE of the primary transshipment hub for indirect services (is_direct_service = False). Used for multi-leg ETA calculation, customs transit declaration in Descartes Customs, and FourKites milestone tracking.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vgmCutoffHoursBeforeDeparture rdf:type rdf:Property ;
    rdfs:label 'Vgm Cutoff Hours Before Departure' ;
    rdfs:comment 'Deadline for submission of Verified Gross Mass (VGM) declaration expressed as hours before scheduled departure. Mandatory for ocean shipments under SOLAS Amendment 2016. Null for non-ocean modes.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voyageRotationNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Rotation Number' ;
    rdfs:comment 'Carrier-assigned voyage or rotation number for ocean services, or equivalent rotation identifier for air/rail. Used for Bill of Lading (BOL) and Master Bill of Lading (MBL) cross-referencing and port authority reporting.' ;
    rdfs:domain ind:CarrierSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorLegId rdf:type rdf:Property ;
    rdfs:label 'Corridor Leg Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual transport leg within a service corridor. Primary key for the corridor_leg entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorridorLeg .

ind:primaryCorridorNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Corridor Network Node Id' ;
    rdfs:comment 'Reference to the network node (hub, port, airport, depot, ICD, CFS, or warehouse) where this leg originates. Supports hub-and-spoke topology decomposition in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:departureDaysMask rdf:type rdf:Property ;
    rdfs:label 'Departure Days Mask' ;
    rdfs:comment '7-character binary string (Mon=pos1 through Sun=pos7) indicating which days of the week this leg operates departures (1=operates, 0=does not operate). Enables precise booking calendar generation in SAP TM and Oracle TMS scheduling.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureFrequency rdf:type rdf:Property ;
    rdfs:label 'Departure Frequency' ;
    rdfs:comment 'Frequency at which this leg operates departures. Drives shipment booking availability windows, capacity planning in Blue Yonder, and customer-facing transit time commitments. ON_DEMAND applies to charter and FTL legs.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalLaneReference rdf:type rdf:Property ;
    rdfs:label 'External Lane Reference' ;
    rdfs:comment 'Carrier-assigned or partner-assigned lane reference code for this leg as used in EDI interchange, carrier rate agreements, or NVOCC tariff filings. Enables reconciliation between internal lane definitions and external carrier systems.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fourtitesTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Fourtites Tracking Enabled' ;
    rdfs:comment 'Indicates whether this leg is enrolled in FourKites real-time visibility tracking (True). When enabled, GPS/IoT telemetry is streamed for predictive ETA updates and exception management. Supports independent leg trackability as defined in the corridor_leg product scope.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border' ;
    rdfs:comment 'Indicates whether this leg crosses an international border (True) or is a domestic movement (False). Triggers customs declaration requirements in Descartes, ISF/AMS filing obligations, and AEO/C-TPAT compliance checks.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDangerousGoodsPermitted rdf:type rdf:Property ;
    rdfs:label 'Is Dangerous Goods Permitted' ;
    rdfs:comment 'Indicates whether this leg is certified and permitted to carry dangerous goods (True) or not (False). Governs shipment acceptance rules per IMDG Code for ocean legs and ICAO Technical Instructions for air legs.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legCode rdf:type rdf:Property ;
    rdfs:label 'Leg Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this corridor leg, used in SAP TM route planning, Oracle TMS load optimization, and EDI interchange with carriers. Unique within the parent corridor.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Leg Sequence Number' ;
    rdfs:comment 'Ordinal position of this leg within the parent corridor, starting at 1. Defines the execution order for multi-modal route decomposition (e.g., leg 1 = road pickup, leg 2 = air haul, leg 3 = road delivery). Aligns with Oracle TMS load optimization sequencing.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaOnTimeThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Threshold Hours' ;
    rdfs:comment 'Maximum allowable transit time in hours for this leg before it is classified as a late delivery for OTD (On-Time Delivery) and OTIF (On-Time In-Full) KPI measurement. Sourced from contracted SLA terms and used in FourKites exception management.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Standard Arrival Time' ;
    rdfs:comment 'Standard local arrival time (HH:MM, 24-hour) at the destination node for this leg. Used as the baseline Estimated Time of Arrival (ETA) for downstream leg connections, delivery scheduling, and OTD/OTIF KPI measurement.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standardDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Standard Departure Time' ;
    rdfs:comment 'Standard local departure time (HH:MM, 24-hour) for this leg at the origin node. Used as the baseline Estimated Time of Departure (ETD) for shipment scheduling, FourKites tracking initialization, and customer notification triggers.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standardTransitHours rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Hours' ;
    rdfs:comment 'Contracted or standard transit time for this leg expressed in decimal hours. Used as the baseline for ETA calculation, SLA commitment derivation, and predictive ETA modeling in FourKites. Sourced from SAP TM transit time matrix.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum temperature in degrees Celsius maintained during transport on this leg. Applicable only when is_temperature_controlled is True. Used for cold chain compliance validation and cargo acceptance rules.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum temperature in degrees Celsius maintained during transport on this leg. Applicable only when is_temperature_controlled is True. Used for cold chain compliance validation and cargo acceptance rules.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timezoneDestination rdf:type rdf:Property ;
    rdfs:label 'Timezone Destination' ;
    rdfs:comment 'IANA timezone identifier for the destination node (e.g., Asia/Singapore, Europe/Frankfurt). Required to correctly interpret standard_arrival_time and compute accurate ETA in local destination time for delivery scheduling.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezoneOrigin rdf:type rdf:Property ;
    rdfs:label 'Timezone Origin' ;
    rdfs:comment 'IANA timezone identifier for the origin node (e.g., America/New_York, Europe/London). Required to correctly interpret cutoff_time and standard_departure_time for cross-timezone route planning and ETA calculations.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingMethod rdf:type rdf:Property ;
    rdfs:label 'Tracking Method' ;
    rdfs:comment 'Method used to track shipment progress on this leg. GPS for road/fleet, AIS (Automatic Identification System) for ocean vessels, EDI_MILESTONE for carrier EDI updates, API_CARRIER for direct carrier API integration, RFID for warehouse handoffs, or MANUAL for exception-based updates. Drives FourKites data ingestion configuration.' ;
    rdfs:domain ind:CorridorLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Type of vehicle, vessel, or aircraft used on this leg (e.g., B747F for air freighter, 20FT_CONTAINER for ocean, SEMI_TRAILER for road, FLATCAR for rail). Determines capacity constraints, dangerous goods handling rules per IMDG/ICAO TI, and emissions factors for CO2e calculation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etaEventId rdf:type rdf:Property ;
    rdfs:label 'Eta Event Id' ;
    rdfs:comment 'Unique identifier for the ETA/ETD event record. Primary key for the eta_event product.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Network Node Id' ;
    rdfs:comment 'Reference to the destination location (hub, terminal, warehouse, customer site) for this shipment leg. Links to the location master data. Used for Door-to-Door (D2D) transit time calculation and last-mile delivery zone assignment.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:primaryEtaLocationNodeNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Eta Location Node Network Node Id' ;
    rdfs:comment 'Reference to the network node (hub, terminal, warehouse, Container Freight Station (CFS), Inland Container Depot (ICD), or delivery zone) where the shipment was located at the time of this event. Links to the network topology master data.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:shipmentLegId rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Id' ;
    rdfs:comment 'Reference to the specific shipment leg or route segment for which this ETA/ETD event applies. A shipment may have multiple legs across different transport modes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentLeg .

ind:actualEtd rdf:type rdf:Property ;
    rdfs:label 'Actual Etd' ;
    rdfs:comment 'The actual recorded time of departure when the shipment left the origin location, hub, or intermediate node. Captured from GPS, carrier Electronic Data Interchange (EDI), or manual confirmation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentPredictedEta rdf:type rdf:Property ;
    rdfs:label 'Current Predicted Eta' ;
    rdfs:comment 'The most recent predicted estimated time of arrival based on real-time tracking data, traffic conditions, weather, and predictive algorithms from FourKites or SAP TM. This is the current best estimate of when the shipment will arrive. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Boolean indicator (True/False) that identifies whether a customer notification (email, SMS, Application Programming Interface (API) push) was sent for this ETA/ETD event. True indicates the customer was notified; False indicates no notification was sent. Used for customer communication audit and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delayReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Description' ;
    rdfs:comment 'A free-text description providing additional context or details about the delay or exception. Captured from carrier Electronic Data Interchange (EDI) messages, driver notes, or customer service case logs.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etaVarianceHours rdf:type rdf:Property ;
    rdfs:label 'Eta Variance Hours' ;
    rdfs:comment 'The difference in hours between the original planned ETA and the current predicted ETA. Positive values indicate a delay; negative values indicate the shipment is ahead of schedule. Used for Service Level Agreement (SLA) monitoring and On-Time Delivery (OTD) / On-Time In-Full (OTIF) Key Performance Indicator (KPI) calculation.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etdVarianceHours rdf:type rdf:Property ;
    rdfs:label 'Etd Variance Hours' ;
    rdfs:comment 'The difference in hours between the original planned ETD and the actual ETD. Positive values indicate a late departure; negative values indicate an early departure. Used for root cause analysis of delays and transit time performance.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionSeverity rdf:type rdf:Property ;
    rdfs:label 'Exception Severity' ;
    rdfs:comment 'The severity level of the exception condition. Critical indicates Service Level Agreement (SLA) breach or customer escalation required; High indicates significant delay; Medium indicates minor delay; Low indicates minimal impact; None indicates no exception.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPlannedEta rdf:type rdf:Property ;
    rdfs:label 'Original Planned Eta' ;
    rdfs:comment 'The initial planned estimated time of arrival as defined in the original route plan or shipment booking. This is the baseline ETA against which all subsequent updates and variances are measured. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalPlannedEtd rdf:type rdf:Property ;
    rdfs:label 'Original Planned Etd' ;
    rdfs:comment 'The initial planned estimated time of departure as defined in the original route plan or shipment booking. This is the baseline ETD for the origin or intermediate hub. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Transit Time Hours' ;
    rdfs:comment 'The planned transit time in hours for this shipment leg as defined in the route plan or service corridor standard. Used as the baseline for On-Time Delivery (OTD) and transit time variance analysis.' ;
    rdfs:domain ind:EtaEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podStatus rdf:type rdf:Property ;
    rdfs:label 'Pod Status' ;
    rdfs:comment 'The Proof of Delivery (POD) status for this shipment leg. Indicates whether the shipment has not been delivered, has been delivered, delivery was attempted, was refused by the consignee, was damaged, or was lost. Used for Electronic Proof of Delivery (ePOD) integration and claims processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Prediction Confidence Score' ;
    rdfs:comment 'A confidence score (0-100) indicating the reliability of the current predicted ETA. Higher scores indicate greater confidence based on historical accuracy, data quality, and real-time tracking signal strength. Generated by FourKites or SAP TM predictive algorithms.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficCondition rdf:type rdf:Property ;
    rdfs:label 'Traffic Condition' ;
    rdfs:comment 'A description of the traffic conditions at the time of the ETA/ETD event or along the route. Captured from traffic Application Programming Interface (API) integration, Global Positioning System (GPS) data, or driver reports. Used for delay analysis and dynamic route optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'A description of the weather conditions at the time of the ETA/ETD event or along the route. Examples include clear, rain, snow, fog, storm, hurricane. Captured from weather Application Programming Interface (API) integration or driver reports. Used for delay analysis and predictive modeling.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubSpokeConfigId rdf:type rdf:Property ;
    rdfs:label 'Hub Spoke Config Id' ;
    rdfs:comment 'Unique identifier for the hub-and-spoke network configuration record. Primary key.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Config Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Network design configurations require designated employee owner for ongoing maintenance, performance monitoring, change management, and accountability. Existing \'config_owner\' text field should be rep' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Id' ;
    rdfs:comment 'Reference to the primary carrier or 3PL partner assigned to operate this hub-spoke configuration. Links to carrier master data.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:spokeDepotId rdf:type rdf:Property ;
    rdfs:label 'Spoke Depot Id' ;
    rdfs:comment 'Foreign key linking to fleet.fleet_depot. Business justification: Hub-spoke configurations define which depots serve as spokes (in addition to hub_node_id); critical for fleet deployment planning, asset allocation, and last-mile service design.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:carrierAllocationStrategy rdf:type rdf:Property ;
    rdfs:label 'Carrier Allocation Strategy' ;
    rdfs:comment 'Strategy for allocating carriers to hub-spoke lanes: dedicated carriers per lane, shared carrier pool, dynamic selection via TMS, or contract-based assignment.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configCode rdf:type rdf:Property ;
    rdfs:label 'Config Code' ;
    rdfs:comment 'Business identifier code for the hub-spoke configuration, used for external reference and reporting. Typically follows a naming convention combining region, service product, and version.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configName rdf:type rdf:Property ;
    rdfs:label 'Config Name' ;
    rdfs:comment 'Human-readable name describing the hub-spoke configuration, typically including geographic scope and service type (e.g., \'APAC Express Hub-Spoke Q1 2024\').' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle status of the hub-spoke configuration. Only active configurations are used for operational route planning and shipment execution.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configVersion rdf:type rdf:Property ;
    rdfs:label 'Config Version' ;
    rdfs:comment 'Version number of this configuration. Incremented when the configuration is updated, supporting change tracking and audit trails.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Consolidation Cutoff Time' ;
    rdfs:comment 'Daily cutoff time (HH:MM format, hub local time) by which shipments must arrive at the hub to be included in the next consolidation cycle.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consolidationFrequency rdf:type rdf:Property ;
    rdfs:label 'Consolidation Frequency' ;
    rdfs:comment 'Frequency at which shipments are consolidated at the hub before distribution to spokes. Impacts inventory holding time and service level.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryScope rdf:type rdf:Property ;
    rdfs:label 'Country Scope' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes covered by this hub-spoke configuration. Defines the geographic boundary for customs and trade compliance.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required' ;
    rdfs:comment 'Indicates whether customs clearance is required at the hub for cross-border shipments in this configuration. Triggers Descartes Customs integration.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directLaneBypassEnabled rdf:type rdf:Property ;
    rdfs:label 'Direct Lane Bypass Enabled' ;
    rdfs:comment 'Indicates whether direct spoke-to-spoke or spoke-to-destination lanes are allowed when volume/weight thresholds are met, bypassing the hub.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftzZoneApplicable rdf:type rdf:Property ;
    rdfs:label 'Ftz Zone Applicable' ;
    rdfs:comment 'Indicates whether the hub operates within or has access to a Free Trade Zone, enabling duty deferral and trade compliance benefits.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hubCapacityPallets rdf:type rdf:Property ;
    rdfs:label 'Hub Capacity Pallets' ;
    rdfs:comment 'Maximum handling capacity of the hub in standard pallet positions. Relevant for LTL, parcel, and e-commerce fulfillment operations.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hubCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Hub Capacity Teu' ;
    rdfs:comment 'Maximum handling capacity of the hub in Twenty-foot Equivalent Units (TEU) for containerized freight. Used for capacity planning and network design.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxHubToSpokeTransitHours rdf:type rdf:Property ;
    rdfs:label 'Max Hub To Spoke Transit Hours' ;
    rdfs:comment 'Maximum allowable transit time in hours from the hub to any spoke node. Critical for On-Time Delivery (OTD) and On-Time In-Full (OTIF) performance.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxSpokeToHubTransitHours rdf:type rdf:Property ;
    rdfs:label 'Max Spoke To Hub Transit Hours' ;
    rdfs:comment 'Maximum allowable transit time in hours from any spoke node to the hub. Used for SLA validation, route planning, and network design optimization.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minVolumeThresholdCbm rdf:type rdf:Property ;
    rdfs:label 'Min Volume Threshold Cbm' ;
    rdfs:comment 'Minimum shipment volume in cubic meters (CBM) required to bypass the hub and establish a direct lane from spoke to destination. Used for load optimization and cost efficiency.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minWeightThresholdKg rdf:type rdf:Property ;
    rdfs:label 'Min Weight Threshold Kg' ;
    rdfs:comment 'Minimum shipment weight in kilograms required to qualify for direct lane bypass, avoiding hub consolidation. Supports FTL and FCL optimization logic.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkDesignModelCode rdf:type rdf:Property ;
    rdfs:label 'Network Design Model Code' ;
    rdfs:comment 'Reference to the Blue Yonder network design model or optimization run that generated or validated this hub-spoke configuration.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkRegion rdf:type rdf:Property ;
    rdfs:label 'Network Region' ;
    rdfs:comment 'Geographic region or market area covered by this hub-spoke configuration (e.g., \'North America\', \'APAC\', \'EU West\'). Used for regional network planning and optimization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationObjective rdf:type rdf:Property ;
    rdfs:label 'Optimization Objective' ;
    rdfs:comment 'Primary objective used by Blue Yonder and SAP TM for network optimization: minimize cost, maximize speed, maximize reliability, or balanced multi-objective.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictiveEtaEnabled rdf:type rdf:Property ;
    rdfs:label 'Predictive Eta Enabled' ;
    rdfs:comment 'Indicates whether predictive ETA calculation using FourKites or Blue Yonder is enabled for this configuration, supporting proactive exception management.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:realTimeVisibilityEnabled rdf:type rdf:Property ;
    rdfs:label 'Real Time Visibility Enabled' ;
    rdfs:comment 'Indicates whether FourKites real-time visibility tracking is enabled for shipments routed through this hub-spoke configuration.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceProductScope rdf:type rdf:Property ;
    rdfs:label 'Service Product Scope' ;
    rdfs:comment 'The service product line or business segment this hub-spoke configuration applies to. Determines operational rules, SLA targets, and routing logic.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetOtdPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Otd Percent' ;
    rdfs:comment 'Target On-Time Delivery percentage for shipments routed through this hub-spoke configuration. Used for performance monitoring and carrier evaluation.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetOtifPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Otif Percent' ;
    rdfs:comment 'Target On-Time In-Full percentage for shipments routed through this hub-spoke configuration. Measures both timeliness and completeness of delivery.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spokeCount rdf:type rdf:Property ;
    rdfs:label 'Spoke Count' ;
    rdfs:comment 'Total number of spoke nodes included in this hub-spoke configuration. Used for network complexity analysis and capacity planning.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spokeNodesList rdf:type rdf:Property ;
    rdfs:label 'Spoke Nodes List' ;
    rdfs:comment 'Comma-separated list of spoke node codes or identifiers that are served by this hub. Represents the delivery/pickup points connected to the hub in this configuration.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityTargetCo2eKgPerShipment rdf:type rdf:Property ;
    rdfs:label 'Sustainability Target Co2e Kg Per Shipment' ;
    rdfs:comment 'Target carbon emissions in CO2e kilograms per shipment for this hub-spoke configuration. Supports CORSIA and EU ETS compliance and sustainability reporting.' ;
    rdfs:domain ind:HubSpokeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedCarrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Contracted Carrier Service Id' ;
    rdfs:comment 'Foreign key linking to network.carrier_service. Business justification: Lanes are often contracted under specific carrier service products with defined service levels. Required for rate application during quoting, service-level routing decisions, and contracted service va' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:laneNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Lane Network Node Id' ;
    rdfs:comment 'Reference to the origin network node (city, port, airport, Inland Container Depot (ICD), Container Freight Station (CFS), or postal zone) from which this lane departs. Drives carrier selection and rate lookup in SAP TM.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:aeoRequired rdf:type rdf:Property ;
    rdfs:label 'Aeo Required' ;
    rdfs:comment 'Indicates whether Authorized Economic Operator (AEO) certification is required for carriers or shippers operating on this lane. Enforced during carrier selection in SAP TM and compliance screening in Descartes Customs.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blueYonderLaneCode rdf:type rdf:Property ;
    rdfs:label 'Blue Yonder Lane Code' ;
    rdfs:comment 'External lane identifier assigned by Blue Yonder Supply Chain Planning system for network optimization, demand forecasting, and inventory optimization workflows. Used for cross-system reconciliation between the lakehouse and Blue Yonder.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationUnlocode rdf:type rdf:Property ;
    rdfs:label 'Destination Unlocode' ;
    rdfs:comment 'United Nations Code for Trade and Transport Locations (UN/LOCODE) for the lane destination node. Used in EDI messages, Air Waybill (AWB), Master Bill of Lading (MBL), and Automated Manifest System (AMS) filings.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Miles' ;
    rdfs:comment 'Physical distance of the lane corridor in miles. Maintained alongside distance_km to support US DOT regulatory reporting and North American carrier rate negotiations where miles are the contractual unit.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediLaneCode rdf:type rdf:Property ;
    rdfs:label 'Edi Lane Code' ;
    rdfs:comment 'Lane identifier used in Electronic Data Interchange (EDI) messages exchanged with carriers, customs authorities, and trading partners. May differ from internal lane_code due to carrier-specific EDI mapping requirements.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzApplicable rdf:type rdf:Property ;
    rdfs:label 'Ftz Applicable' ;
    rdfs:comment 'Indicates whether this lane passes through or terminates in a Free Trade Zone (FTZ), enabling duty deferral, bonded warehouse processing, or re-export without full customs clearance. Managed in Descartes Customs.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCapacityFreeze rdf:type rdf:Property ;
    rdfs:label 'Is Capacity Freeze' ;
    rdfs:comment 'Indicates whether capacity on this lane is frozen, preventing new load optimization allocations. Set by Blue Yonder during peak season planning or carrier capacity constraint events. Synchronized to Oracle TMS for load optimization.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDgPermitted rdf:type rdf:Property ;
    rdfs:label 'Is Dg Permitted' ;
    rdfs:comment 'Indicates whether Dangerous Goods (DG) shipments are permitted on this lane. False triggers a DG prohibition restriction. Governed by IMDG Code for ocean, ICAO Technical Instructions for air, and ADR for road transport.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEmbargoActive rdf:type rdf:Property ;
    rdfs:label 'Is Embargo Active' ;
    rdfs:comment 'Indicates whether a trade or operational embargo is currently active on this lane, blocking new shipment bookings. Embargo status is managed in Descartes Customs and synchronized to SAP TM for carrier selection exclusion.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonalClosure rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal Closure' ;
    rdfs:comment 'Indicates whether this lane is subject to a seasonal closure (e.g., weather-related road closures, monsoon port restrictions). When True, the lane is excluded from carrier selection and route planning during the closure window.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneCode rdf:type rdf:Property ;
    rdfs:label 'Lane Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the lane, used in SAP TM and Oracle TMS for rate lookup, freight order management, and carrier selection. Serves as the canonical cross-system reference key.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneName rdf:type rdf:Property ;
    rdfs:label 'Lane Name' ;
    rdfs:comment 'Human-readable descriptive name for the lane, typically formatted as origin-destination pair (e.g., \'Shanghai Port – Los Angeles Port Ocean FCL\'). Used in reporting, carrier communications, and network planning dashboards.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Status' ;
    rdfs:comment 'Current operational lifecycle status of the lane. Active lanes are available for shipment booking and carrier allocation. Suspended lanes are temporarily unavailable. Under_review lanes are pending network optimization assessment in Blue Yonder.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneTier rdf:type rdf:Property ;
    rdfs:label 'Lane Tier' ;
    rdfs:comment 'Strategic tier classification of the lane based on volume, revenue contribution, and network criticality. Tier 1 lanes are high-volume strategic corridors; Tier 3 are low-frequency secondary lanes. Used by Blue Yonder for network optimization prioritization.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Classification of the lane by service category: express (time-definite premium), freight (standard bulk), last_mile (final delivery segment), cross_border (international), domestic (within-country), or multimodal (multiple transport modes). Drives SLA assignment and pricing tier in SAP TM. [ENUM-REF-CANDIDATE: express|freight|last_mile|cross_border|domestic|multimodal — promote to reference product]' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMileZoneCode rdf:type rdf:Property ;
    rdfs:label 'Last Mile Zone Code' ;
    rdfs:comment 'Delivery zone code for last-mile operations at the destination, used for postal zone routing, delivery slot assignment, and Door-to-Door (D2D) service configuration. Applicable when lane_type is \'last_mile\'.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originUnlocode rdf:type rdf:Property ;
    rdfs:label 'Origin Unlocode' ;
    rdfs:comment 'United Nations Code for Trade and Transport Locations (UN/LOCODE) for the lane origin node. Five-character code used in EDI (Electronic Data Interchange) messages, customs declarations, and Bill of Lading (BOL) documentation.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionAuthority rdf:type rdf:Property ;
    rdfs:label 'Restriction Authority' ;
    rdfs:comment 'Name of the regulatory body or internal authority that imposed the current lane restriction (e.g., \'IMO\', \'IATA\', \'US DOT\', \'WCO\', \'Internal Network Operations\'). Required for compliance audit and regulatory reporting.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionEffectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Restriction Effective From' ;
    rdfs:comment 'Date from which the current operational restriction on this lane becomes effective. Used by SAP TM to exclude the lane from carrier selection and by Descartes Customs for trade compliance enforcement.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionEffectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Restriction Effective Until' ;
    rdfs:comment 'Date on which the current operational restriction on this lane expires and normal operations resume. Null indicates an indefinite restriction. Monitored by Blue Yonder for network re-optimization upon restriction lift.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Categorical type of the most recently applied operational restriction on this lane. Used for exception reporting and compliance audit trails. Detailed restriction history is maintained in the lane_restriction event log.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapTmLaneCode rdf:type rdf:Property ;
    rdfs:label 'Sap Tm Lane Code' ;
    rdfs:comment 'External lane identifier from SAP TM (Transportation Management) used for route planning, freight order management, charge calculation, and carrier selection. Enables bidirectional synchronization between the Silver Layer and SAP TM.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Visibility Tracking Enabled' ;
    rdfs:comment 'Indicates whether FourKites real-time GPS/IoT shipment tracking and predictive ETA calculation is enabled for shipments on this lane. Drives exception management and proactive customer notification workflows.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Performance measurement records require analyst attribution for audit trail, data quality accountability, analysis methodology tracking, and performance review input. Supports network optimization tea' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:networkOptimizationRunId rdf:type rdf:Property ;
    rdfs:label 'Network Optimization Run Id' ;
    rdfs:comment 'Identifier of the Blue Yonder supply chain planning optimization run that produced or last updated the planned transit time and lane configuration for this measurement period. Supports traceability of network design decisions.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkOptimizationRun .

ind:actualTransitHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transit Hours' ;
    rdfs:comment 'The measured average actual transit time in hours for shipments on this lane during the measurement period. Sourced from FourKites actuals and Oracle TMS freight audit data. Compared against planned_transit_hours to derive delay.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgDelayHours rdf:type rdf:Property ;
    rdfs:label 'Avg Delay Hours' ;
    rdfs:comment 'Average number of hours by which shipments on this lane exceeded the planned transit time during the measurement period. Positive values indicate late delivery; negative values indicate early delivery. Key input for SLA breach analysis.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgDimWeightKg rdf:type rdf:Property ;
    rdfs:label 'Avg Dim Weight Kg' ;
    rdfs:comment 'Average dimensional (volumetric) weight in kilograms per shipment on this lane during the measurement period. DIM weight is used by carriers to price low-density shipments. Sourced from Oracle TMS freight audit.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgFreightCost rdf:type rdf:Property ;
    rdfs:label 'Avg Freight Cost' ;
    rdfs:comment 'Average freight cost per shipment on this lane during the measurement period, in the reporting currency. Sourced from Oracle TMS freight audit. Used for cost-per-lane benchmarking and network optimization analysis.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgShipmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Avg Shipment Weight Kg' ;
    rdfs:comment 'Average actual gross weight in kilograms per shipment on this lane during the measurement period. Used for load optimization, carrier rate benchmarking, and CO2e intensity calculations.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierInvoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Carrier Invoice Accuracy Rate' ;
    rdfs:comment 'Proportion of carrier invoices for shipments on this lane that matched the contracted rate without dispute during the measurement period. Sourced from Oracle TMS freight audit. Supports carrier financial performance evaluation.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Carrier Performance Score' ;
    rdfs:comment 'Composite carrier performance score for this lane-period, typically on a 0–100 scale, derived from OTD rate, OTIF rate, exception rate, and transit time adherence. Primary input for carrier scorecard and SAP TM carrier selection decisions.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2ePerShipmentKg rdf:type rdf:Property ;
    rdfs:label 'Co2e Per Shipment Kg' ;
    rdfs:comment 'Average CO2e emissions in kilograms per shipment on this lane during the measurement period. Calculated from fuel consumption, transport mode, and distance. Supports EU ETS, CORSIA, and GHG sustainability reporting.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsClearanceDelayHours rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Delay Hours' ;
    rdfs:comment 'Average hours of delay attributable to customs clearance processes for shipments on this lane during the measurement period. Sourced from Descartes Customs. Used for cross-border lane performance root cause analysis.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageRate rdf:type rdf:Property ;
    rdfs:label 'Damage Rate' ;
    rdfs:comment 'Proportion of shipments on this lane that incurred cargo damage during the measurement period, expressed as a decimal. Used for carrier liability assessment, insurance claims analysis, and lane risk scoring.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'Total number of shipment exceptions (delays, damages, misroutes, customs holds, etc.) recorded on this lane during the measurement period. Sourced from FourKites exception management. Triggers network optimization review.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionRate rdf:type rdf:Property ;
    rdfs:label 'Exception Rate' ;
    rdfs:comment 'Proportion of shipments on this lane that incurred at least one exception during the measurement period, expressed as a decimal (exception_count / shipment_count). Used for lane risk scoring and network optimization triggers.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:folioSource rdf:type rdf:Property ;
    rdfs:label 'Folio Source' ;
    rdfs:comment 'Identifies the primary operational system of record from which actuals for this lane-period measurement were sourced (FourKites, Oracle TMS, SAP TM, or manual entry). Supports data lineage and audit traceability.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foukitesTrackingCoverageRate rdf:type rdf:Property ;
    rdfs:label 'Foukites Tracking Coverage Rate' ;
    rdfs:comment 'Proportion of shipments on this lane that had active FourKites real-time GPS/IoT tracking during the measurement period. Low coverage rates may indicate data quality issues in actuals-based metrics.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMileDelayHours rdf:type rdf:Property ;
    rdfs:label 'Last Mile Delay Hours' ;
    rdfs:comment 'Average hours of delay attributable specifically to the last-mile delivery segment for shipments on this lane during the measurement period. Enables root cause decomposition of total delay into linehaul vs. last-mile components.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkOptimizationTrigger rdf:type rdf:Property ;
    rdfs:label 'Network Optimization Trigger' ;
    rdfs:comment 'Indicates whether this lane-period measurement has triggered a network optimization review in Blue Yonder based on SLA breach, high exception rate, or cost threshold exceedance. True = optimization review triggered.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeShipmentCount rdf:type rdf:Property ;
    rdfs:label 'On Time Shipment Count' ;
    rdfs:comment 'Number of shipments on this lane that were delivered on or before the planned delivery date/time during the measurement period. Numerator for OTD rate calculation.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otifRate rdf:type rdf:Property ;
    rdfs:label 'Otif Rate' ;
    rdfs:comment 'Proportion of shipments on this lane delivered both on time and in full (no quantity shortfall) during the measurement period, expressed as a decimal. Composite SLA metric used for customer contract compliance and carrier evaluation.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTransitHours rdf:type rdf:Property ;
    rdfs:label 'Planned Transit Hours' ;
    rdfs:comment 'The contracted or standard planned transit time in hours for this lane as defined in the SLA or service corridor standard. Sourced from SAP TM route planning master data. Baseline for OTD and delay calculations.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Pod Completion Rate' ;
    rdfs:comment 'Proportion of shipments on this lane for which an electronic Proof of Delivery (ePOD) was captured and confirmed during the measurement period. Supports compliance with customer SLA documentation requirements.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictiveEtaAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Predictive Eta Accuracy Rate' ;
    rdfs:comment 'Proportion of shipments on this lane for which FourKites\' predictive ETA was within the agreed tolerance window of the actual delivery time during the measurement period. Measures the reliability of the real-time visibility platform\'s ETA predictions.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaThresholdOtd rdf:type rdf:Property ;
    rdfs:label 'Sla Threshold Otd' ;
    rdfs:comment 'The contracted minimum OTD rate threshold for this lane as defined in the applicable SLA or carrier agreement, expressed as a decimal (e.g., 0.9500 = 95%). Used to determine SLA compliance status for the period.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'The native record identifier from the operational source system (FourKites or Oracle TMS) from which this lane-period measurement was extracted. Enables back-tracing to the system of record for audit and reconciliation.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Total Co2e Kg' ;
    rdfs:comment 'Total CO2e emissions in kilograms for all shipments on this lane during the measurement period. Aggregate of co2e_per_shipment_kg × shipment_count. Used for sustainability reporting and carbon offset calculations.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFreightCost rdf:type rdf:Property ;
    rdfs:label 'Total Freight Cost' ;
    rdfs:comment 'Total freight cost for all shipments on this lane during the measurement period, in the reporting currency. Sourced from Oracle TMS freight audit and SAP S/4HANA Finance. Used for P&L lane-level cost analysis.' ;
    rdfs:domain ind:LanePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blueYonderNodeCode rdf:type rdf:Property ;
    rdfs:label 'Blue Yonder Node Code' ;
    rdfs:comment 'Node identifier as defined in Blue Yonder Supply Chain Planning for network design, demand forecasting, and inventory optimization models. Used to synchronize network topology between the lakehouse silver layer and Blue Yonder planning outputs.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgHandlingEnabled rdf:type rdf:Property ;
    rdfs:label 'Dg Handling Enabled' ;
    rdfs:comment 'Indicates whether the node is certified and equipped to handle Dangerous Goods (DG) shipments. True = DG-certified facility. Used in SAP TM carrier and route selection to ensure DG shipments are only routed through compliant nodes per IMDG Code and ICAO Technical Instructions.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:folioVisibilityCode rdf:type rdf:Property ;
    rdfs:label 'Folio Visibility Code' ;
    rdfs:comment 'Location identifier assigned to this node in the FourKites Real-Time Visibility Platform. Used to correlate network node records with live shipment tracking events, predictive ETA calculations, and exception alerts from FourKites.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Handling Capacity Cbm' ;
    rdfs:comment 'Maximum volumetric throughput capacity of the node measured in Cubic Meters (CBM) per day. Used for load optimization in Oracle TMS, capacity planning in Blue Yonder, and network bottleneck analysis.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hubTier rdf:type rdf:Property ;
    rdfs:label 'Hub Tier' ;
    rdfs:comment 'Hierarchical tier of the node within the hub-and-spoke network topology. \'primary\' = global mega-hub (e.g., main international gateway); \'secondary\' = regional hub; \'tertiary\' = country-level distribution center; \'spoke\' = local delivery depot. Drives routing hierarchy in SAP TM and Blue Yonder network design.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoAirportCode rdf:type rdf:Property ;
    rdfs:label 'Icao Airport Code' ;
    rdfs:comment 'Four-letter ICAO airport designator for air cargo terminal nodes (e.g., \'VHHH\' for Hong Kong International). Used for air freight routing, MAWB/HAWB coding, and ICAO regulatory compliance. Null for non-airport nodes.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoPortCode rdf:type rdf:Property ;
    rdfs:label 'Imo Port Code' ;
    rdfs:comment 'Seven-digit IMO port facility code assigned to sea port nodes. Used for ocean freight Bill of Lading (BOL) routing, vessel manifest filing, and IMO regulatory compliance reporting. Null for non-port nodes.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known, human-readable unique business code assigned to the node (e.g., \'HKG-HUB-01\', \'SIN-CFS-02\'). Used as the operational reference key in SAP TM route planning, Blue Yonder network design, and FourKites visibility integration.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Full descriptive name of the network node (e.g., \'Hong Kong International Gateway Hub\', \'Singapore Container Freight Station\'). Used in operational reports, carrier communications, and customer-facing shipment tracking.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of the network node. Controls whether the node is available for route planning and shipment assignment in SAP TM and Oracle TMS. \'active\' = fully operational; \'inactive\' = temporarily not in use; \'suspended\' = operations halted pending review; \'under_construction\' = not yet operational; \'decommissioned\' = permanently retired from the network.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the node by its operational role in the transport network. Drives hub-and-spoke topology logic in SAP TM and Blue Yonder. Values: hub (major consolidation/distribution center), gateway (international entry/exit point), sorting_center (parcel sorting facility), warehouse (storage and fulfillment), port (sea port terminal), airport (air cargo terminal), icd (Inland Container Depot), cfs (Container Freight Station), ftz (Free Trade Zone), last_mile_depot (final delivery depot). [ENUM-REF-CANDIDATE: hub|gateway|sorting_center|warehouse|port|airport|icd|cfs|ftz|last_mile_depot — promote to reference product]' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDays rdf:type rdf:Property ;
    rdfs:label 'Operating Days' ;
    rdfs:comment 'Comma-separated list of operating days using ISO weekday abbreviations (e.g., \'MON,TUE,WED,THU,FRI\' or \'MON,TUE,WED,THU,FRI,SAT\'). Used for freight scheduling, carrier dispatch planning, and SLA transit time calculation in SAP TM.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversizedCargoEnabled rdf:type rdf:Property ;
    rdfs:label 'Oversized Cargo Enabled' ;
    rdfs:comment 'Indicates whether the node has the equipment and infrastructure to handle oversized or out-of-gauge cargo (e.g., heavy lift cranes, wide-load bays). True = oversized cargo capable. Used in SAP TM special cargo routing.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentNodeCode rdf:type rdf:Property ;
    rdfs:label 'Parent Node Code' ;
    rdfs:comment 'Node code of the parent node in the hub-and-spoke hierarchy (e.g., a spoke depot\'s parent is its regional hub). Enables hierarchical network topology traversal for route planning and network performance roll-up reporting. Self-referencing relationship resolved in the linking step.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tempRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temp Range Max Celsius' ;
    rdfs:comment 'Maximum temperature in degrees Celsius that the node\'s temperature-controlled facility can maintain (e.g., 8.00 for refrigerated). Null if temperature_controlled is False. Used for cold-chain shipment routing and cargo integrity compliance.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temp Range Min Celsius' ;
    rdfs:comment 'Minimum temperature in degrees Celsius that the node\'s temperature-controlled facility can maintain (e.g., -25.00 for deep freeze). Null if temperature_controlled is False. Used for cold-chain shipment routing and SLA compliance validation.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timezoneCode rdf:type rdf:Property ;
    rdfs:label 'Timezone Code' ;
    rdfs:comment 'IANA time zone identifier for the node\'s local time zone (e.g., \'Asia/Hong_Kong\', \'America/New_York\', \'Europe/London\'). Critical for accurate ETD/ETA calculation, operating hours enforcement in SAP TM, and SLA compliance measurement across time zones.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Tms Location Code' ;
    rdfs:comment 'Location identifier code as registered in SAP TM and Oracle TMS for route planning, freight order management, and carrier selection. Serves as the cross-system reference key for transport execution systems.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Wms Facility Code' ;
    rdfs:comment 'Facility identifier code as registered in Manhattan WMS for nodes that perform warehousing and fulfillment operations. Used to link network node records to WMS inventory, labor, and slotting data. Null for non-warehouse nodes.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Algorithm Version' ;
    rdfs:comment 'Version identifier of the optimization algorithm or solver used for this run, enabling reproducibility and audit trail.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineAverageTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Baseline Average Transit Time Hours' ;
    rdfs:comment 'Network-wide average transit time in hours under current configuration, weighted by shipment volume.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineCapacityUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Baseline Capacity Utilization Percentage' ;
    rdfs:comment 'Average network capacity utilization under current configuration, calculated as actual volume divided by available capacity.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineCo2eEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Baseline Co2e Emissions Kg' ;
    rdfs:comment 'Total greenhouse gas emissions in kilograms of CO2 equivalent under current network configuration, calculated per GLEC Framework.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineTotalCost rdf:type rdf:Property ;
    rdfs:label 'Baseline Total Cost' ;
    rdfs:comment 'Total network operating cost under the current configuration before optimization, used as the comparison baseline.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carriersEvaluatedCount rdf:type rdf:Property ;
    rdfs:label 'Carriers Evaluated Count' ;
    rdfs:comment 'Number of carrier partners considered for lane allocation and capacity planning in this run.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:co2eReductionKg rdf:type rdf:Property ;
    rdfs:label 'Co2e Reduction Kg' ;
    rdfs:comment 'Reduction in greenhouse gas emissions achieved by the optimization, supporting sustainability reporting and CORSIA compliance.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eReductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Co2e Reduction Percentage' ;
    rdfs:comment 'Emissions reduction expressed as a percentage of baseline emissions, used for ESG reporting and EU ETS compliance.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constraintsCount rdf:type rdf:Property ;
    rdfs:label 'Constraints Count' ;
    rdfs:comment 'Total number of business and operational constraints applied in the optimization model (capacity limits, SLA requirements, carrier contracts, etc.).' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:convergenceStatus rdf:type rdf:Property ;
    rdfs:label 'Convergence Status' ;
    rdfs:comment 'Mathematical convergence state of the optimization solver, indicating solution quality and completeness.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Savings Amount' ;
    rdfs:comment 'Calculated difference between baseline and optimized total cost, representing potential savings from implementing recommendations.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costSavingsPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Savings Percentage' ;
    rdfs:comment 'Cost savings expressed as a percentage of baseline cost, used for executive reporting and ROI analysis.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from start to completion of the optimization run, used for performance monitoring and capacity planning.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iterationsCount rdf:type rdf:Property ;
    rdfs:label 'Iterations Count' ;
    rdfs:comment 'Number of solver iterations performed during optimization, used for performance analysis and tuning.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lanesEvaluatedCount rdf:type rdf:Property ;
    rdfs:label 'Lanes Evaluated Count' ;
    rdfs:comment 'Total number of origin-destination lane combinations analyzed during this optimization run.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nodesEvaluatedCount rdf:type rdf:Property ;
    rdfs:label 'Nodes Evaluated Count' ;
    rdfs:comment 'Total number of network nodes (hubs, terminals, distribution centers, cross-docks) included in the optimization scope.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objectiveFunction rdf:type rdf:Property ;
    rdfs:label 'Objective Function' ;
    rdfs:comment 'Mathematical expression or description of the optimization goal (e.g., \'Minimize total network cost\', \'Minimize CO2e emissions while maintaining SLA\', \'Maximize capacity utilization\').' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimalityGapPercentage rdf:type rdf:Property ;
    rdfs:label 'Optimality Gap Percentage' ;
    rdfs:comment 'Percentage difference between the best solution found and the theoretical optimal solution, indicating solution quality.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Optimization Horizon Days' ;
    rdfs:comment 'Number of days into the future that the optimization considers for planning purposes (e.g., 30, 90, 365 days).' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimizationType rdf:type rdf:Property ;
    rdfs:label 'Optimization Type' ;
    rdfs:comment 'Category of optimization objective being pursued in this run. Determines the primary goal and algorithm configuration.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizedAverageTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Optimized Average Transit Time Hours' ;
    rdfs:comment 'Projected network-wide average transit time in hours if recommendations are implemented.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizedCapacityUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Optimized Capacity Utilization Percentage' ;
    rdfs:comment 'Projected average network capacity utilization if recommendations are implemented, indicating efficiency improvement.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizedCo2eEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Optimized Co2e Emissions Kg' ;
    rdfs:comment 'Projected greenhouse gas emissions in kilograms of CO2 equivalent if optimization recommendations are implemented.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Optimized Total Cost' ;
    rdfs:comment 'Projected total network operating cost if all recommendations from this run are implemented.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputVersion rdf:type rdf:Property ;
    rdfs:label 'Output Version' ;
    rdfs:comment 'Version identifier for the output dataset and recommendations produced by this run, enabling version control and rollback.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning End Date' ;
    rdfs:comment 'Last date of the planning period covered by this optimization run.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Start Date' ;
    rdfs:comment 'First date of the planning period covered by this optimization run.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendationsGeneratedCount rdf:type rdf:Property ;
    rdfs:label 'Recommendations Generated Count' ;
    rdfs:comment 'Total number of network change recommendations produced by this optimization run.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-text field for capturing business context, special considerations, or explanatory notes about this optimization run.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioCode rdf:type rdf:Property ;
    rdfs:label 'Scenario Code' ;
    rdfs:comment 'Reference to the optimization scenario configuration that defines the business context, constraints, and parameters for this run.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Descriptive name of the optimization scenario (e.g., \'Q4 Peak Season Network\', \'Cost Reduction Initiative 2024\', \'Carbon Neutral Routing\').' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceBaselinePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Baseline Percentage' ;
    rdfs:comment 'Percentage of shipments meeting SLA commitments under current network configuration, used as optimization constraint.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaComplianceOptimizedPercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Optimized Percentage' ;
    rdfs:comment 'Projected SLA compliance percentage if recommendations are implemented, ensuring service quality is maintained or improved.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solverEngine rdf:type rdf:Property ;
    rdfs:label 'Solver Engine' ;
    rdfs:comment 'Name of the mathematical optimization solver engine used (e.g., \'CPLEX\', \'Gurobi\', \'Blue Yonder Proprietary\').' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeImprovementHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Improvement Hours' ;
    rdfs:comment 'Reduction in average transit time achieved by the optimization, expressed in hours.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variablesCount rdf:type rdf:Property ;
    rdfs:label 'Variables Count' ;
    rdfs:comment 'Total number of decision variables in the optimization model, indicating problem complexity.' ;
    rdfs:domain ind:NetworkOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimizationRecommendationId rdf:type rdf:Property ;
    rdfs:label 'Optimization Recommendation Id' ;
    rdfs:comment 'Unique identifier for the network optimization recommendation. Primary key.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedDepotId rdf:type rdf:Property ;
    rdfs:label 'Affected Depot Id' ;
    rdfs:comment 'Foreign key linking to fleet.fleet_depot. Business justification: Network optimization recommendations (hub relocation, lane changes, capacity adjustments) affect specific depots; linking enables impact analysis on depot capacity, catchment areas, and operational fe' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:affectedLaneId rdf:type rdf:Property ;
    rdfs:label 'Affected Lane Id' ;
    rdfs:comment 'Reference to the origin-destination lane that this recommendation impacts. Null for hub-level or network-wide recommendations.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:implementationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Implementation Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Network optimization recommendations require designated implementation owner for project accountability, progress tracking, cross-functional coordination, and benefits realization measurement. Distinc' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryOptimizationCurrentCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Optimization Current Carrier Id' ;
    rdfs:comment 'Reference to the carrier currently assigned to the affected lane. Applicable for carrier reallocation recommendations.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:primaryOptimizationNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Optimization Network Node Id' ;
    rdfs:comment 'Reference to the origin location for lane-based recommendations. Null for non-lane recommendations.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:recommendedCarrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Recommended Carrier Service Id' ;
    rdfs:comment 'Foreign key linking to network.carrier_service. Business justification: Network optimization recommendations propose specific service-level changes (switch from express to economy, not just carrier changes). Required for accurate cost-benefit analysis, service-level impac' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:actionDetail rdf:type rdf:Property ;
    rdfs:label 'Action Detail' ;
    rdfs:comment 'Specific operational steps required to implement the recommendation, including system changes, contract modifications, and operational adjustments.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCo2eImpactKg rdf:type rdf:Property ;
    rdfs:label 'Actual Co2e Impact Kg' ;
    rdfs:comment 'Realized annual greenhouse gas emissions impact measured after implementation, used for sustainability reporting and model validation.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCostImpact rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Impact' ;
    rdfs:comment 'Realized annual cost impact measured after implementation, used for model accuracy validation and continuous improvement. In USD.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualTransitTimeImpactHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transit Time Impact Hours' ;
    rdfs:comment 'Realized transit time change measured after implementation, used for model accuracy validation and continuous improvement.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualVolumeForecast rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Forecast' ;
    rdfs:comment 'Projected annual shipment volume for the affected lane or corridor, used to calculate total cost impact.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eImpactPerShipmentKg rdf:type rdf:Property ;
    rdfs:label 'Co2e Impact Per Shipment Kg' ;
    rdfs:comment 'Net change in greenhouse gas emissions per shipment (positive = increase, negative = reduction) resulting from the recommendation, in kilograms of CO2 equivalent.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Blue Yonder model confidence in the accuracy of projected impacts: high (>90% confidence), medium (70-90%), or low (<70%).' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactPerShipment rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Per Shipment' ;
    rdfs:comment 'Net change in cost per shipment (positive = cost increase, negative = cost savings) resulting from the recommendation, in USD.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentCo2ePerShipmentKg rdf:type rdf:Property ;
    rdfs:label 'Current Co2e Per Shipment Kg' ;
    rdfs:comment 'Baseline greenhouse gas emissions per shipment in kilograms of CO2 equivalent under current network configuration.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentCostPerShipment rdf:type rdf:Property ;
    rdfs:label 'Current Cost Per Shipment' ;
    rdfs:comment 'Baseline average cost per shipment under current network configuration, in USD.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Current Transit Time Hours' ;
    rdfs:comment 'Baseline transit time in hours for the affected lane or corridor under current network configuration.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date when the recommendation was formally accepted, rejected, or cancelled by the decision maker.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionMaker rdf:type rdf:Property ;
    rdfs:label 'Decision Maker' ;
    rdfs:comment 'Name or role of the business stakeholder responsible for approving or rejecting the recommendation.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Business justification for accepting, rejecting, or cancelling the recommendation, including strategic considerations and constraints.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedImplementationDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Implementation Days' ;
    rdfs:comment 'Projected number of calendar days required to fully implement the recommendation from approval to operationalization.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completion Date' ;
    rdfs:comment 'Date when the recommendation was fully operationalized and the network change became effective.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationComplexity rdf:type rdf:Property ;
    rdfs:label 'Implementation Complexity' ;
    rdfs:comment 'Estimated operational complexity of implementing the recommendation: simple (configuration change only), moderate (requires contract or process changes), or complex (requires infrastructure or multi-party coordination).' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationPriority rdf:type rdf:Property ;
    rdfs:label 'Implementation Priority' ;
    rdfs:comment 'Business priority for implementing the recommendation: critical (immediate action required), high (implement within quarter), medium (implement within year), or low (consider for future planning).' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStartDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Start Date' ;
    rdfs:comment 'Date when implementation activities began for accepted recommendations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityScore rdf:type rdf:Property ;
    rdfs:label 'Priority Score' ;
    rdfs:comment 'Numeric priority ranking (1-100) calculated by Blue Yonder based on cost impact, service impact, and strategic alignment. Higher scores indicate higher priority.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendationDescription rdf:type rdf:Property ;
    rdfs:label 'Recommendation Description' ;
    rdfs:comment 'Detailed narrative explanation of the recommended network change, including rationale and expected business impact.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationNumber rdf:type rdf:Property ;
    rdfs:label 'Recommendation Number' ;
    rdfs:comment 'Human-readable business identifier for the recommendation, formatted as REC- followed by 10 digits.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationStatus rdf:type rdf:Property ;
    rdfs:label 'Recommendation Status' ;
    rdfs:comment 'Current lifecycle state of the recommendation: pending (awaiting review), under_review (being evaluated), accepted (approved for implementation), rejected (declined), implemented (operationalized), or cancelled (withdrawn).' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationType rdf:type rdf:Property ;
    rdfs:label 'Recommendation Type' ;
    rdfs:comment 'Category of network change being recommended: add lane (new origin-destination pair), remove lane (discontinue service), change hub (modify hub assignment), reallocate carrier (switch carrier on lane), adjust transit time (modify service level), or consolidate route (merge multiple routes).' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedCo2ePerShipmentKg rdf:type rdf:Property ;
    rdfs:label 'Recommended Co2e Per Shipment Kg' ;
    rdfs:comment 'Projected greenhouse gas emissions per shipment in kilograms of CO2 equivalent if the recommendation is implemented.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedCostPerShipment rdf:type rdf:Property ;
    rdfs:label 'Recommended Cost Per Shipment' ;
    rdfs:comment 'Projected average cost per shipment if the recommendation is implemented, in USD.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Recommended Transit Time Hours' ;
    rdfs:comment 'Projected transit time in hours if the recommendation is implemented.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAnnualCo2eImpactKg rdf:type rdf:Property ;
    rdfs:label 'Total Annual Co2e Impact Kg' ;
    rdfs:comment 'Projected total annual greenhouse gas emissions impact across all shipments, in kilograms of CO2 equivalent.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAnnualCostImpact rdf:type rdf:Property ;
    rdfs:label 'Total Annual Cost Impact' ;
    rdfs:comment 'Projected total annual cost impact (positive = cost increase, negative = cost savings) across all shipments, in USD.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeImpactHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Impact Hours' ;
    rdfs:comment 'Net change in transit time (positive = slower, negative = faster) resulting from the recommendation.' ;
    rdfs:domain ind:OptimizationRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servicingAgentId rdf:type rdf:Property ;
    rdfs:label 'Servicing Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Last-mile delivery zones are frequently serviced by local agents. Required for agent commission calculation, service coverage validation, and agent performance tracking. Essential for agent-based dist' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:servingDepotId rdf:type rdf:Property ;
    rdfs:label 'Serving Depot Id' ;
    rdfs:comment 'Foreign key linking to fleet.fleet_depot. Business justification: Delivery zones are served from specific depots; linking enables territory management, last-mile route planning, depot workload balancing, and service coverage analysis.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:applicableServiceProducts rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Products' ;
    rdfs:comment 'Pipe-separated list of service product codes eligible for delivery within this zone (e.g., \'EXPRESS|STANDARD|ECONOMY|FREIGHT\'). Drives service product availability validation during shipment booking and carrier selection in SAP TM. [ENUM-REF-CANDIDATE: promote to reference product for zone-service-product association]' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqkm rdf:type rdf:Property ;
    rdfs:label 'Area Sqkm' ;
    rdfs:comment 'Total geographic area of the delivery zone in square kilometres. Used in network density analysis, carrier capacity planning, and cost-per-delivery benchmarking in Blue Yonder network design.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eFactorKgPerShipment rdf:type rdf:Property ;
    rdfs:label 'Co2e Factor Kg Per Shipment' ;
    rdfs:comment 'Estimated CO2e (Carbon Dioxide Equivalent) emission factor in kilograms per shipment for last-mile delivery within this zone. Used for GHG (Greenhouse Gas) emissions reporting, EU ETS compliance, and CORSIA carbon offsetting calculations.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codRestricted rdf:type rdf:Property ;
    rdfs:label 'Cod Restricted' ;
    rdfs:comment 'Indicates whether Cash on Delivery (COD) service is restricted or unavailable within this delivery zone. COD restrictions may apply due to security concerns, carrier capability limitations, or local regulatory requirements. Referenced during e-commerce fulfillment order validation.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageGeojson rdf:type rdf:Property ;
    rdfs:label 'Coverage Geojson' ;
    rdfs:comment 'GeoJSON-encoded polygon or multipolygon representing the precise geographic boundary of the delivery zone. Used for GPS-based serviceability validation, FourKites real-time visibility geofencing, and last-mile dispatch optimization. Stored as serialized GeoJSON string per RFC 7946.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsZoneType rdf:type rdf:Property ;
    rdfs:label 'Customs Zone Type' ;
    rdfs:comment 'Classification of the zone from a customs and trade compliance perspective: domestic (standard domestic territory), ftz (Free Trade Zone), bonded (customs bonded area), international (cross-border delivery zone), special_economic (Special Economic Zone). Used in Descartes Customs for trade compliance routing and ISF/AMS filing requirements.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgRestricted rdf:type rdf:Property ;
    rdfs:label 'Dg Restricted' ;
    rdfs:comment 'Indicates whether the transport of dangerous goods (DG) is restricted or prohibited within this delivery zone. Enforced during shipment booking validation and carrier selection. Aligned with IMDG Code, ICAO Technical Instructions, and local regulatory requirements.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hubNodeCode rdf:type rdf:Property ;
    rdfs:label 'Hub Node Code' ;
    rdfs:comment 'Code of the hub, depot, or distribution center assigned to service this delivery zone in the hub-and-spoke network topology. Drives carrier selection, load optimization, and last-mile dispatch routing in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfRequired rdf:type rdf:Property ;
    rdfs:label 'Isf Required' ;
    rdfs:comment 'Indicates whether an Importer Security Filing (ISF) is required for shipments entering this zone. Applicable to US import zones under CBP 10+2 rule. Used in Descartes Customs for automated compliance filing.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDimWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Dim Weight Kg' ;
    rdfs:comment 'Maximum dimensional weight (DIM weight) in kilograms accepted for delivery within this zone. DIM weight is calculated from volumetric dimensions and used alongside actual weight for carrier charge calculation and capacity planning.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLengthCm rdf:type rdf:Property ;
    rdfs:label 'Max Length Cm' ;
    rdfs:comment 'Maximum allowable length in centimetres for a single shipment piece accepted for delivery within this zone. Used in oversized shipment validation during booking and load optimization in Oracle TMS.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oversizedRestricted rdf:type rdf:Property ;
    rdfs:label 'Oversized Restricted' ;
    rdfs:comment 'Indicates whether oversized or overweight shipments are restricted within this delivery zone due to infrastructure limitations, road access constraints, or local regulations. Used in load optimization and carrier selection in Oracle TMS.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakSurcharge rdf:type rdf:Property ;
    rdfs:label 'Peak Surcharge' ;
    rdfs:comment 'Indicates whether a peak season surcharge is applicable for this zone during designated peak periods (e.g., holiday season, Chinese New Year). Drives dynamic pricing adjustments in SAP TM charge calculation.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCodeFrom rdf:type rdf:Property ;
    rdfs:label 'Postal Code From' ;
    rdfs:comment 'Starting postal code of the range covered by this delivery zone. Together with postal_code_to, defines the postal code band for zone membership evaluation. Used in SAP TM zone-based routing and pricing surcharge determination.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeTo rdf:type rdf:Property ;
    rdfs:label 'Postal Code To' ;
    rdfs:comment 'Ending postal code of the range covered by this delivery zone. Together with postal_code_from, defines the postal code band for zone membership evaluation. Null if the zone is defined by a single postal code or polygon only.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteAreaSurcharge rdf:type rdf:Property ;
    rdfs:label 'Remote Area Surcharge' ;
    rdfs:comment 'Indicates whether a remote area surcharge (RAS) applies to shipments delivered within this zone. Remote area surcharges are applied by carriers for zones with limited accessibility or extended delivery routes. Referenced by the pricing and rating domain for charge calculation.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialSurcharge rdf:type rdf:Property ;
    rdfs:label 'Residential Surcharge' ;
    rdfs:comment 'Indicates whether a residential delivery surcharge applies to shipments within this zone. Residential surcharges are levied by carriers for deliveries to non-commercial addresses. Used in pricing and rating charge calculation for B2C and e-commerce fulfillment.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Service Cutoff Time' ;
    rdfs:comment 'Latest time of day (HH:MM, 24-hour local time) by which a shipment must be tendered to the hub to achieve the standard transit time for this zone. Critical for last-mile dispatch scheduling and customer booking cutoff enforcement.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceable rdf:type rdf:Property ;
    rdfs:label 'Serviceable' ;
    rdfs:comment 'Master serviceability flag indicating whether Transport Shipping currently provides delivery service within this zone. A zone may be defined but temporarily unserviceable due to operational, regulatory, or capacity constraints. Used as the primary gate in shipment booking serviceability checks.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaStandardCode rdf:type rdf:Property ;
    rdfs:label 'Sla Standard Code' ;
    rdfs:comment 'Code referencing the standard SLA profile applicable to this delivery zone. Defines OTD (On-Time Delivery) and OTIF (On-Time In-Full) performance targets. Used in SLA entitlement validation and KPI reporting.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneGroupCode rdf:type rdf:Property ;
    rdfs:label 'Zone Group Code' ;
    rdfs:comment 'Code of the zone group or zone cluster to which this delivery zone belongs. Zone groups aggregate individual zones for pricing rate card application, carrier contract negotiation, and network planning. Used in SAP TM zone group configuration.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneTier rdf:type rdf:Property ;
    rdfs:label 'Zone Tier' ;
    rdfs:comment 'Service tier classification of the zone reflecting delivery density, infrastructure quality, and cost profile (e.g., tier_1 = major urban centre, tier_4 = remote/rural). Used in pricing rate card assignment, SLA differentiation, and network optimization in Blue Yonder.' ;
    rdfs:domain ind:RouteDeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingAgentId rdf:type rdf:Property ;
    rdfs:label 'Handling Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Agents handle exception resolution in their assigned territories (customs delays, delivery failures, etc.). Required for agent performance tracking, escalation workflows, and agent accountability in e' ;
    rdfs:domain ind:RouteException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:planLegId rdf:type rdf:Property ;
    rdfs:label 'Plan Leg Id' ;
    rdfs:comment 'Reference to the specific route plan leg affected by this exception. A route plan may have multiple legs; this identifies the precise leg in deviation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanLeg .

ind:affectedCountryCode rdf:type rdf:Property ;
    rdfs:label 'Affected Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the route exception occurred. Used for geographic exception analytics, regulatory reporting, and cross-border compliance tracking.' ;
    rdfs:domain ind:RouteException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Usd' ;
    rdfs:comment 'Estimated or actual incremental cost incurred as a result of the route exception, expressed in US Dollars (USD). Includes carrier surcharges, expedite fees, re-routing costs, and storage charges. Used for P&L impact analysis and OPEX reporting.' ;
    rdfs:domain ind:RouteException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Reference' ;
    rdfs:comment 'Identifier of the Electronic Data Interchange (EDI) transaction (e.g., EDI 214 Transportation Carrier Shipment Status Message) from the carrier that reported this exception. Null if exception source is not carrier_edi.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionSource rdf:type rdf:Property ;
    rdfs:label 'Exception Source' ;
    rdfs:comment 'System or channel through which the route exception was detected and raised. FourKites provides real-time GPS-based detection; carrier EDI provides carrier-reported events; manual indicates operations team entry. [ENUM-REF-CANDIDATE: fourkites|carrier_edi|manual|sap_tm|oracle_tms|iot_sensor|blue_yonder — promote to reference product]' ;
    rdfs:domain ind:RouteException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fourkitesEventCode rdf:type rdf:Property ;
    rdfs:label 'Fourkites Event Code' ;
    rdfs:comment 'External event identifier from the FourKites Real-Time Visibility Platform that triggered or corresponds to this route exception. Enables bi-directional traceability between the lakehouse exception record and the FourKites source event.' ;
    rdfs:domain ind:RouteException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEta rdf:type rdf:Property ;
    rdfs:label 'Planned Eta' ;
    rdfs:comment 'The originally planned Estimated Time of Arrival (ETA) at the destination of the affected route leg. Baseline for SLA breach determination and On-Time Delivery (OTD) KPI calculation.' ;
    rdfs:domain ind:RouteException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedEtd rdf:type rdf:Property ;
    rdfs:label 'Planned Etd' ;
    rdfs:comment 'The originally planned Estimated Time of Departure (ETD) for the affected route leg as defined in the route plan. Baseline for delay calculation and SLA compliance measurement.' ;
    rdfs:domain ind:RouteException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recoveryCostUsd rdf:type rdf:Property ;
    rdfs:label 'Recovery Cost Usd' ;
    rdfs:comment 'Cost incurred to execute the resolution action for the route exception, expressed in US Dollars (USD). Distinct from exception_cost_usd which captures the impact cost; this captures the remediation spend.' ;
    rdfs:domain ind:RouteException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionActionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Type' ;
    rdfs:comment 'Categorical classification of the resolution action taken, enabling structured analytics on exception resolution patterns and carrier/network performance improvement initiatives.' ;
    rdfs:domain ind:RouteException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing granular detail within the exception type (e.g., under \'delay\': port_congestion, mechanical_failure, driver_shortage; under \'customs_hold\': documentation_error, inspection_hold). Supports root-cause analytics.' ;
    rdfs:domain ind:RouteException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Plan Network Node Id' ;
    rdfs:comment 'Reference to the starting location (warehouse, port, terminal, customer site) for this route plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Timestamp when this route plan was completed (final leg arrival at destination). Null if not yet completed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Timestamp when this route plan was confirmed and approved for execution. Null if plan is still in draft status. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationAddress rdf:type rdf:Property ;
    rdfs:label 'Destination Address' ;
    rdfs:comment 'Full address of the destination location including street, city, postal code, and country. Business-confidential organizational contact data.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Start Timestamp' ;
    rdfs:comment 'Timestamp when execution of this route plan began (first leg departure). Null if execution has not started. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:numberOfLegs rdf:type rdf:Property ;
    rdfs:label 'Number Of Legs' ;
    rdfs:comment 'Total number of transport legs (segments) in this route plan. Each leg represents movement between two consecutive nodes.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfStops rdf:type rdf:Property ;
    rdfs:label 'Number Of Stops' ;
    rdfs:comment 'Total number of intermediate stops (hubs, terminals, cross-docks) between origin and destination, excluding origin and destination.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originAddress rdf:type rdf:Property ;
    rdfs:label 'Origin Address' ;
    rdfs:comment 'Full address of the origin location including street, city, postal code, and country. Business-confidential organizational contact data.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the route plan: Draft (under planning), Confirmed (approved for execution), In Execution (actively being executed), Completed (successfully finished), Cancelled (terminated before completion), or Failed (execution unsuccessful).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Timestamp' ;
    rdfs:comment 'Planned Estimated Time of Arrival (ETA) at the destination location. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedCo2eEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Planned Co2e Emissions Kg' ;
    rdfs:comment 'Estimated total greenhouse gas emissions for this route plan, measured in kilograms of CO2 equivalent (CO2e). Used for sustainability reporting and carbon offsetting.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Amount' ;
    rdfs:comment 'Total planned cost for executing this route plan, including carrier charges, fuel surcharges, and terminal handling charges. Business-confidential financial data.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the planned cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Planning Source System' ;
    rdfs:comment 'System that generated this route plan: SAP TM (Transportation Management), Blue Yonder (Supply Chain Planning), Oracle TMS, or manual planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planning Timestamp' ;
    rdfs:comment 'Timestamp when this route plan was generated or last re-optimized by the planning system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresCustomsClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Customs Clearance' ;
    rdfs:comment 'Indicates whether this route plan requires customs brokerage and trade compliance processing. True if customs clearance is required, False otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPlannedDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Planned Distance Km' ;
    rdfs:comment 'Total planned distance for the entire route from origin to destination, measured in kilometers. Sum of all leg distances.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Planned Transit Time Hours' ;
    rdfs:comment 'Total planned transit time for the entire route from origin to destination, measured in hours. Includes transport time and planned dwell time at intermediate nodes.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPlanNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Plan Network Node Id' ;
    rdfs:comment 'Reference to the origin location node for this leg. Represents the departure point such as a warehouse, hub, terminal, or customer location.' ;
    rdfs:domain ind:PlanLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:vehicleTransportAssetId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Transport Asset Id' ;
    rdfs:comment 'Reference to the specific vehicle, vessel, or aircraft assigned to this leg. Links to fleet master data for trucks, containers, ships, or planes.' ;
    rdfs:domain ind:PlanLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportAsset .

ind:bookingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Booking Reference Number' ;
    rdfs:comment 'Carrier booking or reservation number for this leg. Used for ocean freight bookings, air freight reservations, and dedicated transport bookings.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Emissions Kg' ;
    rdfs:comment 'Estimated carbon dioxide equivalent (CO2e) emissions for this leg in kilograms. Calculated based on transport mode, distance, and load weight. Used for sustainability reporting and compliance with EU ETS and CORSIA.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Minutes' ;
    rdfs:comment 'Total delay time in minutes for this leg. Calculated as the difference between actual and planned arrival times. Null if leg arrived on time or early.' ;
    rdfs:domain ind:PlanLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Datetime' ;
    rdfs:comment 'Planned arrival date and time for this leg. Represents the scheduled ETA (Estimated Time of Arrival) at the destination node.' ;
    rdfs:domain ind:PlanLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:awbPrefix rdf:type rdf:Property ;
    rdfs:label 'Awb Prefix' ;
    rdfs:comment 'Three-digit IATA Air Waybill (AWB) prefix assigned to the primary carrier operating this air corridor. Applicable only for AIR transport mode corridors. Used for MAWB (Master Air Waybill) and HAWB (House Air Waybill) number generation in SAP TM.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScacCodes rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Codes' ;
    rdfs:comment 'Comma-separated list of Standard Carrier Alpha Codes (SCAC) or IATA carrier codes for carriers allocated to operate on this corridor. Used in SAP TM carrier selection and Oracle TMS freight audit. Supports multi-carrier corridor configurations.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorCode rdf:type rdf:Property ;
    rdfs:label 'Corridor Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the service corridor, used in SAP TM route planning and Blue Yonder network design (e.g., \'APAC-AIR-EXP-01\', \'TPAC-OCN-FCL-02\'). Referenced in EDI messages and carrier lane allocations.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorName rdf:type rdf:Property ;
    rdfs:label 'Corridor Name' ;
    rdfs:comment 'Human-readable name of the service corridor describing the route path and service product (e.g., \'Express Air Asia-Pacific\', \'Ocean FCL Trans-Pacific\', \'Road FTL Europe Central\'). Used in operational dashboards, carrier communications, and Blue Yonder network design outputs.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorStatus rdf:type rdf:Property ;
    rdfs:label 'Corridor Status' ;
    rdfs:comment 'Current operational lifecycle status of the service corridor. ACTIVE corridors are available for shipment routing in SAP TM. SUSPENDED corridors are temporarily unavailable (e.g., due to port congestion, regulatory hold). PLANNED corridors are in network design phase in Blue Yonder. DISCONTINUED corridors are archived.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationHubCode rdf:type rdf:Property ;
    rdfs:label 'Destination Hub Code' ;
    rdfs:comment 'IATA airport code or UN/LOCODE of the primary destination hub node for this corridor (e.g., \'LHR\' for London Heathrow, \'USLAX\' for Los Angeles). Anchors the corridor\'s terminal network node in SAP TM route planning and FourKites real-time visibility.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directionType rdf:type rdf:Property ;
    rdfs:label 'Direction Type' ;
    rdfs:comment 'Indicates whether the corridor is defined for outbound (origin to destination), inbound (destination to origin), or bilateral (both directions) traffic flow. Drives lane allocation and backhaul optimization in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightProduct rdf:type rdf:Property ;
    rdfs:label 'Freight Product' ;
    rdfs:comment 'Specific freight product type carried on this corridor. FCL (Full Container Load), LCL (Less than Container Load), FTL (Full Truckload), LTL (Less than Truckload), AIR_FREIGHT, PARCEL, BULK, or BREAKBULK. Governs load optimization rules in Oracle TMS and capacity planning in Blue Yonder. [ENUM-REF-CANDIDATE: FCL|LCL|FTL|LTL|AIR_FREIGHT|PARCEL|BULK|BREAKBULK — promote to reference product]' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Frequency Days Of Week' ;
    rdfs:comment 'Comma-separated list of days on which the corridor operates (e.g., \'MON,WED,FRI\' for tri-weekly ocean service, \'MON,TUE,WED,THU,FRI,SAT,SUN\' for daily express). Used in SAP TM departure scheduling and customer-facing ETD commitments.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyType rdf:type rdf:Property ;
    rdfs:label 'Frequency Type' ;
    rdfs:comment 'Operational frequency at which the service corridor runs (e.g., DAILY for express parcel, WEEKLY for ocean FCL). Drives departure schedule planning in SAP TM, capacity allocation in Blue Yonder, and ETD/ETA commitments communicated to customers.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubSpokeRole rdf:type rdf:Property ;
    rdfs:label 'Hub Spoke Role' ;
    rdfs:comment 'Classification of this corridor\'s role within the hub-and-spoke network topology. HUB_TO_HUB for main trunk routes, HUB_TO_SPOKE for distribution legs, SPOKE_TO_HUB for collection legs, SPOKE_TO_SPOKE for direct point-to-point routes. Used in Blue Yonder network design and SAP TM route planning.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediateHubSequence rdf:type rdf:Property ;
    rdfs:label 'Intermediate Hub Sequence' ;
    rdfs:comment 'Ordered, pipe-delimited sequence of intermediate hub codes (IATA or UN/LOCODE) traversed between origin and destination (e.g., \'DXB|FRA\' for Dubai then Frankfurt). Defines the multi-node path that distinguishes a corridor from a single O-D lane. Consumed by SAP TM for multi-leg route planning.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMileIncluded rdf:type rdf:Property ;
    rdfs:label 'Last Mile Included' ;
    rdfs:comment 'Indicates whether last-mile delivery to the final consignee is included within this corridor\'s scope. TRUE for D2D (Door-to-Door) corridors. FALSE for port-to-port or hub-to-hub corridors where last-mile is handled separately.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legCount rdf:type rdf:Property ;
    rdfs:label 'Leg Count' ;
    rdfs:comment 'Total number of transport legs in this service corridor, including origin-to-first-hub, all intermediate legs, and final leg to destination. Derived from the hub sequence but stored for query performance in SAP TM load optimization and Blue Yonder network design.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkDesignCode rdf:type rdf:Property ;
    rdfs:label 'Network Design Code' ;
    rdfs:comment 'Reference to the Blue Yonder network design scenario that generated or last optimized this corridor configuration. Enables traceability between network optimization outputs and operational corridor definitions.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originHubCode rdf:type rdf:Property ;
    rdfs:label 'Origin Hub Code' ;
    rdfs:comment 'IATA airport code or UN/LOCODE of the primary origin hub node for this corridor (e.g., \'HKG\' for Hong Kong, \'CNSHA\' for Shanghai). Anchors the corridor\'s starting network node in SAP TM route planning and FourKites real-time visibility.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingVisibilityEnabled rdf:type rdf:Property ;
    rdfs:label 'Tracking Visibility Enabled' ;
    rdfs:comment 'Indicates whether real-time shipment tracking and predictive ETA via FourKites is enabled for this corridor. TRUE enables GPS/IoT-based visibility, exception alerts, and predictive ETA updates for shipments on this corridor.' ;
    rdfs:domain ind:ServiceCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitTimeStandardId rdf:type rdf:Property ;
    rdfs:label 'Transit Time Standard Id' ;
    rdfs:comment 'Unique surrogate identifier for the transit time standard record. Primary key for this entity in the route domain Silver layer.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTransitLaneId rdf:type rdf:Property ;
    rdfs:label 'Primary Transit Lane Id' ;
    rdfs:comment 'Reference to the origin-destination lane master record that this transit time standard applies to. Links to the lane product in the route domain.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:supersededByTransitTimeStandardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Transit Time Standard Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer transit time standard record that replaces this one when lifecycle_status is SUPERSEDED. Enables version chain traversal for historical SLA analysis.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransitTimeStandard .

ind:blueYonderStandardCode rdf:type rdf:Property ;
    rdfs:label 'Blue Yonder Standard Code' ;
    rdfs:comment 'External identifier from Blue Yonder Supply Chain Planning that maps this transit time standard to the network design and demand forecasting outputs. Enables traceability between the route domain SSOT and Blue Yonder optimization results.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceDays rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Days' ;
    rdfs:comment 'Number of days allocated for customs clearance included within the standard transit time for cross-border shipments. Used in Descartes Customs integration and trade compliance planning. Relevant for DDP, DAP, and CIF Incoterms.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cutoffTimezone rdf:type rdf:Property ;
    rdfs:label 'Cutoff Timezone' ;
    rdfs:comment 'IANA timezone identifier for the cut-off time (e.g., America/New_York, Europe/London). Ensures unambiguous interpretation of cutoff_time across global operations.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimezone rdf:type rdf:Property ;
    rdfs:label 'Delivery Timezone' ;
    rdfs:comment 'IANA timezone identifier for the delivery time window at the destination node (e.g., Asia/Singapore, America/Los_Angeles). Ensures unambiguous interpretation of first_available_delivery_time and latest_delivery_time.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeCode rdf:type rdf:Property ;
    rdfs:label 'Destination Node Code' ;
    rdfs:comment 'Code identifying the destination hub, depot, port, airport, or facility node for this transit time standard. Aligns with IATA airport codes, UN/LOCODE, or internal network node identifiers.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeType rdf:type rdf:Property ;
    rdfs:label 'Destination Node Type' ;
    rdfs:comment 'Classification of the destination node (e.g., airport, seaport, Inland Container Depot (ICD), Container Freight Station (CFS), Free Trade Zone (FTZ)). Supports network topology and hub-and-spoke configuration. [ENUM-REF-CANDIDATE: AIRPORT|SEAPORT|RAIL_TERMINAL|ROAD_HUB|WAREHOUSE|ICD|CFS|FTZ — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAvailableDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'First Available Delivery Time' ;
    rdfs:comment 'The earliest time of day (HH:MM, 24-hour local) at which delivery can be attempted at the destination under this transit time standard. Used in last-mile scheduling, delivery window commitments, and ePOD (Electronic Proof of Delivery) planning.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hubRoutingRequired rdf:type rdf:Property ;
    rdfs:label 'Hub Routing Required' ;
    rdfs:comment 'Indicates whether this transit time standard requires routing through an intermediate hub node (hub-and-spoke configuration). When true, hub transit time is included in standard_transit_days.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermediateHubCode rdf:type rdf:Property ;
    rdfs:label 'Intermediate Hub Code' ;
    rdfs:comment 'Code of the primary intermediate hub node through which shipments are routed when hub_routing_required is true. Aligns with IATA airport codes or internal network node identifiers.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latestDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Latest Delivery Time' ;
    rdfs:comment 'The latest time of day (HH:MM, 24-hour local) by which delivery must be completed at the destination to meet this transit time standard. Used in SLA compliance measurement and On-Time In-Full (OTIF) reporting.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current operational state of this transit time standard in its lifecycle. ACTIVE records are used in ETA calculation and carrier selection. SUPERSEDED records are retained for historical SLA audit. DRAFT records are pending approval.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCorridorCode rdf:type rdf:Property ;
    rdfs:label 'Network Corridor Code' ;
    rdfs:comment 'Code identifying the service corridor or trade lane grouping to which this transit time standard belongs (e.g., TRANS-PACIFIC, EUROPE-ASIA). Used in network optimization outputs from Blue Yonder and corridor-level SLA reporting.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDaysMask rdf:type rdf:Property ;
    rdfs:label 'Operating Days Mask' ;
    rdfs:comment '7-character binary string (Mon-Sun) indicating which days of the week this transit time standard is active (1=active, 0=inactive). Example: \'1111100\' = Monday to Friday only. Encodes day-of-week restrictions for scheduling and ETA calculation.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originNodeCode rdf:type rdf:Property ;
    rdfs:label 'Origin Node Code' ;
    rdfs:comment 'Code identifying the origin hub, depot, port, airport, or facility node for this transit time standard. Aligns with IATA airport codes, UN/LOCODE, or internal network node identifiers.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originNodeType rdf:type rdf:Property ;
    rdfs:label 'Origin Node Type' ;
    rdfs:comment 'Classification of the origin node (e.g., airport, seaport, Inland Container Depot (ICD), Container Freight Station (CFS), Free Trade Zone (FTZ)). Supports network topology analysis and hub-and-spoke configuration. [ENUM-REF-CANDIDATE: AIRPORT|SEAPORT|RAIL_TERMINAL|ROAD_HUB|WAREHOUSE|ICD|CFS|FTZ — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originZoneCode rdf:type rdf:Property ;
    rdfs:label 'Origin Zone Code' ;
    rdfs:comment 'Postal or geographic zone code for the origin area, used in last-mile delivery zone mapping and zone-based transit time calculations in SAP TM and Oracle TMS.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapTmRouteCode rdf:type rdf:Property ;
    rdfs:label 'Sap Tm Route Code' ;
    rdfs:comment 'External route identifier from SAP TM used to link this transit time standard to the corresponding route planning and freight order management record in SAP TM. Supports system-of-record traceability.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Externally-known unique business code identifying this transit time standard record, used in SAP TM, Oracle TMS, and FourKites integrations for ETA calculation and carrier selection.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardDescription rdf:type rdf:Property ;
    rdfs:label 'Standard Description' ;
    rdfs:comment 'Free-text description providing additional context about this transit time standard, including special conditions, exceptions, or operational notes relevant to SLA management and carrier selection.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Human-readable descriptive name for this transit time standard, used in reporting, SLA contract references, and carrier selection displays.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitDayType rdf:type rdf:Property ;
    rdfs:label 'Transit Day Type' ;
    rdfs:comment 'Specifies whether standard_transit_days is measured in calendar days, business days, or working days. Critical for accurate SLA commitment and ETA calculation, particularly for cross-border shipments with customs clearance.' ;
    rdfs:domain ind:TransitTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorId rdf:type rdf:Property ;
    rdfs:label 'Contractor Id' ;
    rdfs:comment 'Reference to the contractor or third-party service provider company being pre-qualified.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contractor .

ind:prequalificationAuditId rdf:type rdf:Property ;
    rdfs:label 'Prequalification Audit Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_audit. Business justification: Contractor safety prequalification often includes a formal safety audit of the contractor\'s operations. This FK links the prequal record to the audit that supported the approval decision, enabling aud' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:primaryContractorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Contractor Employee Id' ;
    rdfs:comment 'Reference to the Transport Shipping safety officer who reviewed and approved the pre-qualification.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:questionnaireTemplateId rdf:type rdf:Property ;
    rdfs:label 'Questionnaire Template Id' ;
    rdfs:comment 'Reference to the safety questionnaire template used for the assessment.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Notes and comments recorded by the reviewing safety officer regarding the approval decision.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedFacilities rdf:type rdf:Property ;
    rdfs:label 'Authorized Facilities' ;
    rdfs:comment 'Comma-separated list of facility IDs or names where the contractor is authorized to work.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalApprovalRequirements rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Requirements' ;
    rdfs:comment 'Specific requirements or conditions that must be met for conditional approvals.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorType rdf:type rdf:Property ;
    rdfs:label 'Contractor Type' ;
    rdfs:comment 'Classification of the contractor service type (e.g., Third-Party Logistics (3PL), freight forwarder, warehouse operator, maintenance provider, transport carrier, customs broker).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Coverage Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the liability coverage amount.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Dg Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the dangerous goods handling certification.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dgCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Dg Certification Number' ;
    rdfs:comment 'Certification number for dangerous goods handling qualification.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Document Repository Url' ;
    rdfs:comment 'URL or path to the document repository containing the contractor\'s pre-qualification documentation.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inductionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Induction Completion Date' ;
    rdfs:comment 'Date when all required safety inductions were completed.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceCertificateValid rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Valid' ;
    rdfs:comment 'Indicates whether the contractor has provided valid insurance certificates meeting Transport Shipping requirements.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Coverage Amount' ;
    rdfs:comment 'Total liability insurance coverage amount provided by the contractor.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ltir rdf:type rdf:Property ;
    rdfs:label 'Ltir' ;
    rdfs:comment 'Contractor\'s Lost Time Incident Rate (LTIR) - number of lost time incidents per 200,000 work hours.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPassingScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Passing Score' ;
    rdfs:comment 'Minimum score required to pass the safety pre-qualification assessment.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Scheduled Date' ;
    rdfs:comment 'Date when the next safety audit is scheduled for the contractor.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oshaViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Osha Violations Count' ;
    rdfs:comment 'Number of OSHA violations recorded for the contractor in the review period.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prequalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Prequal Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the pre-qualification application or assessment.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prequalStatus rdf:type rdf:Property ;
    rdfs:label 'Prequal Status' ;
    rdfs:comment 'Current status of the contractor safety pre-qualification (pending, approved, conditional, rejected, expired, suspended).' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequiredDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Date' ;
    rdfs:comment 'Date by which the contractor must submit a renewal application to maintain pre-qualification status.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewingSafetyOfficerName rdf:type rdf:Property ;
    rdfs:label 'Reviewing Safety Officer Name' ;
    rdfs:comment 'Name of the Transport Shipping safety officer who reviewed and approved the pre-qualification.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyInductionsCompleted rdf:type rdf:Property ;
    rdfs:label 'Safety Inductions Completed' ;
    rdfs:comment 'Indicates whether all required safety inductions and training have been completed by the contractor\'s personnel.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyQuestionnaireScore rdf:type rdf:Property ;
    rdfs:label 'Safety Questionnaire Score' ;
    rdfs:comment 'Numerical score achieved by the contractor on the safety questionnaire assessment (0-100 scale).' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyRecordReviewDate rdf:type rdf:Property ;
    rdfs:label 'Safety Record Review Date' ;
    rdfs:comment 'Date when the contractor\'s safety record was reviewed.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyRecordReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Safety Record Review Outcome' ;
    rdfs:comment 'Overall outcome of the contractor\'s safety record review based on TRIR, LTIR, and historical incident analysis.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Serious Violations Count' ;
    rdfs:comment 'Number of serious safety violations recorded for the contractor in the review period.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteAccessAuthorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Site Access Authorization Level' ;
    rdfs:comment 'Level of site access authorization granted to the contractor (unrestricted, restricted, escorted only, no access).' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trir rdf:type rdf:Property ;
    rdfs:label 'Trir' ;
    rdfs:comment 'Contractor\'s Total Recordable Incident Rate (TRIR) - number of recordable incidents per 200,000 work hours.' ;
    rdfs:domain ind:ContractorSafetyPrequal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiativeId rdf:type rdf:Property ;
    rdfs:label 'Initiative Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainability_initiative. Business justification: Safety corrective actions often drive sustainability capital investments: incident reveals need for electric vehicle fleet, LED lighting after electrical fire, solar panels after generator failure. Ca' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:observationId rdf:type rdf:Property ;
    rdfs:label 'Observation Id' ;
    rdfs:comment 'Reference to the near-miss report that prompted this corrective action, if applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Observation .

ind:primaryCorrectiveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Corrective Employee Id' ;
    rdfs:comment 'Employee responsible for implementing and completing the corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryCorrectiveLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Corrective Last Modified By Employee Id' ;
    rdfs:comment 'Employee who last modified the corrective action record.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:responsiblePartnerId rdf:type rdf:Property ;
    rdfs:label 'Responsible Partner Id' ;
    rdfs:comment 'Foreign key linking to network.network_partner. Business justification: Corrective actions arising from partner-related incidents or audit findings must track the responsible partner for accountability, completion verification, and performance impact assessment. Standard ' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:tertiaryCorrectiveCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Corrective Created By Employee Id' ;
    rdfs:comment 'Employee who created the corrective action record.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business-facing unique identifier for the corrective action, typically formatted as CA-YYYYNNNN for external reference and tracking.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date when the corrective action was actually completed and ready for verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual financial cost incurred to implement the corrective action.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Department' ;
    rdfs:comment 'Department or business unit responsible for executing the corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOwnerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Name' ;
    rdfs:comment 'Full name of the employee assigned as the action owner for quick reference and reporting.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Regulatory or legal deadline by which the corrective action must be completed to maintain compliance.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of days past the target completion date, calculated when action is not completed on time.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Date when the effectiveness review was conducted, typically 30-90 days after action completion.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Notes' ;
    rdfs:comment 'Detailed findings from the effectiveness review including evidence of sustained improvement and any follow-up actions needed.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Outcome' ;
    rdfs:comment 'Assessment of whether the corrective action successfully eliminated the root cause and prevented recurrence.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Category' ;
    rdfs:comment 'Classification of the hazard type addressed by this action (e.g., chemical exposure, ergonomic, fall hazard, vehicle safety, dangerous goods handling). [ENUM-REF-CANDIDATE: chemical_exposure|ergonomic|fall_hazard|vehicle_safety|dangerous_goods|electrical|fire|confined_space|machinery|noise — promote to reference product]' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Specific location within the facility where the action is required (e.g., loading dock, warehouse aisle, driver break room).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrencePreventionMeasures rdf:type rdf:Property ;
    rdfs:label 'Recurrence Prevention Measures' ;
    rdfs:comment 'Specific measures implemented to prevent recurrence of the nonconformity or hazard, including process changes, training, or engineering controls.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFindingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Finding Id' ;
    rdfs:comment 'Reference to the regulatory inspection finding that mandated this corrective action, if applicable.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Specific OSHA, DOT, IATA, IMO, or other regulatory standard that mandates this corrective action.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective action must be completed, often driven by regulatory deadlines or risk severity.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when all required training associated with the corrective action was completed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Detailed notes from the verification process documenting findings, evidence reviewed, and verification outcome.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Holder Employee Id' ;
    rdfs:comment 'The unique identifier of the entity (employee, facility, vehicle, equipment, or organizational unit) that holds this certification. This is a polymorphic reference resolved based on holder_type.' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'The specific dangerous goods function or role that this certification authorizes the holder to perform. Packer (authorized to pack DG into packages), shipper (authorized to prepare DG shipments and documentation), handler (authorized to physically handle DG cargo), inspector (authorized to inspect DG shipments for compliance), driver (authorized to transport DG by road), acceptance checker (authorized to accept DG shipments at origin), load planner (authorized to plan aircraft/vessel loading with DG), emergency responder (trained for DG incident response), security screener (authorized to screen DG cargo). [ENUM-REF-CANDIDATE: packer|shipper|handler|inspector|driver|acceptance_checker|load_planner|emergency_responder|security_screener — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyLevel rdf:type rdf:Property ;
    rdfs:label 'Competency Level' ;
    rdfs:comment 'The proficiency or qualification level of the certification holder in dangerous goods handling. Basic (entry-level awareness training), intermediate (operational handling certification), advanced (senior handler or supervisor certification), specialist (expert in specific DG classes or complex operations), instructor (authorized to train and certify others).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAuditDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Date' ;
    rdfs:comment 'The date of the most recent compliance audit or inspection that verified the certification holders continued competency and adherence to dangerous goods regulations. Null if no audit has been conducted.' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceAuditResult rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Result' ;
    rdfs:comment 'The outcome of the most recent compliance audit. Pass (full compliance confirmed), pass_with_observations (compliant but minor improvement areas noted), fail (non-compliance identified requiring corrective action), not_audited (no audit conducted).' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgClassCoverage rdf:type rdf:Property ;
    rdfs:label 'Dg Class Coverage' ;
    rdfs:comment 'The UN dangerous goods classes that this certification covers, represented as a comma-separated list of class numbers (e.g., 1,2,3,4,5,6,7,8,9). Class 1 (explosives), Class 2 (gases), Class 3 (flammable liquids), Class 4 (flammable solids), Class 5 (oxidizing substances), Class 6 (toxic substances), Class 7 (radioactive material), Class 8 (corrosive substances), Class 9 (miscellaneous dangerous goods). Empty if certification covers all classes.' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderName rdf:type rdf:Property ;
    rdfs:label 'Holder Name' ;
    rdfs:comment 'The full name or designation of the certification holder (employee full name, facility name, vehicle registration, equipment serial number, or organizational unit name). Provides human-readable identification.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderType rdf:type rdf:Property ;
    rdfs:label 'Holder Type' ;
    rdfs:comment 'The category of entity that holds this dangerous goods certification. Employee (individual person trained and certified), facility (warehouse or terminal authorized for DG handling), vehicle (truck, aircraft, vessel certified for DG transport), equipment (container, packaging, handling equipment), organizational unit (business division or operational unit).' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'The date on which this certification was most recently renewed or recertified. Null if the certification has never been renewed (i.e., still on original issue).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modeOfTransport rdf:type rdf:Property ;
    rdfs:label 'Mode Of Transport' ;
    rdfs:comment 'The transport mode(s) for which this dangerous goods certification is valid. Air (IATA/ICAO regulations), ocean (IMDG Code), road (ADR), rail (RID), multimodal (valid across multiple modes).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRecurrentTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Recurrent Training Due Date' ;
    rdfs:comment 'The date by which the certification holder must complete the next recurrent dangerous goods training session to maintain certification validity. Calculated based on last training date plus recurrent_training_frequency_months. Null if no recurrent training is required.' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passThreshold rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold' ;
    rdfs:comment 'The minimum score or percentage required to pass the certification examination and obtain the certification. Typically 80.00 or 85.00 for dangerous goods certifications. Null if no formal assessment was required.' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurrentTrainingFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Recurrent Training Frequency Months' ;
    rdfs:comment 'The required interval in months between recurrent dangerous goods training sessions to maintain certification validity. Typically 24 months (2 years) for IATA DGR certifications. Null if no recurrent training is required.' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryVersion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Version' ;
    rdfs:comment 'The edition or version of the dangerous goods regulations under which this certification was issued. For example, IATA DGR 64th Edition, IMDG Code Amendment 40-20. Important for tracking regulatory currency as DG regulations are updated regularly.' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseReference rdf:type rdf:Property ;
    rdfs:label 'Training Course Reference' ;
    rdfs:comment 'The reference number, code, or identifier of the dangerous goods training course that the certification holder completed to obtain this certification. Links to the training program record.' ;
    rdfs:domain ind:DgCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerDgCertificationId rdf:type rdf:Property ;
    rdfs:label 'Handler Dg Certification Id' ;
    rdfs:comment 'Foreign key linking to safety.dg_certification. Business justification: DG incidents should track which certified handler was involved. Links the incident to the specific DG certification of the employee handling the dangerous goods at the time of the incident. This suppo' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DgCertification .

ind:primaryDgReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Dg Reported By Employee Id' ;
    rdfs:comment 'Reference to the employee who first reported the dangerous goods incident. Used for incident tracking and safety culture metrics.' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:responsibleCarrierId rdf:type rdf:Property ;
    rdfs:label 'Responsible Carrier Id' ;
    rdfs:comment 'Foreign key linking to network.carrier. Business justification: Dangerous goods incidents during carrier transport require tracking which carrier was responsible for regulatory notification to authorities, liability assessment, remediation costs, and compliance en' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:resultingEnvironmentalIncidentId rdf:type rdf:Property ;
    rdfs:label 'Resulting Environmental Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.environmental_incident. Business justification: DG incidents that cause environmental releases (spills, emissions) spawn environmental_incident records. This FK links the DG incident to the resulting environmental incident, supporting integrated in' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalIncident .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Date and time when the dangerous goods incident was formally closed after all corrective actions were completed and verified.' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveActions rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions' ;
    rdfs:comment 'Description of corrective and preventive actions implemented to prevent recurrence of similar dangerous goods incidents.' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseActions rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Actions' ;
    rdfs:comment 'Detailed description of immediate emergency response actions taken to contain and mitigate the dangerous goods incident (e.g., spill containment, evacuation, fire suppression).' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment' ;
    rdfs:comment 'Assessment of environmental damage or contamination resulting from the dangerous goods incident. Used for EPA/environmental authority reporting and remediation planning.' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Release Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods incident resulted in release of hazardous material to the environment (air, water, soil). Triggers additional reporting requirements.' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatalitiesReported rdf:type rdf:Property ;
    rdfs:label 'Fatalities Reported' ;
    rdfs:comment 'Count of fatalities resulting from the dangerous goods incident. Triggers immediate regulatory notification and investigation.' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:injuriesReported rdf:type rdf:Property ;
    rdfs:label 'Injuries Reported' ;
    rdfs:comment 'Count of personnel injuries resulting from the dangerous goods incident. Used for OSHA reporting and safety performance metrics.' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Timestamp' ;
    rdfs:comment 'Date and time when the dangerous goods incident investigation was completed and findings documented.' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notifiedAuthority rdf:type rdf:Property ;
    rdfs:label 'Notified Authority' ;
    rdfs:comment 'Name of the regulatory authority to which the dangerous goods incident was reported (e.g., FAA, CAA, Coast Guard, national maritime authority).' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInvolved rdf:type rdf:Property ;
    rdfs:label 'Quantity Involved' ;
    rdfs:comment 'Amount of dangerous goods substance involved in the incident. Used for environmental impact assessment and regulatory reporting thresholds.' ;
    rdfs:domain ind:DgIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the dangerous goods incident meets thresholds requiring mandatory notification to regulatory authorities (IATA, IMO, national CAA, maritime authority).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coachingSessionId rdf:type rdf:Property ;
    rdfs:label 'Coaching Session Id' ;
    rdfs:comment 'Identifier of the coaching session conducted in response to this safety event.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoachingSession .

ind:coachingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Coaching Completed Date' ;
    rdfs:comment 'Date when driver coaching was completed for this safety event in format yyyy-MM-dd.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coachingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Coaching Completed Flag' ;
    rdfs:comment 'Indicates whether required driver coaching has been completed for this safety event.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dashcamFootageReference rdf:type rdf:Property ;
    rdfs:label 'Dashcam Footage Reference' ;
    rdfs:comment 'Reference identifier or URI to the dashcam video footage captured during the safety event.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Driver Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the driver has acknowledged and reviewed the safety event.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Driver Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the driver acknowledged the safety event in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:driverComment rdf:type rdf:Property ;
    rdfs:label 'Driver Comment' ;
    rdfs:comment 'Optional comment or explanation provided by the driver regarding the safety event.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Event Duration Seconds' ;
    rdfs:comment 'Duration of the safety event in seconds, applicable for sustained behaviors such as speeding or mobile phone use.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventSeverity rdf:type rdf:Property ;
    rdfs:label 'Event Severity' ;
    rdfs:comment 'Severity classification of the safety event based on risk assessment criteria.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gForceValue rdf:type rdf:Property ;
    rdfs:label 'G Force Value' ;
    rdfs:comment 'Measured gravitational force (g-force) during harsh braking, acceleration, or cornering events.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedSpeedLimitKph rdf:type rdf:Property ;
    rdfs:label 'Posted Speed Limit Kph' ;
    rdfs:comment 'Legal posted speed limit in kilometers per hour at the location where the event occurred.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roadCondition rdf:type rdf:Property ;
    rdfs:label 'Road Condition' ;
    rdfs:comment 'Road surface condition at the time and location of the safety event. [ENUM-REF-CANDIDATE: dry|wet|icy|snow_covered|gravel|construction|pothole|debris — promote to reference product]' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyScoreImpact rdf:type rdf:Property ;
    rdfs:label 'Safety Score Impact' ;
    rdfs:comment 'Numeric impact of this event on the drivers overall safety score, positive or negative.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speedOverLimitKph rdf:type rdf:Property ;
    rdfs:label 'Speed Over Limit Kph' ;
    rdfs:comment 'Amount by which the vehicle speed exceeded the posted speed limit in kilometers per hour, if applicable.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supervisorComment rdf:type rdf:Property ;
    rdfs:label 'Supervisor Comment' ;
    rdfs:comment 'Comment or notes provided by the supervisor during review of the safety event.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Status' ;
    rdfs:comment 'Current status of the supervisors review of this safety event.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Timestamp' ;
    rdfs:comment 'Date and time when the supervisor completed their review of the safety event in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vehicleSpeedKph rdf:type rdf:Property ;
    rdfs:label 'Vehicle Speed Kph' ;
    rdfs:comment 'Speed of the vehicle in kilometers per hour at the time of the safety event.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:violationCode rdf:type rdf:Property ;
    rdfs:label 'Violation Code' ;
    rdfs:comment 'Code identifying the specific policy or regulatory violation associated with this safety event.' ;
    rdfs:domain ind:DriverSafetyEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Actual Enrollment Count' ;
    rdfs:comment 'Current count of drivers who have enrolled in this safety program to date.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableDriverPopulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Driver Population' ;
    rdfs:comment 'Target driver segment or population to which this safety program applies (e.g., long-haul drivers, last-mile delivery, hazmat-certified drivers).' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationValidityDays rdf:type rdf:Property ;
    rdfs:label 'Certification Validity Days' ;
    rdfs:comment 'Number of days the certification remains valid after program completion before recertification is required. Null if no certification or perpetual validity.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionRateTarget rdf:type rdf:Property ;
    rdfs:label 'Completion Rate Target' ;
    rdfs:comment 'Target percentage (0-100) of enrolled drivers expected to successfully complete the program.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'Method by which the safety program training is delivered to drivers (e.g., classroom, online, blended, on-the-job, simulator-based).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentCriteria rdf:type rdf:Property ;
    rdfs:label 'Enrollment Criteria' ;
    rdfs:comment 'Eligibility requirements and conditions for driver participation in the safety program (e.g., minimum driving hours, incident history, license class).' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harshBrakingRateThreshold rdf:type rdf:Property ;
    rdfs:label 'Harsh Braking Rate Threshold' ;
    rdfs:comment 'Maximum acceptable harsh braking rate (events per 100 miles or per trip) as defined by program KPI targets.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:languageAvailability rdf:type rdf:Property ;
    rdfs:label 'Language Availability' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes in which this program is available (e.g., EN, ES, FR, DE).' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether participation in this safety program is mandatory (true) or voluntary (false) for the applicable driver population.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score (percentage or points) required to successfully complete the program assessment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Unique business identifier code for the driver safety program used in operational systems and reporting.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCostPerDriver rdf:type rdf:Property ;
    rdfs:label 'Program Cost Per Driver' ;
    rdfs:comment 'Estimated or actual cost per driver to deliver this safety program, including training materials, instructor time, and certification fees.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Program Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for program cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Comprehensive description of the safety program including scope, methodology, expected outcomes, and key learning modules.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDurationDays rdf:type rdf:Property ;
    rdfs:label 'Program Duration Days' ;
    rdfs:comment 'Standard duration of the safety program measured in days from enrollment to completion.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programObjectives rdf:type rdf:Property ;
    rdfs:label 'Program Objectives' ;
    rdfs:comment 'Detailed description of the safety program goals, expected behavioral changes, and target outcomes.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwner rdf:type rdf:Property ;
    rdfs:label 'Program Owner' ;
    rdfs:comment 'Name or identifier of the business unit, department, or individual responsible for managing and maintaining this safety program.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the driver safety program indicating operational state.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programVersion rdf:type rdf:Property ;
    rdfs:label 'Program Version' ;
    rdfs:comment 'Version number of the safety program content and curriculum (e.g., 1.0, 2.1) for tracking updates and revisions.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAlignment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Alignment' ;
    rdfs:comment 'Comma-separated list of regulatory frameworks and standards this program aligns with (e.g., DOT, FMCSA, EU Directive 2003/59, OSHA).' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatbeltComplianceRateThreshold rdf:type rdf:Property ;
    rdfs:label 'Seatbelt Compliance Rate Threshold' ;
    rdfs:comment 'Minimum required seatbelt compliance rate expressed as a percentage (0-100) for program success criteria.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speedingEventsThreshold rdf:type rdf:Property ;
    rdfs:label 'Speeding Events Threshold' ;
    rdfs:comment 'Maximum acceptable number of speeding events per trip or per period as defined by the program KPI targets.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Target Enrollment Count' ;
    rdfs:comment 'Planned or target number of drivers to be enrolled in this safety program during its active period.' ;
    rdfs:domain ind:DriverSafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the external or internal organization providing training content and certification for this safety program.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyDrillId rdf:type rdf:Property ;
    rdfs:label 'Emergency Drill Id' ;
    rdfs:comment 'Unique identifier for the emergency drill record. Primary key.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyResponsePlanId rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Plan Id' ;
    rdfs:comment 'Foreign key linking to safety.emergency_response_plan. Business justification: Emergency drills test specific emergency response plans. This FK links each drill execution to the ERP being tested, enabling tracking of drill frequency per plan and verification of regulatory compli' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyResponsePlan .

ind:primaryEmergencyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Emergency Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for planning, organizing, and executing the emergency drill. Typically a facility safety manager, HSE (Health, Safety, and Environment) coordinator, or designated emergency response team leader.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryEmergencyModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Emergency Modified By User Employee Id' ;
    rdfs:comment 'Reference to the system user or employee who last modified this emergency drill record. Used for audit trail and accountability.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deficienciesIdentified rdf:type rdf:Property ;
    rdfs:label 'Deficiencies Identified' ;
    rdfs:comment 'Detailed list of deficiencies, gaps, or failures observed during the drill, such as blocked egress routes, malfunctioning alarms, inadequate communication, delayed response times, missing equipment, or personnel not following procedures.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillAnnouncementType rdf:type rdf:Property ;
    rdfs:label 'Drill Announcement Type' ;
    rdfs:comment 'Indicates whether participants were notified in advance of the drill (announced) or the drill was conducted without prior warning (unannounced). Unannounced drills provide a more realistic assessment of emergency preparedness.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillDate rdf:type rdf:Property ;
    rdfs:label 'Drill Date' ;
    rdfs:comment 'Calendar date on which the emergency drill was conducted. This is the principal business event date for the drill.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drillDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Drill Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from drill start to drill end, calculated as the difference between drill_end_time and drill_start_time.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillEndTime rdf:type rdf:Property ;
    rdfs:label 'Drill End Time' ;
    rdfs:comment 'Timestamp when the emergency drill scenario was concluded and all-clear was given.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drillNumber rdf:type rdf:Property ;
    rdfs:label 'Drill Number' ;
    rdfs:comment 'Business identifier for the emergency drill, typically assigned by the facility safety coordinator or HSE (Health, Safety, and Environment) management system.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillOutcome rdf:type rdf:Property ;
    rdfs:label 'Drill Outcome' ;
    rdfs:comment 'Overall assessment of the drill performance. Successful indicates all objectives were met without significant issues; successful with deficiencies indicates objectives were met but corrective actions are required; unsuccessful indicates critical failures or objectives not met; aborted indicates drill was terminated early due to safety concerns or operational issues.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillReportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Drill Report Document Url' ;
    rdfs:comment 'URL or file path to the formal drill report document, which includes detailed observations, performance metrics, photographs, and recommendations. Used for audit trail and regulatory compliance documentation.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillStartTime rdf:type rdf:Property ;
    rdfs:label 'Drill Start Time' ;
    rdfs:comment 'Timestamp when the emergency drill scenario was initiated (e.g., alarm activation, announcement, or simulated incident trigger).' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drillStatus rdf:type rdf:Property ;
    rdfs:label 'Drill Status' ;
    rdfs:comment 'Current lifecycle state of the emergency drill event. Scheduled indicates planned but not yet executed; in progress indicates drill is actively underway; completed indicates drill has concluded and evaluation is finalized; cancelled indicates drill was called off; postponed indicates drill was rescheduled to a future date.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillType rdf:type rdf:Property ;
    rdfs:label 'Drill Type' ;
    rdfs:comment 'Category of emergency scenario being drilled. Fire evacuation tests building egress procedures; DG (Dangerous Goods) spill response tests hazardous material containment; lockdown tests security protocols; medical emergency tests first aid and EMS (Emergency Medical Services) response; natural disaster tests earthquake, flood, or severe weather procedures; active shooter tests threat response; hazmat incident tests chemical or biological hazard protocols. [ENUM-REF-CANDIDATE: fire_evacuation|dg_spill_response|lockdown|medical_emergency|natural_disaster|active_shooter|hazmat_incident — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evacuationTimeAchievedMinutes rdf:type rdf:Property ;
    rdfs:label 'Evacuation Time Achieved Minutes' ;
    rdfs:comment 'Actual time in minutes required to evacuate all personnel from the facility or affected area to the designated assembly point. Applicable to fire evacuation and natural disaster drills.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evacuationTimeTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Evacuation Time Target Minutes' ;
    rdfs:comment 'Target or benchmark evacuation time in minutes established by facility safety plan, regulatory requirement, or industry best practice. Used to assess whether the drill met performance expectations.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evacuationTimeVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Evacuation Time Variance Minutes' ;
    rdfs:comment 'Difference between evacuation_time_achieved_minutes and evacuation_time_target_minutes. Positive values indicate the drill exceeded the target time; negative values indicate the drill was completed faster than the target.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAgencyName rdf:type rdf:Property ;
    rdfs:label 'External Agency Name' ;
    rdfs:comment 'Name of the external emergency response agency or agencies that participated in or observed the drill (e.g., local fire department, county EMS, police department, hazmat response team).' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgencyParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'External Agency Participation Flag' ;
    rdfs:comment 'Indicates whether external emergency response agencies (fire department, EMS, police, hazmat team) participated in or observed the drill. True if external agencies were involved; false if drill was conducted internally only.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions Required' ;
    rdfs:comment 'List of corrective actions, remediation tasks, or process improvements that must be implemented as a result of the drill findings. May include equipment repairs, procedure updates, additional training, or facility modifications.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which all follow-up actions must be completed and verified. Used to track corrective action closure and ensure timely remediation of deficiencies.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDrillScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Drill Scheduled Date' ;
    rdfs:comment 'Planned date for the next emergency drill of the same type at this facility. Used to ensure compliance with periodic drill frequency requirements (e.g., quarterly, semi-annual, annual).' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of employees, contractors, and visitors who participated in the emergency drill. Used to measure drill coverage and compliance with mandatory participation requirements.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenarioDescription rdf:type rdf:Property ;
    rdfs:label 'Scenario Description' ;
    rdfs:comment 'Detailed narrative of the simulated emergency scenario used for the drill, including the nature of the incident, location within the facility, and any special conditions or complications introduced to test response capabilities.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Description of weather conditions at the time of the drill (e.g., clear, rain, snow, high wind, extreme heat, extreme cold). Weather can impact evacuation times and response effectiveness.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationTrigger rdf:type rdf:Property ;
    rdfs:label 'Activation Trigger' ;
    rdfs:comment 'Specific conditions or events that trigger the activation of this emergency response plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Full name of the manager or authority who officially approved this emergency response plan.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByTitle rdf:type rdf:Property ;
    rdfs:label 'Approved By Title' ;
    rdfs:comment 'Job title or role of the person who approved this emergency response plan (e.g., Safety Director, Operations Manager).' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Backup Coordinator Name' ;
    rdfs:comment 'Full name of the backup or alternate emergency coordinator who assumes responsibility if the primary coordinator is unavailable.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Backup Coordinator Phone' ;
    rdfs:comment 'Contact phone number for the backup emergency coordinator.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationCascadeProcedure rdf:type rdf:Property ;
    rdfs:label 'Communication Cascade Procedure' ;
    rdfs:comment 'Documented procedure outlining the sequence and method for notifying personnel, management, and external agencies during an emergency.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationCriteria rdf:type rdf:Property ;
    rdfs:label 'Deactivation Criteria' ;
    rdfs:comment 'Conditions or criteria that must be met before the emergency response plan can be deactivated and normal operations resumed.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillFrequency rdf:type rdf:Property ;
    rdfs:label 'Drill Frequency' ;
    rdfs:comment 'Required frequency for conducting emergency drills to test and validate the effectiveness of this emergency response plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Email' ;
    rdfs:comment 'Email address of the emergency coordinator for plan-related communications and notifications.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Name' ;
    rdfs:comment 'Full name of the designated emergency coordinator responsible for executing this emergency response plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Phone' ;
    rdfs:comment 'Primary contact phone number for the emergency coordinator, available 24/7 for emergency activation.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evacuationAssemblyPoint rdf:type rdf:Property ;
    rdfs:label 'Evacuation Assembly Point' ;
    rdfs:comment 'Designated safe location where personnel must assemble during an evacuation, including address or GPS coordinates.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireBrigadeContact rdf:type rdf:Property ;
    rdfs:label 'Fire Brigade Contact' ;
    rdfs:comment 'Contact details (name, phone, station) for the local fire brigade or fire department that responds to emergencies at this facility.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatTeamContact rdf:type rdf:Property ;
    rdfs:label 'Hazmat Team Contact' ;
    rdfs:comment 'Contact details for the specialized HAZMAT response team or contractor responsible for chemical spill and dangerous goods incidents.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hospitalContact rdf:type rdf:Property ;
    rdfs:label 'Hospital Contact' ;
    rdfs:comment 'Contact details (name, address, phone) for the nearest hospital or medical facility designated for emergency medical response.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDrillDate rdf:type rdf:Property ;
    rdfs:label 'Last Drill Date' ;
    rdfs:comment 'Date when the most recent emergency drill or simulation exercise was conducted for this plan.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDrillDate rdf:type rdf:Property ;
    rdfs:label 'Next Drill Date' ;
    rdfs:comment 'Scheduled date for the next emergency drill or simulation exercise to test this emergency response plan.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'URL or file path to the full emergency response plan document stored in the document management system.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive name of the emergency response plan for identification and reference purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Business identifier for the emergency response plan, externally referenced in safety documentation and regulatory filings.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the emergency scenario covered by this plan: fire evacuation, chemical spill, dangerous goods (DG) incident, natural disaster, security threat, or pandemic response.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number of the emergency response plan document, incremented with each revision or update.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policeContact rdf:type rdf:Property ;
    rdfs:label 'Police Contact' ;
    rdfs:comment 'Contact details for local police or security authorities to be notified in case of security threats or criminal incidents.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Basis' ;
    rdfs:comment 'List of regulatory standards, codes, and legal requirements that this emergency response plan is designed to comply with (e.g., OSHA 29 CFR 1910.38, SEVESO III, local fire codes).' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryAssemblyPoint rdf:type rdf:Property ;
    rdfs:label 'Secondary Assembly Point' ;
    rdfs:comment 'Alternate safe assembly location to be used if the primary evacuation assembly point is inaccessible or unsafe.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Special Equipment Required' ;
    rdfs:comment 'List of specialized equipment, tools, or resources required to execute this emergency response plan (e.g., fire extinguishers, spill kits, personal protective equipment).' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activatedEmergencyResponsePlanId rdf:type rdf:Property ;
    rdfs:label 'Activated Emergency Response Plan Id' ;
    rdfs:comment 'Foreign key linking to safety.emergency_response_plan. Business justification: Environmental incidents (spills, releases) trigger emergency response plans. This FK tracks which ERP was activated during the incident response, supporting post-incident review and ERP effectiveness ' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyResponsePlan .

ind:primaryEnvironmentalReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Environmental Reported By Employee Id' ;
    rdfs:comment 'Reference to the employee who initially reported the environmental incident.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Actual Remediation Cost' ;
    rdfs:comment 'Actual total cost incurred for environmental remediation, cleanup, and restoration activities in the currency specified by cost_currency_code.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Unique CAS registry number identifying the chemical substance involved in the environmental incident, if applicable.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanupContractorEngagedFlag rdf:type rdf:Property ;
    rdfs:label 'Cleanup Contractor Engaged Flag' ;
    rdfs:comment 'Indicates whether an external cleanup or remediation contractor was engaged to respond to the environmental incident (True) or not (False).' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleanupContractorName rdf:type rdf:Property ;
    rdfs:label 'Cleanup Contractor Name' ;
    rdfs:comment 'Name of the external contractor or remediation firm engaged to perform environmental cleanup and remediation activities.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Containment Actions Taken' ;
    rdfs:comment 'Description of immediate containment actions taken to prevent further environmental release or spread of contamination.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentDatetime rdf:type rdf:Property ;
    rdfs:label 'Containment Datetime' ;
    rdfs:comment 'The date and time when the environmental incident was successfully contained and further release was stopped.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveActionsCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Completed Flag' ;
    rdfs:comment 'Indicates whether all required corrective actions have been completed (True) or are still pending (False).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Discovery Method' ;
    rdfs:comment 'The method by which the environmental incident was discovered: routine inspection, employee report, customer complaint, sensor alarm, third party notification, or regulatory inspection.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMediaAffected rdf:type rdf:Property ;
    rdfs:label 'Environmental Media Affected' ;
    rdfs:comment 'The environmental medium or media impacted by the incident: soil, water (surface or groundwater), air, or multiple media.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Remediation Cost' ;
    rdfs:comment 'Estimated total cost of environmental remediation, cleanup, and restoration activities in the currency specified by cost_currency_code.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:immediateCause rdf:type rdf:Property ;
    rdfs:label 'Immediate Cause' ;
    rdfs:comment 'The direct, proximate cause that triggered the environmental incident (e.g., equipment failure, human error, external event).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentClosedDate rdf:type rdf:Property ;
    rdfs:label 'Incident Closed Date' ;
    rdfs:comment 'The date when the environmental incident was officially closed after all remediation, corrective actions, and regulatory requirements were completed.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDatetime rdf:type rdf:Property ;
    rdfs:label 'Incident Datetime' ;
    rdfs:comment 'The date and time when the environmental incident occurred or was first detected. Principal business event timestamp for the incident.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:insuranceClaimFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Filed Flag' ;
    rdfs:comment 'Indicates whether an insurance claim was filed for the environmental incident and associated remediation costs (True) or not (False).' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Investigation Required Flag' ;
    rdfs:comment 'Indicates whether a formal environmental incident investigation is required (True) or not (False) based on severity and regulatory requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyAssessedFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Assessed Flag' ;
    rdfs:comment 'Indicates whether regulatory penalties or fines were assessed against Transport Shipping for the environmental incident (True) or not (False).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityReleased rdf:type rdf:Property ;
    rdfs:label 'Quantity Released' ;
    rdfs:comment 'The quantity or volume of substance released into the environment during the incident, measured in the unit specified in release_unit_of_measure.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Case Number' ;
    rdfs:comment 'Case or reference number assigned by the regulatory authority for tracking the environmental incident investigation and compliance.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'The date on which the environmental incident was officially reported to the regulatory authority.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Release Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the quantity released: liters, gallons, kilograms, pounds, cubic meters, or tons.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'The date when environmental remediation and cleanup activities were completed and the site was restored.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationStartDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Start Date' ;
    rdfs:comment 'The date when environmental remediation and cleanup activities commenced.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of environmental remediation and cleanup activities: not started, in progress, completed, ongoing monitoring, or verified complete.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'Severity rating of the environmental incident based on environmental impact, regulatory implications, and remediation complexity: minor, moderate, major, critical, or catastrophic.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceInvolved rdf:type rdf:Property ;
    rdfs:label 'Substance Involved' ;
    rdfs:comment 'Name or description of the hazardous substance, chemical, fuel, or material involved in the environmental incident.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistTemplateId rdf:type rdf:Property ;
    rdfs:label 'Checklist Template Id' ;
    rdfs:comment 'Reference to the standardized inspection checklist template used for this inspection, defining the specific items and criteria to be evaluated.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:primaryFacilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Facility Employee Id' ;
    rdfs:comment 'Reference to the employee or contractor who conducted the inspection. Typically a safety officer, facility manager, or certified inspector.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:checklistCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Checklist Completion Status' ;
    rdfs:comment 'Indicates whether all items on the inspection checklist have been evaluated. Not started means no items checked; partial means some items remain; complete means all items evaluated.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDeficiencies rdf:type rdf:Property ;
    rdfs:label 'Critical Deficiencies' ;
    rdfs:comment 'Number of deficiencies classified as critical or high-severity, representing immediate safety hazards or regulatory violations requiring urgent remediation.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficienciesFound rdf:type rdf:Property ;
    rdfs:label 'Deficiencies Found' ;
    rdfs:comment 'Total count of safety deficiencies, non-conformances, or violations identified during the inspection that require corrective action.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencySummary rdf:type rdf:Property ;
    rdfs:label 'Deficiency Summary' ;
    rdfs:comment 'Consolidated narrative description of all deficiencies found during the inspection, including locations, conditions observed, and potential safety impacts.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Date' ;
    rdfs:comment 'Scheduled date for the follow-up inspection to verify corrective action completion, if required.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Required' ;
    rdfs:comment 'Flag indicating whether a follow-up inspection must be scheduled to verify that corrective actions have been completed and deficiencies resolved.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immediateActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Actions Taken' ;
    rdfs:comment 'Description of any immediate remediation actions performed on-site during or immediately following the inspection to address critical safety hazards (e.g., cordoning off area, shutting down equipment, posting warnings).' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Scheduled recurrence pattern for this type of inspection at the facility. Daily for high-risk areas; weekly for operational zones; monthly for general facility; quarterly for equipment; annual for comprehensive audits; ad hoc for incident-driven inspections.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScore rdf:type rdf:Property ;
    rdfs:label 'Inspection Score' ;
    rdfs:comment 'Numerical score or rating assigned to the inspection based on checklist compliance, typically expressed as a percentage (0.00 to 100.00) representing the proportion of items meeting safety standards.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemsInspected rdf:type rdf:Property ;
    rdfs:label 'Items Inspected' ;
    rdfs:comment 'Number of checklist items that have been evaluated and marked as inspected by the inspector.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:majorDeficiencies rdf:type rdf:Property ;
    rdfs:label 'Major Deficiencies' ;
    rdfs:comment 'Number of deficiencies classified as major or medium-severity, representing significant safety concerns that require timely corrective action.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDeficiencies rdf:type rdf:Property ;
    rdfs:label 'Minor Deficiencies' ;
    rdfs:comment 'Number of deficiencies classified as minor or low-severity, representing housekeeping issues or minor non-conformances that should be addressed but do not pose immediate risk.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Overall Inspection Result' ;
    rdfs:comment 'Summary outcome of the inspection. Pass indicates no deficiencies or only minor issues; pass with observations indicates deficiencies noted but not critical; fail indicates critical deficiencies requiring immediate action; incomplete indicates inspection could not be fully completed.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Report Document Url' ;
    rdfs:comment 'Link or file path to the detailed inspection report document, including photos, annotated checklists, and supporting evidence.' ;
    rdfs:domain ind:FacilityInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFatigueEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fatigue Employee Id' ;
    rdfs:comment 'Reference to the driver or operational crew member being assessed for fatigue risk.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryFatigueAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Fatigue Assessor Employee Id' ;
    rdfs:comment 'Reference to the employee (supervisor, safety officer, or medical professional) who conducted the fatigue risk assessment.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessedFatigueRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Assessed Fatigue Risk Level' ;
    rdfs:comment 'The overall fatigue risk level determined by the assessment. Low indicates minimal risk; medium indicates moderate risk requiring monitoring; high indicates significant risk requiring intervention; critical indicates immediate safety concern.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDatetime rdf:type rdf:Property ;
    rdfs:label 'Assessment Datetime' ;
    rdfs:comment 'The date and time when the fatigue risk assessment was conducted. This is the principal business event timestamp for the assessment.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentLocation rdf:type rdf:Property ;
    rdfs:label 'Assessment Location' ;
    rdfs:comment 'Description of the physical location where the fatigue risk assessment was conducted (e.g., terminal office, roadside inspection point, crew rest facility).' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome' ;
    rdfs:comment 'The final outcome or decision resulting from the fatigue risk assessment. Cleared indicates the employee is fit for duty; modified duty indicates restrictions or adjustments were applied; stood down indicates the employee was removed from duty; referred medical indicates further medical evaluation is required.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTrigger rdf:type rdf:Property ;
    rdfs:label 'Assessment Trigger' ;
    rdfs:comment 'The event or condition that initiated this fatigue risk assessment. Scheduled assessments are routine; post-incident assessments follow safety events; regulatory assessments are mandated by compliance requirements; operational change assessments occur when duty assignments are modified; supervisor request and self-report are initiated by management or the crew member.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the individual who conducted the fatigue risk assessment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'The role or title of the assessor (e.g., operations supervisor, safety manager, occupational health physician, FRMS coordinator).' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countermeasuresApplied rdf:type rdf:Property ;
    rdfs:label 'Countermeasures Applied' ;
    rdfs:comment 'Description of fatigue mitigation countermeasures applied or recommended, such as rest break scheduling, route splitting, relief driver assignment, duty reassignment, or operational delay.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Duty End Datetime' ;
    rdfs:comment 'The scheduled or actual date and time when the duty period or shift is expected to end.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dutyRestrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Duty Restriction Description' ;
    rdfs:comment 'Detailed description of any duty restrictions or modifications imposed as a result of the assessment (e.g., no night driving, reduced hours, local routes only).' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Duty Start Datetime' ;
    rdfs:comment 'The date and time when the current duty period or shift began for the assessed employee.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:employeeRole rdf:type rdf:Property ;
    rdfs:label 'Employee Role' ;
    rdfs:comment 'The operational role of the employee at the time of assessment (e.g., long-haul driver, local delivery driver, flight crew, warehouse operator).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueScore rdf:type rdf:Property ;
    rdfs:label 'Fatigue Score' ;
    rdfs:comment 'Numerical score representing the quantified fatigue risk level, typically on a standardized scale (e.g., 0-100), where higher scores indicate greater fatigue risk.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hosComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Hos Compliance Status' ;
    rdfs:comment 'Indicates whether the employee is in compliance with applicable hours-of-service regulations at the time of assessment. HOS refers to Hours of Service regulations governing maximum driving and duty hours.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursDriving rdf:type rdf:Property ;
    rdfs:label 'Hours Driving' ;
    rdfs:comment 'Total number of hours the employee has spent actively driving at the time of assessment.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursOnDuty rdf:type rdf:Property ;
    rdfs:label 'Hours On Duty' ;
    rdfs:comment 'Total number of hours the employee has been on duty at the time of assessment, including driving and non-driving work time.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursSinceLastRest rdf:type rdf:Property ;
    rdfs:label 'Hours Since Last Rest' ;
    rdfs:comment 'Number of hours elapsed since the employee\'s last qualifying rest or sleep period.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRestDurationHours rdf:type rdf:Property ;
    rdfs:label 'Last Rest Duration Hours' ;
    rdfs:comment 'Duration in hours of the employee\'s most recent rest or sleep period.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:objectiveFatigueIndicators rdf:type rdf:Property ;
    rdfs:label 'Objective Fatigue Indicators' ;
    rdfs:comment 'Observable or measurable indicators of fatigue identified during the assessment (e.g., reaction time test results, eye tracking data, behavioral observations).' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Date' ;
    rdfs:comment 'The date on which the fatigue risk assessment was reported to the relevant regulatory authority, if applicable.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reliefDriverAssigned rdf:type rdf:Property ;
    rdfs:label 'Relief Driver Assigned' ;
    rdfs:comment 'Indicates whether a relief driver was assigned to take over the duty assignment due to fatigue risk.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restBreakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Rest Break Duration Minutes' ;
    rdfs:comment 'Duration in minutes of the scheduled rest break, if applicable.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restBreakScheduled rdf:type rdf:Property ;
    rdfs:label 'Rest Break Scheduled' ;
    rdfs:comment 'Indicates whether a mandatory or recommended rest break was scheduled as a result of this assessment.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeModified rdf:type rdf:Property ;
    rdfs:label 'Route Modified' ;
    rdfs:comment 'Indicates whether the route or duty assignment was modified (e.g., shortened, split, or rescheduled) as a result of the fatigue assessment.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sleepOpportunityAdequacy rdf:type rdf:Property ;
    rdfs:label 'Sleep Opportunity Adequacy' ;
    rdfs:comment 'Assessment of whether the employee had adequate opportunity for restorative sleep prior to the current duty period.' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectiveFatigueRating rdf:type rdf:Property ;
    rdfs:label 'Subjective Fatigue Rating' ;
    rdfs:comment 'Self-reported fatigue level provided by the employee, typically on a standardized scale (e.g., 1-10 or Karolinska Sleepiness Scale).' ;
    rdfs:domain ind:FatigueRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHazardControlOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Hazard Control Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee or manager responsible for implementing and maintaining the control measures for this hazard.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryHazardModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Hazard Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who last modified this hazard register entry.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityOrProcess rdf:type rdf:Property ;
    rdfs:label 'Activity Or Process' ;
    rdfs:comment 'The specific operational activity, work process, or task during which the hazard exists or may be encountered by workers or the public.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedWorkerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Worker Count' ;
    rdfs:comment 'Estimated number of workers or personnel who may be exposed to this hazard during normal operations.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness' ;
    rdfs:comment 'Assessment of how effective the existing controls are in reducing the risk, rated from ineffective to highly effective.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Related Flag' ;
    rdfs:comment 'Boolean indicator of whether the hazard is related to the handling, storage, or transport of dangerous goods or hazardous materials.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyResponseProcedure rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Procedure' ;
    rdfs:comment 'Reference to or description of the emergency response procedure to be followed if the hazard is realized or an incident occurs.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:existingControls rdf:type rdf:Property ;
    rdfs:label 'Existing Controls' ;
    rdfs:comment 'Description of the current control measures, safeguards, or mitigation strategies in place to manage or reduce the hazard risk.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Detailed description of the hazard including the nature of the danger, potential harm, and circumstances under which the hazard may be realized.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hazard Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the hazard entry, used for tracking and communication across operational sites.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatus rdf:type rdf:Property ;
    rdfs:label 'Hazard Status' ;
    rdfs:comment 'Current lifecycle status of the hazard register entry indicating whether the hazard is active, has been mitigated, closed, under review, or pending corrective action.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardSubcategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Subcategory' ;
    rdfs:comment 'Secondary or more granular classification of the hazard within its primary category, providing additional specificity for risk management.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardTitle rdf:type rdf:Property ;
    rdfs:label 'Hazard Title' ;
    rdfs:comment 'Short descriptive title or name of the identified hazard for quick reference and reporting.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'Date when the hazard was first identified and recorded in the register.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentHistoryCount rdf:type rdf:Property ;
    rdfs:label 'Incident History Count' ;
    rdfs:comment 'Number of recorded incidents or near-misses associated with this specific hazard, providing historical context for risk assessment.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentConsequence rdf:type rdf:Property ;
    rdfs:label 'Inherent Consequence' ;
    rdfs:comment 'Severity rating of the potential consequence or impact if the hazard is realized without controls, ranging from insignificant to catastrophic.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentLikelihood rdf:type rdf:Property ;
    rdfs:label 'Inherent Likelihood' ;
    rdfs:comment 'Likelihood rating of the hazard occurring in the absence of any controls, using a qualitative scale from rare to almost certain.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'Overall inherent risk level calculated from likelihood and consequence before any controls are applied, categorized as low, medium, high, or extreme.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Numerical risk score representing the inherent risk level, typically calculated as likelihood multiplied by consequence on a defined scale.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date when the hazard risk assessment was most recently reviewed or updated.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastIncidentDate rdf:type rdf:Property ;
    rdfs:label 'Last Incident Date' ;
    rdfs:comment 'Date of the most recent incident or near-miss event related to this hazard, if any have occurred.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppeRequired rdf:type rdf:Property ;
    rdfs:label 'Ppe Required' ;
    rdfs:comment 'Description of the personal protective equipment required when working in the presence of this hazard, such as gloves, respirators, safety glasses, or protective clothing.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Exposure Flag' ;
    rdfs:comment 'Boolean indicator of whether the hazard may also affect members of the public, customers, or visitors in addition to employees.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'Description of recommended additional control measures, corrective actions, or risk treatment strategies to further reduce the residual risk.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualConsequence rdf:type rdf:Property ;
    rdfs:label 'Residual Consequence' ;
    rdfs:comment 'Severity rating of the potential consequence after existing controls have been applied, using the same scale as inherent consequence.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualLikelihood rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood' ;
    rdfs:comment 'Likelihood rating of the hazard occurring after existing controls have been applied, using the same qualitative scale as inherent likelihood.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Overall residual risk level after controls are applied, categorized as low, medium, high, or extreme, representing the remaining risk exposure.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Numerical risk score representing the residual risk level after controls, calculated using the same methodology as inherent risk score.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAcceptability rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptability' ;
    rdfs:comment 'Determination of whether the residual risk level is acceptable to the organization, tolerable with monitoring, or unacceptable requiring further action.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTreatmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Treatment Required Flag' ;
    rdfs:comment 'Boolean indicator of whether additional risk treatment or control measures are required to bring the residual risk to an acceptable level.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleAgentId rdf:type rdf:Property ;
    rdfs:label 'Responsible Agent Id' ;
    rdfs:comment 'Foreign key linking to network.agent. Business justification: Incidents at agent-operated facilities or during agent-handled segments require linking to the responsible agent for accountability, investigation, insurance claims, and performance tracking. Essentia' ;
    rdfs:domain ind:HseIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'The body part(s) injured or affected by the incident (e.g., hand, back, head, respiratory system). Null for non-injury incidents.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Involved Flag' ;
    rdfs:comment 'Indicates whether dangerous goods (hazardous materials, hazmat) were involved in or contributed to the incident.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Number of calendar days the injured party was unable to work due to the incident. Zero for incidents not resulting in lost time. Used for Lost Time Injury (LTI) rate calculations.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysRestrictedDuty rdf:type rdf:Property ;
    rdfs:label 'Days Restricted Duty' ;
    rdfs:comment 'Number of calendar days the injured party worked on restricted or light duty due to the incident. Zero if no work restrictions were imposed.' ;
    rdfs:domain ind:HseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Flag' ;
    rdfs:comment 'Indicates whether the incident resulted in environmental damage or pollution (spill, release, contamination).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDamageCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Damage Cost' ;
    rdfs:comment 'Estimated monetary cost of property damage resulting from the incident, in the reporting currency (USD). Null if no property damage occurred.' ;
    rdfs:domain ind:HseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:injuredPartyName rdf:type rdf:Property ;
    rdfs:label 'Injured Party Name' ;
    rdfs:comment 'Full name of the person(s) injured or affected by the incident. May be employee, contractor, or third party. Null for property-only or near-miss incidents.' ;
    rdfs:domain ind:HseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyType rdf:type rdf:Property ;
    rdfs:label 'Injured Party Type' ;
    rdfs:comment 'Classification of the injured or affected party: employee (Transport Shipping employee), contractor (third-party contractor), third-party (customer, vendor, partner), public (member of public), none (no injury - property or near-miss incident).' ;
    rdfs:domain ind:HseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryType rdf:type rdf:Property ;
    rdfs:label 'Injury Type' ;
    rdfs:comment 'Specific type or nature of injury sustained (e.g., laceration, fracture, sprain, burn, respiratory exposure). Null for non-injury incidents. [ENUM-REF-CANDIDATE: laceration|fracture|sprain|strain|burn|contusion|abrasion|puncture|amputation|respiratory|chemical_exposure|heat_stress|cold_stress|hearing_loss|eye_injury|back_injury|head_injury|multiple_injuries — promote to reference product]' ;
    rdfs:domain ind:HseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordableFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Flag' ;
    rdfs:comment 'Indicates whether this incident meets OSHA criteria for recordability under 29 CFR 1904. True if the incident must be recorded on OSHA Form 300.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:propertyDamageFlag rdf:type rdf:Property ;
    rdfs:label 'Property Damage Flag' ;
    rdfs:comment 'Indicates whether the incident resulted in damage to property, equipment, vehicles, or facilities.' ;
    rdfs:domain ind:HseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Name of the person who initially reported the incident to HSE management or the safety system.' ;
    rdfs:domain ind:HseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'The work shift during which the incident occurred: day (daytime shift), night (overnight shift), evening (evening shift), rotating (rotating shift schedule).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spillVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Spill Volume Liters' ;
    rdfs:comment 'Volume of hazardous material or pollutant spilled or released, measured in liters. Null if no spill occurred.' ;
    rdfs:domain ind:HseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hseLegalRegisterId rdf:type rdf:Property ;
    rdfs:label 'Hse Legal Register Id' ;
    rdfs:comment 'Unique identifier for the HSE legal register entry. Primary key for the HSE legal and regulatory obligations register.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementingSafetyProgramId rdf:type rdf:Property ;
    rdfs:label 'Implementing Safety Program Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_program. Business justification: Legal obligations in the HSE legal register drive the creation and operation of safety programs (e.g., OSHA 1910.134 respiratory protection standard → Respiratory Protection Program). This FK links ea' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:primaryHseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Hse Employee Id' ;
    rdfs:comment 'Employee identifier of the individual accountable for ensuring compliance with this regulation within Transport Shipping (typically HSE manager, compliance officer, or department head).' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryHseResponsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Hse Responsible Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByRegulationHseLegalRegisterId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Regulation Hse Legal Register Id' ;
    rdfs:comment 'Foreign key reference to the newer regulation that supersedes this entry. Null if not superseded.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HseLegalRegister .

ind:tertiaryHseLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Hse Last Modified By User Employee Id' ;
    rdfs:comment 'Employee identifier of the user who last modified this register entry.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment, revision, or update to the regulation. Null if no amendments since original effective date.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicabilityToOperations rdf:type rdf:Property ;
    rdfs:label 'Applicability To Operations' ;
    rdfs:comment 'Detailed description of how and where the regulation applies to Transport Shipping operations, including specific business units, facilities, activities, or processes covered.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceGapDescription rdf:type rdf:Property ;
    rdfs:label 'Compliance Gap Description' ;
    rdfs:comment 'Detailed description of any identified compliance gaps, deficiencies, or non-conformances. Null if status is compliant or not_applicable.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationDetail rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Detail' ;
    rdfs:comment 'Comprehensive detailed description of all specific compliance obligations, including reporting requirements, operational controls, training mandates, record-keeping duties, and performance standards.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationSummary rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Summary' ;
    rdfs:comment 'Concise summary of the key compliance requirements, duties, and obligations imposed by the regulation on Transport Shipping.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseDomain rdf:type rdf:Property ;
    rdfs:label 'Hse Domain' ;
    rdfs:comment 'Primary HSE domain category that the regulation addresses: occupational health, workplace safety, environmental protection, dangerous goods handling, emergency response, or process safety management.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Internal Document Reference' ;
    rdfs:comment 'Reference to internal Transport Shipping policy, procedure, or compliance document that implements this regulation (e.g., document management system reference, SharePoint path).' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso45001ClauseReference rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Clause Reference' ;
    rdfs:comment 'Reference to the specific ISO 45001:2018 clause(s) that this regulation supports or relates to (e.g., 6.1.3 Legal requirements and other requirements).' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Record Retention Years' ;
    rdfs:comment 'Minimum number of years that compliance records, documentation, and evidence must be retained as mandated by the regulation. Null if no specific retention requirement.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registerEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Register Entry Number' ;
    rdfs:comment 'Business-assigned unique reference number for the legal register entry, used for tracking and audit purposes.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerStatus rdf:type rdf:Property ;
    rdfs:label 'Register Status' ;
    rdfs:comment 'Lifecycle status of this register entry: active (current and applicable), superseded (replaced by newer regulation), archived (no longer applicable), or under_review (applicability being assessed).' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationName rdf:type rdf:Property ;
    rdfs:label 'Regulation Name' ;
    rdfs:comment 'Full official name or title of the health, safety, or environmental legislation, regulation, standard, or code of practice.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference Number' ;
    rdfs:comment 'Official citation, act number, or reference code assigned by the regulatory authority (e.g., 29 CFR 1910, ISO 45001:2018).' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Regulation Source Url' ;
    rdfs:comment 'Web URL or hyperlink to the official source document, regulatory authority website, or legal database where the full regulation text can be accessed.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationType rdf:type rdf:Property ;
    rdfs:label 'Regulation Type' ;
    rdfs:comment 'Classification of the legal obligation: legislation (primary law), regulation (statutory instrument), standard (ISO/industry standard), code of practice (approved code), permit condition (site-specific requirement), or guideline (non-binding best practice).' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement Flag' ;
    rdfs:comment 'Boolean indicator whether the regulation mandates periodic or event-driven reporting to regulatory authorities. True if reporting required, False otherwise.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department or business unit with primary responsibility for managing compliance with this regulation (e.g., HSE, Operations, Fleet Management, Warehouse Operations).' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequirementDescription rdf:type rdf:Property ;
    rdfs:label 'Training Requirement Description' ;
    rdfs:comment 'Description of mandatory training, certification, or competency requirements specified by the regulation. Null if no training requirement.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Training Requirement Flag' ;
    rdfs:comment 'Boolean indicator whether the regulation mandates specific training or competency requirements for employees. True if training required, False otherwise.' ;
    rdfs:domain ind:HseLegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Incident Investigation Id' ;
    rdfs:comment 'Unique identifier for the incident investigation record. Primary key.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Detailed list of contributing factors identified during the investigation. May include human factors, equipment failures, procedural gaps, environmental conditions, and organizational factors.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRecommended rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Recommended' ;
    rdfs:comment 'Detailed list of corrective actions recommended by the investigation team to prevent recurrence. Includes immediate actions, short-term improvements, and long-term systemic changes.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalFactorsIdentified rdf:type rdf:Property ;
    rdfs:label 'Environmental Factors Identified' ;
    rdfs:comment 'Environmental factors contributing to the incident, such as weather conditions, lighting, noise, temperature, or workspace layout.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentFactorsIdentified rdf:type rdf:Property ;
    rdfs:label 'Equipment Factors Identified' ;
    rdfs:comment 'Equipment or mechanical factors contributing to the incident, such as equipment failure, design flaws, maintenance deficiencies, or inadequate safeguards.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceCollected rdf:type rdf:Property ;
    rdfs:label 'Evidence Collected' ;
    rdfs:comment 'Indicates whether physical or digital evidence was collected during the investigation. Includes photos, videos, equipment samples, documents, and logs.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalInvestigatorEngaged rdf:type rdf:Property ;
    rdfs:label 'External Investigator Engaged' ;
    rdfs:comment 'Indicates whether an external third-party investigator or consultant was engaged to support the investigation. Common for high-severity incidents or specialized expertise needs.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'External Investigator Name' ;
    rdfs:comment 'Name of the external investigation firm or consultant engaged. Used for vendor management and audit trails.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanFactorsIdentified rdf:type rdf:Property ;
    rdfs:label 'Human Factors Identified' ;
    rdfs:comment 'Human factors contributing to the incident, such as fatigue, training gaps, communication failures, situational awareness issues, or procedural non-compliance.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentScenePreserved rdf:type rdf:Property ;
    rdfs:label 'Incident Scene Preserved' ;
    rdfs:comment 'Indicates whether the incident scene was preserved for investigation purposes. Critical for forensic analysis and root cause determination.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationClosedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Closed Date' ;
    rdfs:comment 'Date when the investigation was formally closed after all corrective actions were reviewed and approved. Final lifecycle milestone.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Investigation Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the investigation cost estimate. Examples: USD, EUR, GBP.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Investigation Cost Estimate' ;
    rdfs:comment 'Estimated total cost of conducting the investigation, including labor hours, external consultants, testing, and evidence analysis. Used for HSE budget management.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investigationDurationDays rdf:type rdf:Property ;
    rdfs:label 'Investigation Duration Days' ;
    rdfs:comment 'Total number of calendar days from investigation initiation to completion. Used for performance monitoring and continuous improvement of investigation processes.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Initiated Date' ;
    rdfs:comment 'Date when the formal investigation was officially initiated. Regulatory compliance often requires investigation to begin within 24-48 hours of incident occurrence.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Initiated Timestamp' ;
    rdfs:comment 'Precise timestamp when the investigation was formally initiated. Used for compliance tracking and SLA monitoring.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationMethodology rdf:type rdf:Property ;
    rdfs:label 'Investigation Methodology' ;
    rdfs:comment 'Formal investigation methodology applied to determine root cause. Common methods include 5-Why, Fault Tree Analysis, ICAM (Incident Cause Analysis Method), Fishbone Diagram, and Bow-Tie Analysis. [ENUM-REF-CANDIDATE: 5_why|fault_tree_analysis|icam|root_cause_analysis|fishbone_diagram|bow_tie|tripod_beta|taproot|scat|incident_cause_analysis — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Additional notes, observations, or context captured during the investigation process. Free-text field for investigator commentary and supplemental information.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Externally-known unique business identifier for the investigation. Format: INV-YYYYMMDD-XXXXXX. Used for tracking and regulatory reporting.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationPriority rdf:type rdf:Property ;
    rdfs:label 'Investigation Priority' ;
    rdfs:comment 'Priority level assigned to the investigation based on incident severity, potential for recurrence, and regulatory requirements. Determines resource allocation and completion timelines.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the investigation process. Tracks progression from initiation through closure and regulatory submission. [ENUM-REF-CANDIDATE: initiated|in_progress|witness_interviews|root_cause_analysis|corrective_actions|pending_review|completed|closed|regulatory_submitted — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Investigation Team Members' ;
    rdfs:comment 'Comma-separated list of investigation team member names or IDs. Includes subject matter experts, safety officers, operational managers, and union representatives as applicable.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Lead Investigator Name' ;
    rdfs:comment 'Full name of the lead investigator. Captured for reporting and audit trail purposes.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalFactorsIdentified rdf:type rdf:Property ;
    rdfs:label 'Organizational Factors Identified' ;
    rdfs:comment 'Organizational or systemic factors contributing to the incident, such as inadequate policies, resource constraints, safety culture issues, or management system gaps.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionsRecommended rdf:type rdf:Property ;
    rdfs:label 'Preventive Actions Recommended' ;
    rdfs:comment 'Preventive actions recommended to address similar risks across the organization. Broader than corrective actions, focusing on systemic risk reduction.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date when the investigation report was submitted to the relevant regulatory authority. Critical for compliance tracking and audit trails.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Status' ;
    rdfs:comment 'Status of regulatory submission for this investigation. Tracks compliance with OSHA, DOT, IMO, IATA, and other governing body reporting requirements. [ENUM-REF-CANDIDATE: not_required|pending|submitted|acknowledged|under_review|accepted|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDetermination rdf:type rdf:Property ;
    rdfs:label 'Root Cause Determination' ;
    rdfs:comment 'Final determination of the root cause(s) of the incident based on investigation findings. Represents the fundamental reason(s) the incident occurred, addressing underlying systemic issues.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessStatementsSummary rdf:type rdf:Property ;
    rdfs:label 'Witness Statements Summary' ;
    rdfs:comment 'High-level summary of witness statements collected during the investigation. Detailed statements are stored separately for confidentiality. This field captures key themes and observations.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupationalHealthCaseId rdf:type rdf:Property ;
    rdfs:label 'Occupational Health Case Id' ;
    rdfs:comment 'Unique identifier for the occupational health case record. Primary key for the occupational health case entity.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OccupationalHealthCase .

ind:caseDocumentPackageId rdf:type rdf:Property ;
    rdfs:label 'Case Document Package Id' ;
    rdfs:comment 'Foreign key linking to document.document_package. Business justification: Occupational health cases generate document packages (medical records, workers compensation filings, return-to-work documentation, OSHA forms). Required for workers comp claims, regulatory compliance,' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentPackage .

ind:primaryOccupationalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Occupational Employee Id' ;
    rdfs:comment 'Reference to the Transport Shipping employee who is the subject of this occupational health case.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOccupationalModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Occupational Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the system user who last modified this occupational health case record.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accommodationDescription rdf:type rdf:Property ;
    rdfs:label 'Accommodation Description' ;
    rdfs:comment 'Description of workplace accommodations provided or planned to support the employee, such as ergonomic equipment, schedule modifications, or job restructuring.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accommodationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Accommodation Required Flag' ;
    rdfs:comment 'Indicates whether workplace accommodations are required to support the employees return to work or continued employment.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualReturnToFullDutyDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return To Full Duty Date' ;
    rdfs:comment 'Actual date when the employee was medically cleared and returned to full, unrestricted work duties.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseClosedDate rdf:type rdf:Property ;
    rdfs:label 'Case Closed Date' ;
    rdfs:comment 'Date when the occupational health case was officially closed after completion of all required interventions and clearances.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseClosureOutcome rdf:type rdf:Property ;
    rdfs:label 'Case Closure Outcome' ;
    rdfs:comment 'Final outcome classification of the occupational health case at the time of closure, indicating the employees work status resolution. [ENUM-REF-CANDIDATE: full_recovery|partial_recovery|permanent_restrictions|disability_retirement|resignation|termination|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseManagerName rdf:type rdf:Property ;
    rdfs:label 'Case Manager Name' ;
    rdfs:comment 'Name of the case manager responsible for coordinating the occupational health case and return-to-work process.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseOpenDate rdf:type rdf:Property ;
    rdfs:label 'Case Open Date' ;
    rdfs:comment 'Date when the occupational health case was officially opened and case management began.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Open Timestamp' ;
    rdfs:comment 'Precise timestamp when the occupational health case was opened in the system, including time zone information.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysOnRestrictedDuty rdf:type rdf:Property ;
    rdfs:label 'Days On Restricted Duty' ;
    rdfs:comment 'Total number of calendar days the employee worked under modified or restricted duty arrangements.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diagnosisCategory rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Category' ;
    rdfs:comment 'High-level categorization of the medical diagnosis or health condition being managed, without detailed clinical information. Examples include musculoskeletal disorder, respiratory condition, hearing loss, stress-related condition.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisCode rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Code' ;
    rdfs:comment 'Standardized ICD-10 or ICD-11 code representing the medical diagnosis associated with this occupational health case.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Estimated total cost associated with managing this occupational health case, including medical expenses, lost time, and administrative costs.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedReturnToFullDutyDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return To Full Duty Date' ;
    rdfs:comment 'Anticipated date when the employee is expected to return to full, unrestricted work duties based on medical prognosis.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitnessClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Fitness Clearance Date' ;
    rdfs:comment 'Date when the employee received medical clearance confirming fitness to perform their job duties.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitnessForDutyStatus rdf:type rdf:Property ;
    rdfs:label 'Fitness For Duty Status' ;
    rdfs:comment 'Current medical determination of the employees ability to safely perform their assigned job duties.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAppointmentDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Appointment Date' ;
    rdfs:comment 'Date of the next scheduled follow-up appointment with the occupational health provider for case review and assessment.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedDutyPlan rdf:type rdf:Property ;
    rdfs:label 'Modified Duty Plan' ;
    rdfs:comment 'Details of the modified duty or light duty work plan established to accommodate the employees restrictions while facilitating return to work.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedDutyStartDate rdf:type rdf:Property ;
    rdfs:label 'Modified Duty Start Date' ;
    rdfs:comment 'Date when the employee began working under modified duty or light duty arrangements.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:privacyCaseFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Case Flag' ;
    rdfs:comment 'Indicates whether this case qualifies as a privacy concern case under OSHA recordkeeping rules, requiring special handling of employee identity.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatingProviderFacility rdf:type rdf:Property ;
    rdfs:label 'Treating Provider Facility' ;
    rdfs:comment 'Name of the medical facility, clinic, or occupational health center where the employee is receiving treatment.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatingProviderName rdf:type rdf:Property ;
    rdfs:label 'Treating Provider Name' ;
    rdfs:comment 'Name of the occupational health physician, nurse practitioner, or medical professional managing the employees health case.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workRestrictionsImposed rdf:type rdf:Property ;
    rdfs:label 'Work Restrictions Imposed' ;
    rdfs:comment 'Description of any temporary or permanent work restrictions placed on the employee by the treating provider, such as lifting limits, no driving, reduced hours, or environmental restrictions.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompensationCarrier rdf:type rdf:Property ;
    rdfs:label 'Workers Compensation Carrier' ;
    rdfs:comment 'Name of the insurance carrier handling the workers compensation claim associated with this case.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompensationClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Workers Compensation Claim Number' ;
    rdfs:comment 'Associated workers compensation insurance claim number if the occupational health case resulted in a compensable claim.' ;
    rdfs:domain ind:OccupationalHealthCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordableId rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Id' ;
    rdfs:comment 'Unique identifier for the OSHA recordable injury or illness case. Primary key for regulatory compliance tracking.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amputationFlag rdf:type rdf:Property ;
    rdfs:label 'Amputation Flag' ;
    rdfs:comment 'Indicates whether the injury resulted in amputation of any body part. Triggers OSHA 24-hour reporting requirement for severe injuries.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseClassification rdf:type rdf:Property ;
    rdfs:label 'Case Classification' ;
    rdfs:comment 'OSHA 300 Log classification of case severity: death, days away from work, job transfer or restriction, or other recordable case. Determines column placement on OSHA 300 Log.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOnJobTransferRestriction rdf:type rdf:Property ;
    rdfs:label 'Days On Job Transfer Restriction' ;
    rdfs:comment 'Total number of calendar days the employee was on restricted work activity or job transfer due to the injury or illness. Used for OSHA 300 Log column 6 and DART rate calculation.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deathDate rdf:type rdf:Property ;
    rdfs:label 'Death Date' ;
    rdfs:comment 'Date of employee death if the injury or illness was fatal. Required for OSHA fatality reporting within 8 hours.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deathFlag rdf:type rdf:Property ;
    rdfs:label 'Death Flag' ;
    rdfs:comment 'Indicates whether the injury or illness resulted in the death of the employee. Critical flag for OSHA 300 Log column 1 and fatality reporting requirements.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eyeLossFlag rdf:type rdf:Property ;
    rdfs:label 'Eye Loss Flag' ;
    rdfs:comment 'Indicates whether the injury resulted in loss of an eye. Triggers OSHA 24-hour reporting requirement for severe injuries.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hospitalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Hospitalization Flag' ;
    rdfs:comment 'Indicates whether the employee was hospitalized overnight as an in-patient. Triggers OSHA 8-hour reporting requirement for severe injuries.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentTime rdf:type rdf:Property ;
    rdfs:label 'Incident Time' ;
    rdfs:comment 'Time of day when the incident occurred (24-hour format HH:MM). Used for shift-based safety analysis and temporal risk pattern identification.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:injuryIllnessType rdf:type rdf:Property ;
    rdfs:label 'Injury Illness Type' ;
    rdfs:comment 'Classification of the recordable case as injury or specific illness category per OSHA 300 Log column requirements.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:natureOfInjuryIllness rdf:type rdf:Property ;
    rdfs:label 'Nature Of Injury Illness' ;
    rdfs:comment 'Detailed description of the nature of the injury or illness (e.g., fracture, sprain, laceration, chemical burn, respiratory illness). Free-text field for OSHA 301 reporting.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osha300aIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Osha 300a Included Flag' ;
    rdfs:comment 'Indicates whether this case was included in the annual OSHA 300A Summary of Work-Related Injuries and Illnesses for the reporting year.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicianDiagnosis rdf:type rdf:Property ;
    rdfs:label 'Physician Diagnosis' ;
    rdfs:comment 'Medical diagnosis provided by treating physician or healthcare professional. Used to determine recordability and case classification.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordableDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Recordable Determination Date' ;
    rdfs:comment 'Date on which the case was determined to be OSHA recordable. Used for compliance timeline tracking and audit trail.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Method' ;
    rdfs:comment 'Method by which the case was submitted to regulatory authorities (electronic filing, paper form, phone report). Tracks compliance process efficiency.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'Calendar year for which this case is recorded on the OSHA 300 Log. Used for annual summary aggregation and OSHA 300A posting requirements.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentFacilityName rdf:type rdf:Property ;
    rdfs:label 'Treatment Facility Name' ;
    rdfs:comment 'Name of the medical facility or healthcare provider where the employee received treatment. Required for OSHA 301 Incident Report.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workRelatedDetermination rdf:type rdf:Property ;
    rdfs:label 'Work Related Determination' ;
    rdfs:comment 'Determination of whether the injury or illness is work-related per OSHA criteria. Only work-related cases are recordable on OSHA 300 Log.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Ppe Issuance Id' ;
    rdfs:comment 'Unique identifier for the PPE issuance transaction record.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPpeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ppe Employee Id' ;
    rdfs:comment 'Identifier of the Transport Shipping employee receiving the PPE.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgmentSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Signature Flag' ;
    rdfs:comment 'Indicates whether the receiving employee provided a signature or electronic acknowledgment confirming receipt of the PPE.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the employee acknowledged receipt of the PPE.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'Safety certification standard or regulatory compliance mark that the PPE item meets (e.g., ANSI Z87.1, EN 397, CSA Z94.1).' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementMet rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Met' ;
    rdfs:comment 'Indicates whether this PPE issuance fulfills a mandatory safety compliance requirement for the employees role and work area.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionAtIssue rdf:type rdf:Property ;
    rdfs:label 'Condition At Issue' ;
    rdfs:comment 'Physical condition of the PPE item at the time of issuance to the employee.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the PPE cost amounts.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReplacementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Replacement Date' ;
    rdfs:comment 'Anticipated date when the PPE item should be replaced based on manufacturer guidelines, usage patterns, or regulatory requirements.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitTestDate rdf:type rdf:Property ;
    rdfs:label 'Fit Test Date' ;
    rdfs:comment 'Date when the employee completed a fit test for the issued PPE, if required.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitTestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fit Test Required Flag' ;
    rdfs:comment 'Indicates whether the issued PPE (e.g., respirator) requires a fit test to ensure proper seal and protection.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fitTestResult rdf:type rdf:Property ;
    rdfs:label 'Fit Test Result' ;
    rdfs:comment 'Outcome of the fit test conducted for the issued PPE.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceNumber rdf:type rdf:Property ;
    rdfs:label 'Issuance Number' ;
    rdfs:comment 'Business-readable unique reference number for the PPE issuance transaction, used for tracking and audit purposes.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceReason rdf:type rdf:Property ;
    rdfs:label 'Issuance Reason' ;
    rdfs:comment 'Business reason or trigger for issuing the PPE to the employee.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeItemCode rdf:type rdf:Property ;
    rdfs:label 'Ppe Item Code' ;
    rdfs:comment 'Stock Keeping Unit (SKU) or catalog code identifying the specific PPE item issued from inventory.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeItemDescription rdf:type rdf:Property ;
    rdfs:label 'Ppe Item Description' ;
    rdfs:comment 'Detailed description of the PPE item including brand, model, size, and specifications.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeType rdf:type rdf:Property ;
    rdfs:label 'Ppe Type' ;
    rdfs:comment 'Category of PPE issued to the employee. [ENUM-REF-CANDIDATE: hard_hat|high_visibility_vest|safety_boots|gloves|respirator|hearing_protection|eye_protection|fall_arrest_harness|face_shield|protective_coverall — promote to reference product]' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityIssued rdf:type rdf:Property ;
    rdfs:label 'Quantity Issued' ;
    rdfs:comment 'Number of PPE units issued to the employee in this transaction.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnCondition rdf:type rdf:Property ;
    rdfs:label 'Return Condition' ;
    rdfs:comment 'Physical condition of the PPE item when returned by the employee.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date when the PPE item was returned by the employee, if applicable (e.g., upon role change, termination, or equipment replacement).' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Size specification of the PPE item issued to ensure proper fit and protection.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Training Completed Flag' ;
    rdfs:comment 'Indicates whether the employee has completed required training on proper use, maintenance, and limitations of the issued PPE.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workArea rdf:type rdf:Property ;
    rdfs:label 'Work Area' ;
    rdfs:comment 'Primary work area or operational zone where the employee is assigned, determining PPE requirements.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Id' ;
    rdfs:comment 'Unique identifier for the regulatory notification record. Primary key.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRegulatorySubmittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Submitted By Employee Id' ;
    rdfs:comment 'Reference to the employee who submitted the notification to the regulatory authority.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorityActionRequired rdf:type rdf:Property ;
    rdfs:label 'Authority Action Required' ;
    rdfs:comment 'Description of any follow-up actions or corrective measures required by the regulatory authority.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Authority Reference Number' ;
    rdfs:comment 'Unique reference or case number assigned by the regulatory authority to this notification.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hospitalizationCount rdf:type rdf:Property ;
    rdfs:label 'Hospitalization Count' ;
    rdfs:comment 'Number of individuals hospitalized as a result of the incident.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'High-level classification of the incident type that triggered the notification (e.g., workplace injury, dangerous goods incident, environmental spill, vehicle accident).' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Late Submission Flag' ;
    rdfs:comment 'Indicates whether the notification was submitted after the statutory deadline.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationContentSummary rdf:type rdf:Property ;
    rdfs:label 'Notification Content Summary' ;
    rdfs:comment 'High-level summary of the notification content, including key facts reported to the authority.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDetails rdf:type rdf:Property ;
    rdfs:label 'Notification Details' ;
    rdfs:comment 'Detailed narrative or structured content of the notification as submitted to the regulatory authority.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Business identifier for the regulatory notification, used for tracking and reference purposes.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTrigger rdf:type rdf:Property ;
    rdfs:label 'Notification Trigger' ;
    rdfs:comment 'Specific regulatory requirement or threshold that triggered the mandatory notification (e.g., fatality, lost-time injury, dangerous goods release, environmental discharge).' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Classification of the regulatory notification based on reporting stage and purpose.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Code' ;
    rdfs:comment 'Standardized code or abbreviation for the regulatory authority (e.g., OSHA, EPA, IMO).' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSummary rdf:type rdf:Property ;
    rdfs:label 'Response Summary' ;
    rdfs:comment 'Summary of the response or feedback received from the regulatory authority.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statutoryDeadline rdf:type rdf:Property ;
    rdfs:label 'Statutory Deadline' ;
    rdfs:comment 'Legal deadline by which the notification must be submitted to the regulatory authority.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Confirmation Number' ;
    rdfs:comment 'Confirmation or tracking number provided by the submission system upon successful filing.' ;
    rdfs:domain ind:RegulatoryNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRiskAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Assessor Employee Id' ;
    rdfs:comment 'Employee identifier for the individual who conducted the risk assessment. Links to workforce records.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByAssessmentRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Assessment Risk Assessment Id' ;
    rdfs:comment 'Identifier of the risk assessment that supersedes this one. Used to track assessment lineage when a new assessment replaces an older one. Null if not superseded.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:approvalAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Name' ;
    rdfs:comment 'Full name of the individual with authority to approve the risk assessment. Typically an HSE manager, operations manager, or senior leader.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Assessment Team Members' ;
    rdfs:comment 'List or description of team members who participated in the risk assessment. May include subject matter experts, supervisors, and frontline workers.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Category of risk assessment conducted. Defines the scope and methodology applied (e.g., Job Safety Analysis for specific tasks, Change Management Risk Assessment for operational changes, New Facility Risk Assessment for site evaluations).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional comments, notes, or observations related to the risk assessment. Provides supplementary context or clarifications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationWithWorkersFlag rdf:type rdf:Property ;
    rdfs:label 'Consultation With Workers Flag' ;
    rdfs:comment 'Indicates whether workers or their representatives were consulted during the risk assessment process. Required by ISO 45001 and many jurisdictions. True if consultation occurred.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlHierarchyApplied rdf:type rdf:Property ;
    rdfs:label 'Control Hierarchy Applied' ;
    rdfs:comment 'The level of the hierarchy of controls applied to mitigate the identified risk. Follows the standard hierarchy: Elimination, Substitution, Engineering Controls, Administrative Controls, Personal Protective Equipment (PPE).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasuresRecommended rdf:type rdf:Property ;
    rdfs:label 'Control Measures Recommended' ;
    rdfs:comment 'Detailed description of control measures, safeguards, or mitigation actions recommended to reduce risk. May include engineering controls, administrative controls, and personal protective equipment (PPE).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponsePlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Plan Required Flag' ;
    rdfs:comment 'Indicates whether the assessed activity requires a formal emergency response plan due to the nature or severity of identified risks. True if emergency response planning is required.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Description' ;
    rdfs:comment 'Description of potential environmental impacts identified during the risk assessment. Null if no environmental impacts are identified.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardsIdentified rdf:type rdf:Property ;
    rdfs:label 'Hazards Identified' ;
    rdfs:comment 'Comprehensive list or description of all hazards identified during the risk assessment. May include physical, chemical, biological, ergonomic, and psychosocial hazards.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Level' ;
    rdfs:comment 'Risk level before any control measures are applied. Represents the raw or unmitigated risk exposure.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentSeverity rdf:type rdf:Property ;
    rdfs:label 'Inherent Severity' ;
    rdfs:comment 'Potential consequence or impact of the hazard before controls are applied. Part of the inherent risk calculation.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Risk level after recommended control measures are implemented. Represents the mitigated or remaining risk exposure.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualSeverity rdf:type rdf:Property ;
    rdfs:label 'Residual Severity' ;
    rdfs:comment 'Potential consequence or impact of the hazard after controls are applied. Part of the residual risk calculation.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Scheduled date for the next review or re-assessment of this risk assessment. Ensures periodic validation and updates to reflect changing conditions.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAcceptableFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptable Flag' ;
    rdfs:comment 'Indicates whether the residual risk level is deemed acceptable according to organizational risk tolerance criteria. True if acceptable, False if further mitigation is required.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskRatingMethodology rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Methodology' ;
    rdfs:comment 'The methodology or framework used to evaluate and rate risks. Common methods include risk matrices (likelihood x severity), Failure Mode and Effects Analysis (FMEA), Hazard and Operability Study (HAZOP), or Bow-Tie Analysis.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertId rdf:type rdf:Property ;
    rdfs:label 'Alert Id' ;
    rdfs:comment 'Unique identifier for the safety alert record. Primary key.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alert Employee Id' ;
    rdfs:comment 'Identifier of the HSE manager or authorized personnel who approved the safety alert for publication.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertIssuingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alert Issuing Employee Id' ;
    rdfs:comment 'Identifier of the HSE employee who authored or issued the safety alert.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alert Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who last modified the safety alert record.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedIncidentHseIncidentId rdf:type rdf:Property ;
    rdfs:label 'Related Incident Hse Incident Id' ;
    rdfs:comment 'Reference to the HSE incident record that triggered this safety alert, if the alert is a lessons-learned notice derived from a specific incident investigation.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HseIncident .

ind:supersedesAlertId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Alert Id' ;
    rdfs:comment 'Identifier of the previous safety alert that this alert replaces or supersedes. Used to maintain alert version history and ensure outdated information is retired.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:trainingId rdf:type rdf:Property ;
    rdfs:label 'Training Id' ;
    rdfs:comment 'Identifier of the training course that recipients must complete in response to this alert, if training is required.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Training .

ind:triggeringConsignmentId rdf:type rdf:Property ;
    rdfs:label 'Triggering Consignment Id' ;
    rdfs:comment 'Foreign key linking to shipment.consignment. Business justification: Safety alerts triggered by specific shipment incidents (DG packaging failure, temperature excursion, security breach) require shipment reference for targeted distribution to affected stakeholders, cor' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consignment .

ind:triggeringSafetyObservationId rdf:type rdf:Property ;
    rdfs:label 'Triggering Safety Observation Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_observation. Business justification: Safety alerts may be issued based on specific safety observations or observation trends. This FK links the alert to the observation that triggered it, supporting alert effectiveness tracking and obser' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Observation .

ind:acknowledgementCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Completion Rate' ;
    rdfs:comment 'Percentage of recipients who have acknowledged the alert, calculated as (acknowledgements_received / total_recipients) * 100. Used to track compliance with acknowledgement requirements.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acknowledgementDeadline rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Deadline' ;
    rdfs:comment 'Target date by which all recipients should acknowledge the safety alert. Applicable only when acknowledgement is required.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementsReceived rdf:type rdf:Property ;
    rdfs:label 'Acknowledgements Received' ;
    rdfs:comment 'Number of recipients who have formally acknowledged receipt and understanding of the safety alert.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertDescription rdf:type rdf:Property ;
    rdfs:label 'Alert Description' ;
    rdfs:comment 'Detailed narrative describing the safety-critical information, hazard details, regulatory changes, lessons learned, or recommended actions. Provides full context for the alert.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertNumber rdf:type rdf:Property ;
    rdfs:label 'Alert Number' ;
    rdfs:comment 'Business-facing unique reference number for the safety alert, used for external communication and tracking (e.g., SA-2024-001).' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle status of the safety alert: draft for initial creation, pending approval for review stage, active for published and in-effect alerts, superseded when replaced by newer alert, archived for historical reference, or cancelled if withdrawn.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the safety alert indicating the nature of the communication: safety bulletin for general safety information, lessons learned notice for incident-derived insights, regulatory update for compliance changes, dangerous goods (DG) advisory for hazmat handling updates, weather advisory for environmental hazards, or environmental advisory for ecological concerns.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'Primary communication channel used to distribute the safety alert to the target audience: email for electronic distribution, intranet for portal posting, mobile app for push notifications, printed notice for physical postings, toolbox talk for in-person briefings, or all channels for critical alerts requiring multi-channel distribution.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Intended recipient groups for the safety alert (e.g., all staff, drivers, warehouse personnel, dangerous goods handlers, management, specific facilities). May be comma-separated list for multiple audiences. [ENUM-REF-CANDIDATE: all staff|drivers|warehouse|dangerous goods handlers|management|facility managers|fleet operators|customs brokers|customer service|maintenance|security — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRecipients rdf:type rdf:Property ;
    rdfs:label 'Total Recipients' ;
    rdfs:comment 'Total number of employees or personnel to whom the safety alert was distributed.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:translationAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Available Flag' ;
    rdfs:comment 'Indicates whether the safety alert has been translated into additional languages for multi-lingual workforce communication. True if translations exist, false otherwise.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditedPartnerId rdf:type rdf:Property ;
    rdfs:label 'Audited Partner Id' ;
    rdfs:comment 'Foreign key linking to network.network_partner. Business justification: Safety audits of network partners (3PLs, agents, carriers) are standard supply chain risk management practice. Links audit to partner for certification tracking, contract compliance verification, and ' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:auditedSafetyProgramId rdf:type rdf:Property ;
    rdfs:label 'Audited Safety Program Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_program. Business justification: Safety audits verify implementation and effectiveness of specific safety programs (e.g., audit of Lockout/Tagout program). This FK links each audit to the program being audited, enabling program-speci' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:previousAuditId rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Id' ;
    rdfs:comment 'Identifier of the previous audit conducted at this facility or for this scope. Used to track audit history and trend analysis. Null if this is the first audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the audit fieldwork was completed. Used to measure audit duration and efficiency.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when the audit fieldwork commenced. May differ from scheduled date due to operational constraints or delays.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:areasAudited rdf:type rdf:Property ;
    rdfs:label 'Areas Audited' ;
    rdfs:comment 'Comma-separated list or free text description of specific operational areas, processes, or systems covered in the audit (e.g., hazardous materials handling, forklift operations, emergency response procedures, PPE compliance, ergonomics program).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the third-party certification body conducting the audit for ISO 45001, OHSAS 18001, or other management system certification. Null if not a certification audit.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteria rdf:type rdf:Property ;
    rdfs:label 'Criteria' ;
    rdfs:comment 'Detailed description of the criteria, policies, procedures, or requirements against which the audit was conducted. May reference specific clauses of standards, internal policies, or regulatory requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentsReviewedCount rdf:type rdf:Property ;
    rdfs:label 'Documents Reviewed Count' ;
    rdfs:comment 'Number of documents, records, or procedures reviewed during the audit (e.g., safety policies, training records, incident reports, inspection logs).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeesInterviewedCount rdf:type rdf:Property ;
    rdfs:label 'Employees Interviewed Count' ;
    rdfs:comment 'Number of employees interviewed during the audit as part of the evidence-gathering process.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Scheduled Date' ;
    rdfs:comment 'Scheduled date for the follow-up audit to verify corrective action implementation. Null if no follow-up is required.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor for reporting and accountability purposes.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Audit Date' ;
    rdfs:comment 'Planned date for the next periodic audit of this facility or scope, based on audit frequency requirements (e.g., annual, biennial). Used for audit program planning.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Primary objective or purpose of the audit (e.g., annual compliance verification, incident follow-up, pre-certification assessment, new facility commissioning, post-acquisition integration). Free text to capture specific business context.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallAuditRating rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Rating' ;
    rdfs:comment 'Summary rating assigned by the audit team reflecting the overall health, safety, and environmental compliance posture of the audited entity: excellent (exceeds standards), satisfactory (meets standards), needs_improvement (minor gaps), unsatisfactory (significant gaps), or critical (immediate action required).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positiveFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Positive Findings Count' ;
    rdfs:comment 'Number of positive findings or commendations noted during the audit, recognizing exemplary safety practices or compliance achievements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date when the final audit report was formally issued to the audited facility and stakeholders.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date when the audit was scheduled to conclude. Used for resource planning and timeline management.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score representing the percentage of audit criteria met or compliance level achieved (0.00 to 100.00). Used for quantitative benchmarking and trend analysis.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standard rdf:type rdf:Property ;
    rdfs:label 'Standard' ;
    rdfs:comment 'The health, safety, and environmental standard or framework against which the audit is conducted (e.g., ISO 45001, OHSAS 18001, IATA ISAGO, SQAS, OSHA VPP, C-TPAT security standards, internal HSE policy). Free text to accommodate various international and industry-specific standards.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of names or identifiers of additional audit team members who participated in the audit alongside the lead auditor.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Safety Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the safety audit finding record. Primary key for the safety audit finding entity.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousFindingSafetyAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Safety Audit Finding Id' ;
    rdfs:comment 'Reference to the previous finding record if this is a repeat finding. Enables tracking of recurring issues.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyAuditFinding .

ind:primarySafetyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Employee Id' ;
    rdfs:comment 'Reference to the auditor or audit team member who identified and documented this finding.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternarySafetyModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Safety Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this finding record. Supports audit trail and accountability.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySafetyVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Safety Verified By Employee Id' ;
    rdfs:comment 'Reference to the auditor or safety manager who verified the effectiveness of corrective action and authorized finding closure.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Actual date on which the finding was verified as closed following successful completion and verification of corrective action.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditProgramType rdf:type rdf:Property ;
    rdfs:label 'Audit Program Type' ;
    rdfs:comment 'Type of audit program or framework under which this finding was identified. Supports traceability across multiple audit programs. [ENUM-REF-CANDIDATE: iso_45001|iata_isago|sqas|osha_vpp|internal_hse|client_audit|regulatory_inspection|certification_audit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Estimate' ;
    rdfs:comment 'Estimated financial cost to implement corrective action and resolve the finding. Used for budgeting and prioritization.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Business domain or functional area to which the finding relates. Enables categorization and trend analysis across Health, Safety, and Environmental (HSE) domains. [ENUM-REF-CANDIDATE: workplace_safety|dangerous_goods_handling|driver_safety|facility_safety|equipment_safety|emergency_preparedness|training_compliance|documentation|ppe_compliance|environmental_health_safety — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'Date on which the finding was identified during the audit. Represents the business event timestamp for the finding discovery.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this finding for tracking and communication purposes. Used in audit reports and corrective action tracking.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of any immediate containment or interim actions taken at the time of finding identification to mitigate immediate risk.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Likelihood Score' ;
    rdfs:comment 'Numerical score representing the probability that the identified hazard or non-conformance will result in an incident. Typically scored 1-5 where 5 is most likely.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date on which the finding was reported to the relevant regulatory authority, if applicable.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseAnalysisRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Required Flag' ;
    rdfs:comment 'Indicates whether formal root cause analysis is required for this finding. Typically required for major non-conformances and critical findings.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityScore rdf:type rdf:Property ;
    rdfs:label 'Severity Score' ;
    rdfs:comment 'Numerical score representing the potential impact or consequence if the hazard materializes. Typically scored 1-5 where 5 is most severe (fatality or catastrophic loss).' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardClauseReference rdf:type rdf:Property ;
    rdfs:label 'Standard Clause Reference' ;
    rdfs:comment 'Specific clause, section, or requirement number from the applicable standard or regulation that was violated or observed. Examples: ISO 45001 clause 8.1.2, OSHA 1910.178, IATA DGR 7.1.4.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Target date by which the finding must be resolved and corrective action completed. Based on finding severity and regulatory requirements.' ;
    rdfs:domain ind:SafetyAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedIncidentHseIncidentId rdf:type rdf:Property ;
    rdfs:label 'Linked Incident Hse Incident Id' ;
    rdfs:comment 'Identifier of a related HSE incident record if this observation later resulted in an actual incident. Links to the hse_incident product in the safety domain. Null if no incident occurred.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HseIncident .

ind:observationActionOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Observation Action Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee assigned as the owner of the corrective action. Links to the employee master in the workforce domain. Null if no action is required or not yet assigned.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:observationModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Observation Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who last modified the observation record. Links to the employee master in the workforce domain. Used for audit trail.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:observationObserverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Observation Observer Employee Id' ;
    rdfs:comment 'Identifier of the employee who made the safety observation. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:observationVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Observation Verified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who verified the completion and effectiveness of the corrective action, typically a safety officer or supervisor. Links to the employee master in the workforce domain.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:resultingHazardRegisterId rdf:type rdf:Property ;
    rdfs:label 'Resulting Hazard Register Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard_register. Business justification: Safety observations that identify new hazards result in hazard register entries. This FK links the observation to the hazard it identified, creating an audit trail from observation → hazard registrati' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardRegister .

ind:safetyProgramId rdf:type rdf:Property ;
    rdfs:label 'Safety Program Id' ;
    rdfs:comment 'Foreign key linking to safety.program. Business justification: Observations have a program_name text field indicating they are conducted under a specific safety program. Adding a proper FK to program normalizes this relationship, enabling reporting on observation' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:actionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Action Completed Date' ;
    rdfs:comment 'Actual date when the corrective action was completed and verified. Null if action is still in progress or not yet started.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Due Date' ;
    rdfs:comment 'Target date by which the corrective action must be completed. Used to track action closure timeliness and ensure timely risk mitigation.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Action Verification Status' ;
    rdfs:comment 'Status of the corrective action verification process: not started, in progress, completed (action done but not yet verified), verified (action confirmed effective), or rejected (action deemed insufficient, requires rework).' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anonymousSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Anonymous Submission Flag' ;
    rdfs:comment 'Indicates whether the observation was submitted anonymously (True) or with observer identification (False). Supports confidential reporting channels to encourage safety culture.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalatedFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated Flag' ;
    rdfs:comment 'Indicates whether the observation was escalated to senior management or safety leadership due to severity or systemic risk (True) or handled at operational level (False).' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Required Flag' ;
    rdfs:comment 'Indicates whether formal follow-up corrective or preventive action is required (True) or not (False). Drives workflow routing to safety management for action assignment.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immediateActionFlag rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Flag' ;
    rdfs:comment 'Indicates whether immediate action was taken at the time of observation (True) or not (False). Used to track proactive intervention rates.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observationCategory rdf:type rdf:Property ;
    rdfs:label 'Observation Category' ;
    rdfs:comment 'Thematic category of the safety observation for classification and trend analysis: housekeeping (cleanliness, clutter), PPE usage (Personal Protective Equipment compliance), equipment condition (machinery, tools), ergonomics (lifting, posture), vehicle operation (driving behavior), loading/unloading (cargo handling), hazmat handling (dangerous goods), fall protection (working at height), lockout/tagout (energy isolation), or other. [ENUM-REF-CANDIDATE: housekeeping|ppe_usage|equipment_condition|ergonomics|vehicle_operation|loading_unloading|hazmat_handling|fall_protection|lockout_tagout|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationDescription rdf:type rdf:Property ;
    rdfs:label 'Observation Description' ;
    rdfs:comment 'Detailed narrative description of what was observed. Captures the specific unsafe act, unsafe condition, near-miss event, or positive behavior in sufficient detail to enable investigation and corrective action.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationNumber rdf:type rdf:Property ;
    rdfs:label 'Observation Number' ;
    rdfs:comment 'Human-readable unique business identifier for the safety observation, typically system-generated following organizational numbering convention (e.g., OBS-20240115-A3F7G2).' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationStatus rdf:type rdf:Property ;
    rdfs:label 'Observation Status' ;
    rdfs:comment 'Current lifecycle status of the safety observation in the workflow: submitted (initial entry), under review (being evaluated by safety team), action assigned (corrective action owner designated), action in progress (remediation underway), resolved (action completed), closed (verified and archived), or cancelled (observation withdrawn or deemed invalid). [ENUM-REF-CANDIDATE: submitted|under_review|action_assigned|action_in_progress|resolved|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationType rdf:type rdf:Property ;
    rdfs:label 'Observation Type' ;
    rdfs:comment 'Classification of the safety observation: unsafe act (human behavior that could lead to incident), unsafe condition (environmental or equipment hazard), near-miss (incident that could have caused harm but did not), positive observation (safe behavior or condition to be reinforced), hazard identification (potential risk identified), or behavioral observation (general behavior-based safety observation).' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observerName rdf:type rdf:Property ;
    rdfs:label 'Observer Name' ;
    rdfs:comment 'Full name of the person who submitted the safety observation. Captured for reporting and recognition purposes in safety culture programs.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observerRole rdf:type rdf:Property ;
    rdfs:label 'Observer Role' ;
    rdfs:comment 'Functional role or job category of the observer at the time of observation: driver, warehouse worker, supervisor, safety officer, manager, contractor, visitor, or other. Used to analyze observation patterns by workforce segment. [ENUM-REF-CANDIDATE: driver|warehouse_worker|supervisor|safety_officer|manager|contractor|visitor|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoAttachedFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Attached Flag' ;
    rdfs:comment 'Indicates whether photographic evidence was attached to the observation record (True) or not (False). Photos support investigation and verification.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Url' ;
    rdfs:comment 'URL or file path to the photographic evidence attached to the observation. Null if no photo was attached.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionGivenFlag rdf:type rdf:Property ;
    rdfs:label 'Recognition Given Flag' ;
    rdfs:comment 'Indicates whether the observer received formal recognition or reward for submitting the observation (True) or not (False). Used to track safety culture incentive programs.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionType rdf:type rdf:Property ;
    rdfs:label 'Recognition Type' ;
    rdfs:comment 'Type of recognition or reward given to the observer (e.g., safety award, certificate, monetary incentive, public acknowledgment). Null if no recognition was given.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDatetime rdf:type rdf:Property ;
    rdfs:label 'Submitted Datetime' ;
    rdfs:comment 'Date and time when the observation was formally submitted into the safety observation system by the observer.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:permitApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Permit Approved By Employee Id' ;
    rdfs:comment 'Reference to the senior manager or safety director who provided final approval for this permit. Links to employee master data.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:permitClosedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Permit Closed By Employee Id' ;
    rdfs:comment 'Reference to the employee who closed the permit after verifying work completion and site restoration. Links to employee master data.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:permitEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Permit Employee Id' ;
    rdfs:comment 'Reference to the employee who has the authority to issue this permit (typically a safety officer, facility manager, or authorized supervisor). Links to employee master data.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:permitHolderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Permit Holder Employee Id' ;
    rdfs:comment 'Reference to the employee or contractor who is the primary permit holder responsible for executing the work under this permit. Links to employee or contractor master data.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:atmosphericTestingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Atmospheric Testing Required Flag' ;
    rdfs:comment 'Indicates whether atmospheric testing (oxygen level, flammable gases, toxic gases) is required before and during the work. Typically true for confined space entry and hot work permits.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Comprehensive audit trail notes capturing all significant events, inspections, sign-offs, and changes throughout the permit lifecycle. Used for compliance documentation and incident investigation.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confinedSpaceFlag rdf:type rdf:Property ;
    rdfs:label 'Confined Space Flag' ;
    rdfs:comment 'Indicates whether this permit authorizes entry into a confined space. True if confined space entry is involved, false otherwise.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireWatchRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fire Watch Required Flag' ;
    rdfs:comment 'Indicates whether a dedicated fire watch person must be present during and after the work. Typically required for hot work activities.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holderCompany rdf:type rdf:Property ;
    rdfs:label 'Holder Company' ;
    rdfs:comment 'Name of the company employing the permit holder (Transport Shipping or external contractor company). Used to distinguish internal employees from third-party contractors.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hotWorkFlag rdf:type rdf:Property ;
    rdfs:label 'Hot Work Flag' ;
    rdfs:comment 'Indicates whether this permit authorizes hot work activities (welding, cutting, grinding, or other spark-producing operations). True if hot work is involved, false otherwise.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentOccurredFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Occurred Flag' ;
    rdfs:comment 'Indicates whether any safety incident occurred during the execution of work under this permit. True if an incident occurred, false otherwise.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedDate rdf:type rdf:Property ;
    rdfs:label 'Issued Date' ;
    rdfs:comment 'Date when the permit was officially issued by the issuing authority. Represents the formal approval date.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Precise date and time when the permit was officially issued. Provides exact moment of permit approval for audit trail.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lockoutTagoutRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lockout Tagout Required Flag' ;
    rdfs:comment 'Indicates whether lockout-tagout procedures must be applied to isolate energy sources before work begins. True if LOTO is required, false otherwise.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Externally-known unique permit number assigned to this permit-to-work. Business identifier for tracking and audit purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the permit: draft (being prepared), issued (approved but not yet active), active (work in progress), suspended (temporarily halted), closed (work completed), cancelled (permit voided), or expired (validity period lapsed). [ENUM-REF-CANDIDATE: draft|issued|active|suspended|closed|cancelled|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the permit based on the nature of high-risk activity: hot work (welding, cutting, grinding), confined space entry, working at height, electrical isolation, excavation, or chemical handling.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Detailed list of personal protective equipment that must be worn by all personnel involved in the permitted work (e.g., hard hat, safety glasses, gloves, respirator, fall protection harness).' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precautionsRequired rdf:type rdf:Property ;
    rdfs:label 'Precautions Required' ;
    rdfs:comment 'Mandatory safety precautions and control measures that must be in place before and during the work. Includes personal protective equipment (PPE), engineering controls, administrative controls, and emergency procedures.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescuePlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rescue Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal rescue plan must be in place before work begins. Typically required for confined space entry and working at height.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validityEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Validity End Datetime' ;
    rdfs:comment 'Date and time when the permit expires and work must cease. Represents the end of the permit\'s active period. Work continuing beyond this time requires permit renewal or new permit issuance.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validityStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Validity Start Datetime' ;
    rdfs:comment 'Date and time when the permit becomes valid and work may commence. Represents the beginning of the permit\'s active period.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed description of any permit violations that occurred, including nature of violation, corrective actions taken, and personnel involved.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCompletionVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Work Completion Verified Flag' ;
    rdfs:comment 'Indicates whether the work completion has been verified and the work area has been inspected and deemed safe. True if verified, false otherwise.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workDescription rdf:type rdf:Property ;
    rdfs:label 'Work Description' ;
    rdfs:comment 'Comprehensive description of the work to be performed under this permit, including scope, methods, equipment to be used, and any special considerations.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Work Location Description' ;
    rdfs:comment 'Detailed description of the specific work location within the facility (e.g., warehouse bay 3, loading dock A, maintenance shop floor 2). Provides granular location context beyond facility-level identification.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for overall program governance, performance, and compliance. Links to the employee master record.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:programModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who last modified this safety program record. Links to the employee master record.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Total budget allocated for the operation and administration of this safety program in the current fiscal period.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget allocated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCoverage rdf:type rdf:Property ;
    rdfs:label 'Business Unit Coverage' ;
    rdfs:comment 'List or description of business units or divisions covered by this program (e.g., \'Express Parcel Delivery\', \'Freight Forwarding\', \'Warehouse Operations\'). Free text for flexibility.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certification Issue Date' ;
    rdfs:comment 'Date on which the current certification was issued by the certification body.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objectives rdf:type rdf:Property ;
    rdfs:label 'Objectives' ;
    rdfs:comment 'Detailed description of the strategic objectives and goals of the safety program, including target outcomes, risk reduction aims, and compliance milestones.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programNumber rdf:type rdf:Property ;
    rdfs:label 'Program Number' ;
    rdfs:comment 'Externally-known unique business identifier for the safety program, typically formatted as a code (e.g., HSE-001234, ISO-045001).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programScope rdf:type rdf:Property ;
    rdfs:label 'Program Scope' ;
    rdfs:comment 'Geographic or organizational scope of the safety program. Indicates whether the program applies globally, to a specific region, business unit, individual facility, or fleet segment.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetrics rdf:type rdf:Property ;
    rdfs:label 'Target Metrics' ;
    rdfs:comment 'Key performance indicators (KPIs) and target metrics defined for this program (e.g., \'Zero fatalities\', \'TRIR < 1.0\', \'DART rate < 0.5\', \'100% DG certification compliance\'). Stored as free text; actual performance tracked in linked transactional entities.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingFrequency rdf:type rdf:Property ;
    rdfs:label 'Training Frequency' ;
    rdfs:comment 'Required frequency for participant training or recertification under this program. Null if training is not required.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationIssued rdf:type rdf:Property ;
    rdfs:label 'Certification Issued' ;
    rdfs:comment 'Indicates whether a formal certificate or credential is issued upon successful completion of this training course.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationValidityMonths rdf:type rdf:Property ;
    rdfs:label 'Certification Validity Months' ;
    rdfs:comment 'Number of months the issued certification remains valid before recertification is required. Null if certification does not expire.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competencyAssessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Competency Assessment Method' ;
    rdfs:comment 'Method used to evaluate participant competency and determine successful completion of the training course. [ENUM-REF-CANDIDATE: written_exam|practical_demonstration|observation|simulation|oral_exam|portfolio|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerParticipant rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant' ;
    rdfs:comment 'Standard cost per participant for delivering this training course. Includes instructor fees, materials, facility costs, and external vendor charges if applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the training course within the safety management system. Used for course catalog lookups and employee training assignments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Detailed description of the training course content, learning objectives, and expected outcomes. Used for course catalog display and employee self-service portals.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseMaterialsLocation rdf:type rdf:Property ;
    rdfs:label 'Course Materials Location' ;
    rdfs:comment 'File path, URL, or document management system reference where the training course materials, presentations, and resources are stored.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseOwner rdf:type rdf:Property ;
    rdfs:label 'Course Owner' ;
    rdfs:comment 'Name or identifier of the department, role, or individual responsible for maintaining and updating this training course.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseStatus rdf:type rdf:Property ;
    rdfs:label 'Course Status' ;
    rdfs:comment 'Current lifecycle status of the training course in the safety management system. Active courses are available for assignment and enrollment.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseTitle rdf:type rdf:Property ;
    rdfs:label 'Course Title' ;
    rdfs:comment 'Full descriptive title of the safety training course as displayed in the learning management system and training certificates.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseVersion rdf:type rdf:Property ;
    rdfs:label 'Course Version' ;
    rdfs:comment 'Version number of the training course content. Incremented when course materials, assessments, or regulatory requirements are updated.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalProviderName rdf:type rdf:Property ;
    rdfs:label 'External Provider Name' ;
    rdfs:comment 'Name of the external training provider or vendor if the course is delivered by a third party. Null if delivered internally.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorQualificationRequired rdf:type rdf:Property ;
    rdfs:label 'Instructor Qualification Required' ;
    rdfs:comment 'Description of the qualifications, certifications, or experience required for instructors authorized to deliver this training course.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOffered rdf:type rdf:Property ;
    rdfs:label 'Language Offered' ;
    rdfs:comment 'Primary language in which the training course is delivered. Multiple languages may be listed if the course is available in multiple versions.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningObjectives rdf:type rdf:Property ;
    rdfs:label 'Learning Objectives' ;
    rdfs:comment 'Specific, measurable learning objectives that participants will achieve upon successful completion of the training course.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxParticipants rdf:type rdf:Property ;
    rdfs:label 'Max Participants' ;
    rdfs:comment 'Maximum number of participants allowed per training session. Used for scheduling and resource allocation. Null if no limit applies.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percentage' ;
    rdfs:comment 'Minimum score percentage required to successfully complete the training course. Null if no scored assessment is used.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisites rdf:type rdf:Property ;
    rdfs:label 'Prerequisites' ;
    rdfs:comment 'Description of any prerequisite training courses, certifications, or qualifications required before enrolling in this course.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refresherFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Refresher Frequency Months' ;
    rdfs:comment 'Number of months after which the training must be repeated to maintain compliance and competency. Null if no refresher is required.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Primary classification of the training course type. [ENUM-REF-CANDIDATE: induction|dangerous_goods_handling|fire_safety|manual_handling|first_aid|emergency_response|fatigue_management|personal_protective_equipment|forklift_operation|hazmat_awareness|confined_space|fall_protection|lockout_tagout|defensive_driving|incident_investigation|environmental_compliance — promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyTrainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Safety Training Completion Id' ;
    rdfs:comment 'Unique identifier for the safety training completion record. Primary key for this entity.' ;
    rdfs:domain ind:SafetyTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultingDgCertificationId rdf:type rdf:Property ;
    rdfs:label 'Resulting Dg Certification Id' ;
    rdfs:comment 'Foreign key linking to safety.dg_certification. Business justification: When an employee completes DG training, a dg_certification record is issued. This FK links the training completion event to the resulting certification, enabling audit trail from training → certificat' ;
    rdfs:domain ind:SafetyTrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DgCertification .

ind:tertiarySafetyLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Safety Last Modified By User Employee Id' ;
    rdfs:comment 'User ID or system account that last modified this training completion record. Audit trail field.' ;
    rdfs:domain ind:SafetyTrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingProviderId rdf:type rdf:Property ;
    rdfs:label 'Training Provider Id' ;
    rdfs:comment 'Reference to the organization or vendor that delivered the training. May be internal training department or external third-party provider.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingProvider .

ind:attendanceHours rdf:type rdf:Property ;
    rdfs:label 'Attendance Hours' ;
    rdfs:comment 'Actual hours attended by the employee. May differ from training duration if employee joined late or left early.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current lifecycle status of the training completion record indicating whether the employee passed, failed, did not complete, was granted a waiver, or the certification has expired.' ;
    rdfs:domain ind:SafetyTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsCategory rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Category' ;
    rdfs:comment 'Specific dangerous goods category or class covered by this training (e.g., Class 1 Explosives, Class 3 Flammable Liquids, Class 9 Miscellaneous). Applicable only to DG handling training.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationName rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Name' ;
    rdfs:comment 'Name of the facility, warehouse, or training center where the training was conducted.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the instructor or facilitator who delivered the training session.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Interval Months' ;
    rdfs:comment 'Number of months between required recertification or refresher training sessions. Nullable if recertification is not required.' ;
    rdfs:domain ind:SafetyTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether periodic recertification or refresher training is required (True) or if this is a one-time training (False).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total duration of the training course in hours, including instruction, assessment, and practical exercises.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLanguage rdf:type rdf:Property ;
    rdfs:label 'Training Language' ;
    rdfs:comment 'Language in which the training was delivered, using ISO 639-1 two-letter language codes (e.g., EN for English, ES for Spanish, FR for French).' ;
    rdfs:domain ind:SafetyTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingStartDate rdf:type rdf:Property ;
    rdfs:label 'Training Start Date' ;
    rdfs:comment 'Date on which the employee began the training course. May differ from completion date for multi-day or self-paced courses.' ;
    rdfs:domain ind:SafetyTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingChannel rdf:type rdf:Property ;
    rdfs:label 'Booking Channel' ;
    rdfs:comment 'The channel through which the consignment was booked: web portal, mobile app, API integration, EDI, call center, branch office, or partner system. [ENUM-REF-CANDIDATE: web_portal|mobile_app|api|edi|call_center|branch|partner — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingReference rdf:type rdf:Property ;
    rdfs:label 'Booking Reference' ;
    rdfs:comment 'The customer-facing booking reference or tracking number provided at the time of shipment booking.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Timestamp' ;
    rdfs:comment 'The precise date and time when the consignment booking was created in the system.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'The date by which delivery is committed to the customer per the service level agreement.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:committedDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Time' ;
    rdfs:comment 'The precise date and time by which delivery is committed to the customer per the service level agreement.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consigneeContactPhone rdf:type rdf:Property ;
    rdfs:label 'Consignee Contact Phone' ;
    rdfs:comment 'The contact phone number for the consignee or receiver.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredWeightKg rdf:type rdf:Property ;
    rdfs:label 'Declared Weight Kg' ;
    rdfs:comment 'The actual or declared gross weight of the consignment in kilograms as provided by the shipper.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryInstructionType rdf:type rdf:Property ;
    rdfs:label 'Delivery Instruction Type' ;
    rdfs:comment 'The type of special delivery instruction provided by the customer (e.g., signature required, leave at door, call before delivery, safe place).' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCod rdf:type rdf:Property ;
    rdfs:label 'Is Cod' ;
    rdfs:comment 'Indicates whether this consignment requires cash on delivery payment collection from the consignee.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOtdTarget rdf:type rdf:Property ;
    rdfs:label 'Is Otd Target' ;
    rdfs:comment 'Indicates whether this consignment is included in on-time delivery performance measurement and reporting.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOtifTarget rdf:type rdf:Property ;
    rdfs:label 'Is Otif Target' ;
    rdfs:comment 'Indicates whether this consignment is included in on-time in-full performance measurement and reporting.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Origin Address Line1' ;
    rdfs:comment 'The first line of the pickup or origin address for the consignment.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCity rdf:type rdf:Property ;
    rdfs:label 'Origin City' ;
    rdfs:comment 'The city or municipality of the consignment origin location.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPostalCode rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the consignment origin location.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperContactPhone rdf:type rdf:Property ;
    rdfs:label 'Shipper Contact Phone' ;
    rdfs:comment 'The contact phone number for the shipper or sender.' ;
    rdfs:domain ind:Consignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaSource rdf:type rdf:Property ;
    rdfs:label 'Sla Source' ;
    rdfs:comment 'The source of the service level commitment: customer contract, published rate card, spot booking, or standard terms.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingNotes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Notes' ;
    rdfs:comment 'Free-text notes describing any special handling requirements, access instructions, or delivery preferences for the consignment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumetricWeightKg rdf:type rdf:Property ;
    rdfs:label 'Volumetric Weight Kg' ;
    rdfs:comment 'The dimensional or volumetric weight calculated based on the consignment dimensions, used for pricing when it exceeds actual weight.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentStatusId rdf:type rdf:Property ;
    rdfs:label 'Consignment Status Id' ;
    rdfs:comment 'Unique identifier for the consignment status transition record. Primary key for the consignment status history table.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Cleared Flag' ;
    rdfs:comment 'Boolean indicator of whether customs clearance was completed at this status transition. Relevant for cross-border shipments and international freight.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Reference Number' ;
    rdfs:comment 'The customs declaration or clearance reference number associated with this status transition, if applicable. Links to customs brokerage and trade compliance records.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'The duration in minutes that the consignment remained in the previous status before this transition. Measures processing time and identifies bottlenecks in the supply chain.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etaUpdatedFlag rdf:type rdf:Property ;
    rdfs:label 'Eta Updated Flag' ;
    rdfs:comment 'Boolean indicator of whether the estimated time of arrival was recalculated or updated as a result of this status transition. Used to track predictive ETA accuracy.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'The unique identifier for this status transition in the source system or carrier system. Used for cross-system reconciliation and EDI message correlation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'The geographic latitude coordinate where the status transition occurred, captured from GPS or RFID tracking systems. Enables spatial analysis of consignment movements.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'The geographic longitude coordinate where the status transition occurred, captured from GPS or RFID tracking systems. Enables spatial analysis of consignment movements.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityPercentage rdf:type rdf:Property ;
    rdfs:label 'Humidity Percentage' ;
    rdfs:comment 'The relative humidity percentage recorded at the time of the status transition. Relevant for sensitive cargo requiring environmental monitoring.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newEtaTimestamp rdf:type rdf:Property ;
    rdfs:label 'New Eta Timestamp' ;
    rdfs:comment 'The updated estimated time of arrival calculated at this status transition. Reflects the latest predictive delivery time based on current consignment progress.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:newStatusCode rdf:type rdf:Property ;
    rdfs:label 'New Status Code' ;
    rdfs:comment 'The lifecycle status code of the consignment after this transition. Represents the current state following the status change event. [ENUM-REF-CANDIDATE: BOOKED|PICKED_UP|IN_TRANSIT|AT_HUB|OUT_FOR_DELIVERY|DELIVERED|EXCEPTION|CANCELLED|RETURNED|ON_HOLD — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Captured Flag' ;
    rdfs:comment 'Boolean indicator of whether a photo was captured as proof of delivery or condition at this status transition. Used for ePOD and claims evidence.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStatusCode rdf:type rdf:Property ;
    rdfs:label 'Previous Status Code' ;
    rdfs:comment 'The lifecycle status code of the consignment immediately before this transition. Represents the prior state in the consignment workflow. [ENUM-REF-CANDIDATE: BOOKED|PICKED_UP|IN_TRANSIT|AT_HUB|OUT_FOR_DELIVERY|DELIVERED|EXCEPTION|CANCELLED|RETURNED|ON_HOLD — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Route Deviation Flag' ;
    rdfs:comment 'Boolean indicator of whether the consignment deviated from the planned route at this status transition. Used for exception management and route optimization analysis.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scanType rdf:type rdf:Property ;
    rdfs:label 'Scan Type' ;
    rdfs:comment 'The method or technology used to capture the status transition event. Indicates whether the update was via barcode scan, RFID read, manual entry, GPS tracking, or API integration.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Captured Flag' ;
    rdfs:comment 'Boolean indicator of whether an electronic proof of delivery signature was captured at this status transition. Typically true for DELIVERED status transitions.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusNotes rdf:type rdf:Property ;
    rdfs:label 'Status Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context about the status transition. May include operator remarks, exception details, or customer instructions.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason or cause for the status transition. Provides context for why the consignment moved to the new status, especially for exceptions. [ENUM-REF-CANDIDATE: NORMAL_FLOW|CUSTOMER_REQUEST|EXCEPTION_DELAY|WEATHER|CUSTOMS_HOLD|ADDRESS_CORRECTION|DAMAGED|REFUSED|SECURITY_HOLD — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusTransitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Transition Timestamp' ;
    rdfs:comment 'The precise date and time when the consignment status changed from the previous status to the new status. Represents the real-world business event time of the lifecycle transition.' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeredBySource rdf:type rdf:Property ;
    rdfs:label 'Triggered By Source' ;
    rdfs:comment 'The originating system or channel that initiated the status transition. Identifies whether the change was automated (system/EDI), manual (user), or via integration (API/WMS).' ;
    rdfs:domain ind:ConsignmentStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructionId rdf:type rdf:Property ;
    rdfs:label 'Delivery Instruction Id' ;
    rdfs:comment 'Unique identifier for the delivery instruction record. Primary key.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerContactId rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Delivery instructions frequently specify customer contact person for access coordination, delivery authorization, and issue resolution. Normalizes denormalized contact fields. Critical for last-mile d' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:alternativeDeliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Alternative Delivery Address Line1' ;
    rdfs:comment 'First line of an alternative delivery address specified by the consignee if the primary delivery address is unavailable. Includes street number and street name.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeDeliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Alternative Delivery Address Line2' ;
    rdfs:comment 'Second line of the alternative delivery address. May include apartment number, suite, floor, or building name.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeDeliveryCity rdf:type rdf:Property ;
    rdfs:label 'Alternative Delivery City' ;
    rdfs:comment 'City or locality of the alternative delivery address.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeDeliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Alternative Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the alternative delivery address.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeDeliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Alternative Delivery Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the alternative delivery address.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeDeliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Alternative Delivery State Province' ;
    rdfs:comment 'State, province, or region of the alternative delivery address.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityToLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Authority To Leave Flag' ;
    rdfs:comment 'Indicates whether the delivery driver has authority to leave the shipment unattended at the delivery location without obtaining a signature. True if authority is granted, False otherwise.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNotificationPreference rdf:type rdf:Property ;
    rdfs:label 'Delivery Notification Preference' ;
    rdfs:comment 'Preferred method for receiving delivery notifications. Specifies whether the consignee wants to be notified via SMS, email, phone call, mobile app push notification, or no notification.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idVerificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Id Verification Required Flag' ;
    rdfs:comment 'Indicates whether government-issued identification must be verified at delivery. Typically required for age-restricted or high-value shipments.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instructionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Instruction Effective Date' ;
    rdfs:comment 'The date from which this delivery instruction becomes effective. Supports future-dated instructions and instruction scheduling.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instructionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Instruction Expiry Date' ;
    rdfs:comment 'The date on which this delivery instruction expires and is no longer valid. Nullable for instructions with no expiration.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instructionPriority rdf:type rdf:Property ;
    rdfs:label 'Instruction Priority' ;
    rdfs:comment 'Priority level assigned to this delivery instruction. High priority instructions take precedence in case of conflicting instructions or operational constraints.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionSource rdf:type rdf:Property ;
    rdfs:label 'Instruction Source' ;
    rdfs:comment 'The origin or channel through which the delivery instruction was captured. Indicates whether the instruction came from the shipper, consignee, customer portal, call center, mobile app, or Electronic Data Interchange (EDI) system.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionStatus rdf:type rdf:Property ;
    rdfs:label 'Instruction Status' ;
    rdfs:comment 'Current lifecycle status of the delivery instruction. Tracks whether the instruction is active, has been cancelled, completed, superseded by a newer instruction, or is pending activation.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionType rdf:type rdf:Property ;
    rdfs:label 'Instruction Type' ;
    rdfs:comment 'The type of delivery instruction specified by the shipper or consignee. Defines the primary delivery handling requirement for last-mile execution.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockerCode rdf:type rdf:Property ;
    rdfs:label 'Locker Code' ;
    rdfs:comment 'Identifier of the parcel locker or automated pickup point where the shipment should be delivered if locker delivery is selected.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockerLocationCode rdf:type rdf:Property ;
    rdfs:label 'Locker Location Code' ;
    rdfs:comment 'Geographic or facility code identifying the location of the parcel locker. Used for routing and last-mile optimization.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Requirement' ;
    rdfs:comment 'Minimum age of the recipient required for delivery. Used for age-restricted goods such as alcohol, tobacco, or pharmaceuticals.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:neighbourDeliveryAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Neighbour Delivery Allowed Flag' ;
    rdfs:comment 'Indicates whether the shipment can be delivered to a neighbor if the consignee is not available. True if neighbor delivery is permitted, False otherwise.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Date' ;
    rdfs:comment 'The date on which the consignee prefers to receive the delivery. Used for appointment scheduling and delivery planning.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredNeighbourAddress rdf:type rdf:Property ;
    rdfs:label 'Preferred Neighbour Address' ;
    rdfs:comment 'Address of a preferred neighbor to whom the shipment can be delivered if the consignee is unavailable.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Preferred Time Window End' ;
    rdfs:comment 'The end of the preferred delivery time window specified by the consignee. Defines the latest acceptable time for delivery within the preferred window.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferredTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Preferred Time Window Start' ;
    rdfs:comment 'The start of the preferred delivery time window specified by the consignee. Enables time-definite delivery services and appointment-based deliveries.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnIfAbsentFlag rdf:type rdf:Property ;
    rdfs:label 'Return If Absent Flag' ;
    rdfs:comment 'Indicates whether the shipment should be returned to the depot or origin if the consignee is not present. True if return is required, False if alternative delivery options should be attempted.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safePlaceDescription rdf:type rdf:Property ;
    rdfs:label 'Safe Place Description' ;
    rdfs:comment 'Description of a safe place where the parcel can be left if the consignee is not present. Examples include porch, garage, side door, or with a specific neighbor.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialAccessInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Access Instructions' ;
    rdfs:comment 'Free-text instructions provided by the consignee for accessing the delivery location. May include gate codes, building entry procedures, parking instructions, or security protocols.' ;
    rdfs:domain ind:DeliveryInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etaMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Eta Milestone Id' ;
    rdfs:comment 'Unique identifier for the ETA/ETD milestone record. Primary key for the eta_milestone product.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Datetime' ;
    rdfs:comment 'The actual recorded datetime when the milestone event occurred (e.g., actual departure, actual arrival). Populated after the event has been confirmed. Null until the event is completed.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdDatetime rdf:type rdf:Property ;
    rdfs:label 'Created Datetime' ;
    rdfs:comment 'Timestamp when this milestone record was first created in the system. Audit field for record lifecycle tracking.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentPredictedDatetime rdf:type rdf:Property ;
    rdfs:label 'Current Predicted Datetime' ;
    rdfs:comment 'The most recent predicted ETA or ETD datetime based on real-time tracking, AI/ML models, or carrier updates. This value is continuously updated as new information becomes available.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distanceRemainingKm rdf:type rdf:Property ;
    rdfs:label 'Distance Remaining Km' ;
    rdfs:comment 'Estimated distance remaining in kilometers from current position to the milestone location. Updated in real-time based on GPS tracking data.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Modified Datetime' ;
    rdfs:comment 'Timestamp when this milestone record was last modified. Audit field for tracking changes to milestone data.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:milestoneSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Milestone Sequence Number' ;
    rdfs:comment 'Sequential order number of this milestone within the overall shipment journey. Used to track progression through the shipment lifecycle (e.g., 1 = first milestone, 2 = second milestone).' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Type of milestone event in the shipment lifecycle. ETD_ORIGIN = Estimated Time of Departure from origin, ETA_TRANSIT_HUB = Estimated Time of Arrival at transit hub, ETD_TRANSIT_HUB = Estimated Time of Departure from transit hub, ETA_DESTINATION = Estimated Time of Arrival at destination facility, ETA_DELIVERY = Estimated Time of Arrival for final delivery to consignee, ETD_PICKUP = Estimated Time of Departure for pickup from shipper.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDatetime rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Datetime' ;
    rdfs:comment 'Timestamp when the customer notification was sent for this milestone update. Null if no notification has been sent.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalCommittedDatetime rdf:type rdf:Property ;
    rdfs:label 'Original Committed Datetime' ;
    rdfs:comment 'The original committed ETA or ETD datetime provided at booking or shipment creation. This is the baseline SLA commitment against which performance is measured.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:predictionLastUpdatedDatetime rdf:type rdf:Property ;
    rdfs:label 'Prediction Last Updated Datetime' ;
    rdfs:comment 'Timestamp when the current predicted datetime was last updated. Used to track the freshness of prediction data and trigger re-prediction cycles.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:predictionSource rdf:type rdf:Property ;
    rdfs:label 'Prediction Source' ;
    rdfs:comment 'Source system or method that generated the current predicted datetime. FOURKITES_AI = FourKites predictive analytics engine, CARRIER_EDI = Electronic Data Interchange from carrier, TMS_CALCULATION = Transportation Management System route calculation, MANUAL_OVERRIDE = Manual adjustment by operations team, GPS_TRACKING = Real-time GPS device data, HISTORICAL_AVERAGE = Statistical average based on historical performance.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionUpdateFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Prediction Update Frequency Minutes' ;
    rdfs:comment 'Frequency in minutes at which the prediction is updated for this milestone. Varies based on transport mode, priority, and data availability (e.g., 15 minutes for air, 60 minutes for ocean).' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Sla Threshold Hours' ;
    rdfs:comment 'The acceptable variance threshold in hours for this milestone as defined in the customer SLA. Variance beyond this threshold triggers SLA breach status.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceHours rdf:type rdf:Property ;
    rdfs:label 'Variance Hours' ;
    rdfs:comment 'Variance in hours between the current predicted datetime and the original committed datetime. Positive values indicate delay (late), negative values indicate early arrival/departure. Used for SLA breach prediction and OTIF measurement.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleIdentifier rdf:type rdf:Property ;
    rdfs:label 'Vehicle Identifier' ;
    rdfs:comment 'Identifier for the specific vehicle, vessel, aircraft, or container handling this leg (e.g., flight number, vessel name, truck license plate, container number).' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether adverse weather conditions are impacting or predicted to impact this milestone. True = weather impact detected, False = no weather impact.' ;
    rdfs:domain ind:EtaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionEventId rdf:type rdf:Property ;
    rdfs:label 'Exception Event Id' ;
    rdfs:comment 'Unique identifier for the exception event record. Primary key.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedExceptionEventId rdf:type rdf:Property ;
    rdfs:label 'Related Exception Event Id' ;
    rdfs:comment 'Reference to another exception event that is related to or caused by this exception, enabling exception chain analysis.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExceptionEvent .

ind:claimEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Claim Eligible Flag' ;
    rdfs:comment 'Indicator of whether this exception event qualifies for a cargo claim or insurance claim filing.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationTier rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier' ;
    rdfs:comment 'Level of escalation indicating the organizational tier handling the exception resolution.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRecoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Recovery Timestamp' ;
    rdfs:comment 'Projected date and time when the shipment is expected to return to normal schedule after exception resolution.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionLocationCode rdf:type rdf:Property ;
    rdfs:label 'Exception Location Code' ;
    rdfs:comment 'Code identifying the facility, terminal, or geographic location where the exception occurred.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Exception Location Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the location where the exception occurred.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionLocationName rdf:type rdf:Property ;
    rdfs:label 'Exception Location Name' ;
    rdfs:comment 'Human-readable name of the location where the exception occurred.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionRaisedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Raised Timestamp' ;
    rdfs:comment 'Date and time when the exception was first detected and recorded in the system. Primary business event timestamp for this transaction.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionActionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Description' ;
    rdfs:comment 'Detailed narrative of the actions taken to resolve the exception and restore normal shipment flow.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachType rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Type' ;
    rdfs:comment 'Classification of the type of SLA commitment that was breached due to this exception.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source System Reference Code' ;
    rdfs:comment 'Unique identifier of this exception event in the originating source system, used for data lineage and reconciliation.' ;
    rdfs:domain ind:ExceptionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Code' ;
    rdfs:comment 'Code identifying the warehouse, terminal, port, or distribution center where the manifest load is destined.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityName rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Name' ;
    rdfs:comment 'Full name of the destination facility, terminal, or port where the manifest will be unloaded.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Code' ;
    rdfs:comment 'Code identifying the type of transport equipment used (e.g., 20ft container, 40ft container, reefer, flatbed, dry van) per ISO 6346 or industry standards.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled Flag' ;
    rdfs:comment 'Indicates whether real-time GPS tracking is enabled for this manifest via FourKites or other visibility platforms.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadPlanReference rdf:type rdf:Property ;
    rdfs:label 'Load Plan Reference' ;
    rdfs:comment 'Reference identifier to the load optimization plan generated by Oracle TMS or SAP TM that produced this manifest.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Closed Timestamp' ;
    rdfs:comment 'Date and time when the manifest was closed and locked for departure, preventing further additions or changes.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Completed Timestamp' ;
    rdfs:comment 'Date and time when the manifest was marked as completed after successful delivery and unloading at destination.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestCostAmount rdf:type rdf:Property ;
    rdfs:label 'Manifest Cost Amount' ;
    rdfs:comment 'Total transportation cost allocated to this manifest, including carrier charges, fuel surcharges, and accessorial fees.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manifestCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Manifest Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the manifest cost amount.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Created Timestamp' ;
    rdfs:comment 'Date and time when this manifest record was first created in the TMS or WMS system.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originFacilityName rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Name' ;
    rdfs:comment 'Full name of the origin facility, terminal, or port where the manifest is loaded.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictedEtaTimestamp rdf:type rdf:Property ;
    rdfs:label 'Predicted Eta Timestamp' ;
    rdfs:comment 'Real-time predicted arrival timestamp generated by visibility platforms such as FourKites based on GPS tracking and predictive analytics.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalConsignments rdf:type rdf:Property ;
    rdfs:label 'Total Consignments' ;
    rdfs:comment 'Total number of individual consignments (AWBs, BOLs, HAWBs) consolidated into this manifest.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPieces rdf:type rdf:Property ;
    rdfs:label 'Total Pieces' ;
    rdfs:comment 'Total number of individual pieces, packages, or handling units loaded onto this manifest across all consignments.' ;
    rdfs:domain ind:FreightManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podId rdf:type rdf:Property ;
    rdfs:label 'Pod Id' ;
    rdfs:comment 'Unique identifier for the proof of delivery record. Primary key for the POD entity.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryTransportAssetId rdf:type rdf:Property ;
    rdfs:label 'Delivery Transport Asset Id' ;
    rdfs:comment 'Foreign key linking to fleet.transport_asset. Business justification: Proof of delivery must record which vehicle performed the delivery for driver accountability, vehicle performance tracking, and dispute resolution. Role-prefixed because delivery context is specific. ' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportAsset .

ind:podDeliveryAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Pod Delivery Agent Employee Id' ;
    rdfs:comment 'Reference to the employee (driver, courier, or delivery agent) who executed the delivery and captured the POD.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:podVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Pod Verified By Employee Id' ;
    rdfs:comment 'Reference to the employee who verified or approved the POD record. Supports quality control and audit requirements.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amountCollected rdf:type rdf:Property ;
    rdfs:label 'Amount Collected' ;
    rdfs:comment 'The actual amount collected from the recipient at delivery. May differ from COD amount if partial payment or variance occurred.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codCurrency rdf:type rdf:Property ;
    rdfs:label 'Cod Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the COD amount to be collected.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Collection Variance Amount' ;
    rdfs:comment 'The difference between the COD amount and the amount collected. Positive value indicates over-collection, negative indicates under-collection or shortfall.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Code' ;
    rdfs:comment 'Standardized code indicating any exception or deviation from normal delivery process noted at the time of delivery (e.g., damaged package, partial delivery, refused).' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery method used to complete the shipment handover. Indicates where and how the package was left.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Flag' ;
    rdfs:comment 'Boolean indicator of whether the shipper or recipient has raised a dispute regarding this delivery or COD collection. True indicates an active or historical dispute.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epodImageReference rdf:type rdf:Property ;
    rdfs:label 'Epod Image Reference' ;
    rdfs:comment 'URI or storage path reference to the digital photograph of the delivered package taken at the delivery location. Supports ePOD standards for visual delivery confirmation.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientContactNumber rdf:type rdf:Property ;
    rdfs:label 'Recipient Contact Number' ;
    rdfs:comment 'Phone number of the recipient who accepted the delivery. Used for delivery confirmation and follow-up communication.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'Email address of the recipient who accepted the delivery. Used for sending electronic proof of delivery confirmation.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientIdNumber rdf:type rdf:Property ;
    rdfs:label 'Recipient Id Number' ;
    rdfs:comment 'Identification document number presented by the recipient at delivery. Captured for high-value shipments or regulatory compliance.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientIdType rdf:type rdf:Property ;
    rdfs:label 'Recipient Id Type' ;
    rdfs:comment 'Type of identification document presented by the recipient at delivery for high-value or restricted shipments.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientSignature rdf:type rdf:Property ;
    rdfs:label 'Recipient Signature' ;
    rdfs:comment 'Base64-encoded signature image or reference URI to the signature captured at delivery. Serves as biometric proof of receipt.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Batch Number' ;
    rdfs:comment 'Identifier of the financial batch in which this COD collection was remitted to the shipper. Supports reconciliation and audit of COD settlements.' ;
    rdfs:domain ind:Pod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShipmentId rdf:type rdf:Property ;
    rdfs:label 'Return Shipment Id' ;
    rdfs:comment 'Unique identifier for the return shipment record. Primary key.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: RMA authorizations require employee approval for fraud prevention, return policy compliance, and refund authorization workflows. Tracks who approved the return/refund, distinct from physical processin' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originalAwbNumber rdf:type rdf:Property ;
    rdfs:label 'Original Awb Number' ;
    rdfs:comment 'Air Waybill number of the original outbound shipment that is being returned.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalBolNumber rdf:type rdf:Property ;
    rdfs:label 'Original Bol Number' ;
    rdfs:comment 'Bill of Lading number of the original outbound shipment that is being returned.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the restocking fee.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAuthorizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Authorized Timestamp' ;
    rdfs:comment 'Date and time when the return was officially authorized and RMA number was issued.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Completed Timestamp' ;
    rdfs:comment 'Date and time when the return process was fully completed including inspection, disposition, and refund/credit processing.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnConditionAssessment rdf:type rdf:Property ;
    rdfs:label 'Return Condition Assessment' ;
    rdfs:comment 'Assessment of the physical condition of the returned goods upon receipt at the return destination. [ENUM-REF-CANDIDATE: undamaged|damaged|missing_items|incomplete|opened|unopened|defective — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDestinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Return Destination Location Code' ;
    rdfs:comment 'Standardized code identifying the specific warehouse, distribution center, or facility where the return will be received.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDestinationType rdf:type rdf:Property ;
    rdfs:label 'Return Destination Type' ;
    rdfs:comment 'Type of facility where the returned goods will be sent for processing, inspection, restocking, repair, or disposal.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDispositionCode rdf:type rdf:Property ;
    rdfs:label 'Return Disposition Code' ;
    rdfs:comment 'Code indicating the final disposition decision for the returned goods: restock for resale, repair, refurbish, dispose, donate, return to vendor, or scrap. [ENUM-REF-CANDIDATE: restock|repair|refurbish|dispose|donate|return_to_vendor|scrap — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnFreightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Return Freight Charge Amount' ;
    rdfs:comment 'Freight charge amount for the return shipment, which may be borne by the customer, shipper, or carrier depending on return policy.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnFreightChargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Return Freight Charge Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the return freight charge.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnFreightPaidBy rdf:type rdf:Property ;
    rdfs:label 'Return Freight Paid By' ;
    rdfs:comment 'Party responsible for paying the return freight charges: customer, shipper, carrier, or third-party.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Initiated Timestamp' ;
    rdfs:comment 'Date and time when the return request was first initiated by the customer, shipper, or e-commerce platform.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnInitiator rdf:type rdf:Property ;
    rdfs:label 'Return Initiator' ;
    rdfs:comment 'Party who initiated the return request: consignee (receiver), shipper (sender), e-commerce platform, carrier, or third-party logistics provider.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnInspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Return Inspection Notes' ;
    rdfs:comment 'Detailed notes from the inspection process documenting the condition, completeness, and quality of the returned items.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnLabelTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Label Tracking Number' ;
    rdfs:comment 'Tracking number assigned to the return shipment label for visibility and proof of return.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPickupAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Return Pickup Address Line1' ;
    rdfs:comment 'First line of the address where the return shipment will be picked up from the customer or consignee.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPickupAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Return Pickup Address Line2' ;
    rdfs:comment 'Second line of the return pickup address (suite, apartment, building).' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPickupCity rdf:type rdf:Property ;
    rdfs:label 'Return Pickup City' ;
    rdfs:comment 'City where the return shipment will be picked up.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPickupCountryCode rdf:type rdf:Property ;
    rdfs:label 'Return Pickup Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the return pickup location.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPickupPostalCode rdf:type rdf:Property ;
    rdfs:label 'Return Pickup Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the return pickup location.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPickupStateProvince rdf:type rdf:Property ;
    rdfs:label 'Return Pickup State Province' ;
    rdfs:comment 'State or province where the return shipment will be picked up.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Return Policy Reference' ;
    rdfs:comment 'Reference to the specific return policy or terms and conditions governing this return (e.g., 30-day return policy, warranty terms).' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Received Timestamp' ;
    rdfs:comment 'Date and time when the returned goods were physically received at the return destination facility.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnServiceType rdf:type rdf:Property ;
    rdfs:label 'Return Service Type' ;
    rdfs:comment 'Type of return service selected: standard return, expedited return, scheduled pickup, customer drop-off, or prepaid label.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle status of the return shipment in the reverse logistics workflow. [ENUM-REF-CANDIDATE: initiated|authorized|pickup_scheduled|in_transit|received|inspected|processed|completed|cancelled|rejected — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTransportMode rdf:type rdf:Property ;
    rdfs:label 'Return Transport Mode' ;
    rdfs:comment 'Primary mode of transportation used for the return shipment.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the return indicating whether it is a full return of all items, partial return of some items, exchange, warranty claim, or product recall.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsReturnReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Wms Return Receipt Number' ;
    rdfs:comment 'Receipt number generated by the warehouse management system when the return is physically received and logged into inventory.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentAsnId rdf:type rdf:Property ;
    rdfs:label 'Shipment Asn Id' ;
    rdfs:comment 'Unique identifier for the Advanced Shipping Notice record.' ;
    rdfs:domain ind:ShipmentAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryShipmentTradePartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Shipment Trade Party Id' ;
    rdfs:comment 'Identifier of the party (shipper or supplier) who originated and sent the ASN.' ;
    rdfs:domain ind:ShipmentAsn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeParty .

ind:receiverNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Receiver Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: ASNs notify receiving facilities of incoming shipments. Linking receiver location to network node master enables dock scheduling, capacity planning, facility performance tracking, and inbound logistic' ;
    rdfs:domain ind:ShipmentAsn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:receivingClerkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Clerk Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ASN receipt confirmation requires a receiving clerk to verify physical goods against advance notice. Critical for warehouse accountability, discrepancy resolution (discrepancy_flag/notes), labor produ' ;
    rdfs:domain ind:ShipmentAsn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Scheduled dock appointment reference number for receiving this ASN.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Externally-known unique identifier for the ASN, typically transmitted via EDI 856 transaction.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnStatus rdf:type rdf:Property ;
    rdfs:label 'Asn Status' ;
    rdfs:comment 'Current lifecycle status of the ASN in the receiving workflow.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether discrepancies were found between the ASN and the actual received goods.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Assigned dock door or bay number for receiving this ASN shipment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Planned date when the inbound shipment is expected to arrive at the receiving location for dock scheduling and inbound planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Timestamp' ;
    rdfs:comment 'Precise timestamp when the inbound shipment is expected to arrive, used for dock appointment scheduling.' ;
    rdfs:domain ind:ShipmentAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:numberOfCartons rdf:type rdf:Property ;
    rdfs:label 'Number Of Cartons' ;
    rdfs:comment 'Total count of cartons included in this ASN shipment.' ;
    rdfs:domain ind:ShipmentAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfPallets rdf:type rdf:Property ;
    rdfs:label 'Number Of Pallets' ;
    rdfs:comment 'Total count of pallets included in this ASN shipment.' ;
    rdfs:domain ind:ShipmentAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Freight bill number assigned by the carrier for LTL or FTL shipments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverPartyName rdf:type rdf:Property ;
    rdfs:label 'Receiver Party Name' ;
    rdfs:comment 'Name of the consignee or receiving warehouse.' ;
    rdfs:domain ind:ShipmentAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderLocationCode rdf:type rdf:Property ;
    rdfs:label 'Sender Location Code' ;
    rdfs:comment 'Code identifying the origin facility or warehouse from which the shipment is dispatched.' ;
    rdfs:domain ind:ShipmentAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderPartyName rdf:type rdf:Property ;
    rdfs:label 'Sender Party Name' ;
    rdfs:comment 'Name of the shipper or supplier who sent the ASN.' ;
    rdfs:domain ind:ShipmentAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Date when the shipment was dispatched from the sender location.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Timestamp when the ASN was transmitted via EDI to the receiving party.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentCarrierAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Carrier Assignment Id' ;
    rdfs:comment 'Unique identifier for the shipment carrier assignment record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentCarrierAssignment .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method by which the carrier was assigned to this shipment leg. Auto-optimized indicates algorithmic carrier selection via SAP TM or Oracle TMS; manual override indicates planner intervention; contract based indicates assignment per existing carrier contract; spot market indicates ad-hoc market rate booking; tender indicates competitive bidding process; preferred carrier indicates selection from preferred carrier list.' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Carrier Performance Rating' ;
    rdfs:comment 'Performance rating assigned to the carrier for this shipment leg, typically on a scale of 0.00 to 5.00. Used for carrier scorecard and future selection optimization.' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRateFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Rate Flag' ;
    rdfs:comment 'Indicates whether the rate applied is a contracted rate (true) or a spot market rate (false).' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Date' ;
    rdfs:comment 'Estimated date of departure for this carrier leg as provided by the carrier.' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCarrierCharge rdf:type rdf:Property ;
    rdfs:label 'Total Carrier Charge' ;
    rdfs:comment 'Total amount charged by the carrier for this shipment leg, including base rate, fuel surcharge, and other carrier fees.' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainNumber rdf:type rdf:Property ;
    rdfs:label 'Train Number' ;
    rdfs:comment 'Train service number assigned for rail freight transport.' ;
    rdfs:domain ind:ShipmentCarrierAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentChargeId rdf:type rdf:Property ;
    rdfs:label 'Shipment Charge Id' ;
    rdfs:comment 'Unique identifier for the shipment charge record. Primary key.' ;
    rdfs:domain ind:ShipmentCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationLevel rdf:type rdf:Property ;
    rdfs:label 'Application Level' ;
    rdfs:comment 'The level at which this charge is applied within the shipment hierarchy.' ;
    rdfs:domain ind:ShipmentCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Charge Amount' ;
    rdfs:comment 'Final charge amount after applying discounts and adding taxes. This is the amount invoiced to the customer.' ;
    rdfs:domain ind:ShipmentCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originSystem rdf:type rdf:Property ;
    rdfs:label 'Origin System' ;
    rdfs:comment 'Source system or process that generated or recorded this charge. [ENUM-REF-CANDIDATE: tms|wms|customs|carrier_invoice|manual|rating_engine|erp — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivedFlag rdf:type rdf:Property ;
    rdfs:label 'Waived Flag' ;
    rdfs:comment 'Indicates whether this charge has been waived and will not be billed to the customer.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentDocumentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Document Id' ;
    rdfs:comment 'Unique identifier for the shipment document record. Primary key.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByDocumentShipmentDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Shipment Document Id' ;
    rdfs:comment 'Reference to the shipment_document_id of the newer version that supersedes this document. Nullable if this is the current version.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentDocument .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Boolean indicator whether the document meets all regulatory and carrier compliance requirements. True=compliant, False=non-compliant or pending review.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileUri rdf:type rdf:Property ;
    rdfs:label 'File Uri' ;
    rdfs:comment 'Uniform Resource Identifier (URI) or file path pointing to the stored digital copy of the document in the document management system or cloud storage. Confidential as it may expose internal storage architecture.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the document file content, used for integrity verification and tamper detection.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Free-text explanation provided by the reviewing authority detailing why the document was rejected and what corrective action is required.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedByAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Authority Name' ;
    rdfs:comment 'Name of the customs office, carrier, or compliance authority that reviewed and approved or rejected the document.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Required Flag' ;
    rdfs:comment 'Boolean indicator whether the document requires translation into the destination country language for customs clearance or carrier acceptance. True=translation required, False=no translation needed.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uploadSource rdf:type rdf:Property ;
    rdfs:label 'Upload Source' ;
    rdfs:comment 'The channel or system through which the document was uploaded or received. Shipper_portal=customer web portal, EDI=Electronic Data Interchange, API=Application Programming Interface integration, Email=email attachment, Manual=manual entry by operations, Carrier_system=received from carrier system.' ;
    rdfs:domain ind:ShipmentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAgentId rdf:type rdf:Property ;
    rdfs:label 'Delivery Agent Id' ;
    rdfs:comment 'Reference to the delivery agent or driver assigned to execute this leg. Primarily used for last-mile delivery legs to track individual courier performance.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:etaPredictionSource rdf:type rdf:Property ;
    rdfs:label 'Eta Prediction Source' ;
    rdfs:comment 'System or method that generated the predicted ETA. Identifies whether the prediction came from FourKites AI engine, carrier EDI feed, manual operator input, TMS route calculation, GPS tracking, or IoT sensor data.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictedEtaConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Predicted Eta Confidence Score' ;
    rdfs:comment 'Confidence level of the predicted ETA expressed as a percentage (0.00 to 100.00). Higher scores indicate greater certainty in the prediction based on data quality and model accuracy.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Reference Number' ;
    rdfs:comment 'Identifier for the vehicle, vessel, aircraft, or rail car used for this leg. May be truck license plate, vessel IMO number, aircraft tail number, or rail car number.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeNumber rdf:type rdf:Property ;
    rdfs:label 'Barcode Number' ;
    rdfs:comment 'Unique barcode or label number assigned to the package for scanning and tracking throughout the logistics network. Used for piece-level visibility and warehouse operations.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentsDescription rdf:type rdf:Property ;
    rdfs:label 'Contents Description' ;
    rdfs:comment 'Textual description of the declared contents within the package. Used for customs declarations, dangerous goods screening, and handling instructions.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySignatureName rdf:type rdf:Property ;
    rdfs:label 'Delivery Signature Name' ;
    rdfs:comment 'Name of the person who signed for the package upon delivery. Part of electronic proof of delivery (ePOD) record.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastScanLocationCode rdf:type rdf:Property ;
    rdfs:label 'Last Scan Location Code' ;
    rdfs:comment 'Location code where the most recent scan event occurred. Used for tracking history and route verification.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Scan Timestamp' ;
    rdfs:comment 'Date and time of the most recent barcode scan event for this package. Provides real-time tracking visibility and exception detection.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxStackWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Stack Weight Kg' ;
    rdfs:comment 'Maximum weight in kilograms that can be stacked on top of this package without causing damage. Used for warehouse stacking rules and load optimization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podImageUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Image Url' ;
    rdfs:comment 'URL reference to the stored proof of delivery image (signature, photo, or scan). Used for delivery verification and dispute resolution.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentSlaCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Sla Commitment Id' ;
    rdfs:comment 'Unique identifier for the SLA commitment record applied to a specific consignment. Primary key.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Amount' ;
    rdfs:comment 'The monetary penalty amount applicable if the SLA commitment is breached, in the specified currency.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachPenaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the breach penalty amount.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachPenaltyFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Flag' ;
    rdfs:comment 'Indicates whether financial or service penalties apply if this SLA commitment is breached.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachReasonCode rdf:type rdf:Property ;
    rdfs:label 'Breach Reason Code' ;
    rdfs:comment 'Standardized code indicating the root cause or reason for the SLA breach (e.g., weather delay, customs hold, carrier failure).' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Breach Reason Description' ;
    rdfs:comment 'Detailed textual description of the circumstances that led to the SLA breach.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDaysFlag rdf:type rdf:Property ;
    rdfs:label 'Business Days Flag' ;
    rdfs:comment 'Indicates whether the SLA commitment is measured in business days (excluding weekends and holidays) or calendar days.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedDeliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Time Window End' ;
    rdfs:comment 'The end of the committed delivery time window, specifying the latest acceptable delivery timestamp to meet SLA.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:committedDeliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Time Window Start' ;
    rdfs:comment 'The start of the committed delivery time window, specifying the earliest acceptable delivery timestamp.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forceMajeureFlag rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Flag' ;
    rdfs:comment 'Indicates whether a force majeure event (natural disaster, war, pandemic, etc.) has been declared that exempts this SLA from breach penalties.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayCalendarCode rdf:type rdf:Property ;
    rdfs:label 'Holiday Calendar Code' ;
    rdfs:comment 'Reference code for the holiday calendar used to calculate business days for this SLA commitment.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementEndEvent rdf:type rdf:Property ;
    rdfs:label 'Measurement End Event' ;
    rdfs:comment 'The specific milestone event that marks the end of the SLA measurement period.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStartEvent rdf:type rdf:Property ;
    rdfs:label 'Measurement Start Event' ;
    rdfs:comment 'The specific milestone event that marks the beginning of the SLA measurement period.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Otd Threshold Percentage' ;
    rdfs:comment 'The minimum percentage threshold for on-time delivery performance required to meet the SLA commitment.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pickup Timestamp' ;
    rdfs:comment 'The actual or planned timestamp when the shipment was picked up, marking the start of the SLA measurement period.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaBreachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Timestamp' ;
    rdfs:comment 'The timestamp when the SLA commitment was determined to be breached, if applicable.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTypeCode rdf:type rdf:Property ;
    rdfs:label 'Sla Type Code' ;
    rdfs:comment 'Classification of the SLA commitment type defining the service tier and delivery speed expectation. [ENUM-REF-CANDIDATE: express_next_day|express_same_day|economy_3day|economy_5day|freight_standard|freight_expedited|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Version Number' ;
    rdfs:comment 'Version identifier for the SLA template or contract terms from which this commitment instance was created.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the person or role who approved the SLA breach penalty waiver.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Timestamp' ;
    rdfs:comment 'The timestamp when the SLA breach penalty waiver was officially approved.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Indicates whether the SLA breach penalty has been waived by mutual agreement or due to force majeure conditions.' ;
    rdfs:domain ind:ShipmentSlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureLogId rdf:type rdf:Property ;
    rdfs:label 'Temperature Log Id' ;
    rdfs:comment 'Unique identifier for the temperature log record. Primary key for the temperature monitoring event.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensorCalibrationCertificateId rdf:type rdf:Property ;
    rdfs:label 'Sensor Calibration Certificate Id' ;
    rdfs:comment 'Foreign key linking to document.certificate. Business justification: Temperature-controlled shipments (pharma, food, biologics) require sensor calibration certificates for GDP compliance, regulatory audits, and quality assurance. Real-world cold chain operations must l' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certificate .

ind:alertRecipientList rdf:type rdf:Property ;
    rdfs:label 'Alert Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses or user IDs who were notified when a temperature breach alert was triggered. Used for audit trail and escalation tracking.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Triggered Flag' ;
    rdfs:comment 'Indicates whether this temperature reading triggered an automated alert to operations or customer service teams. True if alert was sent, false if no alert required.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachSeverityCode rdf:type rdf:Property ;
    rdfs:label 'Breach Severity Code' ;
    rdfs:comment 'Classification of the temperature breach severity based on deviation magnitude and duration. Minor: slight deviation, Moderate: significant deviation, Critical: severe deviation requiring immediate action.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Timestamp' ;
    rdfs:comment 'Date and time when corrective action was initiated in response to a temperature breach. Used to calculate response time for SLA compliance and operational performance metrics.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Unique code of the warehouse, terminal, or facility where the temperature reading was captured. Populated when location_type is facility-based, null for in-transit readings.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Precise date and time when the temperature reading was captured by the sensor device. Critical for cold-chain compliance verification and breach timeline analysis.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Package Reference Number' ;
    rdfs:comment 'Specific package or container identifier within the shipment being monitored. Enables granular tracking when a shipment contains multiple temperature-controlled units.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorBatteryLevelPercentage rdf:type rdf:Property ;
    rdfs:label 'Sensor Battery Level Percentage' ;
    rdfs:comment 'Remaining battery charge percentage of the IoT sensor device at the time of reading. Used for predictive maintenance and data quality assurance to prevent sensor failures.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensorCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Sensor Calibration Date' ;
    rdfs:comment 'Date when the sensor device was last calibrated for accuracy. Critical for regulatory compliance and ensuring measurement reliability for pharmaceutical and perishable cargo.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sensorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Device Code' ;
    rdfs:comment 'Unique identifier of the IoT sensor or RFID device that captured this temperature reading. Used for device calibration tracking and data quality assurance.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setpointMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Setpoint Max Celsius' ;
    rdfs:comment 'Upper bound of the acceptable temperature range for this shipment as defined by the shipper or regulatory requirement. Used to determine temperature breach conditions.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setpointMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Setpoint Min Celsius' ;
    rdfs:comment 'Lower bound of the acceptable temperature range for this shipment as defined by the shipper or regulatory requirement. Used to determine temperature breach conditions.' ;
    rdfs:domain ind:TemperatureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingEventId rdf:type rdf:Property ;
    rdfs:label 'Tracking Event Id' ;
    rdfs:comment 'Unique identifier for the tracking event record. Primary key. Immutable once assigned.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Api Transaction Reference' ;
    rdfs:comment 'Unique identifier of the API call or transaction that created this event record. Used for API audit trail and troubleshooting. Nullable for non-API events.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageReported rdf:type rdf:Property ;
    rdfs:label 'Damage Reported' ;
    rdfs:comment 'Indicates whether damage to the shipment was observed and reported during this event. True if damage detected, False otherwise. Triggers claims workflow.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediMessageReference rdf:type rdf:Property ;
    rdfs:label 'Edi Message Reference' ;
    rdfs:comment 'Unique identifier of the EDI message that generated this event, if applicable. Used for EDI 214 carrier status messages and event reconciliation.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:comment 'High-level classification of the event type. Tracking events are carrier-reported milestones; hub operations are internal facility scans; exceptions are deviations or delays; lifecycle events are status transitions.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTypeCode rdf:type rdf:Property ;
    rdfs:label 'Event Type Code' ;
    rdfs:comment 'Standardized code representing the specific event type. Examples: PICKUP, DEPARTED, ARRIVED, IN_TRANSIT, SORTED, LOADED_OUTBOUND, OUT_FOR_DELIVERY, DELIVERED, EXCEPTION_DELAY, EXCEPTION_DAMAGE, STATUS_CHANGE. Aligns with IATA and carrier EDI standards.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting how the exception was resolved, actions taken, and any follow-up required. Only populated for exception events.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Resolution Status' ;
    rdfs:comment 'Current resolution state of the exception. Only populated for exception events. Tracks whether the issue has been addressed.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionResolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Resolution Timestamp' ;
    rdfs:comment 'Date and time when the exception was resolved. Only populated for exception events that have been closed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The shipment status after this lifecycle event. Only populated for event_category = lifecycle. Represents the state transition target.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podRecipientName rdf:type rdf:Property ;
    rdfs:label 'Pod Recipient Name' ;
    rdfs:comment 'Name of the person who received and signed for the shipment. Only populated for delivered events with POD. Personally identifiable information.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Captured' ;
    rdfs:comment 'Indicates whether a physical or electronic signature was captured at delivery. True if signature obtained, False otherwise. Used for delivery verification and dispute resolution.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The shipment status immediately before this lifecycle event. Only populated for event_category = lifecycle. Enables status transition audit trail.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the operational system that originally created this event record. Examples: SAP TM, Oracle TMS, Manhattan WMS, FourKites, carrier EDI gateway. Used for data lineage and quality assessment.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitHubEventId rdf:type rdf:Property ;
    rdfs:label 'Transit Hub Event Id' ;
    rdfs:comment 'Unique identifier for the transit hub event record. Primary key for this entity.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hubNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Hub Network Node Id' ;
    rdfs:comment 'Foreign key linking to route.network_node. Business justification: Hub events occur at specific network nodes (terminals, sort facilities). Essential for hub performance analysis, dwell time measurement, throughput tracking, and network optimization. Links operationa' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:outboundFreightManifestId rdf:type rdf:Property ;
    rdfs:label 'Outbound Freight Manifest Id' ;
    rdfs:comment 'Foreign key linking to shipment.freight_manifest. Business justification: Transit hub events record when consignments are loaded onto outbound vehicles. The product currently has outbound_manifest_number (STRING) which should be normalized to a FK. Adding outbound_freight_m' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightManifest .

ind:shipmentConsignmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Consignment Id' ;
    rdfs:comment 'Reference to the shipment being processed through the hub. Links this hub event to the parent shipment entity.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consignment .

ind:customsClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Flag' ;
    rdfs:comment 'Boolean indicator whether customs clearance processing occurred at this hub during this event. True if customs processing, False otherwise.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Status' ;
    rdfs:comment 'Status of customs clearance if customs_clearance_flag is True. CLEARED: customs released. PENDING: awaiting clearance. HELD: customs hold. INSPECTION_REQUIRED: physical inspection requested. Null if no customs processing.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Detected Flag' ;
    rdfs:comment 'Boolean indicator whether physical damage to the shipment or packaging was detected during this hub event. True if damage detected, False otherwise.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handlingUnitBarcode rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Barcode' ;
    rdfs:comment 'Barcode or RFID tag identifier of the physical handling unit (parcel, pallet, container) scanned during the event. Used for item-level tracking within the hub.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code indicating why a shipment was placed on hold during a HELD event. Null for non-hold events. CUSTOMS_HOLD: awaiting customs clearance. DAMAGED: physical damage detected. ADDRESS_CORRECTION: address validation required. PAYMENT_REQUIRED: COD or duty payment pending. SECURITY_SCREENING: additional security checks. WEATHER_DELAY: weather-related hold.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Free-text description providing additional context for the hold reason, entered by the operator.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundVehicleNumber rdf:type rdf:Property ;
    rdfs:label 'Outbound Vehicle Number' ;
    rdfs:comment 'Identifier of the vehicle (truck, trailer, aircraft, container) onto which the shipment was loaded during LOADED_OUTBOUND event.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Photo Reference Code' ;
    rdfs:comment 'Unique identifier or storage path reference for the photo captured during the hub event. Null if no photo captured.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Seconds' ;
    rdfs:comment 'Time in seconds taken to complete this hub event, measured from scan-in to scan-out or event completion. Used for labor productivity and throughput analysis.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityScreeningFlag rdf:type rdf:Property ;
    rdfs:label 'Security Screening Flag' ;
    rdfs:comment 'Boolean indicator whether the shipment underwent security screening (X-ray, physical inspection) during this hub event. True if screened, False otherwise.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Security Screening Result' ;
    rdfs:comment 'Result of the security screening if performed. PASSED: cleared for onward movement. FAILED: security concern identified. MANUAL_REVIEW: requires manual inspection. Null if not screened.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortDestinationCode rdf:type rdf:Property ;
    rdfs:label 'Sort Destination Code' ;
    rdfs:comment 'Destination facility or zone code assigned by the sortation system, indicating where the shipment should be routed next.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortLaneCode rdf:type rdf:Property ;
    rdfs:label 'Sort Lane Code' ;
    rdfs:comment 'Identifier of the sortation lane, belt, or chute where the shipment was routed during the SORTED event. Null for non-sortation events.' ;
    rdfs:domain ind:TransitHubEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:additionalityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Additionality Verified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the carbon offset project has been verified to meet additionality criteria (i.e., the reductions would not have occurred without the project).' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'The independent third-party organization that certifies and validates the carbon offset program (e.g., Gold Standard, VCS/Verra, CDM, ACR, CAR, Plan Vivo). [ENUM-REF-CANDIDATE: Gold Standard|VCS|Verra|CDM|ACR|CAR|Plan Vivo — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBenefits rdf:type rdf:Property ;
    rdfs:label 'Co Benefits' ;
    rdfs:comment 'Additional environmental, social, or economic benefits delivered by the carbon offset project beyond GHG reductions (e.g., biodiversity protection, community employment, water quality improvement).' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corsiaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Corsia Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether the carbon offset program is eligible for use under ICAO\'s CORSIA scheme for international aviation emissions offsetting.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditsPurchased rdf:type rdf:Property ;
    rdfs:label 'Credits Purchased' ;
    rdfs:comment 'The total quantity of carbon offset credits (in tonnes CO2e) that Transport Shipping has purchased from this program to date.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditsReserved rdf:type rdf:Property ;
    rdfs:label 'Credits Reserved' ;
    rdfs:comment 'The quantity of carbon offset credits (in tonnes CO2e) currently reserved or allocated for future retirement but not yet retired.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditsRetired rdf:type rdf:Property ;
    rdfs:label 'Credits Retired' ;
    rdfs:comment 'The total quantity of carbon offset credits (in tonnes CO2e) that have been permanently retired or cancelled to offset Transport Shipping\'s emissions.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euEtsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Ets Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether the carbon offset program is eligible for use under the EU Emissions Trading System for compliance purposes.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Internal Approval Status' ;
    rdfs:comment 'The status of Transport Shipping\'s internal approval process for procuring credits from this carbon offset program (e.g., Pending, Approved, Rejected, Under Review).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permanenceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Permanence Risk Rating' ;
    rdfs:comment 'Assessment of the risk that the carbon reductions or removals may be reversed over time (e.g., Low, Medium, High). Particularly relevant for forestry and land-use projects.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerTonneCo2e rdf:type rdf:Property ;
    rdfs:label 'Price Per Tonne Co2e' ;
    rdfs:comment 'The purchase price per metric tonne of CO2e offset credit in the program\'s currency. Used for procurement cost calculations.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative description of the carbon offset project, including its objectives, methodology, and environmental impact.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'The category of carbon offset project (e.g., reforestation, renewable energy, methane capture, energy efficiency, avoided deforestation, carbon sequestration).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryUrl rdf:type rdf:Property ;
    rdfs:label 'Registry Url' ;
    rdfs:comment 'The web URL link to the public registry entry or project page for this carbon offset program, enabling transparency and traceability.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdgAlignment rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment' ;
    rdfs:comment 'Comma-separated list of UN Sustainable Development Goal numbers that the carbon offset project contributes to (e.g., SDG 7, SDG 13, SDG 15).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditsAvailable rdf:type rdf:Property ;
    rdfs:label 'Total Credits Available' ;
    rdfs:comment 'The total quantity of carbon offset credits (in tonnes CO2e) available for procurement from this program.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStandard rdf:type rdf:Property ;
    rdfs:label 'Verification Standard' ;
    rdfs:comment 'The specific verification or validation standard applied to the carbon offset project (e.g., ISO 14064-3, VCS Standard, Gold Standard for Global Goals).' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYearEnd rdf:type rdf:Property ;
    rdfs:label 'Vintage Year End' ;
    rdfs:comment 'The ending year of the vintage period during which the carbon reductions or removals were achieved. Nullable for ongoing projects.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vintageYearStart rdf:type rdf:Property ;
    rdfs:label 'Vintage Year Start' ;
    rdfs:comment 'The starting year of the vintage period during which the carbon reductions or removals were achieved.' ;
    rdfs:domain ind:CarbonOffsetProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retirementCertificateId rdf:type rdf:Property ;
    rdfs:label 'Retirement Certificate Id' ;
    rdfs:comment 'Unique identifier of the retirement certificate issued by the registry when credits are permanently retired, used for customer green shipping certificates and compliance reporting.' ;
    rdfs:domain ind:CarbonOffsetTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certificate .

ind:complianceScheme rdf:type rdf:Property ;
    rdfs:label 'Compliance Scheme' ;
    rdfs:comment 'Regulatory compliance scheme the transaction supports: CORSIA (Carbon Offsetting and Reduction Scheme for International Aviation), EU ETS (European Union Emissions Trading System), voluntary (non-regulatory), or other.' ;
    rdfs:domain ind:CarbonOffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetStandard rdf:type rdf:Property ;
    rdfs:label 'Offset Standard' ;
    rdfs:comment 'Carbon offset certification standard under which the credits were issued: VCS (Verified Carbon Standard), Gold Standard, CDM (Clean Development Mechanism), CAR (Climate Action Reserve), ACR (American Carbon Registry), Plan Vivo, or other. [ENUM-REF-CANDIDATE: VCS|Gold Standard|CDM|CAR|ACR|Plan Vivo|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CarbonOffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Project Location Country' ;
    rdfs:comment 'Three-letter ISO country code where the carbon offset project is located.' ;
    rdfs:domain ind:CarbonOffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityTco2e rdf:type rdf:Property ;
    rdfs:label 'Quantity Tco2e' ;
    rdfs:comment 'Quantity of carbon credits involved in the transaction, measured in metric tons of carbon dioxide equivalent (tCO2e).' ;
    rdfs:domain ind:CarbonOffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registryName rdf:type rdf:Property ;
    rdfs:label 'Registry Name' ;
    rdfs:comment 'Name of the carbon offset registry where the transaction was recorded (e.g., Verra Registry, Gold Standard Registry, UNFCCC CDM Registry).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrySerialNumber rdf:type rdf:Property ;
    rdfs:label 'Registry Serial Number' ;
    rdfs:comment 'Unique serial number or batch identifier assigned by the carbon offset registry to the credits involved in this transaction.' ;
    rdfs:domain ind:CarbonOffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Business reason or beneficiary statement for retiring the carbon credits (e.g., \'Offset for shipment AWB-12345 on behalf of Customer XYZ\').' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionFee rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee' ;
    rdfs:comment 'Registry or broker fee charged for processing the carbon offset transaction.' ;
    rdfs:domain ind:CarbonOffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionPurpose rdf:type rdf:Property ;
    rdfs:label 'Transaction Purpose' ;
    rdfs:comment 'Business purpose for the carbon offset transaction: voluntary customer offset (customer-paid green shipping), regulatory compliance (CORSIA, EU ETS), internal neutrality target (corporate sustainability goals), corporate commitment, customer request, or other.' ;
    rdfs:domain ind:CarbonOffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Name of the third-party verification body that audited the carbon offset transaction or credits.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'Year in which the carbon offset credits were generated or verified, used for compliance eligibility and pricing.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compliancePeriodId rdf:type rdf:Property ;
    rdfs:label 'Compliance Period Id' ;
    rdfs:comment 'Reference to the CORSIA compliance period (e.g., Phase 1: 2021-2023, Phase 2: 2024-2026, Phase 3: 2027-2035). Links to the regulatory period definition.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompliancePeriod .

ind:annualEmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Annual Emissions Tco2e' ;
    rdfs:comment 'Total CO2 equivalent emissions reported by the airline operator for the reporting year, covering all international aviation routes subject to CORSIA.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineEmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Baseline Emissions Tco2e' ;
    rdfs:comment 'The baseline emissions level in tonnes of CO2 equivalent established for the operator, typically based on 2019-2020 average emissions. Used to calculate growth factor and offsetting obligations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competentAuthority rdf:type rdf:Property ;
    rdfs:label 'Competent Authority' ;
    rdfs:comment 'The national or regional regulatory authority responsible for overseeing CORSIA compliance for the airline operator (e.g., FAA, EASA, CAAC).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competentAuthorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Competent Authority Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the competent authority jurisdiction (e.g., USA, GBR, CHN).' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePhase rdf:type rdf:Property ;
    rdfs:label 'Compliance Phase' ;
    rdfs:comment 'The CORSIA implementation phase applicable to this compliance record. Phase 1 (2021-2023) is pilot/voluntary, Phase 2 (2024-2026) expands participation, Phase 3 (2027-2035) is full implementation.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Record Number' ;
    rdfs:comment 'Externally-known unique business identifier for this CORSIA compliance record, used for regulatory submissions and audit trails.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleUnitsRetiredTco2e rdf:type rdf:Property ;
    rdfs:label 'Eligible Units Retired Tco2e' ;
    rdfs:comment 'The quantity of CORSIA-eligible carbon offset units (in tCO2e) that have been retired by the operator to meet their offsetting obligation. Must come from ICAO-approved carbon offset programs.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionApplied rdf:type rdf:Property ;
    rdfs:label 'Exemption Applied' ;
    rdfs:comment 'Indicates whether any exemptions or special provisions were applied to this compliance record (e.g., small operator exemption, humanitarian flight exemption).' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Description of the reason for any exemption applied, including regulatory basis and justification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:growthFactor rdf:type rdf:Property ;
    rdfs:label 'Growth Factor' ;
    rdfs:comment 'The calculated growth factor representing the ratio of annual emissions to baseline emissions. Used to determine the operator\'s share of offsetting obligations under CORSIA.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetUnitType rdf:type rdf:Property ;
    rdfs:label 'Offset Unit Type' ;
    rdfs:comment 'The type or category of carbon offset units retired (e.g., VCS, Gold Standard, CAR, ACR). Must be from ICAO CORSIA-eligible carbon crediting programs.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsettingObligationTco2e rdf:type rdf:Property ;
    rdfs:label 'Offsetting Obligation Tco2e' ;
    rdfs:comment 'The total carbon offsetting obligation in tonnes of CO2 equivalent that the airline operator must retire to achieve CORSIA compliance for the reporting period.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registryConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Registry Confirmation Number' ;
    rdfs:comment 'The unique confirmation or transaction number issued by the carbon offset registry confirming the retirement of eligible units. Used for audit and verification purposes.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlanSubmitted rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Submitted' ;
    rdfs:comment 'Indicates whether a remediation plan has been submitted to address any compliance shortfall or non-compliance issues.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortfallTco2e rdf:type rdf:Property ;
    rdfs:label 'Shortfall Tco2e' ;
    rdfs:comment 'The difference between the offsetting obligation and the eligible units retired, representing any shortfall in compliance. Zero or null indicates full compliance.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationReportReference rdf:type rdf:Property ;
    rdfs:label 'Verification Report Reference' ;
    rdfs:comment 'Reference number or identifier of the verification report issued by the accredited verification body.' ;
    rdfs:domain ind:CorsiaComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentPackageId rdf:type rdf:Property ;
    rdfs:label 'Source Document Package Id' ;
    rdfs:comment 'Foreign key linking to document.document_package. Business justification: Customer carbon reports reference the underlying document packages containing shipment data used in emissions calculations. Real business process: customer ESG reporting verification requires audit tr' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentPackage .

ind:airFreightCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Air Freight Co2e Kg' ;
    rdfs:comment 'Total CO2 equivalent emissions in kilograms attributable to air freight transport mode for this reporting period.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology' ;
    rdfs:comment 'The carbon accounting methodology and standard used to calculate emissions for this report.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAcceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the customer formally accepted or acknowledged receipt of this carbon report.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerEsgFramework rdf:type rdf:Property ;
    rdfs:label 'Customer Esg Framework' ;
    rdfs:comment 'The ESG reporting framework or standard that the customer uses, to which this carbon report is aligned (e.g., GRI, CDP, TCFD, SASB).' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotes rdf:type rdf:Property ;
    rdfs:label 'Customer Notes' ;
    rdfs:comment 'Free-text notes or comments provided by the customer regarding this carbon report, including feedback, questions, or acceptance remarks.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityRating rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rating' ;
    rdfs:comment 'Assessment of the quality and accuracy of the underlying emissions data used in this report, based on data completeness, source reliability, and calculation precision.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsIntensityGco2ePerKg rdf:type rdf:Property ;
    rdfs:label 'Emissions Intensity Gco2e Per Kg' ;
    rdfs:comment 'Carbon emissions intensity expressed as grams of CO2 equivalent per kilogram of freight shipped, a key performance indicator for green logistics.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionsIntensityGco2ePerTonneKm rdf:type rdf:Property ;
    rdfs:label 'Emissions Intensity Gco2e Per Tonne Km' ;
    rdfs:comment 'Carbon emissions intensity expressed as grams of CO2 equivalent per tonne-kilometer, the standard metric for freight transport carbon efficiency.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Gross Co2e Kg' ;
    rdfs:comment 'Total gross greenhouse gas emissions in kilograms of CO2 equivalent before any carbon offsets are applied.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMileCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Last Mile Co2e Kg' ;
    rdfs:comment 'Total CO2 equivalent emissions in kilograms attributable to last-mile delivery operations for this reporting period.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodologyVersion rdf:type rdf:Property ;
    rdfs:label 'Methodology Version' ;
    rdfs:comment 'Version number or identifier of the calculation methodology used, ensuring traceability and consistency over time.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Net Co2e Kg' ;
    rdfs:comment 'Net greenhouse gas emissions in kilograms of CO2 equivalent after carbon offsets have been applied (gross minus offset).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oceanFreightCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Ocean Freight Co2e Kg' ;
    rdfs:comment 'Total CO2 equivalent emissions in kilograms attributable to ocean freight transport mode for this reporting period.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetCertificatesApplied rdf:type rdf:Property ;
    rdfs:label 'Offset Certificates Applied' ;
    rdfs:comment 'Number of carbon offset certificates or credits applied to this customer report to achieve net emissions reduction.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offsetCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Offset Co2e Kg' ;
    rdfs:comment 'Total carbon offsets applied in kilograms of CO2 equivalent through carbon offset programs.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetProgramNames rdf:type rdf:Property ;
    rdfs:label 'Offset Program Names' ;
    rdfs:comment 'Comma-separated list of carbon offset program names from which credits were applied to this report.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:railFreightCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Rail Freight Co2e Kg' ;
    rdfs:comment 'Total CO2 equivalent emissions in kilograms attributable to rail freight transport mode for this reporting period.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceFlags rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flags' ;
    rdfs:comment 'Comma-separated list of regulatory frameworks or compliance schemes this report satisfies (e.g., EU ETS, CORSIA, CDP disclosure).' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Delivery Timestamp' ;
    rdfs:comment 'Date and time when this carbon report was delivered to the customer.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportFormat rdf:type rdf:Property ;
    rdfs:label 'Report Format' ;
    rdfs:comment 'Format in which the carbon report was delivered to the customer (PDF document, Excel spreadsheet, API payload, EDI message, etc.).' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Generation Timestamp' ;
    rdfs:comment 'Date and time when this carbon report was generated by the system.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportLanguage rdf:type rdf:Property ;
    rdfs:label 'Report Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language in which the report was generated for the customer.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known unique business identifier for this carbon report, used for customer reference and tracking.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the carbon report in the delivery and acceptance workflow.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadFreightCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Road Freight Co2e Kg' ;
    rdfs:comment 'Total CO2 equivalent emissions in kilograms attributable to road freight transport mode for this reporting period.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope1Co2eKg rdf:type rdf:Property ;
    rdfs:label 'Scope 1 Co2e Kg' ;
    rdfs:comment 'Direct greenhouse gas emissions from owned or controlled sources (e.g., company-owned fleet fuel combustion) in kilograms of CO2 equivalent.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2Co2eKg rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Co2e Kg' ;
    rdfs:comment 'Indirect greenhouse gas emissions from purchased electricity, heat, or steam consumed in operations (e.g., warehouse energy) in kilograms of CO2 equivalent.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Co2eKg rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Co2e Kg' ;
    rdfs:comment 'Indirect greenhouse gas emissions from value chain activities including contracted carriers, third-party logistics providers, and upstream/downstream transport in kilograms of CO2 equivalent.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalShipments rdf:type rdf:Property ;
    rdfs:label 'Total Shipments' ;
    rdfs:comment 'Total number of shipments included in this carbon report for the reporting period.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTonneKm rdf:type rdf:Property ;
    rdfs:label 'Total Tonne Km' ;
    rdfs:comment 'Total tonne-kilometers (weight multiplied by distance) for all shipments, a key metric for freight carbon intensity.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uncertaintyPercentage rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Percentage' ;
    rdfs:comment 'Estimated percentage uncertainty or margin of error in the reported carbon emissions calculations, reflecting data quality and methodology limitations.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Warehouse Co2e Kg' ;
    rdfs:comment 'Total CO2 equivalent emissions in kilograms attributable to warehouse and distribution center operations for this reporting period.' ;
    rdfs:domain ind:CustomerCarbonReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByFactorEmissionsFactorId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Factor Emissions Factor Id' ;
    rdfs:comment 'Reference to the emissions factor ID that supersedes this record, enabling version lineage tracking. Null if this is the current active version.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionsFactor .

ind:biofuelBlendPercentage rdf:type rdf:Property ;
    rdfs:label 'Biofuel Blend Percentage' ;
    rdfs:comment 'Percentage of biofuel or sustainable aviation fuel (SAF) blended into the fuel mix for this emissions factor. Null if not applicable or 0% biofuel.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionIntensityValue rdf:type rdf:Property ;
    rdfs:label 'Emission Intensity Value' ;
    rdfs:comment 'Numeric value of the emissions factor representing grams of CO2e per unit of activity (e.g., per tonne-km, per liter, per kWh).' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionsFactorStatus rdf:type rdf:Property ;
    rdfs:label 'Emissions Factor Status' ;
    rdfs:comment 'Current lifecycle status of the emissions factor record.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorCode rdf:type rdf:Property ;
    rdfs:label 'Factor Code' ;
    rdfs:comment 'Unique business identifier code for the emissions factor, used for external reference and integration with carbon calculation systems.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorName rdf:type rdf:Property ;
    rdfs:label 'Factor Name' ;
    rdfs:comment 'Human-readable descriptive name of the emissions factor (e.g., \'Air Freight - Boeing 747 - Jet Fuel\', \'Ocean Freight - Container Vessel - HFO\').' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gwpMultiplierCh4 rdf:type rdf:Property ;
    rdfs:label 'Gwp Multiplier Ch4' ;
    rdfs:comment 'Global Warming Potential multiplier for methane relative to CO2e over 100-year time horizon.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gwpMultiplierCo2 rdf:type rdf:Property ;
    rdfs:label 'Gwp Multiplier Co2' ;
    rdfs:comment 'Global Warming Potential multiplier for carbon dioxide relative to CO2e. Typically 1.0 for CO2.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gwpMultiplierN2o rdf:type rdf:Property ;
    rdfs:label 'Gwp Multiplier N2o' ;
    rdfs:comment 'Global Warming Potential multiplier for nitrous oxide relative to CO2e over 100-year time horizon.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intensityUnit rdf:type rdf:Property ;
    rdfs:label 'Intensity Unit' ;
    rdfs:comment 'Unit of measure for the emission intensity value, defining the activity basis for carbon calculation.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadFactorAssumption rdf:type rdf:Property ;
    rdfs:label 'Load Factor Assumption' ;
    rdfs:comment 'Assumed load factor or capacity utilization percentage used in the emissions factor calculation (e.g., 70.0 represents 70% capacity). Null if not applicable.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationYear rdf:type rdf:Property ;
    rdfs:label 'Publication Year' ;
    rdfs:comment 'Year the source publication or emissions factor dataset was released.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scope3Category rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category' ;
    rdfs:comment 'Specific Scope 3 category per GHG Protocol (e.g., \'Category 4: Upstream transportation\', \'Category 9: Downstream transportation\'). Null for Scope 1 and 2.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeClassification rdf:type rdf:Property ;
    rdfs:label 'Scope Classification' ;
    rdfs:comment 'GHG Protocol scope classification: Scope 1 (direct emissions), Scope 2 (purchased energy), Scope 3 (value chain emissions).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceAuthority rdf:type rdf:Property ;
    rdfs:label 'Source Authority' ;
    rdfs:comment 'Authoritative source or standard body that published or certified this emissions factor (e.g., IPCC, IATA, IMO, DEFRA, EPA, GLEC Framework). [ENUM-REF-CANDIDATE: IPCC|IATA|IMO|DEFRA|EPA|GLEC|EEA|custom — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePublication rdf:type rdf:Property ;
    rdfs:label 'Source Publication' ;
    rdfs:comment 'Specific publication, report, or database from which this emissions factor was sourced (e.g., \'IPCC AR5 WG3\', \'DEFRA 2023 Conversion Factors\', \'IATA CO2 Connect\').' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCategory rdf:type rdf:Property ;
    rdfs:label 'Vehicle Category' ;
    rdfs:comment 'Specific category or class of vehicle, vessel, or aircraft (e.g., \'Wide-body jet\', \'Container ship 8000+ TEU\', \'Heavy-duty truck\', \'Electric locomotive\').' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellToTankIncluded rdf:type rdf:Property ;
    rdfs:label 'Well To Tank Included' ;
    rdfs:comment 'Indicates whether upstream well-to-tank emissions (fuel production and distribution) are included in this factor. True if WTT is included, False if only tank-to-wheel (combustion) emissions are covered.' ;
    rdfs:domain ind:EmissionsFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:energyConsumptionRecordId rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Record Id' ;
    rdfs:comment 'Unique identifier for the energy consumption record. Primary key for this operational record capturing energy usage at facility or asset level.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnergyConsumptionRecord .

ind:baselineYear rdf:type rdf:Property ;
    rdfs:label 'Baseline Year' ;
    rdfs:comment 'Reference year against which energy consumption and emissions reductions are measured. Used to track progress toward sustainability targets and regulatory compliance (e.g., EU ETS baseline, CORSIA baseline).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumption Quantity' ;
    rdfs:comment 'Quantity of energy consumed during the measurement period. Numeric value representing the amount of energy used, expressed in the unit specified in consumption_unit.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionUnit rdf:type rdf:Property ;
    rdfs:label 'Consumption Unit' ;
    rdfs:comment 'Unit of measure for the consumption quantity. Specifies whether energy is measured in kilowatt-hours (kWh), megawatt-hours (MWh), gigajoules (GJ), litres, gallons, cubic meters (m3), or kilograms (kg). [ENUM-REF-CANDIDATE: kWh|MWh|GJ|litre|gallon|m3|kg — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Facing Flag' ;
    rdfs:comment 'Boolean flag indicating whether this energy consumption record contributes to customer-facing carbon footprint reporting (e.g., shipment-level CO2e disclosure). True if the record is used in customer carbon reports; false otherwise.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:energyIntensityDenominator rdf:type rdf:Property ;
    rdfs:label 'Energy Intensity Denominator' ;
    rdfs:comment 'Denominator value used to calculate energy intensity ratio (e.g., number of shipments, TEUs handled, square meters of warehouse space, vehicle kilometers traveled). Enables normalization of energy consumption for benchmarking.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyIntensityUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Intensity Unit' ;
    rdfs:comment 'Unit of measure for the energy intensity denominator (e.g., shipment, TEU, square_meter, vehicle_km). Specifies the operational metric against which energy consumption is normalized.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyType rdf:type rdf:Property ;
    rdfs:label 'Energy Type' ;
    rdfs:comment 'Type of energy consumed. Categorizes the fuel or energy source used during the measurement period. Critical for Scope 1 vs Scope 2 emissions classification per GHG Protocol.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'End date and time of the energy consumption measurement period. Defines the conclusion of the interval for which energy usage is recorded.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'Start date and time of the energy consumption measurement period. Defines the beginning of the interval for which energy usage is recorded.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:meterCode rdf:type rdf:Property ;
    rdfs:label 'Meter Code' ;
    rdfs:comment 'Unique identifier of the physical or virtual meter that recorded the consumption. Nullable when consumption is derived from invoice or estimate rather than direct metering.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meteringSource rdf:type rdf:Property ;
    rdfs:label 'Metering Source' ;
    rdfs:comment 'Source or method by which the energy consumption data was captured. Indicates whether the measurement came from a smart meter, manual meter reading, utility invoice, estimation model, IoT sensor, or vehicle telematics system.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalContext rdf:type rdf:Property ;
    rdfs:label 'Operational Context' ;
    rdfs:comment 'Description of the operational activity or process associated with this energy consumption (e.g., warehouse operations, last-mile delivery, line-haul transport, office administration). Enables activity-based energy intensity analysis.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this energy consumption record is included in mandatory regulatory reporting (e.g., EU ETS, CORSIA, national GHG inventories). True if the record is part of a regulatory submission; false otherwise.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewableEnergySharePercent rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Share Percent' ;
    rdfs:comment 'Percentage of the consumed energy that came from renewable sources (solar, wind, hydro, biomass). Used to calculate net emissions and support green logistics reporting. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope1EmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 1 Emissions Tco2e' ;
    rdfs:comment 'Direct greenhouse gas emissions in metric tons of carbon dioxide equivalent (tCO2e) resulting from this energy consumption. Applies to combustion of fossil fuels owned or controlled by the organization (diesel, natural gas, LPG). Calculated using emission factors per GHG Protocol.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2EmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Emissions Tco2e' ;
    rdfs:comment 'Indirect greenhouse gas emissions in metric tons of carbon dioxide equivalent (tCO2e) from purchased electricity, heat, or steam. Calculated using grid emission factors adjusted for renewable energy share per GHG Protocol Scope 2 Guidance.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Account Number' ;
    rdfs:comment 'Account number or customer reference assigned by the energy supplier. Used to reconcile consumption records with utility invoices.' ;
    rdfs:domain ind:EnergyConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the individual, team, or third-party organization that verified this energy consumption record. Nullable for unverified records.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentPackageId rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Package Id' ;
    rdfs:comment 'Foreign key linking to document.document_package. Business justification: ESG disclosures reference document packages containing transport documents as evidence for emissions calculations and regulatory submissions. Real business process: ESG audit trail requires linking di' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentPackage .

ind:assuranceLevel rdf:type rdf:Property ;
    rdfs:label 'Assurance Level' ;
    rdfs:comment 'Level of external assurance obtained for this ESG disclosure. None = no external assurance, Limited = limited assurance engagement, Reasonable = reasonable assurance engagement (equivalent to financial audit).' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assuranceOpinion rdf:type rdf:Property ;
    rdfs:label 'Assurance Opinion' ;
    rdfs:comment 'Type of opinion issued by the external auditor. Unqualified = clean opinion with no material misstatements, Qualified = opinion with exceptions, Adverse = material misstatements present, Disclaimer = auditor unable to form an opinion.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardIndependencePercentage rdf:type rdf:Property ;
    rdfs:label 'Board Independence Percentage' ;
    rdfs:comment 'Percentage of board members classified as independent directors according to applicable corporate governance standards.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetCreditsTonnes rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Credits Tonnes' ;
    rdfs:comment 'Total volume of verified carbon offset credits purchased or retired during the reporting period to compensate for emissions, expressed in metric tonnes of CO2 equivalent.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corsiaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Corsia Compliance Flag' ;
    rdfs:comment 'Indicates whether the reporting entity is subject to and compliant with CORSIA requirements for international aviation emissions offsetting.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPrivacyIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Incidents Count' ;
    rdfs:comment 'Total number of substantiated data privacy breaches or incidents during the reporting period.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disclosureFramework rdf:type rdf:Property ;
    rdfs:label 'Disclosure Framework' ;
    rdfs:comment 'The ESG reporting framework or standard under which this disclosure is prepared. GRI = Global Reporting Initiative, TCFD = Task Force on Climate-related Financial Disclosures, CDP = Carbon Disclosure Project, EU_CSRD = EU Corporate Sustainability Reporting Directive, SASB_TRANSPORT = Sustainability Accounting Standards Board Transport sector, UNGC = UN Global Compact, ISO_14064 = Greenhouse Gas Accounting Standard. [ENUM-REF-CANDIDATE: GRI|TCFD|CDP|EU_CSRD|SASB_TRANSPORT|INTEGRATED_REPORTING|UNGC|ISO_14064 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Disclosure Reference Number' ;
    rdfs:comment 'Externally-known unique reference number or code assigned to this ESG disclosure submission for tracking and citation purposes.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Current lifecycle status of the ESG disclosure record. [ENUM-REF-CANDIDATE: draft|under_review|approved|submitted|published|amended|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumptionMwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Mwh' ;
    rdfs:comment 'Total energy consumed from all sources during the reporting period, expressed in megawatt hours.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ethicsTrainingCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Ethics Training Completion Percentage' ;
    rdfs:comment 'Percentage of employees who completed mandatory ethics and compliance training during the reporting period.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euEtsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Ets Compliance Flag' ;
    rdfs:comment 'Indicates whether the reporting entity is subject to and compliant with EU ETS cap-and-trade requirements for greenhouse gas emissions.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:femaleWorkforcePercentage rdf:type rdf:Property ;
    rdfs:label 'Female Workforce Percentage' ;
    rdfs:comment 'Percentage of total workforce identifying as female at the end of the reporting period.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lostTimeInjuryRate rdf:type rdf:Property ;
    rdfs:label 'Lost Time Injury Rate' ;
    rdfs:comment 'Number of lost time injuries per million hours worked during the reporting period. Lost time injury is a work-related injury resulting in the employee being unable to attend work for at least one full day after the injury.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netZeroTargetYear rdf:type rdf:Property ;
    rdfs:label 'Net Zero Target Year' ;
    rdfs:comment 'Calendar year by which the reporting entity has committed to achieve net-zero greenhouse gas emissions, if applicable.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preparedByName rdf:type rdf:Property ;
    rdfs:label 'Prepared By Name' ;
    rdfs:comment 'Name of the individual or team responsible for preparing this ESG disclosure.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationUrl rdf:type rdf:Property ;
    rdfs:label 'Publication Url' ;
    rdfs:comment 'Web address where the full ESG disclosure report is publicly accessible.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required Flag' ;
    rdfs:comment 'Indicates whether this ESG disclosure is mandated by regulatory requirements (True) or is voluntary (False).' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewableEnergyPercentage rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Percentage' ;
    rdfs:comment 'Percentage of total energy consumption sourced from renewable energy sources during the reporting period.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary amounts reported in this ESG disclosure.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingEntityName rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity Name' ;
    rdfs:comment 'Full legal name of the entity submitting the ESG disclosure.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scienceBasedTargetsFlag rdf:type rdf:Property ;
    rdfs:label 'Science Based Targets Flag' ;
    rdfs:comment 'Indicates whether the reporting entity has committed to and set emissions reduction targets validated by the Science Based Targets initiative.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope1EmissionsCo2eTonnes rdf:type rdf:Property ;
    rdfs:label 'Scope 1 Emissions Co2e Tonnes' ;
    rdfs:comment 'Total direct greenhouse gas emissions from owned or controlled sources during the reporting period, expressed in metric tonnes of CO2 equivalent.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2EmissionsCo2eTonnes rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Emissions Co2e Tonnes' ;
    rdfs:comment 'Total indirect greenhouse gas emissions from purchased electricity, steam, heating, and cooling during the reporting period, expressed in metric tonnes of CO2 equivalent.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3EmissionsCo2eTonnes rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Emissions Co2e Tonnes' ;
    rdfs:comment 'Total indirect greenhouse gas emissions from value chain activities (upstream and downstream) during the reporting period, expressed in metric tonnes of CO2 equivalent.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Sustainability Investment Amount' ;
    rdfs:comment 'Total capital expenditure and operating expenditure invested in sustainability initiatives, green technologies, and ESG programs during the reporting period, expressed in reporting currency.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmissionsCo2eTonnes rdf:type rdf:Property ;
    rdfs:label 'Total Emissions Co2e Tonnes' ;
    rdfs:comment 'Sum of Scope 1, Scope 2, and Scope 3 emissions for the reporting period, expressed in metric tonnes of CO2 equivalent.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWorkforceFte rdf:type rdf:Property ;
    rdfs:label 'Total Workforce Fte' ;
    rdfs:comment 'Total number of employees expressed as full-time equivalents at the end of the reporting period.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteGeneratedTonnes rdf:type rdf:Property ;
    rdfs:label 'Waste Generated Tonnes' ;
    rdfs:comment 'Total weight of waste generated during the reporting period, expressed in metric tonnes.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteRecycledPercentage rdf:type rdf:Property ;
    rdfs:label 'Waste Recycled Percentage' ;
    rdfs:comment 'Percentage of total waste generated that was recycled or diverted from landfill during the reporting period.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterConsumptionCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Cubic Meters' ;
    rdfs:comment 'Total volume of water consumed during the reporting period, expressed in cubic meters.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceDiversityPercentage rdf:type rdf:Property ;
    rdfs:label 'Workforce Diversity Percentage' ;
    rdfs:comment 'Percentage of workforce from underrepresented groups (gender, ethnicity, disability) as defined by applicable diversity frameworks and regulations.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgRatingRecordId rdf:type rdf:Property ;
    rdfs:label 'Esg Rating Record Id' ;
    rdfs:comment 'Unique identifier for the ESG rating record. Primary key for this entity.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentScope rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope' ;
    rdfs:comment 'Description of the organizational scope covered by the assessment (e.g., global operations, specific regions, business units). Defines boundaries of the rating.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerReportingUseFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Reporting Use Flag' ;
    rdfs:comment 'Indicates whether this rating is approved for sharing with customers as part of customer-facing carbon reporting and sustainability communications.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosureUrl rdf:type rdf:Property ;
    rdfs:label 'Disclosure Url' ;
    rdfs:comment 'URL link to the public disclosure document or rating report published by the agency or Transport Shipping. Null if not publicly disclosed.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalScore rdf:type rdf:Property ;
    rdfs:label 'Environmental Score' ;
    rdfs:comment 'Score for the Environmental pillar covering GHG emissions, energy efficiency, waste management, water usage, biodiversity impact, and environmental compliance.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governanceScore rdf:type rdf:Property ;
    rdfs:label 'Governance Score' ;
    rdfs:comment 'Score for the Governance pillar covering board composition, executive compensation, shareholder rights, business ethics, anti-corruption policies, and regulatory compliance.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:improvementRecommendations rdf:type rdf:Property ;
    rdfs:label 'Improvement Recommendations' ;
    rdfs:comment 'Specific recommendations provided by the rating agency for improving ESG performance and achieving higher ratings in future assessments.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryPercentile rdf:type rdf:Property ;
    rdfs:label 'Industry Percentile' ;
    rdfs:comment 'Percentile ranking within the logistics industry peer group (0-100). Higher percentiles indicate better relative performance.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:industryRank rdf:type rdf:Property ;
    rdfs:label 'Industry Rank' ;
    rdfs:comment 'Numerical rank of Transport Shipping within the logistics industry peer group as determined by the rating agency. Lower numbers indicate better performance.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investorRelationsUseFlag rdf:type rdf:Property ;
    rdfs:label 'Investor Relations Use Flag' ;
    rdfs:comment 'Indicates whether this rating is approved for use in investor relations communications, annual reports, and shareholder presentations.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyStrengths rdf:type rdf:Property ;
    rdfs:label 'Key Strengths' ;
    rdfs:comment 'Summary of key strengths and positive performance areas highlighted by the rating agency in their assessment. Used for internal improvement tracking and external communications.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyWeaknesses rdf:type rdf:Property ;
    rdfs:label 'Key Weaknesses' ;
    rdfs:comment 'Summary of key weaknesses, gaps, and areas for improvement identified by the rating agency. Used for action planning and continuous improvement initiatives.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next ESG rating assessment by this agency. Used for planning data collection and submission activities.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallScoreScale rdf:type rdf:Property ;
    rdfs:label 'Overall Score Scale' ;
    rdfs:comment 'Description of the scoring scale used by the rating agency (e.g., 0-100, AAA-CCC, Advanced-Beginner). Provides context for interpreting the overall score.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peerGroupSize rdf:type rdf:Property ;
    rdfs:label 'Peer Group Size' ;
    rdfs:comment 'Total number of companies in the logistics industry peer group used for benchmarking and ranking by the rating agency.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorPeriodOverallScore rdf:type rdf:Property ;
    rdfs:label 'Prior Period Overall Score' ;
    rdfs:comment 'Overall ESG score from the previous assessment period, enabling year-over-year performance comparison and trend analysis.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodRatingTier rdf:type rdf:Property ;
    rdfs:label 'Prior Period Rating Tier' ;
    rdfs:comment 'Rating tier or grade from the previous assessment period for trend analysis and performance tracking.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether this ESG rating has been publicly disclosed by Transport Shipping or the rating agency. True if publicly available; False if confidential.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingAgency rdf:type rdf:Property ;
    rdfs:label 'Rating Agency' ;
    rdfs:comment 'Name of the third-party ESG rating agency or framework that issued the rating. Includes MSCI, Sustainalytics, EcoVadis, CDP (Carbon Disclosure Project), DJSI (Dow Jones Sustainability Index), and ISS (Institutional Shareholder Services).' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Rating Agency Code' ;
    rdfs:comment 'Standardized code or abbreviation for the rating agency used for system integration and reporting.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingTier rdf:type rdf:Property ;
    rdfs:label 'Rating Tier' ;
    rdfs:comment 'Categorical rating tier or grade assigned by the agency (e.g., AAA, AA, A, BBB for MSCI; Leader, Advanced, Intermediate for EcoVadis). Provides qualitative assessment of ESG performance.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Rating Validity End Date' ;
    rdfs:comment 'Date when this ESG rating expires or is no longer considered current by the rating agency. Ratings typically have annual or biennial validity periods.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Report Reference Number' ;
    rdfs:comment 'Unique reference number or identifier assigned by the rating agency to the assessment report for tracking and retrieval purposes.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'End date of the reporting period covered by this ESG rating assessment.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'Start date of the reporting period covered by this ESG rating assessment.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scoreChange rdf:type rdf:Property ;
    rdfs:label 'Score Change' ;
    rdfs:comment 'Numerical change in overall ESG score compared to the prior period. Positive values indicate improvement; negative values indicate decline.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialScore rdf:type rdf:Property ;
    rdfs:label 'Social Score' ;
    rdfs:comment 'Score for the Social pillar covering labor practices, health and safety, diversity and inclusion, human rights, community engagement, and supply chain labor standards.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderQualificationUseFlag rdf:type rdf:Property ;
    rdfs:label 'Tender Qualification Use Flag' ;
    rdfs:comment 'Indicates whether this rating is approved for inclusion in tender submissions and customer procurement qualification responses requiring ESG credentials.' ;
    rdfs:domain ind:EsgRatingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationBody rdf:type rdf:Property ;
    rdfs:label 'Verification Body' ;
    rdfs:comment 'Name of the independent third-party organization that verified or audited the ESG rating data and assessment process.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euEtsAllowanceId rdf:type rdf:Property ;
    rdfs:label 'Eu Ets Allowance Id' ;
    rdfs:comment 'Unique identifier for the EU ETS allowance record. Primary key for tracking allowance holdings, allocations, and surrender obligations across compliance periods.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedAllowances rdf:type rdf:Property ;
    rdfs:label 'Allocated Allowances' ;
    rdfs:comment 'Number of allowances allocated free of charge by the EU to the operator for this compliance period. Measured in tonnes of Carbon Dioxide Equivalent (CO2e). Aviation operators receive limited free allocations; maritime allocations are being phased in.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allowanceType rdf:type rdf:Property ;
    rdfs:label 'Allowance Type' ;
    rdfs:comment 'Type of emission allowance held. EUA = EU Allowance (general), EUAA = EU Aviation Allowance, CER = Certified Emission Reduction (Kyoto), ERU = Emission Reduction Unit (Kyoto). Aviation operators primarily use EUAA; maritime operators use EUA.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageAllowancePrice rdf:type rdf:Property ;
    rdfs:label 'Average Allowance Price' ;
    rdfs:comment 'Weighted average price paid per allowance (per tonne CO2e) for purchased allowances during the compliance period. Used for financial reporting and carbon cost analysis. Expressed in EUR.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compliancePeriodYear rdf:type rdf:Property ;
    rdfs:label 'Compliance Period Year' ;
    rdfs:comment 'The calendar year for which this allowance record applies. EU ETS operates on annual compliance cycles requiring surrender of allowances by April 30 of the following year.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberStateCode rdf:type rdf:Property ;
    rdfs:label 'Member State Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 code of the EU member state under whose jurisdiction this operator falls for EU ETS purposes. Examples: DE (Germany), FR (France), NL (Netherlands).' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCode rdf:type rdf:Property ;
    rdfs:label 'Operator Code' ;
    rdfs:comment 'Identifier for the Transport Shipping operational entity (aviation or maritime operator) subject to EU ETS obligations. Links to the internal operator master data.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingObligationCo2e rdf:type rdf:Property ;
    rdfs:label 'Outstanding Obligation Co2e' ;
    rdfs:comment 'Remaining surrender obligation not yet covered by allowances. Calculated as verified_emissions_co2e minus surrendered_allowances. A positive value indicates a shortfall requiring additional allowance purchases. Measured in tonnes of CO2e.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency' ;
    rdfs:comment 'Currency in which penalties are denominated. EU ETS penalties are always in EUR.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasedAllowances rdf:type rdf:Property ;
    rdfs:label 'Purchased Allowances' ;
    rdfs:comment 'Number of allowances purchased by the operator through auctions or secondary markets to cover emissions obligations. Measured in tonnes of CO2e.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registryAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Registry Account Number' ;
    rdfs:comment 'Unique account identifier in the EU ETS Union Registry where allowances are held. Format follows EU Registry specifications for operator holding accounts.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingEntity rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity' ;
    rdfs:comment 'Legal entity within Transport Shipping responsible for EU ETS reporting and compliance for this record. May differ from operator_name in cases of group structures.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sector rdf:type rdf:Property ;
    rdfs:label 'Sector' ;
    rdfs:comment 'The transport sector to which this allowance record applies. Aviation covers flights within the European Economic Area (EEA); maritime covers vessels under EU MRV (Monitoring, Reporting, Verification) regulation.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surplusAllowances rdf:type rdf:Property ;
    rdfs:label 'Surplus Allowances' ;
    rdfs:comment 'Excess allowances held after meeting surrender obligations. Can be banked for future compliance periods or sold. Calculated as total_available_allowances minus verified_emissions_co2e. Measured in tonnes of CO2e.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surrenderDate rdf:type rdf:Property ;
    rdfs:label 'Surrender Date' ;
    rdfs:comment 'Actual date when allowances were surrendered to the EU Registry to cover emissions obligations. Must be on or before the surrender_deadline_date to avoid penalties.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surrenderDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Surrender Deadline Date' ;
    rdfs:comment 'Regulatory deadline by which allowances must be surrendered for the compliance period. Typically April 30 of the year following the compliance period.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surrenderedAllowances rdf:type rdf:Property ;
    rdfs:label 'Surrendered Allowances' ;
    rdfs:comment 'Number of allowances surrendered by the operator to cover verified emissions for the compliance period. Must be submitted by April 30 of the following year. Measured in tonnes of CO2e.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAllowanceCost rdf:type rdf:Property ;
    rdfs:label 'Total Allowance Cost' ;
    rdfs:comment 'Total cost incurred for purchasing allowances during the compliance period. Calculated as purchased_allowances multiplied by average_allowance_price. Expressed in EUR.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAvailableAllowances rdf:type rdf:Property ;
    rdfs:label 'Total Available Allowances' ;
    rdfs:comment 'Total number of allowances available in the operators account for surrender. Calculated as allocated + purchased + transferred_in - transferred_out. Measured in tonnes of CO2e.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferredInAllowances rdf:type rdf:Property ;
    rdfs:label 'Transferred In Allowances' ;
    rdfs:comment 'Number of allowances transferred into the operators registry account from other accounts during the compliance period. Measured in tonnes of CO2e.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferredOutAllowances rdf:type rdf:Property ;
    rdfs:label 'Transferred Out Allowances' ;
    rdfs:comment 'Number of allowances transferred out of the operators registry account to other accounts during the compliance period. Measured in tonnes of CO2e.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifiedEmissionsCo2e rdf:type rdf:Property ;
    rdfs:label 'Verified Emissions Co2e' ;
    rdfs:comment 'Total verified greenhouse gas emissions for the compliance period, expressed in tonnes of CO2e. This is the amount of allowances that must be surrendered. Verified by an accredited verifier per EU MRV requirements.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifierAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Verifier Accreditation Number' ;
    rdfs:comment 'Official accreditation number of the verifier issued by the national accreditation body. Required for regulatory reporting and audit trail.' ;
    rdfs:domain ind:EuEtsAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonOffsetCertificateId rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Certificate Id' ;
    rdfs:comment 'Identifier of the carbon offset certificate applied to this fuel consumption record. Links to the carbon offset registry.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certificate .

ind:ambientTemperature rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature' ;
    rdfs:comment 'Ambient temperature during fuel consumption in degrees Celsius. Temperature affects fuel efficiency and is used for performance normalization.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetApplied rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Applied' ;
    rdfs:comment 'Indicates whether carbon offsets have been applied to neutralize the emissions from this fuel consumption. Used for net-zero reporting and customer carbon-neutral shipping programs.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cargoWeight rdf:type rdf:Property ;
    rdfs:label 'Cargo Weight' ;
    rdfs:comment 'Total weight of cargo carried during this fuel consumption period. Used for emissions intensity calculations (grams CO2e per tonne-kilometre).' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoWeightUnit rdf:type rdf:Property ;
    rdfs:label 'Cargo Weight Unit' ;
    rdfs:comment 'Unit of measure for cargo weight. Typically kilograms or tonnes.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eEmissions rdf:type rdf:Property ;
    rdfs:label 'Co2e Emissions' ;
    rdfs:comment 'Total greenhouse gas emissions in kilograms of CO2 equivalent (CO2e) calculated from this fuel consumption using applicable emission factors. Primary metric for Scope 1 emissions reporting.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionDate rdf:type rdf:Property ;
    rdfs:label 'Consumption Date' ;
    rdfs:comment 'Date of fuel consumption event. Used for daily aggregation and reporting.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'Date and time when the fuel consumption was recorded or occurred. Primary business event timestamp for this record.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distanceTravelled rdf:type rdf:Property ;
    rdfs:label 'Distance Travelled' ;
    rdfs:comment 'Total distance travelled by the asset during the fuel consumption period. Used to calculate fuel efficiency metrics (litres per 100 km, miles per gallon).' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactor rdf:type rdf:Property ;
    rdfs:label 'Emission Factor' ;
    rdfs:comment 'Emission factor applied to calculate CO2e emissions from fuel quantity. Expressed as kilograms CO2e per litre or kilogram of fuel. Varies by fuel type and regulatory framework.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactorSource rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Source' ;
    rdfs:comment 'Source or standard from which the emission factor was obtained. Ensures traceability and compliance with regulatory requirements.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCost rdf:type rdf:Property ;
    rdfs:label 'Fuel Cost' ;
    rdfs:comment 'Total cost of fuel consumed in this record. Used for cost allocation and profitability analysis.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Fuel Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fuel cost amount.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelQuantity rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity' ;
    rdfs:comment 'Quantity of fuel consumed during the trip or operational period. Measured in litres, kilograms, or kilowatt-hours depending on fuel type.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity Unit' ;
    rdfs:comment 'Unit of measure for the fuel quantity consumed. Typically litres for liquid fuels, kilograms for LNG, kilowatt-hours (kWh) for electric.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSupplier rdf:type rdf:Property ;
    rdfs:label 'Fuel Supplier' ;
    rdfs:comment 'Name of the fuel supplier or refueling station. Used for supplier performance analysis and invoice reconciliation.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadFactor rdf:type rdf:Property ;
    rdfs:label 'Load Factor' ;
    rdfs:comment 'Percentage of asset capacity utilized during this trip. Used to allocate fuel consumption and emissions to cargo vs. empty running. Expressed as percentage (0-100).' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalMode rdf:type rdf:Property ;
    rdfs:label 'Operational Mode' ;
    rdfs:comment 'Operational mode of the asset during fuel consumption. Different modes have different fuel consumption profiles and emission factors. [ENUM-REF-CANDIDATE: cruise|idle|taxiing|loading|unloading|maneuvering|berthing — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refuelingLocation rdf:type rdf:Property ;
    rdfs:label 'Refueling Location' ;
    rdfs:comment 'Physical location where refueling occurred. Airport, port, depot, or station name.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeSegment rdf:type rdf:Property ;
    rdfs:label 'Route Segment' ;
    rdfs:comment 'Specific route segment or leg identifier for this fuel consumption record. Enables segment-level fuel efficiency analysis.' ;
    rdfs:domain ind:FuelConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseYear rdf:type rdf:Property ;
    rdfs:label 'Base Year' ;
    rdfs:comment 'The historical year against which GHG emissions are tracked and reduction targets are measured.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseYearEmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Base Year Emissions Tco2e' ;
    rdfs:comment 'Total GHG emissions in the base year, used as the reference point for tracking emissions reductions over time.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseYearRecalculationFlag rdf:type rdf:Property ;
    rdfs:label 'Base Year Recalculation Flag' ;
    rdfs:comment 'Indicates whether the base year emissions have been recalculated due to structural changes, methodology improvements, or data quality improvements.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biogenicCo2EmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Biogenic Co2 Emissions Tco2e' ;
    rdfs:comment 'Total biogenic CO2 emissions from the combustion or biodegradation of biomass, reported separately from fossil-based emissions.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetsPurchasedTco2e rdf:type rdf:Property ;
    rdfs:label 'Carbon Offsets Purchased Tco2e' ;
    rdfs:comment 'Total carbon offsets purchased and retired during the reporting period to compensate for GHG emissions, expressed in tonnes of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonRemovalsTco2e rdf:type rdf:Property ;
    rdfs:label 'Carbon Removals Tco2e' ;
    rdfs:comment 'Total carbon dioxide removals from the atmosphere through activities such as afforestation, reforestation, or direct air capture, expressed in tonnes of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdpDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Cdp Disclosure Flag' ;
    rdfs:comment 'Indicates whether this inventory was disclosed through the CDP climate change questionnaire.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intensityRatioTco2ePerFte rdf:type rdf:Property ;
    rdfs:label 'Intensity Ratio Tco2e Per Fte' ;
    rdfs:comment 'GHG emissions intensity expressed as tonnes of CO2 equivalent per full-time equivalent employee.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intensityRatioTco2ePerRevenueMillion rdf:type rdf:Property ;
    rdfs:label 'Intensity Ratio Tco2e Per Revenue Million' ;
    rdfs:comment 'GHG emissions intensity expressed as tonnes of CO2 equivalent per million units of revenue, used for benchmarking and trend analysis.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intensityRatioTco2ePerTonneKm rdf:type rdf:Property ;
    rdfs:label 'Intensity Ratio Tco2e Per Tonne Km' ;
    rdfs:comment 'GHG emissions intensity expressed as tonnes of CO2 equivalent per tonne-kilometer of freight transported, a key logistics industry metric.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle status of the GHG inventory record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryYear rdf:type rdf:Property ;
    rdfs:label 'Inventory Year' ;
    rdfs:comment 'The calendar year for which this GHG inventory is reported (e.g., 2023).' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organizationalBoundaryMethod rdf:type rdf:Property ;
    rdfs:label 'Organizational Boundary Method' ;
    rdfs:comment 'The consolidation approach used to define the organizational boundary for this inventory (operational control, financial control, or equity share).' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for preparing this GHG inventory.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this inventory was submitted to a regulatory authority for compliance purposes (e.g., EU ETS, CORSIA).' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingFramework rdf:type rdf:Property ;
    rdfs:label 'Reporting Framework' ;
    rdfs:comment 'The primary GHG accounting and reporting framework or standard used for this inventory (e.g., GHG Protocol Corporate Standard, ISO 14064-1, CDP). [ENUM-REF-CANDIDATE: ghg_protocol_corporate|iso_14064_1|cdp|tcfd|gri|sasb|eu_ets|corsia — promote to reference product]' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope1TotalTco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 1 Total Tco2e' ;
    rdfs:comment 'Total Scope 1 direct GHG emissions from sources owned or controlled by the organization, expressed in tonnes of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2LocationBasedTco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Location Based Tco2e' ;
    rdfs:comment 'Total Scope 2 indirect GHG emissions from purchased electricity, heat, steam, and cooling, calculated using location-based emission factors.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2MarketBasedTco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Market Based Tco2e' ;
    rdfs:comment 'Total Scope 2 indirect GHG emissions from purchased electricity, heat, steam, and cooling, calculated using market-based emission factors reflecting contractual instruments.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category15Tco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 15 Tco2e' ;
    rdfs:comment 'Scope 3 emissions associated with the organization\'s investments, including equity and debt investments and project finance.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category1Tco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 1 Tco2e' ;
    rdfs:comment 'Scope 3 emissions from extraction, production, and transportation of goods and services purchased by the organization.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category2Tco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 2 Tco2e' ;
    rdfs:comment 'Scope 3 emissions from extraction, production, and transportation of capital goods purchased by the organization.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category3Tco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 3 Tco2e' ;
    rdfs:comment 'Scope 3 emissions from extraction, production, and transportation of fuels and energy purchased, including upstream emissions and transmission and distribution losses.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category4Tco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 4 Tco2e' ;
    rdfs:comment 'Scope 3 emissions from transportation and distribution of products purchased by the organization in vehicles not owned or operated by the organization.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category5Tco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 5 Tco2e' ;
    rdfs:comment 'Scope 3 emissions from disposal and treatment of waste generated in the organization\'s operations.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category6Tco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 6 Tco2e' ;
    rdfs:comment 'Scope 3 emissions from transportation of employees for business-related activities in vehicles not owned or operated by the organization.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category7Tco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 7 Tco2e' ;
    rdfs:comment 'Scope 3 emissions from transportation of employees between their homes and worksites.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category9Tco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 9 Tco2e' ;
    rdfs:comment 'Scope 3 emissions from transportation and distribution of products sold by the organization between the organization\'s operations and the end consumer in vehicles not owned or operated by the organization.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3TotalTco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Total Tco2e' ;
    rdfs:comment 'Total Scope 3 indirect GHG emissions from value chain activities not owned or controlled by the organization, aggregated across all relevant categories.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tcfdAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Tcfd Alignment Flag' ;
    rdfs:comment 'Indicates whether this inventory aligns with TCFD recommendations for climate-related financial disclosures.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalGrossEmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Total Gross Emissions Tco2e' ;
    rdfs:comment 'Sum of Scope 1, Scope 2 (location-based or market-based as per reporting choice), and Scope 3 emissions, representing total gross GHG emissions before any offsets or removals.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetEmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Total Net Emissions Tco2e' ;
    rdfs:comment 'Total gross emissions minus carbon removals and any purchased carbon offsets, representing the net GHG emissions position.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStatementUrl rdf:type rdf:Property ;
    rdfs:label 'Verification Statement Url' ;
    rdfs:comment 'URL or file path to the verification statement or assurance report issued by the third-party verifier.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonIntensityGco2ePerTkm rdf:type rdf:Property ;
    rdfs:label 'Carbon Intensity Gco2e Per Tkm' ;
    rdfs:comment 'Carbon intensity of the shipment, measured in grams of CO2 equivalent per tonne-kilometer.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificatePdfUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Pdf Url' ;
    rdfs:comment 'URL to download the PDF version of the green shipment certificate for customer records and ESG reporting.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEsgReportFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Esg Report Flag' ;
    rdfs:comment 'Indicates whether this certificate has been included in the customer\'s ESG or sustainability reporting.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:greenProductTier rdf:type rdf:Property ;
    rdfs:label 'Green Product Tier' ;
    rdfs:comment 'Commercial tier or level of the green logistics product purchased by the customer (e.g., carbon neutral, carbon reduced, SAF-powered).' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceDate rdf:type rdf:Property ;
    rdfs:label 'Issuance Date' ;
    rdfs:comment 'Date when the green shipment certificate was issued to the customer.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingOrganization rdf:type rdf:Property ;
    rdfs:label 'Issuing Organization' ;
    rdfs:comment 'Name of the Transport Shipping business unit or legal entity that issued the certificate.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetCreditSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Offset Credit Serial Number' ;
    rdfs:comment 'Serial number or unique identifier of the carbon credit(s) retired or allocated to this shipment.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetProgramName rdf:type rdf:Property ;
    rdfs:label 'Offset Program Name' ;
    rdfs:comment 'Name of the carbon offset program or project used to neutralize or reduce the shipment emissions (e.g., Gold Standard, Verified Carbon Standard, reforestation project).' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Purchase Amount' ;
    rdfs:comment 'Amount paid by the customer for the green shipment service or carbon offset purchase.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Purchase Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the purchase amount.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safPercentage rdf:type rdf:Property ;
    rdfs:label 'Saf Percentage' ;
    rdfs:comment 'Percentage of Sustainable Aviation Fuel used in the shipment, if applicable. Null for non-air shipments.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Shipment Distance Km' ;
    rdfs:comment 'Total distance traveled by the shipment in kilometers, used for emissions calculation.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Shipment Weight Kg' ;
    rdfs:comment 'Total weight of the shipment in kilograms, used for emissions calculation.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationQrCode rdf:type rdf:Property ;
    rdfs:label 'Verification Qr Code' ;
    rdfs:comment 'QR code data or reference that can be scanned to verify the certificate digitally.' ;
    rdfs:domain ind:GreenShipmentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodegradableFlag rdf:type rdf:Property ;
    rdfs:label 'Biodegradable Flag' ;
    rdfs:comment 'Indicates whether the packaging material is biodegradable (True) or not (False).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:co2eImpactKg rdf:type rdf:Property ;
    rdfs:label 'Co2e Impact Kg' ;
    rdfs:comment 'Carbon footprint of the packaging material expressed in kilograms of CO2 equivalent, calculated from production through disposal.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compostableFlag rdf:type rdf:Property ;
    rdfs:label 'Compostable Flag' ;
    rdfs:comment 'Indicates whether the packaging material is certified compostable (True) or not (False).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerGreenCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Green Commitment Flag' ;
    rdfs:comment 'Indicates whether this packaging was used to fulfill a customer-specific green packaging commitment or sustainability requirement (True) or standard packaging (False).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endOfLifeTreatment rdf:type rdf:Property ;
    rdfs:label 'End Of Life Treatment' ;
    rdfs:comment 'Expected or actual end-of-life treatment method for the packaging material (recycled, composted, landfill, incinerated, reused, returned).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Disclosure Flag' ;
    rdfs:comment 'Indicates whether this packaging record is included in external ESG disclosure reporting (True) or internal tracking only (False).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fscCertificationCode rdf:type rdf:Property ;
    rdfs:label 'Fsc Certification Code' ;
    rdfs:comment 'FSC certification code for forest-based packaging materials, ensuring responsible forest management.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost' ;
    rdfs:comment 'Total cost of the sustainable packaging material for this shipment or order batch.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingDate rdf:type rdf:Property ;
    rdfs:label 'Packaging Date' ;
    rdfs:comment 'Date when the packaging was applied to the shipment or order batch.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packagingLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Packaging Lifecycle Stage' ;
    rdfs:comment 'Current lifecycle stage of the packaging material being tracked (production, distribution, use, end-of-life, recycling, disposal).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterialType rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Type' ;
    rdfs:comment 'Type of sustainable packaging material used (e.g., recycled cardboard, biodegradable filler, reusable container, plastic-free). [ENUM-REF-CANDIDATE: recycled_cardboard|biodegradable_filler|reusable_container|plastic_free|compostable|paper_based|plant_based|recycled_plastic|ocean_bound_plastic|mushroom_packaging|seaweed_packaging — promote to reference product]' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingOptimizationScore rdf:type rdf:Property ;
    rdfs:label 'Packaging Optimization Score' ;
    rdfs:comment 'Score representing how efficiently the packaging was optimized for the shipment (0-100), considering material usage, volume efficiency, and sustainability.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingStandardCompliance rdf:type rdf:Property ;
    rdfs:label 'Packaging Standard Compliance' ;
    rdfs:comment 'Certification or standard compliance for the packaging material (e.g., FSC, PEFC, EU Packaging Directive, Cradle to Cradle, BPI Compostable).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packaging Timestamp' ;
    rdfs:comment 'Precise timestamp when the packaging was applied to the shipment or order batch.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Packaging Volume Cbm' ;
    rdfs:comment 'Total volume of packaging material used, measured in cubic meters (CBM).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingWasteGeneratedKg rdf:type rdf:Property ;
    rdfs:label 'Packaging Waste Generated Kg' ;
    rdfs:comment 'Estimated weight of packaging waste generated after product delivery, measured in kilograms.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Packaging Weight Kg' ;
    rdfs:comment 'Total weight of packaging material used for this shipment or order batch, measured in kilograms.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plasticFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Plastic Free Flag' ;
    rdfs:comment 'Indicates whether the packaging is completely free of plastic materials (True) or contains plastic (False).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recycledContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Recycled Content Percentage' ;
    rdfs:comment 'Percentage of recycled material content in the packaging (0-100%).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnReuseRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Return Reuse Rate Percentage' ;
    rdfs:comment 'Percentage of reusable packaging that is successfully returned and reused (0-100%). Applicable only when reusable_packaging_flag is True.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reusablePackagingFlag rdf:type rdf:Property ;
    rdfs:label 'Reusable Packaging Flag' ;
    rdfs:comment 'Indicates whether the packaging is designed for reuse (True) or single-use (False).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewableEnergyCertificateId rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Certificate Id' ;
    rdfs:comment 'Unique identifier for the renewable energy certificate record. Primary key.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdpReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Cdp Reportable Flag' ;
    rdfs:comment 'Boolean flag indicating whether this certificate is eligible for reporting in CDP Climate Change disclosures (True/False).' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:co2eAvoidedTonnes rdf:type rdf:Property ;
    rdfs:label 'Co2e Avoided Tonnes' ;
    rdfs:comment 'Quantity of Scope 2 greenhouse gas emissions avoided (in metric tonnes CO2e) by applying this renewable energy certificate under the market-based method. Calculated as energy_quantity_mwh multiplied by the grid emission factor for the facility location.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerMwh rdf:type rdf:Property ;
    rdfs:label 'Cost Per Mwh' ;
    rdfs:comment 'Unit cost per megawatt-hour (cost_amount divided by energy_quantity_mwh), used for cost benchmarking and procurement analysis.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyQuantityMwh rdf:type rdf:Property ;
    rdfs:label 'Energy Quantity Mwh' ;
    rdfs:comment 'Quantity of renewable electricity covered by this certificate, measured in megawatt-hours (MWh). Typically one certificate represents 1 MWh.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energySource rdf:type rdf:Property ;
    rdfs:label 'Energy Source' ;
    rdfs:comment 'Type of renewable energy source that generated the electricity covered by this certificate: solar, wind, hydro, biomass, geothermal, tidal, or Other. [ENUM-REF-CANDIDATE: solar|wind|hydro|biomass|geothermal|tidal|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Facility Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the facility covered by this certificate (e.g., USA, DEU, CHN). Used for market-based Scope 2 accounting by geography.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCovered rdf:type rdf:Property ;
    rdfs:label 'Facility Covered' ;
    rdfs:comment 'Name or identifier of the Transport Shipping facility (warehouse, office, distribution center, ground operations hub) whose electricity consumption this certificate is applied to.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatingFacilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Generating Facility Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the generating facility is located (e.g., USA, DEU, CHN).' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatingFacilityLocation rdf:type rdf:Property ;
    rdfs:label 'Generating Facility Location' ;
    rdfs:comment 'Geographic location of the generating facility, typically city and state/province or region.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatingFacilityName rdf:type rdf:Property ;
    rdfs:label 'Generating Facility Name' ;
    rdfs:comment 'Name of the renewable energy generating facility or power plant that produced the electricity covered by this certificate.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationEndDate rdf:type rdf:Property ;
    rdfs:label 'Generation End Date' ;
    rdfs:comment 'End date of the generation period covered by this certificate.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generationStartDate rdf:type rdf:Property ;
    rdfs:label 'Generation Start Date' ;
    rdfs:comment 'Start date of the generation period covered by this certificate.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gridEmissionFactorKgCo2ePerMwh rdf:type rdf:Property ;
    rdfs:label 'Grid Emission Factor Kg Co2e Per Mwh' ;
    rdfs:comment 'The location-based grid emission factor (kg CO2e per MWh) for the facility\'s electricity grid, used to calculate the emissions avoided by this certificate.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementDate rdf:type rdf:Property ;
    rdfs:label 'Procurement Date' ;
    rdfs:comment 'Date when the organization procured or purchased this certificate.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procurementMethod rdf:type rdf:Property ;
    rdfs:label 'Procurement Method' ;
    rdfs:comment 'Method by which the certificate was procured: direct_purchase (spot market), PPA (Power Purchase Agreement), unbundled (certificate only), bundled (with electricity delivery), or Other.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:re100EligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Re100 Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this certificate meets RE100 technical criteria for renewable electricity sourcing commitments (True/False).' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySafEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Saf Employee Id' ;
    rdfs:comment 'User identifier of the person or system that created this SAF procurement record.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:storageFacilityId rdf:type rdf:Property ;
    rdfs:label 'Storage Facility Id' ;
    rdfs:comment 'Identifier of the warehouse or storage facility where the SAF is stored after delivery.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:sustainabilityCertificateId rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certificate Id' ;
    rdfs:comment 'Foreign key linking to document.certificate. Business justification: SAF procurement requires sustainability certification documents (CORSIA batch certificates, ISCC EU certification, RSB certification). Real business process: sustainable aviation fuel compliance verif' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certificate .

ind:blendingRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Blending Ratio Percentage' ;
    rdfs:comment 'Percentage of SAF blended with conventional jet fuel for operational use, typically ranging from 0% to 50% per ASTM D7566 specifications.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookAndClaimCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Book And Claim Certificate Reference' ;
    rdfs:comment 'Reference number for the Book-and-Claim certificate associated with this SAF procurement, enabling physical and environmental attribute separation.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScheme rdf:type rdf:Property ;
    rdfs:label 'Certification Scheme' ;
    rdfs:comment 'Sustainability certification scheme under which this SAF is certified. ISCC = International Sustainability and Carbon Certification, RSB = Roundtable on Sustainable Biomaterials, SCS = Scientific Certification Systems, LCFS = Low Carbon Fuel Standard, RED II = Renewable Energy Directive II, RTFO = Renewable Transport Fuel Obligation.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conventionalJetFuelDisplacedLitres rdf:type rdf:Property ;
    rdfs:label 'Conventional Jet Fuel Displaced Litres' ;
    rdfs:comment 'Volume of conventional jet fuel displaced by this SAF procurement, measured in litres. Used for calculating Scope 1 emissions reductions.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corsiaBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Corsia Batch Number' ;
    rdfs:comment 'CORSIA-registered batch identifier for this SAF procurement, used for regulatory reporting and traceability.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Allocation Flag' ;
    rdfs:comment 'Indicates whether this SAF procurement has been allocated to specific customer shipments for customer-facing carbon reporting.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Code' ;
    rdfs:comment 'IATA airport code or facility code where the SAF was delivered (e.g., JFK, LHR, AMS).' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyContentMj rdf:type rdf:Property ;
    rdfs:label 'Energy Content Mj' ;
    rdfs:comment 'Total energy content of the procured SAF measured in megajoules, used for lifecycle emissions intensity calculations.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedstockOrigin rdf:type rdf:Property ;
    rdfs:label 'Feedstock Origin' ;
    rdfs:comment 'Geographic origin or source description of the feedstock used in SAF production (e.g., used cooking oil from Europe, municipal solid waste from USA).' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedstockType rdf:type rdf:Property ;
    rdfs:label 'Feedstock Type' ;
    rdfs:comment 'Type of feedstock and production pathway used to produce the SAF. HEFA = Hydroprocessed Esters and Fatty Acids, ATJ = Alcohol-to-Jet, FT-SPK = Fischer-Tropsch Synthetic Paraffinic Kerosene, SIP = Synthesized Iso-Paraffins, CHJ = Catalytic Hydrothermolysis Jet.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgEmissionsReductionTonnesCo2e rdf:type rdf:Property ;
    rdfs:label 'Ghg Emissions Reduction Tonnes Co2e' ;
    rdfs:comment 'Total GHG emissions reduction achieved by this SAF procurement compared to conventional jet fuel baseline, measured in tonnes of CO2 equivalent.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intendedUse rdf:type rdf:Property ;
    rdfs:label 'Intended Use' ;
    rdfs:comment 'Intended use case for the procured SAF: operational blending for direct use in aircraft, book-and-claim for environmental attribute transfer, carbon offset programs, or research and development.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleGhgIntensityGco2ePerMj rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Ghg Intensity Gco2e Per Mj' ;
    rdfs:comment 'Lifecycle greenhouse gas emissions intensity of the SAF, measured in grams of CO2 equivalent per megajoule of energy. This value includes well-to-wake emissions and is used to calculate emissions reductions versus conventional jet fuel.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Procurement Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this SAF procurement transaction, used for supplier coordination and audit trails.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementStatus rdf:type rdf:Property ;
    rdfs:label 'Procurement Status' ;
    rdfs:comment 'Current lifecycle status of the SAF procurement transaction. [ENUM-REF-CANDIDATE: draft|confirmed|in_transit|delivered|invoiced|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Saf Volume Gallons' ;
    rdfs:comment 'Total volume of SAF procured in this transaction, measured in US gallons, for regions using imperial units.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safVolumeLitres rdf:type rdf:Property ;
    rdfs:label 'Saf Volume Litres' ;
    rdfs:comment 'Total volume of SAF procured in this transaction, measured in litres.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityReportFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Report Flag' ;
    rdfs:comment 'Indicates whether this SAF procurement has been included in external sustainability or ESG reporting disclosures.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitPricePerLitre rdf:type rdf:Property ;
    rdfs:label 'Unit Price Per Litre' ;
    rdfs:comment 'Price per litre of SAF in the procurement transaction currency.' ;
    rdfs:domain ind:SafProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethodologyVersion rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology Version' ;
    rdfs:comment 'Version identifier of the carbon footprint calculation methodology applied (e.g., GLEC v3.0, ISO 14083:2023). Ensures auditability and comparability over time.' ;
    rdfs:domain ind:ShipmentCarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationNotes rdf:type rdf:Property ;
    rdfs:label 'Calculation Notes' ;
    rdfs:comment 'Free-text notes documenting assumptions, exceptions, or special considerations applied during carbon footprint calculation.' ;
    rdfs:domain ind:ShipmentCarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationRunCode rdf:type rdf:Property ;
    rdfs:label 'Calculation Run Code' ;
    rdfs:comment 'Reference to the batch calculation run that produced this carbon footprint record. Enables traceability and reprocessing.' ;
    rdfs:domain ind:ShipmentCarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbonOffsetKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Kg' ;
    rdfs:comment 'Amount of CO2e emissions offset through carbon offset programs (e.g., reforestation, renewable energy credits) in kilograms.' ;
    rdfs:domain ind:ShipmentCarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityTier rdf:type rdf:Property ;
    rdfs:label 'Data Quality Tier' ;
    rdfs:comment 'Quality tier of the carbon footprint data: measured (primary data from actual fuel consumption), modeled (activity-based with specific factors), or default (industry average factors).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsFactorCo2ePerTonneKm rdf:type rdf:Property ;
    rdfs:label 'Emissions Factor Co2e Per Tonne Km' ;
    rdfs:comment 'Carbon dioxide equivalent emissions factor applied, expressed as kg CO2e per tonne-km. Sourced from GLEC, DEFRA, or carrier-specific data.' ;
    rdfs:domain ind:ShipmentCarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionsFactorSource rdf:type rdf:Property ;
    rdfs:label 'Emissions Factor Source' ;
    rdfs:comment 'Source of the emissions factor used: GLEC default, DEFRA, carrier-specific data, EPA, or custom calculation.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenLogisticsSlaFlag rdf:type rdf:Property ;
    rdfs:label 'Green Logistics Sla Flag' ;
    rdfs:comment 'Indicates whether this shipment is subject to a green logistics SLA commitment with the customer (True/False).' ;
    rdfs:domain ind:ShipmentCarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program' ;
    rdfs:comment 'Applicable regulatory carbon program for this shipment leg: EU ETS (Emissions Trading System), CORSIA (Carbon Offsetting and Reduction Scheme for International Aviation), or none.' ;
    rdfs:domain ind:ShipmentCarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tonneKm rdf:type rdf:Property ;
    rdfs:label 'Tonne Km' ;
    rdfs:comment 'Product of chargeable weight (in tonnes) and distance (in km). Core metric for transport work and emissions calculation.' ;
    rdfs:domain ind:ShipmentCarbonFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationCertificateId rdf:type rdf:Property ;
    rdfs:label 'Verification Certificate Id' ;
    rdfs:comment 'Foreign key linking to document.certificate. Business justification: Supplier emissions disclosures require third-party verification certificates for CDP reporting and supply chain emissions assurance. Real business process: Scope 3 Category 4 (upstream transportation)' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certificate .

ind:alternativeFuelUsagePercentage rdf:type rdf:Property ;
    rdfs:label 'Alternative Fuel Usage Percentage' ;
    rdfs:comment 'Percentage of the suppliers fleet or operations using alternative fuels (biofuels, electric, hydrogen, etc.) during the reporting period.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationApproach rdf:type rdf:Property ;
    rdfs:label 'Calculation Approach' ;
    rdfs:comment 'Approach used by the supplier to calculate emissions (fuel-based, distance-based, spend-based, activity-based, or hybrid).' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdpDisclosureYear rdf:type rdf:Property ;
    rdfs:label 'Cdp Disclosure Year' ;
    rdfs:comment 'Year of the CDP disclosure corresponding to the CDP score.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdpScore rdf:type rdf:Property ;
    rdfs:label 'Cdp Score' ;
    rdfs:comment 'The suppliers most recent Carbon Disclosure Project (CDP) climate change score, indicating their level of environmental disclosure and performance. [ENUM-REF-CANDIDATE: A|A-|B|B-|C|C-|D|D-|F — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCompletenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Data Completeness Percentage' ;
    rdfs:comment 'Percentage of the suppliers operations covered by the disclosed emissions data, indicating the completeness of the disclosure.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disclosureCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Disclosure Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for any financial data included in the disclosure (e.g., carbon pricing, offset costs).' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Disclosure Document Url' ;
    rdfs:comment 'URL or file path to the suppliers full emissions disclosure document or report.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureMethodology rdf:type rdf:Property ;
    rdfs:label 'Disclosure Methodology' ;
    rdfs:comment 'Methodology or framework used by the supplier to calculate and report greenhouse gas emissions.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Submission Date' ;
    rdfs:comment 'Date when the supplier submitted the emissions disclosure to Transport Shipping.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emissionsIntensityGco2ePerShipment rdf:type rdf:Property ;
    rdfs:label 'Emissions Intensity Gco2e Per Shipment' ;
    rdfs:comment 'Emissions intensity metric expressed as grams of carbon dioxide equivalent per shipment, representing the average carbon footprint per shipment handled by the supplier.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euEtsParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Ets Participant Flag' ;
    rdfs:comment 'Flag indicating whether the supplier participates in the European Union Emissions Trading System (EU ETS).' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or identifier of the Transport Shipping sustainability team member who reviewed the disclosure.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbtiCommitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Sbti Commitment Status' ;
    rdfs:comment 'Status of the suppliers commitment to the Science Based Targets initiative (SBTi), indicating whether they have committed to, set, or had science-based emissions reduction targets approved.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbtiTargetYear rdf:type rdf:Property ;
    rdfs:label 'Sbti Target Year' ;
    rdfs:comment 'Target year by which the supplier has committed to achieve their science-based emissions reduction targets.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scope3Category4ApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 4 Applicable Flag' ;
    rdfs:comment 'Flag indicating whether this disclosure is applicable to Scope 3 Category 4 (upstream transportation and distribution) emissions accounting for Transport Shipping.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope3Category9ApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 9 Applicable Flag' ;
    rdfs:comment 'Flag indicating whether this disclosure is applicable to Scope 3 Category 9 (downstream transportation and distribution) emissions accounting for Transport Shipping.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope3EmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Emissions Tco2e' ;
    rdfs:comment 'Total Scope 3 other indirect greenhouse gas emissions disclosed by the supplier in tonnes of carbon dioxide equivalent (tCO2e) for the reporting period.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierSustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Supplier Sustainability Rating' ;
    rdfs:comment 'Internal sustainability rating assigned to the supplier based on their emissions disclosure and overall environmental performance.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFreightVolumeTonneKm rdf:type rdf:Property ;
    rdfs:label 'Total Freight Volume Tonne Km' ;
    rdfs:comment 'Total freight volume transported by the supplier during the reporting period, measured in tonne-kilometers.' ;
    rdfs:domain ind:SupplierEmissionsDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCo2eReductionTco2ePerYear rdf:type rdf:Property ;
    rdfs:label 'Actual Co2e Reduction Tco2e Per Year' ;
    rdfs:comment 'Measured annual reduction in greenhouse gas emissions in metric tonnes of CO2 equivalent (tCO2e) achieved by the initiative based on actual performance data. Null if initiative has not yet delivered measurable reductions.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineCo2eEmissionsTco2ePerYear rdf:type rdf:Property ;
    rdfs:label 'Baseline Co2e Emissions Tco2e Per Year' ;
    rdfs:comment 'Baseline annual GHG emissions in metric tonnes of CO2 equivalent (tCO2e) measured before the initiative was implemented, used as the reference point for calculating emission reductions.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineMeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Measurement Date' ;
    rdfs:comment 'Date when the baseline environmental performance measurement was taken, against which the initiative\'s impact will be compared.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capexInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Capex Investment Amount' ;
    rdfs:comment 'Total capital expenditure investment allocated or spent on the sustainability initiative, including costs for equipment, infrastructure, and long-term assets.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corporateSustainabilityTargetAlignment rdf:type rdf:Property ;
    rdfs:label 'Corporate Sustainability Target Alignment' ;
    rdfs:comment 'Description of how this initiative aligns with and contributes to the organization\'s corporate sustainability targets, such as net-zero commitments, Science Based Targets initiative (SBTi) goals, or specific ESG objectives.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Completion Date' ;
    rdfs:comment 'Planned or forecasted date by which the sustainability initiative is expected to be fully implemented and operational.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalCertificationTarget rdf:type rdf:Property ;
    rdfs:label 'External Certification Target' ;
    rdfs:comment 'Name of external certification, accreditation, or recognition program that this initiative aims to achieve (e.g., ISO 14001, LEED certification, Carbon Neutral certification, EcoVadis rating).' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeCategory rdf:type rdf:Property ;
    rdfs:label 'Initiative Category' ;
    rdfs:comment 'Classification of the sustainability initiative type: fleet electrification (transition to electric vehicles), route optimisation (fuel-efficient routing), packaging reduction (waste minimization), modal shift (air to ocean/rail), SAF adoption (Sustainable Aviation Fuel), or solar installation (renewable energy infrastructure).' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeCode rdf:type rdf:Property ;
    rdfs:label 'Initiative Code' ;
    rdfs:comment 'Externally-known unique business identifier for the sustainability initiative, used for tracking and reporting across systems.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeDescription rdf:type rdf:Property ;
    rdfs:label 'Initiative Description' ;
    rdfs:comment 'Detailed narrative description of the sustainability initiative, including objectives, scope, implementation approach, and expected environmental benefits.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeName rdf:type rdf:Property ;
    rdfs:label 'Initiative Name' ;
    rdfs:comment 'Human-readable name of the sustainability initiative describing the green logistics project or decarbonisation effort.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeStatus rdf:type rdf:Property ;
    rdfs:label 'Initiative Status' ;
    rdfs:comment 'Current lifecycle status of the sustainability initiative indicating whether it is planned, actively in progress, completed, cancelled, or temporarily on hold.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Investment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the CAPEX and OPEX investment amounts (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyPerformanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicator' ;
    rdfs:comment 'Primary KPI or metric used to measure the success and environmental impact of the sustainability initiative (e.g., tCO2e reduced per year, percentage reduction in fuel consumption, renewable energy percentage).' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opexInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Opex Investment Amount' ;
    rdfs:comment 'Total operating expenditure investment allocated or spent on the sustainability initiative, including recurring costs for operations, maintenance, and program management.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Email address of the initiative owner for communication and coordination purposes.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Name of the individual or role responsible for leading and managing the sustainability initiative.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedCo2eReductionTco2ePerYear rdf:type rdf:Property ;
    rdfs:label 'Projected Co2e Reduction Tco2e Per Year' ;
    rdfs:comment 'Estimated annual reduction in greenhouse gas emissions measured in metric tonnes of CO2 equivalent (tCO2e) that the initiative is projected to achieve once fully implemented.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceDriver rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Driver' ;
    rdfs:comment 'Specific regulatory requirement, compliance framework, or environmental legislation that drives or mandates this sustainability initiative (e.g., EU ETS, CORSIA, national carbon tax, local emissions standards).' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Summary of key risks, challenges, and mitigation strategies associated with the implementation and success of the sustainability initiative.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiPaybackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Roi Payback Period Months' ;
    rdfs:comment 'Estimated or actual payback period in months for the sustainability initiative investment, calculated based on cost savings and financial benefits.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scope1ImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Scope 1 Impact Flag' ;
    rdfs:comment 'Indicates whether this initiative directly impacts Scope 1 emissions (direct GHG emissions from owned or controlled sources such as company-owned vehicles and facilities).' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope2ImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Impact Flag' ;
    rdfs:comment 'Indicates whether this initiative directly impacts Scope 2 emissions (indirect GHG emissions from purchased electricity, steam, heating, and cooling).' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope3ImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Impact Flag' ;
    rdfs:comment 'Indicates whether this initiative directly impacts Scope 3 emissions (all other indirect GHG emissions in the value chain, including upstream and downstream activities).' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsoringBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Business Unit' ;
    rdfs:comment 'Name or code of the business unit, division, or department that sponsors and owns this sustainability initiative (e.g., Express Parcel Delivery, Freight Forwarding, Warehouse Operations).' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the sustainability initiative officially commenced or is planned to commence.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineRecalculationPolicy rdf:type rdf:Property ;
    rdfs:label 'Baseline Recalculation Policy' ;
    rdfs:comment 'Policy for recalculating the baseline in response to structural changes such as mergers, acquisitions, divestitures, or changes in calculation methodology (e.g., \'Baseline will be recalculated if structural changes result in a change of more than 5% in baseline emissions\', \'No recalculation policy - baseline is fixed\').' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryDefinition rdf:type rdf:Property ;
    rdfs:label 'Boundary Definition' ;
    rdfs:comment 'Description of the organizational and operational boundaries included in the target (e.g., \'All wholly-owned subsidiaries and operations where Transport Shipping has operational control\', \'Excludes joint ventures and franchises\'). Defines what is in and out of scope.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentValue rdf:type rdf:Property ;
    rdfs:label 'Current Value' ;
    rdfs:comment 'The most recent actual measurement value for tracking progress against the target (e.g., current year emissions, current renewable energy percentage). Updated periodically as new data becomes available.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentValueYear rdf:type rdf:Property ;
    rdfs:label 'Current Value Year' ;
    rdfs:comment 'The year to which the current_value corresponds (e.g., 2023). Indicates the reporting period of the most recent progress measurement.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disclosureChannel rdf:type rdf:Property ;
    rdfs:label 'Disclosure Channel' ;
    rdfs:comment 'The channel or platform through which the target was publicly disclosed (e.g., \'Annual Sustainability Report\', \'CDP Climate Change Response\', \'Investor Presentation\', \'Press Release\', \'Corporate Website\'). Null if not publicly disclosed.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'Date on which the target was first publicly disclosed. Null if not publicly disclosed or if public_disclosure_flag is False.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingFramework rdf:type rdf:Property ;
    rdfs:label 'Governing Framework' ;
    rdfs:comment 'The external standard, initiative, or framework under which this target is set and reported. SBTi (Science Based Targets initiative) for science-based targets; CDP for Carbon Disclosure Project reporting; GHG Protocol for GHG Protocol-aligned targets; ISO 14064 for ISO GHG accounting standard; EU ETS for European Union Emissions Trading System; CORSIA for Carbon Offsetting and Reduction Scheme for International Aviation; TCFD for Task Force on Climate-related Financial Disclosures; GRI for Global Reporting Initiative; SASB for Sustainability Accounting Standards Board; internal for company-defined targets not aligned to external framework. [ENUM-REF-CANDIDATE: sbti|cdp|ghg_protocol|iso_14064|eu_ets|corsia|tcfd|gri|sasb|internal — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Interim Milestone Value' ;
    rdfs:comment 'The quantitative value to be achieved by the interim milestone year. Null if no interim milestones are defined.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interimMilestoneYear rdf:type rdf:Property ;
    rdfs:label 'Interim Milestone Year' ;
    rdfs:comment 'Optional interim year for progress checkpoints between baseline and target year (e.g., 2025 as a milestone toward a 2030 target). Null if no interim milestones are defined.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedIncentiveFlag rdf:type rdf:Property ;
    rdfs:label 'Linked Incentive Flag' ;
    rdfs:comment 'Indicates whether achievement of this target is linked to executive compensation, employee bonuses, or other financial incentives. True if linked to incentives; False if not.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'The calculation methodology or approach used to set the target (e.g., \'Absolute Contraction Approach\', \'Sectoral Decarbonization Approach (SDA)\', \'Economic Intensity Approach\'). Describes how the target value was determined.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsettingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Offsetting Allowed Flag' ;
    rdfs:comment 'Indicates whether carbon offsets or credits are permitted to count toward achieving this target. True if offsets are allowed; False if target must be met through direct emissions reductions only.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsettingLimitPercentage rdf:type rdf:Property ;
    rdfs:label 'Offsetting Limit Percentage' ;
    rdfs:comment 'If offsetting_allowed_flag is True, this field specifies the maximum percentage of the target that can be met through offsets (e.g., 10.00 means up to 10% of reductions can come from offsets). Null if offsets are not allowed or no limit is defined.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Version number of this record, incremented with each update. Supports change tracking and audit trail.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Reduction Percentage' ;
    rdfs:comment 'The percentage reduction from baseline to target (e.g., 50.00 for 50% reduction, 30.00 for 30% reduction). Calculated as ((baseline_value - target_value) / baseline_value) * 100. Null for non-reduction targets.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewableEnergySourceTypes rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Source Types' ;
    rdfs:comment 'For renewable energy targets, specifies the types of renewable energy sources that count toward the target (e.g., \'Solar, Wind, Hydro\', \'All renewable sources per RE100 criteria\'). Null for non-renewable-energy targets.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbtiValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Sbti Validation Status' ;
    rdfs:comment 'If governing_framework is SBTi, this field tracks the validation status with the Science Based Targets initiative. Not_submitted targets have not been submitted for validation; submitted targets are under review; validated targets have been approved by SBTi; rejected targets did not meet SBTi criteria; expired targets have passed their validation period. Null for non-SBTi targets.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeCoverage rdf:type rdf:Property ;
    rdfs:label 'Scope Coverage' ;
    rdfs:comment 'The GHG Protocol scopes covered by this target. Scope 1 covers direct emissions from owned or controlled sources; Scope 2 covers indirect emissions from purchased electricity, steam, heating, and cooling; Scope 3 covers all other indirect emissions in the value chain; scope_1_2 covers both Scope 1 and 2; scope_1_2_3 covers all three scopes; scope_3_category_specific targets a specific Scope 3 category (e.g., upstream transportation, downstream transportation).' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Unique business identifier or code for the target used in reporting and tracking systems (e.g., \'TGT-2030-SCOPE12\', \'RE-2025\').' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDescription rdf:type rdf:Property ;
    rdfs:label 'Target Description' ;
    rdfs:comment 'Detailed narrative description of the target, including context, rationale, methodology, and any specific conditions or assumptions (e.g., \'Reduce absolute Scope 1 and 2 GHG emissions by 50% from 2019 baseline by 2030, aligned with 1.5°C pathway. Baseline recalculated to account for acquisitions and divestitures using the GHG Protocol guidance.\').' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable name or title of the sustainability target (e.g., \'Net Zero by 2050\', \'Scope 1+2 Reduction 2030\', \'Renewable Energy 50% by 2025\').' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle status of the sustainability target. Draft targets are under development; approved targets have been formally endorsed; active targets are in progress; on_track targets are progressing as planned; at_risk targets are behind schedule; achieved targets have been met; expired targets have passed their target year without achievement; cancelled targets have been withdrawn. [ENUM-REF-CANDIDATE: draft|approved|active|on_track|at_risk|achieved|expired|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Classification of the sustainability target type. Absolute emissions reduction targets reduce total emissions; intensity reduction targets reduce emissions per unit of activity; renewable energy percentage targets increase share of renewable energy; net-zero pledge commits to net-zero emissions by target year; SBTi-aligned targets meet Science Based Targets initiative criteria; carbon neutral targets achieve carbon neutrality through reduction and offsetting.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'The year by which the target is to be achieved (e.g., 2030, 2040, 2050). This is the deadline for meeting the commitment.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWasteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Employee Id' ;
    rdfs:comment 'Identifier of the user who created the waste record.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWasteApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Waste Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the waste record.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Free-text notes for audit purposes, capturing any exceptions, issues, or additional context related to the waste record.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Percent' ;
    rdfs:comment 'Percentage of waste diverted from landfill through recycling, composting, or reuse. Key metric for zero-waste-to-landfill targets.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Category' ;
    rdfs:comment 'ESG reporting category to which this waste record contributes (environmental, social, governance). Primarily environmental for waste management.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgEmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Ghg Emissions Tco2e' ;
    rdfs:comment 'Greenhouse gas emissions associated with the waste disposal method, measured in tonnes of carbon dioxide equivalent (tCO2e). Used for ESG reporting and carbon footprint calculations.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification Code' ;
    rdfs:comment 'Regulatory classification code for the waste type, such as IMDG (International Maritime Dangerous Goods) hazardous waste codes or local waste classification codes.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Certificate Number' ;
    rdfs:comment 'Certificate or consignment note number issued by the waste contractor as proof of proper disposal, required for regulatory compliance and audit trails.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteContractorName rdf:type rdf:Property ;
    rdfs:label 'Waste Contractor Name' ;
    rdfs:comment 'Name of the waste management contractor responsible for handling the waste stream.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDescription rdf:type rdf:Property ;
    rdfs:label 'Waste Description' ;
    rdfs:comment 'Detailed description of the waste material, including composition, contamination level, and any special handling requirements.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Waste Quantity' ;
    rdfs:comment 'Quantity of waste generated during the reporting period, measured in the unit specified by waste_quantity_unit.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Waste Quantity Unit' ;
    rdfs:comment 'Unit of measure for the waste quantity (e.g., kg, tonnes, cubic meters, liters).' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Record Number' ;
    rdfs:comment 'Business identifier for the waste record, used for tracking and audit purposes.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteSourceArea rdf:type rdf:Property ;
    rdfs:label 'Waste Source Area' ;
    rdfs:comment 'Specific area or department within the facility where the waste was generated (e.g., warehouse floor, office, cafeteria, loading dock, maintenance shop).' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamType rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Type' ;
    rdfs:comment 'Classification of the waste stream generated (e.g., cardboard, plastic, hazardous, e-waste, food, general waste).' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroWasteTargetContribution rdf:type rdf:Property ;
    rdfs:label 'Zero Waste Target Contribution' ;
    rdfs:comment 'Flag indicating whether this waste record contributes positively toward the organization\'s zero-waste-to-landfill target (True/False).' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterConsumptionRecordId rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Record Id' ;
    rdfs:comment 'Unique identifier for the water consumption record.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dischargeDestinationType rdf:type rdf:Property ;
    rdfs:label 'Discharge Destination Type' ;
    rdfs:comment 'Type of destination where treated or untreated wastewater is discharged.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeWaterQualityStandard rdf:type rdf:Property ;
    rdfs:label 'Discharge Water Quality Standard' ;
    rdfs:comment 'Water quality standard or regulatory threshold applied to discharged water (e.g., EPA effluent guidelines, local environmental authority standards).' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Flag' ;
    rdfs:comment 'Indicates whether this water consumption record is included in external ESG or sustainability reporting disclosures.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityRegion rdf:type rdf:Property ;
    rdfs:label 'Facility Region' ;
    rdfs:comment 'Geographic region or state/province where the facility is located.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gri303DisclosureCategory rdf:type rdf:Property ;
    rdfs:label 'Gri 303 Disclosure Category' ;
    rdfs:comment 'GRI 303 disclosure category that this water consumption record supports (303-1 Interactions with water, 303-2 Management approach, 303-3 Withdrawal, 303-4 Discharge, 303-5 Consumption).' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Method used to measure or estimate water consumption (direct metering, engineering calculation, utility invoice, or estimation).' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Incident Count' ;
    rdfs:comment 'Number of regulatory non-compliance incidents related to water use or discharge during the reporting period.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Date' ;
    rdfs:comment 'Expiration date of the water use or discharge permit.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryPermitReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Permit Reference' ;
    rdfs:comment 'Reference number or identifier of the environmental permit or license authorizing water withdrawal and discharge at this facility.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWaterWithdrawnM3 rdf:type rdf:Property ;
    rdfs:label 'Total Water Withdrawn M3' ;
    rdfs:comment 'Total volume of water withdrawn from all sources during the reporting period, measured in cubic meters.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wastewaterTreatmentMethod rdf:type rdf:Property ;
    rdfs:label 'Wastewater Treatment Method' ;
    rdfs:comment 'Method used to treat wastewater before discharge. Indicates whether treatment is performed on-site, by municipal systems, or by third-party providers.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterConsumedM3 rdf:type rdf:Property ;
    rdfs:label 'Water Consumed M3' ;
    rdfs:comment 'Net water consumption calculated as total withdrawn minus discharged and recycled, measured in cubic meters. Represents water that is evaporated, incorporated into products, or otherwise not returned to the source.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterCostAmount rdf:type rdf:Property ;
    rdfs:label 'Water Cost Amount' ;
    rdfs:comment 'Total cost of water consumed during the reporting period, including supply charges, wastewater treatment fees, and discharge fees.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Water Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for water cost amount.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterDischargedM3 rdf:type rdf:Property ;
    rdfs:label 'Water Discharged M3' ;
    rdfs:comment 'Total volume of water discharged from the facility during the reporting period, measured in cubic meters.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterIntensityPerEmployee rdf:type rdf:Property ;
    rdfs:label 'Water Intensity Per Employee' ;
    rdfs:comment 'Water consumption intensity normalized by number of employees, measured in cubic meters per Full-Time Equivalent (FTE). Supports operational efficiency analysis.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterIntensityPerSqm rdf:type rdf:Property ;
    rdfs:label 'Water Intensity Per Sqm' ;
    rdfs:comment 'Water consumption intensity normalized by facility floor area, measured in cubic meters per square meter. Supports benchmarking and efficiency tracking.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterRecycledM3 rdf:type rdf:Property ;
    rdfs:label 'Water Recycled M3' ;
    rdfs:comment 'Volume of water recycled or reused within the facility during the reporting period, measured in cubic meters.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterSourceType rdf:type rdf:Property ;
    rdfs:label 'Water Source Type' ;
    rdfs:comment 'Type of water source from which water is withdrawn. Categories align with GRI 303 disclosure requirements.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterStewardshipProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Water Stewardship Program Flag' ;
    rdfs:comment 'Indicates whether the facility participates in a formal water stewardship or conservation program (e.g., Alliance for Water Stewardship certification).' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterStressAreaFlag rdf:type rdf:Property ;
    rdfs:label 'Water Stress Area Flag' ;
    rdfs:comment 'Indicates whether the facility is located in a water-stressed area based on World Resources Institute (WRI) Aqueduct tool classification.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterStressLevel rdf:type rdf:Property ;
    rdfs:label 'Water Stress Level' ;
    rdfs:comment 'Classification of water stress level at the facility location based on WRI Aqueduct baseline water stress indicator.' ;
    rdfs:domain ind:WaterConsumptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseAsnId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Asn Id' ;
    rdfs:comment 'Unique identifier for the advanced shipping notice record. Primary key.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseAsn .

ind:destinationFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Id' ;
    rdfs:comment 'Identifier of the receiving warehouse or distribution center where the ASN shipment will arrive.' ;
    rdfs:domain ind:WarehouseAsn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Master or house bill of lading number associated with this ASN. Links to freight documentation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorAssignment rdf:type rdf:Property ;
    rdfs:label 'Dock Door Assignment' ;
    rdfs:comment 'Specific receiving dock door assigned for unloading this ASN shipment. Supports yard management and labor dispatch.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionReference rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Reference' ;
    rdfs:comment 'Unique identifier for the EDI 856 (ASN) transmission that created this record. Used for EDI audit trail and troubleshooting.' ;
    rdfs:domain ind:WarehouseAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Time' ;
    rdfs:comment 'Precise timestamp when the shipment is expected to arrive at the destination facility. Enables detailed dock appointment scheduling.' ;
    rdfs:domain ind:WarehouseAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedCartonCount rdf:type rdf:Property ;
    rdfs:label 'Received Carton Count' ;
    rdfs:comment 'Actual number of cartons received and verified at the destination facility. Used for variance analysis against expected count.' ;
    rdfs:domain ind:WarehouseAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedPalletCount rdf:type rdf:Property ;
    rdfs:label 'Received Pallet Count' ;
    rdfs:comment 'Actual number of pallets received and verified at the destination facility. Used for variance analysis against expected count.' ;
    rdfs:domain ind:WarehouseAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingNotes rdf:type rdf:Property ;
    rdfs:label 'Receiving Notes' ;
    rdfs:comment 'Free-text notes captured by receiving personnel during the unloading and inspection process. Documents exceptions or observations.' ;
    rdfs:domain ind:WarehouseAsn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentPriority rdf:type rdf:Property ;
    rdfs:label 'Shipment Priority' ;
    rdfs:comment 'Priority level assigned to this inbound shipment. Determines receiving dock scheduling sequence and resource allocation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCartonCount rdf:type rdf:Property ;
    rdfs:label 'Total Carton Count' ;
    rdfs:comment 'Total number of cartons or boxes included in this ASN shipment. Used for receiving verification and labor planning.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLineCount rdf:type rdf:Property ;
    rdfs:label 'Total Line Count' ;
    rdfs:comment 'Total number of distinct SKU line items included in this ASN. Used for receiving complexity assessment.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPalletCount rdf:type rdf:Property ;
    rdfs:label 'Total Pallet Count' ;
    rdfs:comment 'Total number of pallets included in this ASN shipment. Used for dock space allocation and material handling equipment planning.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:asnLineId rdf:type rdf:Property ;
    rdfs:label 'Asn Line Id' ;
    rdfs:comment 'Primary key for asn_line' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AsnLine .

ind:primaryAsnEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Asn Employee Id' ;
    rdfs:comment 'Foreign key reference to the warehouse user or employee who performed the receiving transaction. Used for labor tracking and accountability.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:discrepancyReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason Code' ;
    rdfs:comment 'Code indicating the type of discrepancy between expected and received quantities. Used for root cause analysis and supplier performance tracking.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'The quantity of the SKU expected to be received as declared in the ASN. Used for receiving reconciliation against actual received quantity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Number' ;
    rdfs:comment 'Specific line number on the purchase order that corresponds to this ASN line. Enables line-level reconciliation between PO, ASN, and receipt.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayLocation rdf:type rdf:Property ;
    rdfs:label 'Putaway Location' ;
    rdfs:comment 'Designated storage location (bin, slot, or zone) where the received inventory will be placed. Assigned during receiving or putaway process.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Timestamp' ;
    rdfs:comment 'Date and time when the received inventory was placed into its designated storage location. Marks completion of the inbound process.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Boolean flag indicating whether this line item requires quality inspection before putaway. True if inspection is mandatory, False otherwise.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of quality inspection for this line item. Tracks the inspection lifecycle from pending through final disposition.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for temperature-sensitive products. Used for cold chain compliance monitoring.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for temperature-sensitive products. Used for cold chain compliance monitoring.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the cycle count event. Primary key.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:counterTeamId rdf:type rdf:Property ;
    rdfs:label 'Counter Team Id' ;
    rdfs:comment 'Identifier for the team or crew assigned to perform the physical count. Used for labor productivity tracking.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterTeam .

ind:zoneId rdf:type rdf:Property ;
    rdfs:label 'Zone Id' ;
    rdfs:comment 'Foreign key linking to warehouse.zone. Business justification: cycle_count has zone_code (STRING) indicating which zone is being counted. Adding a proper zone_id FK enables JOIN to zone master for zone details. zone_code removed as it can be retrieved via the FK ' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:accuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percentage' ;
    rdfs:comment 'Inventory accuracy percentage for this count event. Calculated as (locations with zero variance / total locations counted) * 100. Key performance indicator for warehouse operations.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentPosted rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted' ;
    rdfs:comment 'Indicates whether inventory adjustments resulting from count variances have been posted to the WMS and financial systems.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentPostedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Timestamp' ;
    rdfs:comment 'Date and time when inventory adjustments were posted to the system. Used for financial reconciliation and audit trail.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aisleRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Aisle Range End' ;
    rdfs:comment 'Ending aisle identifier for the count scope. Used to define physical location boundaries.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleRangeStart rdf:type rdf:Property ;
    rdfs:label 'Aisle Range Start' ;
    rdfs:comment 'Starting aisle identifier for the count scope. Used to define physical location boundaries.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'Actual date and time when the physical count activity was completed. Marks the end of the count execution window.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Method used to perform the physical count. Manual = paper-based or visual; RFID = radio frequency identification; Barcode Scan = handheld scanner; Automated = robotic or sensor-based.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countProgramCode rdf:type rdf:Property ;
    rdfs:label 'Count Program Code' ;
    rdfs:comment 'Business identifier for the cycle count program or event. Externally-known code used for tracking and reporting.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countProgramName rdf:type rdf:Property ;
    rdfs:label 'Count Program Name' ;
    rdfs:comment 'Human-readable name of the cycle count program or event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countReason rdf:type rdf:Property ;
    rdfs:label 'Count Reason' ;
    rdfs:comment 'Business reason or trigger for the cycle count. Examples: scheduled rotation, exception investigation, audit requirement, pre-physical inventory, post-receiving verification.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Actual date and time when the physical count activity began. Marks the beginning of the count execution window.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count event. Scheduled = planned but not started; In-Progress = counting underway; Completed = count finished awaiting approval; Approved = variances reviewed and accepted; Cancelled = count aborted; On-Hold = temporarily suspended.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the count event. Full = complete facility inventory; Cycle = scheduled rotating count; Spot = ad-hoc targeted count; ABC-Velocity = frequency-based on SKU velocity; Blind = count without system quantity reference; Location-Directed = system-assigned location count.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifoLifoMethod rdf:type rdf:Property ;
    rdfs:label 'Fifo Lifo Method' ;
    rdfs:comment 'Inventory valuation method applied during count variance adjustment. FIFO = First In First Out; LIFO = Last In First Out; FEFO = First Expired First Out; Not Applicable = no specific method.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCountFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Count Flag' ;
    rdfs:comment 'Indicates whether this cycle count includes hazardous materials requiring special handling and compliance procedures.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHoursActual rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Actual' ;
    rdfs:comment 'Actual labor hours spent performing the cycle count. Used for labor productivity analysis and cost allocation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recountCount rdf:type rdf:Property ;
    rdfs:label 'Recount Count' ;
    rdfs:comment 'Number of times this cycle count has been recounted. Used to track count quality and identify problematic locations or SKUs.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequired rdf:type rdf:Property ;
    rdfs:label 'Recount Required' ;
    rdfs:comment 'Indicates whether a recount is required due to significant variances or count discrepancies exceeding tolerance thresholds.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuditFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Audit Flag' ;
    rdfs:comment 'Indicates whether this cycle count is part of a regulatory audit or compliance requirement (e.g., customs bonded warehouse audit, ISO certification audit).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalLocationsCounted rdf:type rdf:Property ;
    rdfs:label 'Total Locations Counted' ;
    rdfs:comment 'Total number of storage locations physically counted during this cycle count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSkusCounted rdf:type rdf:Property ;
    rdfs:label 'Total Skus Counted' ;
    rdfs:comment 'Total number of unique SKUs physically counted during this cycle count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsCounted rdf:type rdf:Property ;
    rdfs:label 'Total Units Counted' ;
    rdfs:comment 'Total quantity of inventory units physically counted across all SKUs and locations.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Percentage' ;
    rdfs:comment 'Acceptable variance threshold percentage for this count event. Variances exceeding this threshold trigger recount or approval workflows.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Variance Value Usd' ;
    rdfs:comment 'Financial value of the inventory variance in USD. Calculated as variance quantity multiplied by unit cost. Used for financial reconciliation and inventory accuracy KPI.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsBatchReference rdf:type rdf:Property ;
    rdfs:label 'Wms Batch Reference' ;
    rdfs:comment 'Batch identifier from the source WMS system. Used for traceability and integration with Manhattan WMS.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountLineId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Line Id' ;
    rdfs:comment 'Unique identifier for the cycle count line record. Primary key.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryMovementId rdf:type rdf:Property ;
    rdfs:label 'Inventory Movement Id' ;
    rdfs:comment 'The unique transaction identifier of the inventory adjustment posting in the WMS. Nullable if adjustment not yet posted.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryMovement .

ind:primaryCycleCounterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cycle Counter Employee Id' ;
    rdfs:comment 'The employee identifier of the warehouse associate who performed the initial count. Links to workforce management system.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Flag' ;
    rdfs:comment 'Indicates whether the inventory adjustment has been posted to the WMS and financial systems. True if posted, False if pending.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'The date and time when the inventory adjustment was posted to the system. Nullable if adjustment not yet posted.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Timestamp' ;
    rdfs:comment 'The date and time when the initial physical count was performed. Business event timestamp for the count activity.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The actual physical quantity counted by the warehouse associate during the cycle count.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryConditionCode rdf:type rdf:Property ;
    rdfs:label 'Inventory Condition Code' ;
    rdfs:comment 'The condition or quality status of the inventory counted. Determines whether inventory is available for sale or fulfillment.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountQuantity rdf:type rdf:Property ;
    rdfs:label 'Recount Quantity' ;
    rdfs:comment 'The quantity recorded during the recount verification. Nullable if no recount was performed.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether this line requires a recount due to variance exceeding threshold or other business rules. True if recount is required, False otherwise.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recount Timestamp' ;
    rdfs:comment 'The date and time when the recount verification was performed. Nullable if no recount was performed.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recountVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Recount Variance Quantity' ;
    rdfs:comment 'The variance between recount quantity and system quantity. Nullable if no recount was performed.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The book stock quantity recorded in the WMS system before the physical count. Also known as expected quantity or on-hand quantity.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Value Amount' ;
    rdfs:comment 'The financial value of the variance, calculated as variance_quantity multiplied by cost_per_unit. Used for financial reporting and variance analysis.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dockAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Dock Appointment Id' ;
    rdfs:comment 'Unique identifier for the dock door appointment record. Primary key for the dock appointment entity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DockAppointment .

ind:outboundShipmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Shipment Order Id' ;
    rdfs:comment 'Foreign key linking to warehouse.outbound_shipment_order. Business justification: Dock appointments for outbound shipments MUST reference the outbound shipment order. Currently dock_appointment has outbound_order_number STRING field but lacks proper FK to outbound_shipment_order.ou' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundShipmentOrder .

ind:primaryDockEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Dock Employee Id' ;
    rdfs:comment 'Reference to the user who cancelled the appointment. Used for audit trail and accountability.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appointmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Appointment Duration Minutes' ;
    rdfs:comment 'Estimated or planned duration of the loading or unloading operation in minutes. Used for dock scheduling optimization and labor allocation.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Date and time when the driver completed check-in procedures at the facility gate or reception desk. Marks the beginning of the appointment lifecycle.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedCartonCount rdf:type rdf:Property ;
    rdfs:label 'Expected Carton Count' ;
    rdfs:comment 'Number of cartons expected to be loaded or unloaded during this appointment. Used for labor planning and throughput estimation.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedPalletCount rdf:type rdf:Property ;
    rdfs:label 'Expected Pallet Count' ;
    rdfs:comment 'Number of pallets expected to be loaded or unloaded during this appointment. Used for labor planning and dock capacity management.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Expected Volume Cbm' ;
    rdfs:comment 'Total expected volume of the shipment in cubic meters. Used for space planning and trailer utilization analysis.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Expected Weight Kg' ;
    rdfs:comment 'Total expected weight of the shipment in kilograms. Used for equipment selection and dock floor load capacity verification.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadingCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loading Complete Timestamp' ;
    rdfs:comment 'Date and time when loading or unloading operations were completed. Used for turnaround time calculation and dock throughput metrics.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loading Start Timestamp' ;
    rdfs:comment 'Date and time when loading or unloading operations actually began at the dock door. Used for measuring dock productivity and dwell time.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:noShowReason rdf:type rdf:Property ;
    rdfs:label 'No Show Reason' ;
    rdfs:comment 'Explanation for why a scheduled appointment was missed by the carrier or driver. Used for carrier performance tracking and root cause analysis.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Number' ;
    rdfs:comment 'Reference to the outbound shipment order or wave being loaded during this appointment. Links dock appointment to order fulfillment operations.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival End' ;
    rdfs:comment 'End of the scheduled arrival time window for the carrier or driver. Represents the latest acceptable arrival time for the appointment without being considered late.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledArrivalStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Start' ;
    rdfs:comment 'Beginning of the scheduled arrival time window for the carrier or driver. Represents the earliest acceptable arrival time for the appointment.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:annualGhgEmissionsCo2eTonnes rdf:type rdf:Property ;
    rdfs:label 'Annual Ghg Emissions Co2e Tonnes' ;
    rdfs:comment 'Total annual greenhouse gas emissions from facility operations measured in tonnes of CO2 equivalent. Used for sustainability reporting and carbon footprint tracking.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsBondedWarehouse rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Warehouse' ;
    rdfs:comment 'Indicates whether the facility is a customs bonded warehouse authorized to store imported goods before duties and taxes are paid.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Dock Door Count' ;
    rdfs:comment 'Total number of loading and unloading dock doors available at the facility for inbound and outbound freight operations.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Human-readable name of the warehouse or distribution center facility.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasColdStorage rdf:type rdf:Property ;
    rdfs:label 'Has Cold Storage' ;
    rdfs:comment 'Indicates whether the facility has refrigerated or frozen storage capabilities for temperature-sensitive goods.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasHazmatStorage rdf:type rdf:Property ;
    rdfs:label 'Has Hazmat Storage' ;
    rdfs:comment 'Indicates whether the facility is certified and equipped to store hazardous materials per IMDG Code and local regulations.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAeoCertified rdf:type rdf:Property ;
    rdfs:label 'Is Aeo Certified' ;
    rdfs:comment 'Indicates whether the facility holds AEO certification for trusted trader status and simplified customs procedures in the EU and partner countries.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCtpatCertified rdf:type rdf:Property ;
    rdfs:label 'Is Ctpat Certified' ;
    rdfs:comment 'Indicates whether the facility holds C-TPAT certification for enhanced supply chain security and expedited customs processing.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIso28000Certified rdf:type rdf:Property ;
    rdfs:label 'Is Iso28000 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 28000 certification for supply chain security management.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Is Iso9001 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 9001 certification for quality management systems.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the current facility lease expires, if applicable. Used for real estate planning and contract renewal tracking.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxDailyInboundVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Max Daily Inbound Volume Units' ;
    rdfs:comment 'Maximum number of units (pallets, cartons, or SKUs) the facility can receive and process in a single day. Used for capacity planning and load balancing.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDailyOutboundVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Max Daily Outbound Volume Units' ;
    rdfs:comment 'Maximum number of units (pallets, cartons, or SKUs) the facility can pick, pack, and ship in a single day. Used for capacity planning and order fulfillment forecasting.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for weekdays in format HH:MM-HH:MM (e.g., 08:00-18:00). Used for scheduling inbound and outbound operations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for weekends in format HH:MM-HH:MM. May be different from weekday hours or closed.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZoneCount rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Count' ;
    rdfs:comment 'Number of distinct temperature-controlled zones within the facility (e.g., ambient, refrigerated, frozen) for specialized inventory storage.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatStorageComplianceId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Storage Compliance Id' ;
    rdfs:comment 'Unique identifier for the hazmat storage compliance record.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentStoredQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Stored Quantity' ;
    rdfs:comment 'Current quantity of this hazmat SKU stored in the facility at the time of compliance assessment.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fireSuppressionSystemType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System Type' ;
    rdfs:comment 'Type of fire suppression system installed in the storage zone (sprinkler, foam, CO2, dry-chemical, none).' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Number of safety incidents or compliance violations recorded for this hazmat storage location.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelingCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Labeling Compliant Flag' ;
    rdfs:comment 'Indicates whether the hazmat labeling on packages and storage locations is compliant with regulatory requirements.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'Date when warehouse personnel last completed hazmat handling and storage training for this material class.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStorageQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Storage Quantity' ;
    rdfs:comment 'Maximum permitted quantity of this hazmat SKU that can be stored in the designated zone, as per regulatory limits.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Training Due Date' ;
    rdfs:comment 'Date when the next mandatory hazmat training is due for personnel handling this material.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceReason rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason' ;
    rdfs:comment 'Detailed explanation of the reason for non-compliance if the status is not compliant.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalProtectiveEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Personal Protective Equipment Required' ;
    rdfs:comment 'Description of the personal protective equipment required when handling this hazmat material.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placardingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Placarding Required Flag' ;
    rdfs:comment 'Indicates whether hazmat placarding is required for this storage location per DOT/IMDG regulations.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyDataSheetReference rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Reference' ;
    rdfs:comment 'Reference number or location of the Safety Data Sheet for this hazmat material.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationRequirement rdf:type rdf:Property ;
    rdfs:label 'Segregation Requirement' ;
    rdfs:comment 'Specific segregation requirement level for this hazmat material as per IMDG Code (away from, separated from, separated by deck, separated longitudinally, or none).' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spillContainmentAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Spill Containment Available Flag' ;
    rdfs:comment 'Indicates whether spill containment equipment and procedures are available for this storage location.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageZoneCode rdf:type rdf:Property ;
    rdfs:label 'Storage Zone Code' ;
    rdfs:comment 'Code identifying the designated hazmat storage zone within the warehouse facility.' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationSystemType rdf:type rdf:Property ;
    rdfs:label 'Ventilation System Type' ;
    rdfs:comment 'Type of ventilation system in the storage zone (natural, mechanical, explosion-proof, none).' ;
    rdfs:domain ind:HazmatStorageCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryInboundEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inbound Employee Id' ;
    rdfs:comment 'Identifier of the warehouse employee who processed the inbound receipt. Used for accountability and labor tracking.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bondedGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Bonded Goods Flag' ;
    rdfs:comment 'Indicates whether goods are under customs bond and require special handling in bonded warehouse area. Critical for customs compliance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossDockFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Flag' ;
    rdfs:comment 'Indicates whether goods are designated for immediate cross-docking to outbound shipment without storage. Enables flow-through distribution.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the type of variance or exception identified during receipt. Used for root cause analysis and supplier performance tracking.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCartonsCount rdf:type rdf:Property ;
    rdfs:label 'Expected Cartons Count' ;
    rdfs:comment 'Number of cartons expected based on the ASN or purchase order. Used to calculate receipt variance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedPalletsCount rdf:type rdf:Property ;
    rdfs:label 'Expected Pallets Count' ;
    rdfs:comment 'Number of pallets expected based on the ASN or purchase order. Used to calculate receipt variance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayPriority rdf:type rdf:Property ;
    rdfs:label 'Putaway Priority' ;
    rdfs:comment 'Priority level assigned for moving received goods from dock to storage location. Determines task sequencing in warehouse operations.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether goods require quality inspection before putaway. Determined by product type, supplier rating, or regulatory requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completed Timestamp' ;
    rdfs:comment 'Date and time when the entire receipt process was finalized, including quality checks and system confirmation. Marks the official completion of the receipt transaction.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known unique business identifier for the inbound receipt transaction. Used for tracking and reference across systems and with external parties.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the security seal was found intact upon arrival. False value triggers security investigation.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicates whether temperature-sensitive goods were received within required temperature range. Critical for cold chain compliance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRecordedC rdf:type rdf:Property ;
    rdfs:label 'Temperature Recorded C' ;
    rdfs:comment 'Actual temperature recorded at time of receipt for temperature-controlled shipments. Used for cold chain validation.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCartonsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Cartons Received' ;
    rdfs:comment 'Total number of cartons or cases physically received in this inbound receipt. Used for variance analysis against ASN.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPalletsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Pallets Received' ;
    rdfs:comment 'Total number of pallets or handling units physically received. Used for space planning and material handling resource allocation.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unloadingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unloading End Timestamp' ;
    rdfs:comment 'Date and time when physical unloading of goods was completed. Used to calculate unloading duration and dock turnaround time.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unloadingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unloading Start Timestamp' ;
    rdfs:comment 'Date and time when physical unloading of goods from the vehicle began. Used for labor productivity and dock utilization analysis.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inboundReceiptLineId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Id' ;
    rdfs:comment 'Unique identifier for the inbound receipt line record. Primary key for this entity.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:palletId rdf:type rdf:Property ;
    rdfs:label 'Pallet Id' ;
    rdfs:comment 'Identifier of the pallet on which the received goods are stored. Used for pallet-level tracking and storage optimization.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pallet .

ind:primaryInboundStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Inbound Storage Location Id' ;
    rdfs:comment 'Reference to the warehouse location where the received goods were stored. Final storage location after putaway completion.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Condition classification of the received inventory. Determines storage location, availability for picking, and valuation. NEW=new goods, USED=returned/used items, REFURBISHED=reconditioned goods, DAMAGED=damaged goods, EXPIRED=past expiry date, QUARANTINE=held for inspection.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedQuantity rdf:type rdf:Property ;
    rdfs:label 'Damaged Quantity' ;
    rdfs:comment 'Quantity of the SKU received in damaged condition. Segregated for disposition decision and potential supplier claim.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lpnNumber rdf:type rdf:Property ;
    rdfs:label 'Lpn Number' ;
    rdfs:comment 'License Plate Number assigned to the physical container or pallet holding the received goods. Used for tracking and putaway task assignment.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Completed Timestamp' ;
    rdfs:comment 'Date and time when putaway was completed and goods were stored in their final warehouse location. Marks inventory availability for picking.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:putawayStatus rdf:type rdf:Property ;
    rdfs:label 'Putaway Status' ;
    rdfs:comment 'Status of the putaway process for this receipt line. NOT_STARTED=received but not yet assigned to putaway task, IN_PROGRESS=putaway task active, COMPLETED=goods stored in final location, EXCEPTION=putaway blocked or failed.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Total volume or cubic measurement of the goods received on this line. Used for warehouse space planning and slotting optimization.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Total weight of the goods received on this line. Used for freight reconciliation, capacity planning, and handling equipment selection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Identifier of the material handling equipment used for the movement (forklift, pallet jack, conveyor, automated storage/retrieval system). Supports equipment utilization analysis.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:reversedMovementInventoryMovementId rdf:type rdf:Property ;
    rdfs:label 'Reversed Movement Inventory Movement Id' ;
    rdfs:comment 'Reference to the original inventory movement transaction that this record reverses. Null if this is not a reversal transaction.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryMovement .

ind:taskId rdf:type rdf:Property ;
    rdfs:label 'Task Id' ;
    rdfs:comment 'Identifier of the warehouse task or work assignment that generated this movement. Links to labor management and task optimization systems.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickTask .

ind:bondedStatus rdf:type rdf:Property ;
    rdfs:label 'Bonded Status' ;
    rdfs:comment 'Customs bonded warehouse status of the inventory. Indicates whether goods are held in a Free Trade Zone (FTZ) or bonded warehouse pending customs clearance.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromLocationCode rdf:type rdf:Property ;
    rdfs:label 'From Location Code' ;
    rdfs:comment 'Source warehouse location code from which inventory is being moved. Null for receipt transactions. Supports multi-level location hierarchy (zone-aisle-bay-level-position).' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Number' ;
    rdfs:comment 'Externally-visible business identifier for the inventory movement transaction. Used for audit trail and cross-system reconciliation.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the inventory movement transaction. Tracks progression from initiation through completion or cancellation.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Date and time when the physical inventory movement occurred. Principal business event timestamp for FIFO/LIFO position calculation and audit trail.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the inventory movement transaction. Defines the nature of the stock movement within or between warehouse locations. [ENUM-REF-CANDIDATE: receipt|putaway|pick|replenishment|transfer|adjustment|cycle_count|damage_writeoff|return|consolidation|deconsolidation — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityMoved rdf:type rdf:Property ;
    rdfs:label 'Quantity Moved' ;
    rdfs:comment 'Quantity of inventory units moved in this transaction. Positive for additions, negative for reductions. Supports fractional quantities for catch-weight items.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceLineNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Line Number' ;
    rdfs:comment 'Line item number within the reference document. Links movement to specific order line or ASN line for detailed reconciliation.' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum acceptable storage temperature in Celsius for temperature-sensitive inventory. Used for cold chain compliance monitoring.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum acceptable storage temperature in Celsius for temperature-sensitive inventory. Used for cold chain compliance monitoring.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toLocationCode rdf:type rdf:Property ;
    rdfs:label 'To Location Code' ;
    rdfs:comment 'Destination warehouse location code to which inventory is being moved. Null for shipment/dispatch transactions. Supports multi-level location hierarchy (zone-aisle-bay-level-position).' ;
    rdfs:domain ind:InventoryMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPositionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Id' ;
    rdfs:comment 'Unique identifier for the inventory position record. Primary key for this entity.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Quantity available for allocation to new orders. Calculated as on-hand minus reserved, quarantine, hold, damaged, and expired quantities.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fifoSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fifo Sequence Number' ;
    rdfs:comment 'Sequential number assigned based on receipt date to enforce FIFO picking logic. Lower numbers are picked first to ensure oldest inventory is consumed before newer stock.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdQuantity rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity' ;
    rdfs:comment 'Quantity placed on administrative hold due to customer disputes, regulatory issues, or business decisions. Not available for allocation.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity currently being moved within the facility between storage locations. Temporarily unavailable during putaway or replenishment operations.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifoSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Lifo Sequence Number' ;
    rdfs:comment 'Sequential number assigned based on receipt date to enforce LIFO picking logic. Higher numbers are picked first to ensure newest inventory is consumed before older stock.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'Total physical quantity of the SKU present at the storage location, regardless of availability status. Includes available, reserved, quarantine, hold, and damaged quantities.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickFaceIndicator rdf:type rdf:Property ;
    rdfs:label 'Pick Face Indicator' ;
    rdfs:comment 'Flag indicating whether this inventory position is in an active pick face location (forward pick area) versus reserve storage. Pick face locations are optimized for high-velocity picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:putawayZone rdf:type rdf:Property ;
    rdfs:label 'Putaway Zone' ;
    rdfs:comment 'Warehouse zone designation where the inventory was placed during putaway operations. Used for slotting optimization and pick path planning.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineQuantity rdf:type rdf:Property ;
    rdfs:label 'Quarantine Quantity' ;
    rdfs:comment 'Quantity held for quality inspection or pending release approval. Not available for order fulfillment until cleared.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentTriggerQuantity rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger Quantity' ;
    rdfs:comment 'Minimum quantity threshold that triggers automatic replenishment from reserve storage to pick face. Used to maintain optimal pick face inventory levels.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity committed to existing orders or work orders but not yet picked. Reduces available quantity for new allocations.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Identifier of the vendor or supplier who provided this inventory. Used for supplier performance tracking and quality traceability.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureUom rdf:type rdf:Property ;
    rdfs:label 'Temperature Uom' ;
    rdfs:comment 'Unit of measure for temperature range values. Standard units are celsius or fahrenheit.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumePerUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Per Unit' ;
    rdfs:comment 'Physical volume or cubic measurement of a single unit of the SKU. Used for warehouse space planning, slotting optimization, and freight rating.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightPerUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Per Unit' ;
    rdfs:comment 'Physical weight of a single unit of the SKU. Used for dimensional weight calculations, freight rating, and capacity planning.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborActivityId rdf:type rdf:Property ;
    rdfs:label 'Labor Activity Id' ;
    rdfs:comment 'Unique identifier for the warehouse labor activity record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaborActivity .

ind:primaryLaborEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Labor Employee Id' ;
    rdfs:comment 'Identifier of the warehouse operative who performed the activity. Links to workforce management system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current status of the labor activity in its lifecycle.' ;
    rdfs:domain ind:LaborActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Time Minutes' ;
    rdfs:comment 'Actual time in minutes the operative spent on the activity, excluding breaks and idle time.' ;
    rdfs:domain ind:LaborActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes for the activity, calculated as the difference between end and start timestamps.' ;
    rdfs:domain ind:LaborActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Date and time when the operative completed or paused the activity. Captured from RF scanner or voice device logout.' ;
    rdfs:domain ind:LaborActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incentiveEligible rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligible' ;
    rdfs:comment 'Indicates whether this activity is eligible for productivity-based incentive pay.' ;
    rdfs:domain ind:LaborActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Allocated labor cost for this activity in the facility\'s operating currency, calculated based on operative hourly rate and activity duration.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productivityPercentage rdf:type rdf:Property ;
    rdfs:label 'Productivity Percentage' ;
    rdfs:comment 'Productivity percentage calculated as (standard_time_minutes / actual_time_minutes) * 100. Values above 100% indicate performance exceeding standard.' ;
    rdfs:domain ind:LaborActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCheckPassed rdf:type rdf:Property ;
    rdfs:label 'Quality Check Passed' ;
    rdfs:comment 'Indicates whether the quality inspection was passed (true) or failed (false). Null if no quality check was performed.' ;
    rdfs:domain ind:LaborActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Check Required' ;
    rdfs:comment 'Indicates whether a quality inspection was required for this activity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Time Minutes' ;
    rdfs:comment 'Engineered labor standard time in minutes expected to complete the activity, based on industrial engineering studies and labor standards.' ;
    rdfs:domain ind:LaborActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the operative began the activity. Captured from Radio Frequency (RF) scanner or voice device login.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingMode rdf:type rdf:Property ;
    rdfs:label 'Training Mode' ;
    rdfs:comment 'Indicates whether the operative was in training mode during this activity. Training activities may be excluded from productivity calculations.' ;
    rdfs:domain ind:LaborActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelDistanceMeters rdf:type rdf:Property ;
    rdfs:label 'Travel Distance Meters' ;
    rdfs:comment 'Estimated or tracked travel distance in meters covered by the operative during the activity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsProcessed rdf:type rdf:Property ;
    rdfs:label 'Units Processed' ;
    rdfs:comment 'Number of units (Stock Keeping Units, cartons, pallets, or line items) processed during the activity.' ;
    rdfs:domain ind:LaborActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outboundOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Id' ;
    rdfs:comment 'Unique identifier for the outbound order line. Primary key for this entity.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cartonId rdf:type rdf:Property ;
    rdfs:label 'Carton Id' ;
    rdfs:comment 'Unique identifier for the shipping carton or container holding this line item. Links line to physical package for tracking and proof of delivery.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carton .

ind:pickWaveId rdf:type rdf:Property ;
    rdfs:label 'Pick Wave Id' ;
    rdfs:comment 'Identifier for the pick wave or batch that included this order line. Used for wave planning analysis and labor productivity tracking.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickWave .

ind:primaryOutboundEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Outbound Employee Id' ;
    rdfs:comment 'Identifier of the warehouse associate who picked this line item. Supports labor management and productivity analysis.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity of inventory allocated or reserved for this order line. Represents inventory commitment prior to physical picking.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerItemReference rdf:type rdf:Property ;
    rdfs:label 'Customer Item Reference' ;
    rdfs:comment 'Customer\'s own SKU or item reference number. Used for cross-referencing in e-commerce fulfillment and contract logistics scenarios.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Flag' ;
    rdfs:comment 'Indicates whether this line was fulfilled on-time and in-full per customer SLA. Key performance indicator for warehouse and fulfillment operations.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packStation rdf:type rdf:Property ;
    rdfs:label 'Pack Station' ;
    rdfs:comment 'Packing station identifier where the item was packed. Used for labor productivity tracking and quality control.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickLocation rdf:type rdf:Property ;
    rdfs:label 'Pick Location' ;
    rdfs:comment 'Warehouse location code where the item was picked from. Supports slotting optimization and pick path analysis.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'Date and time when the line item left the warehouse facility. Marks completion of warehouse fulfillment and start of carrier transit.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortShipQuantity rdf:type rdf:Property ;
    rdfs:label 'Short Ship Quantity' ;
    rdfs:comment 'The quantity not fulfilled due to inventory shortage, damage, or other constraints. Calculated as ordered quantity minus shipped quantity.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationHubGatewayId rdf:type rdf:Property ;
    rdfs:label 'Destination Hub Gateway Id' ;
    rdfs:comment 'Foreign key linking to network.hub_gateway. Business justification: Outbound orders are routed through specific consolidation hubs or gateways for line-haul optimization and cross-border clearance. Essential for network planning, load building, and multi-leg shipment ' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HubGateway .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'External reference number or purchase order number provided by the customer for tracking and reconciliation purposes.' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationContactEmail rdf:type rdf:Property ;
    rdfs:label 'Destination Contact Email' ;
    rdfs:comment 'Email address for the consignee or destination contact for delivery notifications and coordination.' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationContactPhone rdf:type rdf:Property ;
    rdfs:label 'Destination Contact Phone' ;
    rdfs:comment 'Primary phone number for the consignee or destination contact for delivery coordination.' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Received Timestamp' ;
    rdfs:comment 'Date and time when the outbound shipment order was received by the warehouse management system from the upstream order management or ERP system.' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otdFlag rdf:type rdf:Property ;
    rdfs:label 'Otd Flag' ;
    rdfs:comment 'Boolean indicator of whether the order was dispatched on or before the requested ship date, meeting the on-time delivery commitment.' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Date by which the customer has requested the order to be shipped from the warehouse.' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Sla Service Level' ;
    rdfs:comment 'Contracted service level commitment for this shipment defining the expected delivery timeframe (same-day, next-day, two-day, standard, economy, or express).' ;
    rdfs:domain ind:OutboundShipmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnitCount rdf:type rdf:Property ;
    rdfs:label 'Total Unit Count' ;
    rdfs:comment 'Total number of individual units (pieces, eaches) across all lines in this outbound shipment order.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packOrderId rdf:type rdf:Property ;
    rdfs:label 'Pack Order Id' ;
    rdfs:comment 'Unique identifier for the pack order. Primary key.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packingStationId rdf:type rdf:Property ;
    rdfs:label 'Packing Station Id' ;
    rdfs:comment 'Identifier of the physical packing station or workbench where items are consolidated and packaged.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackingStation .

ind:primaryPackEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pack Employee Id' ;
    rdfs:comment 'Identifier of the warehouse operative or packer assigned to execute this pack order.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'Total number of cartons or boxes packed for this order. Used for shipment planning and carrier manifesting.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchActualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Actual Timestamp' ;
    rdfs:comment 'Actual timestamp when the packed order was dispatched from the warehouse. Used for On-Time Delivery (OTD) and On-Time In-Full (OTIF) performance tracking.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Scheduled Timestamp' ;
    rdfs:comment 'Scheduled timestamp for outbound dispatch of the packed order. Used for dock scheduling and carrier pickup coordination.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:labelGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Label Generation Timestamp' ;
    rdfs:comment 'Timestamp when shipping labels were generated for the packed cartons or pallets.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Pack Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to complete the packing operation, calculated as the difference between start and completion timestamps. Key performance indicator (KPI) for labor efficiency.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packMethodCode rdf:type rdf:Property ;
    rdfs:label 'Pack Method Code' ;
    rdfs:comment 'Packing methodology applied based on order characteristics: single-item for individual SKUs, multi-item for consolidated cartons, bulk for large quantities, pallet for palletized loads, mixed for heterogeneous packaging.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Pack Order Number' ;
    rdfs:comment 'Human-readable business identifier for the pack order, typically displayed on packing station screens and printed on labels.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packPriorityCode rdf:type rdf:Property ;
    rdfs:label 'Pack Priority Code' ;
    rdfs:comment 'Priority level assigned to the pack order, determining sequence in the packing queue. Urgent orders are typically express shipments or SLA-critical.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Status' ;
    rdfs:comment 'Current lifecycle status of the pack order in the packing workflow.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost Amount' ;
    rdfs:comment 'Total cost of packaging materials consumed for this pack order, used for cost center accounting and profitability analysis.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packingExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Packing Exception Code' ;
    rdfs:comment 'Code indicating any exception or issue encountered during packing (e.g., short pick from upstream, damaged item discovered, packaging material shortage, equipment malfunction).' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingInstructions rdf:type rdf:Property ;
    rdfs:label 'Packing Instructions' ;
    rdfs:comment 'Free-text field capturing specific packing instructions from the customer or order management system, such as gift wrapping, custom labeling, or assembly requirements.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingZoneCode rdf:type rdf:Property ;
    rdfs:label 'Packing Zone Code' ;
    rdfs:comment 'Code identifying the packing zone or area within the warehouse where the station is located, used for labor allocation and workflow optimization.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Total number of pallets used for this pack order. Relevant for Full Truckload (FTL) and Less Than Truckload (LTL) shipments.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetTemperatureRangeC rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Range C' ;
    rdfs:comment 'Required temperature range in Celsius for cold chain shipments (e.g., \'2 to 8\' for vaccines, \'-18 to -22\' for frozen goods).' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Required Flag' ;
    rdfs:comment 'Indicates whether the packed order requires temperature-controlled handling (cold chain for pharmaceuticals, perishables, or temperature-sensitive goods).' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPackedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Packed Volume Cbm' ;
    rdfs:comment 'Total volumetric measurement of all packed units in cubic meters (CBM). Critical for dimensional weight (DIM weight) calculation and load optimization.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPackedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Packed Weight Kg' ;
    rdfs:comment 'Total gross weight of all packed cartons and pallets in kilograms, including packaging materials. Used for freight rating and carrier selection.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total number of distinct SKUs included in this pack order. Used for complexity analysis and packing time estimation.' ;
    rdfs:domain ind:PackOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Required Flag' ;
    rdfs:comment 'Indicates whether the packed order requires quality verification or audit before dispatch, typically for high-value or regulated shipments.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aisleCode rdf:type rdf:Property ;
    rdfs:label 'Aisle Code' ;
    rdfs:comment 'The aisle identifier within the warehouse where the source location is situated. Supports travel distance calculation and slotting analysis.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Order Number' ;
    rdfs:comment 'The customer-facing order number associated with this pick task. Provides traceability from warehouse execution back to customer order.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence Number' ;
    rdfs:comment 'The sequence order of this task within the assigned pick wave or batch. Optimizes travel path and minimizes operative movement.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickType rdf:type rdf:Property ;
    rdfs:label 'Pick Type' ;
    rdfs:comment 'Picking strategy applied to this task. Discrete picks one order at a time; batch picks multiple orders simultaneously; zone assigns pickers to specific warehouse areas.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether the picked inventory is subject to a quality hold pending inspection or release. True if on quality hold.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Triggered Flag' ;
    rdfs:comment 'Indicates whether this pick task triggered an automatic replenishment task to refill the source location from reserve storage. True if replenishment was triggered.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'The quantity of the SKU that the operative is instructed to pick, as determined by the order line requirement.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortPickQuantity rdf:type rdf:Property ;
    rdfs:label 'Short Pick Quantity' ;
    rdfs:comment 'The quantity shortfall when the operative cannot fulfill the full requested quantity due to inventory discrepancy, damage, or location error.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortPickReasonCode rdf:type rdf:Property ;
    rdfs:label 'Short Pick Reason Code' ;
    rdfs:comment 'Standardized code indicating why the operative could not fulfill the full requested quantity. Drives root cause analysis and inventory accuracy improvement.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Task Duration Seconds' ;
    rdfs:comment 'The elapsed time in seconds from task start to completion. Key metric for labor productivity analysis and engineered labor standards.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskPriority rdf:type rdf:Property ;
    rdfs:label 'Task Priority' ;
    rdfs:comment 'Priority level assigned to the pick task, determining execution sequence. Urgent tasks support expedited shipments and SLA commitments.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'The temperature control zone classification of the source location and SKU. Ensures cold chain integrity for perishable goods.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumePickedCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Picked Cbm' ;
    rdfs:comment 'The total volume in cubic meters of the picked quantity. Used for space utilization analysis and container load optimization.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightPickedKg rdf:type rdf:Property ;
    rdfs:label 'Weight Picked Kg' ;
    rdfs:comment 'The total weight in kilograms of the picked quantity. Used for load planning, freight calculation, and weight verification.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPickEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Employee Id' ;
    rdfs:comment 'Identifier of the Warehouse Management System (WMS) user or automated process that created this wave record.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:isHighValue rdf:type rdf:Property ;
    rdfs:label 'Is High Value' ;
    rdfs:comment 'Indicates whether this wave contains high-value goods requiring enhanced security measures, additional insurance, or special handling procedures.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Planned' ;
    rdfs:comment 'Estimated total labor hours required to complete picking and packing for this wave. Used for workforce planning and scheduling.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packing End Timestamp' ;
    rdfs:comment 'Date and time when the last packing task for this wave was completed. Marks readiness for outbound dispatch.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packing Start Timestamp' ;
    rdfs:comment 'Date and time when the first packing task for this wave was started. Marks the beginning of the packing phase.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packingStationCount rdf:type rdf:Property ;
    rdfs:label 'Packing Station Count' ;
    rdfs:comment 'Number of packing stations allocated to process orders from this wave. Used for packing capacity planning.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Pick Accuracy Percentage' ;
    rdfs:comment 'Percentage of pick tasks completed without errors (correct Stock Keeping Unit (SKU), correct quantity, correct location). Key Performance Indicator (KPI) for picking quality.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickerCount rdf:type rdf:Property ;
    rdfs:label 'Picker Count' ;
    rdfs:comment 'Number of warehouse pickers assigned to execute this wave. Used for labor planning and productivity measurement.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking End Timestamp' ;
    rdfs:comment 'Date and time when the last pick task in this wave was completed. Marks the end of picking phase before packing begins.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Start Timestamp' ;
    rdfs:comment 'Date and time when the first pick task in this wave was started by a picker. Marks the beginning of active picking operations.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Timestamp' ;
    rdfs:comment 'Target date and time for completing all picking and packing activities for this wave. Used for capacity planning and Service Level Agreement (SLA) management.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Release Timestamp' ;
    rdfs:comment 'Scheduled date and time when the wave is planned to be released to the warehouse floor for picking execution.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaCutoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Cutoff Timestamp' ;
    rdfs:comment 'Latest date and time by which this wave must be completed to meet Service Level Agreement (SLA) commitments for included orders. Used for On-Time Delivery (OTD) tracking.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalOrderCount rdf:type rdf:Property ;
    rdfs:label 'Total Order Count' ;
    rdfs:comment 'Total number of distinct outbound orders included in this pick wave. Used for wave sizing and throughput analysis.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waveAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Wave Allocation Method' ;
    rdfs:comment 'Inventory allocation strategy used for this wave. First In First Out (FIFO): oldest stock first. Last In First Out (LIFO): newest stock first. First Expired First Out (FEFO): shortest shelf-life first. Nearest Location: minimize travel distance. Optimal Path: system-optimized routing.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveNotes rdf:type rdf:Property ;
    rdfs:label 'Wave Notes' ;
    rdfs:comment 'Free-text operational notes or special instructions for this wave. Used for communicating exceptions, special handling requirements, or coordination messages.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Wave Template Code' ;
    rdfs:comment 'Code identifying the wave template or configuration profile used to generate this wave. Templates define picking rules, zone assignments, and resource allocation strategies.' ;
    rdfs:domain ind:PickWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayTaskId rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Id' ;
    rdfs:comment 'Unique identifier for the putaway task. Primary key.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Storage Location Id' ;
    rdfs:comment 'Identifier of the storage location (bin, slot, pallet position) where the goods must be placed. Determined by slotting optimization rules.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:handlingUnitId rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Id' ;
    rdfs:comment 'Identifier of the physical handling unit (pallet, container, tote) being moved. May be an SSCC (Serial Shipping Container Code) or internal license plate number.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandlingUnit .

ind:primaryPutawayStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Putaway Storage Location Id' ;
    rdfs:comment 'Identifier of the staging or receiving location where the goods are currently located and must be picked up from.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total elapsed time from task start to completion, in seconds. Key metric for labor productivity analysis and engineered labor standards validation.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Required' ;
    rdfs:comment 'Type of material handling equipment required to execute this putaway task, based on weight, height, and location characteristics.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifoDate rdf:type rdf:Property ;
    rdfs:label 'Fifo Date' ;
    rdfs:comment 'Date used for FIFO inventory rotation logic. Typically the receipt date or production date. Ensures oldest inventory is picked first.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Classification of inventory ownership: own_stock (company-owned), customer_stock (3PL client inventory), consignment (supplier-owned), vendor_managed (VMI program).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Status of the quality inspection: not_required (no check needed), pending (awaiting inspection), passed (approved for storage), failed (rejected, requires disposition).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger Flag' ;
    rdfs:comment 'Indicates whether completion of this putaway task will trigger an automatic replenishment task to move goods from reserve to forward pick locations.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Standard Time Seconds' ;
    rdfs:comment 'Engineered labor standard time for this task type and distance, in seconds. Used to calculate labor productivity percentage (actual vs. standard).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:systemDirectedFlag rdf:type rdf:Property ;
    rdfs:label 'System Directed Flag' ;
    rdfs:comment 'Indicates whether the destination location was system-directed by slotting optimization algorithms (true) or manually specified by a user (false).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique identifier for the replenishment order. Primary key for the replenishment order entity.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReplenishmentStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Replenishment Storage Location Id' ;
    rdfs:comment 'Identifier of the reserve or bulk storage location from which inventory will be moved.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:actualQuantityMoved rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Moved' ;
    rdfs:comment 'The actual quantity of inventory units successfully moved upon completion. May differ from planned replenishment quantity due to inventory availability or operational constraints.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'The estimated time in minutes to complete the replenishment task based on labor standards and distance calculations.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fifoSequence rdf:type rdf:Property ;
    rdfs:label 'Fifo Sequence' ;
    rdfs:comment 'Numeric sequence indicating the FIFO priority of the inventory being replenished, ensuring oldest inventory is moved to pick-face first.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickFaceMaxQuantity rdf:type rdf:Property ;
    rdfs:label 'Pick Face Max Quantity' ;
    rdfs:comment 'The maximum inventory capacity for the destination pick-face location used to calculate optimal replenishment quantity.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickFaceMinQuantity rdf:type rdf:Property ;
    rdfs:label 'Pick Face Min Quantity' ;
    rdfs:comment 'The minimum inventory level threshold for the destination pick-face location that triggered the replenishment order.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Replenishment Quantity' ;
    rdfs:comment 'The quantity of inventory units to be moved from source to destination location.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'The business rule or event that initiated the replenishment order. Min-max indicates inventory fell below minimum threshold, demand-driven indicates anticipated pick demand, wave-triggered indicates wave planning requirement, manual indicates operator-initiated, scheduled indicates time-based replenishment.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Returns Receipt Id' ;
    rdfs:comment 'Unique identifier for the returns receipt record. Primary key.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnsReceipt .

ind:primaryReturnsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Returns Employee Id' ;
    rdfs:comment 'Employee or operator identifier who physically received and processed the inbound return at the dock.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:claimInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Claim Initiated Flag' ;
    rdfs:comment 'Indicates whether a cargo claim or insurance claim was initiated for this return due to damage or loss.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionAssessment rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment' ;
    rdfs:comment 'Overall condition assessment of the returned goods after inspection. Determines eligibility for resale or other disposition.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Final disposition action assigned to the returned goods based on condition assessment and business rules. [ENUM-REF-CANDIDATE: restock|refurbish|quarantine|dispose|return_to_vendor|donate|salvage — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Completed Timestamp' ;
    rdfs:comment 'Date and time when the final disposition action was completed and the return was closed in the system.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Timestamp' ;
    rdfs:comment 'Date and time when the physical inspection and condition assessment of the return was completed.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originatingOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Originating Order Number' ;
    rdfs:comment 'Reference to the original outbound order or shipment number that this return is associated with.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Pod Document Reference' ;
    rdfs:comment 'Reference to the Proof of Delivery document or electronic proof of delivery for the return shipment.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantinedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quarantined Quantity' ;
    rdfs:comment 'Number of units from this return that were placed in quarantine pending further investigation or quality review.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Eligible Flag' ;
    rdfs:comment 'Indicates whether this return is eligible for customer refund based on return policy and condition assessment.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockedQuantity rdf:type rdf:Property ;
    rdfs:label 'Restocked Quantity' ;
    rdfs:comment 'Number of units from this return that were restocked into available inventory for resale.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPackagesReceived rdf:type rdf:Property ;
    rdfs:label 'Total Packages Received' ;
    rdfs:comment 'Total number of packages, cartons, or containers received in this return shipment.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Units Received' ;
    rdfs:comment 'Total count of individual units or items received in this return shipment across all SKUs.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnsReceiptLineId rdf:type rdf:Property ;
    rdfs:label 'Returns Receipt Line Id' ;
    rdfs:comment 'Unique identifier for the returns receipt line. Primary key.' ;
    rdfs:domain ind:ReturnsReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Original Order Line Id' ;
    rdfs:comment 'Foreign key reference to the original order line that this return corresponds to.' ;
    rdfs:domain ind:ReturnsReceiptLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:primaryReturnsStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Returns Storage Location Id' ;
    rdfs:comment 'Foreign key reference to the storage location where resalable units will be restocked.' ;
    rdfs:domain ind:ReturnsReceiptLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:creditEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this return line is eligible for customer credit or refund.' ;
    rdfs:domain ind:ReturnsReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destroyedQuantity rdf:type rdf:Property ;
    rdfs:label 'Destroyed Quantity' ;
    rdfs:comment 'Quantity of returned units that are beyond repair and must be destroyed or disposed of.' ;
    rdfs:domain ind:ReturnsReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Code indicating the disposition decision for the returned SKU (restock, repair, scrap, donate, return to vendor).' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspected Timestamp' ;
    rdfs:comment 'Date and time when the quality inspection was completed for this return line.' ;
    rdfs:domain ind:ReturnsReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resalableQuantity rdf:type rdf:Property ;
    rdfs:label 'Resalable Quantity' ;
    rdfs:comment 'Quantity of returned units that are in resalable condition and can be restocked for sale.' ;
    rdfs:domain ind:ReturnsReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Total quantity of the SKU returned by the customer or consignee.' ;
    rdfs:domain ind:ReturnsReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyLedgerId rdf:type rdf:Property ;
    rdfs:label 'Penalty Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger. Business justification: SLA penalty clauses in warehouse service agreements require automated posting to specific GL accounts when breaches occur. Links penalty_amount to the correct revenue reduction or liability account. E' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:primaryServiceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Employee Id' ;
    rdfs:comment 'Reference to the user or employee responsible for managing and monitoring this SLA configuration.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryServiceLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Service Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this SLA configuration record.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryServiceCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Service Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this SLA configuration record.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselinePerformanceValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Performance Value' ;
    rdfs:comment 'Historical baseline performance value measured prior to SLA implementation, used for comparison and improvement tracking.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Unit' ;
    rdfs:comment 'Unit of measure for the breach threshold value, such as hours, minutes, days, percentage, units, orders, or lines. [ENUM-REF-CANDIDATE: hours|minutes|days|percentage|units|orders|lines — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Value' ;
    rdfs:comment 'Numeric threshold value at which the SLA is considered breached, triggering alerts or penalties.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuousImprovementTarget rdf:type rdf:Property ;
    rdfs:label 'Continuous Improvement Target' ;
    rdfs:comment 'Aspirational performance target beyond the contractual SLA commitment, used for internal continuous improvement initiatives.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Description of conditions or scenarios under which SLA measurement is suspended or excluded, such as force majeure events, system outages, or customer-caused delays.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEmailList rdf:type rdf:Property ;
    rdfs:label 'Notification Email List' ;
    rdfs:comment 'Comma-separated list of email addresses to be notified when SLA breach events occur.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDashboardUrl rdf:type rdf:Property ;
    rdfs:label 'Reporting Dashboard Url' ;
    rdfs:comment 'URL link to the performance dashboard or reporting interface where SLA compliance metrics are visualized.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricName rdf:type rdf:Property ;
    rdfs:label 'Target Metric Name' ;
    rdfs:comment 'Name of the performance metric being measured for this SLA, such as turnaround time, accuracy percentage, or on-time delivery rate.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'The ABC inventory classification (A=high-value/high-velocity, B=medium, C=low) used for prioritization and slotting optimization.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'The date from which this SKU became active and available for warehouse operations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'The date on which this SKU was discontinued or became inactive. Null if currently active.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'The primary barcode identifier (UPC, EAN, or other format) used for scanning and automated identification in warehouse operations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeType rdf:type rdf:Property ;
    rdfs:label 'Barcode Type' ;
    rdfs:comment 'The barcode symbology or format type used for this SKU (UPC, EAN, CODE128, etc.).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDateRequired rdf:type rdf:Property ;
    rdfs:label 'Expiry Date Required' ;
    rdfs:comment 'Boolean flag indicating whether this SKU requires expiry date tracking for inventory management and FEFO rotation.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fragile rdf:type rdf:Property ;
    rdfs:label 'Fragile' ;
    rdfs:comment 'Boolean flag indicating whether this SKU is fragile and requires special handling to prevent damage.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Lot Tracking Required' ;
    rdfs:comment 'Boolean flag indicating whether this SKU requires lot or batch number tracking for traceability and quality control.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'The manufacturers own part number or SKU identifier for this item, used for cross-referencing and procurement.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStackHeight rdf:type rdf:Property ;
    rdfs:label 'Max Stack Height' ;
    rdfs:comment 'The maximum number of units that can be safely stacked vertically. Null if not stackable or no limit.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSubcategory rdf:type rdf:Property ;
    rdfs:label 'Product Subcategory' ;
    rdfs:comment 'Detailed subcategory classification within the product category for granular inventory management and analytics.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The inventory quantity threshold that triggers replenishment or reorder action for this SKU.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The minimum buffer inventory quantity maintained to prevent stockouts and ensure service level for this SKU.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serialTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Serial Tracking Required' ;
    rdfs:comment 'Boolean flag indicating whether this SKU requires individual serial number tracking at the unit level for high-value or regulated items.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'The number of days from receipt or manufacture date that the SKU remains usable or saleable before expiration. Null for non-perishable items.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'Detailed human-readable description of the product or item represented by this SKU, including key characteristics and specifications.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current lifecycle status of the SKU indicating whether it is available for warehouse operations, discontinued, or pending activation.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackable rdf:type rdf:Property ;
    rdfs:label 'Stackable' ;
    rdfs:comment 'Boolean flag indicating whether this SKU can be safely stacked vertically in storage and transport.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageClass rdf:type rdf:Property ;
    rdfs:label 'Storage Class' ;
    rdfs:comment 'The warehouse storage class or zone assignment for this SKU based on handling requirements, velocity, and physical characteristics (e.g., fast-pick, bulk, secure, hazmat).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocityCode rdf:type rdf:Property ;
    rdfs:label 'Velocity Code' ;
    rdfs:comment 'The movement velocity classification indicating how frequently this SKU is picked or shipped (fast, medium, slow movers).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'The code or identifier of the primary vendor or supplier for this SKU, used for procurement and replenishment.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Aisle designation within the warehouse where the storage location is physically situated. Used for route optimization and labor management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationType rdf:type rdf:Property ;
    rdfs:label 'Automation Type' ;
    rdfs:comment 'Level and type of automation technology deployed at this storage location. Impacts labor planning and throughput capacity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bin rdf:type rdf:Property ;
    rdfs:label 'Bin' ;
    rdfs:comment 'Specific bin or slot position within the level. Represents the most granular storage position.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether this storage location is within a bonded warehouse zone where goods are stored without payment of customs duties until released for domestic consumption.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Scheduled frequency for physical inventory cycle counting at this storage location. Supports inventory accuracy and compliance with ISO 9001 quality management.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionZone rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Zone' ;
    rdfs:comment 'Fire suppression system zone identifier covering this storage location. Critical for safety compliance and insurance requirements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClassPermitted rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class Permitted' ;
    rdfs:comment 'Comma-separated list of International Maritime Organization (IMO) hazard classes permitted in this storage location (e.g., 1.1, 2.2, 3, 4.1, 5.1, 6.1, 8, 9). Empty if not hazmat suitable.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatSuitable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Suitable' ;
    rdfs:comment 'Indicates whether the storage location is certified and equipped for storing hazardous materials per International Maritime Dangerous Goods (IMDG) Code and International Civil Aviation Organization (ICAO) Technical Instructions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationBarcode rdf:type rdf:Property ;
    rdfs:label 'Location Barcode' ;
    rdfs:comment 'Scannable barcode identifier for the storage location used by handheld Radio Frequency Identification (RFID) devices and mobile scanning equipment during warehouse operations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the storage location indicating availability for putaway and picking operations.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupancyStatus rdf:type rdf:Property ;
    rdfs:label 'Occupancy Status' ;
    rdfs:comment 'Current inventory occupancy state of the storage location based on capacity utilization.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickFaceFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Face Flag' ;
    rdfs:comment 'Indicates whether this location is designated as a pick-face position for order fulfillment operations. Pick-face locations are optimized for high-velocity Stock Keeping Units (SKUs).' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated for quarantine inventory pending quality inspection, customs clearance, or Return Merchandise Authorization (RMA) processing.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rack rdf:type rdf:Property ;
    rdfs:label 'Rack' ;
    rdfs:comment 'Rack or bay identifier within the aisle where the storage location is positioned.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Flag' ;
    rdfs:comment 'Indicates whether this location requires periodic replenishment from bulk storage. Used in First In First Out (FIFO) and Last In First Out (LIFO) inventory management strategies.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnsProcessingFlag rdf:type rdf:Property ;
    rdfs:label 'Returns Processing Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated for processing customer returns and Return Merchandise Authorization (RMA) inventory.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageLocationLevel rdf:type rdf:Property ;
    rdfs:label 'Storage Location Level' ;
    rdfs:comment 'Vertical level or shelf position within the rack structure. Used for slotting optimization based on Stock Keeping Unit (SKU) velocity and weight.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureClass rdf:type rdf:Property ;
    rdfs:label 'Temperature Class' ;
    rdfs:comment 'Temperature control classification of the storage location. Critical for cold-chain logistics and pharmaceutical shipments.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueAddedServicesFlag rdf:type rdf:Property ;
    rdfs:label 'Value Added Services Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated for value-added services such as kitting, labeling, repackaging, or customization operations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms. Used for slotting optimization and safety compliance.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipRecordId rdf:type rdf:Property ;
    rdfs:label 'Wip Record Id' ;
    rdfs:comment 'Unique identifier for the work-in-progress record. Primary key.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWipEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Wip Employee Id' ;
    rdfs:comment 'Reference to the warehouse operative or worker assigned to perform the VAS activity. Used for labor tracking and productivity measurement.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryWipLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Wip Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this WIP record, used for audit trail and accountability.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWipCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Wip Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this WIP record in the system, typically a warehouse supervisor or system administrator.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Total labor hours consumed to complete this WIP activity, calculated from start to completion timestamps. Used for productivity analysis and VAS billing.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized code identifying the type of defect or quality issue found during inspection (e.g., damaged packaging, incorrect labeling, contamination).' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputQuantity rdf:type rdf:Property ;
    rdfs:label 'Input Quantity' ;
    rdfs:comment 'Quantity of goods or units received as input to the WIP process. For kitting, this represents the sum of component quantities; for repackaging, the original quantity before processing.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kitReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Kit Reference Code' ;
    rdfs:comment 'Reference code for the kit configuration when WIP type is kitting. Defines the bill of materials for the kit assembly.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputQuantity rdf:type rdf:Property ;
    rdfs:label 'Output Quantity' ;
    rdfs:comment 'Quantity of goods or units produced as output from the WIP process. For kitting, this represents the number of completed kits; for repackaging, the new quantity after processing.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Outcome of quality inspection when WIP type is quality_inspection: passed (meets quality standards), failed (does not meet standards), conditional (requires additional review), or not_applicable (no inspection performed).' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejection Quantity' ;
    rdfs:comment 'Quantity of goods rejected or failed during the WIP process due to quality issues, damage, or non-conformance. These units are typically moved to quarantine or damaged inventory status.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardLaborHours rdf:type rdf:Property ;
    rdfs:label 'Standard Labor Hours' ;
    rdfs:comment 'Engineered standard labor hours expected for this type of WIP activity based on time-and-motion studies. Used for variance analysis and performance measurement.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vasChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Vas Charge Amount' ;
    rdfs:comment 'Billable charge amount for this VAS activity, calculated based on contract rates, labor hours, or per-unit pricing. Used for contract logistics invoicing.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Wip Record Number' ;
    rdfs:comment 'Business-facing unique identifier for the WIP record, typically human-readable and used in operational communications and documentation.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipStatus rdf:type rdf:Property ;
    rdfs:label 'Wip Status' ;
    rdfs:comment 'Current lifecycle status of the WIP record: queued (awaiting processing), in_progress (actively being worked), completed (successfully finished), failed (processing failed), or cancelled (work order cancelled).' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipType rdf:type rdf:Property ;
    rdfs:label 'Wip Type' ;
    rdfs:comment 'Classification of the value-added service being performed: kitting (assembling multiple SKUs into a kit), labelling (applying customer-specific labels), repackaging (changing packaging configuration), quality inspection (QC checks), customs hold (goods under customs examination), or deconsolidation (breaking down bulk shipments).' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workStationCode rdf:type rdf:Property ;
    rdfs:label 'Work Station Code' ;
    rdfs:comment 'Identifier of the physical work station, packing table, or processing area within the warehouse where the VAS activity is being performed.' ;
    rdfs:domain ind:WipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleCount rdf:type rdf:Property ;
    rdfs:label 'Aisle Count' ;
    rdfs:comment 'Number of aisles within the zone. Used for labor planning and travel distance optimization.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System' ;
    rdfs:comment 'Type of fire suppression system installed in the zone. Critical for safety compliance and insurance requirements.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqm' ;
    rdfs:comment 'Total floor area of the zone measured in square meters. Used for capacity planning and space utilization analysis.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatSuitableFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Suitable Flag' ;
    rdfs:comment 'Indicates whether the zone is certified and equipped for storing hazardous materials per IMDG and ICAO regulations.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightM rdf:type rdf:Property ;
    rdfs:label 'Height M' ;
    rdfs:comment 'Maximum vertical clearance height of the zone in meters. Critical for slotting tall items and equipment operation.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCount rdf:type rdf:Property ;
    rdfs:label 'Location Count' ;
    rdfs:comment 'Total number of discrete storage locations within the zone. Key metric for capacity planning and utilization tracking.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Source Flag' ;
    rdfs:comment 'Indicates whether the zone serves as a bulk storage source for replenishing pick-face locations.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vasFlag rdf:type rdf:Property ;
    rdfs:label 'Vas Flag' ;
    rdfs:comment 'Indicates whether the zone is designated for value-added services such as kitting, labeling, packaging, or customization.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:absenceRecordId rdf:type rdf:Property ;
    rdfs:label 'Absence Record Id' ;
    rdfs:comment 'Unique identifier for the absence record. Primary key.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fmlaCaseId rdf:type rdf:Property ;
    rdfs:label 'Fmla Case Id' ;
    rdfs:comment 'Unique identifier for the FMLA case if this absence is covered under FMLA regulations. Null if not FMLA-related.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FmlaCase .

ind:primaryAbsenceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Absence Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who is absent. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceReason rdf:type rdf:Property ;
    rdfs:label 'Absence Reason' ;
    rdfs:comment 'Detailed reason or description provided by the employee for the absence. May include medical, personal, or family-related explanations.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceStatus rdf:type rdf:Property ;
    rdfs:label 'Absence Status' ;
    rdfs:comment 'Current status of the absence request in the approval and execution workflow.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceType rdf:type rdf:Property ;
    rdfs:label 'Absence Type' ;
    rdfs:comment 'Category of absence or leave taken by the employee. Includes annual leave, sick leave, FMLA (Family and Medical Leave Act), parental leave, bereavement, and unpaid leave.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageArranged rdf:type rdf:Property ;
    rdfs:label 'Coverage Arranged' ;
    rdfs:comment 'Indicates whether replacement or coverage for the absent employee has been arranged (true) or not (false). Used for operational continuity tracking.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAbsenceCode rdf:type rdf:Property ;
    rdfs:label 'External Absence Code' ;
    rdfs:comment 'Unique identifier for this absence record in the source system (e.g., Workday HCM). Used for reconciliation and traceability.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnOperations rdf:type rdf:Property ;
    rdfs:label 'Impact On Operations' ;
    rdfs:comment 'Assessment of the operational impact of this absence on business continuity, service delivery, and team productivity.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntermittent rdf:type rdf:Property ;
    rdfs:label 'Is Intermittent' ;
    rdfs:comment 'Indicates whether this absence is part of an intermittent leave arrangement (true) or a continuous block of leave (false). Relevant for FMLA and chronic condition management.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaid rdf:type rdf:Property ;
    rdfs:label 'Is Paid' ;
    rdfs:comment 'Indicates whether the absence is paid leave (true) or unpaid leave (false).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveBalanceConsumed rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Consumed' ;
    rdfs:comment 'Amount of leave balance (in days or hours) deducted from the employee\'s accrued leave balance for this absence.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalCertificationReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Received' ;
    rdfs:comment 'Indicates whether the required medical certification has been received (true) or is still pending (false). Null if not required.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Required' ;
    rdfs:comment 'Indicates whether medical certification or documentation is required for this absence (true) or not (false). Typically required for sick leave and FMLA.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Actual date when the employee returned to work following the absence. May differ from planned end date.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalDays rdf:type rdf:Property ;
    rdfs:label 'Total Days' ;
    rdfs:comment 'Total number of days (including partial days) covered by this absence record. Calculated based on working days and hours.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHours rdf:type rdf:Property ;
    rdfs:label 'Total Hours' ;
    rdfs:comment 'Total number of hours covered by this absence record. Used for partial-day absences and hourly leave tracking.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record. Primary key for the benefit enrollment entity.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Unique identifier for the benefit plan in which the employee is enrolled. Links to the benefit plan master record.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:benefitsSupplierId rdf:type rdf:Property ;
    rdfs:label 'Benefits Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Benefits administered by third-party suppliers (insurance carriers, benefits administrators, wellness program providers). Enables benefits supplier tracking, vendor-specific enrollment management, ben' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:annualElectionAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Election Amount' ;
    rdfs:comment 'Total annual amount elected by the employee for contribution-based benefits such as Flexible Spending Accounts (FSA) or Health Savings Accounts (HSA). Represents the employees annual commitment for the plan year.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryDesignation rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Designation' ;
    rdfs:comment 'Name or identifier of the primary beneficiary designated to receive benefits in the event of employee death. Applicable to life insurance and retirement plans. May contain multiple beneficiaries with percentage allocations.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCategory rdf:type rdf:Property ;
    rdfs:label 'Benefit Category' ;
    rdfs:comment 'High-level classification of the benefit program type. Health includes medical insurance; dental includes dental insurance; vision includes vision insurance; life insurance includes basic and supplemental life coverage; disability includes short-term and long-term disability; retirement includes 401k and pension plans; flexible spending includes FSA and HSA accounts; employee assistance includes EAP programs; wellness includes gym memberships and wellness programs; supplemental includes additional voluntary benefits. [ENUM-REF-CANDIDATE: health|dental|vision|life_insurance|disability|retirement|flexible_spending|employee_assistance|wellness|supplemental — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Carrier Confirmation Date' ;
    rdfs:comment 'Date when the benefit carrier confirmed receipt and acceptance of the enrollment. Null if carrier has not yet confirmed. Used for reconciliation and issue resolution.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierGroupNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Group Number' ;
    rdfs:comment 'Group policy number assigned by the benefit carrier to identify the employer group plan. All employees under the same plan share this group number. Used for carrier billing and administration.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'Policy or member identification number assigned by the benefit carrier or insurance provider. Used for claims processing, provider verification, and coordination of benefits. Format varies by carrier.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Carrier Submission Date' ;
    rdfs:comment 'Date when the enrollment was transmitted to the benefit carrier for processing. Used to track enrollment processing timelines and ensure timely coverage activation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Flag' ;
    rdfs:comment 'Indicates whether this enrollment is eligible for COBRA continuation coverage upon termination of employment. True for health, dental, and vision plans; false for life insurance and retirement plans. Determined by plan type and company size.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraEndDate rdf:type rdf:Property ;
    rdfs:label 'Cobra End Date' ;
    rdfs:comment 'Date when COBRA continuation coverage ends. Typically 18 months after start date for termination events, 36 months for certain qualifying events. Null for active COBRA enrollments.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraStartDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Start Date' ;
    rdfs:comment 'Date when COBRA continuation coverage begins following a qualifying event such as termination of employment. Null for active employees. Typically the day after employment termination or loss of eligibility.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionBasis rdf:type rdf:Property ;
    rdfs:label 'Contribution Basis' ;
    rdfs:comment 'Tax treatment of employee contributions. Pre-tax indicates contributions reduce taxable income (Section 125 plans); post-tax indicates contributions are made with after-tax dollars; employer paid indicates no employee contribution required.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Frequency at which employee and employer contributions are deducted and remitted. Aligns with company payroll schedule. Weekly indicates 52 pay periods; biweekly indicates 26 pay periods; semimonthly indicates 24 pay periods; monthly indicates 12 pay periods; annual indicates single annual payment.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'Face value or benefit amount of the coverage for life insurance and disability plans. Represents the maximum benefit payable. For health plans, may represent out-of-pocket maximum or deductible amount. Null for plans without defined coverage amounts.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Effective Date' ;
    rdfs:comment 'Date when the benefit coverage begins and the employee is eligible to use the benefit. Typically the first day of the month following enrollment or the hire date for new employees.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage elected by the employee. Employee only covers the employee; employee spouse covers employee and spouse or domestic partner; employee children covers employee and dependent children; employee family covers employee, spouse, and dependent children.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Number of dependents covered under this enrollment. Zero for employee-only coverage. Used for premium calculation and compliance reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'Amount the employee contributes per pay period toward the benefit premium or plan cost. Deducted from employee paycheck on a pre-tax or post-tax basis depending on plan type.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'Amount the employer contributes per pay period toward the benefit premium or plan cost. Represents company subsidy of employee benefit coverage.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentConfirmationSentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Confirmation Sent Date' ;
    rdfs:comment 'Date when enrollment confirmation documentation was sent to the employee. Used for compliance tracking and audit trail. Confirmation includes coverage details, premium amounts, and effective dates.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the employee submitted the enrollment election. May differ from coverage effective date due to waiting periods or enrollment processing time.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentMethod rdf:type rdf:Property ;
    rdfs:label 'Enrollment Method' ;
    rdfs:comment 'Channel through which the employee completed the benefit enrollment. Online self service indicates Workday portal; HR representative indicates assisted enrollment; benefits fair indicates enrollment at company event; phone indicates call center enrollment; paper form indicates manual form submission; auto enrollment indicates system-generated default enrollment.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing unique enrollment reference number generated by Workday HCM Benefits module. Used for tracking and communication with employees and benefit providers.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the benefit enrollment. Active indicates coverage is in effect; pending indicates awaiting approval or effective date; terminated indicates coverage has ended; suspended indicates temporary hold; waived indicates employee declined coverage; cancelled indicates enrollment was voided.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Classification of the enrollment event that triggered this benefit enrollment. New hire indicates initial enrollment upon joining; annual open indicates enrollment during open enrollment period; qualifying life event indicates enrollment due to marriage, birth, adoption, or other qualifying event; mid year change indicates voluntary change outside open enrollment; rehire indicates enrollment upon return to company; status change indicates enrollment due to FTE or role change.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceOfInsurabilityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Required Flag' ;
    rdfs:comment 'Indicates whether the employee must provide medical evidence of insurability for coverage approval. True for supplemental life insurance above guaranteed issue amounts or late enrollments; false for standard enrollments within guaranteed issue limits.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceOfInsurabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Status' ;
    rdfs:comment 'Current status of evidence of insurability review by the insurance carrier. Not required indicates no EOI needed; pending indicates under carrier review; approved indicates coverage approved; denied indicates coverage denied due to health conditions.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Hsa Eligible Flag' ;
    rdfs:comment 'Indicates whether this health plan enrollment qualifies the employee for a Health Savings Account. True for high-deductible health plans (HDHP) meeting IRS requirements; false for traditional health plans.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfPocketMaximum rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Maximum' ;
    rdfs:comment 'Maximum amount the employee will pay in a plan year for covered services. Once reached, the plan pays 100% of covered expenses. Applicable to health plans. Required disclosure under Affordable Care Act (ACA).' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'Calendar year or fiscal year for which this enrollment is effective. Used for annual benefit plan administration, open enrollment tracking, and compliance reporting. Format YYYY.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Date' ;
    rdfs:comment 'Date when the qualifying life event occurred. Used to validate enrollment timing and compliance with 30-day or 60-day election windows required by IRS and HIPAA regulations. Null for non-QLE enrollments.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Type' ;
    rdfs:comment 'Type of qualifying life event that permitted mid-year enrollment change outside of open enrollment period. Marriage, divorce, birth, adoption, death of dependent, loss of other coverage, or change in employment status. Null for enrollments during open enrollment or new hire periods. [ENUM-REF-CANDIDATE: marriage|divorce|birth|adoption|death|loss_of_coverage|employment_change — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tobaccoUserFlag rdf:type rdf:Property ;
    rdfs:label 'Tobacco User Flag' ;
    rdfs:comment 'Indicates whether the employee is a tobacco user. Used for premium rating and wellness program eligibility. True indicates tobacco use; false indicates non-tobacco user. Self-reported by employee during enrollment.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wellnessProgramParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Wellness Program Participant Flag' ;
    rdfs:comment 'Indicates whether the employee is enrolled in the company wellness program associated with this benefit. True indicates active participation; false indicates not enrolled. May affect premium rates or provide incentive credits.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensationPlanId rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Id' ;
    rdfs:comment 'Unique identifier for the compensation plan record. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompensationPlan .

ind:collectiveBargainingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Collective Bargaining Agreement Id' ;
    rdfs:comment 'Reference to the collective bargaining agreement governing this compensation plan. Null for non-union plans.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:laborContractId rdf:type rdf:Property ;
    rdfs:label 'Labor Contract Id' ;
    rdfs:comment 'Foreign key linking to workforce.labor_contract. Business justification: Compensation plans are governed by labor contracts (individual or collective bargaining agreements). Linking compensation_plan to labor_contract provides contractual traceability and ensures compensat' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaborContract .

ind:primaryCompensationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compensation Employee Id' ;
    rdfs:comment 'Reference to the employee assigned to this compensation plan.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCompensationModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Compensation Modified By User Employee Id' ;
    rdfs:comment 'System user ID of the person who last modified this record. Used for audit trail and accountability.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Base Salary Amount' ;
    rdfs:comment 'Annual base salary amount for salaried employees. Null for hourly or commission-only plans. Expressed in plan currency.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for performance or annual bonuses under this plan. True if eligible, False otherwise.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for sales or performance commissions under this plan. True if eligible, False otherwise.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percentage' ;
    rdfs:comment 'Commission rate as a percentage of sales or revenue (e.g., 2.50 for 2.5%). Null if not commission-eligible.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Status' ;
    rdfs:comment 'Current lifecycle status of the compensation plan assignment. Active plans are in effect; inactive/terminated plans are historical.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'FLSA classification determining overtime eligibility. Exempt employees are not eligible for overtime; non-exempt employees are.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeBand rdf:type rdf:Property ;
    rdfs:label 'Grade Band' ;
    rdfs:comment 'Organizational grade or band level for this compensation plan (e.g., \'E1\', \'M3\', \'D5\'). Used for pay equity and career progression.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Hazmat Premium Amount' ;
    rdfs:comment 'Additional pay for handling hazardous materials (HAZMAT) shipments. Common for drivers and warehouse staff with HAZMAT certification.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsuranceSubsidyAmount rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Subsidy Amount' ;
    rdfs:comment 'Monthly employer subsidy toward employee health insurance premiums. Null if no subsidy provided.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Standardized job classification code associated with this compensation plan. Links to job description and competency requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mileageReimbursementRate rdf:type rdf:Property ;
    rdfs:label 'Mileage Reimbursement Rate' ;
    rdfs:comment 'Reimbursement rate per mile or kilometer for drivers using personal vehicles or for mileage-based compensation. Null if not applicable.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overnightDriverAllowance rdf:type rdf:Property ;
    rdfs:label 'Overnight Driver Allowance' ;
    rdfs:comment 'Per-night allowance for drivers on overnight or long-haul routes. Covers lodging and meals. Null if not applicable.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to hourly rate for overtime hours (e.g., 1.5 for time-and-a-half, 2.0 for double-time). Null if overtime not applicable.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'Frequency of payroll disbursement for this plan: weekly, biweekly (every two weeks), semimonthly (twice per month), or monthly.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Pay Range Maximum' ;
    rdfs:comment 'Maximum compensation amount for the grade band or plan. Ceiling for the role without promotion.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRangeMidpoint rdf:type rdf:Property ;
    rdfs:label 'Pay Range Midpoint' ;
    rdfs:comment 'Midpoint compensation amount for the grade band or plan. Target for fully competent performance in role.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Pay Range Minimum' ;
    rdfs:comment 'Minimum compensation amount for the grade band or plan. Used for pay equity analysis and compliance reporting.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemAmount rdf:type rdf:Property ;
    rdfs:label 'Per Diem Amount' ;
    rdfs:comment 'Daily allowance for meals and incidental expenses during business travel. Common for drivers and field staff. Null if not applicable.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Business identifier code for the compensation plan structure. Externally-known unique code used in payroll and HR systems.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonForChange rdf:type rdf:Property ;
    rdfs:label 'Reason For Change' ;
    rdfs:comment 'Business justification for creating or modifying this compensation plan (e.g., \'Annual merit increase\', \'Promotion to supervisor\', \'Market adjustment\').' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementContributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Retirement Contribution Percentage' ;
    rdfs:comment 'Employer contribution to retirement plan as a percentage of base salary (e.g., 5.00 for 5% match). Null if no employer contribution.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialAmount rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Amount' ;
    rdfs:comment 'Additional hourly pay for non-standard shifts (e.g., night shift, weekend shift). Null if no differential applies.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockOptionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Stock Option Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for equity compensation (stock options, RSUs) under this plan. True if eligible, False otherwise.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetBonusPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Bonus Percentage' ;
    rdfs:comment 'Target annual bonus as a percentage of base salary (e.g., 15.00 for 15%). Null if not bonus-eligible.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionAffiliationCode rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation Code' ;
    rdfs:comment 'Code identifying the labor union affiliation for this compensation plan. Null for non-union employees. Used for collective bargaining agreement (CBA) compliance.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyRecordId rdf:type rdf:Property ;
    rdfs:label 'Competency Record Id' ;
    rdfs:comment 'Unique identifier for the competency record. Primary key.' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competencyUpdatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Competency Updated By Employee Id' ;
    rdfs:comment 'Identifier of the user who last updated this competency record.' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCompetencyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Competency Employee Id' ;
    rdfs:comment 'Identifier of the employee to whom this competency record belongs. Links to the employee master data in Workday HCM.' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCompetencyVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Competency Verified By Employee Id' ;
    rdfs:comment 'Identifier of the person who verified the competency certification or credential (typically HR or compliance staff).' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text notes or comments from the assessor regarding the competency assessment, including strengths, areas for improvement, or context.' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationAuthority rdf:type rdf:Property ;
    rdfs:label 'Certification Authority' ;
    rdfs:comment 'Name of the organization or regulatory body that issued the certification (e.g., DOT, ICAO, OSHA, IATA, internal training department).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyCategory rdf:type rdf:Property ;
    rdfs:label 'Competency Category' ;
    rdfs:comment 'Detailed category or domain of the competency (e.g., Warehouse Operations, Transportation Management, Customs and Trade, Customer Service, Safety and Compliance, Leadership and Management).' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyName rdf:type rdf:Property ;
    rdfs:label 'Competency Name' ;
    rdfs:comment 'Name of the competency being assessed (e.g., Forklift Operation, WMS Proficiency, TMS Usage, Customs Classification, Leadership, Communication, Problem-Solving).' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyStatus rdf:type rdf:Property ;
    rdfs:label 'Competency Status' ;
    rdfs:comment 'Current lifecycle status of the competency record: active (valid and current), expired (past expiry date), pending_renewal (approaching expiry), suspended (temporarily invalid), or revoked (permanently invalid).' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyType rdf:type rdf:Property ;
    rdfs:label 'Competency Type' ;
    rdfs:comment 'Category of the competency: operational (forklift, WMS, TMS), professional (communication, problem-solving), technical (customs classification, EDI), leadership (team management), safety (hazmat handling), or compliance (DOT, ICAO certifications).' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Flag' ;
    rdfs:comment 'Indicates whether this competency is required for regulatory or compliance purposes (True), such as DOT driver qualifications or ICAO dangerous goods handling, or is non-regulatory (False).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:developmentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Development Plan Flag' ;
    rdfs:comment 'Indicates whether a development plan has been created to improve this competency (True) or not (False).' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapToTarget rdf:type rdf:Property ;
    rdfs:label 'Gap To Target' ;
    rdfs:comment 'Assessment of the gap between current proficiency and target proficiency: none (at or above target), minor (one level below), moderate (two levels below), or significant (three or more levels below).' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Job family or functional area to which this competency applies (e.g., Warehouse Operations, Transportation, Customs Brokerage, Customer Service, Management).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Job level or grade for which this competency is relevant (e.g., Entry, Mid, Senior, Manager, Executive).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level' ;
    rdfs:comment 'Current proficiency level of the employee in this competency: novice (beginner), intermediate (developing), advanced (proficient), expert (highly skilled), or master (subject matter expert).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyScore rdf:type rdf:Property ;
    rdfs:label 'Proficiency Score' ;
    rdfs:comment 'Numeric score representing the proficiency level, typically on a scale of 0-100 or 0-5, depending on the assessment framework used.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'Number of months between required renewals or reassessments for this competency. Null if renewal is not required.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Role Requirement Flag' ;
    rdfs:comment 'Indicates whether this competency is a formal requirement for the employees job role (True) or is an additional skill (False).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetProficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Target Proficiency Level' ;
    rdfs:comment 'Desired or target proficiency level for this competency, as defined by the employees development plan or role requirements.' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Training Cost Amount' ;
    rdfs:comment 'Total cost incurred for training and assessment to achieve this competency, including course fees, materials, and instructor costs.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Hours Completed' ;
    rdfs:comment 'Total number of training hours completed by the employee to achieve this competency level.' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingProgramName rdf:type rdf:Property ;
    rdfs:label 'Training Program Name' ;
    rdfs:comment 'Name of the training program or course completed to develop this competency.' ;
    rdfs:domain ind:CompetencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewCertificationId rdf:type rdf:Property ;
    rdfs:label 'Crew Certification Id' ;
    rdfs:comment 'Unique identifier for the crew certification record. Primary key.' ;
    rdfs:domain ind:CrewCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredBySupplierId rdf:type rdf:Property ;
    rdfs:label 'Required By Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Certifications required by specific suppliers (hazmat handling for chemical suppliers, security clearances for defense contractors). Enables supplier-mandated workforce compliance tracking, vendor-spe' ;
    rdfs:domain ind:CrewCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:airsidePassNumber rdf:type rdf:Property ;
    rdfs:label 'Airside Pass Number' ;
    rdfs:comment 'Unique identifier for the airside access pass or security badge issued to the crew member. Required for personnel working in restricted airport areas.' ;
    rdfs:domain ind:CrewCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Outcome of the certification assessment. Indicates whether the crew member met the required competency standards.' ;
    rdfs:domain ind:CrewCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalCertificateUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Certificate Url' ;
    rdfs:comment 'URL or file path to the digital copy of the certification document stored in the document management system.' ;
    rdfs:domain ind:CrewCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the certification must be renewed to avoid expiration. Used for proactive workforce planning and compliance monitoring.' ;
    rdfs:domain ind:CrewCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recertificationReason rdf:type rdf:Property ;
    rdfs:label 'Recertification Reason' ;
    rdfs:comment 'Reason why recertification is required (e.g., certification expiration, regulatory changes, incident investigation, performance concerns).' ;
    rdfs:domain ind:CrewCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictions rdf:type rdf:Property ;
    rdfs:label 'Restrictions' ;
    rdfs:comment 'Any limitations, conditions, or restrictions placed on the certification (e.g., supervised operations only, specific cargo types excluded, geographic limitations).' ;
    rdfs:domain ind:CrewCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfAuthorization rdf:type rdf:Property ;
    rdfs:label 'Scope Of Authorization' ;
    rdfs:comment 'Detailed description of the activities, operations, or cargo types the crew member is authorized to handle under this certification (e.g., Class 1 explosives, radioactive materials, lithium batteries).' ;
    rdfs:domain ind:CrewCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'Level of security clearance held by the crew member. Required for certain aviation and cargo security roles.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseCode rdf:type rdf:Property ;
    rdfs:label 'Training Course Code' ;
    rdfs:comment 'Standardized code or identifier for the training course completed by the crew member.' ;
    rdfs:domain ind:CrewCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverQualificationId rdf:type rdf:Property ;
    rdfs:label 'Driver Qualification Id' ;
    rdfs:comment 'Unique identifier for the driver qualification record. Primary key.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alcoholTestLastDate rdf:type rdf:Property ;
    rdfs:label 'Alcohol Test Last Date' ;
    rdfs:comment 'Date of the most recent alcohol test administered to the driver. Testing is required post-accident, reasonable suspicion, and return-to-duty.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alcoholTestResult rdf:type rdf:Property ;
    rdfs:label 'Alcohol Test Result' ;
    rdfs:comment 'Result of the most recent alcohol test. A positive result (BAC 0.04% or higher) or refusal disqualifies the driver.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlClass rdf:type rdf:Property ;
    rdfs:label 'Cdl Class' ;
    rdfs:comment 'The class of CDL held by the driver, determining the types of vehicles they are authorized to operate. Class A for combination vehicles, Class B for heavy straight vehicles, Class C for vehicles carrying hazardous materials or 16+ passengers.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cdl Expiration Date' ;
    rdfs:comment 'Date the CDL expires and must be renewed. Critical for maintaining operational dispatch eligibility.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdlIssueDate rdf:type rdf:Property ;
    rdfs:label 'Cdl Issue Date' ;
    rdfs:comment 'Date the current CDL was issued by the licensing authority.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdlNumber rdf:type rdf:Property ;
    rdfs:label 'Cdl Number' ;
    rdfs:comment 'The unique CDL number issued by the state licensing authority. Required for all commercial vehicle operators.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlStateIssued rdf:type rdf:Property ;
    rdfs:label 'Cdl State Issued' ;
    rdfs:comment 'Two-letter US state code where the CDL was issued. Drivers may only hold one CDL at a time per federal law.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseQueryDate rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Query Date' ;
    rdfs:comment 'Date of the most recent query to the FMCSA Drug and Alcohol Clearinghouse. Employers must conduct pre-employment queries and annual queries for all CDL drivers.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearinghouseStatus rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Status' ;
    rdfs:comment 'Current status in the FMCSA Drug and Alcohol Clearinghouse. Indicates whether any drug or alcohol violations are on record that would prohibit the driver from performing safety-sensitive functions.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationEndDate rdf:type rdf:Property ;
    rdfs:label 'Disqualification End Date' ;
    rdfs:comment 'Date the disqualification period ends and the driver may be eligible for reinstatement, if applicable. Null for permanent disqualifications.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Detailed reason if the driver is disqualified from operating commercial vehicles. Includes regulatory citation and specific violation or condition.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationStartDate rdf:type rdf:Property ;
    rdfs:label 'Disqualification Start Date' ;
    rdfs:comment 'Date the disqualification period began, if applicable.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugTestLastDate rdf:type rdf:Property ;
    rdfs:label 'Drug Test Last Date' ;
    rdfs:comment 'Date of the most recent drug test administered to the driver. FMCSA requires pre-employment, random, post-accident, reasonable suspicion, and return-to-duty testing.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endorsementDoublesTriples rdf:type rdf:Property ;
    rdfs:label 'Endorsement Doubles Triples' ;
    rdfs:comment 'Indicates whether the driver holds a valid doubles/triples endorsement (T) for towing multiple trailers.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endorsementHazmat rdf:type rdf:Property ;
    rdfs:label 'Endorsement Hazmat' ;
    rdfs:comment 'Indicates whether the driver holds a valid HAZMAT endorsement (H) allowing transport of hazardous materials as defined by IMDG and DOT regulations.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endorsementPassenger rdf:type rdf:Property ;
    rdfs:label 'Endorsement Passenger' ;
    rdfs:comment 'Indicates whether the driver holds a valid passenger endorsement (P) for operating vehicles designed to transport 16 or more passengers.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endorsementTanker rdf:type rdf:Property ;
    rdfs:label 'Endorsement Tanker' ;
    rdfs:comment 'Indicates whether the driver holds a valid tanker endorsement (N) for operating tank vehicles.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hosEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Hos Eligibility Status' ;
    rdfs:comment 'Current eligibility status for dispatch based on Hours of Service compliance. Indicates whether the driver has available hours under 11-hour driving and 14-hour on-duty limits.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hosViolationCount12m rdf:type rdf:Property ;
    rdfs:label 'Hos Violation Count 12m' ;
    rdfs:comment 'Number of HOS violations recorded in the past 12 months. Used for compliance monitoring and driver performance evaluation.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalCertificateExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Expiration Date' ;
    rdfs:comment 'Date the medical examiner\'s certificate expires. Drivers must maintain a current medical certificate to remain qualified. Typically valid for 12-24 months.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalCertificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Issue Date' ;
    rdfs:comment 'Date the medical examiner\'s certificate was issued following the driver\'s physical examination.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Number' ;
    rdfs:comment 'Unique identifier for the driver\'s medical examiner\'s certificate issued by a certified medical examiner on the National Registry.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalExaminerName rdf:type rdf:Property ;
    rdfs:label 'Medical Examiner Name' ;
    rdfs:comment 'Name of the certified medical examiner who performed the physical examination and issued the certificate.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalExaminerRegistryNumber rdf:type rdf:Property ;
    rdfs:label 'Medical Examiner Registry Number' ;
    rdfs:comment 'The unique registry number of the medical examiner on the FMCSA National Registry of Certified Medical Examiners.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalVarianceExemption rdf:type rdf:Property ;
    rdfs:label 'Medical Variance Exemption' ;
    rdfs:comment 'Type of medical variance or exemption granted by FMCSA if the driver does not meet standard physical qualification requirements but has been granted an exemption.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvrReviewDate rdf:type rdf:Property ;
    rdfs:label 'Mvr Review Date' ;
    rdfs:comment 'Date of the most recent Motor Vehicle Record review conducted by the employer. FMCSA requires annual MVR reviews for all drivers.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mvrStatus rdf:type rdf:Property ;
    rdfs:label 'Mvr Status' ;
    rdfs:comment 'Current status of the driver\'s MVR based on the most recent review. Indicates whether any violations or disqualifying offenses are present.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationFileComplete rdf:type rdf:Property ;
    rdfs:label 'Qualification File Complete' ;
    rdfs:comment 'Indicates whether the driver\'s qualification file contains all required documents per FMCSA regulations (application, MVR, medical certificate, road test, etc.).' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roadTestDate rdf:type rdf:Property ;
    rdfs:label 'Road Test Date' ;
    rdfs:comment 'Date the driver successfully completed the employer\'s road test demonstrating ability to operate the type of commercial vehicle they will drive.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roadTestExaminer rdf:type rdf:Property ;
    rdfs:label 'Road Test Examiner' ;
    rdfs:comment 'Name of the qualified examiner who administered and certified the driver\'s road test.' ;
    rdfs:domain ind:DriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugAlcoholTestId rdf:type rdf:Property ;
    rdfs:label 'Drug Alcohol Test Id' ;
    rdfs:comment 'Unique identifier for the drug and alcohol test record. Primary key for the drug_alcohol_test product.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:randomPoolId rdf:type rdf:Property ;
    rdfs:label 'Random Pool Id' ;
    rdfs:comment 'Identifier of the random testing pool from which the employee was selected for a random test. Used to track compliance with DOT minimum random testing rate requirements (50% for drugs, 10% for alcohol).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RandomPool .

ind:accidentDate rdf:type rdf:Property ;
    rdfs:label 'Accident Date' ;
    rdfs:comment 'Date of the qualifying accident that triggered a post-accident test. DOT requires post-accident testing for accidents involving fatality, bodily injury requiring immediate medical treatment, or disabling damage to a vehicle requiring tow-away.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accidentReportNumber rdf:type rdf:Property ;
    rdfs:label 'Accident Report Number' ;
    rdfs:comment 'Official accident or incident report number associated with a post-accident test. Links the test record to the accident investigation file.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alcoholConcentration rdf:type rdf:Property ;
    rdfs:label 'Alcohol Concentration' ;
    rdfs:comment 'Measured blood alcohol concentration (BAC) level expressed as a decimal (e.g., 0.040 for 0.04%). DOT prohibits safety-sensitive duties at 0.04% or higher. Null if alcohol test was not performed or result was refused/cancelled.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alcoholResult rdf:type rdf:Property ;
    rdfs:label 'Alcohol Result' ;
    rdfs:comment 'Specific result of the alcohol component of the test. Separated from drug result for tests that include both categories.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlRequired rdf:type rdf:Property ;
    rdfs:label 'Cdl Required' ;
    rdfs:comment 'Indicates whether the employee is required to hold a valid Commercial Driver License (CDL) for the position being tested. CDL holders are subject to FMCSA drug and alcohol testing regulations.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chainOfCustodyNumber rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Number' ;
    rdfs:comment 'Unique chain of custody form number that tracks the specimen from collection through laboratory analysis. Critical for maintaining specimen integrity and legal defensibility of test results.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteCode rdf:type rdf:Property ;
    rdfs:label 'Collection Site Code' ;
    rdfs:comment 'Standardized code identifying the collection site. Used for vendor management and compliance reporting.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteName rdf:type rdf:Property ;
    rdfs:label 'Collection Site Name' ;
    rdfs:comment 'Name of the facility or location where the specimen was collected. May be an on-site clinic, third-party collection facility, or mobile testing unit.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectorName rdf:type rdf:Property ;
    rdfs:label 'Collector Name' ;
    rdfs:comment 'Name of the trained specimen collector who performed the collection. Required for chain of custody documentation.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceYear rdf:type rdf:Property ;
    rdfs:label 'Compliance Year' ;
    rdfs:comment 'Calendar year in which the test was conducted. Used for annual DOT compliance reporting and random testing rate calculations.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drugResult rdf:type rdf:Property ;
    rdfs:label 'Drug Result' ;
    rdfs:comment 'Specific result of the drug component of the test. Separated from alcohol result for tests that include both categories.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFunctionTested rdf:type rdf:Property ;
    rdfs:label 'Job Function Tested' ;
    rdfs:comment 'Specific safety-sensitive job function for which the employee was tested (e.g., commercial driver, aircraft pilot, flight attendant, aircraft maintenance technician, warehouse forklift operator). Used for compliance reporting by job category.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryCode rdf:type rdf:Property ;
    rdfs:label 'Laboratory Code' ;
    rdfs:comment 'Standardized code identifying the HHS-certified laboratory. Used for vendor management and quality assurance.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the Department of Health and Human Services (HHS) certified laboratory that analyzed the specimen.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mroName rdf:type rdf:Property ;
    rdfs:label 'Mro Name' ;
    rdfs:comment 'Name of the licensed physician Medical Review Officer who reviewed and verified the test result. MRO is responsible for determining if there is a legitimate medical explanation for a positive result.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mroVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Mro Verification Date' ;
    rdfs:comment 'Date on which the MRO completed verification of the test result and communicated the final determination to the employer.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mroVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Mro Verification Status' ;
    rdfs:comment 'Status of the MRO verification process. Verified indicates MRO has completed review; pending indicates review is in progress; unable to contact indicates employee did not respond to MRO contact attempts; cancelled by MRO indicates test was invalidated during MRO review.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomSelectionDate rdf:type rdf:Property ;
    rdfs:label 'Random Selection Date' ;
    rdfs:comment 'Date on which the employee was randomly selected for testing. Used to verify unannounced nature of random tests and compliance with selection procedures.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reasonableSuspicionBasis rdf:type rdf:Property ;
    rdfs:label 'Reasonable Suspicion Basis' ;
    rdfs:comment 'Documented observations and specific, contemporaneous, articulable facts that led a trained supervisor to require a reasonable suspicion test. May include appearance, behavior, speech, or body odor consistent with substance use.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Record Retention Date' ;
    rdfs:comment 'Date through which this test record must be retained to meet DOT recordkeeping requirements. DOT requires retention of positive and refusal records for 5 years; negative records for 1 year; records of employee refusals to test for 5 years.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refusalReason rdf:type rdf:Property ;
    rdfs:label 'Refusal Reason' ;
    rdfs:comment 'Documented reason for a refused test result. May include failure to provide sufficient specimen, failure to remain at collection site, adulterating or substituting specimen, failure to cooperate with testing process, or explicit refusal. A refusal is treated as a positive result under DOT regulations.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySensitivePosition rdf:type rdf:Property ;
    rdfs:label 'Safety Sensitive Position' ;
    rdfs:comment 'Indicates whether the employee holds a DOT-defined safety-sensitive position at the time of testing. Only safety-sensitive employees are subject to DOT drug and alcohol testing requirements.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapEvaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Sap Evaluation Status' ;
    rdfs:comment 'Current status of the SAP evaluation and treatment process. Not required for negative tests; pending indicates referral made but evaluation not started; in progress indicates employee is undergoing treatment; completed indicates SAP has cleared employee for return-to-duty testing; non-compliant indicates employee failed to complete SAP requirements.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapName rdf:type rdf:Property ;
    rdfs:label 'Sap Name' ;
    rdfs:comment 'Name of the qualified Substance Abuse Professional (licensed physician, social worker, psychologist, or addiction counselor) to whom the employee was referred for evaluation and treatment.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapReferralDate rdf:type rdf:Property ;
    rdfs:label 'Sap Referral Date' ;
    rdfs:comment 'Date on which the employee was referred to a Substance Abuse Professional following a positive or refused test result.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapReferralRequired rdf:type rdf:Property ;
    rdfs:label 'Sap Referral Required' ;
    rdfs:comment 'Indicates whether the employee must be referred to a Substance Abuse Professional for evaluation and treatment. Required for all positive, refused, and adulterated test results before the employee can return to safety-sensitive duties.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specimenNumber rdf:type rdf:Property ;
    rdfs:label 'Specimen Number' ;
    rdfs:comment 'Unique identifier assigned to the specimen by the collection site or laboratory. Used to maintain chain of custody and link test results to the employee while preserving confidentiality.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenType rdf:type rdf:Property ;
    rdfs:label 'Specimen Type' ;
    rdfs:comment 'Type of biological specimen collected for testing. Urine is standard for drug tests; breath is standard for alcohol tests; blood, saliva, and hair may be used in specific circumstances or for extended detection windows.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substancesDetected rdf:type rdf:Property ;
    rdfs:label 'Substances Detected' ;
    rdfs:comment 'List of specific controlled substances or drug classes detected in a positive drug test (e.g., marijuana, cocaine, opiates, amphetamines, phencyclidine). Null for negative or alcohol-only tests.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCategory rdf:type rdf:Property ;
    rdfs:label 'Test Category' ;
    rdfs:comment 'Category of substance tested: drug only, alcohol only, or both drug and alcohol in a combined testing event.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date on which the drug and alcohol test specimen was collected. This is the principal business event date for the test record.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testNumber rdf:type rdf:Property ;
    rdfs:label 'Test Number' ;
    rdfs:comment 'Externally-known unique test number or specimen identifier assigned by the testing facility or Medical Review Officer (MRO). Used for tracking and audit purposes.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Final result of the drug and alcohol test. Negative indicates no prohibited substances detected; positive indicates presence of prohibited substances above cutoff levels; refused indicates employee declined to provide specimen; cancelled indicates test was invalidated due to procedural error; invalid indicates specimen could not be analyzed.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the test record. Tracks the test from scheduling through final verification and record completion. [ENUM-REF-CANDIDATE: scheduled|specimen collected|in transit|at laboratory|under review|verified|completed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Timestamp' ;
    rdfs:comment 'Precise date and time when the specimen collection occurred. Used for post-accident testing timeline compliance and audit trail.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Type of drug and alcohol test conducted. Pre-employment tests are conducted before hire; random tests are unannounced selections from the pool; post-accident tests follow qualifying incidents; reasonable suspicion tests are based on observed behavior; return-to-duty tests are required before returning after a positive result; follow-up tests are part of a monitoring program.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingVendorCode rdf:type rdf:Property ;
    rdfs:label 'Testing Vendor Code' ;
    rdfs:comment 'Identifier of the third-party vendor or consortium that manages the drug and alcohol testing program. Used for vendor performance tracking and invoice reconciliation.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Employee\'s date of birth, used for age verification for regulatory compliance (e.g., DOT driver age requirements, ICAO crew qualifications) and benefits eligibility.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotMedicalCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Dot Medical Certification Date' ;
    rdfs:comment 'Date of the most recent DOT medical examination certification for commercial drivers. Required for compliance with US DOT Federal Motor Carrier Safety Administration regulations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotMedicalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Dot Medical Expiry Date' ;
    rdfs:comment 'Expiration date of the employee\'s DOT medical certification. Drivers must maintain valid medical certification to operate commercial vehicles.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:driverLicenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Driver License Expiry Date' ;
    rdfs:comment 'Expiration date of the employee\'s driver\'s license. Critical for DOT compliance monitoring and ensuring only qualified drivers operate vehicles.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:driverLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Driver License Number' ;
    rdfs:comment 'Driver\'s license number for employees in driving roles (delivery drivers, freight drivers). Required for DOT compliance and fleet management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'Human-readable business identifier for the employee, typically displayed on badges and used in operational systems. Externally-known unique code assigned at hire.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the employee within the organization. Indicates whether the employee is actively working, on leave, suspended, or separated from the company.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forkliftCertification rdf:type rdf:Property ;
    rdfs:label 'Forklift Certification' ;
    rdfs:comment 'Indicates whether the employee is certified to operate forklifts and material handling equipment in warehouse and distribution center operations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fte rdf:type rdf:Property ;
    rdfs:label 'Fte' ;
    rdfs:comment 'Full-Time Equivalent designation representing the proportion of full-time work this employee performs (e.g., 1.00 for full-time, 0.50 for half-time). Used for workforce capacity planning and labor cost allocation.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatCertification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certification' ;
    rdfs:comment 'Indicates whether the employee holds valid hazardous materials handling certification, required for transporting dangerous goods per IMDG Code and ICAO Technical Instructions.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the employee\'s HAZMAT certification. Must be renewed periodically to maintain compliance with dangerous goods transport regulations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the employee, if applicable, as recorded in official employment documents.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number (e.g., Social Security Number in USA, National Insurance Number in UK) used for tax reporting and employment verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'Passport number for employees requiring international travel for cross-border shipping operations, customs brokerage, or global freight forwarding assignments.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Compensation grade or band assigned to the employee\'s position, defining the salary range and compensation structure. Business-sensitive data used for compensation planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payType rdf:type rdf:Property ;
    rdfs:label 'Pay Type' ;
    rdfs:comment 'Method by which the employee is compensated (salary, hourly, commission, piece rate). Critical for payroll processing and labor cost calculation.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Name the employee prefers to be called in day-to-day business interactions, which may differ from legal name.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Code identifying the specific labor union to which the employee belongs, if applicable. Used for labor agreement compliance and union dues processing.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMembership rdf:type rdf:Property ;
    rdfs:label 'Union Membership' ;
    rdfs:comment 'Indicates whether the employee is a member of a labor union. Important for collective bargaining compliance, labor relations, and workforce management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workCity rdf:type rdf:Property ;
    rdfs:label 'Work City' ;
    rdfs:comment 'City where the employee\'s primary work location is situated. Used for geographic workforce distribution analysis and regional labor planning.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCountry rdf:type rdf:Property ;
    rdfs:label 'Work Country' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the employee primarily works. Used for regulatory compliance, tax reporting, and workforce analytics.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocation rdf:type rdf:Property ;
    rdfs:label 'Work Location' ;
    rdfs:comment 'Primary physical work location or facility where the employee is based (e.g., warehouse, distribution center, office, terminal, depot). Critical for workforce scheduling and labor planning.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftePlanId rdf:type rdf:Property ;
    rdfs:label 'Fte Plan Id' ;
    rdfs:comment 'Unique identifier for the FTE plan record. Primary key for workforce planning headcount targets.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtePlan .

ind:planVersionId rdf:type rdf:Property ;
    rdfs:label 'Plan Version Id' ;
    rdfs:comment 'Reference to the workforce planning version or scenario. Links to the planning cycle and version control for what-if analysis and multi-scenario planning.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:actualFte rdf:type rdf:Property ;
    rdfs:label 'Actual Fte' ;
    rdfs:comment 'Current actual FTE headcount as of the measurement date. Used to calculate variance against plan and track hiring execution.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageSalary rdf:type rdf:Property ;
    rdfs:label 'Average Salary' ;
    rdfs:comment 'Average annual salary per FTE for this job family and location. Used for labor cost modeling and budget planning.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Budget Authorization Date' ;
    rdfs:comment 'Date when the FTE plan and associated labor budget were formally authorized by finance and executive leadership.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalPlanCode rdf:type rdf:Property ;
    rdfs:label 'External Plan Code' ;
    rdfs:comment 'Unique identifier for this FTE plan in the source system. Enables traceability and reconciliation with upstream HCM system.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hiringPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Hiring Plan Status' ;
    rdfs:comment 'Current status of the hiring plan execution for this FTE plan. Tracks progress from approval through fulfillment.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalRole rdf:type rdf:Property ;
    rdfs:label 'Is Critical Role' ;
    rdfs:comment 'Indicates whether this position is classified as business-critical for operational continuity. Prioritizes hiring and succession planning for key roles.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemoteEligible rdf:type rdf:Property ;
    rdfs:label 'Is Remote Eligible' ;
    rdfs:comment 'Indicates whether the planned position is eligible for remote or hybrid work arrangements. Expands talent pool for non-operational roles.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetySensitive rdf:type rdf:Property ;
    rdfs:label 'Is Safety Sensitive' ;
    rdfs:comment 'Indicates whether the planned position is classified as safety-sensitive under DOT or ICAO regulations. Requires additional compliance tracking for driver and crew roles.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobProfileCode rdf:type rdf:Property ;
    rdfs:label 'Job Profile Code' ;
    rdfs:comment 'Standardized job profile or role code from the enterprise job catalog. Used for competency mapping and labor cost modeling.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum education level required for the planned position. Used for talent acquisition planning and candidate screening.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'Minimum years of relevant work experience required for the planned position. Guides recruitment strategy and compensation planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openPositions rdf:type rdf:Property ;
    rdfs:label 'Open Positions' ;
    rdfs:comment 'Number of approved but unfilled positions within this FTE plan. Tracks hiring pipeline and recruitment needs.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Effective end date for this FTE plan record. Defines the planning horizon and enables time-phased workforce planning.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text notes and comments regarding the FTE plan. Captures business justification, special considerations, and planning assumptions.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Effective start date for this FTE plan record. Defines when the planned headcount target becomes active.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedFte rdf:type rdf:Property ;
    rdfs:label 'Planned Fte' ;
    rdfs:comment 'Target FTE headcount approved for this organizational unit, job family, and planning period. Represents the authorized workforce capacity level.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningPeriod rdf:type rdf:Property ;
    rdfs:label 'Planning Period' ;
    rdfs:comment 'Time period identifier for the workforce plan (e.g., 2024-Q1, 2024-FY, 2024-01). Supports annual, quarterly, and monthly planning cycles.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresDotCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Dot Certification' ;
    rdfs:comment 'Indicates whether the planned position requires DOT certification (e.g., CDL for drivers). Impacts hiring requirements and compliance planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeType rdf:type rdf:Property ;
    rdfs:label 'Time Type' ;
    rdfs:comment 'Employment time type for the planned FTE. Distinguishes permanent full-time from part-time, contractor, and seasonal workforce.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Percentage of time the position requires business travel. Relevant for sales, operations management, and field service roles.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFte rdf:type rdf:Property ;
    rdfs:label 'Variance Fte' ;
    rdfs:comment 'Difference between planned and actual FTE (actual minus planned). Positive variance indicates overstaffing; negative indicates understaffing or open positions.' ;
    rdfs:domain ind:FtePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workShift rdf:type rdf:Property ;
    rdfs:label 'Work Shift' ;
    rdfs:comment 'Primary work shift for the planned FTE. Critical for 24/7 operations planning in freight terminals, warehouses, and last-mile delivery.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursOfServiceLogId rdf:type rdf:Property ;
    rdfs:label 'Hours Of Service Log Id' ;
    rdfs:comment 'Unique identifier for the hours of service log record. Primary key for the HOS log entry.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHoursDriverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Hours Driver Employee Id' ;
    rdfs:comment 'Reference to the commercial driver employee who generated this HOS record. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryHoursEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Hours Employee Id' ;
    rdfs:comment 'Identifier of the user (driver or supervisor) who made edits to this log entry. Required for audit trail and accountability.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annotationText rdf:type rdf:Property ;
    rdfs:label 'Annotation Text' ;
    rdfs:comment 'Free-text annotation or comment added by the driver to explain special circumstances, duty status changes, or other relevant information for this log entry.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleHoursAccumulated rdf:type rdf:Property ;
    rdfs:label 'Cycle Hours Accumulated' ;
    rdfs:comment 'Cumulative on-duty hours for the current 7-day or 8-day cycle. Used to enforce the 60-hour/7-day or 70-hour/8-day limits per DOT regulations.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'The regulatory cycle the driver is operating under. 60-hour/7-day cycle for drivers who do not operate every day of the week. 70-hour/8-day cycle for drivers who operate every day of the week.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Dispatch Eligibility Flag' ;
    rdfs:comment 'Indicates whether the driver is eligible for new dispatch assignments based on current HOS status. True if eligible, False if driver has insufficient hours remaining.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distanceTraveled rdf:type rdf:Property ;
    rdfs:label 'Distance Traveled' ;
    rdfs:comment 'Total distance traveled in miles or kilometers during this duty status segment. Calculated from odometer readings or GPS tracking.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drivingHoursAccumulated rdf:type rdf:Property ;
    rdfs:label 'Driving Hours Accumulated' ;
    rdfs:comment 'Cumulative driving hours for the current duty period up to and including this log entry. Used to enforce the 11-hour driving limit per DOT regulations.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:editedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edited Timestamp' ;
    rdfs:comment 'The date and time when this log entry was last edited. Part of the required audit trail for DOT compliance.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eldRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Eld Registration Number' ;
    rdfs:comment 'The FMCSA registration identifier for the ELD device. Required for DOT compliance verification.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeTerminalTimeZone rdf:type rdf:Property ;
    rdfs:label 'Home Terminal Time Zone' ;
    rdfs:comment 'The time zone of the driver\'s home terminal. HOS calculations are based on home terminal time per DOT regulations.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursRemainingInCycle rdf:type rdf:Property ;
    rdfs:label 'Hours Remaining In Cycle' ;
    rdfs:comment 'Calculated number of hours remaining in the current 60/70-hour cycle before the driver must take a 34-hour restart. Used for weekly dispatch planning.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursRemainingOnDuty rdf:type rdf:Property ;
    rdfs:label 'Hours Remaining On Duty' ;
    rdfs:comment 'Calculated number of on-duty hours remaining before the driver reaches the 14-hour on-duty limit. Used for dispatch planning and route optimization.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursRemainingToDrive rdf:type rdf:Property ;
    rdfs:label 'Hours Remaining To Drive' ;
    rdfs:comment 'Calculated number of driving hours remaining before the driver reaches the 11-hour driving limit. Used for dispatch planning and load assignment.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logEntryMethod rdf:type rdf:Property ;
    rdfs:label 'Log Entry Method' ;
    rdfs:comment 'The method by which this HOS record was created. Automatic ELD: captured automatically by electronic logging device. Manual ELD: driver manually entered via ELD interface. Paper Log: transcribed from paper logbook for legacy compliance.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerReadingEnd rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading End' ;
    rdfs:comment 'Vehicle odometer reading in miles or kilometers at the end of this duty status segment. Used to calculate distance traveled during the segment.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odometerReadingStart rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading Start' ;
    rdfs:comment 'Vehicle odometer reading in miles or kilometers at the start of this duty status segment. Used for distance verification and compliance auditing.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onDutyHoursAccumulated rdf:type rdf:Property ;
    rdfs:label 'On Duty Hours Accumulated' ;
    rdfs:comment 'Cumulative on-duty hours (driving plus on-duty not driving) for the current duty period. Used to enforce the 14-hour on-duty limit per DOT regulations.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restBreakCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Rest Break Compliant Flag' ;
    rdfs:comment 'Indicates whether the driver has taken the required 30-minute rest break within the first 8 hours of driving. True if compliant, False if violation.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'The shipment or load number associated with this duty period. Links HOS records to freight operations for dispatch and billing purposes.' ;
    rdfs:domain ind:HoursOfServiceLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToJobProfileId rdf:type rdf:Property ;
    rdfs:label 'Reports To Job Profile Id' ;
    rdfs:comment 'Identifier of the job profile to which this role typically reports in the organizational hierarchy. Defines standard reporting relationships for organizational design.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:educationLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Education Level Required' ;
    rdfs:comment 'Minimum educational qualification required for the job profile, ranging from high school diploma to advanced degrees or professional certifications. [ENUM-REF-CANDIDATE: high_school|associate|bachelor|master|doctorate|professional_certification|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerFacing rdf:type rdf:Property ;
    rdfs:label 'Is Customer Facing' ;
    rdfs:comment 'Indicates whether the job profile involves direct interaction with external customers, affecting training requirements and service level expectations.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionEligible rdf:type rdf:Property ;
    rdfs:label 'Is Union Eligible' ;
    rdfs:comment 'Indicates whether the job profile is eligible for union membership or collective bargaining representation, affecting labor relations and compensation structures.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCategory rdf:type rdf:Property ;
    rdfs:label 'Job Category' ;
    rdfs:comment 'Classification of the job based on the nature of work performed, distinguishing between operational, administrative, technical, managerial, and executive roles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Comprehensive description of the job role, including key responsibilities, duties, reporting relationships, and performance expectations. Used in job postings and employee onboarding.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Job Profile Status' ;
    rdfs:comment 'Current lifecycle status of the job profile. Active profiles are available for position creation; inactive or obsolete profiles are retained for historical reference only.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyResponsibilities rdf:type rdf:Property ;
    rdfs:label 'Key Responsibilities' ;
    rdfs:comment 'Summary of the primary duties and accountabilities associated with the job profile. Used for performance management and role clarity.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSalary rdf:type rdf:Property ;
    rdfs:label 'Max Salary' ;
    rdfs:comment 'Maximum annual salary for the job profile within the assigned pay grade. Defines the upper limit for compensation within this role.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSalary rdf:type rdf:Property ;
    rdfs:label 'Min Salary' ;
    rdfs:comment 'Minimum annual salary for the job profile within the assigned pay grade. Used for compensation benchmarking and offer generation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Min Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for the job profile. Used in recruitment and candidate screening.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalRequirements rdf:type rdf:Property ;
    rdfs:label 'Physical Requirements' ;
    rdfs:comment 'Description of physical demands and working conditions associated with the job, such as lifting requirements, standing duration, exposure to weather, or operation of heavy equipment. Used for ADA compliance and workplace safety.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCompetencies rdf:type rdf:Property ;
    rdfs:label 'Required Competencies' ;
    rdfs:comment 'List of skills, knowledge areas, and behavioral competencies required for successful performance in the job role. Used for talent assessment and development planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCustomsBrokerLicense rdf:type rdf:Property ;
    rdfs:label 'Requires Customs Broker License' ;
    rdfs:comment 'Indicates whether the job profile requires a licensed customs broker credential for managing customs declarations and trade compliance activities.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDotQualification rdf:type rdf:Property ;
    rdfs:label 'Requires Dot Qualification' ;
    rdfs:comment 'Indicates whether the job profile requires US Department of Transportation driver qualification and medical certification for commercial vehicle operation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresForkliftCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Forklift Certification' ;
    rdfs:comment 'Indicates whether the job profile requires forklift operator certification for warehouse and distribution center operations.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresHazmatEndorsement rdf:type rdf:Property ;
    rdfs:label 'Requires Hazmat Endorsement' ;
    rdfs:comment 'Indicates whether the job profile requires a HAZMAT endorsement on commercial driver license for transporting hazardous materials.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresIataDgCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Iata Dg Certification' ;
    rdfs:comment 'Indicates whether the job profile requires IATA Dangerous Goods handling certification for air freight operations involving hazardous materials.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSecurityClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Security Clearance' ;
    rdfs:comment 'Indicates whether the job profile requires security clearance or background screening for roles with access to sensitive cargo, facilities, or data.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelRequirementPct rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Pct' ;
    rdfs:comment 'Percentage of work time expected to involve business travel. Used for role expectations and expense planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workScheduleType rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Type' ;
    rdfs:comment 'Standard work schedule pattern for the job profile, indicating whether the role is full-time, part-time, shift-based, on-call, or seasonal.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualLeaveDays rdf:type rdf:Property ;
    rdfs:label 'Annual Leave Days' ;
    rdfs:comment 'Number of paid annual leave (vacation) days per year granted under this contract. May increase with tenure.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cbaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Cba Reference Number' ;
    rdfs:comment 'Reference number of the applicable collective bargaining agreement if this contract is governed by a union CBA. Null for non-union individual contracts.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Months' ;
    rdfs:comment 'Total duration of the contract in months. Applicable primarily to fixed-term contracts. Null for permanent or open-ended contracts.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Full-time equivalent allocation for this contract, expressed as a decimal (e.g., 1.0000 for full-time, 0.5000 for half-time). Used for workforce planning and budgeting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsuranceCoverage rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Coverage' ;
    rdfs:comment 'Level of health insurance coverage provided under this contract. Indicates whether coverage extends to employee only, employee and spouse, or full family.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for overtime pay under this contract. True for non-exempt employees; false for exempt employees.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:probationEndDate rdf:type rdf:Property ;
    rdfs:label 'Probation End Date' ;
    rdfs:comment 'Date when the probationary period ends and full employment terms take effect. Calculated from effective start date and probation period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redundancyTerms rdf:type rdf:Property ;
    rdfs:label 'Redundancy Terms' ;
    rdfs:comment 'Contractual terms governing severance pay, notice period, and entitlements in the event of redundancy or layoff. May reference statutory minimums or enhanced provisions.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether this contract is eligible for renewal upon expiration. Applicable primarily to fixed-term contracts.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severancePayWeeks rdf:type rdf:Property ;
    rdfs:label 'Severance Pay Weeks' ;
    rdfs:comment 'Number of weeks of base pay provided as severance in the event of involuntary termination or redundancy. May vary by tenure and jurisdiction.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sickLeaveDays rdf:type rdf:Property ;
    rdfs:label 'Sick Leave Days' ;
    rdfs:comment 'Number of paid sick leave days per year granted under this contract. May be statutory or enhanced.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Standard Hours Per Week' ;
    rdfs:comment 'Contractually agreed standard working hours per week. Used to determine full-time equivalent (FTE) allocation and overtime thresholds.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionName rdf:type rdf:Property ;
    rdfs:label 'Union Name' ;
    rdfs:comment 'Full name of the labor union representing the employee. Null for non-union employees.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationCode rdf:type rdf:Property ;
    rdfs:label 'Work Location Code' ;
    rdfs:comment 'Code identifying the primary work location or facility where the employee performs duties under this contract. Links to location master data.' ;
    rdfs:domain ind:LaborContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for the labor cost allocation record.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Payroll Record Id' ;
    rdfs:comment 'Foreign key linking to workforce.payroll_record. Business justification: Labor cost allocations are derived from payroll records. One payroll_record may generate multiple labor_cost_allocation records when an employee\'s time is split across multiple cost centers, projects,' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRecord .

ind:allocatedHours rdf:type rdf:Property ;
    rdfs:label 'Allocated Hours' ;
    rdfs:comment 'The number of hours allocated to this cost center, operational function, or customer contract, calculated as hours_worked multiplied by allocation_percentage.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The basis or driver used for allocating labor costs, such as hours worked, headcount, revenue generated, transaction volume, or facility square footage. [ENUM-REF-CANDIDATE: hours|headcount|revenue|volume|square_footage|transactions|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The method used to determine the allocation percentage, such as manual entry, time tracking system, activity-based costing, or default percentage split.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitsAmount rdf:type rdf:Property ;
    rdfs:label 'Benefits Amount' ;
    rdfs:comment 'The portion of the allocated amount representing employer-paid benefits (health insurance, retirement contributions, etc.) for the pay period.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightMode rdf:type rdf:Property ;
    rdfs:label 'Freight Mode' ;
    rdfs:comment 'The freight transportation mode to which the labor cost is allocated, if applicable to freight forwarding operations.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'The total number of hours worked by the employee during the pay period that are being allocated.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCapitalized rdf:type rdf:Property ;
    rdfs:label 'Is Capitalized' ;
    rdfs:comment 'Indicates whether this allocated labor cost is capitalized as Capital Expenditure (CAPEX) rather than expensed as Operating Expenditure (OPEX), typically for project or asset development work.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalFunction rdf:type rdf:Property ;
    rdfs:label 'Operational Function' ;
    rdfs:comment 'The specific operational function or business process to which the labor cost is allocated, aligning with core business processes. [ENUM-REF-CANDIDATE: express_parcel_delivery|freight_forwarding|warehouse_operations|last_mile_delivery|customs_brokerage|fleet_management|customer_service|administration|sales|it_support — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeAmount rdf:type rdf:Property ;
    rdfs:label 'Overtime Amount' ;
    rdfs:comment 'The portion of the allocated amount representing overtime pay for the pay period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last day of the payroll period for which labor costs are being allocated.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first day of the payroll period for which labor costs are being allocated.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalLaborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Labor Cost Amount' ;
    rdfs:comment 'The total labor cost for the employee during the pay period, including base salary, overtime, bonuses, and employer-paid benefits, before allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy. Enables multi-level organizational structure from enterprise down to team level.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:budgetAmountAnnual rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Annual' ;
    rdfs:comment 'Annual operating budget allocated to this organizational unit in USD. Used for financial planning and variance analysis.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalOrgCode rdf:type rdf:Property ;
    rdfs:label 'External Org Code' ;
    rdfs:comment 'External system identifier for this organizational unit used in integrations with ERP, TMS, WMS, and other operational systems.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountActual rdf:type rdf:Property ;
    rdfs:label 'Headcount Actual' ;
    rdfs:comment 'Current actual headcount for this organizational unit expressed in FTE. Calculated from active employee assignments.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountPlanned rdf:type rdf:Property ;
    rdfs:label 'Headcount Planned' ;
    rdfs:comment 'Planned headcount for this organizational unit expressed in FTE. Used for workforce planning and budget allocation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orgUnitCode rdf:type rdf:Property ;
    rdfs:label 'Org Unit Code' ;
    rdfs:comment 'Business identifier code for the organizational unit. Used for external reporting and integration with financial systems.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organizational unit\'s purpose, responsibilities, and scope of operations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitName rdf:type rdf:Property ;
    rdfs:label 'Org Unit Name' ;
    rdfs:comment 'Full name of the organizational unit as displayed in business reports and organizational charts.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. Active units are operational and can have employees assigned.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitType rdf:type rdf:Property ;
    rdfs:label 'Org Unit Type' ;
    rdfs:comment 'Classification of the organizational unit indicating its level and function within the enterprise hierarchy.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name of the organizational unit for use in constrained display contexts and reports.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresentation rdf:type rdf:Property ;
    rdfs:label 'Union Representation' ;
    rdfs:comment 'Indicates whether employees in this organizational unit are represented by labor unions. Impacts labor relations and compliance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Identifier of the payroll processing batch or run that generated this record. Links to the payroll run master.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:payrollSupplierId rdf:type rdf:Property ;
    rdfs:label 'Payroll Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Payroll processed by third-party payroll suppliers (ADP, Paychex, regional payroll providers). Enables payroll vendor cost allocation, supplier-specific payroll tracking, payroll service procurement m' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:allowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Allowance Amount' ;
    rdfs:comment 'Total allowances paid, including transportation, housing, meal, mobile, or other employee allowances.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Benefit Deduction Amount' ;
    rdfs:comment 'Total employee-paid benefit deductions including health insurance, dental, vision, life insurance, and retirement contributions.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Total commission earnings for sales or performance-based roles during the pay period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerBenefitContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Benefit Contribution Amount' ;
    rdfs:comment 'Total employer contributions to employee benefits including retirement matching, health insurance subsidies, and other employer-paid benefits.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Tax Amount' ;
    rdfs:comment 'Total employer-paid payroll taxes including employer portion of social security, medicare, unemployment, and other statutory taxes.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Federal Tax Amount' ;
    rdfs:comment 'Federal income tax withheld from gross pay for the pay period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garnishmentAmount rdf:type rdf:Property ;
    rdfs:label 'Garnishment Amount' ;
    rdfs:comment 'Total wage garnishments for child support, tax levies, or court-ordered deductions.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Pay Amount' ;
    rdfs:comment 'Total gross earnings before any deductions, including base salary, overtime, bonuses, and allowances.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsuranceDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Deduction Amount' ;
    rdfs:comment 'Employee-paid portion of health insurance premiums deducted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Local Tax Amount' ;
    rdfs:comment 'Local or municipal income tax withheld from gross pay for the pay period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicareTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax Amount' ;
    rdfs:comment 'Medicare tax withheld from gross pay for the pay period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayAmount rdf:type rdf:Property ;
    rdfs:label 'Net Pay Amount' ;
    rdfs:comment 'Final take-home pay after all deductions, representing the amount paid to the employee.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Other Deduction Amount' ;
    rdfs:comment 'Miscellaneous deductions not categorized elsewhere, such as union dues, loan repayments, or voluntary contributions.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Total number of overtime hours worked during the pay period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payDate rdf:type rdf:Property ;
    rdfs:label 'Pay Date' ;
    rdfs:comment 'The date on which payment was issued or scheduled to be issued to the employee.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Payroll Approved By' ;
    rdfs:comment 'User ID or name of the payroll administrator who approved this payroll record for payment.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payroll Approved Timestamp' ;
    rdfs:comment 'The date and time when this payroll record was approved for payment.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payrollProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed Timestamp' ;
    rdfs:comment 'The date and time when this payroll record was calculated and finalized in the payroll system.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payrollStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Status' ;
    rdfs:comment 'Current processing status of the payroll record in the payroll lifecycle.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoHoursUsed rdf:type rdf:Property ;
    rdfs:label 'Pto Hours Used' ;
    rdfs:comment 'Number of paid time off hours taken during the pay period, including vacation, sick leave, and personal days.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptoPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Pto Payout Amount' ;
    rdfs:comment 'Monetary value of PTO hours paid out during the pay period, either as part of regular pay or upon termination.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Regular Hours Worked' ;
    rdfs:comment 'Total number of regular (non-overtime) hours worked during the pay period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Retirement Contribution Amount' ;
    rdfs:comment 'Employee contribution to retirement plans such as 401(k), 403(b), or pension plans.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax Amount' ;
    rdfs:comment 'Social security tax (FICA) withheld from gross pay for the pay period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateTaxAmount rdf:type rdf:Property ;
    rdfs:label 'State Tax Amount' ;
    rdfs:comment 'State income tax withheld from gross pay for the pay period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Deductions Amount' ;
    rdfs:comment 'Sum of all deductions from gross pay, including taxes, benefits, garnishments, and other withholdings.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Identifier of the primary reviewer, typically the direct manager or supervisor conducting the performance evaluation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Worker Assignment Id' ;
    rdfs:comment 'Foreign key linking to workforce.worker_assignment. Business justification: Performance reviews are conducted in the context of a specific worker assignment. While performance_review already has employee_id and position_id, linking to worker_assignment provides the full assig' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkerAssignment .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'Date when the employee acknowledged receipt and review of their performance evaluation. Confirms the employee has been informed of the review outcome.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee has acknowledged their performance review. True indicates the employee has reviewed and acknowledged the evaluation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusPayoutPercentage rdf:type rdf:Property ;
    rdfs:label 'Bonus Payout Percentage' ;
    rdfs:comment 'Percentage of target bonus to be paid out based on performance review results. Expressed as a percentage of the employees target bonus amount. Business-confidential data.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date when the performance review rating was calibrated with peer managers. Ensures consistency in rating standards across teams and departments.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Status indicating whether the performance review has undergone calibration with peer managers to ensure rating consistency and fairness across the organization.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyRatingScore rdf:type rdf:Property ;
    rdfs:label 'Competency Rating Score' ;
    rdfs:comment 'Aggregate numeric score representing the employees demonstration of core competencies and behavioral expectations during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerServiceRating rdf:type rdf:Property ;
    rdfs:label 'Customer Service Rating' ;
    rdfs:comment 'Rating of the employees customer service quality and responsiveness. Applicable to customer-facing roles in express delivery, freight forwarding, and customer support.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentAreas rdf:type rdf:Property ;
    rdfs:label 'Development Areas' ;
    rdfs:comment 'Summary of areas where the employee needs development or improvement. Informs training plans and coaching priorities.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlanCreatedFlag rdf:type rdf:Property ;
    rdfs:label 'Development Plan Created Flag' ;
    rdfs:comment 'Boolean indicator of whether an individual development plan was created as part of this performance review. Supports career development and skill-building initiatives.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeSelfAssessmentComments rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment Comments' ;
    rdfs:comment 'Narrative comments provided by the employee as part of their self-assessment. Captures the employees perspective on their achievements and development needs.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Score' ;
    rdfs:comment 'Numeric score representing the percentage or degree to which the employee achieved their assigned goals during the review period. Used for performance-based compensation decisions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadershipRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Rating' ;
    rdfs:comment 'Rating of the employees leadership capabilities and behaviors. Applicable to roles with leadership responsibilities or leadership potential assessment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerComments rdf:type rdf:Property ;
    rdfs:label 'Manager Comments' ;
    rdfs:comment 'Detailed narrative comments provided by the reviewing manager. Includes strengths, areas for improvement, and specific examples of performance during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIncreaseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee is eligible for a merit-based salary increase based on this performance review. Drives compensation planning decisions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meritIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Percentage' ;
    rdfs:comment 'Recommended percentage increase in base salary as a result of this performance review. Used for merit-based compensation adjustments. Business-confidential data.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Summary performance rating assigned to the employee for the review period. Represents the holistic assessment of performance against expectations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score representing the overall performance rating. Typically on a scale of 1.0 to 5.0, used for quantitative analysis and merit calculations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipFlag rdf:type rdf:Property ;
    rdfs:label 'Pip Flag' ;
    rdfs:comment 'Boolean indicator of whether a Performance Improvement Plan was initiated as a result of this review. True indicates the employee is placed on a formal improvement plan.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipStartDate rdf:type rdf:Property ;
    rdfs:label 'Pip Start Date' ;
    rdfs:comment 'Start date of the Performance Improvement Plan if one was initiated. Marks the beginning of the formal improvement period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommended Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee is recommended for promotion based on this performance review. Used for succession planning and talent management.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the performance review was finalized and approved. Represents the official completion timestamp for the review cycle.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the performance review period being evaluated. Marks the close of the evaluation cycle.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the performance review period being evaluated. Typically aligns with fiscal year or mid-year cycle.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewTemplateName rdf:type rdf:Property ;
    rdfs:label 'Review Template Name' ;
    rdfs:comment 'Name of the performance review template used for this evaluation. Different templates may apply to different job families or organizational levels.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Safety Compliance Rating' ;
    rdfs:comment 'Rating of the employees adherence to safety protocols and regulations. Critical for warehouse, fleet, and freight operations roles. Aligns with DOT and ICAO safety requirements.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Succession Readiness Level' ;
    rdfs:comment 'Assessment of the employees readiness to move into a higher-level or critical role. Used for succession planning and talent pipeline management.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamworkRating rdf:type rdf:Property ;
    rdfs:label 'Teamwork Rating' ;
    rdfs:comment 'Rating of the employees ability to work effectively in teams and collaborate across functions. Critical for cross-functional logistics operations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Dedicated Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Positions dedicated to specific suppliers (Key Account Manager - Carrier X, Supplier Relationship Manager - Vendor Y). Enables dedicated supplier relationship role tracking, vendor-specific position p' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:positionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Position Employee Id' ;
    rdfs:comment 'The user ID of the HR administrator or system user who created this position record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:positionLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Position Last Modified By User Employee Id' ;
    rdfs:comment 'The user ID of the HR administrator or system user who last modified this position record. Used for audit trail and change management.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supervisorPositionId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Position Id' ;
    rdfs:comment 'Reference to the position that supervises this position, establishing the reporting line in the organizational hierarchy. Null for top-level executive positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:workLocationId rdf:type rdf:Property ;
    rdfs:label 'Work Location Id' ;
    rdfs:comment 'Reference to the primary physical work location for this position (e.g., warehouse, distribution center, office, terminal). Links to location master data.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:flsaStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Status' ;
    rdfs:comment 'Classification under the Fair Labor Standards Act determining overtime eligibility. Exempt positions are salaried and not eligible for overtime; non-exempt positions are hourly and eligible for overtime pay.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeLevel rdf:type rdf:Property ;
    rdfs:label 'Grade Level' ;
    rdfs:comment 'The compensation grade or pay band assigned to this position, determining salary range and benefits eligibility. Aligns with organizational compensation structure.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFunction rdf:type rdf:Property ;
    rdfs:label 'Job Function' ;
    rdfs:comment 'Specific functional area within the job family (e.g., Freight Forwarding, Last-Mile Delivery, Customs Brokerage, Warehouse Operations, Fleet Management). Enables detailed workforce analytics.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed narrative description of the position\'s responsibilities, duties, and scope. Used for job postings, performance management, and organizational documentation.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionNumber rdf:type rdf:Property ;
    rdfs:label 'Position Number' ;
    rdfs:comment 'Externally-known unique business identifier for the position, used in HR systems and organizational charts. Typically alphanumeric code assigned by Workday HCM.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position. Active positions are available for hiring or currently filled; frozen positions are temporarily suspended; closed positions are eliminated; pending approval positions await budget authorization.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Classification of the position based on employment duration and nature. Regular positions are permanent; temporary and seasonal positions are time-limited; contract positions are for specific projects; intern positions are for training programs.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitmentRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Recruitment Requisition Id' ;
    rdfs:comment 'Unique identifier for the recruitment requisition record. Primary key.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alt5RecruitmentModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Recruitment Modified By User Employee Id' ;
    rdfs:comment 'System user identifier of the person who last modified this requisition record.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryRecruitmentHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Recruitment Hiring Manager Employee Id' ;
    rdfs:comment 'Reference to the employee who is the hiring manager responsible for this requisition and will supervise the hired candidate.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRecruitmentReplacementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Recruitment Replacement Employee Id' ;
    rdfs:comment 'Reference to the employee being replaced if this is a replacement or backfill requisition. Null for new positions.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryRecruitmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Recruitment Employee Id' ;
    rdfs:comment 'System user identifier of the person who created this requisition record.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:staffingSupplierId rdf:type rdf:Property ;
    rdfs:label 'Staffing Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Recruitment requisitions for contractor/temp labor from staffing suppliers. Enables contingent workforce procurement tracking, staffing vendor requisition management, temporary labor supplier performa' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:tertiaryRecruitmentApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Recruitment Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who provided final approval for this requisition, typically a senior manager or HR business partner.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:candidateCount rdf:type rdf:Property ;
    rdfs:label 'Candidate Count' ;
    rdfs:comment 'Total number of candidates who applied or were sourced for this requisition. Used for funnel analysis.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountQuantity rdf:type rdf:Property ;
    rdfs:label 'Headcount Quantity' ;
    rdfs:comment 'Number of positions to be filled under this requisition. Typically 1 but may be higher for bulk hiring needs.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewCount rdf:type rdf:Property ;
    rdfs:label 'Interview Count' ;
    rdfs:comment 'Total number of candidate interviews conducted for this requisition. Used for recruiting process analysis.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Offer Acceptance Rate' ;
    rdfs:comment 'Percentage of offers extended that were accepted by candidates for this requisition. Used to measure recruiting effectiveness.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingTitle rdf:type rdf:Property ;
    rdfs:label 'Posting Title' ;
    rdfs:comment 'The job title used in external job postings and advertisements. May differ from the internal job title for marketing purposes.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionCloseDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Close Date' ;
    rdfs:comment 'Date when the requisition was closed either due to being filled, cancelled, or withdrawn. Marks the end of the time-to-fill measurement.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionOpenDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Open Date' ;
    rdfs:comment 'Date when the requisition was officially opened and approved for recruiting. Marks the start of the time-to-fill measurement.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salaryRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Maximum' ;
    rdfs:comment 'Maximum salary amount for the position based on the assigned grade level and market data. Used for offer preparation and budget planning.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Minimum' ;
    rdfs:comment 'Minimum salary amount for the position based on the assigned grade level and market data. Used for offer preparation and budget planning.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcingChannel rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channel' ;
    rdfs:comment 'Primary channel or method used to source candidates for this requisition. Used for recruiting effectiveness analysis. [ENUM-REF-CANDIDATE: internal|external|referral|agency|campus|job_board|social_media|direct_sourcing — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired or planned start date for the hired candidate to begin employment. Used for workforce planning and onboarding scheduling.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'Number of calendar days from requisition open date to requisition close date. Key performance indicator (KPI) for recruiting efficiency.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Shift Assignment Id' ;
    rdfs:comment 'Unique identifier for the shift assignment record. Primary key.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryShiftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shift Employee Id' ;
    rdfs:comment 'Identifier of the employee assigned to this shift. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryShiftOriginalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Shift Original Employee Id' ;
    rdfs:comment 'Identifier of the employee originally scheduled for this shift before any swap or reassignment. Null if no change occurred. Used for schedule change tracking and audit.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Absence Reason Code' ;
    rdfs:comment 'Code identifying the reason for absence if the employee did not complete the shift (e.g., sick leave, personal leave, emergency, unauthorized). Used for absence management and compliance tracking.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual clock-out or end timestamp recorded when the employee completes the shift. Used for payroll, labor cost allocation, and attendance tracking.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Worked' ;
    rdfs:comment 'Actual duration worked in hours, calculated from actual start and end times minus break duration. Used for payroll processing and labor cost allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual clock-in or start timestamp recorded when the employee begins the shift. Used for payroll, labor cost allocation, and attendance tracking.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attendanceStatus rdf:type rdf:Property ;
    rdfs:label 'Attendance Status' ;
    rdfs:comment 'Actual attendance outcome for this shift assignment. Used for attendance tracking, performance management, and labor productivity analysis.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total duration of breaks taken during the shift in minutes. Includes meal breaks and rest periods. Deducted from total shift time for payroll calculation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Comma-separated list of certifications or qualifications required to perform this shift (e.g., forklift license, hazmat handling, DOT medical card, IATA dangerous goods). Used for compliance verification.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerified rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified' ;
    rdfs:comment 'Indicates whether the assigned employee has been verified to hold all required certifications and qualifications for this shift. Used for regulatory compliance and safety management.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHolidayShift rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Shift' ;
    rdfs:comment 'Indicates whether this shift falls on a recognized holiday. Affects pay rate calculation and premium pay eligibility.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertime rdf:type rdf:Property ;
    rdfs:label 'Is Overtime' ;
    rdfs:comment 'Indicates whether this shift assignment includes overtime hours. Used for labor cost analysis and compliance reporting.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWeekendShift rdf:type rdf:Property ;
    rdfs:label 'Is Weekend Shift' ;
    rdfs:comment 'Indicates whether this shift falls on a weekend day. May affect pay rate calculation and shift differential eligibility.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobRoleCode rdf:type rdf:Property ;
    rdfs:label 'Job Role Code' ;
    rdfs:comment 'Code identifying the specific job role or function the employee performs during this shift (e.g., warehouse picker, forklift operator, dock loader, dispatcher).' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Planned end date and time for the shift assignment. Used for labor planning and schedule adherence tracking.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours' ;
    rdfs:comment 'Planned duration of the shift in hours. Calculated from scheduled start and end times. Used for labor capacity planning and Full-Time Equivalent (FTE) calculations.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Planned start date and time for the shift assignment. Used for labor planning and schedule adherence tracking.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftDifferentialCode rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Code' ;
    rdfs:comment 'Code identifying the shift differential pay category applicable to this assignment (e.g., night shift, weekend, hazard). Used for payroll premium calculation.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift assignment type. Determines pay rules, labor cost allocation, and compliance tracking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceCoveredFlag rdf:type rdf:Property ;
    rdfs:label 'Absence Covered Flag' ;
    rdfs:comment 'Indicates whether this shift was created to cover an employee absence (sick leave, vacation, emergency). True if this is a coverage shift, False otherwise.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'The actual date and time when the employee clocked out or ended the shift.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualProductivityUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Productivity Units' ;
    rdfs:comment 'The actual productivity output achieved during this shift, measured in the same units as labor standard. Used to calculate performance variance.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attendanceConfirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Attendance Confirmation Method' ;
    rdfs:comment 'Method used to confirm employee attendance for this shift. Biometric = fingerprint/facial recognition; Badge Scan = RFID badge; Manual Entry = supervisor input; Mobile App = employee self-service; Supervisor Approval = manager verification.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentAssigned rdf:type rdf:Property ;
    rdfs:label 'Equipment Assigned' ;
    rdfs:comment 'Identifier or description of equipment assigned to the employee for this shift (e.g., Forklift #23, Scanner Device #456, Delivery Van #789).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountAssigned rdf:type rdf:Property ;
    rdfs:label 'Headcount Assigned' ;
    rdfs:comment 'The number of employees currently assigned to this shift. May be less than, equal to, or greater than the requirement.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountRequirement rdf:type rdf:Property ;
    rdfs:label 'Headcount Requirement' ;
    rdfs:comment 'The number of employees required for this shift to meet operational demand. Used for capacity planning and schedule optimization.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:integrationSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Integration Source System' ;
    rdfs:comment 'The source system from which this shift schedule record originated. Workday = HCM system; Manhattan WMS = warehouse labor management; Manual = direct entry; Mobile App = employee self-service.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobRole rdf:type rdf:Property ;
    rdfs:label 'Job Role' ;
    rdfs:comment 'The specific job role or function the employee is performing during this shift (e.g., Warehouse Picker, Dock Worker, Forklift Operator, Freight Handler, Driver, Supervisor).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborStandardUnits rdf:type rdf:Property ;
    rdfs:label 'Labor Standard Units' ;
    rdfs:comment 'The expected productivity output for this shift measured in standard units (e.g., cases picked, pallets moved, shipments processed). Used to calculate labor efficiency.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Schedule Created By' ;
    rdfs:comment 'Username or identifier of the scheduler, manager, or system that created this shift assignment.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Schedule Modified By' ;
    rdfs:comment 'Username or identifier of the person or system that last modified this shift assignment.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Schedule Modified Timestamp' ;
    rdfs:comment 'Date and time when this shift schedule was last modified. Tracks changes for audit and compliance purposes.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Period End Date' ;
    rdfs:comment 'The last date of the scheduling period this shift belongs to.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schedulePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Period Start Date' ;
    rdfs:comment 'The first date of the scheduling period this shift belongs to. Scheduling periods are typically weekly or bi-weekly cycles.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schedulePublishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Schedule Published Timestamp' ;
    rdfs:comment 'Date and time when this shift schedule was published and communicated to the employee. Used to track advance notice compliance with labor regulations.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDurationHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Hours' ;
    rdfs:comment 'The planned duration of the shift in hours, excluding breaks. Calculated from scheduled start and end times minus break duration.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'The planned date and time when the shift is scheduled to end.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'The planned date and time when the shift is scheduled to begin.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Business identifier or code for the shift template (e.g., WH-DAY-01, DOCK-NIGHT-A). Used for scheduling and reporting purposes.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDifferentialRate rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Rate' ;
    rdfs:comment 'Additional pay rate percentage or amount applied for working undesirable shifts (e.g., night shift, weekend, holiday). Expressed as a percentage or flat amount per hour.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Human-readable name or description of the shift (e.g., Morning Warehouse Shift, Night Dock Operations).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationZone rdf:type rdf:Property ;
    rdfs:label 'Work Location Zone' ;
    rdfs:comment 'Specific zone or area within the facility where the employee is assigned during this shift (e.g., Receiving Dock A, Pick Zone 3, Shipping Lane 5). Used for detailed labor tracking.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Training Record Id' ;
    rdfs:comment 'Unique identifier for the training record. Primary key for the training record entity.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTrainingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who completed the training or competency assessment. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTrainingVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Training Verified By Employee Id' ;
    rdfs:comment 'Unique identifier of the employee or compliance officer who verified the training certification or competency. Links to employee master record. Used for audit trail and accountability.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Outcome of the training assessment or competency evaluation. Pass indicates successful completion meeting minimum requirements. Fail indicates unsuccessful attempt. Incomplete indicates assessment not yet finished. Waived indicates requirement exempted. In progress indicates ongoing assessment.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScore rdf:type rdf:Property ;
    rdfs:label 'Passing Score' ;
    rdfs:comment 'Minimum score required to successfully pass the training assessment or competency evaluation. Used to determine pass/fail status. Typically expressed as a percentage or raw score threshold.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the organization or individual that delivered the training or conducted the competency assessment. May be internal training department, external vendor, regulatory body, or certified assessor.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCode rdf:type rdf:Property ;
    rdfs:label 'Training Code' ;
    rdfs:comment 'Standardized code or identifier for the training course or competency in the learning management system. Used for catalog lookup and reporting.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHours rdf:type rdf:Property ;
    rdfs:label 'Training Hours' ;
    rdfs:comment 'Total number of hours the employee spent completing the training course or competency development program. Used for compliance reporting, labor cost allocation, and professional development tracking.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingMethod rdf:type rdf:Property ;
    rdfs:label 'Training Method' ;
    rdfs:comment 'Method by which the training was delivered. Classroom indicates in-person instructor-led training. Online indicates e-learning or virtual training. On-the-job indicates practical training during work. Blended indicates combination of methods. Simulation indicates virtual or physical simulation environment. Workshop indicates hands-on group training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingName rdf:type rdf:Property ;
    rdfs:label 'Training Name' ;
    rdfs:comment 'Full name of the training course, certification program, or competency being assessed. Examples: DOT Hazmat Awareness, IATA Dangerous Goods Regulations, Forklift Operator Certification, WMS Advanced User Training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Category of training or competency assessment. Compliance includes DOT, IATA, C-TPAT, IMDG, customs procedures. Operational includes forklift, WMS, TMS. Professional development includes career advancement programs.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Unique identifier for the physical work location (office, warehouse, terminal, depot) where the employee performs duties under this assignment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:primaryWorkerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Worker Employee Id' ;
    rdfs:comment 'Unique identifier for the employee being assigned. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Business reason or event triggering this assignment (e.g., new hire, promotion, transfer, reorganization, backfill, project assignment). Used for workforce analytics and change tracking.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessTitle rdf:type rdf:Property ;
    rdfs:label 'Business Title' ;
    rdfs:comment 'External-facing or business title used for this assignment, which may differ from the formal job profile title. Used for business cards, email signatures, and external communications.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicenseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this assignment requires a valid customs broker license for trade compliance and customs declaration activities.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultExpenseCostCenter rdf:type rdf:Property ;
    rdfs:label 'Default Expense Cost Center' ;
    rdfs:comment 'Default cost center code to which employee expenses (travel, supplies, etc.) for this assignment are charged. May differ from labor cost center.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotSafetySensitiveFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Safety Sensitive Flag' ;
    rdfs:comment 'Boolean indicator of whether this assignment is classified as a DOT safety-sensitive position requiring drug and alcohol testing and compliance with hours-of-service regulations.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverQualificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Driver Qualification Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this assignment requires valid commercial driver qualifications and certifications (CDL, ICAO crew license, etc.).' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'Percentage of full-time equivalent hours allocated to this assignment, expressed as a decimal (e.g., 100.00 for full-time, 50.00 for half-time). Used for workforce planning and labor cost allocation.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certification Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this assignment requires hazardous materials handling certification per IMDG Code or ICAO Technical Instructions.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payRateType rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Type' ;
    rdfs:comment 'Method by which compensation is calculated for this assignment: salary, hourly wage, commission-based, or piece-rate. Business-confidential for compensation planning.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether this assignment is eligible for remote or work-from-home arrangements per company policy.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledWeeklyHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Weekly Hours' ;
    rdfs:comment 'Number of hours per week the employee is scheduled to work under this assignment. Used for labor planning and compliance with working time regulations.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successionPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Flag' ;
    rdfs:comment 'Boolean indicator of whether this assignment is part of a formal succession planning program for critical roles and leadership development.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workerCategory rdf:type rdf:Property ;
    rdfs:label 'Worker Category' ;
    rdfs:comment 'High-level categorization of the worker type for this assignment (e.g., Employee, Contingent Worker, Contractor, Consultant) used for workforce segmentation and reporting.' ;
    rdfs:domain ind:WorkerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Building Square Footage' ;
    rdfs:comment 'Total building area in square feet. Used for facilities cost allocation, space utilization analysis, and capacity planning.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentHeadcount rdf:type rdf:Property ;
    rdfs:label 'Current Headcount' ;
    rdfs:comment 'Current number of employees assigned to this workforce location. Updated periodically from Workday HCM.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalLocationCode rdf:type rdf:Property ;
    rdfs:label 'External Location Code' ;
    rdfs:comment 'External system identifier for this location from source systems (e.g., Workday HCM location ID, SAP TM plant code). Used for cross-system reconciliation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSafetySensitiveSite rdf:type rdf:Property ;
    rdfs:label 'Is Safety Sensitive Site' ;
    rdfs:comment 'Indicates whether this location handles safety-sensitive operations requiring DOT/ICAO certifications, dangerous goods handling, or enhanced safety protocols.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionLocation rdf:type rdf:Property ;
    rdfs:label 'Is Union Location' ;
    rdfs:comment 'Indicates whether this location has unionized workforce. Determines applicable labor agreements, shift rules, and compliance requirements.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseOrOwned rdf:type rdf:Property ;
    rdfs:label 'Lease Or Owned' ;
    rdfs:comment 'Indicates whether the location is owned by the company, leased, or subleased. Impacts financial reporting and CAPEX/OPEX allocation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalCapacityFte rdf:type rdf:Property ;
    rdfs:label 'Operational Capacity Fte' ;
    rdfs:comment 'Maximum workforce capacity at this location measured in Full-Time Equivalents. Used for labor planning and resource allocation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parkingCapacity rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity' ;
    rdfs:comment 'Number of parking spaces available at this location for employee and visitor vehicles. Used for facilities planning and employee amenities assessment.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Primary regulatory jurisdiction governing labor law, safety, and employment compliance at this location (e.g., \'US DOT\', \'EU GDPR\', \'ICAO\'). Determines applicable compliance frameworks.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard shift pattern or rotation schedule used at this location (e.g., \'3-shift rotation\', \'4-on-4-off\', \'day shift only\'). Guides workforce scheduling in Manhattan WMS.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Warehouse Management System' ;
    rdfs:comment 'Name and version of the WMS deployed at this location (e.g., \'Manhattan WMS v2022\', \'SAP EWM\'). Used for system integration and labor tracking.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDriverAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Driver Assignment Id' ;
    rdfs:comment 'Primary key for shipment_driver_assignment' ;
    rdfs:domain ind:ShipmentDriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driverAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Driver Assignment Id' ;
    rdfs:comment 'Unique identifier for this driver assignment record. Primary key for the association.' ;
    rdfs:domain ind:ShipmentDriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetDriverAssignment .

ind:carbonEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Carbon Enrollment Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer carbon offset program enrollment record. Primary key.' ;
    rdfs:domain ind:CarbonEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoOffsetEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Offset Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automatic carbon offset retirement is enabled for this customer-program enrollment. When true, Transport Shipping automatically retires offset credits from this program based on the customer\'s shipment emissions and allocation rules. When false, offsets are retired manually or on-demand.' ;
    rdfs:domain ind:CarbonEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerProgramCode rdf:type rdf:Property ;
    rdfs:label 'Customer Program Code' ;
    rdfs:comment 'Optional customer-specific reference code or identifier for this enrollment, used for the customer\'s internal tracking and reconciliation purposes.' ;
    rdfs:domain ind:CarbonEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRetirementDate rdf:type rdf:Property ;
    rdfs:label 'Last Retirement Date' ;
    rdfs:comment 'The date of the most recent carbon offset credit retirement transaction for this customer-program enrollment. Null if no retirements have occurred yet.' ;
    rdfs:domain ind:CarbonEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumMonthlyOffsetTonnes rdf:type rdf:Property ;
    rdfs:label 'Minimum Monthly Offset Tonnes' ;
    rdfs:comment 'The minimum quantity of carbon offset credits (in tonnes CO2e) that the customer has committed to procure or retire from this program on a monthly basis. Used for capacity planning and procurement workflows.' ;
    rdfs:domain ind:CarbonEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'The pricing tier applicable to this customer for this specific carbon offset program. Determines the per-tonne price the customer pays, which may differ from the program\'s base price_per_tonne_co2e based on volume commitments or enterprise agreements. Values: Standard, Volume, Enterprise, Custom.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTonnesRetired rdf:type rdf:Property ;
    rdfs:label 'Total Tonnes Retired' ;
    rdfs:comment 'Cumulative quantity of carbon offset credits (in tonnes CO2e) that have been retired from this program on behalf of this customer since enrollment. Used for sustainability reporting and customer dashboards.' ;
    rdfs:domain ind:CarbonEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiativeParticipationId rdf:type rdf:Property ;
    rdfs:label 'Initiative Participation Id' ;
    rdfs:comment 'Unique identifier for the employee-initiative participation record. Primary key for the association.' ;
    rdfs:domain ind:InitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:achievementPercentage rdf:type rdf:Property ;
    rdfs:label 'Achievement Percentage' ;
    rdfs:comment 'Percentage of the assigned KPI target that the employee has achieved (0-100+). Used for performance evaluation, incentive calculation, and tracking individual contribution to sustainability goals. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionHours rdf:type rdf:Property ;
    rdfs:label 'Contribution Hours' ;
    rdfs:comment 'Total hours the employee has contributed or is allocated to contribute to the sustainability initiative. Used for resource planning, cost allocation, and measuring human capital investment in ESG projects. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiTargetAssigned rdf:type rdf:Property ;
    rdfs:label 'Kpi Target Assigned' ;
    rdfs:comment 'Specific key performance indicator or target assigned to this employee for this initiative (e.g., \'500 tCO2e reduction\', \'10 EV deployments\', \'15% modal shift\'). Enables individual accountability and performance tracking within the initiative. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationEndDate rdf:type rdf:Property ;
    rdfs:label 'Participation End Date' ;
    rdfs:comment 'Date when the employee\'s participation in the sustainability initiative ended or is planned to end. Null for ongoing participation. Enables tracking of participation history and resource allocation over time. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationStartDate rdf:type rdf:Property ;
    rdfs:label 'Participation Start Date' ;
    rdfs:comment 'Date when the employee began participating in or was assigned to the sustainability initiative. Used for tracking participation duration and historical staffing analysis. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current status of the employee\'s participation in the initiative (active, on_hold, completed, withdrawn). Tracks the lifecycle of the participation relationship and enables filtering for active vs. historical assignments.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Responsibility Level' ;
    rdfs:comment 'Level of responsibility or accountability the employee has for the initiative (e.g., primary, secondary, advisory, support). Distinguishes between core team members and supporting contributors. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleInInitiative rdf:type rdf:Property ;
    rdfs:label 'Role In Initiative' ;
    rdfs:comment 'The specific role the employee plays in the sustainability initiative (e.g., sponsor, contributor, champion, technical lead, analyst, coordinator). Defines the nature of their participation and level of accountability. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Time Allocation Percentage' ;
    rdfs:comment 'Percentage of the employee\'s working time allocated to this sustainability initiative (0-100). Used for capacity planning, workload balancing, and ensuring employees are not over-committed across multiple initiatives.' ;
    rdfs:domain ind:InitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceTrainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Workforce Training Completion Id' ;
    rdfs:comment 'Primary key for workforce_training_completion' ;
    rdfs:domain ind:WorkforceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingSessionId rdf:type rdf:Property ;
    rdfs:label 'Training Session Id' ;
    rdfs:comment 'Identifier for the specific training session or class instance in which this completion occurred. Links to scheduling system for session-level tracking (instructor, location, cohort).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingSession .

ind:trainingCompletionReference rdf:type rdf:Property ;
    rdfs:label 'Training Completion Reference' ;
    rdfs:comment 'Unique identifier for this training completion record. Primary key.' ;
    rdfs:domain ind:WorkforceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical location or facility where the training was delivered (e.g., warehouse code, training center, online). Used for geographic compliance reporting and resource planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProviderName rdf:type rdf:Property ;
    rdfs:label 'Training Provider Name' ;
    rdfs:comment 'Name of the organization or individual who delivered this specific training session. May differ from the course master external_provider_name if delivered by internal trainers or alternate providers.' ;
    rdfs:domain ind:WorkforceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCarrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Facility Carrier Service Id' ;
    rdfs:comment 'Unique identifier for this facility-carrier service agreement. Primary key.' ;
    rdfs:domain ind:FacilityCarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when this facility-carrier service record was created in the system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dockDoorAssignments rdf:type rdf:Property ;
    rdfs:label 'Dock Door Assignments' ;
    rdfs:comment 'Comma-separated list of dock door numbers assigned to this carrier at this facility (e.g., D1,D2,D5). Facility-specific operational assignment.' ;
    rdfs:domain ind:FacilityCarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Timestamp when this facility-carrier service record was last updated.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupSchedule rdf:type rdf:Property ;
    rdfs:label 'Pickup Schedule' ;
    rdfs:comment 'Scheduled pickup times for this carrier at this facility (e.g., MON-FRI 14:00, SAT 10:00). Facility-specific schedule that may differ from carrier\'s general availability.' ;
    rdfs:domain ind:FacilityCarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Rate Agreement Reference' ;
    rdfs:comment 'Reference identifier to the facility-specific rate agreement or pricing schedule for this carrier. Links to contract management system.' ;
    rdfs:domain ind:FacilityCarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment' ;
    rdfs:comment 'Committed monthly shipment volume (in units or weight) for this carrier at this facility. Part of facility-level service agreement terms.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depotInitiativeImplementationId rdf:type rdf:Property ;
    rdfs:label 'Depot Initiative Implementation Id' ;
    rdfs:comment 'Unique identifier for this depot-initiative implementation record. Primary key.' ;
    rdfs:domain ind:DepotInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Site Lead Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for leading and coordinating the implementation of this sustainability initiative at this depot. Establishes accountability at the site level.' ;
    rdfs:domain ind:DepotInitiativeImplementation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselineCo2eEmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Baseline Co2e Emissions Tco2e' ;
    rdfs:comment 'Baseline annual GHG emissions in metric tonnes of CO2 equivalent (tCO2e) at this depot before initiative implementation. Used to calculate actual reduction achieved.' ;
    rdfs:domain ind:DepotInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexAllocated rdf:type rdf:Property ;
    rdfs:label 'Capex Allocated' ;
    rdfs:comment 'Capital expenditure allocated or spent for implementing this sustainability initiative at this specific depot. Enables site-level investment tracking and ROI analysis.' ;
    rdfs:domain ind:DepotInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eReductionActualTco2e rdf:type rdf:Property ;
    rdfs:label 'Co2e Reduction Actual Tco2e' ;
    rdfs:comment 'Actual measured annual greenhouse gas emissions reduction in metric tonnes of CO2 equivalent (tCO2e) achieved by this initiative at this specific depot. Enables site-level performance tracking against targets.' ;
    rdfs:domain ind:DepotInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eReductionTargetTco2e rdf:type rdf:Property ;
    rdfs:label 'Co2e Reduction Target Tco2e' ;
    rdfs:comment 'Target annual greenhouse gas emissions reduction in metric tonnes of CO2 equivalent (tCO2e) for this initiative at this specific depot. Site-level contribution to overall initiative target.' ;
    rdfs:domain ind:DepotInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the sustainability initiative implementation at this depot: planned, in-progress, completed, on-hold, or cancelled. Enables site-level progress tracking independent of overall initiative status.' ;
    rdfs:domain ind:DepotInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opexAllocated rdf:type rdf:Property ;
    rdfs:label 'Opex Allocated' ;
    rdfs:comment 'Operating expenditure allocated or spent for implementing this sustainability initiative at this specific depot. Tracks ongoing operational costs at the site level.' ;
    rdfs:domain ind:DepotInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manifestLineItemId rdf:type rdf:Property ;
    rdfs:label 'Manifest Line Item Id' ;
    rdfs:comment 'Unique identifier for this manifest line item record. Primary key.' ;
    rdfs:domain ind:ManifestLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlingNotes rdf:type rdf:Property ;
    rdfs:label 'Handling Notes' ;
    rdfs:comment 'Free-text notes specific to the handling of this consignment on this manifest, such as special handling instructions, damage observations, or loading exceptions. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ManifestLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemStatus rdf:type rdf:Property ;
    rdfs:label 'Line Item Status' ;
    rdfs:comment 'Current status of this manifest line item indicating its operational state (planned, loaded, in_transit, unloaded, exception). Tracks the lifecycle of this specific consignment on this specific manifest.' ;
    rdfs:domain ind:ManifestLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPosition rdf:type rdf:Property ;
    rdfs:label 'Load Position' ;
    rdfs:comment 'Physical position or location where this consignment is loaded within the transport equipment (e.g., container position, pallet location, bay/row/tier). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ManifestLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loaded Timestamp' ;
    rdfs:comment 'Date and time when this specific consignment was physically loaded onto the manifest. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ManifestLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Sequence Number' ;
    rdfs:comment 'Sequential line number of this consignment on the manifest, used for customs documentation and loading order reference. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ManifestLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pieceCountOnManifest rdf:type rdf:Property ;
    rdfs:label 'Piece Count On Manifest' ;
    rdfs:comment 'Number of pieces from this consignment that were actually loaded onto this specific manifest. May differ from consignment.number_of_pieces if the consignment is split across multiple manifests. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ManifestLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unloadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unloaded Timestamp' ;
    rdfs:comment 'Date and time when this specific consignment was physically unloaded from the manifest at the destination facility. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ManifestLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weightOnManifestKg rdf:type rdf:Property ;
    rdfs:label 'Weight On Manifest Kg' ;
    rdfs:comment 'Actual weight in kilograms of the pieces from this consignment loaded onto this specific manifest. May differ from consignment.declared_weight_kg if the consignment is split across multiple manifests. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ManifestLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Id' ;
    rdfs:comment 'Unique identifier for this supply agreement record. Primary key.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'The date of the most recent purchase order placed for this SKU from this supplier, used for supplier performance tracking.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'The quality performance rating for this supplier-SKU combination, typically on a scale of 0.00 to 5.00, based on defect rates and compliance.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetProcurementAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Procurement Agreement Id' ;
    rdfs:comment 'Unique identifier for the carbon offset procurement agreement. Primary key.' ;
    rdfs:domain ind:CarbonOffsetProcurementAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedVolumeTco2e rdf:type rdf:Property ;
    rdfs:label 'Committed Volume Tco2e' ;
    rdfs:comment 'The total quantity of carbon offset credits (in tonnes CO2e) that Transport Shipping has committed to purchase from this supplier for this specific program under the terms of this agreement. Represents the volume commitment negotiated in the contract.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverySchedule rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'The agreed-upon schedule for delivery or transfer of carbon offset credits from the supplier to Transport Shipping for this program. May specify quarterly tranches, annual delivery, or event-triggered delivery terms.' ;
    rdfs:domain ind:CarbonOffsetProcurementAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantityTco2e rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Tco2e' ;
    rdfs:comment 'The minimum quantity of carbon offset credits (in tonnes CO2e) that must be purchased in a single order or tranche from this supplier for this program. Represents supplier-imposed or negotiated minimum purchase requirements.' ;
    rdfs:domain ind:CarbonOffsetProcurementAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementContactEmail rdf:type rdf:Property ;
    rdfs:label 'Procurement Contact Email' ;
    rdfs:comment 'The email address of the primary contact at the supplier organization responsible for this specific carbon offset program procurement relationship.' ;
    rdfs:domain ind:CarbonOffsetProcurementAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementContactName rdf:type rdf:Property ;
    rdfs:label 'Procurement Contact Name' ;
    rdfs:comment 'The name of the primary contact at the supplier organization responsible for this specific carbon offset program procurement relationship.' ;
    rdfs:domain ind:CarbonOffsetProcurementAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Standard' ;
    rdfs:comment 'The quality or verification standard that the supplier must meet for carbon offset credits delivered under this agreement. May specify minimum certification requirements, additionality verification, permanence guarantees, or co-benefit requirements specific to this supplier-program relationship.' ;
    rdfs:domain ind:CarbonOffsetProcurementAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYearPreference rdf:type rdf:Property ;
    rdfs:label 'Vintage Year Preference' ;
    rdfs:comment 'The preferred vintage year or vintage year range for carbon offset credits to be delivered under this agreement. Transport Shipping may negotiate specific vintage preferences with each supplier for each program based on regulatory requirements, pricing, or strategic priorities.' ;
    rdfs:domain ind:CarbonOffsetProcurementAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Agreement Id' ;
    rdfs:comment 'Unique identifier for this carrier service agreement record. Primary key.' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliveryTargetPct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Target Pct' ;
    rdfs:comment 'Target on-time delivery percentage committed by carrier for this agreement (e.g., 95.00 for 95%). Part of the SLA.' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rate rdf:type rdf:Property ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Negotiated rate for this service type and trade lane. Unit depends on service type (per kg, per shipment, per container, per mile). Currency specified in rate_currency.' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the negotiated rate.' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'Unit of measure for the rate (per kg, per shipment, per container, per mile, per pallet).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeCommitmentDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Commitment Days' ;
    rdfs:comment 'Committed transit time in days for this service type and trade lane. Part of the SLA.' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementSupplierServiceId rdf:type rdf:Property ;
    rdfs:label 'Agreement Supplier Service Id' ;
    rdfs:comment 'Unique identifier for this agreement-supplier service assignment. Primary key.' ;
    rdfs:domain ind:AgreementSupplierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier is the primary service provider for this agreement (true) or a backup/secondary provider (false). Used for routing and allocation logic.' ;
    rdfs:domain ind:AgreementSupplierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Reference' ;
    rdfs:comment 'Reference identifier to the detailed rate card or pricing schedule applicable to this supplier for this agreement. Links to external rate management systems or documents.' ;
    rdfs:domain ind:AgreementSupplierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierDocumentSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Carrier Document Specification Id' ;
    rdfs:comment 'Unique identifier for this carrier document specification record. Primary key.' ;
    rdfs:domain ind:CarrierDocumentSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierCustomizationAllowed rdf:type rdf:Property ;
    rdfs:label 'Carrier Customization Allowed' ;
    rdfs:comment 'Indicates whether the carrier permits customization of this document template (logo, additional fields, layout modifications) or requires strict adherence to the standard template format.' ;
    rdfs:domain ind:CarrierDocumentSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediMappingReference rdf:type rdf:Property ;
    rdfs:label 'Edi Mapping Reference' ;
    rdfs:comment 'Reference identifier for the carrier-specific EDI mapping configuration used when generating documents from this template for this carrier. Captures carrier-specific field mappings, segment orders, or qualifier codes.' ;
    rdfs:domain ind:CarrierDocumentSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of this carrier document specification (draft, pending_approval, active, deprecated, superseded). Tracks approval workflow and active/inactive state.' ;
    rdfs:domain ind:CarrierDocumentSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateVersionRequired rdf:type rdf:Property ;
    rdfs:label 'Template Version Required' ;
    rdfs:comment 'Specific version number of the document template required by this carrier agreement (e.g., 2.1, 3.0.1). Carriers may mandate specific template versions for compliance or system compatibility.' ;
    rdfs:domain ind:CarrierDocumentSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Usage Trigger Event' ;
    rdfs:comment 'Business event or shipment milestone that triggers generation of this document template for this carrier (e.g., booking confirmation, cargo ready, customs clearance, delivery completion).' ;
    rdfs:domain ind:CarrierDocumentSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDocumentationRequirementId rdf:type rdf:Property ;
    rdfs:label 'Compliance Documentation Requirement Id' ;
    rdfs:comment 'Unique identifier for the compliance documentation requirement record. Primary key.' ;
    rdfs:domain ind:ComplianceDocumentationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionPeriodOverrideYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Override Years' ;
    rdfs:comment 'Override for the document retention period specific to this compliance obligation context. Overrides the default retention period from document_type when compliance requirements mandate longer retention. Explicitly identified in detection phase.' ;
    rdfs:domain ind:ComplianceDocumentationRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programParticipationId rdf:type rdf:Property ;
    rdfs:label 'Program Participation Id' ;
    rdfs:comment 'Unique identifier for this specific enrollment of a company code in a compliance program' ;
    rdfs:domain ind:ProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for managing this company code\'s compliance with this program. Identified in detection phase relationship_data.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:participationNotes rdf:type rdf:Property ;
    rdfs:label 'Participation Notes' ;
    rdfs:comment 'Free-text notes specific to this company code\'s participation in this program' ;
    rdfs:domain ind:ProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSustainabilityContributionId rdf:type rdf:Property ;
    rdfs:label 'Rate Sustainability Contribution Id' ;
    rdfs:comment 'Unique identifier for this rate-target contribution relationship. Primary key.' ;
    rdfs:domain ind:RateSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Actual Emissions Tco2e' ;
    rdfs:comment 'Actual cumulative emissions in tonnes CO2 equivalent for shipments under this contract rate since contribution tracking began. Updated at each measurement cycle.' ;
    rdfs:domain ind:RateSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusRate rdf:type rdf:Property ;
    rdfs:label 'Bonus Rate' ;
    rdfs:comment 'Financial bonus rate (in currency per tCO2e) awarded if emissions performance under this contract rate exceeds the target trajectory. Part of sustainability-linked pricing incentive. Identified in detection phase.' ;
    rdfs:domain ind:RateSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionStatus rdf:type rdf:Property ;
    rdfs:label 'Contribution Status' ;
    rdfs:comment 'Current status of this contribution relationship: active (rate is contributing to target), suspended (temporarily paused), achieved (target met), discontinued (rate no longer contributes).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveAmountYtd rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount Ytd' ;
    rdfs:comment 'Year-to-date financial incentive amount (bonus or penalty) accrued based on emissions performance under this contract rate relative to target.' ;
    rdfs:domain ind:RateSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Performance Variance Percentage' ;
    rdfs:comment 'Percentage variance between actual emissions performance and target trajectory. Negative values indicate better-than-target performance (emissions below target).' ;
    rdfs:domain ind:RateSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetContributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Contribution Percentage' ;
    rdfs:comment 'The percentage of the sustainability target that this contract rate is expected to contribute toward achieving (e.g., 2.5% of total Scope 3 reduction target). Identified in detection phase.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetEmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Target Emissions Tco2e' ;
    rdfs:comment 'Target emissions in tonnes CO2 equivalent for shipments under this contract rate by the target year. Represents the emissions reduction commitment embedded in this rate agreement. Identified in detection phase.' ;
    rdfs:domain ind:RateSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerProgramEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Program Enrollment Id' ;
    rdfs:comment 'Primary key for customer_program_enrollment' ;
    rdfs:domain ind:CustomerProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentNotes rdf:type rdf:Property ;
    rdfs:label 'Enrollment Notes' ;
    rdfs:comment 'Free-text notes capturing enrollment-specific details, special conditions, or historical context for this customer accounts participation in this specific program.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEnrollmentReference rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Reference' ;
    rdfs:comment 'Unique surrogate identifier for the customer account compliance program enrollment record' ;
    rdfs:domain ind:CustomerProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programTier rdf:type rdf:Property ;
    rdfs:label 'Program Tier' ;
    rdfs:comment 'The tier or level of certification achieved by this customer account within this specific program (e.g., Tier 1, Tier 2, Tier 3 for C-TPAT; different programs have different tier structures). Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAllocationId rdf:type rdf:Property ;
    rdfs:label 'Customer Allocation Id' ;
    rdfs:comment 'Primary key for customer_allocation' ;
    rdfs:domain ind:CustomerAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Employee Id' ;
    rdfs:comment 'Employee identifier of the user who most recently modified this allocation record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationReference rdf:type rdf:Property ;
    rdfs:label 'Allocation Reference' ;
    rdfs:comment 'Unique surrogate identifier for this customer-fulfillment center allocation record. Primary key.' ;
    rdfs:domain ind:CustomerAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityParticipationId rdf:type rdf:Property ;
    rdfs:label 'Sustainability Participation Id' ;
    rdfs:comment 'Unique identifier for the customer sustainability participation record. Primary key.' ;
    rdfs:domain ind:SustainabilityParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountManagerNotes rdf:type rdf:Property ;
    rdfs:label 'Account Manager Notes' ;
    rdfs:comment 'Free-text notes from the account manager regarding the customer\'s participation, strategic importance, or special arrangements' ;
    rdfs:domain ind:SustainabilityParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitSharingPercentage rdf:type rdf:Property ;
    rdfs:label 'Benefit Sharing Percentage' ;
    rdfs:comment 'Percentage of the initiative\'s total CO2e reduction or cost savings that is attributed to this customer for their ESG reporting and carbon accounting purposes' ;
    rdfs:domain ind:SustainabilityParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Co Investment Amount' ;
    rdfs:comment 'Financial contribution amount committed or paid by the customer toward the sustainability initiative CAPEX or OPEX' ;
    rdfs:domain ind:SustainabilityParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coInvestmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Co Investment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the co-investment amount' ;
    rdfs:domain ind:SustainabilityParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentLevel rdf:type rdf:Property ;
    rdfs:label 'Commitment Level' ;
    rdfs:comment 'Classification of the customer\'s level of engagement in the sustainability initiative: pilot (trial participant), partner (operational participant), co-investor (financial contributor), sponsor (strategic funder)' ;
    rdfs:domain ind:SustainabilityParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedBenefitTco2e rdf:type rdf:Property ;
    rdfs:label 'Expected Benefit Tco2e' ;
    rdfs:comment 'Estimated annual CO2 equivalent emissions reduction (in metric tonnes) that the customer expects to achieve through participation in this initiative, used for customer-specific ESG reporting' ;
    rdfs:domain ind:SustainabilityParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationDate rdf:type rdf:Property ;
    rdfs:label 'Participation Date' ;
    rdfs:comment 'Date when the customer formally joined or committed to participate in the sustainability initiative' ;
    rdfs:domain ind:SustainabilityParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountTeamAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Account Team Assignment Id' ;
    rdfs:comment 'Unique identifier for this account team assignment record. Primary key.' ;
    rdfs:domain ind:AccountTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'Level of authorization this employee has for actions on this customer account (pricing approvals, credit holds, service exceptions, etc.)' ;
    rdfs:domain ind:AccountTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'Specific role the employee plays on this account team (Primary account owner, Secondary support, Backup coverage, Technical specialist, etc.)' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningInvoiceCoverageId rdf:type rdf:Property ;
    rdfs:label 'Dunning Invoice Coverage Id' ;
    rdfs:comment 'Unique identifier for this dunning invoice coverage record. Primary key.' ;
    rdfs:domain ind:DunningInvoiceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Communication Sent Flag' ;
    rdfs:comment 'Indicates whether communication about this specific invoice was sent as part of this dunning action.' ;
    rdfs:domain ind:DunningInvoiceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerResponseForInvoice rdf:type rdf:Property ;
    rdfs:label 'Customer Response For Invoice' ;
    rdfs:comment 'Customer response specific to this invoice within this dunning action. Customer may respond differently to different invoices in the same dunning cycle.' ;
    rdfs:domain ind:DunningInvoiceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysPastDueAtDunning rdf:type rdf:Property ;
    rdfs:label 'Days Past Due At Dunning' ;
    rdfs:comment 'Number of days this specific invoice was overdue at the time of this dunning action. Relationship-specific temporal attribute.' ;
    rdfs:domain ind:DunningInvoiceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningLevelForInvoice rdf:type rdf:Property ;
    rdfs:label 'Dunning Level For Invoice' ;
    rdfs:comment 'The escalation level applied to this specific invoice in this dunning action. Same invoice may be at different levels in different dunning cycles.' ;
    rdfs:domain ind:DunningInvoiceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAmountAtDunning rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount At Dunning' ;
    rdfs:comment 'The outstanding amount of this specific invoice at the time it was included in this dunning action. Captures point-in-time state.' ;
    rdfs:domain ind:DunningInvoiceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueInvoiceReferences rdf:type rdf:Property ;
    rdfs:label 'Overdue Invoice References' ;
    rdfs:comment 'Comma-separated list of invoice numbers or identifiers that are overdue and included in this dunning action. [Moved from dunning_record: This is a denormalized STRING list (comma-separated invoice numbers) that represents the M:N relationship. This anti-pattern should be replaced by proper association records in dunning_invoice_coverage. Each invoice reference becomes a row in the association table.]' ;
    rdfs:domain ind:DunningInvoiceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityPartnerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Facility Partner Agreement Id' ;
    rdfs:comment 'Unique identifier for this facility-partner agreement record. Primary key.' ;
    rdfs:domain ind:FacilityPartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnershipType rdf:type rdf:Property ;
    rdfs:label 'Partnership Type' ;
    rdfs:comment 'Classification of the service relationship type between the facility and network partner. Defines the primary service category provided by the partner to this facility.' ;
    rdfs:domain ind:FacilityPartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Percentage of revenue shared with the network partner for services provided to this facility, representing the commercial terms specific to this facility-partner agreement.' ;
    rdfs:domain ind:FacilityPartnerAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depotCertificationId rdf:type rdf:Property ;
    rdfs:label 'Depot Certification Id' ;
    rdfs:comment 'Primary key for the depot certification association record' ;
    rdfs:domain ind:DepotCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetDepotId rdf:type rdf:Property ;
    rdfs:label 'Fleet Depot Id' ;
    rdfs:comment 'Foreign key to fleet_depot' ;
    rdfs:domain ind:DepotCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:certificationNotes rdf:type rdf:Property ;
    rdfs:label 'Certification Notes' ;
    rdfs:comment 'Free-text notes capturing facility-specific conditions, exceptions, or observations related to this depot\'s certification under this program.' ;
    rdfs:domain ind:DepotCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Facility Certification Date' ;
    rdfs:comment 'Date when this specific depot received certification under this compliance program. Distinct from the program\'s general issue_date as each facility is certified individually.' ;
    rdfs:domain ind:DepotCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentAttachmentId rdf:type rdf:Property ;
    rdfs:label 'Document Attachment Id' ;
    rdfs:comment 'Unique identifier for this freight order to trade document attachment record. Primary key for the association.' ;
    rdfs:domain ind:DocumentAttachment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewed By User Employee Id' ;
    rdfs:comment 'Reference to the compliance or operations user who reviewed this document attachment for completeness and accuracy. Nullable if not yet reviewed.' ;
    rdfs:domain ind:DocumentAttachment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attachedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Attached Timestamp' ;
    rdfs:comment 'Timestamp when this trade document was first attached to this freight order in the system. Used for process timeline tracking and SLA monitoring.' ;
    rdfs:domain ind:DocumentAttachment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsReference rdf:type rdf:Property ;
    rdfs:label 'Customs Reference' ;
    rdfs:comment 'Reference number assigned by customs authority to this specific document submission for this freight order. Used for tracking clearance status and correspondence with customs.' ;
    rdfs:domain ind:DocumentAttachment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredFlag rdf:type rdf:Property ;
    rdfs:label 'Required Flag' ;
    rdfs:comment 'Indicates whether this trade document is mandatory for customs clearance of this freight order based on origin/destination countries, commodity type, and incoterms. Drives compliance validation.' ;
    rdfs:domain ind:DocumentAttachment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Lane Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for the lane assignment record. Primary key.' ;
    rdfs:domain ind:LaneAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when the employee\'s assignment to this lane ended or is scheduled to end. Null indicates an active ongoing assignment.' ;
    rdfs:domain ind:LaneAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when the employee\'s assignment to manage this lane became effective. Used for historical tracking and workforce planning.' ;
    rdfs:domain ind:LaneAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryBackupFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Backup Flag' ;
    rdfs:comment 'Indicates whether this employee is the primary responsible party for this lane or serves as a backup. Used for escalation routing and succession planning.' ;
    rdfs:domain ind:LaneAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'The specific role or function the employee performs for this lane (e.g., lane_manager, lane_analyst, lane_coordinator, customs_specialist, hazmat_coordinator). Different roles have different responsibilities and certification requirements.' ;
    rdfs:domain ind:LaneAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workloadPercentage rdf:type rdf:Property ;
    rdfs:label 'Workload Percentage' ;
    rdfs:comment 'Percentage of the employee\'s total workload allocated to this lane. Used for capacity planning and workload balancing across multiple lane assignments. Scale 0-100.' ;
    rdfs:domain ind:LaneAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laneFulfillmentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Lane Fulfillment Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for the lane-fulfillment center allocation record. Primary key.' ;
    rdfs:domain ind:LaneFulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityAllocation rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation' ;
    rdfs:comment 'Maximum capacity (in CBM or weight units) allocated to this fulfillment center on this lane. Used to enforce capacity constraints during shipment routing and prevent overallocation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantComplianceEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Merchant Compliance Enrollment Id' ;
    rdfs:comment 'Unique identifier for this merchant-program enrollment record. Primary key for the association.' ;
    rdfs:domain ind:MerchantComplianceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitsActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Benefits Active Flag' ;
    rdfs:comment 'Indicates whether this merchant is currently receiving the preferential treatment benefits (reduced examination rates, expedited release) associated with this program enrollment.' ;
    rdfs:domain ind:MerchantComplianceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:merchantCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Merchant Certificate Number' ;
    rdfs:comment 'Unique certificate or membership number issued to this merchant for this specific program enrollment.' ;
    rdfs:domain ind:MerchantComplianceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantCarrierAgreementId rdf:type rdf:Property ;
    rdfs:label 'Merchant Carrier Agreement Id' ;
    rdfs:comment 'Primary key for merchant_carrier_agreement' ;
    rdfs:domain ind:MerchantCarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchantCarrierAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Carrier Agreement Status' ;
    rdfs:comment 'Current lifecycle status of this merchant-carrier agreement: active (operational), suspended (temporarily inactive), expired (past expiry_date), terminated (ended before expiry).' ;
    rdfs:domain ind:MerchantCarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardReference rdf:type rdf:Property ;
    rdfs:label 'Rate Card Reference' ;
    rdfs:comment 'Reference code to the negotiated rate card document or pricing schedule applicable to this merchant-carrier relationship. Rates vary by merchant volume and contract terms.' ;
    rdfs:domain ind:MerchantCarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelsAuthorized rdf:type rdf:Property ;
    rdfs:label 'Service Levels Authorized' ;
    rdfs:comment 'Comma-separated list of service levels the merchant is authorized to use with this carrier (e.g., express, standard, economy, freight). Varies by merchant-carrier agreement.' ;
    rdfs:domain ind:MerchantCarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAccountabilityId rdf:type rdf:Property ;
    rdfs:label 'Target Accountability Id' ;
    rdfs:comment 'Unique identifier for this accountability assignment record. Primary key.' ;
    rdfs:domain ind:TargetAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountabilityLevel rdf:type rdf:Property ;
    rdfs:label 'Accountability Level' ;
    rdfs:comment 'The level of accountability this organizational unit holds for the target. Primary indicates direct ownership and decision-making authority. Secondary indicates shared responsibility with reporting obligations. Contributing indicates supporting role. Monitoring indicates oversight or tracking responsibility without operational accountability.' ;
    rdfs:domain ind:TargetAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocation rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation' ;
    rdfs:comment 'The budget amount in USD allocated to this organizational unit specifically for achieving their portion of this sustainability target. Used for tracking investment in emissions reduction projects, renewable energy initiatives, waste reduction programs, etc.' ;
    rdfs:domain ind:TargetAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationThreshold rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold' ;
    rdfs:comment 'The percentage variance from target trajectory that triggers escalation to executive leadership. For example, if set to 10.00, any deviation of 10% or more from the planned progress path requires escalation and corrective action planning.' ;
    rdfs:domain ind:TargetAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneOwnership rdf:type rdf:Property ;
    rdfs:label 'Milestone Ownership' ;
    rdfs:comment 'Indicates whether this organizational unit owns specific interim milestones for this target. Full ownership means the unit is responsible for achieving defined milestones. Partial means shared milestone responsibility. None means the unit contributes to the overall target but does not own specific milestones.' ;
    rdfs:domain ind:TargetAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingResponsibility rdf:type rdf:Property ;
    rdfs:label 'Reporting Responsibility' ;
    rdfs:comment 'The frequency and nature of reporting obligations this organizational unit has for progress against this target. Defines whether the unit must submit monthly progress reports, quarterly updates, annual summaries, or ad-hoc reports as requested.' ;
    rdfs:domain ind:TargetAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleExecutive rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive' ;
    rdfs:comment 'Name or identifier of the executive within this organizational unit who holds ultimate accountability for this target assignment. Used for escalation and executive reporting.' ;
    rdfs:domain ind:TargetAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Allocation Percentage' ;
    rdfs:comment 'The percentage of the overall sustainability target allocated to this organizational unit. Used when a corporate target is split across multiple business units (e.g., 40% of emissions reduction target assigned to freight operations, 30% to warehouse operations, 30% to fleet). Sum of allocations across all org units for a given target should equal 100%.' ;
    rdfs:domain ind:TargetAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedServiceId rdf:type rdf:Property ;
    rdfs:label 'Contracted Service Id' ;
    rdfs:comment 'Unique identifier for this contracted service relationship. Primary key.' ;
    rdfs:domain ind:ContractedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'The priority ranking for allocating shipments to this contracted service when multiple contracted services are available for a lane (1=highest priority).' ;
    rdfs:domain ind:ContractedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'The negotiated rate for this specific carrier service under this procurement contract. Rate structure varies by service (per kg, per shipment, per container).' ;
    rdfs:domain ind:ContractedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeFormula rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Formula' ;
    rdfs:comment 'The formula or reference index used to calculate fuel surcharges for this service (e.g., DOE index, carrier-specific table).' ;
    rdfs:domain ind:ContractedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelTarget rdf:type rdf:Property ;
    rdfs:label 'Service Level Target' ;
    rdfs:comment 'The specific SLA target negotiated for this service (e.g., 99.5% on-time delivery, 48-hour transit time guarantee).' ;
    rdfs:domain ind:ContractedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programTrainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Program Training Requirement Id' ;
    rdfs:comment 'Unique identifier for this program-training requirement record. Primary key.' ;
    rdfs:domain ind:ProgramTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyTrainingId rdf:type rdf:Property ;
    rdfs:label 'Safety Training Id' ;
    rdfs:comment 'Foreign key to safety_training' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Training .

ind:completionDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Completion Deadline Days' ;
    rdfs:comment 'Number of days from program enrollment or effective date by which this training must be completed. Used for compliance tracking and scheduling.' ;
    rdfs:domain ind:ProgramTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Frequency Months' ;
    rdfs:comment 'Number of months between required completions or refreshers for this training within this program. Null indicates one-time requirement with no refresher.' ;
    rdfs:domain ind:ProgramTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current lifecycle status of this training requirement within the program. Active requirements are enforced; suspended are temporarily not enforced; under review are being evaluated; retired are no longer applicable.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementType rdf:type rdf:Property ;
    rdfs:label 'Requirement Type' ;
    rdfs:comment 'Classification of the requirement level for this training within this program. Mandatory training must be completed by all program participants; recommended is strongly advised; conditional depends on role or risk exposure; optional is available but not required.' ;
    rdfs:domain ind:ProgramTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceRole rdf:type rdf:Property ;
    rdfs:label 'Target Audience Role' ;
    rdfs:comment 'Specific role, job function, or participant category within the program for which this training is required (e.g., all drivers, warehouse supervisors, DG handlers, program coordinators). Allows role-specific training requirements within a program.' ;
    rdfs:domain ind:ProgramTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneSurchargeApplicationId rdf:type rdf:Property ;
    rdfs:label 'Lane Surcharge Application Id' ;
    rdfs:comment 'Unique identifier for this specific surcharge application to a lane. Primary key.' ;
    rdfs:domain ind:LaneSurchargeApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierOffsetParticipationId rdf:type rdf:Property ;
    rdfs:label 'Carrier Offset Participation Id' ;
    rdfs:comment 'Unique identifier for this carrier-program participation record. Primary key.' ;
    rdfs:domain ind:CarrierOffsetParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceMandate rdf:type rdf:Property ;
    rdfs:label 'Compliance Mandate' ;
    rdfs:comment 'The regulatory or business mandate driving this carrier\'s participation in this offset program. Examples: CORSIA (aviation), EU_ETS (European emissions trading), voluntary (corporate sustainability), state_mandate, customer_requirement.' ;
    rdfs:domain ind:CarrierOffsetParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditsAllocatedTco2e rdf:type rdf:Property ;
    rdfs:label 'Credits Allocated Tco2e' ;
    rdfs:comment 'The quantity of carbon offset credits (in tonnes CO2e) from this program that have been allocated to this carrier\'s account or inventory. Tracks the carrier\'s share of program credits.' ;
    rdfs:domain ind:CarrierOffsetParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditsRetiredByCarrierTco2e rdf:type rdf:Property ;
    rdfs:label 'Credits Retired By Carrier Tco2e' ;
    rdfs:comment 'The quantity of carbon offset credits (in tonnes CO2e) from this program that this carrier has permanently retired for compliance or voluntary offsetting purposes.' ;
    rdfs:domain ind:CarrierOffsetParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleDgRequirementId rdf:type rdf:Property ;
    rdfs:label 'Schedule Dg Requirement Id' ;
    rdfs:comment 'Unique identifier for this schedule-certification requirement record. Primary key.' ;
    rdfs:domain ind:ScheduleDgRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationRequiredDate rdf:type rdf:Property ;
    rdfs:label 'Certification Required Date' ;
    rdfs:comment 'The date from which this certification became required for this carrier schedule, typically driven by regulatory changes or schedule modifications to carry new DG classes.' ;
    rdfs:domain ind:ScheduleDgRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Verification Date' ;
    rdfs:comment 'The date on which the certification was last verified as valid and applicable for this schedule, typically performed before schedule execution or during compliance audits.' ;
    rdfs:domain ind:ScheduleDgRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dgClassApplicable rdf:type rdf:Property ;
    rdfs:label 'Dg Class Applicable' ;
    rdfs:comment 'The specific UN dangerous goods class (e.g., 3, 4.1, 8) that this certification requirement addresses for this schedule. A schedule carrying multiple DG classes will have multiple requirement records.' ;
    rdfs:domain ind:ScheduleDgRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Allocation Id' ;
    rdfs:comment 'Primary key for fulfillment_allocation' ;
    rdfs:domain ind:FulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationId rdf:type rdf:Property ;
    rdfs:label 'Allocation Id' ;
    rdfs:comment 'Unique identifier for this facility allocation record. Primary key.' ;
    rdfs:domain ind:FulfillmentAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentAllocation .

ind:capacityAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation Percentage' ;
    rdfs:comment 'Percentage of the fulfillment center\'s total capacity allocated to this agreement, used for capacity planning and order prioritization. Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:FulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentProgramEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Program Enrollment Id' ;
    rdfs:comment 'Primary key for fulfillment_program_enrollment' ;
    rdfs:domain ind:FulfillmentProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Coordinator Employee Id' ;
    rdfs:comment 'Identifier of the employee assigned as the local coordinator for this program at this specific fulfillment center. Explicitly identified in detection data as relationship attribute.' ;
    rdfs:domain ind:FulfillmentProgramEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Level or tier of certification achieved by the fulfillment center for this program (e.g., Bronze, Silver, Gold, Platinum for tiered programs; or certification grade). Explicitly identified in detection data as relationship attribute.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsPending rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Pending' ;
    rdfs:comment 'Number of corrective actions currently open and pending closure for this facility-program enrollment.' ;
    rdfs:domain ind:FulfillmentProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Count' ;
    rdfs:comment 'Number of non-conformances or findings identified in the most recent audit for this enrollment.' ;
    rdfs:domain ind:FulfillmentProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceId rdf:type rdf:Property ;
    rdfs:label 'Service Id' ;
    rdfs:comment 'Unique identifier for this center-carrier service agreement. Primary key.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:days rdf:type rdf:Property ;
    rdfs:label 'Days' ;
    rdfs:comment 'Comma-separated list of days of the week this carrier provides pickup service at this fulfillment center (e.g., Mon,Tue,Wed,Thu,Fri). Service days vary by facility location and carrier route coverage.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementComplianceQualificationId rdf:type rdf:Property ;
    rdfs:label 'Agreement Compliance Qualification Id' ;
    rdfs:comment 'Unique identifier for this agreement-compliance program qualification record. Primary key.' ;
    rdfs:domain ind:AgreementComplianceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableTradeLanes rdf:type rdf:Property ;
    rdfs:label 'Applicable Trade Lanes' ;
    rdfs:comment 'Comma-separated list of trade lane codes or origin-destination pairs where this compliance program qualification applies for this agreement (e.g., US-EU, CN-US). Allows lane-specific program application.' ;
    rdfs:domain ind:AgreementComplianceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Effective Date' ;
    rdfs:comment 'Date from which the compliance program benefits become effective for shipments under this agreement. May differ from the programs general effective_date based on agreement-specific qualification timing.' ;
    rdfs:domain ind:AgreementComplianceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Expiry Date' ;
    rdfs:comment 'Date when the compliance program benefits expire for this agreement. May differ from the programs general expiry_date based on agreement-specific terms or renewal cycles.' ;
    rdfs:domain ind:AgreementComplianceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programBenefitTier rdf:type rdf:Property ;
    rdfs:label 'Program Benefit Tier' ;
    rdfs:comment 'Tier or level of customs benefits that this specific compliance program confers to this specific agreement (e.g., Standard, Enhanced, Premium). Benefit tier may vary by agreement based on volume, lanes, or negotiated terms.' ;
    rdfs:domain ind:AgreementComplianceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programReferenceDate rdf:type rdf:Property ;
    rdfs:label 'Program Reference Date' ;
    rdfs:comment 'Date when this compliance program was first referenced or associated with this agreement during contract negotiation or execution' ;
    rdfs:domain ind:AgreementComplianceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Verification Status' ;
    rdfs:comment 'Current verification status of this compliance program qualification for this agreement. Tracks whether the program benefits are actively applicable to shipments under this agreement.' ;
    rdfs:domain ind:AgreementComplianceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneComplianceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Lane Compliance Certification Id' ;
    rdfs:comment 'Unique identifier for this lane-specific compliance program certification record. Primary key for the association.' ;
    rdfs:domain ind:LaneComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laneEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Eligibility Status' ;
    rdfs:comment 'Current operational status of the compliance program benefits on this specific lane. Active means benefits are currently applicable; Suspended/Revoked means benefits temporarily or permanently unavailable on this lane due to compliance issues or program changes.' ;
    rdfs:domain ind:LaneComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reducedExaminationRate rdf:type rdf:Property ;
    rdfs:label 'Reduced Examination Rate' ;
    rdfs:comment 'Percentage reduction in physical customs examination rate granted for shipments on this lane under this compliance program (e.g., 75.00 means 75% reduction from standard examination rate). Lane-specific benefit that varies by origin-destination corridor risk profile.' ;
    rdfs:domain ind:LaneComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentAccessorialApplicationId rdf:type rdf:Property ;
    rdfs:label 'Consignment Accessorial Application Id' ;
    rdfs:comment 'Unique identifier for this specific application of an accessorial charge to a consignment. Primary key for the association.' ;
    rdfs:domain ind:ConsignmentAccessorialApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'The date and time when this accessorial charge was applied to the consignment. Typically set by the rating engine during shipment rating or by billing systems during invoice generation. Critical for audit trails and dispute resolution.' ;
    rdfs:domain ind:ConsignmentAccessorialApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appliedChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Charge Amount' ;
    rdfs:comment 'The actual charge amount applied to this consignment for this accessorial. May differ from the catalog charge_amount due to customer-specific contract rates, negotiated discounts, or manual adjustments. This is the billable amount.' ;
    rdfs:domain ind:ConsignmentAccessorialApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Applied Flag' ;
    rdfs:comment 'Indicates whether this accessorial charge was automatically applied by the rating engine based on business rules (true) or manually added by a billing analyst or customer service representative (false). Used for process improvement and automation metrics.' ;
    rdfs:domain ind:ConsignmentAccessorialApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdBySystem rdf:type rdf:Property ;
    rdfs:label 'Created By System' ;
    rdfs:comment 'Source system that created this accessorial application record. Examples: \'SAP_TM_Rating_Engine\', \'Oracle_TMS_Billing\', \'Manual_Billing_Portal\'. Used for data lineage and system integration troubleshooting.' ;
    rdfs:domain ind:ConsignmentAccessorialApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedFlag rdf:type rdf:Property ;
    rdfs:label 'Disputed Flag' ;
    rdfs:comment 'Indicates whether the customer has disputed this specific accessorial charge application. True means a dispute case has been opened. Used to track dispute rates by charge type and drive operational improvements.' ;
    rdfs:domain ind:ConsignmentAccessorialApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Timestamp' ;
    rdfs:comment 'Date and time when the waiver was approved. Used for audit compliance and management reporting on waiver patterns.' ;
    rdfs:domain ind:ConsignmentAccessorialApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consignmentConsolidationEntryId rdf:type rdf:Property ;
    rdfs:label 'Consignment Consolidation Entry Id' ;
    rdfs:comment 'Unique identifier for this consignment-consolidation entry record. Primary key for the association.' ;
    rdfs:domain ind:ConsignmentConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consolidation Entry Timestamp' ;
    rdfs:comment 'Precise date and time when this consignment was physically loaded into the consolidation container or ULD at the origin CFS facility. Used for cargo cut-off compliance tracking and operational audit trails.' ;
    rdfs:domain ind:ConsignmentConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deconsolidationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deconsolidation Timestamp' ;
    rdfs:comment 'Precise date and time when this consignment was physically unloaded from the consolidation at the destination CFS facility. Used for dwell time calculation, onward delivery planning, and SLA tracking.' ;
    rdfs:domain ind:ConsignmentConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of this consignment within this specific consolidation: planned (scheduled but not yet loaded), loaded (physically in container), in_transit (departed origin), arrived (at destination port), deconsolidated (unloaded at destination CFS), delivered (handed over for final delivery).' ;
    rdfs:domain ind:ConsignmentConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingUnitCount rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Count' ;
    rdfs:comment 'Number of handling units (pieces, pallets, cartons) from this specific consignment that were loaded into this specific consolidation. Critical when a consignment is split across multiple consolidations or when only partial pieces are consolidated.' ;
    rdfs:domain ind:ConsignmentConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadingRemarks rdf:type rdf:Property ;
    rdfs:label 'Loading Remarks' ;
    rdfs:comment 'Free-text operational notes recorded by CFS staff during loading operations, such as special handling performed, damage observed, or deviations from standard procedures.' ;
    rdfs:domain ind:ConsignmentConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceInConsolidation rdf:type rdf:Property ;
    rdfs:label 'Sequence In Consolidation' ;
    rdfs:comment 'The sequential order in which this consignment was loaded into the consolidation. Critical for CFS operations to determine unloading order (LIFO/FIFO) and for deconsolidation planning at destination CFS.' ;
    rdfs:domain ind:ConsignmentConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:splitShipmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Split Shipment Indicator' ;
    rdfs:comment 'Indicates whether this consignment was split across multiple consolidations due to capacity constraints or operational requirements. True if the consignment appears in more than one consolidation.' ;
    rdfs:domain ind:ConsignmentConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeInConsolidationCbm rdf:type rdf:Property ;
    rdfs:label 'Volume In Consolidation Cbm' ;
    rdfs:comment 'The volume in cubic meters of this consignment\'s cargo allocated to this specific consolidation. Used for capacity utilization tracking and pro-rata cost allocation.' ;
    rdfs:domain ind:ConsignmentConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightInConsolidationKg rdf:type rdf:Property ;
    rdfs:label 'Weight In Consolidation Kg' ;
    rdfs:comment 'The weight in kilograms of this consignment\'s cargo that was allocated to this specific consolidation. Essential for pro-rata freight charge allocation when a consignment is split across multiple consolidations, and for accurate consolidation weight reconciliation.' ;
    rdfs:domain ind:ConsignmentConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentOffsetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Consignment Offset Allocation Id' ;
    rdfs:comment 'Unique identifier for this consignment-offset program allocation record. Primary key.' ;
    rdfs:domain ind:ConsignmentOffsetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Allocation Cost Usd' ;
    rdfs:comment 'The cost incurred by Transport Shipping for this offset allocation, calculated as offset_quantity_tco2e multiplied by the program price per tonne at allocation time. Used for financial reconciliation and P&L attribution.' ;
    rdfs:domain ind:ConsignmentOffsetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Flag' ;
    rdfs:comment 'Boolean flag indicating whether a carbon offset certificate has been issued to the customer for this allocation. Used to track customer-facing deliverables and prevent duplicate issuance.' ;
    rdfs:domain ind:ConsignmentOffsetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerChargeUsd rdf:type rdf:Property ;
    rdfs:label 'Customer Charge Usd' ;
    rdfs:comment 'The amount charged to the customer for carbon-neutral shipping on this consignment, if customer_requested_flag is true. May differ from allocation_cost_usd due to pricing strategy.' ;
    rdfs:domain ind:ConsignmentOffsetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Requested Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer explicitly requested and paid for carbon-neutral shipping for this consignment. Used for revenue attribution and customer reporting.' ;
    rdfs:domain ind:ConsignmentOffsetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsetQuantityTco2e rdf:type rdf:Property ;
    rdfs:label 'Offset Quantity Tco2e' ;
    rdfs:comment 'The quantity of carbon offset credits allocated from this program to this consignment, measured in metric tonnes of CO2 equivalent. This is the core transactional attribute representing the actual offset applied.' ;
    rdfs:domain ind:ConsignmentOffsetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registryRetirementReference rdf:type rdf:Property ;
    rdfs:label 'Registry Retirement Reference' ;
    rdfs:comment 'The unique retirement transaction identifier from the external carbon offset registry (e.g., Verra, Gold Standard). Provides audit trail and verification link.' ;
    rdfs:domain ind:ConsignmentOffsetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementStatus rdf:type rdf:Property ;
    rdfs:label 'Retirement Status' ;
    rdfs:comment 'The lifecycle status of the allocated offset credits: allocated (reserved for this consignment), retired (permanently retired in registry), pending_retirement (awaiting registry confirmation), cancelled (allocation reversed).' ;
    rdfs:domain ind:ConsignmentOffsetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAgreementUtilizationId rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Utilization Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer account trade agreement utilization record. Primary key.' ;
    rdfs:domain ind:TradeAgreementUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualDutySavings rdf:type rdf:Property ;
    rdfs:label 'Annual Duty Savings' ;
    rdfs:comment 'Total customs duty amount saved in the current calendar year by applying preferential rates under this trade agreement for this customer account. Calculated as sum of (standard_duty_amount - preferential_duty_amount) across all shipments. Expressed in USD equivalent.' ;
    rdfs:domain ind:TradeAgreementUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateCount rdf:type rdf:Property ;
    rdfs:label 'Certificate Count' ;
    rdfs:comment 'Total number of Certificates of Origin issued for this customer account under this trade agreement in the current calendar year. Used to track documentation volume and compliance activity.' ;
    rdfs:domain ind:TradeAgreementUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Status' ;
    rdfs:comment 'Result of the most recent customs compliance audit for this customer-agreement utilization relationship. compliant = no issues found; minor_findings = documentation gaps that do not affect duty treatment; major_findings = issues requiring corrective action; non_compliant = preference claims suspended pending remediation; not_audited = no audit conducted yet.' ;
    rdfs:domain ind:TradeAgreementUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstUtilizationDate rdf:type rdf:Property ;
    rdfs:label 'First Utilization Date' ;
    rdfs:comment 'Calendar date when this customer account first claimed preferential duty treatment under this trade agreement. Marks the start of the utilization relationship.' ;
    rdfs:domain ind:TradeAgreementUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferenceEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Eligibility Status' ;
    rdfs:comment 'Current eligibility status of the customer account to claim preferential duty rates under this trade agreement. eligible = account meets all origin and compliance criteria; conditionally_eligible = eligible subject to specific product restrictions or documentation requirements; ineligible = account does not meet agreement criteria; under_review = eligibility assessment in progress; suspended = eligibility temporarily revoked due to compliance issues.' ;
    rdfs:domain ind:TradeAgreementUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalShipmentsClaimed rdf:type rdf:Property ;
    rdfs:label 'Total Shipments Claimed' ;
    rdfs:comment 'Cumulative count of shipments for which this customer account has claimed preferential duty treatment under this trade agreement since first utilization date.' ;
    rdfs:domain ind:TradeAgreementUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationRate rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate' ;
    rdfs:comment 'Percentage of eligible shipments under this customer-agreement combination for which preferential duty treatment was actually claimed. Calculated as (shipments_with_preference_claimed / total_eligible_shipments) * 100. Used to measure FTA adoption and identify optimization opportunities.' ;
    rdfs:domain ind:TradeAgreementUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Zone Service Agreement Id' ;
    rdfs:comment 'Unique identifier for this customer-zone service agreement record. Primary key.' ;
    rdfs:domain ind:ZoneServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customTransitDays rdf:type rdf:Property ;
    rdfs:label 'Custom Transit Days' ;
    rdfs:comment 'Customer-specific guaranteed transit time in business days for deliveries to this zone, overriding the zones standard transit days. Null if standard zone transit applies.' ;
    rdfs:domain ind:ZoneServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatedRateDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate Discount Pct' ;
    rdfs:comment 'Percentage discount off standard zone rates negotiated for this customer-zone combination. Applied during shipment rating. Null if no discount applies.' ;
    rdfs:domain ind:ZoneServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelOverride rdf:type rdf:Property ;
    rdfs:label 'Service Level Override' ;
    rdfs:comment 'Customer-specific service level commitment for this zone, overriding the zones default service level. Captured from contract negotiations.' ;
    rdfs:domain ind:ZoneServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeWaiverFlag rdf:type rdf:Property ;
    rdfs:label 'Surcharge Waiver Flag' ;
    rdfs:comment 'Indicates whether remote area, residential, or other zone-specific surcharges are waived for this customer in this zone as part of negotiated contract terms.' ;
    rdfs:domain ind:ZoneServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateCardAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Assignment Id' ;
    rdfs:comment 'Unique identifier for this rate card assignment record. Primary key.' ;
    rdfs:domain ind:RateCardAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneRateId rdf:type rdf:Property ;
    rdfs:label 'Zone Rate Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer-zone rate agreement record. Primary key for the association.' ;
    rdfs:domain ind:ZoneRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guaranteedTransitDays rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Transit Days' ;
    rdfs:comment 'Customer-specific guaranteed transit time in business days for this zone. May differ from the zones standard_transit_days based on customer SLA tier.' ;
    rdfs:domain ind:ZoneRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityHandling rdf:type rdf:Property ;
    rdfs:label 'Priority Handling' ;
    rdfs:comment 'Indicates whether shipments for this customer in this zone receive priority handling or expedited processing as part of the service agreement.' ;
    rdfs:domain ind:ZoneRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteAreaSurchargeWaived rdf:type rdf:Property ;
    rdfs:label 'Remote Area Surcharge Waived' ;
    rdfs:comment 'Indicates whether the remote area surcharge has been waived for this customer in this zone as part of contract negotiation.' ;
    rdfs:domain ind:ZoneRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialSurchargeWaived rdf:type rdf:Property ;
    rdfs:label 'Residential Surcharge Waived' ;
    rdfs:comment 'Indicates whether the residential delivery surcharge has been waived for this customer in this zone as part of contract negotiation.' ;
    rdfs:domain ind:ZoneRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Surcharge Applicable' ;
    rdfs:comment 'Indicates whether remote area, residential, or peak surcharges apply to this customer for shipments in this zone. Customer-specific override of zone-level surcharge flags.' ;
    rdfs:domain ind:ZoneRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneRate rdf:type rdf:Property ;
    rdfs:label 'Zone Rate' ;
    rdfs:comment 'Customer-specific negotiated rate per shipment or per kilogram for delivery within this zone. Overrides standard zone pricing for this customer account.' ;
    rdfs:domain ind:ZoneRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laneQualificationId rdf:type rdf:Property ;
    rdfs:label 'Lane Qualification Id' ;
    rdfs:comment 'Unique surrogate identifier for this driver-lane qualification record. Primary key.' ;
    rdfs:domain ind:LaneQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedBy rdf:type rdf:Property ;
    rdfs:label 'Authorized By' ;
    rdfs:comment 'Name or employee ID of the fleet manager or compliance officer who authorized this driver for this lane. Used for audit trail and accountability.' ;
    rdfs:domain ind:LaneQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssignmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assignment Date' ;
    rdfs:comment 'Date this driver was most recently assigned to a shipment or route on this lane. Used for recency tracking and load balancing in dispatch planning.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date the driver was certified or authorized to operate on this specific lane. Used for compliance audit trails and qualification history tracking.' ;
    rdfs:domain ind:LaneQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tripCount rdf:type rdf:Property ;
    rdfs:label 'Trip Count' ;
    rdfs:comment 'Total number of completed trips this driver has executed on this specific lane. Used for experience tracking, performance analysis, and dispatch prioritization.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driverCertificationId rdf:type rdf:Property ;
    rdfs:label 'Driver Certification Id' ;
    rdfs:comment 'Unique identifier for this driver-program certification record. Primary key.' ;
    rdfs:domain ind:DriverCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date when the driver was certified or approved under this specific compliance program. Represents when the driver met all program requirements.' ;
    rdfs:domain ind:DriverCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifyingOfficer rdf:type rdf:Property ;
    rdfs:label 'Certifying Officer' ;
    rdfs:comment 'Name or identifier of the compliance officer or fleet manager who approved this driver certification under this program.' ;
    rdfs:domain ind:DriverCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Certification Expiry Date' ;
    rdfs:comment 'Expiry date of the IATA dangerous goods certification. Null if driver does not hold this certification. [Moved from driver_profile: This attribute represents the expiry date of the IATA dangerous goods certificate. It should move to driver_certification as expiry_date where certificate_type=\'Dangerous Goods\', enabling unified certificate lifecycle management.]' ;
    rdfs:domain ind:DriverCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dangerousGoodsCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Certification Flag' ;
    rdfs:comment 'Indicates whether the driver holds IATA dangerous goods training certification for air cargo handling and transport. True if certified, False otherwise. [Moved from driver_profile: This flag indicates whether a driver holds an IATA dangerous goods certificate. This should be represented as a record in driver_certification where certificate_type=\'Dangerous Goods\' with certification_status=\'Active\' rather than as a boolean flag.]' ;
    rdfs:domain ind:DriverCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatEndorsementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Endorsement Expiry Date' ;
    rdfs:comment 'Expiry date of the hazmat endorsement. Null if driver does not hold hazmat endorsement. [Moved from driver_profile: This attribute represents the expiry date of the hazmat certificate. It should move to driver_certification as expiry_date where certificate_type=\'Hazmat Endorsement\', consistent with the normalized certificate tracking model.]' ;
    rdfs:domain ind:DriverCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatEndorsementFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Endorsement Flag' ;
    rdfs:comment 'Indicates whether the driver holds a valid hazmat endorsement allowing them to transport dangerous goods by road. True if endorsed, False otherwise. [Moved from driver_profile: This flag indicates whether a driver holds a hazmat certificate. This should be represented as a record in driver_certification where certificate_type=\'Hazmat Endorsement\' with certification_status=\'Active\' rather than as a boolean flag on the driver profile.]' ;
    rdfs:domain ind:DriverCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSafetyTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Safety Training Date' ;
    rdfs:comment 'Date the driver last completed mandatory safety training. Used to ensure compliance with periodic training requirements. [Moved from driver_profile: This represents the completion date of safety training, which results in a training certificate. It should move to driver_certification as training_completion_date where certificate_type=\'Safety Training Certificate\'.]' ;
    rdfs:domain ind:DriverCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Expiry Date' ;
    rdfs:comment 'Expiry date of the driver\'s DOT medical examiner certificate (US) or equivalent medical fitness certificate required for commercial vehicle operation. Drivers must maintain valid medical certification to operate. [Moved from driver_profile: This attribute represents the expiry date of a specific certificate (DOT medical certificate) held by a driver. It should move to the driver_certification association as expiry_date where certificate_type=\'Medical Certificate\'. This allows tracking of multiple certificate types with their individual expiry dates in a normalized structure.]' ;
    rdfs:domain ind:DriverCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextSafetyTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Safety Training Due Date' ;
    rdfs:comment 'Date by which the driver must complete their next mandatory safety training to maintain compliance. [Moved from driver_profile: This represents when the next safety training is due, which is effectively the renewal date for the safety training certificate. It should move to driver_certification as next_renewal_due_date where certificate_type=\'Safety Training Certificate\'.]' ;
    rdfs:domain ind:DriverCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:driverEngagementId rdf:type rdf:Property ;
    rdfs:label 'Driver Engagement Id' ;
    rdfs:comment 'Unique identifier for this driver-carrier engagement record. Primary key for the association.' ;
    rdfs:domain ind:DriverEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierSpecificTrainingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Carrier Specific Training Completed Flag' ;
    rdfs:comment 'Indicates whether the driver has completed mandatory training specific to this carrier\'s operations, systems, and procedures. Many carriers require proprietary training beyond general licensing.' ;
    rdfs:domain ind:DriverEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierSpecificTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Carrier Specific Training Date' ;
    rdfs:comment 'Date when the driver completed carrier-specific training for this engagement. Null if training not yet completed.' ;
    rdfs:domain ind:DriverEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Percentage commission rate paid to the driver for deliveries or routes completed under this carrier engagement. Expressed as percentage (e.g., 15.50 for 15.5%). Varies by carrier and driver negotiation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverEngagementType rdf:type rdf:Property ;
    rdfs:label 'Driver Engagement Type' ;
    rdfs:comment 'Classification of the engagement relationship. Exclusive: driver works only for this carrier. Non-exclusive: driver can work for multiple carriers simultaneously. Platform: gig-economy platform engagement. Seasonal: temporary engagement for peak periods. Project-based: engagement for specific routes or projects.' ;
    rdfs:domain ind:DriverEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAssignmentsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Assignments Completed' ;
    rdfs:comment 'Cumulative count of route assignments or deliveries completed by this driver for this specific carrier. Performance metric tracked per engagement.' ;
    rdfs:domain ind:DriverEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetTrainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Fleet Training Completion Id' ;
    rdfs:comment 'Primary key for fleet_training_completion' ;
    rdfs:domain ind:FleetTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Training Completion Id' ;
    rdfs:comment 'Unique identifier for this training completion record. Primary key.' ;
    rdfs:domain ind:FleetTrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceTrainingCompletion .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date by which the driver must complete refresher training to maintain compliance. Calculated from completion_date plus refresher_frequency_months.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hubEmergencyPlanId rdf:type rdf:Property ;
    rdfs:label 'Hub Emergency Plan Id' ;
    rdfs:comment 'Primary key for the hub_emergency_plan association' ;
    rdfs:domain ind:HubEmergencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationCascade rdf:type rdf:Property ;
    rdfs:label 'Communication Cascade' ;
    rdfs:comment 'Hub-specific communication cascade procedure outlining notification sequence for personnel at this facility when this emergency plan is activated' ;
    rdfs:domain ind:HubEmergencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinationProtocol rdf:type rdf:Property ;
    rdfs:label 'Coordination Protocol' ;
    rdfs:comment 'Documented procedure for coordinating emergency response between the hub facility and the plan\'s emergency coordinator, including escalation paths and communication channels specific to this hub-plan combination' ;
    rdfs:domain ind:HubEmergencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitySpecificNotes rdf:type rdf:Property ;
    rdfs:label 'Facility Specific Notes' ;
    rdfs:comment 'Free-text notes capturing facility-specific considerations, adaptations, or constraints for implementing this emergency plan at this hub/gateway' ;
    rdfs:domain ind:HubEmergencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localEmergencyContact rdf:type rdf:Property ;
    rdfs:label 'Local Emergency Contact' ;
    rdfs:comment 'Hub-specific emergency contact person and phone number for this plan, may differ from the plan\'s global emergency coordinator' ;
    rdfs:domain ind:HubEmergencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planActivationAuthority rdf:type rdf:Property ;
    rdfs:label 'Plan Activation Authority' ;
    rdfs:comment 'Designated authority or role responsible for activating this specific emergency response plan at this hub/gateway facility (e.g., Hub Manager, Safety Officer, Regional Emergency Coordinator)' ;
    rdfs:domain ind:HubEmergencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneFacilityServiceId rdf:type rdf:Property ;
    rdfs:label 'Lane Facility Service Id' ;
    rdfs:comment 'Unique surrogate identifier for this lane-facility service configuration record. Primary key.' ;
    rdfs:domain ind:LaneFacilityService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDailyVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Max Daily Volume Units' ;
    rdfs:comment 'Maximum number of units (pallets, cartons, or SKUs) this facility can process per day for this specific lane. Used for capacity-constrained routing and load optimization. May be lower than facility.max_daily_outbound_volume_units due to lane-specific constraints.' ;
    rdfs:domain ind:LaneFacilityService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTransitDays rdf:type rdf:Property ;
    rdfs:label 'Sla Transit Days' ;
    rdfs:comment 'Committed transit time in calendar days for shipments on this lane when processed through this specific facility. May differ from lane.standard_transit_days based on facility-specific processing capabilities and location.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityAgreementId rdf:type rdf:Property ;
    rdfs:label 'Facility Agreement Id' ;
    rdfs:comment 'Unique identifier for this facility-agreement association record. Primary key.' ;
    rdfs:domain ind:FacilityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedCapacityPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Percentage' ;
    rdfs:comment 'Percentage of the facility\'s total storage capacity allocated to this agreement. Used in multi-tenant warehousing to manage capacity commitments across multiple customers. Sum of all allocations at a facility should not exceed 100%.' ;
    rdfs:domain ind:FacilityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingRateOverride rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Override' ;
    rdfs:comment 'Facility-specific billing rate that overrides the master agreement rate for this facility. Used when different facilities have different cost structures or service levels. Nullable if master agreement rate applies.' ;
    rdfs:domain ind:FacilityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Agreement Status' ;
    rdfs:comment 'Current operational status of services at this facility under this agreement. Allows facility-level service suspension or termination independent of the master agreement status.' ;
    rdfs:domain ind:FacilityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestSupplierPickupId rdf:type rdf:Property ;
    rdfs:label 'Manifest Supplier Pickup Id' ;
    rdfs:comment 'Unique identifier for this manifest-supplier pickup record. Primary key.' ;
    rdfs:domain ind:ManifestSupplierPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consignmentCount rdf:type rdf:Property ;
    rdfs:label 'Consignment Count' ;
    rdfs:comment 'Number of individual consignments (shipments) collected from this supplier for this manifest. Used for load reconciliation and supplier performance metrics.' ;
    rdfs:domain ind:ManifestSupplierPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupSequence rdf:type rdf:Property ;
    rdfs:label 'Pickup Sequence' ;
    rdfs:comment 'The ordinal position of this supplier in the milk run route sequence (1st stop, 2nd stop, etc.). Critical for route optimization and driver instructions.' ;
    rdfs:domain ind:ManifestSupplierPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupStatus rdf:type rdf:Property ;
    rdfs:label 'Pickup Status' ;
    rdfs:comment 'Current status of the pickup at this supplier location (scheduled, in_transit, completed, missed, cancelled). Tracks execution state for operational visibility.' ;
    rdfs:domain ind:ManifestSupplierPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Pickup Timestamp' ;
    rdfs:comment 'Scheduled date and time for pickup at this supplier location as planned by the TMS route optimizer. Used to measure pickup punctuality.' ;
    rdfs:domain ind:ManifestSupplierPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentAgentServiceId rdf:type rdf:Property ;
    rdfs:label 'Shipment Agent Service Id' ;
    rdfs:comment 'Unique identifier for this shipment-agent service assignment record' ;
    rdfs:domain ind:ShipmentAgentService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the handling_fee amount (e.g., USD, EUR, GBP)' ;
    rdfs:domain ind:ShipmentAgentService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingFee rdf:type rdf:Property ;
    rdfs:label 'Handling Fee' ;
    rdfs:comment 'The handling fee amount charged by the agent for services rendered on this specific shipment, covering activities such as documentation, customs processing, or local delivery coordination' ;
    rdfs:domain ind:ShipmentAgentService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'The geographic territory or location where this agent is responsible for servicing this shipment, typically expressed as a country code, city, port code, or region identifier' ;
    rdfs:domain ind:ShipmentAgentService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonAllocationId rdf:type rdf:Property ;
    rdfs:label 'Carbon Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for the freight carbon offset allocation record. Primary key.' ;
    rdfs:domain ind:CarbonAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderFreightOrderId rdf:type rdf:Property ;
    rdfs:label 'Order Freight Order Id' ;
    rdfs:comment 'Foreign key linking to the freight order receiving carbon offset allocation' ;
    rdfs:domain ind:CarbonAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:customerOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Opt In Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer explicitly opted in to carbon offset allocation for this freight order. True indicates customer-initiated carbon neutrality request; false indicates corporate default allocation policy applied.' ;
    rdfs:domain ind:CarbonAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityTco2eAllocated rdf:type rdf:Property ;
    rdfs:label 'Quantity Tco2e Allocated' ;
    rdfs:comment 'The quantity of carbon offset credits in metric tonnes CO2e allocated from this program to this freight order. This value represents the portion of the freight order\'s carbon footprint neutralized by this specific program allocation.' ;
    rdfs:domain ind:CarbonAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Retirement Certificate Number' ;
    rdfs:comment 'The unique certificate or serial number issued by the carbon offset registry when credits are permanently retired for this freight order. Provides audit trail and proof of carbon neutrality claim.' ;
    rdfs:domain ind:CarbonAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAllocationCost rdf:type rdf:Property ;
    rdfs:label 'Total Allocation Cost' ;
    rdfs:comment 'The total cost of this carbon offset allocation, calculated as quantity_tco2e_allocated multiplied by unit_cost_per_tonne. Used for cost accounting and customer billing when carbon offsets are a billable service.' ;
    rdfs:domain ind:CarbonAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCostPerTonne rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Per Tonne' ;
    rdfs:comment 'The actual cost per metric tonne CO2e paid for this specific allocation, captured at the time of allocation. May differ from the program\'s listed price due to volume discounts, contract terms, or market fluctuations.' ;
    rdfs:domain ind:CarbonAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laneBudgetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Lane Budget Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for the lane-budget allocation record. Primary key.' ;
    rdfs:domain ind:LaneBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Allocated By Employee Id' ;
    rdfs:comment 'Reference to the employee or budget planner who created this lane-budget allocation.' ;
    rdfs:domain ind:LaneBudgetAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Spend Amount' ;
    rdfs:comment 'The monetary amount allocated from this budget line to this specific lane for the fiscal period. Used for lane-level budget tracking and variance analysis.' ;
    rdfs:domain ind:LaneBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationEffectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective From' ;
    rdfs:comment 'The date from which this budget allocation becomes active and available for lane operations.' ;
    rdfs:domain ind:LaneBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationEffectiveTo rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective To' ;
    rdfs:comment 'The date on which this budget allocation expires or is closed. Nullable for open-ended allocations.' ;
    rdfs:domain ind:LaneBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laneSafetyProgramRequirementId rdf:type rdf:Property ;
    rdfs:label 'Lane Safety Program Requirement Id' ;
    rdfs:comment 'Unique identifier for this lane-safety program requirement record. Primary key.' ;
    rdfs:domain ind:LaneSafetyProgramRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exemptionAuthority rdf:type rdf:Property ;
    rdfs:label 'Exemption Authority' ;
    rdfs:comment 'Name of the regulatory body or internal authority that granted the exemption. Null if no exemption applies.' ;
    rdfs:domain ind:LaneSafetyProgramRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Exemption Expiry Date' ;
    rdfs:comment 'Date on which the exemption expires and the lane must become compliant. Null if no exemption or exemption is permanent.' ;
    rdfs:domain ind:LaneSafetyProgramRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laneRiskTier rdf:type rdf:Property ;
    rdfs:label 'Lane Risk Tier' ;
    rdfs:comment 'Risk tier classification of this specific lane within the context of this safety program (e.g., HIGH for hazmat lanes under DG safety program, MEDIUM for cross-border lanes under border security program). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:LaneSafetyProgramRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryForLaneFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory For Lane Flag' ;
    rdfs:comment 'Indicates whether this safety program is mandatory for operational approval of this lane, or optional/recommended. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:LaneSafetyProgramRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Date' ;
    rdfs:comment 'Date on which this lane was enrolled in or became subject to this safety program requirement. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:LaneSafetyProgramRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchantSafetyCertificationId rdf:type rdf:Property ;
    rdfs:label 'Merchant Safety Certification Id' ;
    rdfs:comment 'Unique identifier for this merchant-training certification record. Primary key.' ;
    rdfs:domain ind:MerchantSafetyCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costAllocation rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation' ;
    rdfs:comment 'Cost allocated to this specific merchant for completing this training course. Sourced from detection phase relationship_data: training_cost_allocation. May differ from standard cost_per_participant if group discounts or merchant-specific pricing applies.' ;
    rdfs:domain ind:MerchantSafetyCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRecertificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Recertification Date' ;
    rdfs:comment 'Scheduled date when the merchant must recertify or renew this training to maintain compliance. Sourced from detection phase relationship_data: next_recertification_date. Calculated based on completion_date plus refresher_frequency_months from the training course master.' ;
    rdfs:domain ind:MerchantSafetyCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scoreAchieved rdf:type rdf:Property ;
    rdfs:label 'Score Achieved' ;
    rdfs:comment 'Percentage score achieved by the merchant on the competency assessment for this training course. Null if assessment method does not produce a numeric score.' ;
    rdfs:domain ind:MerchantSafetyCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingDeliveryModeUsed rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Mode Used' ;
    rdfs:comment 'The actual delivery mode used for this specific merchant completion. May differ from the course default if multiple modes are offered.' ;
    rdfs:domain ind:MerchantSafetyCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityTeamMemberId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Team Member Id' ;
    rdfs:comment 'Unique identifier for this opportunity team member assignment record' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Split Percentage' ;
    rdfs:comment 'Percentage of total commission this team member will receive if the opportunity closes successfully. Used for compensation calculation and incentive alignment. Sum across team members equals 100%.' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Contribution Percentage' ;
    rdfs:comment 'Percentage of effort or value this team member contributes to the opportunity, used for workload analysis and performance evaluation. Sum across all team members for an opportunity typically equals 100%.' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursAllocated rdf:type rdf:Property ;
    rdfs:label 'Hours Allocated' ;
    rdfs:comment 'Estimated or actual hours this employee is expected to dedicate to this opportunity. Used for capacity planning and utilization analysis across the sales organization.' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryOwner rdf:type rdf:Property ;
    rdfs:label 'Is Primary Owner' ;
    rdfs:comment 'Indicates whether this team member is the primary owner/account executive responsible for the opportunity. Typically one primary owner per opportunity, used for reporting and accountability.' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teamRole rdf:type rdf:Property ;
    rdfs:label 'Team Role' ;
    rdfs:comment 'The specific role this employee plays in pursuing this opportunity. Defines responsibility and expertise area (e.g., Account Executive owns relationship, Sales Engineer provides technical solution design, Pricing Analyst develops rate proposals).' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSustainabilityContributionId rdf:type rdf:Property ;
    rdfs:label 'Contract Sustainability Contribution Id' ;
    rdfs:comment 'Unique identifier for this contract-target contribution relationship. Primary key.' ;
    rdfs:domain ind:ContractSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributionEndDate rdf:type rdf:Property ;
    rdfs:label 'Contribution End Date' ;
    rdfs:comment 'Date when this contract\'s contribution toward the sustainability target ends, typically aligned with contract expiry but may differ if sustainability commitments have different terms.' ;
    rdfs:domain ind:ContractSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionStartDate rdf:type rdf:Property ;
    rdfs:label 'Contribution Start Date' ;
    rdfs:comment 'Date when this contract began contributing toward the sustainability target, typically aligned with contract effective date but may differ if sustainability terms were added later.' ;
    rdfs:domain ind:ContractSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReportedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reported Date' ;
    rdfs:comment 'Date when the most recent sustainability performance data was reported for this contract-target contribution.' ;
    rdfs:domain ind:ContractSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReportedValue rdf:type rdf:Property ;
    rdfs:label 'Last Reported Value' ;
    rdfs:comment 'The most recent reported value for this contract\'s contribution in the target\'s unit of measure (e.g., actual tCO2e reduced, actual renewable energy percentage achieved).' ;
    rdfs:domain ind:ContractSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reductionCommitmentTco2e rdf:type rdf:Property ;
    rdfs:label 'Reduction Commitment Tco2e' ;
    rdfs:comment 'The absolute emissions reduction commitment in tonnes of CO2 equivalent that this contract is expected to deliver toward the target (e.g., 50000.0000 tCO2e reduction from switching to electric fleet).' ;
    rdfs:domain ind:ContractSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Sustainability Requirements' ;
    rdfs:comment 'Environmental and sustainability standards or commitments required from the supplier under this contract. [Moved from procurement_contract: This attribute in procurement_contract is a generic text field describing sustainability requirements. When a contract contributes to specific targets, the quantified commitments (reduction_commitment_tco2e, target_contribution_percentage) belong in the association, not as generic text in the contract. The association provides structured, measurable tracking of sustainability contributions.]' ;
    rdfs:domain ind:ContractSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Target Allocation Id' ;
    rdfs:comment 'Unique identifier for this target allocation record. Primary key.' ;
    rdfs:domain ind:TargetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedBaselineValue rdf:type rdf:Property ;
    rdfs:label 'Allocated Baseline Value' ;
    rdfs:comment 'The baseline measurement value allocated to this profit center based on allocation_percentage and the corporate target baseline. Used as the starting point for measuring this profit center\'s progress toward the allocated target.' ;
    rdfs:domain ind:TargetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedTargetValue rdf:type rdf:Property ;
    rdfs:label 'Allocated Target Value' ;
    rdfs:comment 'The target measurement value allocated to this profit center based on allocation_percentage and the corporate target. This is the value the profit center must achieve by the target year.' ;
    rdfs:domain ind:TargetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective Date' ;
    rdfs:comment 'The date from which this target allocation became effective and performance tracking began. Typically aligns with fiscal year start or target program launch date.' ;
    rdfs:domain ind:TargetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationMethodology rdf:type rdf:Property ;
    rdfs:label 'Allocation Methodology' ;
    rdfs:comment 'Description of the methodology used to allocate this target to the profit center (e.g., proportional to revenue, proportional to baseline emissions, proportional to headcount, strategic allocation). Provides transparency for allocation decisions.' ;
    rdfs:domain ind:TargetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPerformanceValue rdf:type rdf:Property ;
    rdfs:label 'Current Performance Value' ;
    rdfs:comment 'The most recent actual performance measurement for this profit center against this allocated target. Updated periodically (monthly, quarterly, annually) based on actual emissions, energy consumption, or other sustainability metrics.' ;
    rdfs:domain ind:TargetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveWeight rdf:type rdf:Property ;
    rdfs:label 'Incentive Weight' ;
    rdfs:comment 'The weight or percentage of this sustainability target allocation in the profit center manager\'s incentive compensation calculation (e.g., 10.00 means 10% of bonus is tied to achieving this target). Enables ESG-linked compensation.' ;
    rdfs:domain ind:TargetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Timestamp when this allocation record was last modified, including updates to performance values or status changes.' ;
    rdfs:domain ind:TargetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:performancePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period End Date' ;
    rdfs:comment 'The end date of the period for which current_performance_value was measured (e.g., end of quarter, end of year). Enables time-series tracking of progress.' ;
    rdfs:domain ind:TargetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLineId rdf:type rdf:Property ;
    rdfs:label 'Service Line Id' ;
    rdfs:comment 'Identifier of the specific service line or product associated with the obligation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceLine .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'Cumulative amount invoiced against the performance obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency or trigger for invoicing the obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current status of cash collection for the obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Free-form text describing the goods or services promised.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Method by which the discount is applied.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPartialObligation rdf:type rdf:Property ;
    rdfs:label 'Is Partial Obligation' ;
    rdfs:comment 'True if the obligation represents a portion of a larger contract obligation.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metricActualValue rdf:type rdf:Property ;
    rdfs:label 'Metric Actual Value' ;
    rdfs:comment 'Actual measured value of the performance metric to date.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricTargetValue rdf:type rdf:Property ;
    rdfs:label 'Metric Target Value' ;
    rdfs:comment 'Target value for the performance metric that triggers revenue recognition.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricUnit rdf:type rdf:Property ;
    rdfs:label 'Metric Unit' ;
    rdfs:comment 'Unit of measure for the performance metric.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'External identifier assigned to the performance obligation by the billing system.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle state of the performance obligation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unbilledAmount rdf:type rdf:Property ;
    rdfs:label 'Unbilled Amount' ;
    rdfs:comment 'Remaining monetary value of the obligation that has not yet been invoiced.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Business Event Timestamp' ;
    rdfs:comment 'Exact moment the debit note event occurred in the business process.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:debitNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Debit Note Number' ;
    rdfs:comment 'External reference number assigned to the debit note for customer and accounting communication.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRefunded rdf:type rdf:Property ;
    rdfs:label 'Is Refunded' ;
    rdfs:comment 'Indicates whether the debit note amount has been refunded to the customer.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the debit note record was first created in the system.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent modification to the debit note record.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the debit note is exempt from tax.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Reason' ;
    rdfs:comment 'Explanation for tax exemption, if applicable.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Flag' ;
    rdfs:comment 'Indicates whether the claimant is flagged for AML review.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimCount rdf:type rdf:Property ;
    rdfs:label 'Claim Count' ;
    rdfs:comment 'Total count of claims filed by the claimant.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimantCategory rdf:type rdf:Property ;
    rdfs:label 'Claimant Category' ;
    rdfs:comment 'Business classification of the claimant for claim processing.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantType rdf:type rdf:Property ;
    rdfs:label 'Claimant Type' ;
    rdfs:comment 'Category of claimant indicating legal form or role.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Legal full name of the claimant (person or organization).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Claimant\'s preferred channel for communications.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsListed rdf:type rdf:Property ;
    rdfs:label 'Sanctions Listed' ;
    rdfs:comment 'True if the claimant appears on any international sanctions list.' ;
    rdfs:domain ind:Claimant ;
