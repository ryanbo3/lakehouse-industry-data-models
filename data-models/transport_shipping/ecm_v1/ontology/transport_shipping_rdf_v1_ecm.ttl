    rdfs:comment 'Date of the most recent amendment to the lease contract.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseAmount rdf:type rdf:Property ;
