    rdfs:range xsd:boolean .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province component of the claimant\'s address.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claims Amount' ;
    rdfs:comment 'Cumulative monetary value of all claims submitted by the claimant.' ;
    rdfs:domain ind:Claimant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearanceDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Date' ;
    rdfs:comment 'Date on which customs clearance was completed.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Current customs clearance status of the transaction.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpAtCompliance rdf:type rdf:Property ;
    rdfs:label 'Ctp At Compliance' ;
    rdfs:comment 'Indicates participation in the C-TPAT secure supply-chain program.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deniedPartyFlag rdf:type rdf:Property ;
    rdfs:label 'Denied Party Flag' ;
    rdfs:comment 'True if the counter-party appears on a denied-party list.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyRate rdf:type rdf:Property ;
    rdfs:label 'Duty Rate' ;
    rdfs:comment 'Duty rate expressed as a percentage of the goods value.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryPort rdf:type rdf:Property ;
    rdfs:label 'Entry Port' ;
    rdfs:comment 'Port or airport code where goods entered the customs jurisdiction.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitPort rdf:type rdf:Property ;
    rdfs:label 'Exit Port' ;
    rdfs:comment 'Port or airport code where goods exited the customs jurisdiction.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'True if the shipment contains hazardous materials requiring special handling.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfItems rdf:type rdf:Property ;
    rdfs:label 'Number Of Items' ;
    rdfs:comment 'Count of individual items or packages in the shipment.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeType rdf:type rdf:Property ;
    rdfs:label 'Trade Type' ;
    rdfs:comment 'Classification of the transaction as import, export, re-export, or transit.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Unique identifier of the leased asset.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportAsset .

ind:lesseeId rdf:type rdf:Property ;
    rdfs:label 'Lessee Id' ;
    rdfs:comment 'Unique identifier of the party leasing the asset.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lessee .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Accounting framework governing lease treatment.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizedAmount rdf:type rdf:Property ;
    rdfs:label 'Capitalized Amount' ;
    rdfs:comment 'Portion of the lease amount that is capitalized on the balance sheet.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'Link to the electronic copy of the signed lease contract.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name of the lease contract for easy identification.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyTerminationFee rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee' ;
    rdfs:comment 'Fee payable if the lease is terminated before the scheduled end date.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionOption rdf:type rdf:Property ;
    rdfs:label 'Extension Option' ;
    rdfs:comment 'Availability of an extension period beyond the original term.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRenewable rdf:type rdf:Property ;
    rdfs:label 'Is Renewable' ;
    rdfs:comment 'Indicates whether the lease contract can be renewed after its term.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubleaseAllowed rdf:type rdf:Property ;
