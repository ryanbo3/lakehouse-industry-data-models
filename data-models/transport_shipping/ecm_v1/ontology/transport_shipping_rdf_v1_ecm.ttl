    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSpent rdf:type rdf:Property ;
    rdfs:label 'Actual Spent' ;
    rdfs:comment 'Cumulative actual expenditures recorded against the project.' ;
