ind:baselineEmissionsTonnesCo2e rdf:type rdf:Property ;
    rdfs:label 'Baseline Emissions Tonnes Co2e' ;
    rdfs:comment 'The reference baseline emissions level against which reductions or growth are measured for this compliance period, expressed in metric tonnes of CO2 equivalent.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Timestamp when this compliance period record became effective in the system, supporting temporal queries and slowly changing dimension management.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emissionsCapTonnesCo2e rdf:type rdf:Property ;
    rdfs:label 'Emissions Cap Tonnes Co2e' ;
    rdfs:comment 'The total emissions cap or allowance allocation ceiling for the organization under this compliance period, expressed in metric tonnes of CO2 equivalent.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeAllocationTonnesCo2e rdf:type rdf:Property ;
    rdfs:label 'Free Allocation Tonnes Co2e' ;
    rdfs:comment 'The quantity of emission allowances allocated free of charge to the organization for this compliance period, expressed in metric tonnes of CO2 equivalent.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgScopeCoverage rdf:type rdf:Property ;
    rdfs:label 'Ghg Scope Coverage' ;
    rdfs:comment 'Indicates which GHG Protocol emission scopes are covered by this compliance period\'s obligations (Scope 1 direct, Scope 2 indirect energy, Scope 3 value chain).' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:growthFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Growth Factor Percent' ;
    rdfs:comment 'The sectoral growth factor applied to baseline emissions to determine the compliance threshold, accounting for industry growth (used in CORSIA\'s sectoral approach).' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isVoluntary rdf:type rdf:Property ;
    rdfs:label 'Is Voluntary' ;
    rdfs:comment 'Indicates whether participation in this compliance period is voluntary (true) or mandatory (false) for the organization based on regulatory thresholds.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxOffsetPercentage rdf:type rdf:Property ;
    rdfs:label 'Max Offset Percentage' ;
    rdfs:comment 'The maximum percentage of total compliance obligations that may be met through carbon offset credits rather than direct emission reductions or allowance purchases.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringMethodology rdf:type rdf:Property ;
    rdfs:label 'Monitoring Methodology' ;
    rdfs:comment 'The prescribed or adopted methodology for monitoring and calculating emissions during this compliance period (e.g., Tier 1/2/3 calculation, continuous emissions monitoring, fuel-based method).' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Offset Eligibility Flag' ;
    rdfs:comment 'Indicates whether carbon offset credits (e.g., CERs, ERUs, eligible units) may be used to meet compliance obligations during this period.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyRatePerTonne rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Per Tonne' ;
    rdfs:comment 'The monetary penalty rate per tonne of CO2e for non-compliance (failure to surrender sufficient allowances) during this compliance period, in the scheme\'s base currency.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phaseNumber rdf:type rdf:Property ;
    rdfs:label 'Phase Number' ;
    rdfs:comment 'The sequential phase number within the broader regulatory scheme (e.g., Phase 4 of EU ETS, Pilot Phase of CORSIA) to which this compliance period belongs.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reductionTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Reduction Target Percent' ;
    rdfs:comment 'The mandated or committed percentage reduction in greenhouse gas emissions relative to the baseline that must be achieved during this compliance period.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryScheme rdf:type rdf:Property ;
    rdfs:label 'Regulatory Scheme' ;
    rdfs:comment 'The emissions trading or carbon compliance regulatory scheme under which this period is defined (e.g., EU ETS, CORSIA, IMO Data Collection System, UK ETS, California Cap-and-Trade).' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Date' ;
    rdfs:comment 'The regulatory deadline by which emissions reports and monitoring data must be submitted to the competent authority for this compliance period.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Verification Deadline Date' ;
    rdfs:comment 'The regulatory deadline by which third-party verification of emissions reports must be completed and submitted for this compliance period.' ;
    rdfs:domain ind:CompliancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Team Lead Employee Id' ;
    rdfs:comment 'Identifier of the employee designated as the team lead responsible for supervising the counter team\'s operations.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accuracyThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Threshold Percent' ;
    rdfs:comment 'Minimum acceptable inventory count accuracy percentage for the team. Counts below this threshold trigger recount procedures.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countFrequency rdf:type rdf:Property ;
    rdfs:label 'Count Frequency' ;
    rdfs:comment 'Standard frequency at which this counter team is scheduled to perform inventory counts.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCertified rdf:type rdf:Property ;
    rdfs:label 'Is Certified' ;
    rdfs:comment 'Indicates whether the counter team has completed required training and certification for conducting official inventory counts.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatQualified rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Qualified' ;
    rdfs:comment 'Indicates whether the counter team is qualified to count hazardous materials inventory requiring special handling and safety protocols.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHighValueAuthorized rdf:type rdf:Property ;
    rdfs:label 'Is High Value Authorized' ;
    rdfs:comment 'Indicates whether the counter team is authorized to count high-value inventory items that require additional security oversight.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Count Date' ;
    rdfs:comment 'Date of the most recent inventory count completed by this team, used for scheduling and compliance tracking.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Capacity' ;
    rdfs:comment 'Maximum number of members that can be assigned to this counter team based on operational constraints and supervision ratios.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Count Date' ;
    rdfs:comment 'Date of the next planned inventory count assignment for this team.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingSchedule rdf:type rdf:Property ;
    rdfs:label 'Operating Schedule' ;
    rdfs:comment 'Description of the team\'s regular operating schedule including days of week and hours (e.g., \'Mon-Fri 06:00-14:00\').' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLocationsPerShift rdf:type rdf:Property ;
    rdfs:label 'Target Locations Per Shift' ;
    rdfs:comment 'Expected number of storage locations the counter team should count per shift, used as a productivity benchmark.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Percent' ;
    rdfs:comment 'Maximum allowable percentage variance between system inventory and physical count before an exception is raised.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Wms Reference Code' ;
    rdfs:comment 'External reference identifier for this counter team as stored in the Manhattan WMS system for integration and reconciliation purposes.' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneAssignment rdf:type rdf:Property ;
    rdfs:label 'Zone Assignment' ;
    rdfs:comment 'Warehouse zone or area designation where this counter team is primarily assigned to conduct counting activities (e.g., bulk storage, pick modules, mezzanine).' ;
    rdfs:domain ind:CounterTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:color rdf:type rdf:Property ;
    rdfs:label 'Color' ;
    rdfs:comment 'Physical color of the pallet, often used to visually identify pool provider ownership or product segregation requirements.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date the pallet was first put into active service within the warehouse operation.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date the pallet was permanently removed from active service due to damage, age, or end-of-life.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryMethod rdf:type rdf:Property ;
    rdfs:label 'Entry Method' ;
    rdfs:comment 'The material handling method used to move or place the pallet (forklift, conveyor, automated guided vehicle, manual, crane).' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'Height of the pallet deck structure (without load) in millimeters, relevant for stacking calculations and rack compatibility.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFoodGrade rdf:type rdf:Property ;
    rdfs:label 'Is Food Grade' ;
    rdfs:comment 'Indicates whether the pallet meets food-grade hygiene and safety standards for use in food and pharmaceutical supply chains.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHeatTreated rdf:type rdf:Property ;
    rdfs:label 'Is Heat Treated' ;
    rdfs:comment 'Indicates whether the wooden pallet has been heat-treated per ISPM-15 phytosanitary requirements for international shipment.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRackable rdf:type rdf:Property ;
    rdfs:label 'Is Rackable' ;
    rdfs:comment 'Indicates whether the pallet is structurally suitable for placement on warehouse pallet racking systems.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturnable rdf:type rdf:Property ;
    rdfs:label 'Is Returnable' ;
    rdfs:comment 'Indicates whether the pallet is designed for return and reuse in a closed-loop supply chain, as opposed to single-use disposal.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Enabled' ;
    rdfs:comment 'Indicates whether the pallet is equipped with an RFID tag for automated tracking within the warehouse.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStackable rdf:type rdf:Property ;
    rdfs:label 'Is Stackable' ;
    rdfs:comment 'Indicates whether this pallet type is approved for vertical stacking in warehouse racking or during transport.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRepairDate rdf:type rdf:Property ;
    rdfs:label 'Last Repair Date' ;
    rdfs:comment 'Date of the most recent repair or refurbishment performed on the pallet.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthMm rdf:type rdf:Property ;
    rdfs:label 'Length Mm' ;
    rdfs:comment 'External length dimension of the pallet in millimeters, used for slotting optimization and load planning.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLoadCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Max Load Capacity Kg' ;
    rdfs:comment 'Maximum safe static load capacity of the pallet in kilograms as rated by the manufacturer or standard.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStackLayers rdf:type rdf:Property ;
    rdfs:label 'Max Stack Layers' ;
    rdfs:comment 'Maximum number of pallet layers that can be safely stacked vertically in storage or transport.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTripLimit rdf:type rdf:Property ;
    rdfs:label 'Max Trip Limit' ;
    rdfs:comment 'Maximum number of trips or usage cycles allowed before the pallet must be retired or refurbished.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poolProvider rdf:type rdf:Property ;
    rdfs:label 'Pool Provider' ;
    rdfs:comment 'Name of the pallet pooling service provider (e.g., CHEP, PECO, LPR, IPP) if the pallet is leased or pooled.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairCount rdf:type rdf:Property ;
    rdfs:label 'Repair Count' ;
    rdfs:comment 'Total number of repairs performed on the pallet over its lifetime, used to assess remaining useful life.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment 'GS1 Serial Shipping Container Code, an 18-digit globally unique identifier assigned to the pallet for supply chain tracking and EDI messaging.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'External width dimension of the pallet in millimeters, used for slotting optimization and load planning.' ;
    rdfs:domain ind:Pallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'Broad operational category grouping equipment by its primary warehouse function.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionRating rdf:type rdf:Property ;
    rdfs:label 'Condition Rating' ;
    rdfs:comment 'Assessed physical condition of the equipment based on the most recent inspection.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionsLxwxhCm rdf:type rdf:Property ;
    rdfs:label 'Dimensions Lxwxh Cm' ;
    rdfs:comment 'Physical dimensions of the equipment expressed as length x width x height in centimeters.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedRetirementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Retirement Date' ;
    rdfs:comment 'Planned date for decommissioning and retiring the equipment from active service based on lifecycle planning.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Certification Number' ;
    rdfs:comment 'Certificate or reference number issued upon passing the most recent regulatory safety inspection.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIotEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Iot Enabled' ;
    rdfs:comment 'Indicates whether the equipment is fitted with IoT sensors for real-time telemetry and monitoring.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyCertified rdf:type rdf:Property ;
    rdfs:label 'Is Safety Certified' ;
    rdfs:comment 'Indicates whether the equipment currently holds a valid safety certification.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseContractNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Number' ;
    rdfs:comment 'Reference number of the lease or rental contract if the equipment is not owned outright.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Load Capacity Kg' ;
    rdfs:comment 'Maximum rated load capacity of the equipment measured in kilograms.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufactureYear rdf:type rdf:Property ;
    rdfs:label 'Manufacture Year' ;
    rdfs:comment 'Calendar year in which the equipment was manufactured.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxLiftHeightM rdf:type rdf:Property ;
    rdfs:label 'Max Lift Height M' ;
    rdfs:comment 'Maximum vertical lift height of the equipment in meters, applicable to forklifts and reach trucks.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance service for the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingSpeedMps rdf:type rdf:Property ;
    rdfs:label 'Operating Speed Mps' ;
    rdfs:comment 'Rated maximum operating speed of the equipment in meters per second.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerSource rdf:type rdf:Property ;
    rdfs:label 'Power Source' ;
    rdfs:comment 'Type of energy or power source that drives the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOperatingHours rdf:type rdf:Property ;
    rdfs:label 'Total Operating Hours' ;
    rdfs:comment 'Cumulative number of hours the equipment has been in active operation since commissioning.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Useful Life Months' ;
    rdfs:comment 'Estimated useful economic life of the equipment expressed in months for depreciation and replacement planning.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colorCode rdf:type rdf:Property ;
    rdfs:label 'Color Code' ;
    rdfs:comment 'Color designation of the carton exterior used for visual sorting, zone identification, or brand-specific packaging in e-commerce fulfillment.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionalWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Dimensional Weight Factor' ;
    rdfs:comment 'Carrier-specific divisor used to calculate dimensional (volumetric) weight for freight rating purposes (e.g., 5000 for air, 6000 for ground).' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:edgeCrushTestValue rdf:type rdf:Property ;
    rdfs:label 'Edge Crush Test Value' ;
    rdfs:comment 'Edge Crush Test rating in kN/m indicating the carton\'s resistance to crushing forces, critical for stacking strength assessment.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluteType rdf:type rdf:Property ;
    rdfs:label 'Flute Type' ;
    rdfs:comment 'Flute profile designation for corrugated cartons indicating thickness and cushioning properties (e.g., A-flute for heavy items, E-flute for retail packaging).' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFragileRated rdf:type rdf:Property ;
    rdfs:label 'Is Fragile Rated' ;
    rdfs:comment 'Indicates whether the carton includes additional cushioning or reinforcement suitable for fragile goods handling.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Certified' ;
    rdfs:comment 'Indicates whether the carton is certified for transporting hazardous materials per UN packaging group requirements.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecyclable rdf:type rdf:Property ;
    rdfs:label 'Is Recyclable' ;
    rdfs:comment 'Indicates whether the carton material is recyclable at end of life, supporting sustainability reporting and environmental compliance.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReusable rdf:type rdf:Property ;
    rdfs:label 'Is Reusable' ;
    rdfs:comment 'Indicates whether the carton is designed for multiple use cycles in a returnable packaging program.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialGrade rdf:type rdf:Property ;
    rdfs:label 'Material Grade' ;
    rdfs:comment 'Grade or composition of the carton material indicating structural strength and protection level for contents.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxReuseCycles rdf:type rdf:Property ;
    rdfs:label 'Max Reuse Cycles' ;
    rdfs:comment 'Maximum number of times a reusable carton can be cycled before mandatory retirement, based on manufacturer specifications.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxStackableLayers rdf:type rdf:Property ;
    rdfs:label 'Max Stackable Layers' ;
    rdfs:comment 'Maximum number of layers this carton type can be stacked when loaded, used for pallet building and storage optimization.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Quantity' ;
    rdfs:comment 'Reorder point threshold — when on-hand quantity of this carton type falls below this level, a replenishment order is triggered.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Bin or slot location code within the warehouse where empty cartons of this type are stored for picking and packing operations.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unPackagingGroup rdf:type rdf:Property ;
    rdfs:label 'Un Packaging Group' ;
    rdfs:comment 'UN Packaging Group classification (I=Great Danger, II=Medium Danger, III=Minor Danger) for hazmat-certified cartons.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCm3 rdf:type rdf:Property ;
    rdfs:label 'Volume Cm3' ;
    rdfs:comment 'Total internal cubic volume of the carton in cubic centimeters, representing usable packing space for order fulfillment.' ;
    rdfs:domain ind:Carton ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aisleLocation rdf:type rdf:Property ;
    rdfs:label 'Aisle Location' ;
    rdfs:comment 'Physical aisle or bay location reference within the warehouse floor plan for the packing station.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Internal fixed asset tag number assigned for capital asset tracking and depreciation purposes.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedShiftPattern rdf:type rdf:Property ;
    rdfs:label 'Assigned Shift Pattern' ;
    rdfs:comment 'The shift pattern during which this packing station is typically operational and staffed.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conveyorConnected rdf:type rdf:Property ;
    rdfs:label 'Conveyor Connected' ;
    rdfs:comment 'Indicates whether the packing station is connected to the outbound conveyor system for automated parcel dispatch.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentManufacturer rdf:type rdf:Property ;
    rdfs:label 'Equipment Manufacturer' ;
    rdfs:comment 'Name of the manufacturer or vendor who supplied the packing station equipment.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentModel rdf:type rdf:Property ;
    rdfs:label 'Equipment Model' ;
    rdfs:comment 'Model number or designation of the packing station equipment as specified by the manufacturer.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ergonomicHeightAdjustable rdf:type rdf:Property ;
    rdfs:label 'Ergonomic Height Adjustable' ;
    rdfs:comment 'Indicates whether the packing station has height-adjustable work surfaces to support ergonomic working conditions.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Floor or mezzanine level where the packing station is located within a multi-level distribution center.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasBarcodeScanner rdf:type rdf:Property ;
    rdfs:label 'Has Barcode Scanner' ;
    rdfs:comment 'Indicates whether the packing station is equipped with a barcode scanner for item verification and tracking.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasDimensioner rdf:type rdf:Property ;
    rdfs:label 'Has Dimensioner' ;
    rdfs:comment 'Indicates whether the packing station is equipped with automated dimensioning equipment to capture parcel dimensions.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasLabelPrinter rdf:type rdf:Property ;
    rdfs:label 'Has Label Printer' ;
    rdfs:comment 'Indicates whether the packing station has an integrated label printer for shipping labels and documentation.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasScale rdf:type rdf:Property ;
    rdfs:label 'Has Scale' ;
    rdfs:comment 'Indicates whether the packing station is equipped with an integrated weighing scale for parcel weight capture.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the packing station was physically installed and made available in the warehouse.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isColdChainCapable rdf:type rdf:Property ;
    rdfs:label 'Is Cold Chain Capable' ;
    rdfs:comment 'Indicates whether the packing station supports cold chain packing with temperature-controlled materials and insulated packaging.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEcommerceDedicated rdf:type rdf:Property ;
    rdfs:label 'Is Ecommerce Dedicated' ;
    rdfs:comment 'Indicates whether the packing station is dedicated exclusively to e-commerce fulfillment orders.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxOperators rdf:type rdf:Property ;
    rdfs:label 'Max Operators' ;
    rdfs:comment 'Maximum number of operators that can work simultaneously at this packing station.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxParcelHeightCm rdf:type rdf:Property ;
    rdfs:label 'Max Parcel Height Cm' ;
    rdfs:comment 'Maximum height dimension in centimeters of a parcel that can be processed at this station.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxParcelLengthCm rdf:type rdf:Property ;
    rdfs:label 'Max Parcel Length Cm' ;
    rdfs:comment 'Maximum length dimension in centimeters of a parcel that can be processed at this station.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxParcelWidthCm rdf:type rdf:Property ;
    rdfs:label 'Max Parcel Width Cm' ;
    rdfs:comment 'Maximum width dimension in centimeters of a parcel that can be processed at this station.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxThroughputPerHour rdf:type rdf:Property ;
    rdfs:label 'Max Throughput Per Hour' ;
    rdfs:comment 'Maximum rated capacity of parcels or packages the station can process per hour under optimal conditions.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Scheduled date for the next planned preventive maintenance of the packing station.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packingMaterialType rdf:type rdf:Property ;
    rdfs:label 'Packing Material Type' ;
    rdfs:comment 'Primary type of packing material used at this station for cushioning and protection of goods.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerSupplyVoltage rdf:type rdf:Property ;
    rdfs:label 'Power Supply Voltage' ;
    rdfs:comment 'Electrical voltage specification required by the packing station equipment.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationCode rdf:type rdf:Property ;
    rdfs:label 'Station Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code used to identify the packing station across warehouse operations and Manhattan WMS.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationName rdf:type rdf:Property ;
    rdfs:label 'Station Name' ;
    rdfs:comment 'Human-readable descriptive name of the packing station used for operational displays and reporting.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationType rdf:type rdf:Property ;
    rdfs:label 'Station Type' ;
    rdfs:comment 'Classification of the packing station by operational mode and capability, determining the types of orders it can process.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedCarrierServices rdf:type rdf:Property ;
    rdfs:label 'Supported Carrier Services' ;
    rdfs:comment 'Comma-separated list of carrier service codes that this packing station is configured to process (e.g., express, standard, freight).' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Wms Device Code' ;
    rdfs:comment 'Unique device identifier registered in Manhattan WMS for this packing station terminal.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workstationSurfaceAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Workstation Surface Area Sqm' ;
    rdfs:comment 'Total usable work surface area in square meters available at the packing station for packing operations.' ;
    rdfs:domain ind:PackingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentHandlingUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Handling Unit Id' ;
    rdfs:comment 'Identifier of the parent handling unit when this unit is nested within a larger unit (e.g., cartons on a pallet), enabling hierarchical tracking of nested packaging structures.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandlingUnit .

ind:handlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Handling Instructions' ;
    rdfs:comment 'Special handling instructions for this unit such as fragile, this-side-up, keep dry, or forklift-only requirements, communicated to warehouse operatives during movement tasks.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMixedSku rdf:type rdf:Property ;
    rdfs:label 'Is Mixed Sku' ;
    rdfs:comment 'Indicates whether this handling unit contains multiple different SKUs (mixed) versus a single SKU (homogeneous), affecting picking strategy and inventory allocation logic.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Total number of individual items or SKUs contained within this handling unit, used for inventory reconciliation and pick verification.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent physical movement of this handling unit within the warehouse (putaway, replenishment, pick, or relocation), used for dwell time analysis.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Load Unit Number' ;
    rdfs:comment 'Reference number of the outbound load or shipment this handling unit is assigned to for dispatch, linking warehouse operations to transportation execution.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for temperature-sensitive contents, used for cold chain compliance monitoring and alert thresholds.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for temperature-sensitive contents, used for cold chain compliance monitoring.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the physical packaging type of the handling unit, determining storage requirements, handling equipment needs, and slotting optimization rules.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hrAdministratorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Hr Administrator Employee Id' ;
    rdfs:comment 'Identifier of the HR administrator or leave specialist assigned to manage this FMLA case.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Certification Due Date' ;
    rdfs:comment 'Deadline by which the employee must submit medical certification. Typically 15 calendar days from employer request.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Certification Received Date' ;
    rdfs:comment 'Date the employer received the completed medical certification from the employee or healthcare provider.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'General description of the serious health condition or qualifying reason supporting the FMLA leave. Contains protected health information.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Designation Notice Date' ;
    rdfs:comment 'Date the employer issued the designation notice informing the employee whether the leave qualifies as FMLA-protected.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Determination Date' ;
    rdfs:comment 'Date on which the employer made the formal determination of the employee\'s eligibility for FMLA leave. Must be within 5 business days of request per regulation.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entitlementHoursTotal rdf:type rdf:Property ;
    rdfs:label 'Entitlement Hours Total' ;
    rdfs:comment 'Total number of FMLA leave hours the employee is entitled to within the 12-month leave year (typically 480 hours for standard full-time, up to 1,040 for military caregiver).' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:familyMemberRelationship rdf:type rdf:Property ;
    rdfs:label 'Family Member Relationship' ;
    rdfs:comment 'Relationship of the person with the serious health condition to the employee, determining FMLA qualifying reason eligibility.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitnessForDutyReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Fitness For Duty Received Date' ;
    rdfs:comment 'Date the fitness-for-duty certification was received from the employee\'s healthcare provider clearing them for return to work.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitnessForDutyRequired rdf:type rdf:Property ;
    rdfs:label 'Fitness For Duty Required' ;
    rdfs:comment 'Indicates whether the employee must provide a fitness-for-duty certification before returning to work, particularly relevant for DOT-regulated driver positions.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthcareProviderName rdf:type rdf:Property ;
    rdfs:label 'Healthcare Provider Name' ;
    rdfs:comment 'Name of the healthcare provider who issued the medical certification supporting the FMLA leave request.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursRemaining rdf:type rdf:Property ;
    rdfs:label 'Hours Remaining' ;
    rdfs:comment 'Number of FMLA leave hours remaining in the employee\'s entitlement balance for this case within the current leave year.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursUsed rdf:type rdf:Property ;
    rdfs:label 'Hours Used' ;
    rdfs:comment 'Cumulative number of FMLA leave hours the employee has consumed against their entitlement for this case.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intermittentDurationPerEpisode rdf:type rdf:Property ;
    rdfs:label 'Intermittent Duration Per Episode' ;
    rdfs:comment 'Expected duration of each intermittent leave episode as certified by the healthcare provider (e.g., 1-3 days per episode, 2-4 hours per episode).' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermittentFrequency rdf:type rdf:Property ;
    rdfs:label 'Intermittent Frequency' ;
    rdfs:comment 'Expected frequency of intermittent leave episodes as certified by the healthcare provider (e.g., 2-3 times per month, weekly treatments).' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConcurrentWithStd rdf:type rdf:Property ;
    rdfs:label 'Is Concurrent With Std' ;
    rdfs:comment 'Indicates whether this FMLA leave runs concurrently with a short-term disability benefit claim.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConcurrentWithWorkersComp rdf:type rdf:Property ;
    rdfs:label 'Is Concurrent With Workers Comp' ;
    rdfs:comment 'Indicates whether this FMLA leave runs concurrently with a workers compensation absence.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEligible rdf:type rdf:Property ;
    rdfs:label 'Is Eligible' ;
    rdfs:comment 'Indicates whether the employee met FMLA eligibility requirements (12 months employment, 1,250 hours worked, 50+ employees within 75 miles).' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKeyEmployee rdf:type rdf:Property ;
    rdfs:label 'Is Key Employee' ;
    rdfs:comment 'Indicates whether the employee is classified as a key employee (salaried, among highest-paid 10%), which may affect job restoration rights under FMLA.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaidLeaveSubstituted rdf:type rdf:Property ;
    rdfs:label 'Is Paid Leave Substituted' ;
    rdfs:comment 'Indicates whether the employee or employer has elected to substitute accrued paid leave (vacation, sick, PTO) for unpaid FMLA leave.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWorkRelated rdf:type rdf:Property ;
    rdfs:label 'Is Work Related' ;
    rdfs:comment 'Indicates whether the serious health condition is related to a workplace injury or occupational illness, which may trigger concurrent workers compensation coverage.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobProtectionStatus rdf:type rdf:Property ;
    rdfs:label 'Job Protection Status' ;
    rdfs:comment 'Status of the employee\'s job restoration rights under FMLA, indicating whether the employee\'s position is protected, has been restored, or if key employee exception applies.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveEndDate rdf:type rdf:Property ;
    rdfs:label 'Leave End Date' ;
    rdfs:comment 'Last date of the FMLA leave period, either as originally approved or as actually concluded. Nullable for open-ended intermittent cases.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveReason rdf:type rdf:Property ;
    rdfs:label 'Leave Reason' ;
    rdfs:comment 'The qualifying reason for the FMLA leave request as defined by federal regulations. Determines eligibility and entitlement duration.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveStartDate rdf:type rdf:Property ;
    rdfs:label 'Leave Start Date' ;
    rdfs:comment 'First date of the approved FMLA leave period when the employee begins absence from work.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveYearMethod rdf:type rdf:Property ;
    rdfs:label 'Leave Year Method' ;
    rdfs:comment 'Method used by the employer to calculate the 12-month FMLA leave year period for entitlement tracking.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Leave Year Start Date' ;
    rdfs:comment 'Start date of the 12-month leave year period applicable to this FMLA case based on the employer\'s chosen calculation method.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Status' ;
    rdfs:comment 'Status of the medical certification documentation required to support the FMLA leave request for serious health conditions.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateLeaveLawApplies rdf:type rdf:Property ;
    rdfs:label 'State Leave Law Applies' ;
    rdfs:comment 'Indicates whether a state-level family/medical leave law also applies to this case, potentially providing additional protections beyond federal FMLA.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateLeaveLawCode rdf:type rdf:Property ;
    rdfs:label 'State Leave Law Code' ;
    rdfs:comment 'Code identifying the applicable state family/medical leave law (e.g., CFRA for California, PFML for Massachusetts) that runs concurrently with federal FMLA.' ;
    rdfs:domain ind:FmlaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooldownPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Cooldown Period Hours' ;
    rdfs:comment 'Minimum number of hours a member must wait after being selected before becoming eligible for selection again from this pool.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentMemberCount rdf:type rdf:Property ;
    rdfs:label 'Current Member Count' ;
    rdfs:comment 'Current number of active members enrolled in the random pool, updated as members are added or removed.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Business rules or criteria that determine which workforce members qualify for inclusion in this random pool (e.g., certification level, seniority, job classification).' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDrugTestRequired rdf:type rdf:Property ;
    rdfs:label 'Is Drug Test Required' ;
    rdfs:comment 'Indicates whether members of this pool must maintain current drug testing compliance per DOT or company safety regulations.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertimeEligible rdf:type rdf:Property ;
    rdfs:label 'Is Overtime Eligible' ;
    rdfs:comment 'Indicates whether members selected from this pool are eligible for overtime assignments under labor agreements.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSelectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Selection Timestamp' ;
    rdfs:comment 'Timestamp of the most recent selection event drawn from this pool, used for tracking pool utilization and freshness.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxConsecutiveSelections rdf:type rdf:Property ;
    rdfs:label 'Max Consecutive Selections' ;
    rdfs:comment 'Maximum number of consecutive times a single member can be selected before being excluded from the next draw, ensuring fairness.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumPoolSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Pool Size' ;
    rdfs:comment 'Maximum number of members allowed in the pool to maintain manageable selection ratios and equitable assignment distribution.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPoolSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Pool Size' ;
    rdfs:comment 'Minimum number of eligible members required in the pool before selections can be made, ensuring adequate coverage for operational needs.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'Department or organizational unit responsible for managing and maintaining this random pool within the workforce hierarchy.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolCode rdf:type rdf:Property ;
    rdfs:label 'Pool Code' ;
    rdfs:comment 'Unique business code identifying the random pool for cross-system reference and operational use in workforce scheduling systems.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolName rdf:type rdf:Property ;
    rdfs:label 'Pool Name' ;
    rdfs:comment 'Human-readable name of the random pool used for display in workforce management interfaces and reporting.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolType rdf:type rdf:Property ;
    rdfs:label 'Pool Type' ;
    rdfs:comment 'Classification of the random pool by workforce category, indicating the type of labor resource the pool draws from.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Rotation Interval Days' ;
    rdfs:comment 'Number of days between mandatory pool membership rotations to ensure equitable opportunity distribution among eligible workers.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Selection Frequency' ;
    rdfs:comment 'How often selections are drawn from this pool for workforce assignment or scheduling cycles.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Union Agreement Code' ;
    rdfs:comment 'Code referencing the collective bargaining agreement or union contract that governs random selection rules for this pool.' ;
    rdfs:domain ind:RandomPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiated By Employee Id' ;
    rdfs:comment 'Identifier of the payroll specialist who initiated this payroll run. Supports segregation of duties controls requiring different individuals to initiate and approve.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:payGroupId rdf:type rdf:Property ;
    rdfs:label 'Pay Group Id' ;
    rdfs:comment 'Identifier for the pay group this run processes. Pay groups segment the workforce by pay frequency, legal entity, or operational division (e.g., drivers, warehouse staff, corporate).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayGroup .

ind:reversedRunId rdf:type rdf:Property ;
    rdfs:label 'Reversed Run Id' ;
    rdfs:comment 'Identifier of the original payroll run that this run reverses, if this is a reversal run. Establishes the audit trail between correction and original transactions.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:bankFileReference rdf:type rdf:Property ;
    rdfs:label 'Bank File Reference' ;
    rdfs:comment 'Reference number for the ACH/bank file generated for direct deposit payments. Used for reconciliation with banking institutions and payment confirmation.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkCount rdf:type rdf:Property ;
    rdfs:label 'Check Count' ;
    rdfs:comment 'Total number of individual payment transactions (checks or direct deposits) generated by this payroll run. May differ from employee count due to multiple payment methods per employee.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Total number of employees processed in this payroll run. Includes all active employees in the pay group who received compensation during the pay period.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employerBenefitsAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Benefits Amount' ;
    rdfs:comment 'Total employer-paid benefits contributions for this payroll run including health insurance, retirement plan matching, life insurance, and other employer-funded benefits.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Number of calculation or validation errors encountered during payroll run processing. Zero indicates a clean run; non-zero requires review before approval.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:garnishmentCount rdf:type rdf:Property ;
    rdfs:label 'Garnishment Count' ;
    rdfs:comment 'Number of active wage garnishment orders processed in this payroll run. Includes court-ordered child support, tax levies, and creditor garnishments requiring compliance tracking.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFinalRun rdf:type rdf:Property ;
    rdfs:label 'Is Final Run' ;
    rdfs:comment 'Indicates whether this is the final payroll run for the pay period. False for preliminary/preview runs used for validation before the confirmed disbursement run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether this payroll run includes retroactive pay adjustments for prior periods. True when back-dated compensation changes (e.g., rate increases, reclassifications) are processed.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeHoursTotal rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours Total' ;
    rdfs:comment 'Aggregate overtime hours across all employees in this payroll run. Critical for DOT hours-of-service compliance monitoring for drivers and warehouse labor cost analysis.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing End Timestamp' ;
    rdfs:comment 'Timestamp when the payroll run calculation processing completed. Used with start timestamp to measure processing duration and identify performance issues.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regularHoursTotal rdf:type rdf:Property ;
    rdfs:label 'Regular Hours Total' ;
    rdfs:comment 'Aggregate regular (non-overtime) hours worked across all employees in this payroll run. Used for FTE planning and labor utilization analysis.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payroll run indicating its nature. Regular runs are scheduled cycles; supplemental covers additional payments; off-cycle handles ad-hoc processing; correction adjusts prior errors; bonus processes incentive payments; final handles employee separations.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLaborCost rdf:type rdf:Property ;
    rdfs:label 'Total Labor Cost' ;
    rdfs:comment 'Fully-loaded labor cost for this payroll run including gross pay, employer taxes, and employer benefit contributions. Used for labor cost allocation across freight and fulfillment operations.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningCount rdf:type rdf:Property ;
    rdfs:label 'Warning Count' ;
    rdfs:comment 'Number of non-blocking warnings generated during payroll run processing. Warnings flag potential issues (e.g., unusual overtime, missing time entries) that do not prevent completion.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:courseId rdf:type rdf:Property ;
    rdfs:label 'Course Id' ;
    rdfs:comment 'Reference to the parent course or learning program that this session belongs to within the training curriculum.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:instructorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Instructor Employee Id' ;
    rdfs:comment 'Reference to the employee record of the primary instructor or facilitator delivering the training session.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:prerequisiteSessionId rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Session Id' ;
    rdfs:comment 'Reference to another training session that must be completed before enrollment in this session is permitted.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingSession .

ind:assessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Assessment Required' ;
    rdfs:comment 'Indicates whether participants must complete a formal assessment or examination as part of this training session.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attendanceCount rdf:type rdf:Property ;
    rdfs:label 'Attendance Count' ;
    rdfs:comment 'Actual number of participants who attended the training session, recorded upon session completion.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competencyArea rdf:type rdf:Property ;
    rdfs:label 'Competency Area' ;
    rdfs:comment 'The role-based competency domain that this training session develops, aligned with the organization\'s competency framework.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Required' ;
    rdfs:comment 'Indicates whether this training session is mandated by regulatory or company compliance requirements (e.g., DOT hours-of-service, OSHA safety).' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerSession rdf:type rdf:Property ;
    rdfs:label 'Cost Per Session' ;
    rdfs:comment 'Total cost allocated to conducting this training session including instructor fees, materials, and facility charges, used for labor cost allocation.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditHours rdf:type rdf:Property ;
    rdfs:label 'Credit Hours' ;
    rdfs:comment 'Number of continuing education or professional development credit hours awarded upon successful completion of this training session.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPlatform rdf:type rdf:Property ;
    rdfs:label 'Delivery Platform' ;
    rdfs:comment 'Name or identifier of the platform used to deliver the training (e.g., Workday Learning, Teams, Zoom, in-person facility name) for virtual and blended sessions.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrolledCount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Count' ;
    rdfs:comment 'Current number of participants enrolled in the training session at the time of record update.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'ISO 639-1 language code indicating the primary language in which the training session is delivered.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsProvided rdf:type rdf:Property ;
    rdfs:label 'Materials Provided' ;
    rdfs:comment 'Indicates whether training materials (manuals, handouts, digital resources) are provided to participants as part of the session.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval Months' ;
    rdfs:comment 'Number of months after which this training must be repeated for ongoing compliance or certification renewal purposes.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionDescription rdf:type rdf:Property ;
    rdfs:label 'Session Description' ;
    rdfs:comment 'Detailed narrative description of the training session content, learning objectives, and expected outcomes.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Classification of the training delivery method indicating how the session is conducted.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetJobFamily rdf:type rdf:Property ;
    rdfs:label 'Target Job Family' ;
    rdfs:comment 'The job family or role group that this training session is designed for (e.g., drivers, warehouse associates, freight handlers, management).' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualMeetingUrl rdf:type rdf:Property ;
    rdfs:label 'Virtual Meeting Url' ;
    rdfs:comment 'Web URL for joining the training session when delivered virtually, applicable for remote and blended delivery modes.' ;
    rdfs:domain ind:TrainingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Default invoicing frequency for customers using this service line, determining how often charges are consolidated and billed.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageScope rdf:type rdf:Property ;
    rdfs:label 'Coverage Scope' ;
    rdfs:comment 'Geographic scope of the service line indicating whether it covers domestic shipments, international cross-border movements, or both.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCodSupported rdf:type rdf:Property ;
    rdfs:label 'Is Cod Supported' ;
    rdfs:comment 'Indicates whether this service line supports cash on delivery payment collection at the point of delivery.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCustomsBrokerageIncluded rdf:type rdf:Property ;
    rdfs:label 'Is Customs Brokerage Included' ;
    rdfs:comment 'Indicates whether customs brokerage and clearance services are bundled as part of this service line offering.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEcommerceEligible rdf:type rdf:Property ;
    rdfs:label 'Is Ecommerce Eligible' ;
    rdfs:comment 'Indicates whether this service line is available for e-commerce fulfillment channels and marketplace integrations.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatEligible rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Eligible' ;
    rdfs:comment 'Indicates whether this service line supports the transport of hazardous materials (dangerous goods) under IATA DGR or IMDG Code regulations.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInsuranceAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Insurance Available' ;
    rdfs:comment 'Indicates whether shipment insurance or cargo liability coverage can be offered as an add-on for this service line.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date when this service line was first made commercially available to customers.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'Name or code of the business unit or division that owns and is accountable for the commercial performance of this service line.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentServiceLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Service Line Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent service line in a hierarchical service line structure, enabling sub-service categorization.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productManager rdf:type rdf:Property ;
    rdfs:label 'Product Manager' ;
    rdfs:comment 'Name or identifier of the product manager responsible for the strategic direction, pricing, and market positioning of this service line.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric value controlling the display sequence of this service line in user interfaces, reports, and dropdown selections.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sunsetDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Date' ;
    rdfs:comment 'Planned or actual date when this service line will be or was discontinued and no longer offered to customers.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'Default tax treatment classification for this service line, determining applicable VAT/GST rules for invoice generation.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumetricDivisor rdf:type rdf:Property ;
    rdfs:label 'Volumetric Divisor' ;
    rdfs:comment 'Divisor factor used to calculate volumetric (dimensional) weight from package dimensions for this service line (e.g., 5000 for air, 6000 for road).' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightBreakUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Break Unit' ;
    rdfs:comment 'Unit of measure used for weight-based pricing tiers (weight breaks) applicable to this service line.' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerName rdf:type rdf:Property ;
    rdfs:label 'Account Manager Name' ;
    rdfs:comment 'Name of the Transport Shipping account manager responsible for managing the commercial relationship with this lessee.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressCity rdf:type rdf:Property ;
    rdfs:label 'Billing Address City' ;
    rdfs:comment 'City component of the lessee\'s billing address.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressCountry rdf:type rdf:Property ;
    rdfs:label 'Billing Address Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the lessee\'s billing address.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line 1' ;
    rdfs:comment 'First line of the lessee\'s billing address used for invoice delivery and official correspondence.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the lessee\'s billing address.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the lessee entity is legally incorporated or registered.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit is denominated.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'Security deposit amount held from the lessee as collateral against potential damage, loss, or non-payment on leased assets.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'The primary industry sector in which the lessee operates, used for risk assessment, credit evaluation, and portfolio segmentation. [ENUM-REF-CANDIDATE: manufacturing|retail|agriculture|automotive|pharmaceuticals|energy|technology|food_beverage|chemicals|construction — promote to reference product]' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVatRegistered rdf:type rdf:Property ;
    rdfs:label 'Is Vat Registered' ;
    rdfs:comment 'Indicates whether the lessee is registered for VAT/GST, affecting tax treatment on lease invoices.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseSegment rdf:type rdf:Property ;
    rdfs:label 'Lease Segment' ;
    rdfs:comment 'Primary asset category that the lessee typically leases, used for portfolio segmentation and asset planning.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lesseeType rdf:type rdf:Property ;
    rdfs:label 'Lessee Type' ;
    rdfs:comment 'Classification of the lessee by organizational type, distinguishing between enterprise accounts, small-medium enterprises, individual shippers, government entities, and third/fourth-party logistics providers.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Reference to the parent lessee account in a hierarchical account structure, enabling corporate group consolidation and multi-entity lease management.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredLeaseCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Lease Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the lessee\'s preferred currency for lease agreements and invoicing.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaEntitlementCode rdf:type rdf:Property ;
    rdfs:label 'Sla Entitlement Code' ;
    rdfs:comment 'Code identifying the service level agreement tier the lessee is entitled to, governing response times, asset availability guarantees, and maintenance commitments.' ;
    rdfs:domain ind:Lessee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedShareCapital rdf:type rdf:Property ;
    rdfs:label 'Authorized Share Capital' ;
    rdfs:comment 'Maximum amount of share capital that the legal entity is authorized to issue as per its articles of incorporation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'Identifier for the chart of accounts assigned to this legal entity, defining the GL account structure for financial postings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfTaxResidence rdf:type rdf:Property ;
    rdfs:label 'Country Of Tax Residence' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the jurisdiction where the entity is tax-resident for corporate income tax purposes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date on which the legal entity was formally dissolved or struck off the corporate register. Null if entity is still active.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date on which the legal entity was officially incorporated or registered with the relevant government authority.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryCode rdf:type rdf:Property ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'Standard industry classification code (NAICS or ISIC) representing the primary business activity of the legal entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntercompanyPartner rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany Partner' ;
    rdfs:comment 'Indicates whether this legal entity participates in intercompany transactions requiring elimination during group consolidation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReportingEntity rdf:type rdf:Property ;
    rdfs:label 'Is Reporting Entity' ;
    rdfs:comment 'Indicates whether this legal entity is required to produce standalone statutory financial statements in its jurisdiction.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paidUpCapital rdf:type rdf:Property ;
    rdfs:label 'Paid Up Capital' ;
    rdfs:comment 'Amount of share capital that has been fully paid by shareholders, representing the entity\'s equity base.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Id' ;
    rdfs:comment 'Reference to the immediate parent legal entity in the corporate ownership hierarchy. Null for the ultimate parent entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registeredAddress rdf:type rdf:Property ;
    rdfs:label 'Registered Address' ;
    rdfs:comment 'Full registered office address of the legal entity as filed with the corporate registry. Used for official correspondence and legal service.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Classification indicating whether the entity is subject to industry-specific regulatory oversight (e.g., customs brokerage, freight forwarding licenses).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Flag' ;
    rdfs:comment 'Indicates whether this legal entity is within scope for SOX internal controls over financial reporting compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statutoryAuditor rdf:type rdf:Property ;
    rdfs:label 'Statutory Auditor' ;
    rdfs:comment 'Name of the external audit firm responsible for the statutory audit of this legal entity\'s financial statements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxGroupCode rdf:type rdf:Property ;
    rdfs:label 'Tax Group Code' ;
    rdfs:comment 'Identifier for the tax consolidation group to which this entity belongs, enabling group tax filing and loss offset arrangements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingCategory rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Category' ;
    rdfs:comment 'Functional characterization of the entity for transfer pricing purposes, determining the appropriate intercompany pricing methodology.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingCode rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Code' ;
    rdfs:comment 'The SWIFT/BIC code or domestic routing number identifying the party\'s bank for electronic fund transfers and intercompany settlements.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'The commonly used or trading name of the party for display purposes in reports and user interfaces. May differ from the legal name.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Dunning Procedure Code' ;
    rdfs:comment 'The dunning procedure assigned to this party that governs the escalation levels and timing of overdue payment reminders.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'The standard industry classification code (NAICS, NACE, or SIC) identifying the party\'s primary business sector. Used for credit risk segmentation and regulatory reporting.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this party is an intercompany entity within the Transport Shipping corporate group. Drives intercompany elimination rules in consolidated financial reporting.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRelatedParty rdf:type rdf:Property ;
    rdfs:label 'Is Related Party' ;
    rdfs:comment 'Indicates whether this party qualifies as a related party under IAS 24 disclosure requirements. Triggers additional reporting obligations for related party transactions.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentPartyId rdf:type rdf:Property ;
    rdfs:label 'Parent Party Id' ;
    rdfs:comment 'Reference to the parent party in the corporate hierarchy. Enables group-level consolidation, credit exposure aggregation, and intercompany relationship mapping.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'The primary email address for financial correspondence including invoice delivery, payment notifications, and audit communications.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The primary telephone contact number for the party, used for financial and operational communications.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account' ;
    rdfs:comment 'The general ledger reconciliation account number linked to this party for automatic posting of subledger transactions to the general ledger.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressCity rdf:type rdf:Property ;
    rdfs:label 'Registered Address City' ;
    rdfs:comment 'The city or municipality of the party\'s registered address.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Address Country' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the party\'s registered address. Used for jurisdiction determination in tax and regulatory reporting.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'The first line of the party\'s official registered address used for legal correspondence, tax filings, and regulatory submissions.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Address Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the party\'s registered address.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'The native primary key or business partner number from the source system, enabling traceability back to the operational system of record.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsTariffCode rdf:type rdf:Property ;
    rdfs:label 'Customs Tariff Code' ;
    rdfs:comment 'National or regional customs tariff classification code extending the HS code for duty rate determination and trade preference eligibility.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Export License Required Flag' ;
    rdfs:comment 'Indicates whether an export license or permit is required for this cargo based on its classification and destination restrictions.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatPackingGroup rdf:type rdf:Property ;
    rdfs:label 'Hazmat Packing Group' ;
    rdfs:comment 'Packing group (I, II, or III) indicating the degree of danger for hazardous cargo, determining packaging and handling requirements.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marksAndNumbers rdf:type rdf:Property ;
    rdfs:label 'Marks And Numbers' ;
    rdfs:comment 'Shipping marks, labels, and identification numbers physically applied to the cargo packages for identification during handling and delivery.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Max Temperature Celsius' ;
    rdfs:comment 'Maximum allowable temperature for temperature-sensitive cargo during transport and storage, measured in degrees Celsius.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Min Temperature Celsius' ;
    rdfs:comment 'Minimum allowable temperature for temperature-sensitive cargo during transport and storage, measured in degrees Celsius.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Primary key for training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableJobFamily rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Family' ;
    rdfs:comment 'The Workday HCM job family or families to which this course applies, supporting role-based competency assignment and workforce planning.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentOwner rdf:type rdf:Property ;
    rdfs:label 'Content Owner' ;
    rdfs:comment 'Name or identifier of the business unit or individual responsible for maintaining and updating the course content.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryApplicability rdf:type rdf:Property ;
    rdfs:label 'Country Applicability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this course is applicable or required, supporting global logistics operations across multiple jurisdictions.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'Classification of the training course by its purpose or requirement level within the organization.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentOpenFlag rdf:type rdf:Property ;
    rdfs:label 'Enrollment Open Flag' ;
    rdfs:comment 'Indicates whether the course is currently accepting new enrollments. Used by workforce scheduling systems to determine available training options.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certification Flag' ;
    rdfs:comment 'Indicates whether this course provides or renews hazardous materials handling certification required for freight and express delivery operations.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lmsCourseUrl rdf:type rdf:Property ;
    rdfs:label 'Lms Course Url' ;
    rdfs:comment 'Direct URL link to the course within the Learning Management System for e-learning and blended delivery access.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Attempts' ;
    rdfs:comment 'Maximum number of attempts allowed for the final assessment before requiring course re-enrollment.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxClassSize rdf:type rdf:Property ;
    rdfs:label 'Max Class Size' ;
    rdfs:comment 'Maximum number of participants allowed per session or cohort for instructor-led or virtual classroom delivery.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Timestamp when this training course record was last updated or modified.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:passingScorePercent rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percent' ;
    rdfs:comment 'Minimum assessment score percentage required to successfully complete the course and receive certification.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteCourseCode rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Course Code' ;
    rdfs:comment 'Course code of the prerequisite training that must be completed before enrolling in this course. Null if no prerequisite exists.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDomain rdf:type rdf:Property ;
    rdfs:label 'Regulatory Domain' ;
    rdfs:comment 'The regulatory body or compliance framework that mandates or governs this training course. Critical for DOT driver certifications, ICAO crew qualifications, and OSHA safety requirements in logistics.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether this course covers safety-critical operations where non-compliance could result in injury, environmental harm, or regulatory penalty.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillLevel rdf:type rdf:Property ;
    rdfs:label 'Skill Level' ;
    rdfs:comment 'The proficiency level targeted by this course, used for role-based competency mapping and talent development planning.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitsEligible rdf:type rdf:Property ;
    rdfs:label 'Benefits Eligible' ;
    rdfs:comment 'Indicates whether employees in this pay group are eligible for company-sponsored benefits (health insurance, retirement plans, etc.).' ;
    rdfs:domain ind:PayGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectiveBargainingAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Collective Bargaining Agreement Ref' ;
    rdfs:comment 'Reference code or name of the applicable collective bargaining agreement governing compensation terms for unionized pay groups.' ;
    rdfs:domain ind:PayGroup ;
    rdf:type owl:DatatypeProperty ;
