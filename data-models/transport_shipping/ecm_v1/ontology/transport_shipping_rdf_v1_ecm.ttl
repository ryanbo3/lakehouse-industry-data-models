    rdfs:comment 'Current lifecycle status of the compliance review process.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
