    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizedFlag rdf:type rdf:Property ;
    rdfs:label 'Capitalized Flag' ;
    rdfs:comment 'Indicates whether the project costs are capitalized on the balance sheet.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depreciationPeriodYears rdf:type rdf:Property ;
