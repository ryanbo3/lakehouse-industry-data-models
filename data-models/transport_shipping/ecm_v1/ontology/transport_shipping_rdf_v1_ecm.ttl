    rdfs:range xsd:string .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'The date on which the granted waiver or exemption expires and the obligation becomes enforceable again.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether a waiver or exemption has been granted for this compliance obligation (True/False).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Explanation or justification for granting a waiver or exemption from this compliance obligation.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewId rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Id' ;
    rdfs:comment 'Unique identifier for the compliance review record. Primary key.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceReview .

ind:ghgInventoryId rdf:type rdf:Property ;
    rdfs:label 'Ghg Inventory Id' ;
    rdfs:comment 'Foreign key linking to sustainability.ghg_inventory. Business justification: Compliance reviews of contractual sustainability obligations verify against annual GHG inventory submissions for accuracy, completeness, and methodology compliance. Required for third-party assurance ' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GhgInventory .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Flag indicating whether the compliance review findings require formal approval before closure.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFinding rdf:type rdf:Property ;
    rdfs:label 'Compliance Finding' ;
    rdfs:comment 'Overall outcome of the compliance review indicating whether the obligation was met, not met, or partially met.' ;
    rdfs:domain ind:ComplianceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'Target date by which corrective actions must be completed to remediate non-compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Description of the corrective actions required to remediate non-compliance findings and achieve compliance.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionOwner rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Owner' ;
    rdfs:comment 'Name or identifier of the individual or department responsible for implementing corrective actions.' ;
    rdfs:domain ind:ComplianceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Flag indicating whether corrective action is required to address non-compliance findings.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of the corrective action implementation and verification process.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRecipient rdf:type rdf:Property ;
    rdfs:label 'Escalation Recipient' ;
    rdfs:comment 'Name or role of the individual or department to whom the compliance finding was escalated.' ;
    rdfs:domain ind:ComplianceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Flag indicating whether the compliance finding requires escalation to senior management or regulatory authorities.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Reference to supporting documentation, records, or evidence collected during the compliance review.' ;
    rdfs:domain ind:ComplianceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the compliance finding, including evidence, observations, and specific non-compliance details.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingSeverity rdf:type rdf:Property ;
    rdfs:label 'Finding Severity' ;
    rdfs:comment 'Severity classification of non-compliance findings, indicating the level of risk or impact to the business.' ;
    rdfs:domain ind:ComplianceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for follow-up review to verify that corrective actions have been implemented and are effective.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Flag indicating whether a follow-up review is required to verify corrective action effectiveness.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The regulatory or compliance framework under which this review was conducted, such as International Maritime Organization (IMO), International Air Transport Association (IATA), Customs-Trade Partnership Against Terrorism (C-TPAT), or Authorized Economic Operator (AEO).' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Additional comments, observations, or notes provided by the reviewer regarding the compliance review.' ;
    rdfs:domain ind:ComplianceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The date on which the compliance review was conducted or completed.' ;
    rdfs:domain ind:TransportShipping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNumber rdf:type rdf:Property ;
