    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Amount' ;
    rdfs:comment 'Monetary value of labor for the entry, used for cost posting.' ;
