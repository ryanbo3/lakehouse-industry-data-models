ind:osatWorkOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Osat Work Order Status' ;
    rdfs:comment 'Current lifecycle status of the work order.' ;
    rdfs:domain ind:OsatWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
