    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeRecordId rdf:type rdf:Property ;
    rdfs:label 'Oee Record Id' ;
    rdfs:comment 'Unique surrogate key for each OEE measurement record.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeFabToolId rdf:type rdf:Property ;
    rdfs:label 'Oee Fab Tool Id' ;
    rdfs:comment 'Unique identifier of the fab tool for which the OEE record is captured.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:ObjectProperty ;
