    rdfs:range xsd:string .

ind:taxStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Status' ;
    rdfs:comment 'Current tax compliance status of the entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentLocation rdf:type rdf:Property ;
    rdfs:label 'Consignment Location' ;
    rdfs:comment 'Warehouse or facility code where the consigned inventory is stored.' ;
    rdfs:domain ind:ConsignmentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Consignment Quantity' ;
    rdfs:comment 'Total quantity of the item placed on consignment.' ;
    rdfs:domain ind:ConsignmentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryItemSku rdf:type rdf:Property ;
    rdfs:label 'Inventory Item Sku' ;
    rdfs:comment 'Stock-keeping unit of the consigned item as defined in the product master.' ;
