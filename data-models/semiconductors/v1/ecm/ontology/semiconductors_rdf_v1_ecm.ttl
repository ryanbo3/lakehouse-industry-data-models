    rdfs:comment 'Supplier\'s own part number for the material.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productChangeNotificationId rdf:type rdf:Property ;
    rdfs:label 'Product Change Notification Id' ;
    rdfs:comment 'System-generated unique identifier for the product change notification record.' ;
    rdfs:domain ind:ProductChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSupplierId rdf:type rdf:Property ;
    rdfs:label 'Product Supplier Id' ;
    rdfs:comment 'Unique identifier of the supplier issuing the PCN.' ;
