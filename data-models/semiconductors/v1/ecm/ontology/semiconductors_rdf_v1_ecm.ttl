    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentDescription rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Description' ;
    rdfs:comment 'Details of any safety incident associated with the maintenance.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'True if the maintenance event involved a safety incident.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Combined cost of parts, labor, and any additional charges.' ;
