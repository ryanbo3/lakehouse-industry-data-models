    rdfs:range xsd:decimal .

ind:billingEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing End Date' ;
    rdfs:comment 'Date of the final billing occurrence; null if billing continues until obligation end.' ;
    rdfs:domain ind:PerformanceObligation ;
