    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Review Status' ;
    rdfs:comment 'Current review status of the measurement.' ;
