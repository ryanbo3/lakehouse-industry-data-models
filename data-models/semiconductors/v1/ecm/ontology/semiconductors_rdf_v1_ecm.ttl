    rdfs:range xsd:string .

ind:disruptionEventType rdf:type rdf:Property ;
    rdfs:label 'Disruption Event Type' ;
    rdfs:comment 'Category of the disruption that occurred.' ;
    rdfs:domain ind:RiskAssessment ;
