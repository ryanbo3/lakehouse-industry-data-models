    rdfs:comment 'Date when the disruption began.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disruptionStatus rdf:type rdf:Property ;
    rdfs:label 'Disruption Status' ;
    rdfs:comment 'Current status of the disruption record.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactEstimateWaferStarts rdf:type rdf:Property ;
    rdfs:label 'Impact Estimate Wafer Starts' ;
    rdfs:comment 'Estimated number of wafer starts that could be lost if the risk occurs.' ;
