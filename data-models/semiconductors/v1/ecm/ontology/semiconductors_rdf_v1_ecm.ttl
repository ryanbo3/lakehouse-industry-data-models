    rdfs:comment 'Identifier of the wafer lot from which the tested devices were drawn.' ;
    rdfs:domain ind:ReliabilityTestRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:primaryTestProgramId rdf:type rdf:Property ;
    rdfs:label 'Primary Test Program Id' ;
    rdfs:comment 'FK to test.test_program.test_program_id — Reliability test executions (including burn-in) reference test programs for pre/post stress testing.' ;
    rdfs:domain ind:ReliabilityTestRun ;
