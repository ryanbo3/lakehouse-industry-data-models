    rdfs:range xsd:string .

ind:isControlledSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Substance' ;
    rdfs:comment 'True if the substance is subject to any export or use control regulations.' ;
    rdfs:domain ind:SubstanceInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isItarControlled rdf:type rdf:Property ;
    rdfs:label 'Is Itar Controlled' ;
    rdfs:comment 'True if the substance is subject to ITAR export controls.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPfas rdf:type rdf:Property ;
    rdfs:label 'Is Pfas' ;
    rdfs:comment 'True if the substance is a per- and poly-fluoroalkyl substance.' ;
