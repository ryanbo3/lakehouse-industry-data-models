ind:packageCapabilities rdf:type rdf:Property ;
    rdfs:label 'Package Capabilities' ;
    rdfs:comment 'Comma-separated list of package types the vendor is qualified to assemble (e.g., WLCSP, InFO, CoWoS, TSV, flip-chip, BGA).' ;
    rdfs:domain ind:OsatVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Status' ;
    rdfs:comment 'Current qualification status of the vendor within the OSAT program.' ;
    rdfs:domain ind:OsatVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPackageTypes rdf:type rdf:Property ;
    rdfs:label 'Preferred Package Types' ;
    rdfs:comment 'Comma-separated list of package types the vendor is preferred for.' ;
    rdfs:domain ind:OsatVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the vendor.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertifications rdf:type rdf:Property ;
    rdfs:label 'Quality Certifications' ;
    rdfs:comment 'Semicolon-separated list of quality certifications held by the vendor (e.g., IATF 16949, ISO 9001, AEC-Q100).' ;
    rdfs:domain ind:OsatVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Typical lead time in days for standard package orders.' ;
    rdfs:domain ind:OsatVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorAddress rdf:type rdf:Property ;
    rdfs:label 'Vendor Address' ;
    rdfs:comment 'Physical address of the vendor\'s primary site.' ;
    rdfs:domain ind:OsatVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Unique vendor code used in ERP and PLM systems.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCountry rdf:type rdf:Property ;
    rdfs:label 'Vendor Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the vendor\'s headquarters. [ENUM-REF-CANDIDATE: USA|CHN|KOR|JPN|TWN|DEU|... — promote to reference product]' ;
    rdfs:domain ind:OsatVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorShortName rdf:type rdf:Property ;
    rdfs:label 'Vendor Short Name' ;
    rdfs:comment 'Commonly used short name or abbreviation for the vendor.' ;
    rdfs:domain ind:OsatVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor based on ownership and relationship.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageQualificationId rdf:type rdf:Property ;
    rdfs:label 'Package Qualification Id' ;
    rdfs:comment 'Primary key for package_qualification' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageQualification .

ind:complianceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.certification. Business justification: Package qualification results are tied to specific certifications; linking enables compliance verification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:primaryPackagingPackageTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Packaging Package Type Id' ;
    rdfs:comment 'FK to packaging.package_type' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:qualificationPlanId rdf:type rdf:Property ;
    rdfs:label 'Qualification Plan Id' ;
    rdfs:comment 'Business identifier for the qualification plan used to certify the package.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualificationPlan .

ind:tertiaryPackageTypeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Package Type Id' ;
    rdfs:comment 'FK to packaging.package_type.package_type_id — Qualifications certify specific package types for production. Essential for determining which package types are production-released.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:defectRatePpm rdf:type rdf:Property ;
    rdfs:label 'Defect Rate Ppm' ;
    rdfs:comment 'Defective parts per million observed in the qualification samples.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditDate rdf:type rdf:Property ;
    rdfs:label 'External Audit Date' ;
    rdfs:comment 'Scheduled date for the external audit, if required.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAuditRequired rdf:type rdf:Property ;
    rdfs:label 'External Audit Required' ;
    rdfs:comment 'Indicates whether an external audit is mandated for this qualification.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFailCriteria rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Criteria' ;
    rdfs:comment 'Defined criteria that determine pass or fail outcomes for each test.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Qualification Cost Usd' ;
    rdfs:comment 'Total cost incurred for the qualification program, expressed in US dollars.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Document Number' ;
    rdfs:comment 'Reference to the document that contains the full qualification report.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationMethod rdf:type rdf:Property ;
    rdfs:label 'Qualification Method' ;
    rdfs:comment 'Approach used for qualification testing.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationOwner rdf:type rdf:Property ;
    rdfs:label 'Qualification Owner' ;
    rdfs:comment 'Name of the person responsible for managing the qualification program.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStandard rdf:type rdf:Property ;
    rdfs:label 'Qualification Standard' ;
    rdfs:comment 'Standard or specification against which the package is qualified.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCompliance rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance' ;
    rdfs:comment 'Regulatory framework(s) the qualification adheres to.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Number of sample units tested during qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stressTestMatrix rdf:type rdf:Property ;
    rdfs:label 'Stress Test Matrix' ;
    rdfs:comment 'Set of stress tests applied during qualification (e.g., High Temperature Operating Life, Temperature Cycling).' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDurationHours rdf:type rdf:Property ;
    rdfs:label 'Test Duration Hours' ;
    rdfs:comment 'Total duration of the qualification test cycle in hours.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testEquipmentCode rdf:type rdf:Property ;
    rdfs:label 'Test Equipment Code' ;
    rdfs:comment 'Identifier of the equipment used to perform the qualification tests.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testLocation rdf:type rdf:Property ;
    rdfs:label 'Test Location' ;
    rdfs:comment 'Physical location or facility where the qualification testing was conducted.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Test Temperature C' ;
    rdfs:comment 'Maximum temperature (in Celsius) applied during stress testing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ballCountMax rdf:type rdf:Property ;
    rdfs:label 'Ball Count Max' ;
    rdfs:comment 'Maximum number of solder balls for BGA-type packages.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ballCountMin rdf:type rdf:Property ;
    rdfs:label 'Ball Count Min' ;
    rdfs:comment 'Minimum number of solder balls for BGA-type packages.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:is3dIc rdf:type rdf:Property ;
    rdfs:label 'Is 3d Ic' ;
    rdfs:comment 'True if the package incorporates through-silicon vias or other 3-D stacking.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAdvancedPackage rdf:type rdf:Property ;
    rdfs:label 'Is Advanced Package' ;
    rdfs:comment 'True for cutting-edge or specialty package formats.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBallGridArray rdf:type rdf:Property ;
    rdfs:label 'Is Ball Grid Array' ;
    rdfs:comment 'True if the package is a ball-grid array type.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFlipChip rdf:type rdf:Property ;
    rdfs:label 'Is Flip Chip' ;
    rdfs:comment 'True if the package utilizes flip-chip interconnect technology.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHeterogeneousIntegration rdf:type rdf:Property ;
    rdfs:label 'Is Heterogeneous Integration' ;
    rdfs:comment 'Indicates whether the package supports heterogeneous integration (e.g., chip-on-wafer).' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadframe rdf:type rdf:Property ;
    rdfs:label 'Is Leadframe' ;
    rdfs:comment 'True if the package uses a traditional leadframe.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOsatSupported rdf:type rdf:Property ;
    rdfs:label 'Is Osat Supported' ;
    rdfs:comment 'True if the package type is commonly offered by outsourced assembly providers.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReachCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Reach Compliant' ;
    rdfs:comment 'True if the package complies with REACH chemical safety regulations.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRohsCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Rohs Compliant' ;
    rdfs:comment 'True if the package meets RoHS restriction requirements.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWireBond rdf:type rdf:Property ;
    rdfs:label 'Is Wire Bond' ;
    rdfs:comment 'True if the package uses wire-bond interconnects.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jedecOutlineCode rdf:type rdf:Property ;
    rdfs:label 'Jedec Outline Code' ;
    rdfs:comment 'Official JEDEC outline identifier for the package (e.g., 5x5-1mm).' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCurrentA rdf:type rdf:Property ;
    rdfs:label 'Max Current A' ;
    rdfs:comment 'Maximum continuous current rating for the package.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDiePitchUm rdf:type rdf:Property ;
    rdfs:label 'Max Die Pitch Um' ;
    rdfs:comment 'Maximum center-to-center spacing between dies for multi-die packages.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxOperatingTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Operating Temperature C' ;
    rdfs:comment 'Highest temperature at which the package can reliably operate.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPowerDissipationW rdf:type rdf:Property ;
    rdfs:label 'Max Power Dissipation W' ;
    rdfs:comment 'Maximum power the package can dissipate safely.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVoltageV rdf:type rdf:Property ;
    rdfs:label 'Max Voltage V' ;
    rdfs:comment 'Maximum voltage rating the package can withstand.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minDiePitchUm rdf:type rdf:Property ;
    rdfs:label 'Min Die Pitch Um' ;
    rdfs:comment 'Minimum center-to-center spacing between dies for multi-die packages.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOperatingTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Operating Temperature C' ;
    rdfs:comment 'Lowest temperature at which the package can reliably operate.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageCategory rdf:type rdf:Property ;
    rdfs:label 'Package Category' ;
    rdfs:comment 'Primary category of the package format; limited to six most common values.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDimensionsHeightUm rdf:type rdf:Property ;
    rdfs:label 'Package Dimensions Height Um' ;
    rdfs:comment 'External height (thickness) dimension of the package.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageDimensionsLengthUm rdf:type rdf:Property ;
    rdfs:label 'Package Dimensions Length Um' ;
    rdfs:comment 'External length dimension of the package.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageDimensionsWidthUm rdf:type rdf:Property ;
    rdfs:label 'Package Dimensions Width Um' ;
    rdfs:comment 'External width dimension of the package.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageFamily rdf:type rdf:Property ;
    rdfs:label 'Package Family' ;
    rdfs:comment 'Higher-level family grouping (e.g., Wafer-Level, Flip-Chip, 3D-IC).' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable name of the package format (e.g., WLCSP, CoWoS).' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Package Type Description' ;
    rdfs:comment 'Free-form description of the package’s mechanical and electrical characteristics.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Package Type Status' ;
    rdfs:comment 'Current lifecycle status of the package type.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinCountMax rdf:type rdf:Property ;
    rdfs:label 'Pin Count Max' ;
    rdfs:comment 'Maximum number of electrical pins/balls the package can support.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pinCountMin rdf:type rdf:Property ;
    rdfs:label 'Pin Count Min' ;
    rdfs:comment 'Minimum number of electrical pins/balls the package can support.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'Identifier or URL of the primary specification document for the package type.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thermalResistanceCPerW rdf:type rdf:Property ;
    rdfs:label 'Thermal Resistance C Per W' ;
    rdfs:comment 'Thermal resistance from die to ambient, expressed in degrees Celsius per Watt.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalThicknessUm rdf:type rdf:Property ;
    rdfs:label 'Typical Thickness Um' ;
    rdfs:comment 'Nominal vertical thickness of the finished package.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reliabilityStressTestId rdf:type rdf:Property ;
    rdfs:label 'Reliability Stress Test Id' ;
    rdfs:comment 'System-generated unique identifier for each reliability stress test run.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityReliabilityTestId rdf:type rdf:Property ;
    rdfs:label 'Quality Reliability Test Id' ;
    rdfs:comment 'Foreign key linking to quality.reliability_test. Business justification: Integrates packaging stress test results with wafer-level reliability data for the Reliability Consolidated Report used in product qualification.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReliabilityTest .

ind:reliabilityPackageQualificationId rdf:type rdf:Property ;
    rdfs:label 'Reliability Package Qualification Id' ;
    rdfs:comment 'FK to packaging.package_qualification.package_qualification_id — Stress tests are executed as part of a qualification program. Required for qualification evidence chain.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageQualification .

ind:cycles rdf:type rdf:Property ;
    rdfs:label 'Cycles' ;
    rdfs:comment 'Number of electrical or mechanical cycles applied (relevant for cycling tests).' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureCount rdf:type rdf:Property ;
    rdfs:label 'Failure Count' ;
    rdfs:comment 'Number of units that failed during the test.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Descriptive classification of the observed failure mechanism.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mttfHours rdf:type rdf:Property ;
    rdfs:label 'Mttf Hours' ;
    rdfs:comment 'Estimated mean time to failure derived from test results, expressed in hours.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reliabilityStressTestStatus rdf:type rdf:Property ;
    rdfs:label 'Reliability Stress Test Status' ;
    rdfs:comment 'Current lifecycle state of the reliability test.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultMetric rdf:type rdf:Property ;
    rdfs:label 'Result Metric' ;
    rdfs:comment 'Name of the primary quantitative result measured (e.g., failure_rate).' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultUnit rdf:type rdf:Property ;
    rdfs:label 'Result Unit' ;
    rdfs:comment 'Unit of measure for the result value (e.g., failures_per_hour).' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'Numeric value of the primary result metric.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of individual units subjected to the stress test.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stressTestToQualification rdf:type rdf:Property ;
    rdfs:label 'Stress Test To Qualification' ;
    rdfs:comment 'FK to packaging.pkg_qualification.pkg_qualification_id — Reliability stress tests are executed as part of qualification programs. Each test run links to its parent qualification.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testConditionsDescription rdf:type rdf:Property ;
    rdfs:label 'Test Conditions Description' ;
    rdfs:comment 'Narrative description of the test environment and setup.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testRunCode rdf:type rdf:Property ;
    rdfs:label 'Test Run Code' ;
    rdfs:comment 'External code or number assigned to the test run for traceability across systems.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSpecVersion rdf:type rdf:Property ;
    rdfs:label 'Test Spec Version' ;
    rdfs:comment 'Version identifier of the test specification document.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStandard rdf:type rdf:Property ;
    rdfs:label 'Test Standard' ;
    rdfs:comment 'Industry or internal standard governing the test methodology.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Start Timestamp' ;
    rdfs:comment 'Date and time when the stress test started.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Type of reliability stress test performed (e.g., HTOL, TC, HAST, PRECON, ESD, Latch-up, Drop). [ENUM-REF-CANDIDATE: HTOL|TC|HAST|PRECON|ESD|Latch-up|Drop — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voltageV rdf:type rdf:Property ;
    rdfs:label 'Voltage V' ;
    rdfs:comment 'Voltage applied to the device under test, expressed in volts.' ;
    rdfs:domain ind:ReliabilityStressTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substratePackageTypeId rdf:type rdf:Property ;
    rdfs:label 'Substrate Package Type Id' ;
    rdfs:comment 'FK to packaging.package_type.package_type_id — Substrate BOMs are specific to a package type. Required for procurement and assembly material planning.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:avlStatus rdf:type rdf:Property ;
    rdfs:label 'Avl Status' ;
    rdfs:comment 'AVL qualification status of the substrate supplier.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bumpPitchUm rdf:type rdf:Property ;
    rdfs:label 'Bump Pitch Um' ;
    rdfs:comment 'Center-to-center distance between bumps on the substrate, expressed in micrometers.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coreMaterial rdf:type rdf:Property ;
    rdfs:label 'Core Material' ;
    rdfs:comment 'Primary material of the substrate core (e.g., ABF, BT resin, silicon, glass).' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityGPerCm3 rdf:type rdf:Property ;
    rdfs:label 'Density G Per Cm3' ;
    rdfs:comment 'Material density of the substrate.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dielectricConstant rdf:type rdf:Property ;
    rdfs:label 'Dielectric Constant' ;
    rdfs:comment 'Relative permittivity of the substrate material.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isObsolete rdf:type rdf:Property ;
    rdfs:label 'Is Obsolete' ;
    rdfs:comment 'Indicates whether the substrate is marked as obsolete.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEcoTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Eco Timestamp' ;
    rdfs:comment 'Timestamp of the most recent engineering change order affecting this BOM.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:layerCount rdf:type rdf:Property ;
    rdfs:label 'Layer Count' ;
    rdfs:comment 'Number of material layers in the substrate stack.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialGrade rdf:type rdf:Property ;
    rdfs:label 'Material Grade' ;
    rdfs:comment 'Grade or quality level of the substrate material.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxOperatingTempC rdf:type rdf:Property ;
    rdfs:label 'Max Operating Temp C' ;
    rdfs:comment 'Maximum temperature at which the substrate can reliably operate.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOperatingTempC rdf:type rdf:Property ;
    rdfs:label 'Min Operating Temp C' ;
    rdfs:comment 'Minimum temperature for reliable substrate operation.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:padFinish rdf:type rdf:Property ;
    rdfs:label 'Pad Finish' ;
    rdfs:comment 'Surface finish applied to substrate pads (e.g., ENIG, OSP, immersion tin, gold).' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdlSpec rdf:type rdf:Property ;
    rdfs:label 'Rdl Spec' ;
    rdfs:comment 'Specification details of the redistribution layer (RDL) used on the substrate.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date when the current revision was released.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:substrateBomName rdf:type rdf:Property ;
    rdfs:label 'Substrate Bom Name' ;
    rdfs:comment 'Human-readable name or description of the substrate.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substrateBomStatus rdf:type rdf:Property ;
    rdfs:label 'Substrate Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM record.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substrateToPackageType rdf:type rdf:Property ;
    rdfs:label 'Substrate To Package Type' ;
    rdfs:comment 'FK to packaging.packaging_package_type.packaging_package_type_id — Substrate BOMs are defined for specific package types (CoWoS interposer, flip-chip BGA substrate, etc.).' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thermalConductivityWPerMk rdf:type rdf:Property ;
    rdfs:label 'Thermal Conductivity W Per Mk' ;
    rdfs:comment 'Thermal conductivity of the substrate material.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeProcessFlowId rdf:type rdf:Property ;
    rdfs:label 'Change Process Flow Id' ;
    rdfs:comment 'Foreign key linking to process.process_process_flow. Business justification: Change notifications affect a specific process flow; an internal FK provides direct reference within the process domain.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessFlow .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Actual date when the process change was implemented in production manufacturing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedCustomerList rdf:type rdf:Property ;
    rdfs:label 'Affected Customer List' ;
    rdfs:comment 'List of customer names or identifiers who have products affected by this change and require notification per contractual agreements.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedEquipmentList rdf:type rdf:Property ;
    rdfs:label 'Affected Equipment List' ;
    rdfs:comment 'List of manufacturing equipment tools or tool sets impacted by this process change, including tool IDs or model numbers.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedMaterialList rdf:type rdf:Property ;
    rdfs:label 'Affected Material List' ;
    rdfs:comment 'List of raw materials, chemicals, gases, or consumables that are being changed or affected by this process modification.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductList rdf:type rdf:Property ;
    rdfs:label 'Affected Product List' ;
    rdfs:comment 'Comma-separated list or description of product families, part numbers, or device types impacted by this process change.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachments rdf:type rdf:Property ;
    rdfs:label 'Attachments' ;
    rdfs:comment 'References to supporting documentation such as technical specifications, test reports, FMEA analyses, customer communications, or qualification data associated with this PCN.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeClassification rdf:type rdf:Property ;
    rdfs:label 'Change Classification' ;
    rdfs:comment 'Impact classification of the change: major (requires customer approval and qualification), minor (notification required but no requalification), or notification_only (informational, no customer action required).' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:comment 'Brief descriptive title summarizing the nature of the process change.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Impact' ;
    rdfs:comment 'Assessment of the financial impact of the process change including implementation costs, ongoing cost savings or increases, and return on investment.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Required' ;
    rdfs:comment 'Indicates whether explicit customer approval is required before implementing the change, typically for major changes affecting form, fit, function, or reliability.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleTimeImpactHours rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Impact Hours' ;
    rdfs:comment 'Expected change in manufacturing cycle time resulting from the process change, measured in hours (positive for increase, negative for reduction).' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalImpact rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact' ;
    rdfs:comment 'Description of any environmental, health, or safety impacts resulting from the process change, including changes to hazardous material usage or waste generation.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTimeBuyDate rdf:type rdf:Property ;
    rdfs:label 'Last Time Buy Date' ;
    rdfs:comment 'Final date for customers to place orders for products manufactured using the old process before the change is implemented.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTimeShipDate rdf:type rdf:Property ;
    rdfs:label 'Last Time Ship Date' ;
    rdfs:comment 'Final date for shipping products manufactured using the old process before transitioning to the new process.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerEngineerName rdf:type rdf:Property ;
    rdfs:label 'Owner Engineer Name' ;
    rdfs:comment 'Name of the process engineer or technical owner responsible for managing this change notification through implementation.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerOrganization rdf:type rdf:Property ;
    rdfs:label 'Owner Organization' ;
    rdfs:comment 'Department or organizational unit responsible for the process change, such as Process Engineering, Equipment Engineering, or Quality Assurance.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Implementation Date' ;
    rdfs:comment 'Target date for implementing the process change in production manufacturing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryImpact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact' ;
    rdfs:comment 'Assessment of whether the process change affects compliance with regulatory requirements such as RoHS, REACH, ITAR, EAR, or automotive quality standards (IATF 16949).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldImpactPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Impact Percent' ;
    rdfs:comment 'Expected or measured change in manufacturing yield resulting from the process change, expressed as a percentage point change (positive for improvement, negative for degradation).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmpConditionId rdf:type rdf:Property ;
    rdfs:label 'Cmp Condition Id' ;
    rdfs:comment 'Unique identifier for the CMP process condition master record. Primary key.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierSpeedRpm rdf:type rdf:Property ;
    rdfs:label 'Carrier Speed Rpm' ;
    rdfs:comment 'Rotational speed of the wafer carrier head during CMP processing, measured in revolutions per minute. Affects relative velocity and material removal uniformity.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmpConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Cmp Condition Description' ;
    rdfs:comment 'Detailed textual description of this CMP process condition, including special considerations, application scope, and any unique characteristics or constraints.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmpStepType rdf:type rdf:Property ;
    rdfs:label 'Cmp Step Type' ;
    rdfs:comment 'Classification of the CMP process step based on the material and layer being planarized. STI (Shallow Trench Isolation) for FEOL, ILD (Inter-Layer Dielectric) for MOL/BEOL, W-plug for tungsten contact fill, Cu damascene for copper interconnect, barrier for barrier metal removal. [ENUM-REF-CANDIDATE: STI|ILD|W-plug|Cu damascene|barrier|poly|tungsten contact|cobalt contact — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to this CMP condition for tracking and reference in Manufacturing Execution System (MES) and process control systems.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionName rdf:type rdf:Property ;
    rdfs:label 'Condition Name' ;
    rdfs:comment 'Human-readable name or identifier for this CMP process condition, typically including the CMP step type and target layer.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionerType rdf:type rdf:Property ;
    rdfs:label 'Conditioner Type' ;
    rdfs:comment 'Type of diamond conditioning disk or brush used to maintain pad surface texture and porosity during CMP processing. Conditioning prevents pad glazing and maintains consistent removal rates.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditioningFrequency rdf:type rdf:Property ;
    rdfs:label 'Conditioning Frequency' ;
    rdfs:comment 'Schedule for pad conditioning operations, such as ex-situ (between wafers), in-situ (during polishing), or time-based intervals. Maintains pad performance and removal rate stability.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDensitySpecPerWafer rdf:type rdf:Property ;
    rdfs:label 'Defect Density Spec Per Wafer' ;
    rdfs:comment 'Maximum allowable number of CMP-induced defects per wafer, including scratches, particles, residue, and surface damage. Measured by post-CMP inspection tools.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dishingSpecAngstrom rdf:type rdf:Property ;
    rdfs:label 'Dishing Spec Angstrom' ;
    rdfs:comment 'Maximum allowable depression or dishing in metal features (copper lines, tungsten plugs) after CMP, measured in angstroms. Excessive dishing degrades electrical performance and reliability.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endpointDetectionMethod rdf:type rdf:Property ;
    rdfs:label 'Endpoint Detection Method' ;
    rdfs:comment 'Technology used to determine when the target material removal amount has been achieved. Optical methods detect reflectivity changes, motor current monitors torque variations, time-based uses fixed duration, acoustic detects friction changes, eddy current senses metal thickness.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erosionSpecAngstrom rdf:type rdf:Property ;
    rdfs:label 'Erosion Spec Angstrom' ;
    rdfs:comment 'Maximum allowable thinning of dielectric material in dense pattern areas relative to isolated areas, measured in angstroms. Erosion affects metal line height uniformity and interconnect reliability.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBaselineCondition rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Condition' ;
    rdfs:comment 'Indicates whether this is the baseline or reference CMP condition for this step type and technology node. Baseline conditions serve as the standard for process capability and yield comparisons.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:padProductName rdf:type rdf:Property ;
    rdfs:label 'Pad Product Name' ;
    rdfs:comment 'Commercial product name or part number of the CMP polishing pad as designated by the vendor.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:padType rdf:type rdf:Property ;
    rdfs:label 'Pad Type' ;
    rdfs:comment 'Classification and material composition of the CMP polishing pad, including hardness, porosity, groove pattern, and surface texture characteristics that affect removal rate and uniformity.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:padVendor rdf:type rdf:Property ;
    rdfs:label 'Pad Vendor' ;
    rdfs:comment 'Manufacturer or supplier of the CMP polishing pad used in this process condition.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platenPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Platen Pressure Psi' ;
    rdfs:comment 'Downforce pressure applied by the wafer carrier to the polishing pad surface, measured in pounds per square inch. Critical parameter controlling removal rate and within-wafer uniformity.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:polishTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Polish Time Seconds' ;
    rdfs:comment 'Target duration of the CMP polishing step in seconds, from wafer contact with pad to endpoint detection or time-based completion.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postCmpCleanRecipe rdf:type rdf:Property ;
    rdfs:label 'Post Cmp Clean Recipe' ;
    rdfs:comment 'Cleaning process recipe applied immediately after CMP to remove slurry residue, particles, and contaminants from the wafer surface. Typically includes brush scrubbing, chemical rinse, and DI water rinse steps.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedByEngineerName rdf:type rdf:Property ;
    rdfs:label 'Qualified By Engineer Name' ;
    rdfs:comment 'Name of the process engineer responsible for qualifying and approving this CMP condition for production use.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalRateAngstromPerMin rdf:type rdf:Property ;
    rdfs:label 'Removal Rate Angstrom Per Min' ;
    rdfs:comment 'Expected rate of material removal during CMP processing, measured in angstroms per minute. Determined by slurry chemistry, pad type, pressure, and speed parameters.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:selectivityRatio rdf:type rdf:Property ;
    rdfs:label 'Selectivity Ratio' ;
    rdfs:comment 'Ratio of removal rates between the target material and underlying stop layer or adjacent materials. High selectivity ensures controlled polishing without excessive removal of barrier or dielectric layers.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slurryChemistryType rdf:type rdf:Property ;
    rdfs:label 'Slurry Chemistry Type' ;
    rdfs:comment 'Chemical composition classification of the CMP slurry used in this condition, including abrasive type (silica, ceria, alumina), pH level, and chemical additives for selectivity and removal rate control.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slurryFlowRateMlPerMin rdf:type rdf:Property ;
    rdfs:label 'Slurry Flow Rate Ml Per Min' ;
    rdfs:comment 'Target volumetric flow rate of CMP slurry delivered to the polishing pad surface during processing, measured in milliliters per minute.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slurryProductName rdf:type rdf:Property ;
    rdfs:label 'Slurry Product Name' ;
    rdfs:comment 'Commercial product name or part number of the CMP slurry as designated by the vendor.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slurryVendor rdf:type rdf:Property ;
    rdfs:label 'Slurry Vendor' ;
    rdfs:comment 'Manufacturer or supplier of the CMP slurry chemical used in this process condition.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableSpeedRpm rdf:type rdf:Property ;
    rdfs:label 'Table Speed Rpm' ;
    rdfs:comment 'Rotational speed of the CMP platen table holding the polishing pad, measured in revolutions per minute. Combined with carrier speed determines relative motion and removal characteristics.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLayerName rdf:type rdf:Property ;
    rdfs:label 'Target Layer Name' ;
    rdfs:comment 'Specific layer or film stack being planarized by this CMP process, such as oxide, nitride, metal layer designation (M1, M2, etc.), or via layer.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRemovalAmountAngstrom rdf:type rdf:Property ;
    rdfs:label 'Target Removal Amount Angstrom' ;
    rdfs:comment 'Specified thickness of material to be removed during the CMP process, measured in angstroms. Critical for achieving target post-CMP film thickness and planarity.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferToWaferUniformitySpecPercent rdf:type rdf:Property ;
    rdfs:label 'Wafer To Wafer Uniformity Spec Percent' ;
    rdfs:comment 'Maximum allowable variation in average material removal between wafers processed under this condition, expressed as a percentage. Ensures consistent lot-level processing.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withinWaferUniformitySpecPercent rdf:type rdf:Property ;
    rdfs:label 'Within Wafer Uniformity Spec Percent' ;
    rdfs:comment 'Maximum allowable variation in material removal across the wafer surface, expressed as a percentage. Calculated as (max - min) / (2 * mean) * 100. Critical for device performance uniformity.' ;
    rdfs:domain ind:CmpCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectInspectionResultId rdf:type rdf:Property ;
    rdfs:label 'Defect Inspection Result Id' ;
    rdfs:comment 'Unique identifier for the defect inspection result record. Primary key.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionRecipeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Recipe Id' ;
    rdfs:comment 'Identifier of the inspection recipe or program used to configure the tool for this inspection run. Defines sensitivity, scan area, and detection parameters.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recipe .

ind:lotProcessRunId rdf:type rdf:Property ;
    rdfs:label 'Lot Process Run Id' ;
    rdfs:comment 'FK to process.lot_process_run.lot_process_run_id — Defect inspection results are captured during or after a specific lot process run at an inspection step. This FK enables defect-to-process correlation.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotProcessRun .

ind:crystalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Crystal Defect Count' ;
    rdfs:comment 'Number of defects classified as crystal originated particles (COPs) or intrinsic silicon defects.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectDensityPerCm2 rdf:type rdf:Property ;
    rdfs:label 'Defect Density Per Cm2' ;
    rdfs:comment 'Calculated defect density expressed as defects per square centimeter of inspected wafer area. Key metric for process monitoring and Statistical Process Control (SPC).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectMapFileFormat rdf:type rdf:Property ;
    rdfs:label 'Defect Map File Format' ;
    rdfs:comment 'Format of the defect map file: KLARF (KLA Results File), CSV, XML, or proprietary vendor format.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectMapFilePath rdf:type rdf:Property ;
    rdfs:label 'Defect Map File Path' ;
    rdfs:comment 'File system path or URI to the defect map file (typically KLARF or proprietary format) containing spatial coordinates and attributes of all detected defects.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSizeBinLargeCount rdf:type rdf:Property ;
    rdfs:label 'Defect Size Bin Large Count' ;
    rdfs:comment 'Number of defects in the large size bin (typically > 0.5 µm or tool-specific threshold).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectSizeBinMediumCount rdf:type rdf:Property ;
    rdfs:label 'Defect Size Bin Medium Count' ;
    rdfs:comment 'Number of defects in the medium size bin (typically 0.1-0.5 µm or tool-specific threshold).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectSizeBinSmallCount rdf:type rdf:Property ;
    rdfs:label 'Defect Size Bin Small Count' ;
    rdfs:comment 'Number of defects in the small size bin (typically < 0.1 µm or tool-specific threshold).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionDetected rdf:type rdf:Property ;
    rdfs:label 'Excursion Detected' ;
    rdfs:comment 'Indicates whether a process excursion was detected based on defect density or count exceeding Statistical Process Control (SPC) limits.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectedAreaCm2 rdf:type rdf:Property ;
    rdfs:label 'Inspected Area Cm2' ;
    rdfs:comment 'Total wafer surface area inspected, measured in square centimeters. Used to calculate defect density.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionAtStep rdf:type rdf:Property ;
    rdfs:label 'Inspection At Step' ;
    rdfs:comment 'FK to process.process_process_step.process_process_step_id — Defect inspections occur at specific process steps in the flow. Step reference provides manufacturing context for defect analysis.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionMode rdf:type rdf:Property ;
    rdfs:label 'Inspection Mode' ;
    rdfs:comment 'Inspection coverage mode: full wafer scan, die sampling, edge exclusion, or hot spot targeted inspection.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Type of inspection technology used: brightfield scanner, darkfield scanner, e-beam inspection, optical inspection, or macro inspection.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:killerDefectCount rdf:type rdf:Property ;
    rdfs:label 'Killer Defect Count' ;
    rdfs:comment 'Number of defects classified as killer defects (defects large enough or critical enough to cause die failure).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nuisanceDefectCount rdf:type rdf:Property ;
    rdfs:label 'Nuisance Defect Count' ;
    rdfs:comment 'Number of defects classified as nuisance (false positives or non-yield-impacting detections filtered by nuisance filter).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nuisanceFilterApplied rdf:type rdf:Property ;
    rdfs:label 'Nuisance Filter Applied' ;
    rdfs:comment 'Indicates whether a nuisance filter was applied to remove false positives or non-critical defects from the reported count.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nuisanceFilterVersion rdf:type rdf:Property ;
    rdfs:label 'Nuisance Filter Version' ;
    rdfs:comment 'Version identifier of the nuisance filter algorithm or rule set applied during this inspection.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:particleDefectCount rdf:type rdf:Property ;
    rdfs:label 'Particle Defect Count' ;
    rdfs:comment 'Number of defects classified as particles (foreign material on wafer surface).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patternDefectCount rdf:type rdf:Property ;
    rdfs:label 'Pattern Defect Count' ;
    rdfs:comment 'Number of defects classified as pattern defects (lithography or etch anomalies in the circuit pattern).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residueDefectCount rdf:type rdf:Property ;
    rdfs:label 'Residue Defect Count' ;
    rdfs:comment 'Number of defects classified as residue (chemical or material residue remaining after processing).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewRequired rdf:type rdf:Property ;
    rdfs:label 'Review Required' ;
    rdfs:comment 'Indicates whether engineering review is required based on defect count, type, or pattern analysis.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scratchDefectCount rdf:type rdf:Property ;
    rdfs:label 'Scratch Defect Count' ;
    rdfs:comment 'Number of defects classified as scratches (linear surface damage).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spcControlLimitLower rdf:type rdf:Property ;
    rdfs:label 'Spc Control Limit Lower' ;
    rdfs:comment 'Lower control limit for defect density used in SPC monitoring.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spcControlLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Spc Control Limit Upper' ;
    rdfs:comment 'Upper control limit for defect density used in SPC monitoring. Excursions above this limit trigger alerts.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Total Defect Count' ;
    rdfs:comment 'Total number of defects detected on the wafer during this inspection, including all defect types and sizes.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depositionConditionId rdf:type rdf:Property ;
    rdfs:label 'Deposition Condition Id' ;
    rdfs:comment 'Unique identifier for the thin film deposition process condition record.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spcControlChartId rdf:type rdf:Property ;
    rdfs:label 'Spc Control Chart Id' ;
    rdfs:comment 'Reference to the SPC control plan defining monitoring strategy, control limits, and sampling frequency for this deposition condition.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpcControlChart .

ind:carrierGas rdf:type rdf:Property ;
    rdfs:label 'Carrier Gas' ;
    rdfs:comment 'Inert carrier gas used to transport precursors and maintain chamber environment (e.g., Ar, N2, He).' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierGasFlowRateSccm rdf:type rdf:Property ;
    rdfs:label 'Carrier Gas Flow Rate Sccm' ;
    rdfs:comment 'Flow rate of carrier gas in standard cubic centimeters per minute (sccm).' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Deposition Condition Description' ;
    rdfs:comment 'Detailed textual description of the deposition condition, including application notes, special considerations, and process intent.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositionMethod rdf:type rdf:Property ;
    rdfs:label 'Deposition Method' ;
    rdfs:comment 'Thin film deposition technique used: LPCVD (Low Pressure Chemical Vapor Deposition), PECVD (Plasma Enhanced Chemical Vapor Deposition), ALD (Atomic Layer Deposition), PVD (Physical Vapor Deposition), EPI (Epitaxial Growth), MOCVD (Metal Organic Chemical Vapor Deposition).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositionPressureTorr rdf:type rdf:Property ;
    rdfs:label 'Deposition Pressure Torr' ;
    rdfs:comment 'Process chamber pressure in Torr during deposition. Affects film density, step coverage, and deposition rate.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionRateAngstromPerMinute rdf:type rdf:Property ;
    rdfs:label 'Deposition Rate Angstrom Per Minute' ;
    rdfs:comment 'Target deposition rate in angstroms per minute. Key process control parameter affecting throughput and film quality.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Deposition Temperature Celsius' ;
    rdfs:comment 'Process chamber temperature in degrees Celsius during deposition. Critical parameter affecting film quality, stress, and conformality.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Deposition Time Seconds' ;
    rdfs:comment 'Total duration of the deposition step in seconds required to achieve target thickness.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filmStressMpa rdf:type rdf:Property ;
    rdfs:label 'Film Stress Mpa' ;
    rdfs:comment 'Intrinsic mechanical stress in the deposited film measured in megapascals (MPa). Positive values indicate tensile stress, negative values indicate compressive stress. Affects wafer bow and device reliability.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precursorGas1 rdf:type rdf:Property ;
    rdfs:label 'Precursor Gas 1' ;
    rdfs:comment 'Primary precursor gas or chemical reactant used in the deposition process (e.g., SiH4, TiCl4, WF6, TEOS).' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precursorGas1FlowRateSccm rdf:type rdf:Property ;
    rdfs:label 'Precursor Gas 1 Flow Rate Sccm' ;
    rdfs:comment 'Flow rate of primary precursor gas in standard cubic centimeters per minute (sccm). Controls deposition rate and film stoichiometry.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precursorGas2 rdf:type rdf:Property ;
    rdfs:label 'Precursor Gas 2' ;
    rdfs:comment 'Secondary precursor gas or reactant used in the deposition process (e.g., NH3, O2, N2, H2).' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precursorGas2FlowRateSccm rdf:type rdf:Property ;
    rdfs:label 'Precursor Gas 2 Flow Rate Sccm' ;
    rdfs:comment 'Flow rate of secondary precursor gas in standard cubic centimeters per minute (sccm).' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processCapabilityCpk rdf:type rdf:Property ;
    rdfs:label 'Process Capability Cpk' ;
    rdfs:comment 'Statistical process capability index (Cpk) for this deposition condition, measuring process centering and variation relative to specification limits. Target is typically ≥1.33 for production.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refractiveIndex rdf:type rdf:Property ;
    rdfs:label 'Refractive Index' ;
    rdfs:comment 'Optical refractive index of the deposited film at specified wavelength. Used for film characterization and thickness measurement via ellipsometry.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Rf Frequency Mhz' ;
    rdfs:comment 'Radio frequency in megahertz used for plasma generation (e.g., 13.56 MHz, 27.12 MHz).' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Step Coverage Percent' ;
    rdfs:comment 'Ratio of film thickness on vertical sidewalls to horizontal surfaces, expressed as percentage. Critical for via and trench filling in advanced nodes.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLayer rdf:type rdf:Property ;
    rdfs:label 'Target Layer' ;
    rdfs:comment 'Functional layer name in the device stack where material is deposited (e.g., gate oxide, barrier layer, metal1, via2, passivation).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThicknessAngstrom rdf:type rdf:Property ;
    rdfs:label 'Target Thickness Angstrom' ;
    rdfs:comment 'Specified target thickness of the deposited film in angstroms (Å). Critical for device electrical performance and process control.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thicknessToleranceAngstrom rdf:type rdf:Property ;
    rdfs:label 'Thickness Tolerance Angstrom' ;
    rdfs:comment 'Allowable deviation from target thickness in angstroms, defining the acceptable process window.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toolClass rdf:type rdf:Property ;
    rdfs:label 'Tool Class' ;
    rdfs:comment 'Equipment type or platform family qualified for this deposition condition (e.g., Applied Materials Centura, Lam Vector, Tokyo Electron Telius).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniformitySpecificationPercent rdf:type rdf:Property ;
    rdfs:label 'Uniformity Specification Percent' ;
    rdfs:comment 'Maximum allowable thickness non-uniformity across the wafer surface, expressed as percentage (e.g., ±2% 1-sigma). Critical for yield and device performance.' ;
    rdfs:domain ind:DepositionCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doeExperimentId rdf:type rdf:Property ;
    rdfs:label 'Doe Experiment Id' ;
    rdfs:comment 'Unique identifier for the DOE experiment record. Primary key for the DOE experiment entity.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analysisSoftware rdf:type rdf:Property ;
    rdfs:label 'Analysis Software' ;
    rdfs:comment 'Software tool or platform used for DOE design and statistical analysis (e.g., JMP, Minitab, Design-Expert, R, Python).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineCpk rdf:type rdf:Property ;
    rdfs:label 'Baseline Cpk' ;
    rdfs:comment 'Process capability index (Cpk) measured before the DOE experiment, serving as the baseline for comparison.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockingFactor rdf:type rdf:Property ;
    rdfs:label 'Blocking Factor' ;
    rdfs:comment 'Factor used to group experimental runs into blocks to control for known sources of variation (e.g., different lots, different days, different chambers).' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doeType rdf:type rdf:Property ;
    rdfs:label 'Doe Type' ;
    rdfs:comment 'Statistical design methodology used for the experiment. Full factorial explores all factor combinations; fractional factorial reduces runs; RSM optimizes response surfaces; Taguchi focuses on robustness; Plackett-Burman screens many factors efficiently; Central Composite designs for quadratic models.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentNumber rdf:type rdf:Property ;
    rdfs:label 'Experiment Number' ;
    rdfs:comment 'Business identifier for the DOE experiment, typically a human-readable code used for tracking and reference across engineering teams.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentObjective rdf:type rdf:Property ;
    rdfs:label 'Experiment Objective' ;
    rdfs:comment 'Detailed description of the business and technical objectives of the DOE experiment, including the problem statement, hypothesis, and expected outcomes.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentStatus rdf:type rdf:Property ;
    rdfs:label 'Experiment Status' ;
    rdfs:comment 'Current lifecycle status of the DOE experiment. Tracks progression from planning through execution to completion. [ENUM-REF-CANDIDATE: planned|in_progress|data_collection|analysis|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentTitle rdf:type rdf:Property ;
    rdfs:label 'Experiment Title' ;
    rdfs:comment 'Descriptive title of the DOE experiment that summarizes the objective and scope of the study.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorCount rdf:type rdf:Property ;
    rdfs:label 'Factor Count' ;
    rdfs:comment 'Number of independent variables (factors) being studied in the DOE experiment. Each factor represents a process parameter that may influence the response variables.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:factorLevels rdf:type rdf:Property ;
    rdfs:label 'Factor Levels' ;
    rdfs:comment 'Description of the levels (values) tested for each factor in the experiment. Typically includes low, medium, and high settings or specific numerical values.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorList rdf:type rdf:Property ;
    rdfs:label 'Factor List' ;
    rdfs:comment 'Comma-separated list of factors (independent variables) being studied, such as temperature, pressure, dose, time, gas flow rate, power, etc.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionEffects rdf:type rdf:Property ;
    rdfs:label 'Interaction Effects' ;
    rdfs:comment 'Description of any significant interaction effects between factors, where the effect of one factor depends on the level of another factor.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyFindings rdf:type rdf:Property ;
    rdfs:label 'Key Findings' ;
    rdfs:comment 'Summary of the main conclusions from the DOE experiment, including significant factors, interactions, optimal settings, and process insights.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postDoeCpk rdf:type rdf:Property ;
    rdfs:label 'Post Doe Cpk' ;
    rdfs:comment 'Process capability index (Cpk) measured after implementing the DOE recommendations, demonstrating the improvement achieved.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryResponseVariable rdf:type rdf:Property ;
    rdfs:label 'Primary Response Variable' ;
    rdfs:comment 'The main response variable of interest for optimization or characterization in this DOE experiment.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCapabilityImprovement rdf:type rdf:Property ;
    rdfs:label 'Process Capability Improvement' ;
    rdfs:comment 'Quantitative or qualitative assessment of process capability improvement achieved through the DOE experiment, such as Cpk improvement, defect reduction, or yield enhancement.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processWindowLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Process Window Lower Limit' ;
    rdfs:comment 'Lower boundary of the acceptable process window for key factors, defining the range within which the process remains stable and meets specifications.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processWindowUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Process Window Upper Limit' ;
    rdfs:comment 'Upper boundary of the acceptable process window for key factors, defining the range within which the process remains stable and meets specifications.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedSetpoints rdf:type rdf:Property ;
    rdfs:label 'Recommended Setpoints' ;
    rdfs:comment 'Optimal or recommended process parameter settings derived from the DOE analysis to achieve desired response variable targets.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationCount rdf:type rdf:Property ;
    rdfs:label 'Replication Count' ;
    rdfs:comment 'Number of times each experimental condition is replicated to assess measurement variability and improve statistical power.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseVariableCount rdf:type rdf:Property ;
    rdfs:label 'Response Variable Count' ;
    rdfs:comment 'Number of dependent variables (responses) being measured in the DOE experiment. Response variables are the outcomes being optimized or characterized.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseVariableList rdf:type rdf:Property ;
    rdfs:label 'Response Variable List' ;
    rdfs:comment 'Comma-separated list of response variables being measured, such as Critical Dimension (CD), uniformity, defect density, yield, thickness, etch rate, etc.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCount rdf:type rdf:Property ;
    rdfs:label 'Run Count' ;
    rdfs:comment 'Total number of experimental runs (treatment combinations) planned or executed in the DOE study.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runOrderStrategy rdf:type rdf:Property ;
    rdfs:label 'Run Order Strategy' ;
    rdfs:comment 'Strategy used to sequence experimental runs. Randomization minimizes bias; blocking controls for known sources of variation; center point replication assesses curvature and repeatability.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significantFactors rdf:type rdf:Property ;
    rdfs:label 'Significant Factors' ;
    rdfs:comment 'List of factors that were statistically significant in affecting the response variables, based on the analysis results.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Statistical Analysis Method' ;
    rdfs:comment 'Statistical techniques applied to analyze the DOE results, such as ANOVA, regression analysis, main effects plots, interaction plots, contour plots, or optimization algorithms.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferSplitPlan rdf:type rdf:Property ;
    rdfs:label 'Wafer Split Plan' ;
    rdfs:comment 'Description of how wafers are allocated across different experimental conditions, including split assignments, replication strategy, and randomization approach.' ;
    rdfs:domain ind:DoeExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etchConditionId rdf:type rdf:Property ;
    rdfs:label 'Etch Condition Id' ;
    rdfs:comment 'Unique identifier for the etch process condition master record. Primary key for the etch condition entity.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationScope rdf:type rdf:Property ;
    rdfs:label 'Application Scope' ;
    rdfs:comment 'Description of the intended application scope or use case for this etch condition (e.g., high aspect ratio contact etch, metal gate patterning, shallow trench isolation).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chamberPressureTorr rdf:type rdf:Property ;
    rdfs:label 'Chamber Pressure Torr' ;
    rdfs:comment 'Operating pressure inside the etch chamber measured in Torr. Critical parameter for plasma density and etch uniformity control.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalDimensionBiasNm rdf:type rdf:Property ;
    rdfs:label 'Critical Dimension Bias Nm' ;
    rdfs:comment 'Expected change in critical dimension (CD) due to the etch process in nanometers. Positive value indicates CD growth, negative indicates CD shrinkage. Used for Optical Proximity Correction (OPC) and Design for Manufacturability (DFM).' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchMethod rdf:type rdf:Property ;
    rdfs:label 'Etch Method' ;
    rdfs:comment 'Specific etch method or technology used. For dry etch: Reactive Ion Etch (RIE), Inductively Coupled Plasma (ICP), Capacitively Coupled Plasma (CCP). For wet etch: immersion or spray.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etchRateAngstromPerMinute rdf:type rdf:Property ;
    rdfs:label 'Etch Rate Angstrom Per Minute' ;
    rdfs:comment 'Target etch rate for the primary material in angstroms per minute. Key process parameter for throughput and uniformity control.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Etch Time Seconds' ;
    rdfs:comment 'Duration of the etch process in seconds. May be time-based or endpoint-detection-based depending on the process control strategy.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchType rdf:type rdf:Property ;
    rdfs:label 'Etch Type' ;
    rdfs:comment 'Classification of the etch process as either dry etch (plasma-based: RIE, ICP, CCP) or wet etch (chemical immersion).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etchantChemistry rdf:type rdf:Property ;
    rdfs:label 'Etchant Chemistry' ;
    rdfs:comment 'The chemical composition of the etchant used. For dry etch: gas mixture (e.g., CF4/O2, SF6/O2, Cl2/BCl3). For wet etch: liquid chemistry (e.g., HF, BOE, H3PO4).' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overEtchPercent rdf:type rdf:Property ;
    rdfs:label 'Over Etch Percent' ;
    rdfs:comment 'Percentage of additional etch time beyond endpoint detection to ensure complete material removal. Expressed as a percentage of the main etch time.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryGasFlowSccm rdf:type rdf:Property ;
    rdfs:label 'Primary Gas Flow Sccm' ;
    rdfs:comment 'Flow rate of the primary etch gas in standard cubic centimeters per minute (SCCM). Applicable to dry etch processes.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Profile Angle Degrees' ;
    rdfs:comment 'Target sidewall angle of the etched feature in degrees from vertical. 90 degrees indicates perfectly vertical (anisotropic) etch. Critical for device performance and yield.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfBiasPowerWatts rdf:type rdf:Property ;
    rdfs:label 'Rf Bias Power Watts' ;
    rdfs:comment 'RF power applied to the substrate electrode (bias power) in watts. Controls ion energy and directionality for anisotropic etching.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfSourcePowerWatts rdf:type rdf:Property ;
    rdfs:label 'Rf Source Power Watts' ;
    rdfs:comment 'RF power applied to the plasma source coil or electrode in watts. Controls plasma density and etch rate in ICP and CCP systems.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryGasFlowSccm rdf:type rdf:Property ;
    rdfs:label 'Secondary Gas Flow Sccm' ;
    rdfs:comment 'Flow rate of the secondary or carrier gas in standard cubic centimeters per minute (SCCM). Used for process tuning and selectivity control.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substrateTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Substrate Temperature Celsius' ;
    rdfs:comment 'Temperature of the wafer substrate during the etch process in degrees Celsius. Affects etch rate, selectivity, and profile control.' ;
    rdfs:domain ind:EtchCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCdNm rdf:type rdf:Property ;
    rdfs:label 'Target Cd Nm' ;
    rdfs:comment 'Target critical dimension after etch in nanometers. Defines the intended feature size for the etched structure.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantConditionId rdf:type rdf:Property ;
    rdfs:label 'Implant Condition Id' ;
    rdfs:comment 'Unique identifier for the ion implantation process condition master record. Primary key for the implant condition entity.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annealRecipeId rdf:type rdf:Property ;
    rdfs:label 'Anneal Recipe Id' ;
    rdfs:comment 'Reference to the thermal anneal recipe applied after implantation to activate dopants and repair crystal damage. Critical for electrical junction formation.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recipe .

ind:annealTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Anneal Temperature Celsius' ;
    rdfs:comment 'Peak temperature of the post-implant anneal process in degrees Celsius. Typical range: 400°C to 1100°C depending on anneal type and dopant activation requirements.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annealTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Anneal Time Seconds' ;
    rdfs:comment 'Duration of the anneal process at peak temperature, measured in seconds. RTA processes are typically 1-60 seconds, while furnace anneals may be minutes to hours.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annealType rdf:type rdf:Property ;
    rdfs:label 'Anneal Type' ;
    rdfs:comment 'Type of thermal anneal process used for dopant activation. RTA (Rapid Thermal Anneal), furnace anneal, spike anneal, laser anneal, or flash anneal. Each has different thermal budget characteristics.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beamCurrentMa rdf:type rdf:Property ;
    rdfs:label 'Beam Current Ma' ;
    rdfs:comment 'Ion beam current in milliamperes (mA). Determines the implantation rate and throughput. Higher beam currents enable faster processing but may increase wafer heating.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dopantSpecies rdf:type rdf:Property ;
    rdfs:label 'Dopant Species' ;
    rdfs:comment 'Chemical element or compound used for ion implantation. Common species include boron (p-type), phosphorus and arsenic (n-type), BF2 (boron difluoride for shallow junctions), and specialty dopants. [ENUM-REF-CANDIDATE: boron|phosphorus|arsenic|antimony|indium|bf2|germanium|silicon|nitrogen|carbon — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implantConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Implant Condition Description' ;
    rdfs:comment 'Detailed textual description of this implant condition, including its purpose, special considerations, and any process integration notes.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implantDoseIonsPerCm2 rdf:type rdf:Property ;
    rdfs:label 'Implant Dose Ions Per Cm2' ;
    rdfs:comment 'Total number of ions implanted per square centimeter of wafer surface. Expressed in scientific notation (e.g., 1.0E15 ions/cm²). Controls the dopant concentration.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantLayerName rdf:type rdf:Property ;
    rdfs:label 'Implant Layer Name' ;
    rdfs:comment 'Name of the device layer being implanted (e.g., PWELL, NWELL, LDD, HDD, VT_ADJUST). Identifies the target region in the device structure.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implantPurpose rdf:type rdf:Property ;
    rdfs:label 'Implant Purpose' ;
    rdfs:comment 'Functional purpose of this implant step in the device structure. Examples: well formation, threshold voltage adjustment, lightly-doped drain (LDD), heavily-doped drain (HDD), source/drain, halo/pocket implants, or isolation. [ENUM-REF-CANDIDATE: well|vt_adjust|ldd|hdd|source_drain|halo|pocket|channel_stop|field_implant — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implantToolClass rdf:type rdf:Property ;
    rdfs:label 'Implant Tool Class' ;
    rdfs:comment 'Classification of ion implanter equipment type required for this condition. Different tool classes are optimized for specific energy and dose ranges.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implantToolModel rdf:type rdf:Property ;
    rdfs:label 'Implant Tool Model' ;
    rdfs:comment 'Specific model or type of ion implanter equipment qualified for this condition (e.g., Applied Materials Quantum X, Axcelis Purion).' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processWindowDoseTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Process Window Dose Tolerance Percent' ;
    rdfs:comment 'Allowable variation in implant dose as a percentage of target dose, defining the process window for dose control. Typical values: ±1% to ±5%.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processWindowEnergyTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Process Window Energy Tolerance Percent' ;
    rdfs:comment 'Allowable variation in implant energy as a percentage of target energy, defining the process window for energy control. Typical values: ±1% to ±3%.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresPreAmorphization rdf:type rdf:Property ;
    rdfs:label 'Requires Pre Amorphization' ;
    rdfs:comment 'Boolean flag indicating whether a pre-amorphization implant (typically germanium or silicon) is required before the main dopant implant to reduce channeling effects.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetJunctionDepthNm rdf:type rdf:Property ;
    rdfs:label 'Target Junction Depth Nm' ;
    rdfs:comment 'Intended electrical junction depth in nanometers after implant and anneal. Critical specification for transistor performance and short-channel effect control.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSheetResistanceOhmsPerSq rdf:type rdf:Property ;
    rdfs:label 'Target Sheet Resistance Ohms Per Sq' ;
    rdfs:comment 'Target electrical sheet resistance in ohms per square after implant and anneal. Key electrical parameter for verifying dopant activation and concentration.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetThresholdVoltageMv rdf:type rdf:Property ;
    rdfs:label 'Target Threshold Voltage Mv' ;
    rdfs:comment 'Target transistor threshold voltage in millivolts that this implant condition is designed to achieve. Critical for device performance and power consumption.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tiltAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Tilt Angle Degrees' ;
    rdfs:comment 'Angle of wafer tilt relative to the ion beam axis, measured in degrees. Used to control channeling effects and implant profile symmetry. Typical range: 0° to 7°.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twistAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Twist Angle Degrees' ;
    rdfs:comment 'Rotational angle of the wafer around its normal axis during implantation, measured in degrees. Used in conjunction with tilt angle to optimize implant uniformity. Typical range: 0° to 360°.' ;
    rdfs:domain ind:ImplantCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithoConditionId rdf:type rdf:Property ;
    rdfs:label 'Litho Condition Id' ;
    rdfs:comment 'Unique identifier for the photolithography process condition master record.' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opcRuleSetId rdf:type rdf:Property ;
    rdfs:label 'Opc Rule Set Id' ;
    rdfs:comment 'Reference to the OPC rule set used to correct mask patterns for optical proximity effects at this lithography condition.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpcRuleSet .

ind:cdToleranceNm rdf:type rdf:Property ;
    rdfs:label 'Cd Tolerance Nm' ;
    rdfs:comment 'Allowable tolerance range for critical dimension variation in nanometers.' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depthOfFocusNm rdf:type rdf:Property ;
    rdfs:label 'Depth Of Focus Nm' ;
    rdfs:comment 'Depth of focus in nanometers, representing the range over which acceptable image quality is maintained.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developProcessType rdf:type rdf:Property ;
    rdfs:label 'Develop Process Type' ;
    rdfs:comment 'Method used for resist development (e.g., puddle, spray, immersion).' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Develop Time Seconds' ;
    rdfs:comment 'Duration in seconds for the resist development step.' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureLatitudePercent rdf:type rdf:Property ;
    rdfs:label 'Exposure Latitude Percent' ;
    rdfs:comment 'Exposure latitude as a percentage, indicating the allowable variation in exposure dose while maintaining acceptable CD control.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardBakeTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Hard Bake Temperature C' ;
    rdfs:comment 'Temperature in Celsius for the hard bake step performed after development to stabilize the resist pattern.' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardBakeTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Hard Bake Time Seconds' ;
    rdfs:comment 'Duration in seconds for the hard bake step.' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:illuminationMode rdf:type rdf:Property ;
    rdfs:label 'Illumination Mode' ;
    rdfs:comment 'Off-axis illumination mode used to enhance resolution and process window (e.g., dipole, quadrupole, freeform).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiPatterningType rdf:type rdf:Property ;
    rdfs:label 'Multi Patterning Type' ;
    rdfs:comment 'Multi-patterning technique used: none, LELE (Litho-Etch-Litho-Etch), SADP (Self-Aligned Double Patterning), SAQP (Self-Aligned Quadruple Patterning), or EUV single exposure.' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numericalAperture rdf:type rdf:Property ;
    rdfs:label 'Numerical Aperture' ;
    rdfs:comment 'Numerical aperture of the scanner lens system, determining resolution capability (e.g., 0.33 for EUV, 1.35 for immersion DUV).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overlayToleranceNm rdf:type rdf:Property ;
    rdfs:label 'Overlay Tolerance Nm' ;
    rdfs:comment 'Maximum allowable overlay error in nanometers between this layer and previous layers.' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postExposureBakeTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Post Exposure Bake Temperature C' ;
    rdfs:comment 'Temperature in Celsius for the post-exposure bake step, critical for chemically amplified resists.' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postExposureBakeTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Post Exposure Bake Time Seconds' ;
    rdfs:comment 'Duration in seconds for the post-exposure bake step.' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resistThicknessNm rdf:type rdf:Property ;
    rdfs:label 'Resist Thickness Nm' ;
    rdfs:comment 'Target thickness of the photoresist coating in nanometers.' ;
    rdfs:domain ind:LithoCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resistType rdf:type rdf:Property ;
    rdfs:label 'Resist Type' ;
    rdfs:comment 'Type or brand of photoresist material used (e.g., chemically amplified resist, metal oxide resist for EUV).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sigmaInner rdf:type rdf:Property ;
    rdfs:label 'Sigma Inner' ;
    rdfs:comment 'Inner sigma value defining the inner radius of the illumination pupil, used for off-axis illumination optimization.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sigmaOuter rdf:type rdf:Property ;
    rdfs:label 'Sigma Outer' ;
    rdfs:comment 'Outer sigma value defining the outer radius of the illumination pupil, used for off-axis illumination optimization.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wavelengthNm rdf:type rdf:Property ;
    rdfs:label 'Wavelength Nm' ;
    rdfs:comment 'Exposure wavelength in nanometers (e.g., 13.5 for EUV, 193 for ArF DUV, 248 for KrF DUV).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotRecipeId rdf:type rdf:Property ;
    rdfs:label 'Lot Recipe Id' ;
    rdfs:comment 'Reference to the actual recipe executed for this process step. May differ from the planned recipe if engineering overrides or recipe revisions occurred. Links to the recipe master in the fabrication domain.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recipe .

ind:shiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Id' ;
    rdfs:comment 'Foreign key linking to workforce.shift_schedule. Business justification: Labor costing and compliance audits require linking each lot run to the shift schedule that covered it.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSchedule .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the lot processing completed on the equipment. Used to calculate actual process duration and equipment throughput.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the lot processing began on the equipment. Captured from MES equipment interface for cycle time analysis and equipment utilization tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controlChartRuleViolated rdf:type rdf:Property ;
    rdfs:label 'Control Chart Rule Violated' ;
    rdfs:comment 'Specific SPC rule violated if control_chart_violation_flag is true (e.g., \'Western Electric Rule 1: Point beyond 3-sigma\', \'Nelson Rule 2: Nine points in a row on same side of centerline\'). Null if no violation.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChartViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Control Chart Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this process run violated SPC control chart rules (e.g., out-of-control limits, run rules, trend rules). True indicates a violation requiring engineering investigation.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementResultValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Result Value' ;
    rdfs:comment 'Primary in-line measurement result collected at this process step (e.g., film thickness, CD (Critical Dimension), overlay, resistivity). The specific measurement type is defined by the process step. Used for real-time SPC and process control.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementSiteCount rdf:type rdf:Property ;
    rdfs:label 'Measurement Site Count' ;
    rdfs:comment 'Number of measurement sites sampled on the wafer(s) for this in-line measurement. Used to assess measurement sampling adequacy and statistical confidence.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processGasFlowSccm rdf:type rdf:Property ;
    rdfs:label 'Process Gas Flow Sccm' ;
    rdfs:comment 'Total process gas flow rate in standard cubic centimeters per minute (SCCM) for this run. Aggregated flow for multi-gas processes; individual gas flows tracked in separate metrology records.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processNotes rdf:type rdf:Property ;
    rdfs:label 'Process Notes' ;
    rdfs:comment 'Free-text notes entered by the operator or process engineer documenting any anomalies, deviations, or special conditions during this process run. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processPowerWatts rdf:type rdf:Property ;
    rdfs:label 'Process Power Watts' ;
    rdfs:comment 'Actual RF or DC power in watts applied during this process run. Key parameter for plasma-based processes including etch, PVD, and PECVD (Plasma-Enhanced Chemical Vapor Deposition).' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Process Qualification Status' ;
    rdfs:comment 'Qualification status of the process step execution. Qualified indicates the process met all capability and stability requirements; not_qualified indicates process failed qualification criteria; pending_qualification indicates qualification in progress; requalification_required indicates process drift detected requiring re-qualification.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Process Temperature C' ;
    rdfs:comment 'Actual process temperature in degrees Celsius recorded during this run. Key process parameter for thermal processes such as CVD (Chemical Vapor Deposition), diffusion, annealing, and oxidation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meefParameterId rdf:type rdf:Property ;
    rdfs:label 'Meef Parameter Id' ;
    rdfs:comment 'Unique identifier for the MEEF parameter record. Primary key for this entity.' ;
    rdfs:domain ind:MeefParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferLotId rdf:type rdf:Property ;
    rdfs:label 'Wafer Lot Id' ;
    rdfs:comment 'Reference to the wafer lot used for MEEF characterization experiments.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:cdTargetNm rdf:type rdf:Property ;
    rdfs:label 'Cd Target Nm' ;
    rdfs:comment 'Target critical dimension in nanometers for the feature at wafer level.' ;
    rdfs:domain ind:MeefParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureType rdf:type rdf:Property ;
    rdfs:label 'Feature Type' ;
    rdfs:comment 'Type of lithographic feature being characterized (line, space, contact, via, trench, island).' ;
    rdfs:domain ind:MeefParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskCdTargetNm rdf:type rdf:Property ;
    rdfs:label 'Mask Cd Target Nm' ;
    rdfs:comment 'Target critical dimension on the photomask in nanometers (at 4X or 5X magnification).' ;
    rdfs:domain ind:MeefParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maskCdToleranceNm rdf:type rdf:Property ;
    rdfs:label 'Mask Cd Tolerance Nm' ;
    rdfs:comment 'Allowable tolerance for mask CD in nanometers, derived from MEEF and wafer CD specifications.' ;
    rdfs:domain ind:MeefParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'Date when the MEEF measurement was performed.' ;
    rdfs:domain ind:MeefParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementTool rdf:type rdf:Property ;
    rdfs:label 'Measurement Tool' ;
    rdfs:comment 'Specific metrology tool or equipment used to characterize the MEEF parameter.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchNm rdf:type rdf:Property ;
    rdfs:label 'Pitch Nm' ;
    rdfs:comment 'The pitch (center-to-center spacing) of the feature in nanometers at which the MEEF was measured.' ;
    rdfs:domain ind:MeefParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processCondition rdf:type rdf:Property ;
    rdfs:label 'Process Condition' ;
    rdfs:comment 'Description of the specific process conditions (resist type, bake temperatures, development time) under which MEEF was characterized.' ;
    rdfs:domain ind:MeefParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processWindowScore rdf:type rdf:Property ;
    rdfs:label 'Process Window Score' ;
    rdfs:comment 'Composite score representing the overall process window quality, combining DOF and exposure latitude metrics.' ;
    rdfs:domain ind:MeefParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processMetrologyMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Process Metrology Measurement Id' ;
    rdfs:comment 'Unique identifier for the metrology_measurement data product.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metrologyMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Metrology Measurement Id' ;
    rdfs:comment 'Unique identifier for the metrology measurement record.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityMetrologyMeasurement .

ind:cpValue rdf:type rdf:Property ;
    rdfs:label 'Cp Value' ;
    rdfs:comment 'Process capability index (Cp) calculated from this measurement, indicating the potential capability of the process without considering centering.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpkValue rdf:type rdf:Property ;
    rdfs:label 'Cpk Value' ;
    rdfs:comment 'Process capability index (Cpk) calculated from this measurement, indicating how well the process is centered and controlled within specification limits.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Flag indicating the quality and reliability of the measurement data. Good indicates reliable data, Suspect indicates questionable data, Bad indicates invalid data, Uncalibrated indicates tool calibration issue.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'Lower control limit for Statistical Process Control (SPC) monitoring. Values below this trigger investigation.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Spec Limit' ;
    rdfs:comment 'Lower specification limit for this measurement parameter. Values below this threshold fail specification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxValue rdf:type rdf:Property ;
    rdfs:label 'Max Value' ;
    rdfs:comment 'Maximum measured value across all sites on the wafer.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementParameter rdf:type rdf:Property ;
    rdfs:label 'Measurement Parameter' ;
    rdfs:comment 'Specific physical parameter being measured (e.g., critical dimension, overlay X/Y, film thickness, resistivity, reflectivity).' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Status of the measurement execution. Completed indicates successful measurement, In Progress indicates measurement underway, Failed indicates measurement error, Aborted indicates user-terminated, Pending indicates queued.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medianValue rdf:type rdf:Property ;
    rdfs:label 'Median Value' ;
    rdfs:comment 'Median value of all site measurements for this parameter.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metrologyAtStep rdf:type rdf:Property ;
    rdfs:label 'Metrology At Step' ;
    rdfs:comment 'FK to process.process_process_step.process_process_step_id — Metrology measurements are taken at specific process steps. Step context is essential for measurement interpretation and SPC feeding.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minValue rdf:type rdf:Property ;
    rdfs:label 'Min Value' ;
    rdfs:comment 'Minimum measured value across all sites on the wafer.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rangeValue rdf:type rdf:Property ;
    rdfs:label 'Range Value' ;
    rdfs:comment 'Difference between maximum and minimum site measurements (max - min).' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteCount rdf:type rdf:Property ;
    rdfs:label 'Site Count' ;
    rdfs:comment 'Total number of measurement sites sampled on the wafer.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stdDeviation rdf:type rdf:Property ;
    rdfs:label 'Std Deviation' ;
    rdfs:comment 'Standard deviation (1-sigma) of the site measurements, indicating within-wafer uniformity.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:threeSigma rdf:type rdf:Property ;
    rdfs:label 'Three Sigma' ;
    rdfs:comment 'Three times the standard deviation, representing the process variation range.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uniformityPercent rdf:type rdf:Property ;
    rdfs:label 'Uniformity Percent' ;
    rdfs:comment 'Within-wafer uniformity expressed as a percentage, calculated as (range / mean) * 100 or (3-sigma / mean) * 100 depending on convention.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'Upper control limit for Statistical Process Control (SPC) monitoring. Values above this trigger investigation.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Spec Limit' ;
    rdfs:comment 'Upper specification limit for this measurement parameter. Values above this threshold fail specification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferSlotNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Slot Number' ;
    rdfs:comment 'Position of the wafer within the lot carrier or cassette.' ;
    rdfs:domain ind:ProcessMetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ocapActionId rdf:type rdf:Property ;
    rdfs:label 'Ocap Action Id' ;
    rdfs:comment 'Unique identifier for the OCAP action record triggered by an SPC rule violation or process excursion event.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ocapSpcControlChartId rdf:type rdf:Property ;
    rdfs:label 'Ocap Spc Control Chart Id' ;
    rdfs:comment 'Reference to the SPC control chart that triggered this OCAP action due to a rule violation or out-of-control condition.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpcControlChart .

ind:primaryOcapEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ocap Employee Id' ;
    rdfs:comment 'Reference to the process engineer or quality engineer assigned to investigate and resolve the OCAP action.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySpcControlChartId rdf:type rdf:Property ;
    rdfs:label 'Primary Spc Control Chart Id' ;
    rdfs:comment 'FK to process.spc_control_chart.spc_control_chart_id — OCAP actions are triggered by SPC rule violations on a specific control chart. This FK enables traceability from corrective action back to the triggering monitoring event.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpcControlChart .

ind:spcMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Spc Measurement Id' ;
    rdfs:comment 'FK to process.spc_measurement.spc_measurement_id — OCAP actions are triggered by specific SPC rule violations on measurements. This link connects the corrective action to its triggering event.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpcMeasurement .

ind:tertiaryOcapAssignedEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Ocap Assigned Engineer Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Completed Timestamp' ;
    rdfs:comment 'Date and time when the OCAP action was completed and the process excursion was resolved.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Initiated Timestamp' ;
    rdfs:comment 'Date and time when the OCAP action was formally initiated in response to the detected excursion.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Type of corrective action taken in response to the SPC excursion. Defines the immediate response workflow per OCAP procedure. [ENUM-REF-CANDIDATE: hold_lot|notify_engineer|adjust_recipe|escalate|rework|scrap|continue_with_monitoring|equipment_maintenance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOrganization rdf:type rdf:Property ;
    rdfs:label 'Assigned Organization' ;
    rdfs:comment 'Organizational unit or department responsible for executing the OCAP action (e.g., Process Engineering, Quality Assurance, Equipment Engineering).' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Final notes and comments documenting the closure of the OCAP action, including lessons learned and recommendations for process improvement.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentActionFlag rdf:type rdf:Property ;
    rdfs:label 'Containment Action Flag' ;
    rdfs:comment 'Boolean flag indicating whether immediate containment actions were taken to prevent further processing of potentially defective material.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective actions taken to address the root cause and prevent recurrence of the process excursion.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date when the customer was notified about the process excursion and its potential impact on product quality.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether customer notification is required due to the potential impact of the excursion on delivered product quality.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether the OCAP action required escalation to senior engineering or management due to severity or complexity.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excursionSeverity rdf:type rdf:Property ;
    rdfs:label 'Excursion Severity' ;
    rdfs:comment 'Severity classification of the process excursion based on the magnitude of deviation from control limits and potential impact on product quality.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocapProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Ocap Procedure Reference' ;
    rdfs:comment 'Reference number or identifier of the documented OCAP procedure that defines the corrective response workflow for this type of excursion.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocapRespondsToExcursion rdf:type rdf:Property ;
    rdfs:label 'Ocap Responds To Excursion' ;
    rdfs:comment 'FK to process.process_excursion.process_excursion_id — OCAP actions are triggered by excursions/SPC violations. This link connects the corrective action to its triggering event for audit trail and effectiveness tracking.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Detailed description of preventive actions implemented to reduce the likelihood of similar excursions occurring in the future.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from excursion detection to OCAP action completion. Key metric for evaluating effectiveness of corrective response.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Time Minutes' ;
    rdfs:comment 'Elapsed time in minutes from excursion detection to OCAP action initiation. Key metric for evaluating responsiveness of the quality control system.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rootCauseClassification rdf:type rdf:Property ;
    rdfs:label 'Root Cause Classification' ;
    rdfs:comment 'High-level classification of the root cause identified during OCAP investigation (e.g., equipment drift, recipe deviation, material variation). [ENUM-REF-CANDIDATE: equipment_drift|recipe_deviation|material_variation|operator_error|environmental_factor|measurement_error|unknown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcRuleViolated rdf:type rdf:Property ;
    rdfs:label 'Spc Rule Violated' ;
    rdfs:comment 'Specific SPC rule that was violated and triggered the OCAP action (e.g., Western Electric Rule 1, Rule 2, Nelson Rule 1-8).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the effectiveness of the corrective action (e.g., SPC monitoring, metrology inspection, yield analysis).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationResult rdf:type rdf:Property ;
    rdfs:label 'Verification Result' ;
    rdfs:comment 'Result of the verification activity confirming whether the corrective action successfully resolved the process excursion.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Date and time when the effectiveness of the corrective action was verified.' ;
    rdfs:domain ind:OcapAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assistFeatureRules rdf:type rdf:Property ;
    rdfs:label 'Assist Feature Rules' ;
    rdfs:comment 'Description or reference to the sub-resolution assist feature (SRAF) placement rules included in this OPC rule set.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edaToolName rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Name' ;
    rdfs:comment 'Name of the specific EDA tool product used for OPC processing (e.g., Proteus, Calibre nmOPC).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edaToolVendor rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Vendor' ;
    rdfs:comment 'Vendor of the EDA tool used to generate and apply this OPC rule set (e.g., Synopsys, Cadence, Mentor Graphics).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lithographyWavelengthNm rdf:type rdf:Property ;
    rdfs:label 'Lithography Wavelength Nm' ;
    rdfs:comment 'Wavelength of the lithography exposure light in nanometers (e.g., 193 for DUV, 13.5 for EUV).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meefFeatureType rdf:type rdf:Property ;
    rdfs:label 'Meef Feature Type' ;
    rdfs:comment 'Type of feature for which the MEEF value was characterized (e.g., line, space, contact, via, dense, isolated).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meefMeasurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Meef Measurement Methodology' ;
    rdfs:comment 'Methodology used to measure and characterize MEEF (e.g., wafer metrology, simulation, focus-exposure matrix).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meefPitchNm rdf:type rdf:Property ;
    rdfs:label 'Meef Pitch Nm' ;
    rdfs:comment 'Feature pitch in nanometers at which the MEEF value was measured.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meefTargetCdNm rdf:type rdf:Property ;
    rdfs:label 'Meef Target Cd Nm' ;
    rdfs:comment 'Target critical dimension in nanometers for the MEEF characterization measurement.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opcForNode rdf:type rdf:Property ;
    rdfs:label 'Opc For Node' ;
    rdfs:comment 'FK to process.process_technology_node.process_technology_node_id — OPC rule sets are defined per technology node and layer. Node reference is essential for OPC management.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opcModelType rdf:type rdf:Property ;
    rdfs:label 'Opc Model Type' ;
    rdfs:comment 'Type of OPC correction methodology employed in this rule set.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processBiasTableReference rdf:type rdf:Property ;
    rdfs:label 'Process Bias Table Reference' ;
    rdfs:comment 'Reference identifier to the process bias lookup tables used for CD correction in this OPC rule set.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processWindowDofNm rdf:type rdf:Property ;
    rdfs:label 'Process Window Dof Nm' ;
    rdfs:comment 'Depth of focus in nanometers defining the usable focus range for this OPC rule set and layer.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processWindowElPercent rdf:type rdf:Property ;
    rdfs:label 'Process Window El Percent' ;
    rdfs:comment 'Exposure latitude as a percentage defining the usable dose range for this OPC rule set and layer.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleSetFileFormat rdf:type rdf:Property ;
    rdfs:label 'Rule Set File Format' ;
    rdfs:comment 'File format of the OPC rule set (e.g., proprietary Synopsys format, Cadence format, industry standard).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetFilePath rdf:type rdf:Property ;
    rdfs:label 'Rule Set File Path' ;
    rdfs:comment 'File system path or repository location of the OPC rule set file used by EDA tools (Synopsys, Cadence).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Set Version' ;
    rdfs:comment 'Version identifier for this OPC rule set, tracking revisions and updates to the correction algorithms.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scannerNumericalAperture rdf:type rdf:Property ;
    rdfs:label 'Scanner Numerical Aperture' ;
    rdfs:comment 'Numerical aperture of the lithography scanner lens system, defining the light-gathering capability and resolution.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capabilityId rdf:type rdf:Property ;
    rdfs:label 'Capability Id' ;
    rdfs:comment 'Unique identifier for the process capability record.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Capability Status' ;
    rdfs:comment 'Overall assessment of process capability status based on Cpk threshold criteria. Typically capable (Cpk >= 1.33), marginal (1.0 <= Cpk < 1.33), incapable (Cpk < 1.0).' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChartType rdf:type rdf:Property ;
    rdfs:label 'Control Chart Type' ;
    rdfs:comment 'Type of Statistical Process Control (SPC) control chart used for monitoring this parameter (e.g., X-bar R, X-bar S, Individuals, P-chart, C-chart, U-chart).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpIndex rdf:type rdf:Property ;
    rdfs:label 'Cp Index' ;
    rdfs:comment 'Process capability index Cp measuring the potential capability of the process assuming it is centered on target. Calculated as (USL - LSL) / (6 * standard deviation).' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpkIndex rdf:type rdf:Property ;
    rdfs:label 'Cpk Index' ;
    rdfs:comment 'Process capability index Cpk measuring the actual capability of the process accounting for centering. Calculated as minimum of [(USL - mean) / (3 * standard deviation), (mean - LSL) / (3 * standard deviation)].' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the time window over which process capability was calculated.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the time window over which process capability was calculated.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'Lower specification limit defining the minimum acceptable value for the parameter.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:normalityTestResult rdf:type rdf:Property ;
    rdfs:label 'Normality Test Result' ;
    rdfs:comment 'Result of statistical normality test (e.g., Anderson-Darling, Shapiro-Wilk) to validate that data follows normal distribution, a prerequisite for capability index calculation.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfControlPoints rdf:type rdf:Property ;
    rdfs:label 'Out Of Control Points' ;
    rdfs:comment 'Number of data points that violated SPC control rules during the evaluation period, indicating special cause variation.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'Standardized code or identifier for the process parameter in the Manufacturing Execution System (MES).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppIndex rdf:type rdf:Property ;
    rdfs:label 'Pp Index' ;
    rdfs:comment 'Process performance index Pp measuring the overall performance of the process over time. Calculated as (USL - LSL) / (6 * overall standard deviation).' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppkIndex rdf:type rdf:Property ;
    rdfs:label 'Ppk Index' ;
    rdfs:comment 'Process performance index Ppk measuring the actual performance of the process accounting for centering over time. Calculated as minimum of [(USL - mean) / (3 * overall standard deviation), (mean - LSL) / (3 * overall standard deviation)].' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCount rdf:type rdf:Property ;
    rdfs:label 'Sample Count' ;
    rdfs:comment 'Number of measurement samples included in the capability calculation.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardDeviation rdf:type rdf:Property ;
    rdfs:label 'Standard Deviation' ;
    rdfs:comment 'Standard deviation of the parameter measurements, representing process variation.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subgroupSize rdf:type rdf:Property ;
    rdfs:label 'Subgroup Size' ;
    rdfs:comment 'Number of measurements per subgroup used in the SPC control chart analysis.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'Upper specification limit defining the maximum acceptable value for the parameter.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excursionId rdf:type rdf:Property ;
    rdfs:label 'Excursion Id' ;
    rdfs:comment 'Primary key for excursion' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedDieCount rdf:type rdf:Property ;
    rdfs:label 'Affected Die Count' ;
    rdfs:comment 'Estimated total number of die units affected by this excursion. Used for financial impact assessment and customer notification.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedLotCount rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Count' ;
    rdfs:comment 'Total number of wafer lots affected by this excursion event. Used for impact assessment and containment scope determination.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containmentActionTaken rdf:type rdf:Property ;
    rdfs:label 'Containment Action Taken' ;
    rdfs:comment 'Immediate containment actions taken upon excursion detection. Describes steps such as lot hold, equipment quarantine, process parameter adjustment, or rework initiation.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Timestamp' ;
    rdfs:comment 'Date and time when containment actions were completed. Used to measure response time and containment effectiveness.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Source system or method that detected the excursion event. Indicates whether the excursion was identified through Statistical Process Control (SPC), inspection, metrology measurement, electrical test, operator observation, or automated monitoring system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Usd' ;
    rdfs:comment 'Estimated financial impact of the excursion in US dollars. Includes scrap cost, rework cost, yield loss, and potential customer claims.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedYieldImpactPercent rdf:type rdf:Property ;
    rdfs:label 'Estimated Yield Impact Percent' ;
    rdfs:comment 'Estimated percentage point impact on wafer yield due to this excursion. Calculated based on defect density, affected area, and historical correlation data.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excursionNumber rdf:type rdf:Property ;
    rdfs:label 'Excursion Number' ;
    rdfs:comment 'Business identifier for the excursion event. Human-readable reference number used for tracking and communication across engineering teams.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionType rdf:type rdf:Property ;
    rdfs:label 'Excursion Type' ;
    rdfs:comment 'Classification of the excursion event. Categorizes whether the excursion is due to out-of-specification parameters, out-of-control process conditions, yield loss, excessive defect density, parametric drift, or equipment fault.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the excursion investigation. Tracks progression from initial detection through root cause analysis to closure.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Specification Lower Limit' ;
    rdfs:comment 'Lower specification limit for the parameter. Used to determine out-of-specification conditions and product quality impact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Specification Upper Limit' ;
    rdfs:comment 'Upper specification limit for the parameter. Used to determine out-of-specification conditions and product quality impact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossMode rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Mode' ;
    rdfs:comment 'Classification of the yield loss mechanism. Parametric indicates parameter drift, systematic indicates repeatable pattern defects, random indicates sporadic defects, electrical indicates functional test failures, none indicates no yield impact detected.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Owner Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Governance report requires each process flow to be owned by a specific org unit for accountability and performance tracking.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:criticalLayerCount rdf:type rdf:Property ;
    rdfs:label 'Critical Layer Count' ;
    rdfs:comment 'Number of critical layers requiring advanced lithography techniques (EUV, multi-patterning, or tight overlay control).' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceFamily rdf:type rdf:Property ;
    rdfs:label 'Device Family' ;
    rdfs:comment 'The device family or product line for which this process flow is applicable (e.g., \'FinFET\', \'GAA\', \'Planar CMOS\', \'DRAM\', \'NAND Flash\').' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euvLayerCount rdf:type rdf:Property ;
    rdfs:label 'Euv Layer Count' ;
    rdfs:comment 'Number of layers using Extreme Ultraviolet (EUV) lithography in the process flow.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flowForNode rdf:type rdf:Property ;
    rdfs:label 'Flow For Node' ;
    rdfs:comment 'FK to process.technology_node.technology_node_id — Every process flow is designed for a specific technology node. This is the top-level classification relationship enabling node-based process management.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBaselineFlow rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Flow' ;
    rdfs:comment 'Flag indicating whether this is the baseline (reference) process flow for the technology node. True if baseline, False otherwise.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lithographyLayerCount rdf:type rdf:Property ;
    rdfs:label 'Lithography Layer Count' ;
    rdfs:comment 'Total number of photolithography (patterning) layers in the complete process flow.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opcRuleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Opc Rule Set Version' ;
    rdfs:comment 'Version identifier of the Optical Proximity Correction (OPC) rule set used for mask data preparation in this process flow.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFlowDescription rdf:type rdf:Property ;
    rdfs:label 'Process Flow Description' ;
    rdfs:comment 'Detailed textual description of the process flow, including key process characteristics, intended applications, and any special considerations.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsMultiPatterning rdf:type rdf:Property ;
    rdfs:label 'Supports Multi Patterning' ;
    rdfs:comment 'Flag indicating whether the process flow includes multi-patterning lithography techniques (LELE, SADP, SAQP). True if multi-patterning is used, False otherwise.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalStepCount rdf:type rdf:Property ;
    rdfs:label 'Total Step Count' ;
    rdfs:comment 'Total number of unit process steps in the complete flow from wafer start through final inspection.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedPositionId rdf:type rdf:Property ;
    rdfs:label 'Assigned Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Manufacturing execution assigns each step to a defined position; staffing and training reports depend on this link.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:fabOperatorQualificationId rdf:type rdf:Property ;
    rdfs:label 'Fab Operator Qualification Id' ;
    rdfs:comment 'Foreign key linking to workforce.fab_operator_qualification. Business justification: Operator qualification records must be tied to the steps they qualify for to enforce qualification compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabOperatorQualification .

ind:metrologyPlanId rdf:type rdf:Property ;
    rdfs:label 'Metrology Plan Id' ;
    rdfs:comment 'Reference to the metrology measurement plan for this step, specifying what measurements are taken and at what frequency.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetrologyPlan .

ind:primaryProcessFlowId rdf:type rdf:Property ;
    rdfs:label 'Primary Process Flow Id' ;
    rdfs:comment 'Foreign key linking to process.process_process_flow. Business justification: A process step belongs to a process flow; adding internal FK enables direct navigation within the process domain.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessFlow .

ind:cycleTimeTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Target Minutes' ;
    rdfs:comment 'Target processing time for this step in minutes, used for manufacturing planning, scheduling, and throughput optimization.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doseTarget rdf:type rdf:Property ;
    rdfs:label 'Dose Target' ;
    rdfs:comment 'Target ion implantation dose in ions per square centimeter, or exposure dose in millijoules per square centimeter for lithography steps.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyTargetKev rdf:type rdf:Property ;
    rdfs:label 'Energy Target Kev' ;
    rdfs:comment 'Target ion implantation energy in kilo-electron volts (keV), controlling the depth of dopant penetration into the silicon substrate.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCriticalStep rdf:type rdf:Property ;
    rdfs:label 'Is Critical Step' ;
    rdfs:comment 'Boolean flag indicating whether this step is classified as critical for yield, quality, or device performance, requiring enhanced monitoring and control.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReworkAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Rework Allowed' ;
    rdfs:comment 'Boolean flag indicating whether wafers can be reworked or reprocessed through this step if defects or out-of-spec conditions are detected.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerSetpointWatts rdf:type rdf:Property ;
    rdfs:label 'Power Setpoint Watts' ;
    rdfs:comment 'Nominal RF or DC power setpoint in watts for plasma-based process steps such as reactive ion etch or PECVD.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressureSetpointTorr rdf:type rdf:Property ;
    rdfs:label 'Pressure Setpoint Torr' ;
    rdfs:comment 'Nominal chamber pressure setpoint in Torr for vacuum process steps such as CVD, PVD, or plasma etch.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Numeric ordering of this step within the parent process flow, determining the execution sequence in the manufacturing line.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepNumber rdf:type rdf:Property ;
    rdfs:label 'Step Number' ;
    rdfs:comment 'Business identifier for the process step, typically a hierarchical or sequential code used in manufacturing documentation and traveler cards.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureSetpointCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Setpoint Celsius' ;
    rdfs:comment 'Nominal process temperature setpoint in degrees Celsius for thermal process steps such as deposition, diffusion, or annealing.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processQualificationId rdf:type rdf:Property ;
    rdfs:label 'Process Qualification Id' ;
    rdfs:comment 'Unique identifier for the process qualification program record. Primary key.' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processQualificationForFlow rdf:type rdf:Property ;
    rdfs:label 'Process Qualification For Flow' ;
    rdfs:comment 'FK to process.process_flow.process_flow_id — Process qualifications validate a process flow or step change. This link is required for qualification status lookup during production release decisions.' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessFlow .

ind:acceptanceCriteriaSummary rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Summary' ;
    rdfs:comment 'High-level summary of the key acceptance criteria that must be met for qualification to pass (e.g., yield > 95%, Cpk > 1.33, defect density < 0.1/cm²).' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCpk rdf:type rdf:Property ;
    rdfs:label 'Actual Cpk' ;
    rdfs:comment 'Actual process capability index (Cpk) achieved during qualification testing. Populated upon completion of qualification runs.' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureModeSummary rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Summary' ;
    rdfs:comment 'Summary of failure modes observed during qualification testing, if applicable. Used for failed or waived qualifications to document issues encountered.' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotCount rdf:type rdf:Property ;
    rdfs:label 'Lot Count' ;
    rdfs:comment 'Total number of fabrication lots planned or executed for the qualification program.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planReference rdf:type rdf:Property ;
    rdfs:label 'Plan Reference' ;
    rdfs:comment 'Document reference or identifier for the formal qualification plan that defines acceptance criteria, test methodology, and success metrics. May reference PLM document number or file path.' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmSystemSource rdf:type rdf:Property ;
    rdfs:label 'Plm System Source' ;
    rdfs:comment 'Source PLM system from which this qualification record was extracted: oracle_agile (Oracle Agile PLM), siemens_teamcenter (Siemens Teamcenter PLM), other.' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmWorkflowReference rdf:type rdf:Property ;
    rdfs:label 'Plm Workflow Reference' ;
    rdfs:comment 'Workflow or change order identifier in the source PLM system that tracks the qualification approval process.' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationName rdf:type rdf:Property ;
    rdfs:label 'Qualification Name' ;
    rdfs:comment 'Descriptive name of the qualification program, identifying the process or change being qualified.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCustomerApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Customer Approval' ;
    rdfs:comment 'Flag indicating whether this qualification requires formal customer approval before production deployment. True for customer-specific processes or foundry qualifications.' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signOffEngineerName rdf:type rdf:Property ;
    rdfs:label 'Sign Off Engineer Name' ;
    rdfs:comment 'Name of the process engineer or technical authority who signed off on the qualification results.' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCpk rdf:type rdf:Property ;
    rdfs:label 'Target Cpk' ;
    rdfs:comment 'Target process capability index (Cpk) that must be achieved for qualification to pass. Typical semiconductor requirement is Cpk >= 1.33.' ;
    rdfs:domain ind:ProcessQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineYieldTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Baseline Yield Target Percent' ;
    rdfs:comment 'Target baseline yield percentage (good dies per wafer) for production qualification of this technology node.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beolLayerCount rdf:type rdf:Property ;
    rdfs:label 'Beol Layer Count' ;
    rdfs:comment 'Number of process layers in the Back End of Line, covering metal interconnect formation.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceArchitecture rdf:type rdf:Property ;
    rdfs:label 'Device Architecture' ;
    rdfs:comment 'Transistor architecture type used in this technology node. Planar for traditional flat transistors, FinFET (Fin Field-Effect Transistor) for 3D fin structures, GAA (Gate All Around) for next-generation wrap-around gates, nanowire or nanosheet for advanced GAA variants.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dramHalfPitchNm rdf:type rdf:Property ;
    rdfs:label 'Dram Half Pitch Nm' ;
    rdfs:comment 'DRAM half-pitch in nanometers, a key metric for memory density and technology node classification per ITRS standards.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feolLayerCount rdf:type rdf:Property ;
    rdfs:label 'Feol Layer Count' ;
    rdfs:comment 'Number of process layers in the Front End of Line, covering transistor formation steps.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gatePitchNm rdf:type rdf:Property ;
    rdfs:label 'Gate Pitch Nm' ;
    rdfs:comment 'Gate pitch in nanometers, representing the distance between adjacent transistor gates in the Front End of Line (FEOL). Key dimension for transistor density.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:introductionYear rdf:type rdf:Property ;
    rdfs:label 'Introduction Year' ;
    rdfs:comment 'Calendar year when this technology node was first introduced or qualified for production.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBaselineNode rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Node' ;
    rdfs:comment 'Indicates whether this is the baseline or reference technology node for a given generation. Used for comparison and benchmarking purposes.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumMetalPitchNm rdf:type rdf:Property ;
    rdfs:label 'Minimum Metal Pitch Nm' ;
    rdfs:comment 'Minimum metal interconnect pitch in nanometers, representing the smallest distance between adjacent metal lines in the Back End of Line (BEOL).' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processTechnologyNodeDescription rdf:type rdf:Property ;
    rdfs:label 'Process Technology Node Description' ;
    rdfs:comment 'Detailed textual description of the technology node, including key features, capabilities, and differentiators.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Production Readiness Status' ;
    rdfs:comment 'Current production readiness state of the technology node. Research: early R&D phase. Development: active development. Qualification: undergoing process qualification. Pilot: pilot production runs. Production: full production ready. Mature: established high-volume production. EOL (End of Life): being phased out. [ENUM-REF-CANDIDATE: research|development|qualification|pilot|production|mature|eol — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPerformanceImprovementPercent rdf:type rdf:Property ;
    rdfs:label 'Target Performance Improvement Percent' ;
    rdfs:comment 'Target percentage improvement in performance (speed/frequency) compared to the previous technology node generation. Part of PPA (Power Performance Area) metrics.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPowerEfficiencyImprovementPercent rdf:type rdf:Property ;
    rdfs:label 'Target Power Efficiency Improvement Percent' ;
    rdfs:comment 'Target percentage improvement in power efficiency compared to the previous technology node generation. Part of PPA (Power Performance Area) metrics.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTransistorDensityPerMm2 rdf:type rdf:Property ;
    rdfs:label 'Target Transistor Density Per Mm2' ;
    rdfs:comment 'Target transistor density in millions of transistors per square millimeter for this technology node. Key metric for comparing node scaling and integration capability.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultFabToolId rdf:type rdf:Property ;
    rdfs:label 'Default Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: A recipe is authored for a specific fab tool model; the FK supports recipe-tool compatibility checks and tool-specific parameter validation.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:cmpPadType rdf:type rdf:Property ;
    rdfs:label 'Cmp Pad Type' ;
    rdfs:comment 'CMP polishing pad material and type identifier. Null for non-CMP recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmpPlatenPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Cmp Platen Pressure Psi' ;
    rdfs:comment 'Downforce pressure in PSI applied to wafer during CMP. Null for non-CMP recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmpRemovalTargetNm rdf:type rdf:Property ;
    rdfs:label 'Cmp Removal Target Nm' ;
    rdfs:comment 'Target material removal thickness in nanometers for CMP process. Null for non-CMP recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmpTableSpeedRpm rdf:type rdf:Property ;
    rdfs:label 'Cmp Table Speed Rpm' ;
    rdfs:comment 'Platen rotation speed in RPM during CMP. Null for non-CMP recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionRfPowerW rdf:type rdf:Property ;
    rdfs:label 'Deposition Rf Power W' ;
    rdfs:comment 'Radio frequency power in Watts for plasma-enhanced deposition processes (PECVD). Null for non-plasma deposition recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionTargetThicknessNm rdf:type rdf:Property ;
    rdfs:label 'Deposition Target Thickness Nm' ;
    rdfs:comment 'Target film thickness in nanometers for deposition processes. Null for non-deposition recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Deposition Temperature C' ;
    rdfs:comment 'Process chamber temperature in degrees Celsius during deposition. Null for non-deposition recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchChemistry rdf:type rdf:Property ;
    rdfs:label 'Etch Chemistry' ;
    rdfs:comment 'Primary etchant chemistry or gas mixture (e.g., CF4/O2, HBr/Cl2, SF6, HF/HNO3). Null for non-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etchPressureMtorr rdf:type rdf:Property ;
    rdfs:label 'Etch Pressure Mtorr' ;
    rdfs:comment 'Process chamber pressure in milliTorr during dry etch. Null for non-dry-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchRfBiasPowerW rdf:type rdf:Property ;
    rdfs:label 'Etch Rf Bias Power W' ;
    rdfs:comment 'RF bias power in Watts controlling ion bombardment energy in reactive ion etch. Null for non-plasma-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchRfSourcePowerW rdf:type rdf:Property ;
    rdfs:label 'Etch Rf Source Power W' ;
    rdfs:comment 'RF source power in Watts for plasma generation in reactive ion etch. Null for non-plasma-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchSelectivityRatio rdf:type rdf:Property ;
    rdfs:label 'Etch Selectivity Ratio' ;
    rdfs:comment 'Ratio of etch rate of target material to etch rate of mask or underlying material, indicating process selectivity. Null for non-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantDoseCm2 rdf:type rdf:Property ;
    rdfs:label 'Implant Dose Cm2' ;
    rdfs:comment 'Ion implantation dose in ions per square centimeter controlling dopant concentration. Null for non-implant recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantTiltAngleDeg rdf:type rdf:Property ;
    rdfs:label 'Implant Tilt Angle Deg' ;
    rdfs:comment 'Wafer tilt angle in degrees during ion implantation to control channeling effects. Null for non-implant recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantTwistAngleDeg rdf:type rdf:Property ;
    rdfs:label 'Implant Twist Angle Deg' ;
    rdfs:comment 'Wafer twist (rotation) angle in degrees during ion implantation to control channeling effects. Null for non-implant recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithoExposureDoseMjCm2 rdf:type rdf:Property ;
    rdfs:label 'Litho Exposure Dose Mj Cm2' ;
    rdfs:comment 'Exposure energy dose in mJ/cm² for photoresist exposure. Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithoFocusOffsetNm rdf:type rdf:Property ;
    rdfs:label 'Litho Focus Offset Nm' ;
    rdfs:comment 'Focus offset in nanometers from best focus position for process window optimization. Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithoIlluminationMode rdf:type rdf:Property ;
    rdfs:label 'Litho Illumination Mode' ;
    rdfs:comment 'Illumination source configuration (e.g., conventional, annular, dipole, quadrupole, freeform). Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lithoNumericalAperture rdf:type rdf:Property ;
    rdfs:label 'Litho Numerical Aperture' ;
    rdfs:comment 'Numerical aperture of the lithography lens system controlling resolution. Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithoScannerModel rdf:type rdf:Property ;
    rdfs:label 'Litho Scanner Model' ;
    rdfs:comment 'Photolithography scanner tool model (e.g., ASML NXT:2000i, Nikon NSR-S630D). Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lithoWavelengthNm rdf:type rdf:Property ;
    rdfs:label 'Litho Wavelength Nm' ;
    rdfs:comment 'Exposure wavelength in nanometers (e.g., 193 for ArF DUV, 13.5 for EUV). Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineDataPoints rdf:type rdf:Property ;
    rdfs:label 'Baseline Data Points' ;
    rdfs:comment 'Number of data points collected during the baseline period to establish initial control limits. Typically 25-30 subgroups are required for reliable limit calculation.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chartActivationDate rdf:type rdf:Property ;
    rdfs:label 'Chart Activation Date' ;
    rdfs:comment 'Date when the SPC chart was first activated for production monitoring. Marks the beginning of the charts operational lifecycle.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chartName rdf:type rdf:Property ;
    rdfs:label 'Chart Name' ;
    rdfs:comment 'Business-friendly name of the SPC control chart for identification and reporting purposes.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOwner rdf:type rdf:Property ;
    rdfs:label 'Chart Owner' ;
    rdfs:comment 'Name or identifier of the process engineer or team responsible for monitoring and maintaining this SPC chart.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartRetirementDate rdf:type rdf:Property ;
    rdfs:label 'Chart Retirement Date' ;
    rdfs:comment 'Date when the SPC chart was retired from active monitoring. Nullable for active charts. Retired charts are preserved for historical analysis.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chartStatus rdf:type rdf:Property ;
    rdfs:label 'Chart Status' ;
    rdfs:comment 'Current lifecycle status of the SPC chart. Active charts are in production monitoring; suspended charts are temporarily paused; retired charts are no longer used; under review charts are being evaluated for limit adjustments; baseline collection charts are gathering initial data to establish control limits.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlLimitCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Control Limit Calculation Method' ;
    rdfs:comment 'Method used to calculate the control limits for this SPC chart. Three sigma uses standard deviation-based limits; six sigma uses tighter limits; Cpk-based derives limits from process capability index; historical baseline uses past performance data; engineering specification uses design requirements.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLimitRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Last Limit Revision Date' ;
    rdfs:comment 'Date when the control limits were last revised or recalculated. Control limits should be periodically reviewed and updated as process capability improves.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowerWarningLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Warning Limit' ;
    rdfs:comment 'Lower warning limit (LWL) for the SPC chart. Typically set at -2 sigma from the target value. Measurements below this limit trigger a warning but do not necessarily indicate an out-of-control process.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Sequence Number' ;
    rdfs:comment 'Sequential number of this measurement within the SPC chart history. Used for time-series analysis and trend detection.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoredParameterName rdf:type rdf:Property ;
    rdfs:label 'Monitored Parameter Name' ;
    rdfs:comment 'Name of the process parameter being monitored by this SPC chart (e.g., critical dimension, film thickness, overlay, etch rate, resistivity).' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocapReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ocap Reference Number' ;
    rdfs:comment 'Reference number of the Out-of-Control Action Plan (OCAP) triggered by this measurement, if applicable. Links to the OCAP tracking system for root cause analysis and corrective action.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Parameter Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the monitored parameter (e.g., nm, angstrom, ohm-cm, percent, degrees Celsius).' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processActionTaken rdf:type rdf:Property ;
    rdfs:label 'Process Action Taken' ;
    rdfs:comment 'Action taken in response to the measurement and any rule violations. None indicates no action required; warning issued indicates notification sent; OCAP triggered indicates Out-of-Control Action Plan initiated; lot hold indicates lot placed on hold; equipment hold indicates equipment taken offline; process adjustment indicates recipe or parameter adjustment made; engineering review indicates escalation to process engineering. [ENUM-REF-CANDIDATE: none|warning_issued|ocap_triggered|lot_hold|equipment_hold|process_adjustment|engineering_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCapabilityIndexCp rdf:type rdf:Property ;
    rdfs:label 'Process Capability Index Cp' ;
    rdfs:comment 'Process capability index Cp, calculated as (USL - LSL) / (6 * sigma). Measures the potential capability of the process to meet specifications, assuming the process is centered. Values > 1.33 are typically considered acceptable.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processCapabilityIndexCpk rdf:type rdf:Property ;
    rdfs:label 'Process Capability Index Cpk' ;
    rdfs:comment 'Process capability index Cpk, calculated as min[(USL - mean) / (3 * sigma), (mean - LSL) / (3 * sigma)]. Measures the actual capability of the process to meet specifications, accounting for process centering. Values > 1.33 are typically considered acceptable.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleViolationsTriggered rdf:type rdf:Property ;
    rdfs:label 'Rule Violations Triggered' ;
    rdfs:comment 'Comma-separated list of SPC rule violations detected for this measurement (e.g., Western Electric rules 1-4, Nelson rules 1-8). Examples: Rule 1 (one point beyond 3 sigma), Rule 2 (nine points in a row on same side of center line), Rule 3 (six points in a row steadily increasing or decreasing).' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteXCoordinate rdf:type rdf:Property ;
    rdfs:label 'Site X Coordinate' ;
    rdfs:comment 'X-axis coordinate of the measurement site on the wafer surface. Used for spatial analysis and mapping of process uniformity.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteYCoordinate rdf:type rdf:Property ;
    rdfs:label 'Site Y Coordinate' ;
    rdfs:comment 'Y-axis coordinate of the measurement site on the wafer surface. Used for spatial analysis and mapping of process uniformity.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperWarningLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Warning Limit' ;
    rdfs:comment 'Upper warning limit (UWL) for the SPC chart. Typically set at +2 sigma from the target value. Measurements exceeding this limit trigger a warning but do not necessarily indicate an out-of-control process.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingPlanId rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan Id' ;
    rdfs:comment 'The identifier of the sampling plan that defined which wafers and sites to measure. Links to the metrology sampling strategy for this process step.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SamplingPlan .

ind:deviationFromTarget rdf:type rdf:Property ;
    rdfs:label 'Deviation From Target' ;
    rdfs:comment 'The calculated difference between the measured value and the target value. Positive values indicate measurements above target; negative values indicate measurements below target.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementOnChart rdf:type rdf:Property ;
    rdfs:label 'Measurement On Chart' ;
    rdfs:comment 'FK to process.process_spc_control_chart.process_spc_control_chart_id — Every SPC measurement data point belongs to a specific control chart. This is the fundamental transaction-to-master relationship for SPC.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfControlFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Control Flag' ;
    rdfs:comment 'Boolean indicator of whether this measurement triggered an out-of-control condition. True if the measurement violated control limits or SPC rules requiring corrective action.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfSpecFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Spec Flag' ;
    rdfs:comment 'Boolean indicator of whether this measurement exceeded specification limits. True if the measured value fell outside the upper or lower specification limits defined by engineering.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleViolationFlags rdf:type rdf:Property ;
    rdfs:label 'Rule Violation Flags' ;
    rdfs:comment 'Comma-separated list of SPC rule violations triggered by this measurement. Includes Western Electric rules (e.g., WE1, WE2, WE3, WE4) and Nelson rules (e.g., N1, N2, N3) that detected out-of-control conditions or trends.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sigmaLevel rdf:type rdf:Property ;
    rdfs:label 'Sigma Level' ;
    rdfs:comment 'The number of standard deviations the measured value is from the process mean. Used to assess process capability and identify outliers.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteNumber rdf:type rdf:Property ;
    rdfs:label 'Site Number' ;
    rdfs:comment 'The sequential identifier of the measurement site within the wafer sampling plan. Corresponds to the predefined site map used for metrology sampling.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specificationLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Specification Limit Upper' ;
    rdfs:comment 'The upper specification limit defined by the process design. Represents the maximum acceptable value for the parameter as defined by engineering requirements.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossEventId rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Event Id' ;
    rdfs:comment 'Unique identifier for the yield loss event record. Primary key.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionPointId rdf:type rdf:Property ;
    rdfs:label 'Inspection Point Id' ;
    rdfs:comment 'Reference to the inspection or metrology point where the yield loss was detected. May be inline or offline inspection station.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPoint .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the engineer or team assigned to investigate and resolve the yield loss event. Used for workload management and escalation.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSizeNm rdf:type rdf:Property ;
    rdfs:label 'Defect Size Nm' ;
    rdfs:comment 'Measured or estimated size of the defect in nanometers. Critical for determining defect criticality and kill ratio at advanced technology nodes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method or technique used to detect the yield loss event. Indicates whether detected via inline inspection, offline inspection, electrical test, parametric test, visual inspection, or metrology measurement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Timestamp' ;
    rdfs:comment 'Date and time when root cause investigation of the yield loss event was initiated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotHoldApplied rdf:type rdf:Property ;
    rdfs:label 'Lot Hold Applied' ;
    rdfs:comment 'Indicates whether a lot hold was placed on the affected wafer lot as a result of this yield loss event. True if hold applied; false if no hold applied.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the engineer, operator, or automated system that reported or logged the yield loss event. Used for accountability and follow-up.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferPositionXMm rdf:type rdf:Property ;
    rdfs:label 'Wafer Position X Mm' ;
    rdfs:comment 'X-coordinate position on the wafer where the yield loss event was detected, in millimeters from wafer center. Used for spatial yield analysis and wafer mapping.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferPositionYMm rdf:type rdf:Property ;
    rdfs:label 'Wafer Position Y Mm' ;
    rdfs:comment 'Y-coordinate position on the wafer where the yield loss event was detected, in millimeters from wafer center. Used for spatial yield analysis and wafer mapping.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Unique identifier for the bill of materials header record. Primary key for the BOM entity.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Bom Ic Catalog Id' ;
    rdfs:comment 'Reference to the parent IC product or assembly that this BOM defines. Links to the product master catalog.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:toIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'To Ic Catalog Id' ;
    rdfs:comment 'FK to product.ic_catalog.ic_catalog_id — Each BOM defines the component structure of a specific IC product. The BOM header must reference the product it describes.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:alternativeBomIndicator rdf:type rdf:Property ;
    rdfs:label 'Alternative Bom Indicator' ;
    rdfs:comment 'Identifier for alternative BOM configurations for the same product. Used when multiple valid component combinations exist (e.g., different suppliers, different process nodes, or design variants).' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The quantity of the parent product that this BOM defines. Typically 1 for single-unit BOMs, but may be higher for batch or lot-based manufacturing. All component quantities in BOM lines are relative to this base quantity.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, typically a human-readable code used across PLM and ERP systems for tracking and reference.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Draft indicates work in progress, in_review indicates pending approval, approved indicates ready for use, active indicates currently in production, frozen indicates locked for manufacturing, obsolete indicates no longer valid, superseded indicates replaced by newer revision. [ENUM-REF-CANDIDATE: draft|in_review|approved|active|frozen|obsolete|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM by its intended use: engineering BOM (EBOM) for design, manufacturing BOM (MBOM) for production, service BOM for maintenance, planning BOM for forecasting, as-designed for original specification, or as-built for actual production configuration.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Compliant Flag' ;
    rdfs:comment 'Indicates whether the BOM and all its components are free from conflict minerals (tin, tantalum, tungsten, gold) sourced from conflict regions, per Dodd-Frank Act Section 1502 requirements.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the total material cost. Typically USD for semiconductor industry but may vary by region.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Material Flag' ;
    rdfs:comment 'Indicates whether this BOM contains components classified as critical materials (long lead time, single source, strategic importance). Used for supply chain risk management.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineeringChangeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Order Number' ;
    rdfs:comment 'Reference to the engineering change order that created or last modified this BOM revision. Critical for change traceability and audit compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:explosionType rdf:type rdf:Property ;
    rdfs:label 'Explosion Type' ;
    rdfs:comment 'Defines how the BOM should be exploded for planning and costing: single-level shows only immediate children, multi-level shows full hierarchy, summarized shows consolidated component totals.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalBomReference rdf:type rdf:Property ;
    rdfs:label 'External Bom Reference' ;
    rdfs:comment 'Original BOM identifier from the source PLM or ERP system. Maintains traceability to upstream systems and enables cross-system reconciliation.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Standard production lot size for which this BOM is optimized. Used in material requirements planning (MRP) and capacity planning calculations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltbNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Ltb Notification Date' ;
    rdfs:comment 'Date when Last Time Buy notification was issued for this BOM, indicating the product is approaching end-of-life and customers should place final orders.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'Production version identifier linking this BOM to a specific routing or process flow. Enables coordination between BOM and manufacturing process definitions.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'Expected scrap or yield loss percentage at the BOM level. Used to adjust material requirements and costing. Typical semiconductor yield losses are factored here.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalComponentCount rdf:type rdf:Property ;
    rdfs:label 'Total Component Count' ;
    rdfs:comment 'Total number of distinct component line items in this BOM. Provides quick visibility into BOM complexity without querying detail records.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Total Material Cost' ;
    rdfs:comment 'Rolled-up total material cost for all components in this BOM, calculated from component costs and quantities. Used for product costing and margin analysis.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usage rdf:type rdf:Property ;
    rdfs:label 'Usage' ;
    rdfs:comment 'Intended usage context for this BOM: production for manufacturing execution, costing for financial analysis, engineering for design reference, maintenance for service operations, or sales for customer quotations.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the BOM line entity.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentLineBomLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Line Bom Line Id' ;
    rdfs:comment 'Reference to the parent BOM line in a multi-level BOM structure. Null for top-level components. Enables recursive BOM explosion and indented BOM reports.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomLine .

ind:primaryBomEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Bom Employee Id' ;
    rdfs:comment 'The user ID or system account that created this BOM line record. Supports audit trail and accountability.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryBomId rdf:type rdf:Property ;
    rdfs:label 'Primary Bom Id' ;
    rdfs:comment 'Reference to the parent BOM header that this line belongs to. Links the line item to the overall product BOM structure.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:toBomHeader rdf:type rdf:Property ;
    rdfs:label 'To Bom Header' ;
    rdfs:comment 'FK to product.bom.bom_id — BOM lines are detail records belonging to a BOM header. This is a classic header-line pattern that is non-negotiable for BOM explosion and cost rollup.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:toBomId rdf:type rdf:Property ;
    rdfs:label 'To Bom Id' ;
    rdfs:comment 'FK to product.bom.bom_id — Classic header-line relationship. BOM lines are meaningless without their parent BOM header.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:approvedSubstitutePartNumbers rdf:type rdf:Property ;
    rdfs:label 'Approved Substitute Part Numbers' ;
    rdfs:comment 'Comma-separated list of approved alternate or substitute part numbers that can be used in place of the primary component. Supports supply chain flexibility and risk mitigation.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyProcessCode rdf:type rdf:Property ;
    rdfs:label 'Assembly Process Code' ;
    rdfs:comment 'Code identifying the assembly or packaging process used to integrate this component (e.g., wirebond, flip-chip, CoWoS, InFO). Links to process routing and manufacturing execution.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'The hierarchical level of this component in the multi-level BOM structure. Level 0 is the finished product, level 1 is direct sub-assembly, level 2 is sub-component of level 1, and so on. Supports BOM explosion for cost rollup and supply chain analysis.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed textual description of the component, including technical specifications, material properties, and functional purpose within the assembly.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPartNumber rdf:type rdf:Property ;
    rdfs:label 'Component Part Number' ;
    rdfs:comment 'The unique part number or SKU of the component material used in this BOM line. May reference die, package substrate, passive components, interposer, or other materials.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component by its functional role in the semiconductor assembly. Includes die (silicon chip), package substrate, passive components (resistors, capacitors), interposer, leadframe, wirebond, solder ball, underfill material, and mold compound. [ENUM-REF-CANDIDATE: die|package_substrate|passive|interposer|leadframe|wirebond|solder_ball|underfill|mold_compound — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Status' ;
    rdfs:comment 'Compliance status for conflict minerals (tin, tantalum, tungsten, gold) sourcing per Dodd-Frank Act Section 1502. Tracks whether component supply chain is free from conflict region sourcing.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical to product functionality, quality, or supply chain continuity. Used for risk assessment and inventory planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity End Date' ;
    rdfs:comment 'The date on which this BOM line becomes obsolete or is replaced. Null for currently active components. Supports phase-in/phase-out scenarios and Product Change Notification (PCN) tracking.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Start Date' ;
    rdfs:comment 'The date from which this BOM line becomes effective. Supports date-based BOM versioning and engineering change management.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makeOrBuyIndicator rdf:type rdf:Property ;
    rdfs:label 'Make Or Buy Indicator' ;
    rdfs:comment 'Indicates whether the component is manufactured in-house (make), procured externally (buy), or transferred from another plant (transfer). Drives procurement and production planning logic.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'The name of the original equipment manufacturer (OEM) or component manufacturer. May differ from the supplier if purchased through distributors.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phantomBomFlag rdf:type rdf:Property ;
    rdfs:label 'Phantom Bom Flag' ;
    rdfs:comment 'Indicates whether this is a phantom or transient sub-assembly that is not stocked or tracked as inventory. Phantom BOMs are exploded through during MRP but not manufactured as discrete items.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'The typical lead time in days required to procure this component from suppliers. Used for material requirements planning (MRP) and supply chain risk analysis.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityPerAssembly rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Assembly' ;
    rdfs:comment 'The quantity of this component required to produce one unit of the parent assembly. Supports fractional quantities for materials measured by weight or volume.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDesignator rdf:type rdf:Property ;
    rdfs:label 'Reference Designator' ;
    rdfs:comment 'The reference designator or location identifier for the component on the physical layout or assembly drawing (e.g., U1, C23, R45). Links BOM to physical design.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percent' ;
    rdfs:comment 'Expected scrap or yield loss percentage for this component during manufacturing. Used to calculate net material requirements accounting for process losses.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:singleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Single Source Flag' ;
    rdfs:comment 'Indicates whether this component is available from only one supplier, representing a supply chain risk. Triggers dual-sourcing initiatives and risk mitigation strategies.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCertId rdf:type rdf:Property ;
    rdfs:label 'Compliance Cert Id' ;
    rdfs:comment 'Unique identifier for the product compliance certification record.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cert Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance certification records must reference the employee responsible for maintaining the certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Compliance Ic Catalog Id' ;
    rdfs:comment 'Reference to the semiconductor product or SKU (Stock Keeping Unit) for which this compliance certification applies.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:primaryIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Ic Catalog Id' ;
    rdfs:comment 'FK to product.ic_catalog.ic_catalog_id — Compliance certifications are obtained for specific products or SKUs. Required for export control screening and customer documentation.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Comma-separated list of geographic markets, regions, or countries where this compliance certification is recognized and valid (e.g., USA, EU, CHN, JPN, KOR). Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Regions' ;
    rdfs:comment 'Comma-separated list of regulatory regions or jurisdictions where this certification applies (e.g., North America, European Union, Asia-Pacific, EMEA).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automotiveGradeCertified rdf:type rdf:Property ;
    rdfs:label 'Automotive Grade Certified' ;
    rdfs:comment 'Boolean flag indicating whether the product has achieved automotive-grade qualification certification (e.g., AEC-Q100 for ICs, AEC-Q101 for discrete semiconductors) for use in automotive applications.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the accredited third-party organization or regulatory authority that issued the compliance certification (e.g., TÜV, UL, Intertek, SGS, Bureau Veritas).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Detailed description of the scope of the certification, including specific product variants, process nodes, package types, or application domains covered by this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for additional notes, exceptions, conditions, or special handling instructions related to this compliance certification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsDeclaration rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Declaration' ;
    rdfs:comment 'Declaration of conflict minerals (tin, tantalum, tungsten, gold - 3TG) sourcing and compliance status with Dodd-Frank Act Section 1502 and OECD Due Diligence Guidance.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecificRequirement rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Requirement' ;
    rdfs:comment 'Description of any customer-specific compliance requirements or certifications that this record addresses beyond standard regulatory requirements.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earControlled rdf:type rdf:Property ;
    rdfs:label 'Ear Controlled' ;
    rdfs:comment 'Boolean flag indicating whether the product is subject to EAR (Export Administration Regulations) export controls administered by the Bureau of Industry and Security.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalStandard rdf:type rdf:Property ;
    rdfs:label 'Environmental Standard' ;
    rdfs:comment 'Environmental management system standard under which this certification was issued (e.g., ISO 14001, ISO 50001 for energy management).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalSafetyLevel rdf:type rdf:Property ;
    rdfs:label 'Functional Safety Level' ;
    rdfs:comment 'Functional safety integrity level achieved by the product under ISO 26262 (ASIL A/B/C/D for automotive) or IEC 61508 (SIL 1/2/3/4 for industrial) standards. ASIL (Automotive Safety Integrity Level), SIL (Safety Integrity Level). [ENUM-REF-CANDIDATE: ASIL_A|ASIL_B|ASIL_C|ASIL_D|SIL_1|SIL_2|SIL_3|SIL_4|not_applicable — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousSubstanceDeclaration rdf:type rdf:Property ;
    rdfs:label 'Hazardous Substance Declaration' ;
    rdfs:comment 'Detailed declaration of hazardous substances present in the product, including substance names, CAS (Chemical Abstracts Service) numbers, concentration levels, and compliance status with RoHS, REACH, and TSCA regulations.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOwner rdf:type rdf:Property ;
    rdfs:label 'Internal Owner' ;
    rdfs:comment 'Name or employee identifier of the internal compliance manager or product quality engineer responsible for maintaining this certification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityManagementStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Management Standard' ;
    rdfs:comment 'Quality management system standard under which this certification was issued (e.g., ISO 9001, IATF 16949, AS9100, ISO 13485).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Frequency Months' ;
    rdfs:comment 'Number of months between required recertification cycles. Null if recertification is not required or is event-driven rather than time-based.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationTriggerEvents rdf:type rdf:Property ;
    rdfs:label 'Recertification Trigger Events' ;
    rdfs:comment 'Comma-separated list of business events that trigger mandatory recertification (e.g., design change, process node migration, package change, supplier change, PCN issuance, material substitution).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedCountries rdf:type rdf:Property ;
    rdfs:label 'Restricted Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes to which export or sale of this product is restricted or prohibited under applicable export control regulations.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Url' ;
    rdfs:comment 'URL or file path to the repository location containing supporting documentation, test reports, certificates, and compliance declarations for this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testLaboratory rdf:type rdf:Property ;
    rdfs:label 'Test Laboratory' ;
    rdfs:comment 'Name of the accredited testing laboratory that performed the compliance testing and analysis supporting this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'Reference number of the official test report or assessment document that supports this compliance certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationRuleId rdf:type rdf:Property ;
    rdfs:label 'Configuration Rule Id' ;
    rdfs:comment 'System-generated unique identifier for the configuration rule.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rule Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Configuration Rule governance requires a rule owner employee for change approval and audit.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableMarket rdf:type rdf:Property ;
    rdfs:label 'Applicable Market' ;
    rdfs:comment 'Target market segment (e.g., automotive, consumer, industrial) for which the rule is valid.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProcessNode rdf:type rdf:Property ;
    rdfs:label 'Applicable Process Node' ;
    rdfs:comment 'Process node (e.g., 7nm, 5nm) for which the rule is valid.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automotiveQualified rdf:type rdf:Property ;
    rdfs:label 'Automotive Qualified' ;
    rdfs:comment 'True if the rule applies to automotive-qualified SKUs.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configurationRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Configuration Rule Description' ;
    rdfs:comment 'Detailed free-text description of the rule logic and intent.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Rule Status' ;
    rdfs:comment 'Current lifecycle status of the rule.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintExpression rdf:type rdf:Property ;
    rdfs:label 'Constraint Expression' ;
    rdfs:comment 'Logical expression defining the valid combination of options (e.g., "package_type=\'BGA\' AND speed_grade=\'high\' => voltage_variant=\'1.2V\'").' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultRule rdf:type rdf:Property ;
    rdfs:label 'Is Default Rule' ;
    rdfs:comment 'Indicates whether this rule is the default fallback when no other rule matches.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionDependencies rdf:type rdf:Property ;
    rdfs:label 'Option Dependencies' ;
    rdfs:comment 'Textual description of any dependent options or exclusions related to the rule.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Qualification Level' ;
    rdfs:comment 'Qualification level option that the rule constrains.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business identifier or code used to reference the rule in downstream systems.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name describing the purpose of the rule.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOwner rdf:type rdf:Property ;
    rdfs:label 'Rule Owner' ;
    rdfs:comment 'Name or identifier of the person or team responsible for the rule.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Category of rule based on the option it governs.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Incremental version number for change management of the rule.' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRange rdf:type rdf:Property ;
    rdfs:label 'Temperature Range' ;
    rdfs:comment 'Temperature range option that the rule constrains.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voltageVariant rdf:type rdf:Property ;
    rdfs:label 'Voltage Variant' ;
    rdfs:comment 'Voltage variant option that the rule constrains.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errataId rdf:type rdf:Property ;
    rdfs:label 'Errata Id' ;
    rdfs:comment 'Unique identifier for the product errata record. Primary key.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engineeringOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Engineering Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Errata tracking assigns an engineering owner employee for root-cause analysis and customer communication.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:errataIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Errata Ic Catalog Id' ;
    rdfs:comment 'Reference to the affected integrated circuit (IC) product, system on chip (SoC), application-specific integrated circuit (ASIC), or field-programmable gate array (FPGA) product.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:testCaseId rdf:type rdf:Property ;
    rdfs:label 'Test Case Id' ;
    rdfs:comment 'Reference to the automatic test equipment (ATE) test pattern, design verification plan test case, or simulation run that reproduces the errata. Used for regression testing and validation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestCase .

ind:affectedRevisions rdf:type rdf:Property ;
    rdfs:label 'Affected Revisions' ;
    rdfs:comment 'Comma-separated list of all silicon revisions affected by this errata (e.g., A0,A1,B0). Used to determine scope of customer impact.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedUseCases rdf:type rdf:Property ;
    rdfs:label 'Affected Use Cases' ;
    rdfs:comment 'Description of customer application scenarios or operating modes impacted by the errata (e.g., high-speed PCIe Gen4 operation, concurrent multi-channel DMA, low-power sleep modes).' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Reason for closing the errata record. Fixed in Silicon: corrected in new revision; Fixed in Software: resolved via patch; Workaround Sufficient: mitigation acceptable; Product EOL: end-of-life product; Not Reproducible: cannot verify; Working as Designed: not a defect.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerDisclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Disclosure Status' ;
    rdfs:comment 'Status of customer communication regarding this errata. Not Disclosed: internal only; Pending Approval: awaiting management approval; Disclosed NDA: shared under non-disclosure agreement; Disclosed Public: published in public errata sheet.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'Date when the errata was first communicated to customers via product change notification (PCN), errata sheet update, or technical advisory. Null if not yet disclosed.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveredBy rdf:type rdf:Property ;
    rdfs:label 'Discovered By' ;
    rdfs:comment 'Source or method by which the errata was discovered. Internal Validation: found during wafer testing or quality assurance; Customer Report: reported by design-in customer; Field Failure: observed in production deployment; Design Verification: identified during design for testability (DFT) or automatic test pattern generation (ATPG).' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveredDate rdf:type rdf:Property ;
    rdfs:label 'Discovered Date' ;
    rdfs:comment 'Date when the silicon bug or functional deviation was first identified, either during internal validation, customer testing, or field deployment.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringOwner rdf:type rdf:Property ;
    rdfs:label 'Engineering Owner' ;
    rdfs:comment 'Name or identifier of the design engineer or engineering team responsible for investigating and resolving this errata. Used for accountability and workload tracking.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errataNumber rdf:type rdf:Property ;
    rdfs:label 'Errata Number' ;
    rdfs:comment 'Business identifier for the errata record, typically formatted as product-family prefix followed by sequential number (e.g., SOC-001234, FPGA-000567). Used in customer communications and product change notifications (PCN).' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errataStatus rdf:type rdf:Property ;
    rdfs:label 'Errata Status' ;
    rdfs:comment 'Current lifecycle status of the errata record. Draft: initial documentation; Under Review: engineering validation; Confirmed: verified silicon bug; Disclosed: communicated to customers; Resolved: fix available; Closed: no longer applicable.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixPlan rdf:type rdf:Property ;
    rdfs:label 'Fix Plan' ;
    rdfs:comment 'Planned resolution approach for the errata. Next Silicon Revision: will be corrected in next tapeout; Software Patch: addressable via firmware/driver update; No Fix Planned: low priority or end-of-life (EOL) product; Under Evaluation: fix strategy being assessed.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixTargetRevision rdf:type rdf:Property ;
    rdfs:label 'Fix Target Revision' ;
    rdfs:comment 'Silicon stepping or revision where the errata will be corrected (e.g., C0, D1). Null if fix is software-only or no fix planned.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalBlock rdf:type rdf:Property ;
    rdfs:label 'Functional Block' ;
    rdfs:comment 'Name of the intellectual property (IP) core, register transfer level (RTL) module, or functional block where the errata occurs (e.g., PCIe Controller, DDR PHY, CPU Core, DMA Engine).' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Customer Count' ;
    rdfs:comment 'Estimated or actual number of customers affected by this errata based on product shipments and silicon revision distribution. Used for risk assessment and communication prioritization.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedErrataIds rdf:type rdf:Property ;
    rdfs:label 'Related Errata Ids' ;
    rdfs:comment 'Comma-separated list of related errata record identifiers that share common root cause, affect the same functional block, or have dependencies. Used for impact analysis and consolidated fixes.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the errata was resolved either through silicon revision fix, software patch release, or closure decision. Null if still open or under evaluation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siliconRevision rdf:type rdf:Property ;
    rdfs:label 'Silicon Revision' ;
    rdfs:comment 'Silicon stepping or revision identifier where the errata was discovered (e.g., A0, B1, C2). Corresponds to mask revision in the fabrication process.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:symptomDescription rdf:type rdf:Property ;
    rdfs:label 'Symptom Description' ;
    rdfs:comment 'Detailed technical description of the observable behavior or functional deviation caused by the silicon bug. Includes conditions under which the issue manifests.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toRevision rdf:type rdf:Property ;
    rdfs:label 'To Revision' ;
    rdfs:comment 'FK to product.product_revision.product_revision_id — Errata are specific to a silicon revision/stepping. Must link to the affected revision.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workaroundAvailable rdf:type rdf:Property ;
    rdfs:label 'Workaround Available' ;
    rdfs:comment 'Indicates whether a software, firmware, or operational workaround exists to mitigate the errata impact. True if workaround documented; False if no mitigation available.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workaroundDescription rdf:type rdf:Property ;
    rdfs:label 'Workaround Description' ;
    rdfs:comment 'Detailed instructions for software, firmware, or operational workaround to avoid or mitigate the errata. May include register configuration changes, driver patches, or usage restrictions. Null if no workaround available.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workaroundPerformanceImpact rdf:type rdf:Property ;
    rdfs:label 'Workaround Performance Impact' ;
    rdfs:comment 'Description of any power, performance, or area (PPA) degradation introduced by the workaround (e.g., 5% throughput reduction, 10mW additional power consumption, increased latency). Null if no measurable impact or no workaround.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icProcessNodeId rdf:type rdf:Property ;
    rdfs:label 'Ic Process Node Id' ;
    rdfs:comment 'FK to product.process_node.process_node_id — Every IC product is manufactured on a specific process node. This is a fundamental product attribute that references the process node master.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessNode .

ind:icProductProcessNodeId rdf:type rdf:Property ;
    rdfs:label 'Ic Product Process Node Id' ;
    rdfs:comment 'FK to product.process_node' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessNode .

ind:productManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Product Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for Product Portfolio Management report: each IC catalog entry must have a designated product manager employee.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aecQualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Aec Qualification Level' ;
    rdfs:comment 'Specific AEC qualification standard met. Q100: ICs, Q101: Discretes, Q102: Optoelectronics, Q200: Passives. Set to NA if not automotive qualified.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogToFamily rdf:type rdf:Property ;
    rdfs:label 'Catalog To Family' ;
    rdfs:comment 'FK to product.product_family.product_family_id — Every IC product belongs to a product family in the taxonomy hierarchy. This is the primary classification FK.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalPartNumber rdf:type rdf:Property ;
    rdfs:label 'External Part Number' ;
    rdfs:comment 'Customer-facing orderable part number published in datasheets and used for commercial transactions. May differ from internal part number for marketing or legacy reasons.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstSiliconDate rdf:type rdf:Property ;
    rdfs:label 'First Silicon Date' ;
    rdfs:comment 'Date when first fabricated silicon wafers were received from the fab for initial testing and validation. Marks start of silicon bring-up phase.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalPartNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Part Number' ;
    rdfs:comment 'Company-assigned unique part number for internal identification, tracking, and PLM integration. Primary business identifier for the IC design.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastShipDate rdf:type rdf:Property ;
    rdfs:label 'Last Ship Date' ;
    rdfs:comment 'Final date when product shipments will be made. Marks complete discontinuation of the product. Typically 6-12 months after last-time-buy date to allow for manufacturing lead time.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadFreeCompliant rdf:type rdf:Property ;
    rdfs:label 'Lead Free Compliant' ;
    rdfs:comment 'Indicates whether the product meets RoHS (Restriction of Hazardous Substances) lead-free requirements. True if compliant with EU RoHS Directive for lead-free solder and materials.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npiPhase rdf:type rdf:Property ;
    rdfs:label 'Npi Phase' ;
    rdfs:comment 'Detailed phase within NPI lifecycle for products in pre-production stages. Tracks progress from concept through design, tapeout, silicon bring-up, and qualification. Set to NA for production products. [ENUM-REF-CANDIDATE: Concept|Design|Tapeout|Silicon_Validation|Qualification|Ramp|Production|NA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingFrequencyMaxMhz rdf:type rdf:Property ;
    rdfs:label 'Operating Frequency Max Mhz' ;
    rdfs:comment 'Maximum clock frequency in MHz at which the IC can reliably operate. Key performance metric for processors, SoCs, and high-speed digital circuits. Part of PPA metrics.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageMaxV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage Max V' ;
    rdfs:comment 'Maximum supply voltage in volts for safe operation. Defines upper bound of operating voltage range. Exceeding this may cause device damage or reliability issues.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageMinV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage Min V' ;
    rdfs:comment 'Minimum supply voltage in volts for guaranteed operation. Defines lower bound of operating voltage range for power optimization and battery operation.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerMaxMw rdf:type rdf:Property ;
    rdfs:label 'Power Max Mw' ;
    rdfs:comment 'Maximum power consumption in milliwatts under worst-case operating conditions. Used for thermal design, power supply sizing, and system integration planning.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerTypicalMw rdf:type rdf:Property ;
    rdfs:label 'Power Typical Mw' ;
    rdfs:comment 'Typical operating power consumption in milliwatts under nominal conditions. Critical PPA metric for mobile, IoT, and battery-powered applications. Measured at specified voltage and frequency.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level classification of the semiconductor product type. Determines design flow, manufacturing process, and business model (silicon vs. licensable IP). [ENUM-REF-CANDIDATE: IC|SoC|ASIC|FPGA|IP_Core|Discrete|Memory|Analog|Mixed_Signal|RF — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Production Release Date' ;
    rdfs:comment 'Date when product was officially released to production status and made available for volume manufacturing and customer orders. Marks end of qualification phase.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'Primary market segment or application domain for which the IC is designed. Determines qualification requirements, reliability standards, and regulatory compliance needs. [ENUM-REF-CANDIDATE: Automotive|Consumer|Industrial|Medical|Aerospace|Defense|Telecom|Computing|IoT|AI_ML — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transistorCount rdf:type rdf:Property ;
    rdfs:label 'Transistor Count' ;
    rdfs:comment 'Total number of transistors on the die. Key complexity metric for digital ICs and SoCs. Used for design effort estimation and manufacturing complexity assessment.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pcnId rdf:type rdf:Property ;
    rdfs:label 'Pcn Id' ;
    rdfs:comment 'Unique identifier for the product change notification record. Primary key.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Change Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: PCN Change Management process mandates linking each change to the responsible engineer employee for regulatory reporting.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:pcnIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Pcn Ic Catalog Id' ;
    rdfs:comment 'Foreign key linking to product.ic_catalog. Business justification: pcn records are change notifications for specific IC products; linking pcn to ic_catalog provides parent relationship and enables traceability.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:affectedCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Customer Count' ;
    rdfs:comment 'Total number of customers who have active orders, design-ins, or inventory of the affected products and must be notified of the change.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the executive or manager who provided final approval for the PCN, typically a VP of Engineering, Quality Director, or Product Line Manager.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automotiveQualificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Automotive Qualification Required Flag' ;
    rdfs:comment 'Indicates whether the change requires re-qualification under automotive quality standards such as IATF 16949 or AEC-Q100/Q200, applicable when affected products are used in automotive applications.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Severity classification of the change: major (requires customer qualification), minor (limited impact, may require notification), or notification_only (informational, no action required).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Change Owner Email' ;
    rdfs:comment 'Email address of the change owner for customer inquiries and internal coordination regarding the PCN.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRationale rdf:type rdf:Property ;
    rdfs:label 'Change Rationale' ;
    rdfs:comment 'Business and technical justification for the change, including reasons such as cost reduction, yield improvement, supply chain continuity, obsolescence mitigation, or performance enhancement.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalCount rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Count' ;
    rdfs:comment 'Number of customers who explicitly approved or acknowledged acceptance of the proposed change.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Required Flag' ;
    rdfs:comment 'Indicates whether explicit customer approval or acknowledgment is required before implementing the change, typically true for major changes affecting form, fit, or function.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerObjectionCount rdf:type rdf:Property ;
    rdfs:label 'Customer Objection Count' ;
    rdfs:comment 'Number of customers who formally objected to or raised concerns about the proposed change during the notification period.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerResponseDeadline rdf:type rdf:Property ;
    rdfs:label 'Customer Response Deadline' ;
    rdfs:comment 'Date by which customers must provide feedback, objections, or approval for the proposed change. After this date, silence may be interpreted as acceptance per JEDEC guidelines.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electricalImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Electrical Impact Assessment' ;
    rdfs:comment 'Engineering assessment of how the change affects electrical characteristics such as timing, power consumption, signal integrity, or parametric specifications.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Impact' ;
    rdfs:comment 'Assessment of whether the change affects environmental compliance status, including RoHS, REACH, halogen-free, or conflict minerals declarations.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formFitFunctionImpact rdf:type rdf:Property ;
    rdfs:label 'Form Fit Function Impact' ;
    rdfs:comment 'Classification of whether the change affects form (physical dimensions/appearance), fit (mechanical interchangeability), function (electrical/performance characteristics), multiple aspects, or none. Critical for customer qualification scope determination.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Actual date when the product change was implemented in production and new shipments began reflecting the change. May differ from planned effective_date.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jedecComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Jedec Compliance Status' ;
    rdfs:comment 'Indicates whether the PCN process and content comply with JEDEC JESD46 standard requirements for product change notification in the semiconductor industry.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newSpecification rdf:type rdf:Property ;
    rdfs:label 'New Specification' ;
    rdfs:comment 'Technical specification, process parameters, material composition, or design revision identifier for the product after the change. Defines the target state.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oldSpecification rdf:type rdf:Property ;
    rdfs:label 'Old Specification' ;
    rdfs:comment 'Technical specification, process parameters, material composition, or design revision identifier for the product before the change. Provides baseline for comparison.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnStatus rdf:type rdf:Property ;
    rdfs:label 'Pcn Status' ;
    rdfs:comment 'Current lifecycle state of the PCN: draft (being prepared), pending_approval (awaiting internal review), approved (ready for customer notification), customer_notification_sent (communicated to affected customers), in_qualification (customers testing), implemented (change is live in production), cancelled (change abandoned), or superseded (replaced by newer PCN). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|customer_notification_sent|in_qualification|implemented|cancelled|superseded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnType rdf:type rdf:Property ;
    rdfs:label 'Pcn Type' ;
    rdfs:comment 'Classification of the change being notified: process change (fab process modification), material change (substrate or compound change), package change (assembly or form factor), test change (ATE or test flow), design change (die revision), or specification change (datasheet update).' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationPlan rdf:type rdf:Property ;
    rdfs:label 'Qualification Plan' ;
    rdfs:comment 'Description of the testing and validation activities required to qualify the changed product, including reliability tests, electrical characterization, and compatibility verification per JEDEC standards.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPcnNumbers rdf:type rdf:Property ;
    rdfs:label 'Related Pcn Numbers' ;
    rdfs:comment 'Comma-separated list of related PCN numbers that are associated with this change, such as dependent changes, parallel changes to related products, or prerequisite notifications.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Reliability Impact Assessment' ;
    rdfs:comment 'Engineering assessment of how the change affects product reliability, including MTBF, failure modes, stress test results, and long-term performance predictions.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequestDeadline rdf:type rdf:Property ;
    rdfs:label 'Sample Request Deadline' ;
    rdfs:comment 'Last date by which customers can request evaluation samples of the changed product for their own qualification testing.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:samplesAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Samples Available Flag' ;
    rdfs:comment 'Indicates whether product samples manufactured with the new change are available for customer evaluation and qualification testing.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByPcnNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Pcn Number' ;
    rdfs:comment 'PCN number that replaces or supersedes this PCN, used when a newer change notification obsoletes or modifies a previous one.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeProductCount rdf:type rdf:Property ;
    rdfs:label 'Active Product Count' ;
    rdfs:comment 'Current count of active product SKUs (ICs, SoCs, ASICs, FPGAs) assigned to this process node. Used for capacity planning and node utilization analysis.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Baseline Yield Percent' ;
    rdfs:comment 'Expected baseline yield percentage (good dies per wafer) for this process node under standard manufacturing conditions. Used for cost modeling and capacity planning. Confidential manufacturing metric.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerWaferUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Wafer Usd' ;
    rdfs:comment 'Standard manufacturing cost per wafer in USD for this process node. Includes FEOL (Front End of Line), MOL (Middle of Line), and BEOL (Back End of Line) processing costs. Confidential financial data used for product costing and NRE (Non-Recurring Engineering) estimation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Status' ;
    rdfs:comment 'Compliance status with environmental regulations including RoHS (Restriction of Hazardous Substances), REACH (Registration Evaluation Authorization and Restriction of Chemicals), and TSCA (Toxic Substances Control Act). Compliant indicates full adherence; Non-Compliant indicates violations; Under Review indicates pending assessment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current lifecycle stage of the process node. NPI (New Product Introduction) indicates initial ramp; Growth indicates volume expansion; Mature indicates stable production; Decline indicates phasing out; EOL (End of Life) indicates discontinued with LTB (Last Time Buy) notifications issued.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltbDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Ltb Deadline Date' ;
    rdfs:comment 'Final date for customers to place orders for products manufactured on this process node before complete discontinuation. Null if node is not in EOL status.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:multiPatterningLayers rdf:type rdf:Property ;
    rdfs:label 'Multi Patterning Layers' ;
    rdfs:comment 'Number of critical layers requiring multi-patterning techniques (double, triple, or quad patterning) to achieve target feature sizes. Zero indicates single-exposure capability. Higher counts increase mask costs and cycle time.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opcRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Opc Required Flag' ;
    rdfs:comment 'Indicates whether OPC (Optical Proximity Correction) is mandatory for mask preparation at this process node. True for advanced nodes where lithography effects require computational correction.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdkReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Pdk Release Date' ;
    rdfs:comment 'Date when the current PDK version was officially released and made available to design teams. Tracks PDK maturity and design enablement timeline.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportedDeviceTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Device Types' ;
    rdfs:comment 'Comma-separated list of device types and IP (Intellectual Property Core) categories supported by this process node (e.g., Logic, SRAM, Analog, RF, High-Voltage, IO). Defines the breadth of design capabilities.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Parent Family Id' ;
    rdfs:comment 'Reference to the parent product family in the hierarchy. Supports multi-level taxonomy: portfolio → family → sub-family → product → variant. Null for top-level portfolio entries.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:activePcnCount rdf:type rdf:Property ;
    rdfs:label 'Active Pcn Count' ;
    rdfs:comment 'Number of active PCNs currently in effect for this product family. Indicates ongoing changes to process, materials, or design that require customer notification and approval.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationDomain rdf:type rdf:Property ;
    rdfs:label 'Application Domain' ;
    rdfs:comment 'Specific application domain or use case this product family addresses (e.g., Advanced Driver Assistance Systems, Edge AI Inference, 5G Baseband Processing). Used for technical marketing and customer solution mapping.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCenterLocation rdf:type rdf:Property ;
    rdfs:label 'Design Center Location' ;
    rdfs:comment 'Primary design center location responsible for this product family (e.g., San Jose CA, Austin TX, Bangalore India). Used for resource planning and IP ownership tracking.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Dft Coverage Percent' ;
    rdfs:comment 'Design for Testability coverage percentage indicating the proportion of circuit nodes accessible for ATPG (Automatic Test Pattern Generation). Higher coverage enables better defect detection during wafer test.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:familyCode rdf:type rdf:Property ;
    rdfs:label 'Family Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the product family in external systems and customer communications. Used in PLM, ERP, and CRM systems for product taxonomy navigation.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyDescription rdf:type rdf:Property ;
    rdfs:label 'Family Description' ;
    rdfs:comment 'Detailed description of the product family including target applications, key features, and market positioning. Used for technical documentation and sales enablement.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Business name of the product family (e.g., Cortex-M Series, Automotive MCU Family, RF Transceiver Family). Used in roadmap planning, marketing materials, and customer design-in targeting.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'Classification of the product family by semiconductor device type. Aligns with industry standard device categories for design, fabrication, and test planning. [ENUM-REF-CANDIDATE: IC|SoC|ASIC|FPGA|IP_Core|Discrete|Mixed_Signal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltbDate rdf:type rdf:Property ;
    rdfs:label 'Ltb Date' ;
    rdfs:comment 'Final date for customers to place orders before product family is discontinued. Part of EOL process and customer lifecycle management.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npiStartDate rdf:type rdf:Property ;
    rdfs:label 'Npi Start Date' ;
    rdfs:comment 'Date when this product family entered NPI phase. Marks the beginning of qualification, ramp, and early customer shipments. Used for TTM (Time to Market) tracking.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:osatPartner rdf:type rdf:Property ;
    rdfs:label 'Osat Partner' ;
    rdfs:comment 'Name of the OSAT partner responsible for packaging and final test of this product family. Critical for supply chain planning and quality management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineManager rdf:type rdf:Property ;
    rdfs:label 'Product Line Manager' ;
    rdfs:comment 'Name of the product line manager responsible for roadmap, positioning, and lifecycle management of this product family. Business owner for strategic decisions.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPerformanceMetric rdf:type rdf:Property ;
    rdfs:label 'Target Performance Metric' ;
    rdfs:comment 'Key performance metric and target value for this product family (e.g., 3.5 GHz clock frequency, 100 TOPS AI performance, 10 Gbps throughput). Used for competitive analysis and roadmap planning.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPowerMw rdf:type rdf:Property ;
    rdfs:label 'Target Power Mw' ;
    rdfs:comment 'Target typical power consumption in milliwatts for this product family. Part of PPA (Power Performance Area) metrics used for competitive positioning and customer design-in evaluation.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalDieSizeMm2 rdf:type rdf:Property ;
    rdfs:label 'Typical Die Size Mm2' ;
    rdfs:comment 'Representative die size in square millimeters for products in this family. Used for wafer yield modeling, cost estimation, and capacity planning. Actual die sizes may vary by specific product variant.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeProductionDate rdf:type rdf:Property ;
    rdfs:label 'Volume Production Date' ;
    rdfs:comment 'Date when this product family achieved volume production status (Active lifecycle). Indicates full manufacturing qualification and capacity availability.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:areaMm2 rdf:type rdf:Property ;
    rdfs:label 'Area Mm2' ;
    rdfs:comment 'Physical silicon area occupied by the IP core in square millimeters. Part of PPA (Power, Performance, Area) metrics.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designForTestability rdf:type rdf:Property ;
    rdfs:label 'Design For Testability' ;
    rdfs:comment 'Indicates whether the IP core includes DFT features such as scan chains, BIST (Built-In Self-Test), or ATPG support.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationPackage rdf:type rdf:Property ;
    rdfs:label 'Documentation Package' ;
    rdfs:comment 'Reference to the documentation package location or identifier (e.g., datasheet, integration guide, verification plan, user manual).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errataNotes rdf:type rdf:Property ;
    rdfs:label 'Errata Notes' ;
    rdfs:comment 'Known issues, limitations, or workarounds for the IP core. Reference to errata document or summary of key issues.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationComplexity rdf:type rdf:Property ;
    rdfs:label 'Integration Complexity' ;
    rdfs:comment 'Estimated complexity level for integrating the IP core into an SoC or ASIC design: low (plug-and-play), medium (moderate customization), high (significant integration effort), very high (extensive customization required).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCategory rdf:type rdf:Property ;
    rdfs:label 'Ip Category' ;
    rdfs:comment 'Functional classification of the IP core: processor cores, memory controllers, interface controllers (USB, PCIe, Ethernet), analog blocks, PHYs, security engines, DSP blocks, or hardware accelerators. [ENUM-REF-CANDIDATE: processor|memory_controller|interface|analog|phy|security|dsp|accelerator — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCoreName rdf:type rdf:Property ;
    rdfs:label 'Ip Core Name' ;
    rdfs:comment 'Human-readable name of the IP core block (e.g., ARM Cortex-A78, USB 3.2 PHY, DDR5 Memory Controller).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCoreToNode rdf:type rdf:Property ;
    rdfs:label 'Ip Core To Node' ;
    rdfs:comment 'FK to product.product_process_node.product_process_node_id — IP cores have process node compatibility. Must reference which nodes the IP is qualified for.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licensingModel rdf:type rdf:Property ;
    rdfs:label 'Licensing Model' ;
    rdfs:comment 'Business model for IP core licensing: royalty-free (one-time fee), per-unit royalty (fee per chip manufactured), NRE upfront (non-recurring engineering fee), subscription (annual license), or hybrid (combination).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowPowerModes rdf:type rdf:Property ;
    rdfs:label 'Low Power Modes' ;
    rdfs:comment 'Comma-separated list of low-power operating modes supported by the IP core (e.g., sleep, retention, power gating, clock gating).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or name of the person who last modified the IP core record.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Operating Frequency Mhz' ;
    rdfs:comment 'Maximum operating frequency of the IP core in megahertz.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage V' ;
    rdfs:comment 'Nominal operating voltage for the IP core in volts (e.g., 0.8V, 1.2V).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perUnitRoyaltyUsd rdf:type rdf:Property ;
    rdfs:label 'Per Unit Royalty Usd' ;
    rdfs:comment 'Royalty fee in USD charged per manufactured chip that incorporates this IP core. Null if licensing model is royalty-free.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDesigns rdf:type rdf:Property ;
    rdfs:label 'Reference Designs' ;
    rdfs:comment 'Comma-separated list of reference design identifiers or links that demonstrate the IP core integration and usage.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityFeatures rdf:type rdf:Property ;
    rdfs:label 'Security Features' ;
    rdfs:comment 'Comma-separated list of security features provided by the IP core (e.g., AES encryption, secure boot, TrustZone, cryptographic accelerators).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContact rdf:type rdf:Property ;
    rdfs:label 'Support Contact' ;
    rdfs:comment 'Contact information for technical support and integration assistance for the IP core.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range C' ;
    rdfs:comment 'Operating temperature range for the IP core in Celsius (e.g., -40 to 125). Format: min to max.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLtbNotificationId rdf:type rdf:Property ;
    rdfs:label 'Product Ltb Notification Id' ;
    rdfs:comment 'Unique identifier for the Last Time Buy notification record. Primary key for the product LTB notification entity.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ltbOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ltb Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: LTB Notification handling is assigned to a product manager employee; required for LTB revenue tracking.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryReplacementProductIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Replacement Product Ic Catalog Id' ;
    rdfs:comment 'Reference to the recommended replacement product in the product catalog. Identifies the form-fit-function equivalent or next-generation product that customers should transition to. May be null if no direct replacement exists.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:productIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Product Ic Catalog Id' ;
    rdfs:comment 'FK to product.ic_catalog.ic_catalog_id — LTB notifications are issued for specific products reaching EOL. Must reference the affected product.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:actualLtbRevenue rdf:type rdf:Property ;
    rdfs:label 'Actual Ltb Revenue' ;
    rdfs:comment 'Actual revenue realized from LTB orders. Captured after the final order date to measure forecast accuracy and assess the financial impact of the product discontinuance.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLtbUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Ltb Units' ;
    rdfs:comment 'Actual unit volume of LTB orders received. Captured after the final order date to measure demand forecast accuracy and assess inventory disposition requirements.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancelledBy rdf:type rdf:Property ;
    rdfs:label 'Cancelled By' ;
    rdfs:comment 'Name or identifier of the business authority who cancelled the LTB notification. Populated only if the notification is cancelled before completion, typically due to business strategy changes or supply chain recovery.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAcknowledgmentDeadline rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledgment Deadline' ;
    rdfs:comment 'Date by which customers must acknowledge the LTB notification if acknowledgment is required. Ensures timely customer response and enables proactive follow-up for non-responsive accounts.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerAcknowledgmentRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledgment Required' ;
    rdfs:comment 'Indicates whether customers are required to formally acknowledge receipt and understanding of the LTB notification. True for high-value or strategic customers; false for standard commercial notifications.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuanceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discontinuance Reason Code' ;
    rdfs:comment 'Primary business reason for product discontinuance and LTB issuance. Categorizes the strategic, operational, or compliance driver behind the End of Life (EOL) decision.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuanceReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Discontinuance Reason Description' ;
    rdfs:comment 'Detailed explanation of the business rationale for product discontinuance. Provides context for customers and internal stakeholders on the strategic or operational factors driving the EOL decision.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLtbRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Ltb Revenue' ;
    rdfs:comment 'Projected revenue from LTB orders during the notification period. Used for financial planning, production capacity allocation, and business impact assessment of the product discontinuance.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLtbUnits rdf:type rdf:Property ;
    rdfs:label 'Estimated Ltb Units' ;
    rdfs:comment 'Projected unit volume of LTB orders. Used for production planning, wafer start authorization, and supply chain capacity allocation during the LTB period.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalOrderDate rdf:type rdf:Property ;
    rdfs:label 'Final Order Date' ;
    rdfs:comment 'Last date on which customers may place orders for the discontinued product. After this date, no new orders will be accepted. Critical milestone for customers planning bridge inventory or transitioning to replacement products.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Final Shipment Date' ;
    rdfs:comment 'Last date on which the discontinued product will be shipped to customers. Represents the absolute end of product availability and marks the transition to replacement product or alternative sourcing.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuedBy rdf:type rdf:Property ;
    rdfs:label 'Issued By' ;
    rdfs:comment 'Name or identifier of the individual who issued the LTB notification to customers. Typically a product marketing manager, customer communications specialist, or PCN coordinator.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when the LTB notification was issued to customers. Marks the official start of the notification period and triggers customer acknowledgment and ordering timelines.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity that may be ordered during the LTB period. Caps total available inventory to prevent over-commitment and ensure fair allocation across customer base.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationIssueDate rdf:type rdf:Property ;
    rdfs:label 'Notification Issue Date' ;
    rdfs:comment 'Date when the LTB notification was formally issued to customers. Marks the start of the official notification period and triggers customer acknowledgment requirements per JEDEC JESD48 standard.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationLanguage rdf:type rdf:Property ;
    rdfs:label 'Notification Language' ;
    rdfs:comment 'Primary language in which the LTB notification was issued. Supports multi-lingual customer communication requirements and regulatory compliance in international markets.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Classification of the LTB notification based on timeline and business circumstances. Standard LTB follows normal discontinuance timelines; expedited LTB has shortened notice periods; extended LTB provides longer lead times; emergency discontinuance addresses immediate supply chain or compliance issues.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required' ;
    rdfs:comment 'Indicates whether the product discontinuance requires regulatory approval or notification in specific jurisdictions. True for products subject to ITAR, EAR, or industry-specific regulations; false for standard commercial products.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replacementProductQualificationRequired rdf:type rdf:Property ;
    rdfs:label 'Replacement Product Qualification Required' ;
    rdfs:comment 'Indicates whether the replacement product requires customer qualification and design-in activities. True if the replacement is not a drop-in substitute and requires engineering validation; false if it is form-fit-function compatible.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCustomersAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Total Customers Acknowledged' ;
    rdfs:comment 'Count of customers who have formally acknowledged the LTB notification. Enables tracking of acknowledgment completion rate and identification of customers requiring follow-up.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCustomersNotified rdf:type rdf:Property ;
    rdfs:label 'Total Customers Notified' ;
    rdfs:comment 'Count of unique customers who received the LTB notification. Tracks the breadth of customer impact and supports acknowledgment tracking and follow-up activities.' ;
    rdfs:domain ind:ProductLtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSampleRequestId rdf:type rdf:Property ;
    rdfs:label 'Product Sample Request Id' ;
    rdfs:comment 'Unique surrogate key for each engineering sample request record.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceItarFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Itar Flag' ;
    rdfs:comment 'True if the sample is subject to ITAR export controls.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReachFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Reach Flag' ;
    rdfs:comment 'True if the sample complies with REACH chemical regulations.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceRohsFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Rohs Flag' ;
    rdfs:comment 'True if the sample complies with RoHS restrictions.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designWinConversionFlag rdf:type rdf:Property ;
    rdfs:label 'Design Win Conversion Flag' ;
    rdfs:comment 'True if the sample request resulted in a confirmed design win.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designWinStatus rdf:type rdf:Property ;
    rdfs:label 'Design Win Status' ;
    rdfs:comment 'Indicates whether the sample request led to a design-win for the product.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationOutcome rdf:type rdf:Property ;
    rdfs:label 'Evaluation Outcome' ;
    rdfs:comment 'Result of the customer\'s technical evaluation of the sample.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'Numeric score (e.g., 0-100) assigned by the customer to the sample.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expeditedFlag rdf:type rdf:Property ;
    rdfs:label 'Expedited Flag' ;
    rdfs:comment 'True if the request requires accelerated processing.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportControlInfo rdf:type rdf:Property ;
    rdfs:label 'Export Control Info' ;
    rdfs:comment 'Export control classification and any restricted country restrictions applicable to the sample.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackDueDate rdf:type rdf:Property ;
    rdfs:label 'Feedback Due Date' ;
    rdfs:comment 'Date by which the customer is expected to return evaluation feedback.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feedbackReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Feedback Received Date' ;
    rdfs:comment 'Date the customer submitted evaluation feedback.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feedbackSummary rdf:type rdf:Property ;
    rdfs:label 'Feedback Summary' ;
    rdfs:comment 'Brief textual summary of the customer\'s feedback.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSampleRequestStatus rdf:type rdf:Property ;
    rdfs:label 'Product Sample Request Status' ;
    rdfs:comment 'Current lifecycle state of the sample request.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSource rdf:type rdf:Property ;
    rdfs:label 'Request Source' ;
    rdfs:comment 'Origin of the request within the organization.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCondition rdf:type rdf:Property ;
    rdfs:label 'Sample Condition' ;
    rdfs:comment 'Physical condition of the sample upon receipt or return.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCostAmount rdf:type rdf:Property ;
    rdfs:label 'Sample Cost Amount' ;
    rdfs:comment 'Monetary cost associated with providing the sample.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Sample Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the sample cost.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleReturnedFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Returned Flag' ;
    rdfs:comment 'True if the customer returned the sample after evaluation.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number for traceability.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Category of sample: engineering silicon, qualification unit, or production-representative.' ;
    rdfs:domain ind:ProductSampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking identifier for the sample shipment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automotiveGrade rdf:type rdf:Property ;
    rdfs:label 'Automotive Grade' ;
    rdfs:comment 'AEC-Q100 automotive qualification grade indicating temperature range and reliability requirements (Grade 0: -40°C to 150°C, Grade 1: -40°C to 125°C, Grade 2: -40°C to 105°C, Grade 3: -40°C to 85°C).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterizationDate rdf:type rdf:Property ;
    rdfs:label 'Characterization Date' ;
    rdfs:comment 'Date when this specification was characterized and validated through silicon testing or simulation.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Data Retention Years' ;
    rdfs:comment 'Guaranteed data retention period in years for non-volatile memory components at specified temperature.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieAreaAchievedMm2 rdf:type rdf:Property ;
    rdfs:label 'Die Area Achieved Mm2' ;
    rdfs:comment 'Actual measured silicon die area in square millimeters (mm²) from physical layout. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieAreaTargetMm2 rdf:type rdf:Property ;
    rdfs:label 'Die Area Target Mm2' ;
    rdfs:comment 'Target silicon die area in square millimeters (mm²). Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPowerAchievedMw rdf:type rdf:Property ;
    rdfs:label 'Dynamic Power Achieved Mw' ;
    rdfs:comment 'Actual measured or characterized dynamic power consumption in milliwatts (mW) during active switching operation at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPowerTargetMw rdf:type rdf:Property ;
    rdfs:label 'Dynamic Power Target Mw' ;
    rdfs:comment 'Target dynamic power consumption in milliwatts (mW) during active switching operation at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enduranceCycles rdf:type rdf:Property ;
    rdfs:label 'Endurance Cycles' ;
    rdfs:comment 'Number of program/erase cycles guaranteed for non-volatile memory components (applicable to flash, EEPROM).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esdProtectionLevelKv rdf:type rdf:Property ;
    rdfs:label 'Esd Protection Level Kv' ;
    rdfs:comment 'Electrostatic discharge protection rating in kilovolts (kV) per JEDEC standards (e.g., HBM, CDM models).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Functional Safety Rating' ;
    rdfs:comment 'Functional safety certification level achieved by the product. ISO 26262 ASIL (Automotive Safety Integrity Level) A through D for automotive applications; IEC 61508 SIL (Safety Integrity Level) 1 through 4 for industrial applications. [ENUM-REF-CANDIDATE: none|iso_26262_asil_a|iso_26262_asil_b|iso_26262_asil_c|iso_26262_asil_d|iec_61508_sil_1|iec_61508_sil_2|iec_61508_sil_3|iec_61508_sil_4 — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioCount rdf:type rdf:Property ;
    rdfs:label 'Io Count' ;
    rdfs:comment 'Total number of input/output pins or pads available on the integrated circuit for signal connectivity.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leakagePowerAchievedMw rdf:type rdf:Property ;
    rdfs:label 'Leakage Power Achieved Mw' ;
    rdfs:comment 'Actual measured or characterized static leakage power consumption in milliwatts (mW) when the circuit is idle at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leakagePowerTargetMw rdf:type rdf:Property ;
    rdfs:label 'Leakage Power Target Mw' ;
    rdfs:comment 'Target static leakage power consumption in milliwatts (mW) when the circuit is idle at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxFrequencyAchievedMhz rdf:type rdf:Property ;
    rdfs:label 'Max Frequency Achieved Mhz' ;
    rdfs:comment 'Actual measured or characterized maximum operating frequency in megahertz (MHz) at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxFrequencyTargetMhz rdf:type rdf:Property ;
    rdfs:label 'Max Frequency Target Mhz' ;
    rdfs:comment 'Target maximum operating frequency in megahertz (MHz) at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memoryConfiguration rdf:type rdf:Property ;
    rdfs:label 'Memory Configuration' ;
    rdfs:comment 'Description of on-chip memory architecture including SRAM, cache, ROM, and embedded flash sizes and organization (e.g., 256KB L2 Cache, 2MB SRAM, 512KB ROM).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingConditionCorner rdf:type rdf:Property ;
    rdfs:label 'Operating Condition Corner' ;
    rdfs:comment 'Process-voltage-temperature (PVT) corner at which this specification is characterized. Typical represents nominal conditions; best/worst case represent performance extremes; slow/fast combinations represent process variation corners. [ENUM-REF-CANDIDATE: typical|best_case|worst_case|slow_slow|fast_fast|slow_fast|fast_slow — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Max C' ;
    rdfs:comment 'Maximum junction temperature in degrees Celsius at which the product is guaranteed to function within specification.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Min C' ;
    rdfs:comment 'Minimum junction temperature in degrees Celsius at which the product is guaranteed to function within specification.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageNominalV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage Nominal V' ;
    rdfs:comment 'Nominal (typical) operating voltage in volts (V) for standard operation.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specStatus rdf:type rdf:Property ;
    rdfs:label 'Spec Status' ;
    rdfs:comment 'Current lifecycle status of this product specification (Draft: under development, Preliminary: pre-silicon or early silicon, Final: production-qualified, Obsolete: superseded by newer version).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productQualificationProgramId rdf:type rdf:Property ;
    rdfs:label 'Product Qualification Program Id' ;
    rdfs:comment 'Unique identifier for the product qualification program record. Primary key.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductQualificationProgram .

ind:programManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Qualification Program execution is overseen by a program manager employee; required for qualification status dashboards.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deviationGranted rdf:type rdf:Property ;
    rdfs:label 'Deviation Granted' ;
    rdfs:comment 'Indicates whether any deviations from the standard qualification test matrix were granted by engineering review board.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esdCdmEnabled rdf:type rdf:Property ;
    rdfs:label 'Esd Cdm Enabled' ;
    rdfs:comment 'Indicates whether ESD Charged Device Model stress test is included in the qualification plan. CDM simulates discharge from a charged device to ground.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esdCdmVoltageV rdf:type rdf:Property ;
    rdfs:label 'Esd Cdm Voltage V' ;
    rdfs:comment 'Target voltage level in volts for ESD Charged Device Model testing, typically 500V minimum for Class C2 devices.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esdHbmEnabled rdf:type rdf:Property ;
    rdfs:label 'Esd Hbm Enabled' ;
    rdfs:comment 'Indicates whether ESD Human Body Model stress test is included in the qualification plan. HBM simulates discharge from human contact.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esdHbmVoltageV rdf:type rdf:Property ;
    rdfs:label 'Esd Hbm Voltage V' ;
    rdfs:comment 'Target voltage level in volts for ESD Human Body Model testing, typically 2000V minimum for Class 2 devices.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureThresholdPpm rdf:type rdf:Property ;
    rdfs:label 'Failure Threshold Ppm' ;
    rdfs:comment 'Maximum allowable failure rate expressed in Defective Parts Per Million (DPPM) for the qualification program to pass.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hastDurationHours rdf:type rdf:Property ;
    rdfs:label 'Hast Duration Hours' ;
    rdfs:comment 'Duration in hours for Highly Accelerated Stress Test, typically 96 to 264 hours.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hastEnabled rdf:type rdf:Property ;
    rdfs:label 'Hast Enabled' ;
    rdfs:comment 'Indicates whether Highly Accelerated Stress Test is included in the qualification plan. HAST combines high temperature, high humidity, and voltage bias to accelerate corrosion and moisture-related failures.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hastRelativeHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Hast Relative Humidity Pct' ;
    rdfs:comment 'Relative humidity percentage for Highly Accelerated Stress Test, typically 85% RH.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hastTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Hast Temperature C' ;
    rdfs:comment 'Temperature in degrees Celsius for Highly Accelerated Stress Test, typically 110°C to 130°C.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:htolDurationHours rdf:type rdf:Property ;
    rdfs:label 'Htol Duration Hours' ;
    rdfs:comment 'Duration in hours for High Temperature Operating Life stress test, typically 1000 hours minimum per JEDEC standards.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:htolEnabled rdf:type rdf:Property ;
    rdfs:label 'Htol Enabled' ;
    rdfs:comment 'Indicates whether High Temperature Operating Life stress test is included in the qualification plan. HTOL accelerates time-dependent failure mechanisms under elevated temperature and voltage bias.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:htolTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Htol Temperature C' ;
    rdfs:comment 'Junction temperature in degrees Celsius for High Temperature Operating Life stress testing, typically 125°C to 150°C.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latchupCurrentMa rdf:type rdf:Property ;
    rdfs:label 'Latchup Current Ma' ;
    rdfs:comment 'Trigger current in milliamperes for latch-up testing, typically 100mA minimum per JEDEC standards.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latchupEnabled rdf:type rdf:Property ;
    rdfs:label 'Latchup Enabled' ;
    rdfs:comment 'Indicates whether latch-up susceptibility test is included in the qualification plan. Latch-up is a CMOS failure mode where parasitic thyristor structures create low-impedance paths.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Business identifier for the qualification program, typically combining product family code and qualification standard abbreviation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Descriptive name of the qualification program including product identifier and target application domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the qualification program. Gate-keeps product lifecycle transition from NPI to volume production.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer' ;
    rdfs:comment 'Name of the reliability engineer responsible for planning, executing, and reporting the qualification program.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tcCycleCount rdf:type rdf:Property ;
    rdfs:label 'Tc Cycle Count' ;
    rdfs:comment 'Number of temperature cycles for Temperature Cycling test, typically 500 to 1000 cycles minimum.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tcEnabled rdf:type rdf:Property ;
    rdfs:label 'Tc Enabled' ;
    rdfs:comment 'Indicates whether Temperature Cycling stress test is included in the qualification plan. TC accelerates thermal fatigue failures due to coefficient of thermal expansion mismatch.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tcMaxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Tc Max Temperature C' ;
    rdfs:comment 'Maximum temperature in degrees Celsius for Temperature Cycling test, typically 125°C to 150°C.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tcMinTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Tc Min Temperature C' ;
    rdfs:comment 'Minimum temperature in degrees Celsius for Temperature Cycling test, typically -55°C or -65°C.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testMatrixVersion rdf:type rdf:Property ;
    rdfs:label 'Test Matrix Version' ;
    rdfs:comment 'Version identifier of the qualification test matrix document defining the complete set of reliability and environmental stress tests, sample sizes, and acceptance criteria.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverGranted rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted' ;
    rdfs:comment 'Indicates whether a waiver was granted to allow production release despite qualification test failures or incomplete testing.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replacementSkuId rdf:type rdf:Property ;
    rdfs:label 'Replacement Sku Id' ;
    rdfs:comment 'Reference to the recommended replacement SKU for customers when this SKU reaches end of life. Facilitates design migration and continuity planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:salesOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sales Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for Sales Forecasting process: each SKU is owned by a sales employee who approves forecasts and pricing.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:skuIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Sku Ic Catalog Id' ;
    rdfs:comment 'Reference to the parent product definition in the IC catalog. Links this SKU to the base product design and specification.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:halogenFree rdf:type rdf:Property ;
    rdfs:label 'Halogen Free' ;
    rdfs:comment 'Indicates whether this SKU is manufactured without halogen-containing materials (chlorine, bromine compounds). Required for certain environmental certifications.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:introductionDate rdf:type rdf:Property ;
    rdfs:label 'Introduction Date' ;
    rdfs:comment 'Date when this SKU was first made available for customer orders. Marks the transition from NPI to Active lifecycle status.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listPriceUsd rdf:type rdf:Property ;
    rdfs:label 'List Price Usd' ;
    rdfs:comment 'Published list price in US dollars for this SKU at 1000-unit quantity. Actual transaction prices subject to volume discounts and customer agreements.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderableFlag rdf:type rdf:Property ;
    rdfs:label 'Orderable Flag' ;
    rdfs:comment 'Indicates whether this SKU is currently available for new customer orders. May be false during allocation, quality holds, or phase-out periods.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcnRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pcn Required Flag' ;
    rdfs:comment 'Indicates whether any changes to this SKU specification, manufacturing process, or supply chain require formal Product Change Notification (PCN) to customers per contractual or regulatory requirements.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippableFlag rdf:type rdf:Property ;
    rdfs:label 'Shippable Flag' ;
    rdfs:comment 'Indicates whether this SKU is currently authorized for shipment. May be false during quality holds, regulatory blocks, or export restrictions.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardPackQuantity rdf:type rdf:Property ;
    rdfs:label 'Standard Pack Quantity' ;
    rdfs:comment 'Number of units in a standard shipping container (tape and reel, tray, tube). Orders are typically placed in multiples of this quantity.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitWeightGrams rdf:type rdf:Property ;
    rdfs:label 'Unit Weight Grams' ;
    rdfs:comment 'Weight of a single packaged unit in grams. Used for shipping cost calculation and logistics planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Primary key for audit' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:applicableStandard rdf:type rdf:Property ;
    rdfs:label 'Applicable Standard' ;
    rdfs:comment 'Regulatory or industry standard against which the audit is performed.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Reference' ;
    rdfs:comment 'Identifier of the certification issued (if any) as a result of the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsTotal rdf:type rdf:Property ;
    rdfs:label 'Findings Total' ;
    rdfs:comment 'Aggregate number of findings recorded for the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:majorNonconformances rdf:type rdf:Property ;
    rdfs:label 'Major Nonconformances' ;
    rdfs:comment 'Count of major non-conformances identified.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNonconformances rdf:type rdf:Property ;
    rdfs:label 'Minor Nonconformances' ;
    rdfs:comment 'Count of minor non-conformances identified.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observations rdf:type rdf:Property ;
    rdfs:label 'Observations' ;
    rdfs:comment 'Number of observations (non-conformance but not a defect).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opportunitiesForImprovement rdf:type rdf:Property ;
    rdfs:label 'Opportunities For Improvement' ;
    rdfs:comment 'Count of OFI (Opportunity for Improvement) findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planDocument rdf:type rdf:Property ;
    rdfs:label 'Plan Document' ;
    rdfs:comment 'Reference (e.g., file name or URL) to the detailed audit plan.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned calendar date for the audit to commence.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:team rdf:type rdf:Property ;
    rdfs:label 'Team' ;
    rdfs:comment 'Comma-separated list of auditor identifiers or names participating in the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceReportId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Report Id' ;
    rdfs:comment 'FK to quality.nonconformance_report.nonconformance_report_id — CAPAs are triggered by nonconformances. This is a critical traceability link for ISO 9001 clause 10.2 compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NonconformanceReport .

ind:relatedAuditFindingQualityAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Related Audit Finding Quality Audit Finding Id' ;
    rdfs:comment 'Identifier of the audit finding associated with the CAPA.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityAuditFinding .

ind:relatedCustomerComplaintId rdf:type rdf:Property ;
    rdfs:label 'Related Customer Complaint Id' ;
    rdfs:comment 'Identifier of the customer complaint that triggered the CAPA.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerComplaint .

ind:relatedDefectDefectRecordId rdf:type rdf:Property ;
    rdfs:label 'Related Defect Defect Record Id' ;
    rdfs:comment 'Identifier of the defect record linked to this CAPA.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectRecord .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business identifier or code assigned to the CAPA for tracking and reference.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Record Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA record.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Indicates whether the action is corrective or preventive.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Approval Status' ;
    rdfs:comment 'Approval status of the CAPA closure after verification.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costActual rdf:type rdf:Property ;
    rdfs:label 'Cost Actual' ;
    rdfs:comment 'Actual financial cost incurred after implementation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated financial cost to implement the corrective or preventive action.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'Date when the problem was first detected.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detectionPhase rdf:type rdf:Property ;
    rdfs:label 'Detection Phase' ;
    rdfs:comment 'Phase of the product lifecycle where the issue was detected.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Criteria' ;
    rdfs:comment 'Criteria and metrics used to verify that the CAPA was effective.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impact rdf:type rdf:Property ;
    rdfs:label 'Impact' ;
    rdfs:comment 'Description of the business or technical impact of the non-conformance.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemStatement rdf:type rdf:Property ;
    rdfs:label 'Problem Statement' ;
    rdfs:comment 'Clear description of the problem or non-conformance that triggered the CAPA.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterId rdf:type rdf:Property ;
    rdfs:label 'Cluster Id' ;
    rdfs:comment 'Identifier linking defects that belong to the same spatial cluster.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectCluster .

ind:defectWaferMapId rdf:type rdf:Property ;
    rdfs:label 'Defect Wafer Map Id' ;
    rdfs:comment 'Identifier for the generated wafer defect map.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferMap .

ind:detectionFabToolId rdf:type rdf:Property ;
    rdfs:label 'Detection Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Defect Analysis Report ties each defect to the detecting Fab Tool for root-cause analysis and corrective action planning.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:primaryWaferMapId rdf:type rdf:Property ;
    rdfs:label 'Primary Wafer Map Id' ;
    rdfs:comment 'FK to quality.wafer_map.wafer_map_id — Defects with X/Y coordinates must link to the wafer map for spatial analysis. This is critical for systematic defect pattern detection.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferMap .

ind:processRecipeId rdf:type rdf:Property ;
    rdfs:label 'Process Recipe Id' ;
    rdfs:comment 'Foreign key linking to process.recipe. Business justification: Defect analysis reports need the recipe used during the step to correlate process parameters with defect types.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recipe .

ind:zoneId rdf:type rdf:Property ;
    rdfs:label 'Zone Id' ;
    rdfs:comment 'Logical zone on the wafer used for density calculations.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferZone .

ind:binAssignment rdf:type rdf:Property ;
    rdfs:label 'Bin Assignment' ;
    rdfs:comment 'Pass/fail bin code assigned to the die (e.g., P, F1, F2).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectAreaUm2 rdf:type rdf:Property ;
    rdfs:label 'Defect Area Um2' ;
    rdfs:comment 'Calculated area of the defect in square micrometers.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectClassification rdf:type rdf:Property ;
    rdfs:label 'Defect Classification' ;
    rdfs:comment 'High-level classification of the defect (e.g., particle, patterning, etch).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDensityPerZone rdf:type rdf:Property ;
    rdfs:label 'Defect Density Per Zone' ;
    rdfs:comment 'Number of defects per unit area within the zone.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectLayer rdf:type rdf:Property ;
    rdfs:label 'Defect Layer' ;
    rdfs:comment 'Process layer where the defect was found.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectStatus rdf:type rdf:Property ;
    rdfs:label 'Defect Status' ;
    rdfs:comment 'Current workflow status of the defect record.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieX rdf:type rdf:Property ;
    rdfs:label 'Die X' ;
    rdfs:comment 'Column index of the die containing the defect on the wafer grid.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieY rdf:type rdf:Property ;
    rdfs:label 'Die Y' ;
    rdfs:comment 'Row index of the die containing the defect on the wafer grid.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:edgeExclusionZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Edge Exclusion Zone Flag' ;
    rdfs:comment 'Indicates whether the defect lies within the defined edge exclusion area.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flatNotchOrientation rdf:type rdf:Property ;
    rdfs:label 'Flat Notch Orientation' ;
    rdfs:comment 'Orientation of wafer flat or notch relative to the defect.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRecipe rdf:type rdf:Property ;
    rdfs:label 'Inspection Recipe' ;
    rdfs:comment 'Name of the inspection recipe or parameter set used.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Repeatability Flag' ;
    rdfs:comment 'True if the defect pattern repeats across multiple wafers.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:xCoordinate rdf:type rdf:Property ;
    rdfs:label 'X Coordinate' ;
    rdfs:comment 'Horizontal position of the defect on the wafer map (millimeters).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yCoordinate rdf:type rdf:Property ;
    rdfs:label 'Y Coordinate' ;
    rdfs:comment 'Vertical position of the defect on the wafer map (millimeters).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dppmRecordId rdf:type rdf:Property ;
    rdfs:label 'Dppm Record Id' ;
    rdfs:comment 'System-generated unique identifier for the DPPM record.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceIso9001 rdf:type rdf:Property ;
    rdfs:label 'Compliance Iso9001' ;
    rdfs:comment 'Compliance status of the record with ISO 9001 quality management requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectiveUnits rdf:type rdf:Property ;
    rdfs:label 'Defective Units' ;
    rdfs:comment 'Number of units returned by the customer that were identified as defective.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eightDReportReference rdf:type rdf:Property ;
    rdfs:label 'Eight D Report Reference' ;
    rdfs:comment 'Identifier of the associated 8-D problem-solving report.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Narrative description of the observed failure mode or defect.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKgdCertified rdf:type rdf:Property ;
    rdfs:label 'Is Kgd Certified' ;
    rdfs:comment 'Indicates whether the returned die was a Known Good Die (KGD) certified part.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kgdCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Kgd Certification Date' ;
    rdfs:comment 'Date on which the KGD certification was granted.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Preventive measures introduced to avoid recurrence of similar defects.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordNumber rdf:type rdf:Property ;
    rdfs:label 'Record Number' ;
    rdfs:comment 'Business identifier assigned to the DPPM record, used for external reference and tracking.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which the customer or supplier must respond to the notification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Shipment End Date' ;
    rdfs:comment 'Last calendar date of the shipment period covered by this DPPM record.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Start Date' ;
    rdfs:comment 'First calendar date of the shipment period covered by this DPPM record.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalUnitsShipped rdf:type rdf:Property ;
    rdfs:label 'Total Units Shipped' ;
    rdfs:comment 'Total number of units shipped to the customer during the shipment period.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Failure Analysis Report requires linking the analyst employee to the report for accountability and skill tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:failureNonconformanceReportId rdf:type rdf:Property ;
    rdfs:label 'Failure Nonconformance Report Id' ;
    rdfs:comment 'FK to quality.nonconformance_report.nonconformance_report_id — FA reports are triggered by non-conformances. FA description explicitly states \'Links to... nonconformance_report\'. This is a critical investigation-to-disposition link.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NonconformanceReport .

ind:failureRelatedNcrNonconformanceReportId rdf:type rdf:Property ;
    rdfs:label 'Failure Related Ncr Nonconformance Report Id' ;
    rdfs:comment 'Identifier of the linked non-conformance report, when the failure triggers a quality NCR.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NonconformanceReport .

ind:relatedFailureFailureAnalysisReportId rdf:type rdf:Property ;
    rdfs:label 'Related Failure Failure Analysis Report Id' ;
    rdfs:comment 'Identifier of the associated reliability failure record, if the analysis originates from a reliability test.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureAnalysisReport .

ind:reliabilityTestId rdf:type rdf:Property ;
    rdfs:label 'Reliability Test Id' ;
    rdfs:comment 'FK to quality.reliability_test.reliability_test_id — Failure analysis reports investigate failures detected during reliability testing. FA report description states \'Links to reliability_failure\' which is now merged into reliability_test.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReliabilityTest .

ind:analysisEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis End Timestamp' ;
    rdfs:comment 'Timestamp when the failure analysis investigation was completed.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analysisStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Start Timestamp' ;
    rdfs:comment 'Timestamp when the failure analysis investigation began.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analysisTechnique rdf:type rdf:Property ;
    rdfs:label 'Analysis Technique' ;
    rdfs:comment 'Primary analytical method(s) employed during the failure investigation.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureAnalysisReportStatus rdf:type rdf:Property ;
    rdfs:label 'Failure Analysis Report Status' ;
    rdfs:comment 'Current lifecycle status of the report.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureMechanism rdf:type rdf:Property ;
    rdfs:label 'Failure Mechanism' ;
    rdfs:comment 'Descriptive classification of the underlying failure mechanism (e.g., electromigration, latch-up, oxide breakdown).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureSeverity rdf:type rdf:Property ;
    rdfs:label 'Failure Severity' ;
    rdfs:comment 'Severity rating assigned to the failure based on impact and recurrence risk.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureSiteLocation rdf:type rdf:Property ;
    rdfs:label 'Failure Site Location' ;
    rdfs:comment 'Physical location on the die/wafer where the failure was observed (e.g., metal layer 3, die X12Y7).' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Business identifier assigned to the report (e.g., FA-2023-0012).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTitle rdf:type rdf:Property ;
    rdfs:label 'Report Title' ;
    rdfs:comment 'Human-readable title of the failure analysis report.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Category indicating the origin of the failure analysis request.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDescription rdf:type rdf:Property ;
    rdfs:label 'Sample Description' ;
    rdfs:comment 'Brief description of the physical sample(s) examined (e.g., wafer lot, die coordinates, package type).' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingEvidenceRefs rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence Refs' ;
    rdfs:comment 'Comma-separated list of file paths or identifiers for images, data files, and test logs that support the analysis.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwner rdf:type rdf:Property ;
    rdfs:label 'Action Owner' ;
    rdfs:comment 'Name or identifier of the person accountable for implementing the recommended action.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeOfFailure rdf:type rdf:Property ;
    rdfs:label 'Cause Of Failure' ;
    rdfs:comment 'Identified underlying cause(s) that could lead to the failure mode.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPlanReference rdf:type rdf:Property ;
    rdfs:label 'Control Plan Reference' ;
    rdfs:comment 'Identifier linking the FMEA to the relevant control plan document.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionRating rdf:type rdf:Property ;
    rdfs:label 'Detection Rating' ;
    rdfs:comment 'Numerical rating (1-10) indicating how likely the failure will be detected before it reaches the customer.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectionTechnique rdf:type rdf:Property ;
    rdfs:label 'Detection Technique' ;
    rdfs:comment 'Specific detection approach (e.g., visual inspection, automated metrology).' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Description' ;
    rdfs:comment 'Narrative describing how the failure can occur within the product or process.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaCode rdf:type rdf:Property ;
    rdfs:label 'Fmea Code' ;
    rdfs:comment 'Business-level code used to reference the FMEA in reports and change management systems.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaName rdf:type rdf:Property ;
    rdfs:label 'Fmea Name' ;
    rdfs:comment 'Human-readable name that identifies the FMEA, often reflecting the product or process it evaluates.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Fmea Record Status' ;
    rdfs:comment 'Lifecycle status of the FMEA record, tracking its progression from creation to retirement.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaScope rdf:type rdf:Property ;
    rdfs:label 'Fmea Scope' ;
    rdfs:comment 'Narrative defining the boundaries (product, process, geography) covered by the analysis.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaToQualification rdf:type rdf:Property ;
    rdfs:label 'Fmea To Qualification' ;
    rdfs:comment 'FK to quality.qualification_program.qualification_program_id — FMEAs feed into qualification programs. IATF 16949 requires FMEA linkage to qualification activities.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fmeaType rdf:type rdf:Property ;
    rdfs:label 'Fmea Type' ;
    rdfs:comment 'Indicates whether the record is a Design FMEA (DFMEA) or Process FMEA (PFMEA).' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceRating rdf:type rdf:Property ;
    rdfs:label 'Occurrence Rating' ;
    rdfs:comment 'Numerical rating (1-10) representing the probability that the failure mode will occur.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postActionRpn rdf:type rdf:Property ;
    rdfs:label 'Post Action Rpn' ;
    rdfs:comment 'Re-calculated risk priority number after corrective actions have been applied.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:potentialEffect rdf:type rdf:Property ;
    rdfs:label 'Potential Effect' ;
    rdfs:comment 'Explanation of the impact on the customer if the failure mode materializes.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Text describing the action(s) proposed to mitigate the identified failure mode.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedDesignItem rdf:type rdf:Property ;
    rdfs:label 'Related Design Item' ;
    rdfs:comment 'Reference to the specific IC design element, IP core, or component associated with the failure.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedProcessStep rdf:type rdf:Property ;
    rdfs:label 'Related Process Step' ;
    rdfs:comment 'Name or identifier of the manufacturing/process step where the failure is observed.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskPriorityNumber rdf:type rdf:Property ;
    rdfs:label 'Risk Priority Number' ;
    rdfs:comment 'Calculated risk priority number derived from severity, occurrence, and detection ratings.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Numerical rating (1-10) of the seriousness of the failure effect on the end customer.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionFabToolId rdf:type rdf:Property ;
    rdfs:label 'Inspection Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Inspection Lot Report requires linking each lot to the Fab Tool used for inspection to ensure traceability and compliance.' ;
    rdfs:domain ind:InspectionLot ;
