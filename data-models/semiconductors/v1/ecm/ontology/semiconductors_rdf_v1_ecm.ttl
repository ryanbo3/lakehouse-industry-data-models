ind:amortizationMethod rdf:type rdf:Property ;
    rdfs:label 'Amortization Method' ;
    rdfs:comment 'Method used to calculate periodic amortization amounts.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationCategory rdf:type rdf:Property ;
    rdfs:label 'Depreciation Category' ;
    rdfs:comment 'Category that determines the accounting treatment of the amortization.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodAmount rdf:type rdf:Property ;
    rdfs:label 'Period Amount' ;
    rdfs:comment 'Amortization charge allocated to the specific period.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential number of the period within the schedule (e.g., 1 for first month).' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Frequency of amortization periods (e.g., monthly, quarterly, annually).' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'External business identifier assigned to the amortization schedule (e.g., schedule reference code).' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the schedule.' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the schedule based on the nature of the underlying cost (e.g., asset, lease, R&D).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxEffectFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Effect Flag' ;
    rdfs:comment 'Indicates whether the amortization amount has tax implications (true = tax effect).' ;
    rdfs:domain ind:AmortizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Legal Entity Id' ;
    rdfs:comment 'Identifier of the immediate parent entity in a corporate hierarchy, if applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:ultimateParentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Ultimate Parent Legal Entity Id' ;
    rdfs:comment 'Identifier of the top-most parent entity in the corporate structure.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Fiscal year total revenue reported in the entity\'s reporting currency.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'ISO 3166-1 alpha-3 code of the jurisdiction where the entity was incorporated.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Alternate trade name under which the entity conducts business.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date the entity ceased to exist, if applicable.' ;
    rdfs:domain ind:LegalEntity ;
