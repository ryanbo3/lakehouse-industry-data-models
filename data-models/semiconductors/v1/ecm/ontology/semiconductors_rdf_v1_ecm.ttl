    rdfs:range xsd:string .

ind:overallStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Status' ;
    rdfs:comment 'Aggregated result of the qualification program.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programBudgetUsd rdf:type rdf:Property ;
