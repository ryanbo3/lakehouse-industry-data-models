    rdfs:comment 'Maximum temperature applied during the stress phase, expressed in degrees Celsius.' ;
    rdfs:domain ind:ReliabilityTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressVoltageV rdf:type rdf:Property ;
    rdfs:label 'Stress Voltage V' ;
