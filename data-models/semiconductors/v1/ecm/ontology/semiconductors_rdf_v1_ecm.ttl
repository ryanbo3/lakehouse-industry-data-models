    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isChannelConflict rdf:type rdf:Property ;
    rdfs:label 'Is Channel Conflict' ;
    rdfs:comment 'True if the registration was flagged for potential double-claiming.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPriceProtected rdf:type rdf:Property ;
    rdfs:label 'Is Price Protected' ;
    rdfs:comment 'True if the registration includes protected pricing terms.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protectedPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Protected Price Usd' ;
    rdfs:comment 'Unit price that is protected for the duration of the registration, expressed in US dollars.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
