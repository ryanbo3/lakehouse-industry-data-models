    rdfs:comment 'Description of the die site arrangement on the wafer for this probe card.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceCycleMonths rdf:type rdf:Property ;
