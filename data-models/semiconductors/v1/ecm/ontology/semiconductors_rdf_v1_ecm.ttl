    rdfs:comment 'Orientation of the wafer flat/notch relative to the map coordinate system.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kgdCertificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Kgd Certification Timestamp' ;
    rdfs:comment 'Timestamp when KGD certification was applied.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mapChecksum rdf:type rdf:Property ;
    rdfs:label 'Map Checksum' ;
    rdfs:comment 'Checksum (e.g., SHA-256) of the map file for integrity verification.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapFilePath rdf:type rdf:Property ;
    rdfs:label 'Map File Path' ;
    rdfs:comment 'File system path or URI where the wafer map image/file is stored.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Map Generation Timestamp' ;
    rdfs:comment 'Date and time when the wafer map was generated.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mapStatus rdf:type rdf:Property ;
    rdfs:label 'Map Status' ;
    rdfs:comment 'Current processing status of the wafer map.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapVersion rdf:type rdf:Property ;
    rdfs:label 'Map Version' ;
    rdfs:comment 'Version identifier of the map generation algorithm or software.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passBinCode rdf:type rdf:Property ;
    rdfs:label 'Pass Bin Code' ;
    rdfs:comment 'Bin code representing passing (good) dies.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingDieCount rdf:type rdf:Property ;
    rdfs:label 'Passing Die Count' ;
    rdfs:comment 'Number of dies classified as passing.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDieCount rdf:type rdf:Property ;
    rdfs:label 'Total Die Count' ;
    rdfs:comment 'Total number of dies evaluated on the wafer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binDistributionSummary rdf:type rdf:Property ;
    rdfs:label 'Bin Distribution Summary' ;
    rdfs:comment 'Compact representation (e.g., JSON) of die bin counts across test bins.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabLine rdf:type rdf:Property ;
    rdfs:label 'Fab Line' ;
    rdfs:comment 'Production line identifier within the fab.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSystem rdf:type rdf:Property ;
    rdfs:label 'Inspection System' ;
    rdfs:comment 'Name of the inspection/metrology system used (e.g., KLA ICOS).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotHumidityPercent rdf:type rdf:Property ;
    rdfs:label 'Lot Humidity Percent' ;
    rdfs:comment 'Relative humidity of the fab environment during measurement.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Lot Temperature C' ;
    rdfs:comment 'Average temperature of the wafer lot during measurement.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementStage rdf:type rdf:Property ;
    rdfs:label 'Measurement Stage' ;
    rdfs:comment 'Quality gate at which the yield was measured.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGate rdf:type rdf:Property ;
    rdfs:label 'Quality Gate' ;
    rdfs:comment 'Specific quality gate where the measurement was recorded.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileName rdf:type rdf:Property ;
    rdfs:label 'Source File Name' ;
    rdfs:comment 'Name of the source file or data feed that supplied the measurement.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Test Time Seconds' ;
    rdfs:comment 'Total time taken to perform the yield test.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toolSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Tool Serial Number' ;
    rdfs:comment 'Serial number of the measurement tool.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldGapPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Gap Percent' ;
    rdfs:comment 'Difference between actual yield and target yield.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossCategory rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Category' ;
    rdfs:comment 'Root cause classification for yield loss.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Yield Record Status' ;
    rdfs:comment 'Current validation status of the yield record.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Id' ;
    rdfs:comment 'Primary key for budget_allocation' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBudgetPrincipalInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Principal Investigator Employee Id' ;
    rdfs:comment 'The employee identifier of the principal investigator responsible for the funded work.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryBudgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Budget Employee Id' ;
    rdfs:comment 'The user identifier of the person who last modified this budget allocation record.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Code' ;
    rdfs:comment 'Business-readable unique code for the budget allocation, used for tracking and reporting purposes.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationName rdf:type rdf:Property ;
    rdfs:label 'Allocation Name' ;
    rdfs:comment 'Descriptive name of the budget allocation identifying the purpose or initiative being funded.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Name' ;
    rdfs:comment 'The name of the individual or committee that approved this budget allocation.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardAmount rdf:type rdf:Property ;
    rdfs:label 'Award Amount' ;
    rdfs:comment 'The total monetary amount awarded or allocated for this budget allocation.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'The date on which the funding award was officially granted or approved.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetForProgram rdf:type rdf:Property ;
    rdfs:label 'Budget For Program' ;
    rdfs:comment 'FK to research.program.program_id — Budget allocations fund R&D programs. Critical for financial tracking, CHIPS Act compliance reporting, and program cost management.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetFundsProgram rdf:type rdf:Property ;
    rdfs:label 'Budget Funds Program' ;
    rdfs:comment 'FK to research.program.program_id — Budget allocations are assigned to R&D programs (and their constituent projects). This is essential for financial tracking and CHIPS Act compliance reporting.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Budget Period End Date' ;
    rdfs:comment 'The end date of the budget allocation period.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Budget Period Start Date' ;
    rdfs:comment 'The start date of the budget allocation period.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chipsActAwardNumber rdf:type rdf:Property ;
    rdfs:label 'Chips Act Award Number' ;
    rdfs:comment 'The official CHIPS Act award number assigned by the granting agency, if applicable.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chipsActComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Chips Act Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this budget allocation is subject to CHIPS Act compliance requirements.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collaborationPartnerName rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partner Name' ;
    rdfs:comment 'The name of external collaboration partners (universities, research institutions, consortia) involved in the funded work, if applicable.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationsDescription rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligations Description' ;
    rdfs:comment 'Description of compliance obligations associated with this funding, including CHIPS Act requirements, ITAR, EAR, and other regulatory constraints.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverables Description' ;
    rdfs:comment 'Description of the expected deliverables and milestones associated with this budget allocation.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSourceType rdf:type rdf:Property ;
    rdfs:label 'Funding Source Type' ;
    rdfs:comment 'The type of funding source for this budget allocation.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantProgramName rdf:type rdf:Property ;
    rdfs:label 'Grant Program Name' ;
    rdfs:comment 'The specific name of the grant program under which funding is provided (e.g., CHIPS for America R&D Program, DARPA ERI).' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantType rdf:type rdf:Property ;
    rdfs:label 'Grant Type' ;
    rdfs:comment 'The type of government grant or funding mechanism (e.g., direct funding, tax credit, matching fund, equipment grant).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Granting Agency Name' ;
    rdfs:comment 'The name of the government or external agency providing the grant funding, if applicable (e.g., DARPA, NSF, DOE, CHIPS Act office).' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performancePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period End Date' ;
    rdfs:comment 'The end date of the performance period during which the funded work must be completed.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performancePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period Start Date' ;
    rdfs:comment 'The start date of the performance period during which the funded work must be completed.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingRequirementsDescription rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirements Description' ;
    rdfs:comment 'Description of the reporting requirements and frequency mandated by the funding source or internal governance.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Level' ;
    rdfs:comment 'The strategic priority level assigned to this budget allocation by executive leadership.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Technical Scope Description' ;
    rdfs:comment 'Detailed description of the technical scope and objectives covered by this budget allocation.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterizationResultId rdf:type rdf:Property ;
    rdfs:label 'Characterization Result Id' ;
    rdfs:comment 'Unique identifier for the characterization result record. Primary key for R&D electrical and physical characterization measurement results from research test structures, Process Control Vehicles (PCVs), and experimental devices.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characterizationExperimentalLotId rdf:type rdf:Property ;
    rdfs:label 'Characterization Experimental Lot Id' ;
    rdfs:comment 'FK to research.experimental_lot.experimental_lot_id — Characterization measurements are performed on wafers from experimental lots. Essential for tracing measurement results back to process conditions.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExperimentalLot .

ind:experimentId rdf:type rdf:Property ;
    rdfs:label 'Experiment Id' ;
    rdfs:comment 'Identifier for the R&D experiment or proof-of-concept project to which this characterization belongs. Links characterization results to broader research initiatives and technology roadmap milestones.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessFlowExperiment .

ind:primaryExperimentalLotId rdf:type rdf:Property ;
    rdfs:label 'Primary Experimental Lot Id' ;
    rdfs:comment 'FK to research.experimental_lot.experimental_lot_id — Characterization measurements are performed on wafers from experimental lots. Without this link, you cannot trace measurement results back to the process conditions that produced them — breaking the f' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExperimentalLot .

ind:processSplitId rdf:type rdf:Property ;
    rdfs:label 'Process Split Id' ;
    rdfs:comment 'Identifier for the specific process split or experimental condition being evaluated. Used in Design of Experiments (DOE) to track variations in materials, recipes, or process sequences.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessSplit .

ind:testStructureId rdf:type rdf:Property ;
    rdfs:label 'Test Structure Id' ;
    rdfs:comment 'Identifier for the specific test structure or device under test (DUT) on the wafer. May reference Process Control Vehicle (PCV) structures, experimental device patterns, or dedicated characterization sites.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestStructure .

ind:correctiveActionProposed rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Proposed' ;
    rdfs:comment 'Proposed corrective actions to address identified yield limiters or parametric issues. May include process recipe changes, equipment maintenance, design rule modifications, or material substitutions.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataFilePath rdf:type rdf:Property ;
    rdfs:label 'Data File Path' ;
    rdfs:comment 'File system path or object storage location of the raw measurement data file. For curve measurements (IV, CV) or imaging data (TEM, AFM), points to the detailed data set for further analysis.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Die Yield Percent' ;
    rdfs:comment 'Percentage of functional dies on the wafer that pass all characterization tests. Represents the ratio of Known Good Die (KGD) to total dies tested.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dominantYieldDetractor rdf:type rdf:Property ;
    rdfs:label 'Dominant Yield Detractor' ;
    rdfs:comment 'Primary defect type or failure mode contributing most significantly to yield loss. Identified through Pareto analysis of defect types and failure modes.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Functional Yield Percent' ;
    rdfs:comment 'Percentage of dies that pass functional testing, demonstrating correct logical operation. Subset of die yield focusing on functional correctness rather than parametric performance.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:learningCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Learning Cycle Number' ;
    rdfs:comment 'Sequential number identifying the learning cycle or iteration in which this characterization was performed. Tracks progression through Design of Experiments (DOE) and process optimization cycles.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementCondition rdf:type rdf:Property ;
    rdfs:label 'Measurement Condition' ;
    rdfs:comment 'Environmental and operational conditions under which the measurement was performed. Includes temperature, voltage bias, frequency, ambient conditions, and test mode settings that affect measurement results.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementEquipmentCode rdf:type rdf:Property ;
    rdfs:label 'Measurement Equipment Code' ;
    rdfs:comment 'Identifier for the Automatic Test Equipment (ATE) or characterization tool used to perform the measurement. Includes parametric testers, probe stations, analytical microscopes, and metrology systems.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parametricYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Parametric Yield Percent' ;
    rdfs:comment 'Percentage of dies that meet all parametric specifications (timing, power, voltage, current). Subset of die yield focusing on performance parameters within specification limits.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdkCalibrationFlag rdf:type rdf:Property ;
    rdfs:label 'Pdk Calibration Flag' ;
    rdfs:comment 'Boolean flag indicating whether this characterization result is used for Process Design Kit (PDK) model calibration. PDK calibration data feeds SPICE models and design rules for IC design tools.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reliabilityStressType rdf:type rdf:Property ;
    rdfs:label 'Reliability Stress Type' ;
    rdfs:comment 'Type of reliability stress testing applied before or during characterization. Includes HTOL (High Temperature Operating Life), LTOL (Low Temperature Operating Life), HAST (Highly Accelerated Stress Test), THB (Temperature Humidity Bias), TC (Temperature Cycling), HCI (Hot Carrier Injection), NBTI (Negative Bias Temperature Instability), PBTI (Positive Bias Temperature Instability), TDDB (Time-Dependent Dielectric Breakdown), EM (Electromigration), SM (Stress Migration). [ENUM-REF-CANDIDATE: none|htol|ltol|hast|thb|tc|hci|nbti|pbti|tddb|em|sm — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldImprovementDelta rdf:type rdf:Property ;
    rdfs:label 'Yield Improvement Delta' ;
    rdfs:comment 'Measured improvement in yield percentage achieved after implementing corrective actions. Quantifies the effectiveness of yield learning and process optimization efforts.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLimitingMechanism rdf:type rdf:Property ;
    rdfs:label 'Yield Limiting Mechanism' ;
    rdfs:comment 'Identified root cause or mechanism that is limiting yield performance. Examples include random defects, systematic pattern issues, parametric drift, edge exclusion, or specific process step failures.' ;
    rdfs:domain ind:CharacterizationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationId rdf:type rdf:Property ;
    rdfs:label 'Collaboration Id' ;
    rdfs:comment 'Primary key for collaboration' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Collaboration .

ind:primaryTechnicalContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Technical Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Collaboration agreements require a designated employee contact for technical coordination and reporting.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backgroundIpIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Background Ip Included Flag' ;
    rdfs:comment 'Indicates whether the collaboration agreement includes access to or licensing of pre-existing background intellectual property from either party.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collaborationCode rdf:type rdf:Property ;
    rdfs:label 'Collaboration Code' ;
    rdfs:comment 'Unique business identifier or reference code for the collaboration agreement used in external communications and internal tracking systems.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationName rdf:type rdf:Property ;
    rdfs:label 'Collaboration Name' ;
    rdfs:comment 'Official name or title of the research collaboration agreement.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationStatus rdf:type rdf:Property ;
    rdfs:label 'Collaboration Status' ;
    rdfs:comment 'Current lifecycle state of the research collaboration agreement.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationType rdf:type rdf:Property ;
    rdfs:label 'Collaboration Type' ;
    rdfs:comment 'Classification of the research collaboration arrangement. Defines the nature of the partnership relationship.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'Data classification level governing information sharing and disclosure restrictions under the collaboration agreement.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiumName rdf:type rdf:Property ;
    rdfs:label 'Consortium Name' ;
    rdfs:comment 'Name of the research consortium if the collaboration is conducted through a multi-party consortium (e.g., imec, SEMATECH, Fraunhofer). Nullable for bilateral collaborations.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Legal contract or master agreement reference number for the collaboration. Links to the formal legal document repository.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSharingPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Percentage' ;
    rdfs:comment 'Percentage of total research costs borne by the company under cost-sharing arrangements. Expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverablesSchedule rdf:type rdf:Property ;
    rdfs:label 'Deliverables Schedule' ;
    rdfs:comment 'Structured description or reference to the timeline and milestones for research deliverables, reports, prototypes, or technology transfer activities defined in the collaboration agreement.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractual mechanism for resolving disputes arising from the collaboration agreement.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Contribution Amount' ;
    rdfs:comment 'Total financial contribution committed by the company to the research collaboration, expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Funding Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the funding contribution amount.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law specified in the collaboration agreement for contract interpretation and enforcement.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentProgramName rdf:type rdf:Property ;
    rdfs:label 'Government Program Name' ;
    rdfs:comment 'Name of the government research program or funding initiative if the collaboration is part of a public-sector research program (e.g., CHIPS Act funded research). Nullable for private collaborations.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipTerms rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Terms' ;
    rdfs:comment 'Contractual terms defining ownership, licensing rights, and usage rights for intellectual property generated through the collaboration. Critical for patent filing and technology commercialization decisions.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jointPatentFilingTerms rdf:type rdf:Property ;
    rdfs:label 'Joint Patent Filing Terms' ;
    rdfs:comment 'Terms governing joint patent filing procedures, cost allocation, and prosecution responsibilities for inventions arising from the collaboration.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Nda Reference Number' ;
    rdfs:comment 'Reference number or identifier for the associated non-disclosure agreement governing confidential information exchange under the collaboration.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Partner Institution Name' ;
    rdfs:comment 'Name of the external research partner organization (university, national laboratory, research consortium, or government research program).' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTechnicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Partner Technical Contact Email' ;
    rdfs:comment 'Email address of the external partner\'s primary technical contact for the collaboration.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTechnicalContactName rdf:type rdf:Property ;
    rdfs:label 'Partner Technical Contact Name' ;
    rdfs:comment 'Name of the external partner\'s technical lead or principal investigator responsible for the collaboration.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationRights rdf:type rdf:Property ;
    rdfs:label 'Publication Rights' ;
    rdfs:comment 'Terms governing the right to publish research findings, present at conferences, or disclose results publicly. Defines pre-publication review requirements and embargo periods.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the collaboration agreement includes an option for renewal or extension beyond the initial term.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:researchScope rdf:type rdf:Property ;
    rdfs:label 'Research Scope' ;
    rdfs:comment 'Detailed description of the research objectives, technical focus areas, and deliverables covered by the collaboration agreement. May include process node development, device architecture research, packaging technologies, or materials research.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyFocusArea rdf:type rdf:Property ;
    rdfs:label 'Technology Focus Area' ;
    rdfs:comment 'Primary technology domain or research area targeted by the collaboration. Aligns with semiconductor technology roadmap categories. [ENUM-REF-CANDIDATE: process_node_development|finfet_architecture|gaa_architecture|cfet_architecture|advanced_packaging|materials_research|ip_core_development|euv_lithography|beol_interconnect|feol_device|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark Id' ;
    rdfs:comment 'Primary key for competitive_benchmark' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benchmarkCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Code' ;
    rdfs:comment 'Business identifier code for the competitive benchmark analysis, used for external reference and tracking.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkDate rdf:type rdf:Property ;
    rdfs:label 'Benchmark Date' ;
    rdfs:comment 'Date when the competitive benchmark analysis was conducted or published.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benchmarkMethodology rdf:type rdf:Property ;
    rdfs:label 'Benchmark Methodology' ;
    rdfs:comment 'Detailed description of the methodology used to conduct the competitive benchmark, including measurement techniques, test conditions, and analytical approaches.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkName rdf:type rdf:Property ;
    rdfs:label 'Benchmark Name' ;
    rdfs:comment 'Descriptive name of the competitive benchmark analysis, typically including the technology node or device architecture being compared.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkSourceReference rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source Reference' ;
    rdfs:comment 'Detailed citation or reference to the source document, publication, or analysis from which the benchmark data was derived.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkSourceType rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source Type' ;
    rdfs:comment 'The type of source from which the competitive benchmark data was obtained, such as public disclosure, teardown analysis, academic paper, or industry report.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkStatus rdf:type rdf:Property ;
    rdfs:label 'Benchmark Status' ;
    rdfs:comment 'Current lifecycle status of the competitive benchmark record, indicating whether it is in draft, under review, approved for use, or archived.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveGapAnalysis rdf:type rdf:Property ;
    rdfs:label 'Competitive Gap Analysis' ;
    rdfs:comment 'Assessment of the performance gap between internal technology capabilities and competitor offerings, identifying areas of advantage or disadvantage.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the competitor company or foundry whose technology is being benchmarked against internal capabilities.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorProductName rdf:type rdf:Property ;
    rdfs:label 'Competitor Product Name' ;
    rdfs:comment 'Specific product, chip, or technology offering from the competitor that is the subject of this benchmark.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Assessment of the confidence level in the benchmark data accuracy and reliability, based on source quality and verification methods.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Numerical score from 1 to 100 representing the overall quality and reliability of the benchmark data, based on source credibility and verification.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceArchitectureType rdf:type rdf:Property ;
    rdfs:label 'Device Architecture Type' ;
    rdfs:comment 'Type of transistor or device architecture being benchmarked, such as FinFET (Fin Field-Effect Transistor), GAA (Gate All Around), CFET (Complementary FET), or other advanced structures. [ENUM-REF-CANDIDATE: FinFET|GAA|CFET|Planar|Nanowire|Nanosheet|FDSOI|Other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveCurrentUaPerUm rdf:type rdf:Property ;
    rdfs:label 'Drive Current Ua Per Um' ;
    rdfs:comment 'On-state drive current of the competitor device normalized per unit width, measured in microamperes per micrometer, indicating performance capability.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leakageCurrentNaPerUm rdf:type rdf:Property ;
    rdfs:label 'Leakage Current Na Per Um' ;
    rdfs:comment 'Off-state leakage current of the competitor device normalized per unit width, measured in nanoamperes per micrometer, indicating power efficiency.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingFrequencyGhz rdf:type rdf:Property ;
    rdfs:label 'Operating Frequency Ghz' ;
    rdfs:comment 'Maximum operating frequency of the competitor technology in gigahertz, a key performance metric.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppaAreaScore rdf:type rdf:Property ;
    rdfs:label 'Ppa Area Score' ;
    rdfs:comment 'Area efficiency score for the competitor technology based on PPA analysis, normalized to a standard scale.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppaPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Ppa Performance Score' ;
    rdfs:comment 'Composite performance score for the competitor technology based on Power, Performance, and Area metrics, normalized to a standard scale.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppaPowerScore rdf:type rdf:Property ;
    rdfs:label 'Ppa Power Score' ;
    rdfs:comment 'Power efficiency score for the competitor technology based on PPA analysis, normalized to a standard scale.' ;
    rdfs:domain ind:CompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicImplicationAssessment rdf:type rdf:Property ;
    rdfs:label 'Strategic Implication Assessment' ;
    rdfs:comment 'Analysis of the strategic implications of the benchmark findings for internal technology roadmap decisions, competitive positioning, and investment priorities.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transistorDensityMtransistorsPerMm2 rdf:type rdf:Property ;
    rdfs:label 'Transistor Density Mtransistors Per Mm2' ;
    rdfs:comment 'Measured or estimated transistor density of the competitor technology in millions of transistors per square millimeter, a key metric for area efficiency.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryDeviceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Device Employee Id' ;
    rdfs:comment 'Foreign key reference to the principal investigator or lead researcher responsible for this architecture development.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:architectureCode rdf:type rdf:Property ;
    rdfs:label 'Architecture Code' ;
    rdfs:comment 'Unique alphanumeric code or designation assigned to the architecture for internal tracking and reference in research documentation.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:architectureMaturityLevel rdf:type rdf:Property ;
    rdfs:label 'Architecture Maturity Level' ;
    rdfs:comment 'Technical maturity classification: concept (paper design), simulated (TCAD/EDA validated), fabricated (physical samples exist), characterized (electrical/physical data collected), or qualified (reliability and performance validated for target application).' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:architectureName rdf:type rdf:Property ;
    rdfs:label 'Architecture Name' ;
    rdfs:comment 'Human-readable name of the device or packaging architecture (e.g., 3nm GAA FET, CoWoS-S 2.5D Integration, InFO-AiP).' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:architectureStatus rdf:type rdf:Property ;
    rdfs:label 'Architecture Status' ;
    rdfs:comment 'Current lifecycle status of the architecture research project: active (ongoing R&D), on hold (paused), cancelled (discontinued), completed (research concluded), or transferred to production (handed off to manufacturing).' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:architectureTargetsNode rdf:type rdf:Property ;
    rdfs:label 'Architecture Targets Node' ;
    rdfs:comment 'FK to research.technology_node.technology_node_id — Device architectures are developed for target technology nodes. Essential for tracking which architectures apply to which process generations.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:architectureType rdf:type rdf:Property ;
    rdfs:label 'Architecture Type' ;
    rdfs:comment 'Classification of the architecture as either device-level (transistor/gate structures) or packaging-level (chip integration and interconnect).' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedExperimentalLotIds rdf:type rdf:Property ;
    rdfs:label 'Associated Experimental Lot Ids' ;
    rdfs:comment 'Comma-separated list of experimental wafer lot IDs or MPW shuttle IDs used to fabricate and test this architecture.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelLengthNm rdf:type rdf:Property ;
    rdfs:label 'Channel Length Nm' ;
    rdfs:comment 'For device architectures, the effective channel length of the transistor in nanometers, critical for electrical performance and short-channel effects.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collaborationPartner rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partner' ;
    rdfs:comment 'Name of external research institution, university, consortium, or industry partner collaborating on the development of this architecture.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptDate rdf:type rdf:Property ;
    rdfs:label 'Concept Date' ;
    rdfs:comment 'Date when the architecture concept was first proposed or documented in the research pipeline.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:developmentMaturityStage rdf:type rdf:Property ;
    rdfs:label 'Development Maturity Stage' ;
    rdfs:comment 'Current stage in the research and development lifecycle: concept (ideation), simulation (modeling), proof-of-concept (lab demonstration), prototype (experimental wafer), pilot (limited production), qualification (reliability testing), or production-ready (transfer to manufacturing). [ENUM-REF-CANDIDATE: concept|simulation|proof_of_concept|prototype|pilot|qualification|production_ready — promote to reference product]' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceStructureCategory rdf:type rdf:Property ;
    rdfs:label 'Device Structure Category' ;
    rdfs:comment 'For device architectures, the fundamental transistor or gate structure type: FinFET (Fin Field-Effect Transistor), GAA (Gate-All-Around), CFET (Complementary FET), FDSOI (Fully Depleted Silicon on Insulator), planar, or other novel structures.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTimeToMarketMonths rdf:type rdf:Property ;
    rdfs:label 'Estimated Time To Market Months' ;
    rdfs:comment 'Estimated number of months from current maturity stage to production readiness and market introduction, based on R&D project plan.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabricationComplexityRating rdf:type rdf:Property ;
    rdfs:label 'Fabrication Complexity Rating' ;
    rdfs:comment 'Qualitative assessment of the manufacturing complexity and process control requirements: low, medium, high, very high, or extreme, based on number of critical layers, process steps, and yield risk.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finWidthNm rdf:type rdf:Property ;
    rdfs:label 'Fin Width Nm' ;
    rdfs:comment 'For FinFET or GAA device architectures, the width of the fin or nanosheet structure in nanometers.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstFabricationDate rdf:type rdf:Property ;
    rdfs:label 'First Fabrication Date' ;
    rdfs:comment 'Date when the first experimental wafer lot incorporating this architecture was started in the fabrication facility or foundry.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:integrationApproach rdf:type rdf:Property ;
    rdfs:label 'Integration Approach' ;
    rdfs:comment 'For packaging architectures, the dimensional integration strategy: 2.5D (side-by-side on interposer), 3D (vertical stacking), fan-out (redistribution layer), chiplet (modular die integration), monolithic, or hybrid approaches.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interconnectDensityTarget rdf:type rdf:Property ;
    rdfs:label 'Interconnect Density Target' ;
    rdfs:comment 'For packaging architectures, the target interconnect density specification (e.g., bump pitch, TSV density, redistribution layer line/space) expressed as a dimensional or density metric.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Status' ;
    rdfs:comment 'Ownership and licensing status of the intellectual property associated with this architecture: proprietary (fully owned), joint (co-developed), licensed (from third party), open (non-proprietary), or pending (patent application in progress).' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyTechnicalChallenges rdf:type rdf:Property ;
    rdfs:label 'Key Technical Challenges' ;
    rdfs:comment 'Narrative description of the primary technical challenges and risks associated with this architecture, such as process variability, defect density, thermal management, electromigration, or integration yield.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsInnovationFlag rdf:type rdf:Property ;
    rdfs:label 'Materials Innovation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this architecture incorporates novel materials research (e.g., high-k dielectrics, 2D materials, new interconnect metals, advanced substrates).' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentFilingReference rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Reference' ;
    rdfs:comment 'Reference number or identifier for associated patent filings or IP disclosures related to this architecture.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerPerformanceAreaTarget rdf:type rdf:Property ;
    rdfs:label 'Power Performance Area Target' ;
    rdfs:comment 'Composite target specification for Power, Performance, and Area trade-offs, expressed as a qualitative or quantitative goal (e.g., 30% power reduction at iso-performance, 2x density improvement).' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuralDescription rdf:type rdf:Property ;
    rdfs:label 'Structural Description' ;
    rdfs:comment 'Detailed technical description of the architecture\'s physical structure, layer composition, material stack, gate configuration, interconnect topology, or integration methodology.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetApplicationDomains rdf:type rdf:Property ;
    rdfs:label 'Target Application Domains' ;
    rdfs:comment 'Comma-separated list of intended application domains for this architecture (e.g., HPC, AI accelerator, mobile SoC, automotive, IoT, edge computing, data center).' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTechnologyNodeNm rdf:type rdf:Property ;
    rdfs:label 'Target Technology Node Nm' ;
    rdfs:comment 'The target process technology node in nanometers (e.g., 3, 5, 7, 10) for which this device architecture is being developed. Null for packaging architectures not tied to a specific node.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technologyRoadmapAlignment rdf:type rdf:Property ;
    rdfs:label 'Technology Roadmap Alignment' ;
    rdfs:comment 'Reference to the internal technology roadmap phase or milestone that this architecture supports (e.g., N3 Roadmap, Advanced Packaging Phase 2, Next-Gen AI Platform).' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thermalPerformanceTargetWCm2 rdf:type rdf:Property ;
    rdfs:label 'Thermal Performance Target W Cm2' ;
    rdfs:comment 'Target thermal dissipation capability or power density handling in watts per square centimeter, critical for high-performance and AI accelerator applications.' ;
    rdfs:domain ind:DeviceArchitecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:experimentalProjectId rdf:type rdf:Property ;
    rdfs:label 'Experimental Project Id' ;
    rdfs:comment 'FK to research.project.project_id — Experimental lots are created to execute specific research projects. This FK is essential for tracing which lots belong to which project, enabling project-level cost tracking and outcome assessment.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:experimentalResearchProjectId rdf:type rdf:Property ;
    rdfs:label 'Experimental Research Project Id' ;
    rdfs:comment 'Reference to the parent research and development project that this experimental lot supports. Links lot to technology roadmap and innovation initiatives.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'Actual total cost in US Dollars incurred for processing this experimental lot, captured after completion. Business-confidential financial data.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCollectionPlan rdf:type rdf:Property ;
    rdfs:label 'Data Collection Plan' ;
    rdfs:comment 'Description of the metrology, inspection, and test data collection strategy for this experimental lot. Defines what measurements will be taken, at which process steps, and with what frequency to support research objectives.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Usd' ;
    rdfs:comment 'Estimated total cost in US Dollars for processing this experimental lot, including materials, equipment time, labor, and overhead. Business-confidential financial data.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:experimentalOutcomeStatus rdf:type rdf:Property ;
    rdfs:label 'Experimental Outcome Status' ;
    rdfs:comment 'Assessment of the experimental lot results: pending (evaluation not yet complete), successful (met all research objectives), partially successful (met some objectives), failed (did not meet objectives), or inconclusive (results require further investigation).' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabLineAssignment rdf:type rdf:Property ;
    rdfs:label 'Fab Line Assignment' ;
    rdfs:comment 'Identifier of the fabrication line or pilot line where this experimental lot is processed. Research lots often use dedicated R&D fab lines or pilot production facilities separate from high-volume manufacturing.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipFilingReference rdf:type rdf:Property ;
    rdfs:label 'Ip Filing Reference' ;
    rdfs:comment 'Reference number or identifier for any patent application, invention disclosure, or IP filing associated with the innovations tested in this experimental lot. Restricted due to pre-publication IP sensitivity.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isArchived rdf:type rdf:Property ;
    rdfs:label 'Is Archived' ;
    rdfs:comment 'Boolean flag indicating whether this experimental lot record has been archived for historical reference. True if archived and no longer actively referenced in operational systems; False if active or recently completed.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotToProject rdf:type rdf:Property ;
    rdfs:label 'Lot To Project' ;
    rdfs:comment 'FK to research.research_project.research_project_id — Every experimental lot is created for a specific research project. This links physical fabrication activity to the project that authorized and funded it.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mesSystemReference rdf:type rdf:Property ;
    rdfs:label 'Mes System Reference' ;
    rdfs:comment 'Reference identifier linking this experimental lot record to the corresponding lot record in the Camstar MES system for wafer tracking and real-time fab operations integration.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Name' ;
    rdfs:comment 'Name of the lead researcher or engineer responsible for this experimental lot and its associated research objectives. Business-confidential to protect internal R&D organization structure.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchNotes rdf:type rdf:Property ;
    rdfs:label 'Research Notes' ;
    rdfs:comment 'Free-text field for capturing detailed research observations, experimental conditions, anomalies, and insights discovered during lot processing. Business-confidential to protect proprietary research findings.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapReason rdf:type rdf:Property ;
    rdfs:label 'Scrap Reason' ;
    rdfs:comment 'Description of the reason why this experimental lot was scrapped, if applicable. Examples: catastrophic process failure, contamination, equipment damage, or project cancellation. Null if lot was not scrapped.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Split Condition Description' ;
    rdfs:comment 'Detailed description of split-lot experimental conditions where different wafers within the lot receive different process parameters, materials, or sequences to enable comparative analysis. Null if lot is not split.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitCount rdf:type rdf:Property ;
    rdfs:label 'Split Count' ;
    rdfs:comment 'Number of distinct experimental splits or conditions applied within this lot. Value of 1 indicates uniform processing; values greater than 1 indicate split-lot design.' ;
    rdfs:domain ind:ExperimentalLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetDeviceStructure rdf:type rdf:Property ;
    rdfs:label 'Target Device Structure' ;
    rdfs:comment 'Description of the novel device architecture or structure being developed in this experimental lot. Examples: FinFET (Fin Field-Effect Transistor), GAA (Gate-All-Around), CFET (Complementary FET), MRAM (Magnetoresistive RAM), or other emerging device types.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentGrantId rdf:type rdf:Property ;
    rdfs:label 'Government Grant Id' ;
    rdfs:comment 'System-generated unique identifier for the government grant record.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardingAgency rdf:type rdf:Property ;
    rdfs:label 'Awarding Agency' ;
    rdfs:comment 'Name of the government agency providing the grant.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligations rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligations' ;
    rdfs:comment 'Regulatory and export-control obligations attached to the grant.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentGrantStatus rdf:type rdf:Property ;
    rdfs:label 'Government Grant Status' ;
    rdfs:comment 'Current lifecycle status of the grant.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantCategory rdf:type rdf:Property ;
    rdfs:label 'Grant Category' ;
    rdfs:comment 'High-level classification of the grant purpose.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'External reference number assigned by the granting agency.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantTitle rdf:type rdf:Property ;
    rdfs:label 'Grant Title' ;
    rdfs:comment 'Official title of the grant as recorded in the award documentation.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantToProgram rdf:type rdf:Property ;
    rdfs:label 'Grant To Program' ;
    rdfs:comment 'FK to research.rd_program.rd_program_id — Government grants fund specific R&D programs. Essential for CHIPS Act compliance reporting and funding traceability.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchingFundAmount rdf:type rdf:Property ;
    rdfs:label 'Matching Fund Amount' ;
    rdfs:comment 'Amount of matching funds required from the recipient, if applicable.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance End Date' ;
    rdfs:comment 'End date of the performance period for the grant.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Start Date' ;
    rdfs:comment 'Start date of the performance period for the grant.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalInvestigatorDepartment rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Department' ;
    rdfs:comment 'Organizational department or research unit of the principal investigator.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalInvestigatorEmail rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Email' ;
    rdfs:comment 'Corporate email address of the principal investigator.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequirements rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirements' ;
    rdfs:comment 'Frequency and format of progress reports required by the agency.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalScope rdf:type rdf:Property ;
    rdfs:label 'Technical Scope' ;
    rdfs:comment 'Brief description of the technical objectives and research areas covered by the grant.' ;
    rdfs:domain ind:GovernmentGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Invention Disclosure Id' ;
    rdfs:comment 'Unique identifier for the invention disclosure record. Primary key for the invention disclosure entity.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventionDisclosure .

ind:primaryInventorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventor Employee Id' ;
    rdfs:comment 'Employee identifier of the primary inventor for internal tracking and inventor compensation programs.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedIpCounsel rdf:type rdf:Property ;
    rdfs:label 'Assigned Ip Counsel' ;
    rdfs:comment 'Name of the IP attorney or patent agent assigned to review the disclosure and manage patent prosecution if filing proceeds.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessValueAssessment rdf:type rdf:Property ;
    rdfs:label 'Business Value Assessment' ;
    rdfs:comment 'Assessment of the inventions potential business value and commercial impact: High (significant competitive advantage or revenue potential), Medium (moderate value), Low (limited impact), Pending (assessment in progress).' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coInventors rdf:type rdf:Property ;
    rdfs:label 'Co Inventors' ;
    rdfs:comment 'Comma-separated list of co-inventor names who contributed to the conception of the invention. Empty if single inventor.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveAdvantageDescription rdf:type rdf:Property ;
    rdfs:label 'Competitive Advantage Description' ;
    rdfs:comment 'Description of how the invention provides competitive advantage in the market, including performance improvements, cost reductions, or enabling capabilities.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date when the IP review committee made the final disposition decision on the disclosure. Null if decision pending.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Explanation of the review committees decision rationale, including factors considered such as novelty, business value, prior art, and strategic alignment.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureNumber rdf:type rdf:Property ;
    rdfs:label 'Disclosure Number' ;
    rdfs:comment 'Business identifier for the invention disclosure, formatted as ID-YYYY-NNNNN where YYYY is year and NNNNN is sequential number. Used for external reference and tracking.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Current lifecycle status of the invention disclosure: Submitted (initial submission), Under Review (technical and business review in progress), Approved for Filing (approved to proceed with patent application), Rejected (not proceeding with IP protection), Withdrawn (inventor withdrew disclosure), Patent Filed (patent application submitted), Published (defensively published), Closed (final disposition completed). [ENUM-REF-CANDIDATE: submitted|under_review|approved_for_filing|rejected|withdrawn|patent_filed|published|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentalWaferLot rdf:type rdf:Property ;
    rdfs:label 'Experimental Wafer Lot' ;
    rdfs:comment 'Wafer lot number(s) used for proof-of-concept or experimental validation of the invention. Comma-separated if multiple lots.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentContractNumber rdf:type rdf:Property ;
    rdfs:label 'Government Contract Number' ;
    rdfs:comment 'Government contract or grant number if the invention was developed under government funding. May trigger special IP rights or reporting requirements under CHIPS Act or similar programs.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionTitle rdf:type rdf:Property ;
    rdfs:label 'Invention Title' ;
    rdfs:comment 'Concise title of the invention describing the technical innovation or discovery.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventorOrganization rdf:type rdf:Property ;
    rdfs:label 'Inventor Organization' ;
    rdfs:comment 'Business unit, division, or research group of the primary inventor at time of disclosure submission.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCounselContact rdf:type rdf:Property ;
    rdfs:label 'Ip Counsel Contact' ;
    rdfs:comment 'Email address of the assigned IP counsel for communication regarding the disclosure.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipProtectionStrategy rdf:type rdf:Property ;
    rdfs:label 'Ip Protection Strategy' ;
    rdfs:comment 'Recommended intellectual property protection strategy: Patent (file patent application), Trade Secret (maintain as confidential), Defensive Publication (publish to prevent others from patenting), No Protection (disclose publicly), Pending Decision (under review).' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketApplication rdf:type rdf:Property ;
    rdfs:label 'Market Application' ;
    rdfs:comment 'Target market applications or product segments where the invention would be deployed (e.g., mobile processors, automotive chips, AI accelerators, IoT devices).' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noveltyAssessment rdf:type rdf:Property ;
    rdfs:label 'Novelty Assessment' ;
    rdfs:comment 'Initial assessment of the inventions novelty and non-obviousness by technical reviewers: High (clearly novel), Medium (potentially novel), Low (incremental), Pending (assessment in progress).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Application Number' ;
    rdfs:comment 'Patent application number assigned by the patent office if a patent application was filed. Null if no application filed yet.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentFilingDate rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Date' ;
    rdfs:comment 'Date when the patent application was officially filed with the patent office. Null if not yet filed.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentFilingRecommendation rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Recommendation' ;
    rdfs:comment 'Boolean flag indicating whether IP counsel recommends filing a patent application for this invention. True if patent filing is recommended, False otherwise.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Patent Jurisdiction' ;
    rdfs:comment 'Recommended patent filing jurisdictions or regions (e.g., US, EP, CN, JP, KR, PCT). Comma-separated list of ISO 3166-1 alpha-2 country codes or regional designations.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryInventorName rdf:type rdf:Property ;
    rdfs:label 'Primary Inventor Name' ;
    rdfs:comment 'Full name of the primary or lead inventor who conceived the invention. First inventor listed on the disclosure.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorArtReferences rdf:type rdf:Property ;
    rdfs:label 'Prior Art References' ;
    rdfs:comment 'List of relevant prior art references identified during search, including patent numbers, publication citations, or public disclosure references.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorArtSearchDate rdf:type rdf:Property ;
    rdfs:label 'Prior Art Search Date' ;
    rdfs:comment 'Date when the prior art search was completed. Null if search not yet completed.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorArtSearchStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Art Search Status' ;
    rdfs:comment 'Status of prior art search to identify existing patents, publications, or public disclosures related to the invention.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationNumber rdf:type rdf:Property ;
    rdfs:label 'Publication Number' ;
    rdfs:comment 'Publication number if the invention was defensively published in a technical journal or defensive publication service. Null if not published.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCommitteeDecision rdf:type rdf:Property ;
    rdfs:label 'Review Committee Decision' ;
    rdfs:comment 'Decision outcome from the IP review committee: Approved (proceed with recommended IP strategy), Rejected (do not pursue IP protection), Deferred (requires additional information or analysis), Pending (decision not yet made).' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDescription rdf:type rdf:Property ;
    rdfs:label 'Technical Description' ;
    rdfs:comment 'Detailed technical description of the invention including the problem solved, technical approach, novel features, and implementation details. Contains proprietary technical information.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyDomain rdf:type rdf:Property ;
    rdfs:label 'Technology Domain' ;
    rdfs:comment 'Primary technology domain or area of the invention within semiconductor R&D (IC Design, Wafer Fabrication, Process Engineering, Packaging, Materials, Device Architecture, Lithography, Testing, Other). [ENUM-REF-CANDIDATE: ic_design|wafer_fabrication|process_engineering|packaging|materials|device_architecture|lithography|testing|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipProjectId rdf:type rdf:Property ;
    rdfs:label 'Ip Project Id' ;
    rdfs:comment 'FK to research.project.project_id — IP core development efforts are organized as research projects. Essential for tracking development lifecycle and resource allocation.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:ipResearchProjectId rdf:type rdf:Property ;
    rdfs:label 'Ip Research Project Id' ;
    rdfs:comment 'Foreign key linking to research.project. Business justification: An IP core development effort is executed within a concrete research project; linking enables traceability of deliverables to the project.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:leadArchitectEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Architect Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: IP core development tracks lead architect for design ownership and performance reviews.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualNreCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Nre Cost Usd' ;
    rdfs:comment 'Actual cumulative non-recurring engineering cost incurred to date for this IP core development, in US dollars.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designForTestabilityCoverage rdf:type rdf:Property ;
    rdfs:label 'Design For Testability Coverage' ;
    rdfs:comment 'Percentage of design for testability coverage achieved, indicating the proportion of the design that can be tested using scan chains and ATPG (0.00 to 100.00).' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designSpecificationVersion rdf:type rdf:Property ;
    rdfs:label 'Design Specification Version' ;
    rdfs:comment 'Version identifier of the design specification document governing this IP core development (e.g., v1.0, v2.3-draft).' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentStatus rdf:type rdf:Property ;
    rdfs:label 'Development Status' ;
    rdfs:comment 'Current lifecycle status of the IP core development project: concept, specification, RTL development, verification, silicon validation, production ready, or archived. [ENUM-REF-CANDIDATE: concept|specification|rtl_development|verification|silicon_validation|production_ready|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentTeamSize rdf:type rdf:Property ;
    rdfs:label 'Development Team Size' ;
    rdfs:comment 'Number of engineers and designers assigned to this IP core development project.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationCompletenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Documentation Completeness Percentage' ;
    rdfs:comment 'Percentage of required design documentation completed, including specifications, user guides, and integration manuals (0.00 to 100.00).' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedNreCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Nre Cost Usd' ;
    rdfs:comment 'Estimated total non-recurring engineering cost for developing this IP core, in US dollars. Includes design, verification, and validation expenses.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstSiliconTargetDate rdf:type rdf:Property ;
    rdfs:label 'First Silicon Target Date' ;
    rdfs:comment 'Planned date for first silicon fabrication and testing of the IP core on a test chip or MPW shuttle.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipPortfolioClassification rdf:type rdf:Property ;
    rdfs:label 'Ip Portfolio Classification' ;
    rdfs:comment 'Strategic classification of the IP core within the company portfolio: strategic (core business), commercial (for licensing revenue), experimental (research), or legacy (maintenance mode).' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMilestoneAchieved rdf:type rdf:Property ;
    rdfs:label 'Last Milestone Achieved' ;
    rdfs:comment 'Description of the most recent development milestone achieved (e.g., RTL freeze, verification signoff, tapeout).' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMilestoneDate rdf:type rdf:Property ;
    rdfs:label 'Last Milestone Date' ;
    rdfs:comment 'Date when the last development milestone was achieved.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentFilingCount rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Count' ;
    rdfs:comment 'Number of patent applications filed related to innovations in this IP core development project.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionReleaseTargetDate rdf:type rdf:Property ;
    rdfs:label 'Production Release Target Date' ;
    rdfs:comment 'Planned date for production release of the IP core, when it becomes available for integration into customer SoC designs.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reusePercentage rdf:type rdf:Property ;
    rdfs:label 'Reuse Percentage' ;
    rdfs:comment 'Percentage of the IP core design that reuses existing verified IP blocks or standard cells (0.00 to 100.00), indicating design efficiency.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtlCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Rtl Completion Percentage' ;
    rdfs:comment 'Percentage of RTL design completion for the IP core, representing progress in the hardware description language implementation (0.00 to 100.00).' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siliconValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Silicon Validation Status' ;
    rdfs:comment 'Status of silicon validation testing on fabricated test chips: not started, in progress, passed, failed, or waived (if validation not required for this IP type).' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPpaAreaMm2 rdf:type rdf:Property ;
    rdfs:label 'Target Ppa Area Mm2' ;
    rdfs:comment 'Target silicon area specification for the IP core in square millimeters, part of the PPA design goals.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPpaPerformanceMhz rdf:type rdf:Property ;
    rdfs:label 'Target Ppa Performance Mhz' ;
    rdfs:comment 'Target operating frequency or performance specification for the IP core in megahertz, part of the PPA design goals.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPpaPowerMw rdf:type rdf:Property ;
    rdfs:label 'Target Ppa Power Mw' ;
    rdfs:comment 'Target power consumption specification for the IP core in milliwatts, part of the PPA (Power, Performance, Area) design goals.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Verification Coverage Percentage' ;
    rdfs:comment 'Percentage of functional verification coverage achieved through simulation and formal verification (0.00 to 100.00). Indicates completeness of design validation.' ;
    rdfs:domain ind:IpCoreDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialsResearchId rdf:type rdf:Property ;
    rdfs:label 'Materials Research Id' ;
    rdfs:comment 'Unique identifier for the materials research record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialsResearch .

ind:principalInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory compliance and PI accountability need a direct employee reference for material research projects.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bandgapEnergyEv rdf:type rdf:Property ;
    rdfs:label 'Bandgap Energy Ev' ;
    rdfs:comment 'The energy bandgap of the material measured in electron volts (eV). Critical for semiconductor channel materials and determines electrical conductivity characteristics.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakdownVoltageMvCm rdf:type rdf:Property ;
    rdfs:label 'Breakdown Voltage Mv Cm' ;
    rdfs:comment 'The dielectric breakdown field strength measured in MV/cm. Critical reliability metric for gate dielectrics and insulating layers.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:characterizationMethod rdf:type rdf:Property ;
    rdfs:label 'Characterization Method' ;
    rdfs:comment 'The primary analytical or metrology technique used to characterize the materials properties (e.g., XRD, TEM, XPS, ellipsometry, C-V measurement, Hall effect).' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalComposition rdf:type rdf:Property ;
    rdfs:label 'Chemical Composition' ;
    rdfs:comment 'The chemical formula or elemental composition of the material (e.g., HfO2, MoS2, GaN, Cu-Co alloy). Includes stoichiometry and doping elements where applicable.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Compatibility Assessment' ;
    rdfs:comment 'Assessment of the materials compatibility with existing fabrication process flows (FEOL, MOL, BEOL). Evaluates integration challenges, contamination risks, and thermal budget constraints.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronMobilityCm2Vs rdf:type rdf:Property ;
    rdfs:label 'Electron Mobility Cm2 Vs' ;
    rdfs:comment 'The electron mobility of the material measured in cm²/(V·s). Key performance metric for channel materials; higher mobility enables faster transistor switching.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchRateNmMin rdf:type rdf:Property ;
    rdfs:label 'Etch Rate Nm Min' ;
    rdfs:comment 'The etch rate of the material in a standard etchant or plasma chemistry, measured in nm/min. Important for process integration and patterning compatibility.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filmThicknessNm rdf:type rdf:Property ;
    rdfs:label 'Film Thickness Nm' ;
    rdfs:comment 'The typical or target film thickness of the deposited material measured in nanometers. Critical dimension for device scaling and performance modeling.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Last Evaluation Date' ;
    rdfs:comment 'The date of the most recent experimental evaluation or characterization run for this material. Indicates currency of research data.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialCostPerGramUsd rdf:type rdf:Property ;
    rdfs:label 'Material Cost Per Gram Usd' ;
    rdfs:comment 'The estimated or actual cost of the raw material per gram in USD. Critical for cost-of-ownership analysis and commercialization feasibility.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Reach Compliance Status' ;
    rdfs:comment 'Compliance status of the material under EU REACH regulation. Identifies if the material contains Substances of Very High Concern (SVHC) or restricted substances.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchInstitutionPartner rdf:type rdf:Property ;
    rdfs:label 'Research Institution Partner' ;
    rdfs:comment 'The name of any external research institution, university, or consortium collaborating on this material investigation (e.g., IMEC, MIT, Stanford).' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchMaturityStage rdf:type rdf:Property ;
    rdfs:label 'Research Maturity Stage' ;
    rdfs:comment 'The current stage of research maturity for the material. Tracks progression from initial concept through pilot integration into manufacturing processes.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchProjectCode rdf:type rdf:Property ;
    rdfs:label 'Research Project Code' ;
    rdfs:comment 'The internal project code or identifier for the R&D program under which this material is being investigated. Links to broader technology roadmap initiatives.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchStartDate rdf:type rdf:Property ;
    rdfs:label 'Research Start Date' ;
    rdfs:comment 'The date when research activities for this material officially began. Tracks project timeline and duration.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:researchStatus rdf:type rdf:Property ;
    rdfs:label 'Research Status' ;
    rdfs:comment 'The current operational status of the materials research effort. Tracks whether investigation is ongoing, paused, completed, or discontinued.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliance Status' ;
    rdfs:comment 'Compliance status of the material under EU RoHS directive. Identifies presence of restricted hazardous substances (lead, mercury, cadmium, hexavalent chromium, etc.).' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stressMpa rdf:type rdf:Property ;
    rdfs:label 'Stress Mpa' ;
    rdfs:comment 'The intrinsic mechanical stress in the deposited film measured in megapascals (MPa). Positive values indicate tensile stress; negative values indicate compressive stress. Critical for wafer warpage and reliability.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierVendorName rdf:type rdf:Property ;
    rdfs:label 'Supplier Vendor Name' ;
    rdfs:comment 'The name of the external supplier, vendor, or research partner providing the material or precursor chemicals for evaluation.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceRoughnessNm rdf:type rdf:Property ;
    rdfs:label 'Surface Roughness Nm' ;
    rdfs:comment 'The root mean square (RMS) surface roughness of the deposited film measured in nanometers. Smooth surfaces are critical for device performance and reliability.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyNodeTarget rdf:type rdf:Property ;
    rdfs:label 'Technology Node Target' ;
    rdfs:comment 'The target process technology node for which this material is being developed (e.g., 3nm, 2nm, 1.4nm, sub-1nm). Aligns material research with roadmap milestones.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStructureType rdf:type rdf:Property ;
    rdfs:label 'Test Structure Type' ;
    rdfs:comment 'The type of test structure or device used to evaluate the material (e.g., MOS capacitor, van der Pauw structure, transistor test device, blanket film).' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thermalConductivityWMk rdf:type rdf:Property ;
    rdfs:label 'Thermal Conductivity W Mk' ;
    rdfs:comment 'The thermal conductivity of the material measured in W/(m·K). Important for heat dissipation in high-performance devices and packaging applications.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tscaComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliance Status' ;
    rdfs:comment 'Compliance status of the material under US TSCA regulation. Identifies if the material is on the TSCA inventory and any use restrictions.' ;
    rdfs:domain ind:MaterialsResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingResearchId rdf:type rdf:Property ;
    rdfs:label 'Packaging Research Id' ;
    rdfs:comment 'Unique identifier for the advanced packaging technology research record.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPackagingPrincipalInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Packaging Principal Investigator Employee Id' ;
    rdfs:comment 'Employee identifier of the principal investigator leading the packaging research.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the NRE budget amounts.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chipsActProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Chips Act Program Flag' ;
    rdfs:comment 'Indicates whether this packaging research is funded or supported under the US CHIPS and Science Act program.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dieStackCount rdf:type rdf:Property ;
    rdfs:label 'Die Stack Count' ;
    rdfs:comment 'Number of die layers in the vertical stack for 3D packaging architectures.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:experimentalLotCount rdf:type rdf:Property ;
    rdfs:label 'Experimental Lot Count' ;
    rdfs:comment 'Number of experimental wafer or packaging lots processed as part of this research program.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interconnectPitchUm rdf:type rdf:Property ;
    rdfs:label 'Interconnect Pitch Um' ;
    rdfs:comment 'Target or achieved interconnect pitch in micrometers for bump, pillar, or TSV connections.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipFilingCount rdf:type rdf:Property ;
    rdfs:label 'Ip Filing Count' ;
    rdfs:comment 'Number of patent applications or IP disclosures filed related to this packaging research.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreBudgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Nre Budget Allocated' ;
    rdfs:comment 'Total non-recurring engineering budget allocated for this packaging research project.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreBudgetSpent rdf:type rdf:Property ;
    rdfs:label 'Nre Budget Spent' ;
    rdfs:comment 'Total non-recurring engineering budget spent to date on this packaging research project.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageSizeXMm rdf:type rdf:Property ;
    rdfs:label 'Package Size X Mm' ;
    rdfs:comment 'Package dimension in the X-axis in millimeters.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageSizeYMm rdf:type rdf:Property ;
    rdfs:label 'Package Size Y Mm' ;
    rdfs:comment 'Package dimension in the Y-axis in millimeters.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageThicknessMm rdf:type rdf:Property ;
    rdfs:label 'Package Thickness Mm' ;
    rdfs:comment 'Total package thickness in millimeters including all die, substrate, and encapsulation layers.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingTechnologyName rdf:type rdf:Property ;
    rdfs:label 'Packaging Technology Name' ;
    rdfs:comment 'Name of the advanced packaging technology under research (e.g., CoWoS-S, InFO-AiP, TSV-3D Stack).' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingTechnologyType rdf:type rdf:Property ;
    rdfs:label 'Packaging Technology Type' ;
    rdfs:comment 'Classification of the packaging technology platform being researched. [ENUM-REF-CANDIDATE: CoWoS|InFO|TSV|WLCSP|Chiplet|Fan-Out|Fan-In|Flip-Chip — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Reliability Qualification Status' ;
    rdfs:comment 'Status of reliability qualification testing (HTOL, HAST, TC, etc.) for the packaging technology.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchRecordCode rdf:type rdf:Property ;
    rdfs:label 'Research Record Code' ;
    rdfs:comment 'Business identifier code for the packaging research record, used for external reference and tracking.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testVehicleDesignCount rdf:type rdf:Property ;
    rdfs:label 'Test Vehicle Design Count' ;
    rdfs:comment 'Number of test vehicle designs created and fabricated to validate the packaging technology.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thermalPerformanceTargetWPerCm2 rdf:type rdf:Property ;
    rdfs:label 'Thermal Performance Target W Per Cm2' ;
    rdfs:comment 'Target thermal dissipation capability in watts per square centimeter for the packaging solution.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thermalResistanceTargetCPerW rdf:type rdf:Property ;
    rdfs:label 'Thermal Resistance Target C Per W' ;
    rdfs:comment 'Target junction-to-ambient thermal resistance in degrees Celsius per watt.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warpageTargetUm rdf:type rdf:Property ;
    rdfs:label 'Warpage Target Um' ;
    rdfs:comment 'Maximum allowable warpage in micrometers for the packaged assembly to ensure assembly yield and reliability.' ;
    rdfs:domain ind:PackagingResearch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patentFilingId rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Id' ;
    rdfs:comment 'Unique identifier for the patent filing record. Primary key for the patent filing entity.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abandonmentDate rdf:type rdf:Property ;
    rdfs:label 'Abandonment Date' ;
    rdfs:comment 'Date the patent application was formally abandoned or withdrawn. Null if application is active or granted.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualFilingCost rdf:type rdf:Property ;
    rdfs:label 'Actual Filing Cost' ;
    rdfs:comment 'Actual total cost incurred for filing and prosecuting this patent application to date. Updated as costs are incurred. Business-confidential financial data.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Official patent application number assigned by the patent office upon filing. Format varies by jurisdiction (e.g., US: 16/123456, EP: EP3123456, CN: CN202110123456).' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedPatentCounsel rdf:type rdf:Property ;
    rdfs:label 'Assigned Patent Counsel' ;
    rdfs:comment 'Name of the patent attorney or agent assigned to prosecute this application. May be internal counsel or external law firm attorney.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessValueScore rdf:type rdf:Property ;
    rdfs:label 'Business Value Score' ;
    rdfs:comment 'Quantitative score (0-100) assessing the commercial value and competitive advantage provided by this invention. Used for portfolio prioritization and maintenance decisions.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chipsActReportable rdf:type rdf:Property ;
    rdfs:label 'Chips Act Reportable' ;
    rdfs:comment 'Indicates whether this patent filing must be reported under CHIPS and Science Act IP reporting requirements. True if invention relates to CHIPS-funded R&D.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimsAllowed rdf:type rdf:Property ;
    rdfs:label 'Claims Allowed' ;
    rdfs:comment 'Number of claims allowed by the examiner for grant. Null if application not yet allowed. May be fewer than filed claims due to examiner rejections.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsFiled rdf:type rdf:Property ;
    rdfs:label 'Claims Filed' ;
    rdfs:comment 'Total number of claims included in the patent application as filed. Independent and dependent claims define the scope of protection sought.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpcClassification rdf:type rdf:Property ;
    rdfs:label 'Cpc Classification' ;
    rdfs:comment 'Cooperative Patent Classification code used by USPTO and EPO for more granular technical categorization. Extension of IPC with additional subclasses.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Submission Date' ;
    rdfs:comment 'Date the initial invention disclosure was submitted to the IP department for review. Precedes filing decision and application preparation.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedFilingCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Filing Cost' ;
    rdfs:comment 'Estimated total cost for filing and prosecuting this patent application, including attorney fees, filing fees, and prosecution costs. Business-confidential financial data.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Official date the patent application was filed with the patent office. Establishes priority date for prior art evaluation and patent term calculation.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the patent filing. Tracks progression from initial draft through final disposition (grant or abandonment). [ENUM-REF-CANDIDATE: draft|filed|pending|under_examination|allowed|granted|abandoned|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'Date the patent was officially granted by the patent office. Null if application is still pending or was abandoned.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:independentClaims rdf:type rdf:Property ;
    rdfs:label 'Independent Claims' ;
    rdfs:comment 'Count of independent claims in the application. Independent claims define the broadest scope of protection; more independent claims increase filing fees.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventorCount rdf:type rdf:Property ;
    rdfs:label 'Inventor Count' ;
    rdfs:comment 'Total count of named inventors on the patent application. Semiconductor inventions often have multiple co-inventors from cross-functional R&D teams.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventors rdf:type rdf:Property ;
    rdfs:label 'Inventors' ;
    rdfs:comment 'Comma-separated list of inventor names as listed on the patent application. Individuals who contributed to the conception of the invention. Business-confidential during pre-filing and prosecution.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipcClassification rdf:type rdf:Property ;
    rdfs:label 'Ipc Classification' ;
    rdfs:comment 'International Patent Classification code assigned to categorize the invention by technical field. Semiconductor inventions typically fall under H01L (semiconductor devices) or H01C (resistors).' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOfficeActionDate rdf:type rdf:Property ;
    rdfs:label 'Last Office Action Date' ;
    rdfs:comment 'Date of the most recent office action received from the patent examiner. Null if no office actions received yet.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lawFirm rdf:type rdf:Property ;
    rdfs:label 'Law Firm' ;
    rdfs:comment 'Name of the external law firm handling prosecution, if applicable. Null if handled by internal counsel.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceFeeDueDate rdf:type rdf:Property ;
    rdfs:label 'Maintenance Fee Due Date' ;
    rdfs:comment 'Next due date for maintenance fee payment to keep the granted patent in force. Applicable to granted patents only; null if not yet granted.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationalPhaseEntryDate rdf:type rdf:Property ;
    rdfs:label 'National Phase Entry Date' ;
    rdfs:comment 'Date of entry into national phase for PCT applications. Deadline for entering individual country jurisdictions after international phase. Null if not a PCT application.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officeActionCount rdf:type rdf:Property ;
    rdfs:label 'Office Action Count' ;
    rdfs:comment 'Total number of office actions (examiner rejections or objections) received during prosecution. Higher counts indicate more complex prosecution.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patentNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Number' ;
    rdfs:comment 'Official patent number assigned upon grant by the patent office. Null if application is still pending or abandoned.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentToProject rdf:type rdf:Property ;
    rdfs:label 'Patent To Project' ;
    rdfs:comment 'FK to research.research_project.research_project_id — Patent filings arise from research project activities. Essential for tracking IP output per project and for CHIPS Act reporting.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patentType rdf:type rdf:Property ;
    rdfs:label 'Patent Type' ;
    rdfs:comment 'Type of patent application filed. Utility patents cover functional inventions (most semiconductor IP), design patents cover ornamental designs, provisional applications establish priority date. [ENUM-REF-CANDIDATE: utility|design|provisional|plant|continuation|divisional|continuation_in_part — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Pct Application Number' ;
    rdfs:comment 'International application number if filed under the Patent Cooperation Treaty. Enables streamlined filing in multiple jurisdictions. Null if not a PCT application.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryInventor rdf:type rdf:Property ;
    rdfs:label 'Primary Inventor' ;
    rdfs:comment 'Name of the lead or primary inventor who initiated the invention disclosure. First-named inventor on the application.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorArtSearchCompleted rdf:type rdf:Property ;
    rdfs:label 'Prior Art Search Completed' ;
    rdfs:comment 'Indicates whether a formal prior art search was conducted before filing. True if search completed; false if filing proceeded without comprehensive search.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityDate rdf:type rdf:Property ;
    rdfs:label 'Priority Date' ;
    rdfs:comment 'Earliest filing date claimed for priority purposes. May reference a provisional application, foreign application, or parent application filing date.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prosecutionStage rdf:type rdf:Property ;
    rdfs:label 'Prosecution Stage' ;
    rdfs:comment 'Current stage in the patent prosecution process. Tracks progress through examination, office action responses, allowance, and final disposition. [ENUM-REF-CANDIDATE: not_started|application_preparation|filed_awaiting_examination|office_action_response|allowance|grant|appeal|abandoned — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionStrategy rdf:type rdf:Property ;
    rdfs:label 'Protection Strategy' ;
    rdfs:comment 'Recommended IP protection strategy determined during disclosure review. Patent filing is pursued when strategy is \'patent\'; trade secret or defensive publication may be chosen for certain inventions.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date the patent application was published by the patent office (typically 18 months after filing). Null if not yet published or if publication was avoided.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedApplications rdf:type rdf:Property ;
    rdfs:label 'Related Applications' ;
    rdfs:comment 'Comma-separated list of related application numbers (parent, continuation, divisional, CIP). Tracks patent family relationships.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicValue rdf:type rdf:Property ;
    rdfs:label 'Strategic Value' ;
    rdfs:comment 'Business assessment of the strategic value of this patent to the company\'s IP portfolio. Critical patents protect core differentiators; high-value patents support key product lines.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdkDevelopmentId rdf:type rdf:Property ;
    rdfs:label 'Pdk Development Id' ;
    rdfs:comment 'Unique identifier for the PDK development record. Primary key for tracking PDK creation, versioning, and release lifecycle.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:researchTechnologyNodeId rdf:type rdf:Property ;
    rdfs:label 'Research Technology Node Id' ;
    rdfs:comment 'FK to research.research_technology_node.research_technology_node_id — Every PDK is developed for a specific technology node. This is the fundamental association between design enablement and process technology.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResearchTechnologyNode .

ind:cadenceVirtuosoCompatible rdf:type rdf:Property ;
    rdfs:label 'Cadence Virtuoso Compatible' ;
    rdfs:comment 'Flag indicating whether this PDK is compatible with Cadence Virtuoso EDA tool suite for analog and custom IC design.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Critical Issues Count' ;
    rdfs:comment 'Number of critical severity issues in this PDK version that may block design activities or cause silicon failures.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:developmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Development Start Date' ;
    rdfs:comment 'Date when development activities for this PDK version were initiated.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:developmentTeam rdf:type rdf:Property ;
    rdfs:label 'Development Team' ;
    rdfs:comment 'Name of the R&D team or organizational unit responsible for developing this PDK.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfSupportDate rdf:type rdf:Property ;
    rdfs:label 'End Of Support Date' ;
    rdfs:comment 'Date when technical support and updates for this PDK version will cease, aligned with technology node EOL planning.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:includesDesignRuleManual rdf:type rdf:Property ;
    rdfs:label 'Includes Design Rule Manual' ;
    rdfs:comment 'Flag indicating whether this PDK version includes comprehensive design rule documentation and guidelines.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesDrcRules rdf:type rdf:Property ;
    rdfs:label 'Includes Drc Rules' ;
    rdfs:comment 'Flag indicating whether this PDK version includes DRC rule decks for physical verification of IC layouts.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesIoLibraries rdf:type rdf:Property ;
    rdfs:label 'Includes Io Libraries' ;
    rdfs:comment 'Flag indicating whether this PDK version includes IO pad libraries for chip-to-package interface design.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesLvsRules rdf:type rdf:Property ;
    rdfs:label 'Includes Lvs Rules' ;
    rdfs:comment 'Flag indicating whether this PDK version includes LVS rule decks for verifying layout-to-schematic correspondence.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesMemoryCompilers rdf:type rdf:Property ;
    rdfs:label 'Includes Memory Compilers' ;
    rdfs:comment 'Flag indicating whether this PDK version includes memory compiler tools for generating SRAM, ROM, or other memory blocks.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesSpiceModels rdf:type rdf:Property ;
    rdfs:label 'Includes Spice Models' ;
    rdfs:comment 'Flag indicating whether this PDK version includes SPICE device models for circuit simulation and analysis.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesStandardCellLibraries rdf:type rdf:Property ;
    rdfs:label 'Includes Standard Cell Libraries' ;
    rdfs:comment 'Flag indicating whether this PDK version includes pre-characterized standard cell libraries for digital design.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCustomerAccessible rdf:type rdf:Property ;
    rdfs:label 'Is Customer Accessible' ;
    rdfs:comment 'Flag indicating whether this PDK version is available for external customer access or restricted to internal use only.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:knownIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Known Issues Count' ;
    rdfs:comment 'Number of documented known issues, limitations, or bugs in this PDK version that design teams should be aware of.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mentorCompatible rdf:type rdf:Property ;
    rdfs:label 'Mentor Compatible' ;
    rdfs:comment 'Flag indicating whether this PDK is compatible with Mentor Graphics (Siemens EDA) tool suite.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metalLayersCount rdf:type rdf:Property ;
    rdfs:label 'Metal Layers Count' ;
    rdfs:comment 'Number of metal interconnect layers available in this PDK for routing, typically ranging from 5 to 15+ layers for advanced nodes.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdkCustodianEmail rdf:type rdf:Property ;
    rdfs:label 'Pdk Custodian Email' ;
    rdfs:comment 'Email contact for the PDK custodian for technical support and escalation.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdkCustodianName rdf:type rdf:Property ;
    rdfs:label 'Pdk Custodian Name' ;
    rdfs:comment 'Name of the individual or team responsible for maintaining and supporting this PDK version.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdkForNode rdf:type rdf:Property ;
    rdfs:label 'Pdk For Node' ;
    rdfs:comment 'FK to research.technology_node.technology_node_id — PDKs are developed for specific technology nodes. This is the fundamental organizing principle for PDK work.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdkTargetsNode rdf:type rdf:Property ;
    rdfs:label 'Pdk Targets Node' ;
    rdfs:comment 'FK to research.technology_node.technology_node_id — Every PDK is developed for a specific technology node. This is the fundamental classification link that determines which design rules, SPICE models, and libraries are included.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Planned Release Date' ;
    rdfs:comment 'Target date for releasing this PDK version, used for roadmap planning and customer commitments.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:predecessorPdkVersion rdf:type rdf:Property ;
    rdfs:label 'Predecessor Pdk Version' ;
    rdfs:comment 'Version number of the previous PDK release that this version supersedes or builds upon.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseType rdf:type rdf:Property ;
    rdfs:label 'Release Type' ;
    rdfs:comment 'Classification of the PDK release maturity level. Alpha for early internal testing, beta for limited customer access, production for general availability, maintenance for updates, deprecated for end-of-life.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsEuvLithography rdf:type rdf:Property ;
    rdfs:label 'Supports Euv Lithography' ;
    rdfs:comment 'Flag indicating whether this PDK supports EUV lithography for critical layers, typically required for advanced nodes below 7nm.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:synopsysCompatible rdf:type rdf:Property ;
    rdfs:label 'Synopsys Compatible' ;
    rdfs:comment 'Flag indicating whether this PDK is compatible with Synopsys EDA tool suite including Design Compiler and PrimeTime.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Validation Completion Date' ;
    rdfs:comment 'Date when all validation activities for this PDK version were completed and signed off.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Validation Completion Percentage' ;
    rdfs:comment 'Percentage of validation test cases completed successfully, ranging from 0.00 to 100.00.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationStartDate rdf:type rdf:Property ;
    rdfs:label 'Validation Start Date' ;
    rdfs:comment 'Date when formal validation and verification activities for this PDK version began.' ;
    rdfs:domain ind:PdkDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current status of PDK validation activities including DRC/LVS rule verification, SPICE model correlation, and design flow testing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFlowExperimentId rdf:type rdf:Property ;
    rdfs:label 'Process Flow Experiment Id' ;
    rdfs:comment 'System-generated unique identifier for the experimental process flow record.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProcessAuthorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Process Author Employee Id' ;
    rdfs:comment 'Identifier of the employee who authored the flow.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Cycle Time Minutes' ;
    rdfs:comment 'Measured total processing time after execution.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doeSplitDetails rdf:type rdf:Property ;
    rdfs:label 'Doe Split Details' ;
    rdfs:comment 'Details of the DOE split (e.g., factor levels, randomization).' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doeSplitFlag rdf:type rdf:Property ;
    rdfs:label 'Doe Split Flag' ;
    rdfs:comment 'Indicates whether the flow includes a DOE split.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flowVersion rdf:type rdf:Property ;
    rdfs:label 'Flow Version' ;
    rdfs:comment 'Version identifier for the flow (e.g., v1, v2).' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyProcessParameters rdf:type rdf:Property ;
    rdfs:label 'Key Process Parameters' ;
    rdfs:comment 'Critical parameters (temperature, pressure, time) for each step, stored as JSON or delimited text.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFlowComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Process Flow Complexity Score' ;
    rdfs:comment 'Numeric score representing the overall complexity of the flow (higher = more complex).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processFlowExperimentDescription rdf:type rdf:Property ;
    rdfs:label 'Process Flow Experiment Description' ;
    rdfs:comment 'Detailed free-text description of the experimental flow.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFlowExperimentStatus rdf:type rdf:Property ;
    rdfs:label 'Process Flow Experiment Status' ;
    rdfs:comment 'Current lifecycle status of the experimental flow.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processPressurePa rdf:type rdf:Property ;
    rdfs:label 'Process Pressure Pa' ;
    rdfs:comment 'Operating pressure for the process step(s).' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processStepSequence rdf:type rdf:Property ;
    rdfs:label 'Process Step Sequence' ;
    rdfs:comment 'Ordered list of process steps (e.g., FEOL→MOL→BEOL) encoded as a delimited string.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitConditions rdf:type rdf:Property ;
    rdfs:label 'Split Conditions' ;
    rdfs:comment 'Design-of-Experiments split criteria for the flow, stored as JSON or delimited text.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tool Identifier' ;
    rdfs:comment 'Unique identifier or serial number of the equipment tool used.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSteps rdf:type rdf:Property ;
    rdfs:label 'Total Steps' ;
    rdfs:comment 'Count of distinct steps in the experimental flow.' ;
    rdfs:domain ind:ProcessFlowExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProcessEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Process Employee Id' ;
    rdfs:comment 'Reference to the process integration engineer responsible for designing, executing, and analyzing this experimental run.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:processExperimentalLotId rdf:type rdf:Property ;
    rdfs:label 'Process Experimental Lot Id' ;
    rdfs:comment 'FK to research.experimental_lot.experimental_lot_id — Process integration runs are executed on experimental lots. This is the core traceability link between process experiments and physical wafers.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExperimentalLot .

ind:contactResistanceOhm rdf:type rdf:Property ;
    rdfs:label 'Contact Resistance Ohm' ;
    rdfs:comment 'Measured contact resistance in ohms. Critical for device performance and interconnect reliability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doeDesignType rdf:type rdf:Property ;
    rdfs:label 'Doe Design Type' ;
    rdfs:comment 'Statistical experimental design methodology applied to this integration run. Defines the split condition strategy for systematic parameter variation and analysis.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveCurrentUa rdf:type rdf:Property ;
    rdfs:label 'Drive Current Ua' ;
    rdfs:comment 'Measured on-state drive current in microamperes. Key performance metric for transistor switching speed and circuit performance.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electricalTestStructureType rdf:type rdf:Property ;
    rdfs:label 'Electrical Test Structure Type' ;
    rdfs:comment 'Type of test structures fabricated for electrical characterization (e.g., ring oscillators, SRAM arrays, parametric test structures, scribe line monitors).' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricalTestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Electrical Test Timestamp' ;
    rdfs:comment 'Date and time when electrical testing was performed on the processed wafers.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:experimentName rdf:type rdf:Property ;
    rdfs:label 'Experiment Name' ;
    rdfs:comment 'Business-friendly name assigned to this process integration experiment for identification and tracking purposes.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateOxideThicknessNm rdf:type rdf:Property ;
    rdfs:label 'Gate Oxide Thickness Nm' ;
    rdfs:comment 'Measured or target gate dielectric thickness in nanometers. Critical parameter for device electrostatics and reliability.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'Executive summary of the key technical findings, insights, and learnings from this process integration run.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leakageCurrentNa rdf:type rdf:Property ;
    rdfs:label 'Leakage Current Na' ;
    rdfs:comment 'Measured off-state leakage current in nanoamperes. Critical for power consumption and device reliability.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextActionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Next Action Recommendation' ;
    rdfs:comment 'Recommended next steps based on the results of this integration run (e.g., proceed to next phase, repeat with modifications, halt development).' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailDetermination rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Determination' ;
    rdfs:comment 'Overall assessment of whether the process integration run met its success criteria based on electrical results and yield targets.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdkContributionFlag rdf:type rdf:Property ;
    rdfs:label 'Pdk Contribution Flag' ;
    rdfs:comment 'Indicates whether results from this integration run contributed data to PDK development or updates. True if data was incorporated into PDK.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:researchProgramName rdf:type rdf:Property ;
    rdfs:label 'Research Program Name' ;
    rdfs:comment 'Name of the broader research program or technology development initiative that this integration run supports.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTargetsNode rdf:type rdf:Property ;
    rdfs:label 'Run Targets Node' ;
    rdfs:comment 'FK to research.technology_node.technology_node_id — Process integration experiments target specific technology nodes. This enables filtering and analysis of all experiments for a given node generation.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:splitConditionCount rdf:type rdf:Property ;
    rdfs:label 'Split Condition Count' ;
    rdfs:comment 'Number of experimental split conditions (parameter variations) included in this DOE design for systematic process learning.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subthresholdSlopeMvPerDecade rdf:type rdf:Property ;
    rdfs:label 'Subthreshold Slope Mv Per Decade' ;
    rdfs:comment 'Measured subthreshold slope in mV/decade. Indicates how sharply the transistor switches between on and off states.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tcadCorrelationAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Tcad Correlation Accuracy Percentage' ;
    rdfs:comment 'Percentage accuracy of TCAD simulation predictions compared to actual electrical test results. Measures predictive model quality.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tcadSimulationCorrelationFlag rdf:type rdf:Property ;
    rdfs:label 'Tcad Simulation Correlation Flag' ;
    rdfs:comment 'Indicates whether TCAD simulation data was correlated with experimental results for this run. True if correlation analysis was performed.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdVoltageMv rdf:type rdf:Property ;
    rdfs:label 'Threshold Voltage Mv' ;
    rdfs:comment 'Measured threshold voltage of the fabricated devices in millivolts. Critical parameter for device performance and power consumption.' ;
    rdfs:domain ind:ProcessIntegrationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Director Employee Id' ;
    rdfs:comment 'Employee identifier for the program director, linking to HR systems for organizational reporting.' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetEnvelopeAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Envelope Amount' ;
    rdfs:comment 'Total approved budget allocation for the program across all fiscal years, in USD. Includes NRE, capital equipment, materials, and labor costs.' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:charterDescription rdf:type rdf:Property ;
    rdfs:label 'Charter Description' ;
    rdfs:comment 'Detailed charter describing program scope, deliverables, success criteria, and boundaries. Defines what is in-scope and out-of-scope for the program.' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationPartners rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partners' ;
    rdfs:comment 'Comma-separated list of external research institutions, universities, consortia, or industry partners collaborating on this program (e.g., \'MIT, IMEC, Stanford University\').' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPhase rdf:type rdf:Property ;
    rdfs:label 'Current Phase' ;
    rdfs:comment 'Current execution phase of the program: concept (initial research), feasibility (proof of concept), development (engineering), integration (system-level), qualification (reliability testing), production_ramp (volume manufacturing readiness), closed (program complete). [ENUM-REF-CANDIDATE: concept|feasibility|development|integration|qualification|production_ramp|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentalWaferLotCount rdf:type rdf:Property ;
    rdfs:label 'Experimental Wafer Lot Count' ;
    rdfs:comment 'Total number of experimental wafer lots processed for this program across all process splits and iterations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateReviewStage rdf:type rdf:Property ;
    rdfs:label 'Gate Review Stage' ;
    rdfs:comment 'Current stage-gate review checkpoint: gate_0 (concept approval), gate_1 (feasibility), gate_2 (development authorization), gate_3 (integration readiness), gate_4 (qualification approval), gate_5 (production release), post_program_review (lessons learned). [ENUM-REF-CANDIDATE: gate_0|gate_1|gate_2|gate_3|gate_4|gate_5|post_program_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyPerformanceIndicators rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicators' ;
    rdfs:comment 'Comma-separated list of quantitative success metrics for the program (e.g., \'PPA improvement: 30% power reduction, 20% area reduction\', \'Yield target: >85% at qualification\').' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastGateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Gate Review Date' ;
    rdfs:comment 'Date of the most recent formal gate review conducted for this program.' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGateReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Gate Review Outcome' ;
    rdfs:comment 'Decision outcome from the most recent gate review: approved (proceed to next phase), conditional_approval (proceed with conditions), deferred (additional work required), rejected (program termination recommended).' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextGateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Gate Review Date' ;
    rdfs:comment 'Scheduled date for the next formal gate review. Null if program is completed or no review scheduled.' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the R&D program by technology domain: process node development (e.g., 2nm, 1.4nm), device architecture (FinFET, GAA, CFET), advanced packaging (CoWoS, InFO), materials research, IP core development, or design methodology.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Business Unit' ;
    rdfs:comment 'Name of the business unit or division sponsoring and funding the R&D program (e.g., \'Advanced Logic Technology\', \'Foundry Services\', \'Memory Solutions\').' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'High-level strategic goal and business rationale for the program (e.g., \'Enable 30% power reduction for mobile SoC applications\', \'Achieve 2x density improvement for AI accelerators\').' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutMilestoneCount rdf:type rdf:Property ;
    rdfs:label 'Tapeout Milestone Count' ;
    rdfs:comment 'Number of design tapeouts (GDSII submissions for mask fabrication) completed within this program for test chips, proof-of-concept designs, or qualification vehicles.' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetApplicationDomain rdf:type rdf:Property ;
    rdfs:label 'Target Application Domain' ;
    rdfs:comment 'Primary market or application domain this technology targets (e.g., \'Mobile SoC\', \'High-Performance Computing\', \'AI/ML Accelerators\', \'Automotive\', \'IoT Edge Devices\').' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalLeadName rdf:type rdf:Property ;
    rdfs:label 'Technical Lead Name' ;
    rdfs:comment 'Full name of the principal engineer or scientist responsible for technical execution and engineering decisions.' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyGenerationTarget rdf:type rdf:Property ;
    rdfs:label 'Technology Generation Target' ;
    rdfs:comment 'Target technology node or generation for this program (e.g., \'2nm\', \'1.4nm\', \'N3\', \'N2\'). For non-node programs, describes the technology generation (e.g., \'Gen 5 CoWoS\', \'3rd Gen GAA\').' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyPlatform rdf:type rdf:Property ;
    rdfs:label 'Technology Platform' ;
    rdfs:comment 'Underlying technology platform or architecture family this program targets (e.g., \'FinFET\', \'GAA Nanosheet\', \'CFET\', \'FDSOI\', \'Hybrid Bonding\').' ;
    rdfs:domain ind:ResearchProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Employee Id' ;
    rdfs:comment 'User identifier or username of the person who last modified the research project record, for audit trail purposes.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:projectPrincipalInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Principal Investigator Employee Id' ;
    rdfs:comment 'Employee identifier of the principal investigator responsible for the research project, linking to Workday Human Capital Management (HCM) system.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deviceArchitectureFocus rdf:type rdf:Property ;
    rdfs:label 'Device Architecture Focus' ;
    rdfs:comment 'Primary device architecture or transistor technology being researched, such as FinFET (Fin Field-Effect Transistor), GAA (Gate All Around), CFET (Complementary FET), or other novel structures.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipFilingPlanned rdf:type rdf:Property ;
    rdfs:label 'Ip Filing Planned' ;
    rdfs:comment 'Boolean flag indicating whether patent or Intellectual Property (IP) filing is planned as an outcome of this research project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mpwShuttleParticipation rdf:type rdf:Property ;
    rdfs:label 'Mpw Shuttle Participation' ;
    rdfs:comment 'Boolean flag indicating whether this research project participated in a Multi-Project Wafer (MPW) shuttle run to share fabrication costs with other projects.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current lifecycle phase of the research project: exploratory (initial concept), feasibility (viability assessment), development (active R&D), qualification (validation and testing), or closed (completed or terminated).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plm System Reference' ;
    rdfs:comment 'External reference identifier or link to the corresponding project record in Product Lifecycle Management (PLM) systems such as Siemens Teamcenter or Oracle Agile PLM.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the research project by its primary objective: proof-of-concept (PoC) demonstration, feasibility study, process integration experiment, materials research, Intellectual Property (IP) development initiative, or novel device architecture exploration.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchDomain rdf:type rdf:Property ;
    rdfs:label 'Research Domain' ;
    rdfs:comment 'Primary technical domain or area of focus for the research project: next-generation process node development, novel device architecture, advanced packaging technologies, materials research, Intellectual Property (IP) core development, lithography techniques, or interconnect technologies. [ENUM-REF-CANDIDATE: process_node|device_architecture|advanced_packaging|materials|ip_core|lithography|interconnect — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'Strategic importance and priority level assigned to the research project by executive management: critical (top priority), high, medium, or low.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalObjectives rdf:type rdf:Property ;
    rdfs:label 'Technical Objectives' ;
    rdfs:comment 'Specific technical objectives and success criteria for the research project, including performance targets, yield goals, or proof-of-concept milestones.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationId rdf:type rdf:Property ;
    rdfs:label 'Publication Id' ;
    rdfs:comment 'Primary key for publication' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAuthorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Author Employee Id' ;
    rdfs:comment 'Employee identifier of the lead or corresponding author responsible for the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:publicationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Publication Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified the publication record.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:publicationProjectId rdf:type rdf:Property ;
    rdfs:label 'Publication Project Id' ;
    rdfs:comment 'FK to research.project.project_id — Publications document results from specific research projects. This link supports IP strategy decisions and technology disclosure management.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:publicationResearchProjectId rdf:type rdf:Property ;
    rdfs:label 'Publication Research Project Id' ;
    rdfs:comment 'Identifier of the research project associated with this publication. Links publication to the originating R&D project.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:technologyDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Technology Disclosure Id' ;
    rdfs:comment 'Identifier of the internal technology disclosure or invention disclosure associated with this publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventionDisclosure .

ind:abstract rdf:type rdf:Property ;
    rdfs:label 'Abstract' ;
    rdfs:comment 'Summary or abstract of the publication content describing the research objectives, methods, and findings.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date when the publication was accepted by the venue for publication or presentation.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authors rdf:type rdf:Property ;
    rdfs:label 'Authors' ;
    rdfs:comment 'Comma-separated list of authors who contributed to the publication, in citation order.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationCount rdf:type rdf:Property ;
    rdfs:label 'Citation Count' ;
    rdfs:comment 'Number of times this publication has been cited by other research works, tracked for impact measurement.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coAuthorCount rdf:type rdf:Property ;
    rdfs:label 'Co Author Count' ;
    rdfs:comment 'Total number of co-authors listed on the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doi rdf:type rdf:Property ;
    rdfs:label 'Doi' ;
    rdfs:comment 'Digital Object Identifier assigned to the publication for permanent citation and retrieval.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Export Control Review Status' ;
    rdfs:comment 'Status of export control review to ensure compliance with ITAR, EAR, and other export regulations before publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Internal Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the internal document repository where the publication manuscript is stored.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isbn rdf:type rdf:Property ;
    rdfs:label 'Isbn' ;
    rdfs:comment 'ISBN assigned to the publication if applicable (for books or book chapters).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issn rdf:type rdf:Property ;
    rdfs:label 'Issn' ;
    rdfs:comment 'ISSN assigned to the journal or serial publication if applicable.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of technical keywords or index terms associated with the publication for search and categorization.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Open Access Flag' ;
    rdfs:comment 'Indicates whether the publication is available as open access to the public.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peerReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Peer Review Status' ;
    rdfs:comment 'Status of external peer review process for the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationCode rdf:type rdf:Property ;
    rdfs:label 'Publication Code' ;
    rdfs:comment 'Business identifier or tracking code assigned to the publication for internal reference and cataloging.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle status of the publication in the submission and review process. [ENUM-REF-CANDIDATE: draft|submitted|under_review|accepted|published|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationType rdf:type rdf:Property ;
    rdfs:label 'Publication Type' ;
    rdfs:comment 'Classification of the publication format and venue type. [ENUM-REF-CANDIDATE: conference_paper|journal_article|invited_talk|white_paper|poster|patent_disclosure|technical_report — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyDisclosureClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Technology Disclosure Clearance Status' ;
    rdfs:comment 'Status of internal IP clearance review to ensure publication does not disclose proprietary or patentable information prematurely.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyNodeFocus rdf:type rdf:Property ;
    rdfs:label 'Technology Node Focus' ;
    rdfs:comment 'Process node or technology generation that is the focus of the publication (e.g., 3nm, 2nm, sub-1nm).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'Web URL or hyperlink to the published article or conference proceedings.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venue rdf:type rdf:Property ;
    rdfs:label 'Venue' ;
    rdfs:comment 'Name of the conference, journal, symposium, or publication outlet (e.g., IEEE IEDM, VLSI Symposium, Nature Electronics, ECTC).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueType rdf:type rdf:Property ;
    rdfs:label 'Venue Type' ;
    rdfs:comment 'Classification of the publication venue category.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Research Milestone Id' ;
    rdfs:comment 'Unique identifier for the research milestone record. Primary key for milestone tracking in R&D programs and projects.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryResearchApprovingAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Research Approving Authority Employee Id' ;
    rdfs:comment 'Employee identifier of the approving authority for audit trail and accountability purposes.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionItems rdf:type rdf:Property ;
    rdfs:label 'Action Items' ;
    rdfs:comment 'List of follow-up actions, corrective measures, or conditions that must be addressed following the gate review. Particularly important for conditional pass outcomes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Baseline date established at project approval or last formal re-baseline. Used to measure schedule performance against the approved plan.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Amount' ;
    rdfs:comment 'Financial impact or variance associated with this milestone, such as cost overruns, savings, or additional Non-Recurring Engineering (NRE) investment required.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget impact amount.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chipsActReportDate rdf:type rdf:Property ;
    rdfs:label 'Chips Act Report Date' ;
    rdfs:comment 'Date when the milestone completion was reported to CHIPS Act oversight authorities, if applicable.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collaborationPartnerInvolved rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partner Involved' ;
    rdfs:comment 'Flag indicating whether external collaboration partners (universities, research institutions, or industry partners) were involved in achieving this milestone.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionCriteria rdf:type rdf:Property ;
    rdfs:label 'Completion Criteria' ;
    rdfs:comment 'Detailed description of the technical, business, or quality criteria that must be met for the milestone to be considered complete. Defines success conditions for gate reviews.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathIndicator rdf:type rdf:Property ;
    rdfs:label 'Critical Path Indicator' ;
    rdfs:comment 'Flag indicating whether this milestone is on the critical path of the project schedule. True if any delay to this milestone will delay the overall project completion.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Detailed description of the tangible deliverable or output associated with this milestone, such as design documentation, test results, prototype hardware, or qualification reports.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Gate Review Date' ;
    rdfs:comment 'Date when the formal gate review was conducted and outcome was determined.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Gate Review Outcome' ;
    rdfs:comment 'Result of the milestone gate review. Pass indicates all criteria met and project proceeds, conditional pass requires specific actions before proceeding, fail stops the project or phase, deferred postpones the decision, not reviewed indicates the review has not yet occurred.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipFilingTriggered rdf:type rdf:Property ;
    rdfs:label 'Ip Filing Triggered' ;
    rdfs:comment 'Flag indicating whether this milestone triggered or enabled intellectual property filing activities, such as patent applications or trade secret documentation.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneToProgram rdf:type rdf:Property ;
    rdfs:label 'Milestone To Program' ;
    rdfs:comment 'FK to research.rd_program.rd_program_id — Milestones track progress of R&D programs. Without this link, milestone tracking is disconnected from program governance.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneToProject rdf:type rdf:Property ;
    rdfs:label 'Milestone To Project' ;
    rdfs:comment 'FK to research.research_project.research_project_id — Milestones can also track individual project progress. Projects have their own gate reviews independent of program-level milestones.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewMeetingMinutesUrl rdf:type rdf:Property ;
    rdfs:label 'Review Meeting Minutes Url' ;
    rdfs:comment 'URL or document management system path to the formal meeting minutes or review documentation for the gate review.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Notification Sent' ;
    rdfs:comment 'Flag indicating whether stakeholder notifications have been sent regarding the milestone completion or gate review outcome.' ;
    rdfs:domain ind:ResearchMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designRuleManualVersion rdf:type rdf:Property ;
    rdfs:label 'Design Rule Manual Version' ;
    rdfs:comment 'Version identifier of the design rule manual (DRM) document that specifies layout constraints, spacing rules, and design-for-manufacturability (DFM) guidelines for this technology node.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstTapeoutDate rdf:type rdf:Property ;
    rdfs:label 'First Tapeout Date' ;
    rdfs:comment 'Date of the first design tapeout (final design submission for manufacturing) using this technology node. Marks transition from development to production readiness.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irdsRoadmapAlignment rdf:type rdf:Property ;
    rdfs:label 'Irds Roadmap Alignment' ;
    rdfs:comment 'Reference to the corresponding IRDS (formerly ITRS) roadmap generation or year that this technology node aligns with. Used for industry benchmarking and planning.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lithographyGeneration rdf:type rdf:Property ;
    rdfs:label 'Lithography Generation' ;
    rdfs:comment 'Primary lithography technology used for patterning at this node. DUV (Deep Ultraviolet) for 28nm and above, EUV (Extreme Ultraviolet) for 7nm and below, hybrid for transitional nodes.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metalPitchNm rdf:type rdf:Property ;
    rdfs:label 'Metal Pitch Nm' ;
    rdfs:comment 'Minimum spacing between metal interconnect lines in the first metal layer, measured in nanometers. Defines routing density.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiPatterningTechnique rdf:type rdf:Property ;
    rdfs:label 'Multi Patterning Technique' ;
    rdfs:comment 'Advanced lithography technique used to achieve sub-wavelength patterning (e.g., LELE - Litho-Etch-Litho-Etch, SADP - Self-Aligned Double Patterning, SAQP - Self-Aligned Quadruple Patterning). Required for nodes below 20nm with DUV lithography.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeMaturityStatus rdf:type rdf:Property ;
    rdfs:label 'Node Maturity Status' ;
    rdfs:comment 'Current lifecycle stage of the technology node. Research: early exploration; Development: process definition; Pilot: qualification runs; Production: volume manufacturing; Mature: stable high-volume; EOL (End of Life): phase-out.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Production Qualification Date' ;
    rdfs:comment 'Date when this technology node achieved production qualification status, meaning it met all yield, reliability, and performance targets for volume manufacturing.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetAreaScalingFactor rdf:type rdf:Property ;
    rdfs:label 'Target Area Scaling Factor' ;
    rdfs:comment 'Expected die area reduction factor compared to the previous technology node generation (e.g., 0.5 represents 50% area reduction). Part of PPA (Power-Performance-Area) characterization.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPerformanceMetricGhz rdf:type rdf:Property ;
    rdfs:label 'Target Performance Metric Ghz' ;
    rdfs:comment 'Target maximum operating frequency for standard cells at this technology node, measured in gigahertz. Part of PPA (Power-Performance-Area) characterization.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPowerMetricMwPerMhz rdf:type rdf:Property ;
    rdfs:label 'Target Power Metric Mw Per Mhz' ;
    rdfs:comment 'Target power consumption metric for this technology node, measured in milliwatts per megahertz. Part of PPA (Power-Performance-Area) characterization.' ;
    rdfs:domain ind:ResearchTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tapeoutProjectId rdf:type rdf:Property ;
    rdfs:label 'Tapeout Project Id' ;
    rdfs:comment 'FK to research.project.project_id — Experimental tapeouts are submitted as part of research projects. This link enables tracking which test chips were produced for which research initiative.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:tapeoutResearchProjectId rdf:type rdf:Property ;
    rdfs:label 'Tapeout Research Project Id' ;
    rdfs:comment 'Identifier of the parent research project or program that this experimental tapeout supports. Links to the broader R&D initiative.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:testPlanId rdf:type rdf:Property ;
    rdfs:label 'Test Plan Id' ;
    rdfs:comment 'Identifier of the characterization and test plan that will be executed on returned silicon. Links to test methodology documentation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestPlan .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'Actual date when fabricated wafers or packaged dies were received back from the foundry. Null if not yet returned.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chipName rdf:type rdf:Property ;
    rdfs:label 'Chip Name' ;
    rdfs:comment 'Name of the test chip, process characterization vehicle (PCV), or technology demonstrator being taped out.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designTeam rdf:type rdf:Property ;
    rdfs:label 'Design Team' ;
    rdfs:comment 'Name or identifier of the design team or research group that executed the chip design for this tapeout.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drcCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Drc Completion Date' ;
    rdfs:comment 'Date when DRC verification was completed and signed off.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drcStatus rdf:type rdf:Property ;
    rdfs:label 'Drc Status' ;
    rdfs:comment 'Status of the design rule check verification. Indicates whether the layout complies with foundry design rules.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Anticipated date when fabricated wafers or packaged dies will be returned from the foundry for testing and characterization.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foundryFabTarget rdf:type rdf:Property ;
    rdfs:label 'Foundry Fab Target' ;
    rdfs:comment 'Name or identifier of the foundry or internal fab facility where this experimental tapeout will be manufactured.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Gds Submission Date' ;
    rdfs:comment 'Date when the final GDS or GDSII design file was submitted to the foundry or fab for mask generation.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipCoreUnderTest rdf:type rdf:Property ;
    rdfs:label 'Ip Core Under Test' ;
    rdfs:comment 'Name or identifier of the IP core being validated in this tapeout (e.g., CPU core, GPU block, memory controller, analog IP). Null if not IP-focused.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lvsCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Lvs Completion Date' ;
    rdfs:comment 'Date when LVS verification was completed and signed off.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lvsStatus rdf:type rdf:Property ;
    rdfs:label 'Lvs Status' ;
    rdfs:comment 'Status of the layout versus schematic verification. Confirms that the physical layout matches the intended circuit schematic.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpwSlotAllocation rdf:type rdf:Property ;
    rdfs:label 'Mpw Slot Allocation' ;
    rdfs:comment 'MPW shuttle slot identifier or allocation code if this tapeout is part of a shared multi-project wafer run. Null if dedicated wafer.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfDiesPerWafer rdf:type rdf:Property ;
    rdfs:label 'Number Of Dies Per Wafer' ;
    rdfs:comment 'Estimated or actual count of dies that can be produced per wafer for this design, based on die size and wafer diameter.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:principalInvestigator rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator' ;
    rdfs:comment 'Name or employee identifier of the lead researcher or principal investigator responsible for this experimental tapeout.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutName rdf:type rdf:Property ;
    rdfs:label 'Tapeout Name' ;
    rdfs:comment 'Human-readable name or designation for this experimental tapeout, typically reflecting the research objective or chip codename.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutPurpose rdf:type rdf:Property ;
    rdfs:label 'Tapeout Purpose' ;
    rdfs:comment 'Primary research objective for this experimental tapeout: process validation, device characterization, IP core validation, yield learning, architecture proof-of-concept, or advanced packaging test.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutToProject rdf:type rdf:Property ;
    rdfs:label 'Tapeout To Project' ;
    rdfs:comment 'FK to research.research_project.research_project_id — Experimental tapeouts are submitted as part of a research project. Links design experiments to their parent project for tracking and funding.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferAllocationType rdf:type rdf:Property ;
    rdfs:label 'Wafer Allocation Type' ;
    rdfs:comment 'Type of wafer allocation for this experimental tapeout: MPW shuttle, dedicated wafer lot, shared research lot, or pilot production run.' ;
    rdfs:domain ind:TapeoutExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaImprovementTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Area Improvement Target Percent' ;
    rdfs:comment 'Target die area reduction percentage or transistor density improvement compared to previous generation, part of PPA (Power Performance Area) metrics.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Benchmark Confidence Level' ;
    rdfs:comment 'Confidence level in the accuracy and reliability of the competitive benchmark data.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBenchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark Source' ;
    rdfs:comment 'Source type of competitive benchmarking data used for strategic positioning analysis.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorDriveCurrent rdf:type rdf:Property ;
    rdfs:label 'Competitor Drive Current' ;
    rdfs:comment 'Benchmarked competitor transistor drive current in microamperes per micrometer (µA/µm), indicating performance capability.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorFrequencyGhz rdf:type rdf:Property ;
    rdfs:label 'Competitor Frequency Ghz' ;
    rdfs:comment 'Benchmarked competitor maximum operating frequency in gigahertz (GHz).' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorLeakageCurrent rdf:type rdf:Property ;
    rdfs:label 'Competitor Leakage Current' ;
    rdfs:comment 'Benchmarked competitor transistor leakage current in nanoamperes per micrometer (nA/µm), indicating power efficiency.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorPowerConsumption rdf:type rdf:Property ;
    rdfs:label 'Competitor Power Consumption' ;
    rdfs:comment 'Benchmarked competitor power consumption in watts (W) or milliwatts per megahertz (mW/MHz).' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorTransistorDensity rdf:type rdf:Property ;
    rdfs:label 'Competitor Transistor Density' ;
    rdfs:comment 'Benchmarked competitor transistor density in millions of transistors per square millimeter (MTr/mm²).' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedNreCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Nre Cost' ;
    rdfs:comment 'Estimated total non-recurring engineering cost in USD required to achieve roadmap milestones.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Investment Priority Level' ;
    rdfs:comment 'Priority level for capital and R&D investment allocation to support this roadmap execution.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyEnablingTechnologies rdf:type rdf:Property ;
    rdfs:label 'Key Enabling Technologies' ;
    rdfs:comment 'Comma-separated list of critical enabling technologies required for roadmap execution (e.g., \'EUV (Extreme Ultraviolet Lithography)\', \'High-NA EUV\', \'ALD (Atomic Layer Deposition)\', \'Selective Etch\').' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceImprovementTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Performance Improvement Target Percent' ;
    rdfs:comment 'Target performance improvement percentage (frequency, speed) compared to previous generation, part of PPA (Power Performance Area) metrics.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'End date of the multi-year planning horizon covered by this roadmap.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'Start date of the multi-year planning horizon covered by this roadmap.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:powerImprovementTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Power Improvement Target Percent' ;
    rdfs:comment 'Target power consumption reduction percentage compared to previous generation, part of PPA (Power Performance Area) metrics.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roadmapName rdf:type rdf:Property ;
    rdfs:label 'Roadmap Name' ;
    rdfs:comment 'Descriptive name of the technology roadmap (e.g., \'Advanced Node Progression 2024-2030\', \'GAA Transition Roadmap\').' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadmapReferencesNodes rdf:type rdf:Property ;
    rdfs:label 'Roadmap References Nodes' ;
    rdfs:comment 'FK to research.technology_node.technology_node_id — Technology roadmaps plan the progression through technology nodes. Each roadmap milestone references target nodes for introduction.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roadmapStatus rdf:type rdf:Property ;
    rdfs:label 'Roadmap Status' ;
    rdfs:comment 'Current lifecycle status of the technology roadmap.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadmapTargetsNode rdf:type rdf:Property ;
    rdfs:label 'Roadmap Targets Node' ;
    rdfs:comment 'FK to research.technology_node.technology_node_id — Technology roadmaps plan the progression through technology nodes. Essential for strategic planning alignment.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roadmapVersion rdf:type rdf:Property ;
    rdfs:label 'Roadmap Version' ;
    rdfs:comment 'Version identifier for the technology roadmap, following semantic versioning convention (e.g., 1.0, 2.1, 3.0.1).' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetIntroductionDate rdf:type rdf:Property ;
    rdfs:label 'Target Introduction Date' ;
    rdfs:comment 'Planned date for technology introduction to production or market availability.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transistorDensityTarget rdf:type rdf:Property ;
    rdfs:label 'Transistor Density Target' ;
    rdfs:comment 'Target transistor density in millions of transistors per square millimeter (MTr/mm²) for this technology generation.' ;
    rdfs:domain ind:TechnologyRoadmap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLearningRecordId rdf:type rdf:Property ;
    rdfs:label 'Yield Learning Record Id' ;
    rdfs:comment 'Unique identifier for the yield learning record. Primary key for this entity.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryYieldLearningEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Yield Learning Engineer Employee Id' ;
    rdfs:comment 'Employee identifier of the learning engineer responsible for this yield learning record.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'Date on which the yield learning analysis was completed and findings were documented.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Baseline Yield Percentage' ;
    rdfs:comment 'Yield percentage measured before corrective actions were implemented, used as the reference point for improvement calculations.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectTypePrimary rdf:type rdf:Property ;
    rdfs:label 'Defect Type Primary' ;
    rdfs:comment 'Primary category of defect identified during yield analysis (e.g., particle contamination, pattern defect, electrical failure). [ENUM-REF-CANDIDATE: Particle|Pattern|Electrical|Scratch|Contamination|Lithography|Etch|Deposition|CMP|Implant|Other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectTypeSecondary rdf:type rdf:Property ;
    rdfs:label 'Defect Type Secondary' ;
    rdfs:comment 'Secondary category of defect contributing to yield loss, if applicable. [ENUM-REF-CANDIDATE: Particle|Pattern|Electrical|Scratch|Contamination|Lithography|Etch|Deposition|CMP|Implant|Other|None — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieCountGood rdf:type rdf:Property ;
    rdfs:label 'Die Count Good' ;
    rdfs:comment 'Number of dies that passed yield testing and are classified as good.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieCountTotal rdf:type rdf:Property ;
    rdfs:label 'Die Count Total' ;
    rdfs:comment 'Total number of dies across all wafers included in this yield learning record.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentIdAffected rdf:type rdf:Property ;
    rdfs:label 'Equipment Id Affected' ;
    rdfs:comment 'Identifier of the specific fabrication equipment tool associated with the yield detractor, if applicable.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Functional Yield Percentage' ;
    rdfs:comment 'Percentage of dies that pass functional testing and meet all electrical specifications. Subset of die yield focusing on operational performance.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionSystemUsed rdf:type rdf:Property ;
    rdfs:label 'Inspection System Used' ;
    rdfs:comment 'Name or identifier of the defect inspection and metrology system used to capture yield and defect data (e.g., KLA ICOS, optical inspection tool).' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningCyclePhase rdf:type rdf:Property ;
    rdfs:label 'Learning Cycle Phase' ;
    rdfs:comment 'Current phase of the yield learning cycle for this record (e.g., initial assessment, root cause analysis, corrective action, validation).' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningEngineerName rdf:type rdf:Property ;
    rdfs:label 'Learning Engineer Name' ;
    rdfs:comment 'Name of the process integration or yield engineer responsible for conducting the yield learning analysis and documenting findings.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paretoAnalysisPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Pareto Analysis Performed Flag' ;
    rdfs:comment 'Indicates whether Pareto analysis was performed to prioritize yield detractors by impact.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processStepAffected rdf:type rdf:Property ;
    rdfs:label 'Process Step Affected' ;
    rdfs:comment 'Specific fabrication process step (e.g., lithography, etch, deposition, CMP) identified as the source of yield loss.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionApplicabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Production Applicability Flag' ;
    rdfs:comment 'Indicates whether the yield learning findings and corrective actions are applicable to production wafer lots and yield ramp planning.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionIntegrationDate rdf:type rdf:Property ;
    rdfs:label 'Production Integration Date' ;
    rdfs:comment 'Date on which the yield learning findings and corrective actions were integrated into production process flows.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseAnalysisFindings rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Findings' ;
    rdfs:comment 'Detailed findings from root cause analysis identifying the underlying process, equipment, or material issues causing yield loss.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Statistical Confidence Level' ;
    rdfs:comment 'Confidence level in the statistical validity of the yield learning findings based on sample size and data quality.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldImprovementDeltaPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Improvement Delta Percentage' ;
    rdfs:comment 'Measured improvement in yield percentage achieved after implementing corrective actions, compared to baseline yield.' ;
    rdfs:domain ind:YieldLearningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activityId rdf:type rdf:Property ;
    rdfs:label 'Activity Id' ;
    rdfs:comment 'Primary key for activity' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Activity Opportunity Id' ;
    rdfs:comment 'Identifier of the sales opportunity linked to this activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle state of the activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Length of the activity measured in minutes.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationResult rdf:type rdf:Property ;
    rdfs:label 'Evaluation Result' ;
    rdfs:comment 'Result of any technical evaluation performed during the activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInternal rdf:type rdf:Property ;
    rdfs:label 'Is Internal' ;
    rdfs:comment 'Flag indicating whether the activity was performed by internal staff (true) or by an external partner (false).' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'Planned date by which the follow-up action identified in the activity should be completed.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Approval Status' ;
    rdfs:comment 'Current approval state of the engineering sample request.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Booking Opportunity Id' ;
    rdfs:comment 'FK to sales.opportunity.opportunity_id — Bookings fulfill opportunities. This link closes the pipeline-to-revenue loop essential for forecast accuracy measurement.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Bookings are tied to a sales territory; FK enables consistent territory hierarchy and reporting.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:bookedQuantity rdf:type rdf:Property ;
    rdfs:label 'Booked Quantity' ;
    rdfs:comment 'Number of units (dies) committed in the booking.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookedRevenueGross rdf:type rdf:Property ;
    rdfs:label 'Booked Revenue Gross' ;
    rdfs:comment 'Total revenue amount before discounts and taxes, in the booking currency.' ;
    rdfs:domain ind:Booking ;
