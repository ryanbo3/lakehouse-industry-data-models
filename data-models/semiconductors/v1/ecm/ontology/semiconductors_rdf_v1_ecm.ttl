    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unscheduledDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Unscheduled Downtime Hours' ;
    rdfs:comment 'Unplanned downtime (e.g., breakdown) duration in hours.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferThroughput rdf:type rdf:Property ;
    rdfs:label 'Wafer Throughput' ;
    rdfs:comment 'Number of good wafers produced per hour (WPH) during the period.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmFabToolId rdf:type rdf:Property ;
    rdfs:label 'Pm Fab Tool Id' ;
    rdfs:comment 'Identifier of the fab tool or chamber to which the schedule applies.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:requiredSparePartId rdf:type rdf:Property ;
    rdfs:label 'Required Spare Part Id' ;
    rdfs:comment 'Identifier of the spare part that must be available for the maintenance.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePart .

ind:complianceRequirement rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement' ;
    rdfs:comment 'Regulatory or industry standard that the maintenance activity must satisfy.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Minutes' ;
    rdfs:comment 'Planned equipment downtime in minutes for the maintenance activity.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intervalUnit rdf:type rdf:Property ;
    rdfs:label 'Interval Unit' ;
    rdfs:comment 'Unit of measure for the interval value (day, week, month, wafer, or run).' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervalValue rdf:type rdf:Property ;
    rdfs:label 'Interval Value' ;
    rdfs:comment 'Numeric value defining the interval between maintenance events (e.g., 500 wafers, 1000 runs, 30 days).' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
