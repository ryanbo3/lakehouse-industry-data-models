ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Category indicating the purpose of the registration such as design win claim or price protection.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesDesignRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Sales Design Registration Status' ;
    rdfs:comment 'Lifecycle status of the registration claim.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRepFirmName rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Firm Name' ;
    rdfs:comment 'Legal name of the sales rep firm.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySalesEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Employee Id' ;
    rdfs:comment 'Identifier of the user who created the record.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySalesSkuId rdf:type rdf:Property ;
