ind:toolFabToolId rdf:type rdf:Property ;
    rdfs:label 'Tool Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: SPC Dashboard links each chart to the Fab Tool that generated the data, enabling tool-level performance monitoring.' ;
    rdfs:domain ind:SpcChart ;
