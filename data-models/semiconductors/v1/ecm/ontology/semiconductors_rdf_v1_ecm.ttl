    rdfs:range xsd:integer .

ind:governanceStructure rdf:type rdf:Property ;
    rdfs:label 'Governance Structure' ;
    rdfs:comment 'High-level governance model of the entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date the entity was legally formed.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryCode rdf:type rdf:Property ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'Standard industry classification (e.g., NAICS) for the entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPublicCompany rdf:type rdf:Property ;
    rdfs:label 'Is Public Company' ;
    rdfs:comment 'Indicates whether the entity is publicly listed.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactDetail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Detail' ;
    rdfs:comment 'Contact information (e.g., email address or phone number) used for the primary contact method.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Method' ;
    rdfs:comment 'Preferred channel for official communications with the entity.' ;
    rdfs:domain ind:LegalEntity ;
