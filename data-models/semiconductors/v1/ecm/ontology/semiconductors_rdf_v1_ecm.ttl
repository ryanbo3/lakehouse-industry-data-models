ind:osatSupplierId rdf:type rdf:Property ;
    rdfs:label 'Osat Supplier Id' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — OSAT work orders are issued to specific OSAT vendors (who are suppliers). Critical for subcontractor management.' ;
    rdfs:domain ind:OsatWorkOrder ;
