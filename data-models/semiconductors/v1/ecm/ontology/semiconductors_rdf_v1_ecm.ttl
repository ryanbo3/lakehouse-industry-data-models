    rdfs:comment 'Effectiveness of the stress screen in removing latent defects, expressed as a percentage.' ;
    rdfs:domain ind:ReliabilityTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stressHumidityPercent rdf:type rdf:Property ;
    rdfs:label 'Stress Humidity Percent' ;
    rdfs:comment 'Relative humidity level maintained during the stress test, expressed as a percentage.' ;
    rdfs:domain ind:ReliabilityTestRun ;
    rdf:type owl:DatatypeProperty ;
