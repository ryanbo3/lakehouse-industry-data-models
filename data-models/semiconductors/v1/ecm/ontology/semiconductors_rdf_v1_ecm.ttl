    rdfs:range xsd:boolean .

ind:complianceRohs rdf:type rdf:Property ;
    rdfs:label 'Compliance Rohs' ;
    rdfs:comment 'True if the device meets Restriction of Hazardous Substances directives.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:devicePartNumber rdf:type rdf:Property ;
    rdfs:label 'Device Part Number' ;
    rdfs:comment 'Manufacturer part number of the device claimed in the registration.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount off the list price that is part of the protected pricing terms.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endApplication rdf:type rdf:Property ;
    rdfs:label 'End Application' ;
    rdfs:comment 'Description of the final application or market for the registered design.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Volume' ;
    rdfs:comment 'Projected number of units the customer will purchase per year.' ;
