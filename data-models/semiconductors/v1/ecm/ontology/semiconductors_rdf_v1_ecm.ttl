    rdfs:range xsd:string .

ind:talentAcquisitionDescription rdf:type rdf:Property ;
    rdfs:label 'Talent Acquisition Description' ;
    rdfs:comment 'Detailed description of duties, responsibilities, and required qualifications.' ;
    rdfs:domain ind:TalentAcquisition ;
