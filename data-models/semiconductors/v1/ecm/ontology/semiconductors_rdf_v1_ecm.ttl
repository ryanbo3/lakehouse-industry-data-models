    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Code' ;
    rdfs:comment 'Standard code describing the root cause of downtime.' ;
