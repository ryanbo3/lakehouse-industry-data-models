    rdfs:comment 'System-generated unique identifier for each supplier quality scorecard record.' ;
    rdfs:domain ind:SupplierQualityScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End' ;
    rdfs:comment 'Last day of the reporting period covered by the scorecard.' ;
    rdfs:domain ind:SupplierQualityScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start' ;
    rdfs:comment 'First day of the reporting period covered by the scorecard.' ;
    rdfs:domain ind:SupplierQualityScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:improvementActionPlan rdf:type rdf:Property ;
