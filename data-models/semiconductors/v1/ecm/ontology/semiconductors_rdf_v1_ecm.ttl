    rdfs:range xsd:dateTime .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Description of the product family or line to which the declaration applies (e.g., ICs, packaging).' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcoiMethodology rdf:type rdf:Property ;
    rdfs:label 'Rcoi Methodology' ;
    rdfs:comment 'Methodology used to conduct the Reasonable Country of Origin Inquiry.' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Requirement' ;
    rdfs:comment 'Regulatory framework under which the declaration is reported.' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'Fiscal year for which the conflict minerals data is reported.' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secFilingDate rdf:type rdf:Property ;
    rdfs:label 'Sec Filing Date' ;
    rdfs:comment 'Date on which the declaration was filed with the U.S. Securities and Exchange Commission.' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:smelterRefinerList rdf:type rdf:Property ;
    rdfs:label 'Smelter Refiner List' ;
    rdfs:comment 'Comma-separated list of smelters and refiners (SOR) used in the supply chain for the declared product.' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCountryOfMaterial rdf:type rdf:Property ;
    rdfs:label 'Source Country Of Material' ;
    rdfs:comment 'Primary country where the raw material containing the conflict minerals was sourced.' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Certification Status' ;
    rdfs:comment 'Current certification status of the supplier(s) providing the minerals.' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyVerification rdf:type rdf:Property ;
    rdfs:label 'Third Party Verification' ;
    rdfs:comment 'Indicates whether a third-party verification service was used.' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalMaterialWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Material Weight Kg' ;
    rdfs:comment 'Total weight of the product or component in kilograms used for the percentage calculation.' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationDocumentPath rdf:type rdf:Property ;
    rdfs:label 'Verification Document Path' ;
    rdfs:comment 'File system or URL path to the uploaded audit or verification documents.' ;
    rdfs:domain ind:ConflictMineralsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eccnClassificationId rdf:type rdf:Property ;
    rdfs:label 'Eccn Classification Id' ;
    rdfs:comment 'Surrogate primary key for the ECCN classification master record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EccnClassification .

ind:eccnExportLicenseId rdf:type rdf:Property ;
    rdfs:label 'Eccn Export License Id' ;
    rdfs:comment 'FK to compliance.export_license.export_license_id — Export licenses authorize specific ECCN-classified items. The license must reference the ECCN classification to validate commodity scope. Critical for license applicability determination.' ;
    rdfs:domain ind:EccnClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExportLicense .

ind:toExportLicenseId rdf:type rdf:Property ;
    rdfs:label 'To Export License Id' ;
    rdfs:comment 'FK to compliance.export_license.export_license_id — Export licenses are issued for specific ECCN-classified items. The ECCN classification drives license requirement determination.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExportLicense .

ind:changeHistory rdf:type rdf:Property ;
    rdfs:label 'Change History' ;
    rdfs:comment 'Chronological log of changes made to the ECCN record.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationRationale rdf:type rdf:Property ;
    rdfs:label 'Classification Rationale' ;
    rdfs:comment 'Narrative explanation of why the specific ECCN was assigned.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Classification Timestamp' ;
    rdfs:comment 'Date and time when the ECCN classification was recorded.' ;
    rdfs:domain ind:EccnClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:classificationVersion rdf:type rdf:Property ;
    rdfs:label 'Classification Version' ;
    rdfs:comment 'Version identifier for the ECCN classification record (e.g., v1.0).' ;
    rdfs:domain ind:EccnClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classifyingEngineer rdf:type rdf:Property ;
    rdfs:label 'Classifying Engineer' ;
    rdfs:comment 'Name of the engineer or specialist who performed the ECCN classification.' ;
    rdfs:domain ind:EccnClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingParameter rdf:type rdf:Property ;
    rdfs:label 'Controlling Parameter' ;
    rdfs:comment 'Key parameter that drives the ECCN decision (e.g., process node, performance level).' ;
    rdfs:domain ind:EccnClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deminimisValueUsd rdf:type rdf:Property ;
    rdfs:label 'Deminimis Value Usd' ;
    rdfs:comment 'Monetary threshold below which export licensing may be waived.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earControlCodes rdf:type rdf:Property ;
    rdfs:label 'Ear Control Codes' ;
    rdfs:comment 'Comma-separated list of applicable EAR control codes (e.g., AT, NS, MT, CB, RS, SS, UN, EI). [ENUM-REF-CANDIDATE: AT|NS|MT|CB|RS|SS|UN|EI — promote to reference product]' ;
    rdfs:domain ind:EccnClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eccnClassificationStatus rdf:type rdf:Property ;
    rdfs:label 'Eccn Classification Status' ;
    rdfs:comment 'Current lifecycle status of the ECCN record.' ;
    rdfs:domain ind:EccnClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eccnCode rdf:type rdf:Property ;
    rdfs:label 'Eccn Code' ;
    rdfs:comment 'Official ECCN code assigned to the product, IP core, technology or software (e.g., 3A001).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when the ECCN classification expires or is superseded (null if open-ended).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which the ECCN classification is considered effective.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Export License Required' ;
    rdfs:comment 'Indicates whether an export license is required for the classified item.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipCoreIdentifier rdf:type rdf:Property ;
    rdfs:label 'Ip Core Identifier' ;
    rdfs:comment 'Identifier for an IP core or reusable design block that may have a distinct ECCN.' ;
    rdfs:domain ind:EccnClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeemedExport rdf:type rdf:Property ;
    rdfs:label 'Is Deemed Export' ;
    rdfs:comment 'Indicates whether the item is subject to deemed export rules.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the ECCN record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Identifier of the export license associated with the ECCN, if applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next ECCN review.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceMetric rdf:type rdf:Property ;
    rdfs:label 'Performance Metric' ;
    rdfs:comment 'Key performance metric used as a controlling parameter for classification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processNodeNm rdf:type rdf:Property ;
    rdfs:label 'Process Node Nm' ;
    rdfs:comment 'Technology node size in nanometers that influences classification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'High-level category of the product to which the ECCN applies.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productIdentifier rdf:type rdf:Property ;
    rdfs:label 'Product Identifier' ;
    rdfs:comment 'Unique part number or SKU that identifies the semiconductor product to which the ECCN applies.' ;
    rdfs:domain ind:EccnClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory regime governing the classification.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedCountryList rdf:type rdf:Property ;
    rdfs:label 'Restricted Country List' ;
    rdfs:comment 'Comma-separated list of country codes where export is restricted.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Number of months between mandatory ECCN review cycles.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'System of record where the ECCN classification originated.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyType rdf:type rdf:Property ;
    rdfs:label 'Technology Type' ;
    rdfs:comment 'Category of the technology subject to classification.' ;
    rdfs:domain ind:EccnClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseId rdf:type rdf:Property ;
    rdfs:label 'Export License Id' ;
    rdfs:comment 'Unique identifier for the export license record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExportLicense .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Export licenses are issued to specific customer accounts; required for license management reports and export compliance tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:empoweredOfficialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Empowered Official Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Export-license issuance requires an authorized official (employee) to sign off per export regulations.' ;
    rdfs:domain ind:ExportLicense ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizedCommodities rdf:type rdf:Property ;
    rdfs:label 'Authorized Commodities' ;
    rdfs:comment 'List of controlled items or technology categories covered by the license.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedCountries rdf:type rdf:Property ;
    rdfs:label 'Authorized Countries' ;
    rdfs:comment 'ISO 3-letter country codes where export is permitted.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedEndUsers rdf:type rdf:Property ;
    rdfs:label 'Authorized End Users' ;
    rdfs:comment 'Names of approved end-user organizations or individuals.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAgreement rdf:type rdf:Property ;
    rdfs:label 'Compliance Agreement' ;
    rdfs:comment 'Reference to the signed compliance agreement document.' ;
    rdfs:domain ind:ExportLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditions rdf:type rdf:Property ;
    rdfs:label 'Conditions' ;
    rdfs:comment 'Specific conditions, restrictions, or reporting requirements attached to the license.' ;
    rdfs:domain ind:ExportLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseCertificateType rdf:type rdf:Property ;
    rdfs:label 'End Use Certificate Type' ;
    rdfs:comment 'Type of supporting end-use documentation.' ;
    rdfs:domain ind:ExportLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseDescription rdf:type rdf:Property ;
    rdfs:label 'End Use Description' ;
    rdfs:comment 'Description of the intended end use of the exported technology.' ;
    rdfs:domain ind:ExportLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUserAddress rdf:type rdf:Property ;
    rdfs:label 'End User Address' ;
    rdfs:comment 'Physical address of the end user.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUserName rdf:type rdf:Property ;
    rdfs:label 'End User Name' ;
    rdfs:comment 'Name of the end user or recipient of the exported item.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseStatus rdf:type rdf:Property ;
    rdfs:label 'Export License Status' ;
    rdfs:comment 'Current lifecycle status of the license.' ;
    rdfs:domain ind:ExportLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Government agency that issued the license (e.g., BIS, DDTC).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Category of export authorization.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCategory rdf:type rdf:Property ;
    rdfs:label 'Registration Category' ;
    rdfs:comment 'ITAR registration category for the entity.' ;
    rdfs:domain ind:ExportLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Deadline by which renewal must be submitted.' ;
    rdfs:domain ind:ExportLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether the license must be renewed before expiry.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usmlCategory rdf:type rdf:Property ;
    rdfs:label 'Usml Category' ;
    rdfs:comment 'United States Munitions List category applicable for ITAR licenses.' ;
    rdfs:domain ind:ExportLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueCeiling rdf:type rdf:Property ;
    rdfs:label 'Value Ceiling' ;
    rdfs:comment 'Maximum monetary value allowed under the license.' ;
    rdfs:domain ind:ExportLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when verification was completed.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of end-use verification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseUsageId rdf:type rdf:Property ;
    rdfs:label 'Export License Usage Id' ;
    rdfs:comment 'System-generated unique identifier for each export license usage record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExportLicenseUsage .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Usage records capture which employee created the entry for auditability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fabricationWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Fabrication Wafer Lot Id' ;
    rdfs:comment 'Foreign key linking to fabrication.fabrication_wafer_lot. Business justification: Export License Usage reports track which wafer lot consumed the licensed technology, essential for audit of export-controlled semiconductor shipments.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:primaryExportLicenseId rdf:type rdf:Property ;
    rdfs:label 'Primary Export License Id' ;
    rdfs:comment 'Internal surrogate key referencing the export license that is being drawn down.' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExportLicense .

ind:toExportLicense rdf:type rdf:Property ;
    rdfs:label 'To Export License' ;
    rdfs:comment 'FK to compliance.export_license.export_license_id — Every license usage drawdown MUST reference its parent export license. Without this FK, usage records are orphaned and license balance tracking is impossible. Production-critical for BIS reporting.' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExportLicense .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'Free-form notes capturing audit comments, exceptions, or manual adjustments.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityUsmlCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Usml Category' ;
    rdfs:comment 'United States Munitions List category, if the commodity falls under ITAR.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Legal name of the consignee organization or individual.' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeLicenseUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Cumulative License Utilization Percent' ;
    rdfs:comment 'Running percentage of the total licensed quantity that has been used.' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code of the declared value.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValue rdf:type rdf:Property ;
    rdfs:label 'Declared Value' ;
    rdfs:comment 'Monetary value declared for customs and licensing purposes.' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the shipment destination.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlRegulation rdf:type rdf:Property ;
    rdfs:label 'Export Control Regulation' ;
    rdfs:comment 'Regulatory regime governing the export (e.g., EAR, ITAR).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportDate rdf:type rdf:Property ;
    rdfs:label 'Export Date' ;
    rdfs:comment 'Date the shipment was exported and the license drawdown occurred.' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportLicenseType rdf:type rdf:Property ;
    rdfs:label 'Export License Type' ;
    rdfs:comment 'Classification of the license (e.g., General, Specific, Temporary).' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseUsageStatus rdf:type rdf:Property ;
    rdfs:label 'Export License Usage Status' ;
    rdfs:comment 'Current lifecycle status of the usage record.' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Sensitive' ;
    rdfs:comment 'Indicates whether the usage record contains information subject to heightened confidentiality.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseBalanceRemaining rdf:type rdf:Property ;
    rdfs:label 'License Balance Remaining' ;
    rdfs:comment 'Remaining quantity or value available under the export license after this drawdown.' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Numeric amount of the commodity shipped.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the exported quantity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the usage record was first created in the system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the usage record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentReference rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference' ;
    rdfs:comment 'Internal reference number for the physical shipment tied to this usage.' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageNumber rdf:type rdf:Property ;
    rdfs:label 'Usage Number' ;
    rdfs:comment 'Business identifier assigned to the usage event, often used in audit and reporting.' ;
    rdfs:domain ind:ExportLicenseUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerEmployeeId rdf:type rdf:Property ;
