ind:mitigationActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions Taken' ;
    rdfs:comment 'Actions executed to mitigate the disruption impact.' ;
    rdfs:domain ind:RiskAssessment ;
