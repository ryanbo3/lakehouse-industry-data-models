    rdfs:comment 'Foreign key linking to research.project. Business justification: Design Registration process requires tying the customer\'s registration to the internal research project developing the part for coordination and status reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:salesRepEmployeeId rdf:type rdf:Property ;
