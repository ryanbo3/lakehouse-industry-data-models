# --- Attribute Properties ---
ind:auditEventId rdf:type rdf:Property ;
    rdfs:label 'Audit Event Id' ;
    rdfs:comment 'Unique system-generated identifier for the audit event record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditEvent .

ind:leadAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Audit Management assigns a lead auditor employee to each audit for accountability and reporting.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditCategory rdf:type rdf:Property ;
    rdfs:label 'Audit Category' ;
    rdfs:comment 'Top-level classification of the audit focus area.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditConductedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Conducted Timestamp' ;
    rdfs:comment 'Exact date-time when the audit was officially started.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'Calendar date when the audit activities concluded.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditLanguage rdf:type rdf:Property ;
    rdfs:label 'Audit Language' ;
    rdfs:comment 'Primary language used for the audit documentation and communication.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Free-form comments or observations recorded by the auditor.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Human-readable audit number assigned by the compliance team.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRegion rdf:type rdf:Property ;
    rdfs:label 'Audit Region' ;
    rdfs:comment 'Three-letter ISO country code where the audited site is located.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Narrative description of the processes, products, or sites covered by the audit.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStandard rdf:type rdf:Property ;
    rdfs:label 'Audit Standard' ;
    rdfs:comment 'Standard or regulatory framework against which the audit is performed.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Start Date' ;
    rdfs:comment 'Calendar date when the audit activities commenced.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Category of audit based on initiator or purpose.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditVersion rdf:type rdf:Property ;
    rdfs:label 'Audit Version' ;
    rdfs:comment 'Version identifier of the audit standard or internal procedure applied.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBody rdf:type rdf:Property ;
    rdfs:label 'Auditing Body' ;
    rdfs:comment 'Organization or authority conducting the audit (e.g., internal audit team, external certifier).' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Current closure state of the audit record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Deadline by which all corrective actions must be completed.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanSummary rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Summary' ;
    rdfs:comment 'High-level description of the remediation plan agreed upon.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'Link to the digital folder or repository containing audit reports and evidence.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Concise summary of all major and minor findings.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Stage of the audit within its overall lifecycle.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of critical non-conformances identified.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of less-critical observations identified.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Final outcome of the audit after evaluation of findings.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when this audit event record was first created in the system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent modification to this audit event record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk classification assigned based on audit findings and impact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAudited rdf:type rdf:Property ;
    rdfs:label 'Site Audited' ;
    rdfs:comment 'Name of the fab, OSAT partner, or supplier location that was audited.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Primary key for certification' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:holderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Holder Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Certification management tracks the employee responsible for maintaining the certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Summary' ;
    rdfs:comment 'High-level summary of audit findings and any non-conformities.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Number of months between required audits.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditReportUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Report Url' ;
    rdfs:comment 'Link to the audit report document.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique identifier assigned by the certifying body.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Standard or scheme of the certification (e.g., ISO 9001, IATF 16949, SEMI S2, AEC-Q100). [ENUM-REF-CANDIDATE: ISO 9001|IATF 16949|ISO 14001|ISO 45001|ISO 27001|SEMI S2|SEMI S8|AEC-Q100|AEC-Q104|AEC-Q200|IECQ|TL 9000 — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'Organization that issued the certification (e.g., ISO, SEMI, IEC).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'Broad category of compliance the certification addresses.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Risk Level' ;
    rdfs:comment 'Risk rating associated with the certification compliance.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Status Effective Date' ;
    rdfs:comment 'Date when the current compliance status became effective.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the certification record was first created in the system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Link to the digital copy of the certification document.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Notice Date' ;
    rdfs:comment 'Date when the expiration notice was sent.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationNoticeSent rdf:type rdf:Property ;
    rdfs:label 'Expiration Notice Sent' ;
    rdfs:comment 'Indicates whether a notice of upcoming expiration has been sent.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date when the certification expires.' ;
    rdfs:domain ind:Semiconductors ;
