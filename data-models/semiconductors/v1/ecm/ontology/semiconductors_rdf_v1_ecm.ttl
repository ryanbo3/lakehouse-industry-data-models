    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMode rdf:type rdf:Property ;
    rdfs:label 'Measurement Mode' ;
    rdfs:comment 'Indicates whether the measurement was performed inline with production or offline.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Category of the physical parameter measured during the run.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metrologyRunStatus rdf:type rdf:Property ;
    rdfs:label 'Metrology Run Status' ;
    rdfs:comment 'Current lifecycle state of the run.' ;
