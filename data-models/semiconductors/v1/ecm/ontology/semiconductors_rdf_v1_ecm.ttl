    rdfs:comment 'Percentage of incoming parts that meet quality specifications.' ;
    rdfs:domain ind:SupplierQualityScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiResponsiveness rdf:type rdf:Property ;
