ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique surrogate key for each time entry record.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who logged the time.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Employee Id' ;
    rdfs:comment 'FK to workforce.employee.employee_id — Time entries must reference the employee who worked the hours. Critical for labor cost allocation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:timeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Time Employee Id' ;
    rdfs:comment 'FK to workforce.employee.employee_id — Time entries must reference the employee who worked the hours. Critical for labor cost allocation to fab cost centers.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceDurationHours rdf:type rdf:Property ;
    rdfs:label 'Absence Duration Hours' ;
    rdfs:comment 'Number of hours attributed to the recorded absence.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:absenceType rdf:type rdf:Property ;
    rdfs:label 'Absence Type' ;
    rdfs:comment 'Classification of the absence recorded for the employee.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'Exact moment the employee started the shift or activity.' ;
    rdfs:domain ind:TimeEntry ;
