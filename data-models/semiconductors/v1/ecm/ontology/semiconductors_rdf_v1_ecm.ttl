ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'Indicates whether the equipment is classified as critical for production (true) or not (false).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPerformedDate rdf:type rdf:Property ;
    rdfs:label 'Last Performed Date' ;
    rdfs:comment 'Date on which the maintenance activity was last executed.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window End' ;
    rdfs:comment 'Planned end time of the maintenance window.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maintenanceWindowStart rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window Start' ;
    rdfs:comment 'Planned start time of the maintenance window.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Date' ;
    rdfs:comment 'Planned calendar date for the next execution of the maintenance.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Oee Impact Estimate' ;
    rdfs:comment 'Estimated impact of the maintenance on Overall Equipment Effectiveness expressed as a percentage.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Pm Procedure Reference' ;
    rdfs:comment 'Reference code or document ID for the detailed preventive maintenance procedure.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Description' ;
    rdfs:comment 'Free-text description of the maintenance activity and its purpose.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the schedule.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmType rdf:type rdf:Property ;
    rdfs:label 'Pm Type' ;
    rdfs:comment 'Category of preventive maintenance activity (e.g., daily, weekly, monthly, wafer-count-based, run-count-based).' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTechnicianSkillLevel rdf:type rdf:Property ;
    rdfs:label 'Required Technician Skill Level' ;
    rdfs:comment 'Skill level required of the technician performing the maintenance.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Business code used to uniquely reference the schedule across systems.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name describing the maintenance schedule.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingConstraint rdf:type rdf:Property ;
    rdfs:label 'Scheduling Constraint' ;
    rdfs:comment 'Business rule or production window constraint that influences when the PM can be run.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Work Order Template Code' ;
    rdfs:comment 'Identifier of the work-order template used to generate PM work orders.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipeExecutionId rdf:type rdf:Property ;
    rdfs:label 'Recipe Execution Id' ;
    rdfs:comment 'Unique system-generated identifier for each recipe execution event.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Foreign key linking to invoice.invoice_line. Business justification: Each recipe execution billed as a line item; linking to invoice_line captures execution details for revenue recognition and traceability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:primaryRecipeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Recipe Employee Id' ;
    rdfs:comment 'Identifier of the human operator who initiated or supervised the execution.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recipeFabToolId rdf:type rdf:Property ;
    rdfs:label 'Recipe Fab Tool Id' ;
    rdfs:comment 'Identifier of the fab tool (e.g., lithography scanner, deposition system) where the recipe was executed.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Category of equipment (e.g., \'Lithography\', \'CVD\', \'Etcher\').' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Outcome of the recipe execution: pass, fail, or abort.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gasFlowActualSccm rdf:type rdf:Property ;
    rdfs:label 'Gas Flow Actual Sccm' ;
    rdfs:comment 'Measured gas flow rate during the run.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gasFlowSetpointSccm rdf:type rdf:Property ;
    rdfs:label 'Gas Flow Setpoint Sccm' ;
    rdfs:comment 'Target gas flow rate in standard cubic centimeters per minute.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCalibrated rdf:type rdf:Property ;
    rdfs:label 'Is Calibrated' ;
    rdfs:comment 'True if the tool was calibrated immediately before execution; otherwise false.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeeAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Percent' ;
    rdfs:comment 'Availability component of Overall Equipment Effectiveness for this execution.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeePerformancePercent rdf:type rdf:Property ;
    rdfs:label 'Oee Performance Percent' ;
    rdfs:comment 'Performance component of Overall Equipment Effectiveness for this execution.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeQualityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Quality Percent' ;
    rdfs:comment 'Quality component of Overall Equipment Effectiveness for this execution.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerActualW rdf:type rdf:Property ;
    rdfs:label 'Power Actual W' ;
    rdfs:comment 'Measured power delivered during execution.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerSetpointW rdf:type rdf:Property ;
    rdfs:label 'Power Setpoint W' ;
    rdfs:comment 'Target power level for plasma or laser processes, in watts.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressureActualPa rdf:type rdf:Property ;
    rdfs:label 'Pressure Actual Pa' ;
    rdfs:comment 'Measured chamber pressure during execution.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Logical name of the process step within the overall flow (e.g., \'Etch\', \'Deposition\').' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeVersion rdf:type rdf:Property ;
    rdfs:label 'Recipe Version' ;
    rdfs:comment 'Version string of the recipe (e.g., v3.2.1) applied during the run.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultCode rdf:type rdf:Property ;
    rdfs:label 'Result Code' ;
    rdfs:comment 'Machine-generated code providing detailed reason for pass/fail/abort.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureActualC rdf:type rdf:Property ;
    rdfs:label 'Temperature Actual C' ;
    rdfs:comment 'Measured temperature achieved during execution.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeActualSec rdf:type rdf:Property ;
    rdfs:label 'Time Actual Sec' ;
    rdfs:comment 'Measured duration the step actually ran.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeSetpointSec rdf:type rdf:Property ;
    rdfs:label 'Time Setpoint Sec' ;
    rdfs:comment 'Target duration for the process step, in seconds.' ;
    rdfs:domain ind:RecipeExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sparePartId rdf:type rdf:Property ;
    rdfs:label 'Spare Part Id' ;
    rdfs:comment 'Unique surrogate key for each spare part record.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePart .

ind:calibrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Required Flag' ;
    rdfs:comment 'True if the part must be calibrated periodically (e.g., sensors, metrology tools).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'Comma-separated list of regulatory or industry certifications applicable to the part (e.g., RoHS, REACH).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityRating rdf:type rdf:Property ;
    rdfs:label 'Criticality Rating' ;
    rdfs:comment 'Business impact rating if the part is unavailable (high = production-stop risk).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStockQty rdf:type rdf:Property ;
    rdfs:label 'Current Stock Qty' ;
    rdfs:comment 'Number of units of the part currently available in the fab stockroom.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentCompatible rdf:type rdf:Property ;
    rdfs:label 'Equipment Compatible' ;
    rdfs:comment 'List of equipment models or tool families that can use this spare part.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the part is classified as hazardous under safety regulations.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Result of the most recent inspection activity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date the part was most recently inspected for quality or safety compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Received Date' ;
    rdfs:comment 'Date the most recent shipment of this part was received into inventory.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Average number of calendar days from order placement to receipt of the part.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Lifecycle End Date' ;
    rdfs:comment 'Date the part was officially retired or marked obsolete.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Start Date' ;
    rdfs:comment 'Date the part was first introduced into the inventory catalog.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific storage bin or area within the fab stockroom.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minStockLevel rdf:type rdf:Property ;
    rdfs:label 'Min Stock Level' ;
    rdfs:comment 'Minimum quantity that must be on hand to avoid stock-out situations.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partCategory rdf:type rdf:Property ;
    rdfs:label 'Part Category' ;
    rdfs:comment 'High-level equipment domain the part supports. [ENUM-REF-CANDIDATE: lithography|deposition|etch|cmp|metrology|ate|assembly|test|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partImageUrl rdf:type rdf:Property ;
    rdfs:label 'Part Image Url' ;
    rdfs:comment 'Link to a digital image or drawing of the spare part.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partName rdf:type rdf:Property ;
    rdfs:label 'Part Name' ;
    rdfs:comment 'Human-readable name of the spare part used in inventory and work orders.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partType rdf:type rdf:Property ;
    rdfs:label 'Part Type' ;
    rdfs:comment 'Classification of the part based on its usage and criticality to fab operations.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partVolumeCm3 rdf:type rdf:Property ;
    rdfs:label 'Part Volume Cm3' ;
    rdfs:comment 'Physical volume of a single unit of the part in cubic centimeters.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partWeightKg rdf:type rdf:Property ;
    rdfs:label 'Part Weight Kg' ;
    rdfs:comment 'Physical weight of a single unit of the part in kilograms.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory quantity threshold that triggers a replenishment order.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Buffer quantity kept to protect against demand variability and supply delays.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartDescription rdf:type rdf:Property ;
    rdfs:label 'Spare Part Description' ;
    rdfs:comment 'Detailed textual description of the part, including function and key specifications.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartStatus rdf:type rdf:Property ;
    rdfs:label 'Spare Part Status' ;
    rdfs:comment 'Current lifecycle status of the part within the inventory system.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Environmental condition required for safe storage of the part.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplier rdf:type rdf:Property ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Primary external supplier or vendor from which the part is sourced.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard purchase cost per individual unit of the part.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spcControlId rdf:type rdf:Property ;
    rdfs:label 'Spc Control Id' ;
    rdfs:comment 'Primary key for spc_control' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySpcEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Spc Employee Id' ;
    rdfs:comment 'Identifier of the operator who acknowledged or entered the violation.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:spcChartId rdf:type rdf:Property ;
    rdfs:label 'Spc Chart Id' ;
    rdfs:comment 'Identifier of the SPC control chart configuration associated with this violation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpcChart .

ind:analysisTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Timestamp' ;
    rdfs:comment 'Timestamp when the violation was analyzed for root cause.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chartType rdf:type rdf:Property ;
    rdfs:label 'Chart Type' ;
    rdfs:comment 'Statistical chart type used for monitoring (X-Bar/R, EWMA, or CUSUM).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlLimitLclAtTime rdf:type rdf:Property ;
    rdfs:label 'Control Limit Lcl At Time' ;
    rdfs:comment 'Lower control limit value that was in effect at the moment of detection.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlLimitUclAtTime rdf:type rdf:Property ;
    rdfs:label 'Control Limit Ucl At Time' ;
    rdfs:comment 'Upper control limit value that was in effect at the moment of detection.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Reference' ;
    rdfs:comment 'Reference code or document identifier for the corrective action plan.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Duplicate of event_timestamp for legacy reporting compatibility.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Immediate action taken in response to the violation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFalseAlarm rdf:type rdf:Property ;
    rdfs:label 'Is False Alarm' ;
    rdfs:comment 'Flag indicating whether the violation was later determined to be a false alarm.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatViolation rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Violation' ;
    rdfs:comment 'Indicates if this violation is a repeat occurrence within a defined time window.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcl rdf:type rdf:Property ;
    rdfs:label 'Lcl' ;
    rdfs:comment 'Statistical lower control limit for the monitored parameter at the time of chart configuration.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReported rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reported' ;
    rdfs:comment 'Indicates whether the violation has been reported to a regulatory body (e.g., SEMI, ISO).' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationDeadline rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline' ;
    rdfs:comment 'Target date by which corrective actions must be completed.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation effort.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Narrative description of the identified root cause for the violation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSet rdf:type rdf:Property ;
    rdfs:label 'Rule Set' ;
    rdfs:comment 'Specific Western Electric rule(s) that were violated.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency' ;
    rdfs:comment 'How often samples are taken for the monitored parameter.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business-defined severity rating of the SPC breach.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcControlStatus rdf:type rdf:Property ;
    rdfs:label 'Spc Control Status' ;
    rdfs:comment 'Current lifecycle status of the violation record.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'Direction of the observed trend when a trend rule is violated.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ucl rdf:type rdf:Property ;
    rdfs:label 'Ucl' ;
    rdfs:comment 'Statistical upper control limit for the monitored parameter at the time of chart configuration.' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Classification of the out-of-control condition (UCL breach, LCL breach, run-rule, trend, or outlier).' ;
    rdfs:domain ind:SpcControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolAlarmId rdf:type rdf:Property ;
    rdfs:label 'Tool Alarm Id' ;
    rdfs:comment 'Unique surrogate key for each alarm event generated by semiconductor manufacturing equipment.' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alarmCategory rdf:type rdf:Property ;
    rdfs:label 'Alarm Category' ;
    rdfs:comment 'High-level classification of the alarm type for reporting and analytics.' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Alarm Duration Seconds' ;
    rdfs:comment 'Elapsed time in seconds from alarm onset to clearance.' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alarmGroup rdf:type rdf:Property ;
    rdfs:label 'Alarm Group' ;
    rdfs:comment 'Logical grouping identifier for related alarms (e.g., temperature excursions, pressure drops).' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmMessage rdf:type rdf:Property ;
    rdfs:label 'Alarm Message' ;
    rdfs:comment 'Human-readable description of the alarm condition provided by the equipment.' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmOrigin rdf:type rdf:Property ;
    rdfs:label 'Alarm Origin' ;
    rdfs:comment 'Indicates whether the alarm was generated automatically by the tool or manually triggered.' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmPriority rdf:type rdf:Property ;
    rdfs:label 'Alarm Priority' ;
    rdfs:comment 'Numeric priority assigned to the alarm for routing and escalation (higher = more urgent).' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alarmSeverity rdf:type rdf:Property ;
    rdfs:label 'Alarm Severity' ;
    rdfs:comment 'Severity level of the alarm indicating impact on production (critical, major, minor, warning, info).' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmSource rdf:type rdf:Property ;
    rdfs:label 'Alarm Source' ;
    rdfs:comment 'Logical source within the tool that raised the alarm (e.g., chamber, subsystem, sensor, control system).' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alarm Timestamp' ;
    rdfs:comment 'Date and time when the alarm condition was first detected on the tool.' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Planned or executed corrective action taken to resolve the alarm condition.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentLocation rdf:type rdf:Property ;
    rdfs:label 'Equipment Location' ;
    rdfs:comment 'Plant or fab line location where the equipment resides (e.g., FAB1_LINEA).' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Oee Impact Flag' ;
    rdfs:comment 'Indicates whether the alarm had a measurable impact on Overall Equipment Effectiveness.' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predictedFailureFlag rdf:type rdf:Property ;
    rdfs:label 'Predicted Failure Flag' ;
    rdfs:comment 'True if the alarm is identified by predictive models as a precursor to equipment failure.' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatCount rdf:type rdf:Property ;
    rdfs:label 'Repeat Count' ;
    rdfs:comment 'Number of times the same alarm code has recurred within a defined time window.' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceModule rdf:type rdf:Property ;
    rdfs:label 'Source Module' ;
    rdfs:comment 'Name of the source system or module that supplied the alarm (e.g., MES, KLA ICOS, Camstar).' ;
    rdfs:domain ind:ToolAlarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolCapexId rdf:type rdf:Property ;
    rdfs:label 'Tool Capex Id' ;
    rdfs:comment 'Unique surrogate key for each tool capital expenditure record.' ;
    rdfs:domain ind:ToolCapex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceProviderSupplierId rdf:type rdf:Property ;
    rdfs:label 'Service Provider Supplier Id' ;
    rdfs:comment 'Identifier of the third-party service organization responsible for maintenance contracts.' ;
    rdfs:domain ind:ToolCapex ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:capexDate rdf:type rdf:Property ;
    rdfs:label 'Capex Date' ;
    rdfs:comment 'Date when the capex transaction was recorded or approved.' ;
    rdfs:domain ind:ToolCapex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capexNumber rdf:type rdf:Property ;
    rdfs:label 'Capex Number' ;
    rdfs:comment 'External reference number assigned to the capex project for tracking and audit.' ;
    rdfs:domain ind:ToolCapex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

