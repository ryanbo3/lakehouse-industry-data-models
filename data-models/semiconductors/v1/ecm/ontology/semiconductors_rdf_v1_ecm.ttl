ind:unitAssemblyCost rdf:type rdf:Property ;
    rdfs:label 'Unit Assembly Cost' ;
    rdfs:comment 'Cost to assemble a single die/package unit, excluding NRE.' ;
    rdfs:domain ind:OsatWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Po Material Master Id' ;
    rdfs:comment 'FK to supply.material_master.material_master_id — Each PO line procures a specific material. Essential for material traceability and MRP consumption.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
