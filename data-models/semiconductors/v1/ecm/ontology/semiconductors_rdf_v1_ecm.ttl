    rdfs:range xsd:integer .

ind:fabCode rdf:type rdf:Property ;
    rdfs:label 'Fab Code' ;
    rdfs:comment 'Business-assigned unique code for the fab.' ;
    rdfs:domain ind:Fab ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabRegion rdf:type rdf:Property ;
    rdfs:label 'Fab Region' ;
    rdfs:comment 'Broad geographic region where the fab is located.' ;
    rdfs:domain ind:Fab ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabType rdf:type rdf:Property ;
    rdfs:label 'Fab Type' ;
    rdfs:comment 'Classification of the fab based on process focus.' ;
