    rdfs:range xsd:date .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Planned start date for the new hire.' ;
    rdfs:domain ind:TalentAcquisition ;
