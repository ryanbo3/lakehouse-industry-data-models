    rdfs:comment 'Explanation for the chosen disposition.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalLotCode rdf:type rdf:Property ;
