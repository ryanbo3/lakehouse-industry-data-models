ind:specLimitHigh rdf:type rdf:Property ;
    rdfs:label 'Spec Limit High' ;
    rdfs:comment 'Upper bound of the acceptable specification window for the measurement.' ;
    rdfs:domain ind:MetrologyRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specLimitLow rdf:type rdf:Property ;
    rdfs:label 'Spec Limit Low' ;
    rdfs:comment 'Lower bound of the acceptable specification window for the measurement.' ;
    rdfs:domain ind:MetrologyRun ;
