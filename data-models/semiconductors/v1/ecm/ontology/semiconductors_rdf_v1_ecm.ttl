ind:fabToolId rdf:type rdf:Property ;
    rdfs:label 'Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Design registration process records the fab tool that will be qualified for the project; needed for the \'Design Qualification Tool Allocation\' workflow.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:icCatalogId rdf:type rdf:Property ;
    rdfs:label 'Ic Catalog Id' ;
    rdfs:comment 'Foreign key linking to product.ic_catalog. Business justification: Design registration validation uses the catalog to verify process node, package, and qualification; part_number is redundant and removed.' ;
    rdfs:domain ind:Semiconductors ;
