    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Calculated total monetary value of the consignment (quantity × price per unit).' ;
    rdfs:domain ind:ConsignmentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWafersPerMonth rdf:type rdf:Property ;
    rdfs:label 'Capacity Wafers Per Month' ;
    rdfs:comment 'Maximum number of wafers the fab can process in a month.' ;
