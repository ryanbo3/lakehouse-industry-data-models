ind:reliabilityTestRunId rdf:type rdf:Property ;
    rdfs:label 'Reliability Test Run Id' ;
    rdfs:comment 'Foreign key linking to test.reliability_test_run. Business justification: REQUIRED: Reliability test plan must be associated with each execution run to satisfy JEDEC reliability compliance and generate post-run reports.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReliabilityTestRun .

ind:analysisMethod rdf:type rdf:Property ;
