    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateProgramDescription rdf:type rdf:Property ;
    rdfs:label 'Rebate Program Description' ;
    rdfs:comment 'Free-text description of the program purpose and scope.' ;
    rdfs:domain ind:RebateProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateProgramStatus rdf:type rdf:Property ;
    rdfs:label 'Rebate Program Status' ;
    rdfs:comment 'Current lifecycle status of the rebate program.' ;
    rdfs:domain ind:RebateProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier1RatePercent rdf:type rdf:Property ;
    rdfs:label 'Tier1 Rate Percent' ;
    rdfs:comment 'Rebate percentage applied to revenue/units that fall within tier 1.' ;
