    rdfs:comment 'Indicates whether this line has been invoiced in its final form.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isServiceLine rdf:type rdf:Property ;
    rdfs:label 'Is Service Line' ;
    rdfs:comment 'True if the line represents a service rather than a material.' ;
