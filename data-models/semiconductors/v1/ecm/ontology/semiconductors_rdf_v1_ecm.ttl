    rdfs:comment 'Portion of the employee\'s total workload allocated to this account (percentage).' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addressId rdf:type rdf:Property ;
