    rdfs:comment 'Overall classification of the supplier based on the scorecard outcome.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferMapId rdf:type rdf:Property ;
    rdfs:label 'Wafer Map Id' ;
    rdfs:comment 'Primary key for wafer_map' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferProbeRunId rdf:type rdf:Property ;
    rdfs:label 'Wafer Probe Run Id' ;
    rdfs:comment 'Foreign key linking to test.wafer_probe_run. Business justification: REQUIRED: Test execution (wafer_probe_run) creates the wafer map; traceability report links map to its probe run for root-cause analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferProbeRun .

ind:binCountTotal rdf:type rdf:Property ;
    rdfs:label 'Bin Count Total' ;
    rdfs:comment 'Total number of distinct bins used in the map.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectDensityPerSqmm rdf:type rdf:Property ;
    rdfs:label 'Defect Density Per Sqmm' ;
    rdfs:comment 'Average defect density across the wafer measured in defects per square millimeter.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectZone rdf:type rdf:Property ;
    rdfs:label 'Defect Zone' ;
    rdfs:comment 'Region of the wafer where defects are concentrated.' ;
    rdfs:domain ind:WaferMap ;
