    rdfs:comment 'Qualitative assessment of how the change affects product performance, yield, and qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productChangeNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Product Change Notification Status' ;
    rdfs:comment 'Current lifecycle status of the product change notification.' ;
    rdfs:domain ind:ProductChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productPcnSupplierFk rdf:type rdf:Property ;
    rdfs:label 'Product Pcn Supplier Fk' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — PCNs are issued BY a specific supplier announcing changes to their materials/processes.' ;
    rdfs:domain ind:ProductChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requalificationDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Requalification Decision Date' ;
    rdfs:comment 'Date on which the re-qualification decision was made.' ;
    rdfs:domain ind:ProductChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredCustomerNotification rdf:type rdf:Property ;
    rdfs:label 'Required Customer Notification' ;
    rdfs:comment 'Indicates whether the supplier requires the customer to be notified of the change.' ;
    rdfs:domain ind:ProductChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryPurchaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Employee Id' ;
    rdfs:comment 'Identifier of the internal employee who created the PO request.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:purchaseSupplierId rdf:type rdf:Property ;
    rdfs:label 'Purchase Supplier Id' ;
    rdfs:comment 'Unique identifier of the supplier (vendor) to which the purchase order is issued.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:complianceFlags rdf:type rdf:Property ;
    rdfs:label 'Compliance Flags' ;
    rdfs:comment 'Semicolon-separated list of compliance indicators (e.g., RoHS, REACH).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySchedule rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'Free-text description of delivery windows or milestones.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Planned date for goods/services to be delivered.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Monetary cost of freight/shipping.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Responsibility for freight costs.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Status' ;
    rdfs:comment 'Current lifecycle state of the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderType rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Type' ;
    rdfs:comment 'Classification of the PO based on its procurement strategy.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseSupplierFk rdf:type rdf:Property ;
    rdfs:label 'Purchase Supplier Fk' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — Every PO is issued TO a supplier. This is a day-1 mandatory FK.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchasingOrg rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org' ;
    rdfs:comment 'SAP purchasing organization that owns the PO.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Total Gross Amount' ;
    rdfs:comment 'Total amount before taxes, discounts, and freight.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Net Amount' ;
    rdfs:comment 'Final payable amount after taxes, discounts, and freight.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Aggregate tax amount applied to the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Primary key for risk_assessment' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRiskAlternateSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Alternate Supplier Id' ;
    rdfs:comment 'Identifier of an approved alternate supplier for the material.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:riskOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Risk Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Risk assessments assign an employee owner for accountability; the owner is recorded in the risk owner employee field.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:riskSupplierId rdf:type rdf:Property ;
    rdfs:label 'Risk Supplier Id' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — Risk assessments evaluate specific suppliers or supplier-material combinations.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:assessmentCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Code' ;
    rdfs:comment 'Business identifier code for the assessment, used for tracking and reporting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the risk assessment was initially created.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentName rdf:type rdf:Property ;
    rdfs:label 'Assessment Name' ;
    rdfs:comment 'Descriptive name of the risk assessment, typically includes supplier or material reference.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the risk assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bufferStockTargetQty rdf:type rdf:Property ;
    rdfs:label 'Buffer Stock Target Qty' ;
    rdfs:comment 'Target quantity of safety stock to buffer against the risk.' ;
