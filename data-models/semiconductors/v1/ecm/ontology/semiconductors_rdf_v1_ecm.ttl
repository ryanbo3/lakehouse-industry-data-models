ind:obligationRegisterId rdf:type rdf:Property ;
    rdfs:label 'Obligation Register Id' ;
    rdfs:comment 'FK to compliance.obligation_register.obligation_register_id — CHIPS Act obligations are a specific subset of the compliance obligation register. Linking ensures CHIPS obligations appear in the unified obligation management framework.' ;
    rdfs:domain ind:Semiconductors ;
