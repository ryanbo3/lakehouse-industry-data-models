    rdfs:range ind:TestProgram .

ind:reliabilityTestProgramId rdf:type rdf:Property ;
    rdfs:label 'Reliability Test Program Id' ;
    rdfs:comment 'Foreign key linking to test.test_program. Business justification: Reliability test runs are associated with the test program they validate; add FK to link them.' ;
    rdfs:domain ind:ReliabilityTestRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestProgram .

ind:accelerationFactor rdf:type rdf:Property ;
    rdfs:label 'Acceleration Factor' ;
    rdfs:comment 'Factor used to extrapolate stress results to normal operating conditions.' ;
    rdfs:domain ind:ReliabilityTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biasCondition rdf:type rdf:Property ;
    rdfs:label 'Bias Condition' ;
    rdfs:comment 'Electrical bias applied to the device (e.g., Vdd=1.2V, ground), described in free text.' ;
