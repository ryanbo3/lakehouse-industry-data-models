    rdfs:comment 'Version identifier for the detailed qualification plan document.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalProcessControlIncluded rdf:type rdf:Property ;
    rdfs:label 'Statistical Process Control Included' ;
    rdfs:comment 'True if SPC data collection is part of the qualification activities.' ;
    rdfs:domain ind:QualityQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualitySpecId rdf:type rdf:Property ;
    rdfs:label 'Quality Spec Id' ;
    rdfs:comment 'Unique identifier for the quality specification record.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementFabToolId rdf:type rdf:Property ;
