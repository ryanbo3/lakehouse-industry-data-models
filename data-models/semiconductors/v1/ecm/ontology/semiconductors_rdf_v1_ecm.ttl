ind:postStressYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Post Stress Yield Percent' ;
    rdfs:comment 'Yield percentage measured after stress exposure.' ;
    rdfs:domain ind:ReliabilityTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preStressYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Pre Stress Yield Percent' ;
    rdfs:comment 'Yield percentage measured before applying stress.' ;
    rdfs:domain ind:ReliabilityTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screenEffectivenessPercent rdf:type rdf:Property ;
