    rdfs:range xsd:decimal .

ind:restrictedPartyScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Restricted Party Screening Status' ;
    rdfs:comment 'Current lifecycle status of the screening process.' ;
    rdfs:domain ind:RestrictedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDeadline rdf:type rdf:Property ;
    rdfs:label 'Review Deadline' ;
    rdfs:comment 'Date by which any required follow-up review must be completed.' ;
    rdfs:domain ind:RestrictedPartyScreening ;
