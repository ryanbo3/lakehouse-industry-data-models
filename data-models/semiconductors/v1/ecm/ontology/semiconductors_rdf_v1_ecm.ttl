    rdfs:comment 'Date of the most recent surveillance audit required by the certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the certification record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version or revision of the certification standard (e.g., ISO 9001:2015).' ;
