    rdfs:comment 'Current lifecycle status of the scorecard record.' ;
    rdfs:domain ind:SupplierQualityScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardVersion rdf:type rdf:Property ;
    rdfs:label 'Scorecard Version' ;
    rdfs:comment 'Version number of the scorecard for change-tracking purposes.' ;
    rdfs:domain ind:SupplierQualityScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierDevelopmentProgram rdf:type rdf:Property ;
    rdfs:label 'Supplier Development Program' ;
    rdfs:comment 'Name or code of the development program linked to the supplier.' ;
    rdfs:domain ind:SupplierQualityScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier based on business relationship (e.g., tier level).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierClassification rdf:type rdf:Property ;
