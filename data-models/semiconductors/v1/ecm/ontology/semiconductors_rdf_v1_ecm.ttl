    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostPerWaferUsd rdf:type rdf:Property ;
    rdfs:label 'Total Cost Per Wafer Usd' ;
    rdfs:comment 'Fully-loaded cost of a wafer after aggregating all direct and indirect cost components.' ;
    rdfs:domain ind:WaferCostModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferCostModelStatus rdf:type rdf:Property ;
    rdfs:label 'Wafer Cost Model Status' ;
    rdfs:comment 'Current lifecycle status of the cost model.' ;
    rdfs:domain ind:WaferCostModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentWbsWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Wbs Element Id' ;
    rdfs:comment 'Identifier of the immediate parent element in the WBS hierarchy.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Real calendar date when work on the element actually completed.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Real calendar date when work on the element actually started.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingElementFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Element Flag' ;
    rdfs:comment 'Indicates whether the WBS element is billable for NRE or customer invoicing.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialYear rdf:type rdf:Property ;
    rdfs:label 'Financial Year' ;
    rdfs:comment 'Fiscal year to which the element\'s financial data belongs.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCapitalExpenditure rdf:type rdf:Property ;
    rdfs:label 'Is Capital Expenditure' ;
    rdfs:comment 'True if costs incurred under this element are treated as capital expenditures.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Template' ;
    rdfs:comment 'True if the element is defined as a reusable template for future projects.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Planned calendar date when work on the element is expected to finish.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'Current phase of the overall project to which the element belongs.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rAndDCapitalizationFlag rdf:type rdf:Property ;
    rdfs:label 'R And D Capitalization Flag' ;
    rdfs:comment 'True if the element\'s costs are eligible for R&D capitalization under accounting standards.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wbsCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Code' ;
    rdfs:comment 'Hierarchical alphanumeric code that uniquely identifies the WBS element within the project hierarchy.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementDescription rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Description' ;
    rdfs:comment 'Detailed description of the work scope represented by the WBS element.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Level' ;
    rdfs:comment 'Depth level of the element within the WBS tree (root = 1).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsElementName rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Name' ;
    rdfs:comment 'Human-readable name of the WBS element.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementStatus rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Status' ;
    rdfs:comment 'Current lifecycle status of the WBS element.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementType rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Type' ;
    rdfs:comment 'Category of the WBS element indicating its granularity within the project hierarchy.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsHierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Wbs Hierarchy Path' ;
    rdfs:comment 'Delimited string representing the full path from root to this element (e.g., 1.2.3).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsStatusReason rdf:type rdf:Property ;
    rdfs:label 'Wbs Status Reason' ;
    rdfs:comment 'Free-text explanation for the current status of the WBS element.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentStockId rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Id' ;
    rdfs:comment 'Unique identifier for the consignment stock record. Primary key.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consignmentAgreementId rdf:type rdf:Property ;
    rdfs:label 'Consignment Agreement Id' ;
    rdfs:comment 'Business identifier for the consignment agreement governing this stock arrangement between the semiconductor company and the OSAT partner or VMI hub.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsignmentAgreement .

ind:consignmentDieBankId rdf:type rdf:Property ;
    rdfs:label 'Consignment Die Bank Id' ;
    rdfs:comment 'Reference to the die bank if the consignment stock consists of Known Good Die (KGD) awaiting packaging.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DieBank .

ind:consignmentStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Consignment Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Consignment stock must reference the OSAT/partner storage location for reconciliation and ownership transfer.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:dieBankId rdf:type rdf:Property ;
    rdfs:label 'Die Bank Id' ;
    rdfs:comment 'FK to inventory.die_bank.die_bank_id — Consignment stock at OSAT partners frequently consists of die bank inventory (KGD dies sent for packaging). This is a primary use case in fabless semiconductor model.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DieBank .

ind:inventoryWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Inventory Wafer Lot Id' ;
    rdfs:comment 'Reference to the originating wafer lot for traceability of consigned die or finished goods.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryWaferLot .

ind:osatVendorId rdf:type rdf:Property ;
    rdfs:label 'Osat Vendor Id' ;
    rdfs:comment 'Reference to the OSAT partner or customer VMI hub where the consignment stock is physically located.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OsatVendor .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Consignment stock is held at specific OSAT partner locations. Required for consignment reconciliation and liability tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Quantity of consigned material currently available at the OSAT partner location for consumption.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin or rack location within the OSAT partner warehouse where the consignment stock is stored.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consigned Quantity' ;
    rdfs:comment 'Total quantity of material consigned to the OSAT partner or VMI hub under this agreement.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consignment Expiry Date' ;
    rdfs:comment 'Date when the consignment agreement expires or when the material must be consumed, returned, or settled.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Consignment Start Date' ;
    rdfs:comment 'Date when the material was first consigned to the OSAT partner or VMI hub under this agreement.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Consignment Status' ;
    rdfs:comment 'Current lifecycle status of the consignment stock record.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentType rdf:type rdf:Property ;
    rdfs:label 'Consignment Type' ;
    rdfs:comment 'Type of consignment arrangement: OSAT assembly, OSAT test, vendor-managed inventory hub, or customer consignment.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumed Quantity' ;
    rdfs:comment 'Quantity of consigned material that has been consumed or used by the OSAT partner, triggering ownership transfer.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eccnNumber rdf:type rdf:Property ;
    rdfs:label 'Eccn Number' ;
    rdfs:comment 'Export Control Classification Number assigned to the consigned material under US Export Administration Regulations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity of consigned material currently in transit to or from the OSAT partner or VMI hub.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kgdStatus rdf:type rdf:Property ;
    rdfs:label 'Kgd Status' ;
    rdfs:comment 'Indicates whether the consigned die or material has been tested and certified as Known Good Die.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date of the most recent consignment stock reconciliation between the semiconductor company and the OSAT partner.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Last Settlement Date' ;
    rdfs:comment 'Date of the most recent financial settlement for consumed consignment stock with the OSAT partner.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityAgingDays rdf:type rdf:Property ;
    rdfs:label 'Liability Aging Days' ;
    rdfs:comment 'Number of days the consignment stock has been at the OSAT partner location, used for aging analysis and liability reporting.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotTraceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Code' ;
    rdfs:comment 'Traceability code linking the consigned material to its manufacturing lot, wafer lot, and production history for quality and compliance tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msdLevel rdf:type rdf:Property ;
    rdfs:label 'Msd Level' ;
    rdfs:comment 'JEDEC moisture sensitivity level classification for the consigned material, indicating required storage and handling conditions. [ENUM-REF-CANDIDATE: 1|2|2a|3|4|5|5a|6 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReconciliationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reconciliation Due Date' ;
    rdfs:comment 'Scheduled date for the next consignment stock reconciliation based on the reconciliation frequency.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipTransferTrigger rdf:type rdf:Property ;
    rdfs:label 'Ownership Transfer Trigger' ;
    rdfs:comment 'Event that triggers ownership transfer from the semiconductor company to the OSAT partner: consumption, shipment, time-based, or withdrawal.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'Frequency at which consignment stock levels are reconciled between the semiconductor company and the OSAT partner.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of consigned material returned to the semiconductor company from the OSAT partner or VMI hub.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Document Reference' ;
    rdfs:comment 'Reference number of the most recent settlement document or invoice generated for consumed consignment stock.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days the consigned material can be stored before it must be used or returned, applicable to moisture-sensitive devices.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfLifeExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiry Date' ;
    rdfs:comment 'Date when the consigned material reaches the end of its shelf life and must be consumed, returned, or scrapped.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Stock keeping unit code for the consigned material, used for inventory tracking and identification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard unit cost of the consigned material used for inventory valuation and settlement calculations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageHumidityMaxPct rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Max Pct' ;
    rdfs:comment 'Maximum relative humidity percentage allowed for storage of the consigned material at the OSAT partner location.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum storage temperature in degrees Celsius required for the consigned material at the OSAT partner location.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Valuation Amount' ;
    rdfs:comment 'Total monetary value of the consigned stock at the OSAT partner location, calculated as available quantity times standard cost.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceArchitectureId rdf:type rdf:Property ;
    rdfs:label 'Device Architecture Id' ;
    rdfs:comment 'Foreign key linking to research.device_architecture. Business justification: Die banks are allocated per device architecture; link supports the Die Bank Allocation per Architecture operational dashboard.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceArchitecture .

ind:dieStorageLocationFk rdf:type rdf:Property ;
    rdfs:label 'Die Storage Location Fk' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Die banks are stored at specific locations (cleanroom storage, cold storage). Location tracking is critical for environmental compliance and retrieval.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:dieStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Die Storage Location Id' ;
    rdfs:comment 'Reference to the physical storage location (warehouse bin, cold storage unit, or OSAT vault) where the die bank is currently stored. Managed in SAP WM/EWM.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:probeCardId rdf:type rdf:Property ;
    rdfs:label 'Probe Card Id' ;
    rdfs:comment 'Identifier of the probe card used during wafer sort for the parent wafer lot. Enables correlation of test results to probe card condition and supports yield excursion root cause analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProbeCard .

ind:responsibleEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Die Bank Inventory must record the responsible engineer who authorizes releases and handles quality holds, supporting compliance audits.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:binClass rdf:type rdf:Property ;
    rdfs:label 'Bin Class' ;
    rdfs:comment 'FK to inventory.bin_classification.bin_classification_id — Every die bank entry is classified by bin (speed grade, power class, pass/fail). This FK drives KGD allocation and customer shipment decisions.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binClassification rdf:type rdf:Property ;
    rdfs:label 'Bin Classification' ;
    rdfs:comment 'Electrical test bin classification assigned during wafer probe/sort (e.g., Bin1=Full-speed pass, Bin2=Speed-binned, Bin3=Partial-function, Bin99=Fail). Determines product grade, pricing tier, and eligible end markets. [ENUM-REF-CANDIDATE: bin1|bin2|bin3|bin4|bin5|bin6|bin99|scrap — promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Physical carrier medium in which the singulated dies are stored (e.g., waffle pack, gel pack, tape-and-reel, JEDEC tray). Determines handling requirements, automated pick-and-place compatibility, and storage density.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieBankCode rdf:type rdf:Property ;
    rdfs:label 'Die Bank Code' ;
    rdfs:comment 'Human-readable, externally-known unique business identifier for the die bank lot, used in MES, ERP, and OSAT partner communications. Follows internal lot numbering conventions.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieBankStatus rdf:type rdf:Property ;
    rdfs:label 'Die Bank Status' ;
    rdfs:comment 'Current lifecycle status of the die bank inventory record. \'Available\' indicates dies are ready for allocation; \'Reserved\' indicates committed to an order; \'Consumed\' indicates fully used in packaging; \'Quarantined\' indicates hold pending quality investigation; \'Scrapped\' indicates disposed; \'Expired\' indicates shelf life exceeded.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieRevision rdf:type rdf:Property ;
    rdfs:label 'Die Revision' ;
    rdfs:comment 'Silicon revision or stepping identifier for the die (e.g., A0, B1, C2). Tracks design iterations post-tapeout; critical for distinguishing engineering samples from production silicon.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esdSensitivityClass rdf:type rdf:Property ;
    rdfs:label 'Esd Sensitivity Class' ;
    rdfs:comment 'JEDEC Human Body Model (HBM) or Charged Device Model (CDM) ESD sensitivity classification for the dies. Determines handling precautions, packaging requirements, and ESD-protected area (EPA) storage mandates.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Accounting method used to value this die bank inventory in the ERP system (e.g., Standard Cost, Moving Average Price, FIFO, LIFO). Determines how cost of goods sold is calculated upon consumption.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsignment rdf:type rdf:Property ;
    rdfs:label 'Is Consignment' ;
    rdfs:comment 'Indicates whether this die bank is held as consignment stock at an OSAT partner or customer site (True) versus owned and stored at an internal facility (False). Affects inventory ownership, liability, and financial reporting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEngineeringSample rdf:type rdf:Property ;
    rdfs:label 'Is Engineering Sample' ;
    rdfs:comment 'Indicates whether the dies in this bank are engineering samples (True) or production-qualified silicon (False). Engineering samples may have restricted use, limited warranty, and different pricing terms.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotOrigin rdf:type rdf:Property ;
    rdfs:label 'Lot Origin' ;
    rdfs:comment 'FK to inventory.wafer_lot.wafer_lot_id — Die banks trace back to their source wafer lot for genealogy and quality traceability. Critical for IATF 16949.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Moisture Sensitivity Level' ;
    rdfs:comment 'JEDEC/IPC Moisture Sensitivity Level classification for the dies, indicating how sensitive the package or die is to ambient moisture and the required floor life before reflow. Governs dry-pack and bake-out requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldReason rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Reason' ;
    rdfs:comment 'Free-text or coded reason for placing this die bank on quality hold or quarantine status. Populated when die_bank_status is \'quarantined\'. Examples: parametric excursion, contamination event, ESD damage suspected.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Current count of dies available for allocation or shipment in this die bank record. Decremented upon reservation or consumption. Expressed in units of individual dies.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityInitial rdf:type rdf:Property ;
    rdfs:label 'Quantity Initial' ;
    rdfs:comment 'Original count of dies placed into this die bank at the time of creation, before any consumption, scrap, or reservation. Used as the baseline for yield and consumption tracking.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Count of dies in this die bank that are currently reserved against open orders or packaging work orders but not yet physically consumed. Supports ATP (Available-to-Promise) calculations.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityScrapped rdf:type rdf:Property ;
    rdfs:label 'Quantity Scrapped' ;
    rdfs:comment 'Cumulative count of dies from this die bank that have been scrapped due to handling damage, quality failures, or shelf life expiry. Used for loss tracking and yield analysis.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this die bank. Violations may cause electrostatic or material degradation. Enforced by warehouse management system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tapeoutVersion rdf:type rdf:Property ;
    rdfs:label 'Tapeout Version' ;
    rdfs:comment 'Identifier of the tapeout submission (GDSII release version) from which the wafers in this die bank were fabricated. Enables traceability back to the design release in EDA and PLM systems.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testProgramVersion rdf:type rdf:Property ;
    rdfs:label 'Test Program Version' ;
    rdfs:comment 'Version identifier of the ATE (Automatic Test Equipment) test program used during wafer probe/sort to classify and bin the dies in this die bank. Critical for test traceability and re-test qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferLotOriginFk rdf:type rdf:Property ;
    rdfs:label 'Wafer Lot Origin Fk' ;
    rdfs:comment 'FK to inventory.wafer_lot.wafer_lot_id — Die banks originate from wafer lots after singulation. This traceability link is required for IATF 16949 compliance and customer complaint root cause analysis.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferProbeYieldPct rdf:type rdf:Property ;
    rdfs:label 'Wafer Probe Yield Pct' ;
    rdfs:comment 'Electrical test yield percentage from wafer probe/sort for the parent wafer lot, representing the fraction of dies that passed all probe tests. Expressed as a decimal percentage (e.g., 92.5000). Used for cost modeling and quality benchmarking.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finishedGoodId rdf:type rdf:Property ;
    rdfs:label 'Finished Good Id' ;
    rdfs:comment 'Unique surrogate identifier for the finished good master record in the inventory system. Primary key for the finished_good data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinishedGood .

ind:releaseEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Release Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Finished-Good Release process mandates an engineer to approve product release, linking the lot to the responsible employee for regulatory traceability.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aecQQualified rdf:type rdf:Property ;
    rdfs:label 'Aec Q Qualified' ;
    rdfs:comment 'Indicates whether the finished good has been qualified to AEC-Q100 (IC), AEC-Q101 (discrete), or AEC-Q200 (passive) automotive reliability standards. Required for automotive supply chain design-in.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binCode rdf:type rdf:Property ;
    rdfs:label 'Bin Code' ;
    rdfs:comment 'Test bin classification code assigned during wafer sort or final test indicating the performance and quality tier of the die/device. Bin codes map to specific product SKUs and determine commercial grade.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateCode rdf:type rdf:Property ;
    rdfs:label 'Date Code' ;
    rdfs:comment 'Manufacturing date code in YYWW format (year + work week) indicating when the device was assembled and packaged. Used for shelf life tracking, lot traceability, and field failure analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceMarking rdf:type rdf:Property ;
    rdfs:label 'Device Marking' ;
    rdfs:comment 'Alphanumeric marking laser-inscribed or printed on the physical package surface. Includes part number, speed grade, temperature grade, and manufacturer code. Used for traceability and counterfeit detection.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Classification of the semiconductor device type. Indicates whether the finished good is an Integrated Circuit (IC), System on Chip (SoC), Application-Specific Integrated Circuit (ASIC), Field-Programmable Gate Array (FPGA), discrete device, or other category. [ENUM-REF-CANDIDATE: IC|SoC|ASIC|FPGA|Discrete|MCU|DSP|PMIC|Memory|RF|Sensor|Analog — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dppmTarget rdf:type rdf:Property ;
    rdfs:label 'Dppm Target' ;
    rdfs:comment 'Quality target expressed as Defective Parts Per Million (DPPM) for outgoing quality of this finished good. Used in customer quality agreements and SPC monitoring. Automotive-grade typically requires <10 DPPM.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eolDate rdf:type rdf:Property ;
    rdfs:label 'Eol Date' ;
    rdfs:comment 'Announced End of Life (EOL) date after which the finished good will no longer be manufactured or sold. Triggers Last Time Buy (LTB) notifications to customers per JEDEC JESD48 standard.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:htsCode rdf:type rdf:Property ;
    rdfs:label 'Hts Code' ;
    rdfs:comment 'Harmonized Tariff Schedule (HTS) classification code used for customs declaration, import/export duty determination, and trade statistics reporting. Follows the 10-digit US HTS format.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current inventory disposition status of the finished good lot. \'available\' indicates unrestricted stock; \'quarantine\' indicates pending quality review; \'reserved\' indicates allocated to an order; \'consignment\' indicates stock held at OSAT or customer site; \'hold\' indicates engineering or compliance hold.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageBodySizeMm rdf:type rdf:Property ;
    rdfs:label 'Package Body Size Mm' ;
    rdfs:comment 'Physical body dimensions of the semiconductor package expressed as length x width in millimeters (e.g., \'10x10\', \'5.5x5.5\'). Used for PCB design, handling equipment setup, and storage tray selection.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnReference rdf:type rdf:Property ;
    rdfs:label 'Pcn Reference' ;
    rdfs:comment 'Reference number of the most recent Product Change Notification (PCN) affecting this finished good. PCNs document changes to materials, processes, or package that may impact customer qualification status.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinCount rdf:type rdf:Property ;
    rdfs:label 'Pin Count' ;
    rdfs:comment 'Total number of electrical pins, balls, or leads on the finished good package. Critical for PCB design compatibility, socket selection, and ATE (Automatic Test Equipment) configuration.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical inventory quantity of this finished good in units (individual packaged devices). Reflects unrestricted stock available for order fulfillment as tracked in SAP MM inventory management.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedGrade rdf:type rdf:Property ;
    rdfs:label 'Speed Grade' ;
    rdfs:comment 'Performance speed grade or frequency bin classification of the finished good (e.g., \'-1\', \'-2\', \'3.0GHz\', \'800MHz\'). Determined during wafer sort and final test binning. Differentiates product variants within the same die.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureGrade rdf:type rdf:Property ;
    rdfs:label 'Temperature Grade' ;
    rdfs:comment 'Operating temperature range classification of the finished good. \'commercial\' (0°C to 70°C), \'industrial\' (-40°C to 85°C), \'automotive\' (-40°C to 125°C/150°C per AEC-Q100), \'military\' (-55°C to 125°C), \'extended\' for specialized ranges.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementId rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Id' ;
    rdfs:comment 'Unique identifier for the goods movement transaction. Primary key for the goods movement record.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodsStockBalanceId rdf:type rdf:Property ;
    rdfs:label 'Goods Stock Balance Id' ;
    rdfs:comment 'FK to inventory.stock_balance.stock_balance_id — Every goods movement posting updates the stock balance. This is the fundamental inventory equation: stock_balance = sum(goods_movements). Critical for reconciliation and audit.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockBalance .

ind:goodsStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Goods Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Every goods movement must reference source location for audit trail and inventory reconciliation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Foreign key linking to order.order. Business justification: REQUIRED: Financial and logistics reporting ties inventory movements to the originating sales order for cost of goods sold and compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:primaryGoodsMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Material Master Id' ;
    rdfs:comment 'Identifier of the material being moved. References the material master record for silicon wafers, chemicals, gases, photomasks, packaged chips, or die banks.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:sourceStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Every goods movement has a source location (for issues, transfers) or destination location (for receipts). Location reference is mandatory for movement posting and audit trail.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:stockBalanceId rdf:type rdf:Property ;
    rdfs:label 'Stock Balance Id' ;
    rdfs:comment 'FK to inventory.stock_balance.stock_balance_id — Goods movements update stock balances — the transactional movement must reference the balance it affects for real-time inventory accuracy.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockBalance .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Delivery note or packing slip number from the supplier or shipping carrier. Used for goods receipt matching and three-way match (PO, goods receipt, invoice) reconciliation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPlantCode rdf:type rdf:Property ;
    rdfs:label 'Destination Plant Code' ;
    rdfs:comment 'Plant or FAB site code where the material was moved to. Used for inter-plant transfers and multi-site inventory tracking. Critical for global supply chain visibility.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location' ;
    rdfs:comment 'Storage location code where the material was moved to. Represents warehouse, stockroom, or FAB storage area. Empty for goods issues to external customers or scrap.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLineItem rdf:type rdf:Property ;
    rdfs:label 'Document Line Item' ;
    rdfs:comment 'Line item number within the material document. Supports multi-line goods movement documents where multiple materials or lots are moved in a single transaction.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementDate rdf:type rdf:Property ;
    rdfs:label 'Movement Date' ;
    rdfs:comment 'Date when the physical goods movement occurred. Business event date for inventory transaction, distinct from posting date. Critical for SOX Section 404 audit trail and inventory valuation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the inventory movement transaction: goods receipt from supplier, goods issue to production, inter-location transfer, scrap disposal, return from production, or posting reversal. Aligns with SAP MM movement type codes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'Production order number for goods issues to manufacturing or goods receipts from production. Links inventory movements to wafer fabrication, die packaging, or assembly operations.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentLineItem rdf:type rdf:Property ;
    rdfs:label 'Reference Document Line Item' ;
    rdfs:comment 'Line item number within the reference document. Provides precise linkage to the specific line of the purchase order, production order, or delivery note.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that triggered this goods movement: purchase order (PO) for receipts, production order for manufacturing issues/receipts, delivery note for shipments, transfer order for inter-location moves, sales order for customer shipments, or reservation for planned consumption.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Material reservation number for planned goods issues. Links to production order or maintenance order reservations for material requirements planning (MRP) and allocation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'Material document number of the original transaction being reversed. Populated only when reversal_indicator is true. Provides linkage for audit trail and reconciliation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Date' ;
    rdfs:comment 'Expiration date for time-sensitive materials such as photoresists, chemicals, or adhesives. Used for shelf-life management and FIFO (First In First Out) inventory control.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourcePlantCode rdf:type rdf:Property ;
    rdfs:label 'Source Plant Code' ;
    rdfs:comment 'Plant or FAB site code where the material originated. Used for inter-plant transfers and multi-site inventory tracking. Aligns with SEMI E120 traceability requirements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location' ;
    rdfs:comment 'Storage location code where the material was moved from. Represents warehouse, stockroom, or FAB storage area. Empty for goods receipts from external suppliers.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Indicator for special stock types: consignment stock at OSAT partners, project-specific stock, sales order allocated stock, returnable packaging, or pipeline inventory. Affects ownership and valuation rules.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Stock status classification: unrestricted (available for use), quality inspection (pending QA release), blocked (quality hold or obsolete), or restricted use (conditional release). Determines material availability for production and sales.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Total monetary value of the goods movement in company currency. Calculated as quantity multiplied by material standard cost or moving average price. Used for inventory valuation and financial reporting.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryLotGenealogyId rdf:type rdf:Property ;
    rdfs:label 'Inventory Lot Genealogy Id' ;
    rdfs:comment 'Unique identifier for the lot genealogy association record. Primary key for traceability relationships between wafer lots, die banks, and finished goods across manufacturing transformations.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automotivePpapRequired rdf:type rdf:Property ;
    rdfs:label 'Automotive Ppap Required' ;
    rdfs:comment 'Indicates whether this transformation requires PPAP documentation for automotive customers. True for new products, process changes, or supplier changes affecting automotive-qualified parts.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:childEntityReference rdf:type rdf:Property ;
    rdfs:label 'Child Entity Reference' ;
    rdfs:comment 'Unique identifier of the child entity. References the specific wafer lot, die bank, or finished good that resulted from the transformation process.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childEntityType rdf:type rdf:Property ;
    rdfs:label 'Child Entity Type' ;
    rdfs:comment 'Type of the child entity in the genealogy relationship. Identifies whether the output material is a wafer lot, die bank, or finished good after transformation.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genealogyStatus rdf:type rdf:Property ;
    rdfs:label 'Genealogy Status' ;
    rdfs:comment 'Current status of the genealogy record. Active indicates ongoing transformation, completed indicates finished operation, voided indicates cancelled or reversed transaction, under_investigation indicates quality review in progress.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentEntityReference rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Reference' ;
    rdfs:comment 'Unique identifier of the parent entity. References the specific wafer lot, die bank, or finished good that served as input to the transformation process.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentEntityType rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Type' ;
    rdfs:comment 'Type of the parent entity in the genealogy relationship. Identifies whether the source material is a wafer lot, die bank, finished good, or raw material before transformation.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pcn Reference Number' ;
    rdfs:comment 'Reference number of the Product Change Notification associated with this transformation. Links genealogy to formal customer communication for process or material changes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepCode rdf:type rdf:Property ;
    rdfs:label 'Process Step Code' ;
    rdfs:comment 'Manufacturing process step code where the transformation occurred. References the specific operation in the process flow (e.g., wafer probe, die saw, wire bond, final test).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepName rdf:type rdf:Property ;
    rdfs:label 'Process Step Name' ;
    rdfs:comment 'Human-readable name of the manufacturing process step. Provides business context for the transformation operation.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkCycleCount rdf:type rdf:Property ;
    rdfs:label 'Rework Cycle Count' ;
    rdfs:comment 'Number of rework cycles applied to the material. Tracks cumulative rework history for quality risk assessment and customer notification requirements.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transformationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transformation Timestamp' ;
    rdfs:comment 'Date and time when the transformation operation occurred. Critical for forward and backward traceability in automotive PPAP documentation and field return investigations.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Manufacturing work order number authorizing the transformation operation. Links genealogy to production planning and scheduling systems.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldAtTransformationPct rdf:type rdf:Property ;
    rdfs:label 'Yield At Transformation Pct' ;
    rdfs:comment 'Yield percentage achieved during the transformation operation. Calculated as (quantity_out / quantity_in) * 100. Critical for process capability analysis and SPC monitoring.' ;
    rdfs:domain ind:InventoryLotGenealogy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryLotHoldId rdf:type rdf:Property ;
    rdfs:label 'Inventory Lot Hold Id' ;
    rdfs:comment 'Unique identifier for the inventory lot hold record. Primary key for the inventory lot hold transaction.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fmeaRecordId rdf:type rdf:Property ;
    rdfs:label 'Fmea Record Id' ;
    rdfs:comment 'Reference to the FMEA document or record associated with this hold. Links the hold to the failure mode analysis that identified the risk or defect mode.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FmeaRecord .

ind:primaryInventoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Employee Id' ;
    rdfs:comment 'Identifier of the person or system that initiated the hold. References employee ID or automated system identifier responsible for placing the hold.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qualityNotificationId rdf:type rdf:Property ;
    rdfs:label 'Quality Notification Id' ;
    rdfs:comment 'Reference to the associated quality notification or non-conformance report. Links the hold to the formal quality management record (e.g., SAP QM notification number).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityNotification .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Description of the immediate containment action taken to prevent further impact. Details the steps taken to isolate the affected lot and prevent similar issues in other lots.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieQuantity rdf:type rdf:Property ;
    rdfs:label 'Die Quantity' ;
    rdfs:comment 'Total number of die (individual chips) in the lot subject to this hold. Applicable for finished goods or die bank inventory holds.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dppmValue rdf:type rdf:Property ;
    rdfs:label 'Dppm Value' ;
    rdfs:comment 'Calculated defect rate in parts per million for the lot under hold. Quality metric indicating the severity of the defect condition.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdComments rdf:type rdf:Property ;
    rdfs:label 'Hold Comments' ;
    rdfs:comment 'Additional free-text comments or notes related to the hold. Provides supplementary information, investigation findings, or disposition rationale.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdDate rdf:type rdf:Property ;
    rdfs:label 'Hold Date' ;
    rdfs:comment 'Date and time when the hold was placed on the lot. Represents the principal business event timestamp when the lot became restricted from further processing or shipment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdDisposition rdf:type rdf:Property ;
    rdfs:label 'Hold Disposition' ;
    rdfs:comment 'Final disposition decision for the lot after hold investigation. Indicates the action taken: rework (reprocess the lot), scrap (discard the lot), release (approve for continued flow), return (send back to supplier or customer), quarantine (extended hold pending further review), or retest (re-inspect or re-qualify).' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Hold Expiration Date' ;
    rdfs:comment 'Date and time when the hold automatically expires if not explicitly released. Null if no expiration is set. Used for time-limited holds that auto-release after a defined period.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdInitiatorName rdf:type rdf:Property ;
    rdfs:label 'Hold Initiator Name' ;
    rdfs:comment 'Full name of the person or system that initiated the hold. Provides human-readable identification of the hold originator.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Business identifier for the hold event. Externally-known unique code assigned to this hold transaction for tracking and reference purposes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdPriority rdf:type rdf:Property ;
    rdfs:label 'Hold Priority' ;
    rdfs:comment 'Priority level assigned to the hold. Indicates the urgency and business impact of the hold (critical for safety or regulatory issues, high for customer impact, medium for process improvement, low for administrative holds).' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Hold Release Authority Name' ;
    rdfs:comment 'Full name of the person or system that released the hold. Provides human-readable identification of the release authority.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'Date and time when the hold was released or lifted. Null if the hold is still active. Marks the point when the lot was cleared for continued processing or shipment.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isRegulatoryHold rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Hold' ;
    rdfs:comment 'Flag indicating whether the hold is mandated by regulatory compliance requirements (e.g., export control, environmental, safety). True if the hold is regulatory-driven, false otherwise.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservationId rdf:type rdf:Property ;
    rdfs:label 'Reservation Id' ;
    rdfs:comment 'System-generated unique identifier for the inventory reservation record.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumingGoodsMovementId rdf:type rdf:Property ;
    rdfs:label 'Consuming Goods Movement Id' ;
    rdfs:comment 'Reference to the goods movement that will consume the reservation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsMovement .

ind:demandSourceReference rdf:type rdf:Property ;
    rdfs:label 'Demand Source Reference' ;
    rdfs:comment 'Identifier of the originating demand record (e.g., sales order, production order).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Date and time when the reservation automatically expires if not consumed.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isKgd rdf:type rdf:Property ;
    rdfs:label 'Is Kgd' ;
    rdfs:comment 'Indicates whether the reservation is for KGD-qualified inventory.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Free-text explanation for why the reservation was created.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the reservation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Timestamp' ;
    rdfs:comment 'Date and time when the reservation was created in the source system.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationType rdf:type rdf:Property ;
    rdfs:label 'Reservation Type' ;
    rdfs:comment 'Category of demand source that triggered the reservation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Amount of inventory units earmarked by the reservation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryInventoryFabricationWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Fabrication Wafer Lot Id' ;
    rdfs:comment 'Externally-known, human-readable lot identifier assigned by the Manufacturing Execution System (MES) at lot creation. Used across FAB operations, quality systems, and customer traceability. Corresponds to the Camstar MES Lot ID / SAP PP Production Order number. This is the BUSINESS_IDENTIFIER category field for this TRANSACTION_HEADER entity.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:processEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Process Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Lot Management requires assigning a process engineer to each wafer lot for traceability, accountability, and release approval.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:waferStartAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Authorization Id' ;
    rdfs:comment 'Reference to the wafer start authorization record that approved and initiated this lot. Provides traceability from WIP inventory back to the demand signal and capacity authorization event.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferStartAuthorization .

ind:currentOperationStep rdf:type rdf:Property ;
    rdfs:label 'Current Operation Step' ;
    rdfs:comment 'The current process operation step name or code at which the wafer lot is positioned in the process flow (e.g., \'FEOL_Gate_Oxide\', \'MOL_Contact_Etch\', \'BEOL_Metal1_CVD\'). Sourced from the MES process flow definition. Critical for WIP traceability and cycle time analysis.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diePerWafer rdf:type rdf:Property ;
    rdfs:label 'Die Per Wafer' ;
    rdfs:comment 'Theoretical number of die that can be patterned on a single wafer for this product at the given process node and die size. Used as the denominator for yield calculations and finished goods quantity forecasting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodWaferCount rdf:type rdf:Property ;
    rdfs:label 'Good Wafer Count' ;
    rdfs:comment 'Number of wafers in the lot that have passed all in-line inspection and metrology checks to date. Represents the current count of wafers expected to yield good die. Updated after each inspection or disposition event.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Amount' ;
    rdfs:comment 'Current standard cost valuation of the wafer lot in the inventory ledger, expressed in the functional currency. Calculated based on the number of wafers and the standard cost per wafer at the current process step. Used for WIP inventory valuation in SAP FI/CO and financial reporting under SOX.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotStartDate rdf:type rdf:Property ;
    rdfs:label 'Lot Start Date' ;
    rdfs:comment 'Calendar date on which the wafer lot was officially started (wafer start authorization executed) in the FAB. Used for cycle time measurement, WIP aging analysis, and on-time delivery tracking. This is the BUSINESS_EVENT_TIMESTAMP (date precision) category field.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle state of the wafer lot within the FAB WIP flow. \'active\' indicates the lot is progressing through process steps; \'on_hold\' indicates a hold flag is set pending disposition; \'completed\' indicates all process steps are finished; \'scrapped\' indicates the lot has been disposed; \'cancelled\' indicates the lot was terminated before completion. This is the LIFECYCLE_STATUS category field.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesLotReference rdf:type rdf:Property ;
    rdfs:label 'Mes Lot Reference' ;
    rdfs:comment 'Native lot reference number as recorded in the Applied Materials SmartFactory or Camstar MES system. Enables direct cross-reference to the operational system of record for lot tracking, dispatch, and WIP management.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record from which this wafer lot record was sourced (e.g., CAMSTAR for Camstar MES, SMARTFACTORY for Applied Materials SmartFactory, SAP_PP for SAP Production Planning). Supports data lineage and multi-system reconciliation in the Databricks Silver layer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the inventory valuation amount (e.g., USD, EUR, JPY, TWD). Required for multi-currency financial reporting and SOX compliance.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferCountCurrent rdf:type rdf:Property ;
    rdfs:label 'Wafer Count Current' ;
    rdfs:comment 'Current number of wafers remaining in the lot after accounting for any scrapped or split wafers during processing. Reflects real-time WIP inventory quantity for this lot.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferCountStart rdf:type rdf:Property ;
    rdfs:label 'Wafer Count Start' ;
    rdfs:comment 'Number of wafers in the lot at the time of lot creation (wafer start). Typically 25 wafers per FOUP/cassette for standard lots. Used as the baseline denominator for yield and scrap rate calculations. This is the QUANTITATIVE_RESULT / principal measured quantity for this WIP transaction.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryKgdCertificationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Kgd Certification Id' ;
    rdfs:comment 'Unique identifier for the KGD certification record. Primary key for the certification transaction.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationRecordId rdf:type rdf:Property ;
    rdfs:label 'Allocation Record Id' ;
    rdfs:comment 'Reference to the customer allocation record if this KGD certification is tied to a specific customer order or design-win. Enables customer-specific quality tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRecord .

ind:ateEquipmentCode rdf:type rdf:Property ;
    rdfs:label 'Ate Equipment Code' ;
    rdfs:comment 'Identifier of the Automatic Test Equipment (ATE) used for electrical testing. Enables equipment-specific yield analysis and calibration tracking.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bin1Count rdf:type rdf:Property ;
    rdfs:label 'Bin 1 Count' ;
    rdfs:comment 'Number of die classified as Bin 1 (highest quality, full specification pass). Prime die suitable for all applications.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bin2Count rdf:type rdf:Property ;
    rdfs:label 'Bin 2 Count' ;
    rdfs:comment 'Number of die classified as Bin 2 (good quality with minor parametric variations). Suitable for most applications.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bin3Count rdf:type rdf:Property ;
    rdfs:label 'Bin 3 Count' ;
    rdfs:comment 'Number of die classified as Bin 3 (acceptable quality with reduced specifications). May be suitable for specific applications or downgraded products.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:burnInDurationHours rdf:type rdf:Property ;
    rdfs:label 'Burn In Duration Hours' ;
    rdfs:comment 'Duration in hours for which the die were subjected to burn-in stress testing. Typical values range from 48 to 168 hours.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:burnInTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Burn In Temperature C' ;
    rdfs:comment 'Temperature in degrees Celsius at which burn-in testing was performed. Typical values are 125°C or 150°C.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:burnInTestResult rdf:type rdf:Property ;
    rdfs:label 'Burn In Test Result' ;
    rdfs:comment 'Result of high-temperature operating life (HTOL) burn-in stress testing. Identifies early-life failures and ensures reliability.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date on which the KGD certification was issued. Represents the business event timestamp when the die bank was officially certified as Known Good Die.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dppmRate rdf:type rdf:Property ;
    rdfs:label 'Dppm Rate' ;
    rdfs:comment 'Calculated defect rate in parts per million for this KGD certification batch. Key quality metric for customer quality agreements and Six Sigma tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electricalTestPassRatePct rdf:type rdf:Property ;
    rdfs:label 'Electrical Test Pass Rate Pct' ;
    rdfs:comment 'Percentage of die that passed comprehensive electrical parametric testing during KGD certification. Includes DC, AC, and functional tests.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failBinCount rdf:type rdf:Property ;
    rdfs:label 'Fail Bin Count' ;
    rdfs:comment 'Total number of die classified into fail bins (did not meet minimum electrical or functional specifications). Not certified as KGD.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kgdGrade rdf:type rdf:Property ;
    rdfs:label 'Kgd Grade' ;
    rdfs:comment 'Quality grade assigned to the certified KGD. Grade A is highest quality for mission-critical applications; Grade B for commercial; Grade C for cost-sensitive applications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingApplication rdf:type rdf:Property ;
    rdfs:label 'Packaging Application' ;
    rdfs:comment 'Intended advanced packaging technology for which the KGD is certified. Includes Chip on Wafer on Substrate (CoWoS), Integrated Fan-Out (InFO), Through-Silicon Via (TSV), or direct die shipment.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probeYieldPct rdf:type rdf:Property ;
    rdfs:label 'Probe Yield Pct' ;
    rdfs:comment 'Percentage of die that passed wafer probe testing. Key quality metric indicating the proportion of functional die before singulation.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reliabilityScreenResult rdf:type rdf:Property ;
    rdfs:label 'Reliability Screen Result' ;
    rdfs:comment 'Result of comprehensive reliability screening tests including temperature cycling, humidity exposure, and electrostatic discharge (ESD) testing.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for additional notes, special handling instructions, or deviations from standard certification procedures. Used for audit trail and quality documentation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Test Facility Code' ;
    rdfs:comment 'Code identifying the test facility (internal or Outsourced Semiconductor Assembly and Test partner) where KGD certification testing was performed.' ;
    rdfs:domain ind:InventoryKgdCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photomaskAssetId rdf:type rdf:Property ;
    rdfs:label 'Photomask Asset Id' ;
    rdfs:comment 'Primary key for photomask_asset' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Custody Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Photomask Custody Tracking logs the employee with physical custody of each mask to meet EHS and export-control compliance.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:photomaskStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Photomask Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: photomask_asset stores location as a free-text string; a proper FK to storage_location improves data integrity and enables location-based queries.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — High-value photomasks must track their storage location for retrieval and environmental control.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:tapeoutExperimentId rdf:type rdf:Property ;
    rdfs:label 'Tapeout Experiment Id' ;
    rdfs:comment 'Foreign key linking to research.tapeout_experiment. Business justification: Tapeout experiments must record assigned photomasks; this FK enables the Tapeout Mask Allocation compliance report.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TapeoutExperiment .

ind:assetValuationUsd rdf:type rdf:Property ;
    rdfs:label 'Asset Valuation Usd' ;
    rdfs:comment 'Financial book value of the photomask asset in US dollars as recorded in the fixed asset or inventory valuation module. EUV masks can cost $500K–$1M+; DUV masks range from $10K–$100K. Used for inventory valuation, depreciation, and insurance purposes.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdUniformityNm rdf:type rdf:Property ;
    rdfs:label 'Cd Uniformity Nm' ;
    rdfs:comment 'Measured critical dimension (CD) uniformity across the mask in nanometers, as determined during mask inspection. A key quality metric indicating pattern fidelity; tighter CD uniformity is required at advanced nodes.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMpwMask rdf:type rdf:Property ;
    rdfs:label 'Is Mpw Mask' ;
    rdfs:comment 'Indicates whether this photomask was manufactured as part of a Multi-Project Wafer (MPW) shuttle run, where multiple designs share a single mask set to reduce NRE costs. MPW masks have shared ownership and usage constraints.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date on which the photomask was manufactured and released by the mask vendor. Used for age-based shelf life tracking and vendor lead time analysis.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maskSetName rdf:type rdf:Property ;
    rdfs:label 'Mask Set Name' ;
    rdfs:comment 'Name of the mask set to which this photomask belongs. A mask set groups all reticles required to pattern a complete device layer stack for a given design tapeout.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskSizeMm rdf:type rdf:Property ;
    rdfs:label 'Mask Size Mm' ;
    rdfs:comment 'Physical size of the photomask substrate in millimeters (e.g., 152mm for standard 6-inch reticle). Determines compatibility with the lithography scanner chuck and handling equipment.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maskSubstrateMaterial rdf:type rdf:Property ;
    rdfs:label 'Mask Substrate Material' ;
    rdfs:comment 'Material of the photomask substrate. Fused silica and quartz are standard for DUV masks; Low Thermal Expansion Material (LTEM) and Ultra-Low Expansion (ULE) glass are used for EUV masks to minimize thermal distortion.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDefectLimit rdf:type rdf:Property ;
    rdfs:label 'Max Defect Limit' ;
    rdfs:comment 'Specification-defined maximum number of defects permitted on the photomask before it must be quarantined or retired. Established during mask qualification per process node requirements.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxUsageLimit rdf:type rdf:Property ;
    rdfs:label 'Max Usage Limit' ;
    rdfs:comment 'Manufacturer- or process-qualified maximum number of exposure shots allowed before mandatory retirement or re-qualification of the photomask. Exceeding this limit triggers automatic quarantine in the MES.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pelliclePresent rdf:type rdf:Property ;
    rdfs:label 'Pellicle Present' ;
    rdfs:comment 'Indicates whether a protective pellicle membrane is currently mounted on the photomask. Pellicles protect the mask pattern from particle contamination during exposure. EUV masks use specialized EUV-transparent pellicles.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pellicleType rdf:type rdf:Property ;
    rdfs:label 'Pellicle Type' ;
    rdfs:comment 'Type of pellicle membrane mounted on the photomask. Standard pellicles are used for DUV masks; EUV pellicles are specialized thin-film membranes for EUV lithography. None indicates no pellicle is installed.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationErrorNm rdf:type rdf:Property ;
    rdfs:label 'Registration Error Nm' ;
    rdfs:comment 'Measured overlay registration error of the mask pattern in nanometers, indicating how accurately the mask features are positioned relative to the design intent. Critical for multi-layer overlay budget management.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reticlePodCode rdf:type rdf:Property ;
    rdfs:label 'Reticle Pod Code' ;
    rdfs:comment 'Identifier of the Reticle Storage Pod (RSP) or reticle SMIF pod in which this photomask is currently housed. RSP tracking is critical for contamination prevention and automated mask library management.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scannerModel rdf:type rdf:Property ;
    rdfs:label 'Scanner Model' ;
    rdfs:comment 'Model identifier of the lithography scanner (stepper/scanner) for which this photomask is qualified (e.g., ASML NXT:2000i, ASML NXE:3600D). Masks are qualified to specific scanner models due to optical system compatibility.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Pct' ;
    rdfs:comment 'Required relative humidity percentage for photomask storage environment. Controlled humidity prevents electrostatic discharge damage and contamination on the mask substrate.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Cumulative number of wafer exposure shots (uses) this photomask has undergone since manufacture or last qualification. Tracked by the MES to manage mask wear and schedule preventive inspection.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalInventoryId rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Id' ;
    rdfs:comment 'Unique identifier for the physical inventory count event record.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Physical Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: physical_inventory records location only as a code; linking to storage_location via storage_location_id normalizes location data.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryPhysicalCounterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Physical Counter Employee Id' ;
    rdfs:comment 'Employee identifier of the person who performed the physical count, ensuring accountability and traceability per ISO 9001 requirements.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bookQuantity rdf:type rdf:Property ;
    rdfs:label 'Book Quantity' ;
    rdfs:comment 'System-recorded inventory quantity (book quantity) at the time of the physical count, representing the expected quantity per ERP records.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Consignment Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this inventory is consignment stock held at an OSAT (Outsourced Semiconductor Assembly and Test) partner or customer location, owned by the company but physically located off-site.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consignmentPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Consignment Partner Code' ;
    rdfs:comment 'Vendor or partner code identifying the OSAT partner or customer location where consignment inventory is held.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Completion Timestamp' ;
    rdfs:comment 'Timestamp when the physical count activity was completed and submitted for review.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The date on which the physical inventory count was performed or is scheduled to be performed.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Count Document Number' ;
    rdfs:comment 'Externally-known unique document number assigned to this physical inventory count event for traceability and audit purposes.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNotes rdf:type rdf:Property ;
    rdfs:label 'Count Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the counter or supervisor regarding count conditions, discrepancies observed, damaged goods, or other relevant observations.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Timestamp when the physical count activity began for this inventory event.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the physical inventory count event: planned (scheduled but not started), in-progress (counting underway), completed (count finished awaiting approval), posted (variance posted to system), cancelled, or on-hold.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the physical inventory count event: cycle count (periodic rotation), annual wall-to-wall (full facility), triggered count (post-movement discrepancy or system exception), spot check, variance recount, or regulatory audit.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Physically counted quantity recorded by the counter during the inventory count event.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freezeFlag rdf:type rdf:Property ;
    rdfs:label 'Freeze Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether inventory movements were frozen (blocked) during the count period to ensure accuracy and prevent discrepancies.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryCategory rdf:type rdf:Property ;
    rdfs:label 'Inventory Category' ;
    rdfs:comment 'High-level classification of the inventory being counted: raw material (silicon wafers, chemicals, gases, photomasks), WIP (Work in Process wafer lots), finished goods (packaged chips), die bank, consignment stock, or spare parts.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Unique identifier for the material being counted: raw materials (silicon wafers, chemicals, gases, photomasks), Work in Process (WIP) wafer lots, finished goods (packaged chips), or die bank inventory.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this count is a recount of a previously counted item due to variance exceeding tolerance thresholds or supervisor request.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountReason rdf:type rdf:Property ;
    rdfs:label 'Recount Reason' ;
    rdfs:comment 'Reason code for why a recount was triggered: variance exceeds threshold, supervisor request, system discrepancy, damaged goods, quality hold, or initial count error.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostUsd rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Usd' ;
    rdfs:comment 'Standard cost per unit of the material at the time of count, used for variance valuation and financial reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Code' ;
    rdfs:comment 'Code indicating required storage conditions for the material: ambient, controlled temperature, controlled humidity, nitrogen purge (for moisture-sensitive devices), vacuum, or cleanroom environment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceExceedsToleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Exceeds Tolerance Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether the calculated variance exceeds the defined tolerance threshold, requiring investigation or recount per quality management procedures.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Calculated difference between counted quantity and book quantity (counted minus book), representing inventory discrepancy. Positive values indicate surplus, negative values indicate shortage.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Pct' ;
    rdfs:comment 'Acceptable variance tolerance percentage for this count event, beyond which a recount or investigation is triggered. Typically set per material category and value class.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Variance Value Usd' ;
    rdfs:comment 'Financial value of the inventory variance in US dollars, calculated as variance quantity multiplied by standard cost or moving average price. Critical for SOX Section 404 financial controls and inventory valuation accuracy.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Raw Material Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a raw material master record in the semiconductor inventory domain. Primary key for the raw_material product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:qualityOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quality Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Raw Material Quality Management designates an owner engineer for each material to ensure compliance with RoHS, REACH, and internal quality audits.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The primary unit of measure in which the raw material is stocked and consumed (e.g., EA for each wafer, KG for chemicals, L for liquids, M2 for photomasks). Corresponds to SAP MARA.MEINS (base unit of measure). [ENUM-REF-CANDIDATE: EA|KG|L|M2|M3|PC|SHT|BOX|DRUM|CYLINDER — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManaged rdf:type rdf:Property ;
    rdfs:label 'Batch Managed' ;
    rdfs:comment 'Indicates whether the raw material is managed at the batch/lot level in SAP inventory management. Batch management is mandatory for silicon wafers, photomasks, and shelf-life-controlled chemicals to enable full lot traceability from receipt through consumption. Corresponds to SAP MARA.XCHPF.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which the raw material is scheduled to be discontinued or reaches end-of-life (EOL). Triggers last-time-buy (LTB) procurement actions and product change notification (PCN) processes. Null if the material is not scheduled for discontinuation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixedLotQty rdf:type rdf:Property ;
    rdfs:label 'Fixed Lot Qty' ;
    rdfs:comment 'Fixed order quantity used when lot_size_type is \'fixed\'. Represents the standard purchase order quantity per replenishment cycle, often aligned with supplier minimum order quantities or packaging units. Corresponds to SAP MARC.BSTFE.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether incoming quality inspection (IQC) is mandatory upon goods receipt for this raw material. When true, received lots are placed in quality inspection stock in SAP QM before being released to unrestricted use. Corresponds to SAP MARC.QKZUL.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeType rdf:type rdf:Property ;
    rdfs:label 'Lot Size Type' ;
    rdfs:comment 'SAP MRP lot-sizing procedure that determines how replenishment quantities are calculated. \'fixed\' orders a fixed quantity, \'lot_for_lot\' orders exact requirement, \'min_max\' uses min/max boundaries, \'periodic\' groups requirements by period. Corresponds to SAP MARC.DISMM.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'The original manufacturer\'s part number for the raw material, which may differ from the supplier part number when the supplier is a distributor. Critical for photomasks, specialty chemicals, and ALD precursors where manufacturer identity affects process qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialClass rdf:type rdf:Property ;
    rdfs:label 'Material Class' ;
    rdfs:comment 'High-level classification of the raw material type used in semiconductor manufacturing. Drives storage, handling, and compliance rules. [ENUM-REF-CANDIDATE: silicon_wafer|photomask|process_chemical|specialty_gas|cmp_slurry|ald_precursor|packaging_material|other — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the raw material in SAP S/4HANA MM (Material Master number / MATNR). Used across procurement, inventory, and manufacturing systems as the primary business identifier for the material.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'SAP material group code (MARA.MATKL) used to categorize raw materials for procurement, reporting, and spend analytics. Examples: \'WAFER-SI\', \'CHEM-ETCH\', \'GAS-SPEC\', \'MASK-EUV\'.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Human-readable short description or name of the raw material (e.g., \'Silicon Wafer 300mm P-Type\', \'HMDS Adhesion Promoter\', \'ArF Photomask Layer 1\'). Corresponds to SAP MARA.MAKTX (material description).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the raw material master record. Controls whether the material can be procured, consumed in production, or is subject to end-of-life (EOL) restrictions. Aligns with SAP MARA.MMSTA (plant-level material status).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Maximum allowable inventory quantity for the raw material, used to prevent overstocking of hazardous materials, shelf-life-limited chemicals, or high-cost items. Corresponds to SAP MARC.MABST (maximum stock level).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Min Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum number of days of remaining shelf life required at the time of goods receipt for the material to be accepted into inventory. Materials received with less than this remaining shelf life are rejected or placed in restricted use. Corresponds to SAP MARA.MHDLP.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movingAvgPrice rdf:type rdf:Property ;
    rdfs:label 'Moving Avg Price' ;
    rdfs:comment 'Current moving average price per base unit of measure, recalculated with each goods receipt based on actual purchase prices. Used for inventory valuation under the moving average price control method. Corresponds to SAP MBEW.VERPR.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceControlType rdf:type rdf:Property ;
    rdfs:label 'Price Control Type' ;
    rdfs:comment 'Determines the inventory valuation method for the material: \'standard\' uses a fixed standard price, \'moving_average\' recalculates price with each goods movement. Corresponds to SAP MBEW.VPRSV (price control indicator: S or V).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the standard price and moving average price fields (e.g., USD, EUR, JPY, TWD). Required for multi-currency financial reporting and SOX compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purityPct rdf:type rdf:Property ;
    rdfs:label 'Purity Pct' ;
    rdfs:comment 'Chemical purity of the raw material expressed as a percentage (e.g., 99.9999 for 6N-grade specialty gases, 99.99 for ultra-high-purity chemicals). Critical quality specification for process chemicals, specialty gases, and ALD precursors where trace contamination causes yield loss.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachSvhcFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Svhc Flag' ;
    rdfs:comment 'Indicates whether the raw material contains or is classified as a Substance of Very High Concern (SVHC) under the EU REACH Regulation. Triggers mandatory disclosure obligations when SVHC concentration exceeds 0.1% w/w in articles.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Inventory level at which a replenishment purchase requisition is automatically triggered in SAP MRP. When on-hand stock falls to or below this quantity, procurement is initiated to prevent production line stoppages. Corresponds to SAP MARC.MINBE (reorder point).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialized rdf:type rdf:Property ;
    rdfs:label 'Serialized' ;
    rdfs:comment 'Indicates whether individual units of the raw material are tracked by unique serial number. Applicable to high-value items such as photomasks and reticles where individual unit traceability is required for defect root cause analysis and reticle qualification tracking.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Standard cost price per base unit of measure used for inventory valuation in SAP CO (Controlling) and FI (Financial Accounting). Used for WIP costing, variance analysis, and financial reporting. Corresponds to SAP MBEW.STPRS (standard price).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temp Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for the raw material. Exceeding this threshold may degrade material quality, trigger safety hazards, or invalidate process qualification. Used for warehouse environmental compliance monitoring.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTempMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temp Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for the raw material. Used to configure environmental monitoring alerts in the warehouse management system and ensure compliance with material safety data sheet (SDS) requirements.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierPartNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Part Number' ;
    rdfs:comment 'The part number or catalog number assigned by the primary supplier to this raw material. Used for purchase order creation, supplier communication, and incoming inspection cross-referencing. Stored in SAP INFO record (EINE.IDNLF).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferType rdf:type rdf:Property ;
    rdfs:label 'Wafer Type' ;
    rdfs:comment 'Specifies the silicon wafer substrate type: bare_silicon (polished CZ), epitaxial (epi-layer deposited), soi (Silicon-on-Insulator), fz (Float Zone), or cz (Czochralski). Determines process compatibility and electrical characteristics. Null for non-wafer materials.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryControllerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inventory Controller Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Stock Balance Reconciliation assigns a controller employee who validates periodic counts, supporting financial reporting and SOX compliance.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Reference to the manufacturing plant or facility (FAB, OSAT partner site, assembly and test facility) where this stock balance is maintained.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:primaryStockMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Material Master Id' ;
    rdfs:comment 'Reference to the material master record representing the specific semiconductor material, component, or product (e.g., silicon wafer, photomask, packaged IC, chemical) for which this stock balance is recorded.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:stockMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Stock Material Master Id' ;
    rdfs:comment 'FK to supply.material_master' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:stockRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Stock Raw Material Id' ;
    rdfs:comment 'Foreign key linking to inventory.raw_material. Business justification: raw_material is a master for raw materials; linking stock_balance to raw_material via raw_material_id replaces generic material_master references and enables direct lookup of raw material attributes.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:stockStorageLocationFk rdf:type rdf:Property ;
    rdfs:label 'Stock Storage Location Fk' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Stock balance is always held AT a specific storage location. This is a fundamental dimension of inventory position — you cannot have a meaningful stock balance without knowing WHERE the stock is. Day-' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:stockStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Stock Storage Location Id' ;
    rdfs:comment 'Reference to the physical or logical storage location (e.g., FAB cleanroom bay, chemical storage vault, finished goods warehouse, OSAT consignment location) where this inventory is held.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:batchClassification rdf:type rdf:Property ;
    rdfs:label 'Batch Classification' ;
    rdfs:comment 'Quality grade classification of the wafer or material batch. \'prime\' = meets all specifications for production; \'test\' = test wafers used for process qualification; \'engineering\' = engineering samples not for production; \'monitor\' = process monitor wafers; \'reject\' = failed quality inspection and not usable.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Flag' ;
    rdfs:comment 'Indicates whether this material is subject to export control regulations (True), including ITAR (International Traffic in Arms Regulations) or EAR (Export Administration Regulations) administered by BIS. Export-controlled inventory requires additional authorization before transfer to foreign nationals or shipment to controlled countries.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether this material is classified as hazardous (True) under applicable regulations (OSHA HazCom, REACH, TSCA, or DOT). Hazardous materials include certain process chemicals, gases (e.g., arsine, phosphine), and solvents used in semiconductor fabrication. Triggers special storage, handling, and disposal requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Issue Date' ;
    rdfs:comment 'Date of the most recent goods issue (GI) posting for this material from this storage location. Used to identify dormant inventory, assess consumption velocity, and support slow-moving inventory analysis.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt (GR) posting for this material at this storage location. Used to calculate stock aging, assess replenishment lead times, and support FIFO/FEFO inventory consumption sequencing.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count performed for this material at this storage location. Used to assess inventory accuracy, schedule next count, and support SOX financial reporting requirements for inventory valuation.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qtyAvailable rdf:type rdf:Property ;
    rdfs:label 'Qty Available' ;
    rdfs:comment 'Quantity of unrestricted stock that is not committed to any open reservation or production order. Represents the net available quantity for Available-to-Promise (ATP) calculations and new production planning decisions. Computed as unrestricted stock minus open reservations.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyBlocked rdf:type rdf:Property ;
    rdfs:label 'Qty Blocked' ;
    rdfs:comment 'Quantity of material placed in blocked stock due to quality rejection, ITAR/EAR export control restrictions, supplier non-conformance, or regulatory hold. Blocked stock is not available for production or shipment until formally released.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyInTransit rdf:type rdf:Property ;
    rdfs:label 'Qty In Transit' ;
    rdfs:comment 'Quantity of material that has been shipped from a source location but has not yet been received at the destination location. Includes inter-plant transfers, OSAT shipments, and inbound supplier deliveries in transit.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyInWip rdf:type rdf:Property ;
    rdfs:label 'Qty In Wip' ;
    rdfs:comment 'Quantity of material currently consumed into active production orders and undergoing fabrication processing (e.g., wafer lots in FEOL/BEOL processing, die in packaging). Tracked by the MES and reflected in SAP PP WIP accounts.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyOnHand rdf:type rdf:Property ;
    rdfs:label 'Qty On Hand' ;
    rdfs:comment 'Total physical quantity of the material present at the storage location across all stock types, expressed in the base unit of measure. Represents the gross inventory position before reservations or quality holds are considered.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyQualityInspection rdf:type rdf:Property ;
    rdfs:label 'Qty Quality Inspection' ;
    rdfs:comment 'Quantity of material currently held in SAP QM quality inspection stock, pending disposition decision (accept, reject, rework). Includes incoming inspection lots, in-process inspection holds, and post-process quality holds.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyReserved rdf:type rdf:Property ;
    rdfs:label 'Qty Reserved' ;
    rdfs:comment 'Total quantity committed to active inventory reservations linked to open production orders, sales orders, or transfer orders. Corresponds to open inventory_reservation records and reduces the available quantity for new demand.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slowMovingFlag rdf:type rdf:Property ;
    rdfs:label 'Slow Moving Flag' ;
    rdfs:comment 'Indicates whether this stock balance has been flagged as slow-moving (True) based on the stock_aging_days exceeding the material-specific slow-moving threshold. Used for inventory write-down risk assessment, EOL (End of Life) planning, and LTB (Last Time Buy) decision support.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The principal business event timestamp indicating when this stock balance snapshot was captured from the source system (SAP MM or MES). Represents the point-in-time inventory position and is the primary temporal key for real-time inventory visibility and ATP calculations.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stockAgingDays rdf:type rdf:Property ;
    rdfs:label 'Stock Aging Days' ;
    rdfs:comment 'Number of days the current on-hand stock has been held at this storage location since the oldest receipt date. Used for slow-moving inventory identification, shelf-life monitoring, and obsolescence risk assessment. Critical for chemicals, gases, and photoresists with defined shelf lives.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unrestrictedUseFlag rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Use Flag' ;
    rdfs:comment 'Indicates whether this stock balance record represents inventory that is fully available for unrestricted use in production or shipment (True), or whether it is subject to any hold, restriction, or quality disposition (False). Derived from stock_type but maintained as an explicit flag for rapid ATP query performance.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'SAP valuation class code that determines the general ledger (GL) accounts to which inventory postings are made for this material. Links inventory movements to the correct balance sheet accounts for financial reporting. Detailed financial valuation fields are maintained in the stock_valuation data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferProcessNode rdf:type rdf:Property ;
    rdfs:label 'Wafer Process Node' ;
    rdfs:comment 'The semiconductor process technology node at which the wafer lot or die was fabricated (e.g., \'7nm\', \'14nm\', \'28nm\', \'180nm\'). Critical for inventory segregation, process compatibility checks, and customer design-in alignment.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockValuationId rdf:type rdf:Property ;
    rdfs:label 'Stock Valuation Id' ;
    rdfs:comment 'Primary key for stock_valuation' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:osatPartnerId rdf:type rdf:Property ;
    rdfs:label 'Osat Partner Id' ;
    rdfs:comment 'Reference to the OSAT partner where consignment inventory is held for packaging and test operations.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelPartner .

ind:primaryStockBalanceId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Balance Id' ;
    rdfs:comment 'FK to inventory.stock_balance.stock_balance_id — Financial valuation must reference the quantity position it values. Links financial and physical inventory views.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockBalance .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'The direct labor cost component allocated to the inventory valuation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastValuationDate rdf:type rdf:Property ;
    rdfs:label 'Last Valuation Date' ;
    rdfs:comment 'The date of the previous valuation calculation for this inventory position, enabling period-over-period variance analysis.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialCost rdf:type rdf:Property ;
    rdfs:label 'Material Cost' ;
    rdfs:comment 'The direct material cost component of the valuation (silicon wafers, chemicals, gases, photomasks, packaging materials).' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'The moving average price per unit, recalculated with each goods receipt when using moving average valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreCostAllocation rdf:type rdf:Property ;
    rdfs:label 'Nre Cost Allocation' ;
    rdfs:comment 'The allocated portion of NRE costs (design, tapeout, mask set, PDK licensing) amortized into the inventory valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadCost rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost' ;
    rdfs:comment 'The manufacturing overhead cost component (facility, equipment depreciation, utilities) allocated to the inventory valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Indicates whether this valuation record is subject to SOX financial reporting controls and audit requirements.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'The total financial value of the inventory position (quantity × unit price), representing the balance sheet valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The date on which the inventory valuation was calculated and recorded. Principal business event timestamp for this financial snapshot.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The inventory costing method applied: standard cost, moving average price, FIFO (First In First Out), LIFO (Last In First Out), or weighted average.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'The current status of the inventory valuation: active (available for use), blocked (restricted), quality hold (pending inspection), obsolete (end of life), or scrapped.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Classification of the valuation split (e.g., unrestricted use, quality inspection, blocked stock, consignment).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationVariance rdf:type rdf:Property ;
    rdfs:label 'Valuation Variance' ;
    rdfs:comment 'The variance between current and previous valuation amounts, highlighting inventory value changes for management review.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferLotFk rdf:type rdf:Property ;
    rdfs:label 'Wafer Lot Fk' ;
    rdfs:comment 'FK to inventory.wafer_lot.wafer_lot_id — WIP valuation is performed at the wafer lot level with cost accumulation through process steps. This is the primary valuation entity for in-process inventory.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wipCostAccumulation rdf:type rdf:Property ;
    rdfs:label 'Wip Cost Accumulation' ;
    rdfs:comment 'The accumulated manufacturing costs for WIP wafer lots, including FEOL (Front End of Line), MOL (Middle of Line), and BEOL (Back End of Line) processing costs.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldImpactFactor rdf:type rdf:Property ;
    rdfs:label 'Yield Impact Factor' ;
    rdfs:comment 'A factor representing the yield percentage impact on valuation, used to adjust WIP and die bank valuations based on expected good die yield.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Storage Location Management assigns a manager responsible for safety, access control, and inventory integrity, used in location audit reports.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Physical access control level for this storage location. unrestricted — open access; badge-access — requires valid facility badge; authorized-personnel — restricted to named personnel list (e.g., for ITAR-controlled materials); security-vault — highest security for KGD die banks, photomask vaults, and ITAR-controlled IP. Supports ITAR/EAR export control compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bay rdf:type rdf:Property ;
    rdfs:label 'Bay' ;
    rdfs:comment 'Bay designation within the building or cleanroom where this storage location is physically situated (e.g., \'BAY-03\', \'A-WEST\'). Used for precise physical navigation, equipment layout planning, and cleanroom zone management per SEMI E187.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Identifier for the physical building within the facility where this storage location resides (e.g., \'FAB1\', \'CHEM-WH-B\', \'OSAT-PKG-C\'). Supports facility layout mapping, emergency response planning, and environmental zone management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure used to express the maximum capacity and current utilization of this storage location. Varies by facility type: cassette (wafer storage), pod (photomask storage), tray (packaged chip storage), container (chemical storage), box (die bank storage), pallet (bulk warehouse storage).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanroomIsoClass rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Iso Class' ;
    rdfs:comment 'ISO 14644-1 cleanroom classification for this storage location, defining the maximum allowable airborne particulate concentration. Critical for wafer, photomask, and KGD die storage compliance. Applicable only to cleanroom facility types; null for non-cleanroom locations. Values: ISO-1 (cleanest) through ISO-6.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date on which this storage location was formally commissioned and made available for inventory use. Marks the start of the location\'s operational lifecycle. Used for asset age tracking, depreciation scheduling, and facility capacity planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentUtilizationUnits rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Units' ;
    rdfs:comment 'Current number of inventory units occupying this storage location at the time of last inventory update. Compared against max_capacity_units to compute utilization percentage for capacity planning and inventory placement decisions. Updated by MES and SAP MM inventory movements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date on which this storage location was permanently decommissioned and removed from active inventory use. Populated only when location_status is \'decommissioned\'. Supports facility lifecycle management and historical inventory traceability.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esdProtectionClass rdf:type rdf:Property ;
    rdfs:label 'Esd Protection Class' ;
    rdfs:comment 'ESD protection classification of this storage location per ANSI/ESD S20.20 and JEDEC JESD625 standards. Determines suitability for storing ESD-sensitive devices (ICs, dies, packaged chips). class-0 (most sensitive, <250V HBM) through class-3 (>2000V HBM); unprotected for non-ESD-controlled areas.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the physical facility type housing this storage location. Drives environmental compliance rules, MSD floor life management, and hazmat handling procedures. Valid values: cleanroom (ISO-classified FAB area), warehouse (general materials storage), cold-storage (temperature-controlled for chemicals/biologics), gas-cabinet (pressurized specialty gas storage), nitrogen-cabinet (nitrogen-purged dry storage for moisture-sensitive devices), die-vault (secure KGD die bank storage).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Type' ;
    rdfs:comment 'Type of fire suppression system installed at this storage location. Critical for chemical warehouse and gas cabinet locations storing flammable or reactive materials. Drives emergency response planning and insurance compliance. Values: sprinkler, halon (legacy), fm200 (clean agent), co2, dry-powder, none.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoLatitude rdf:type rdf:Property ;
    rdfs:label 'Geo Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84 decimal degrees) of the facility where this storage location resides. Used for multi-site supply chain mapping, emergency response planning, and regulatory jurisdiction determination for ITAR/EAR export control compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoLongitude rdf:type rdf:Property ;
    rdfs:label 'Geo Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84 decimal degrees) of the facility where this storage location resides. Used in conjunction with geo_latitude for multi-site supply chain mapping and regulatory jurisdiction determination.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'UN/DOT hazardous materials classification code applicable to materials stored at this location (e.g., \'UN1170\' for ethanol, \'UN2014\' for hydrogen peroxide, \'FLAMMABLE-LIQUID\', \'CORROSIVE\', \'COMPRESSED-GAS\', \'NON-HAZMAT\'). Governs storage segregation, emergency response, and regulatory reporting under REACH, RoHS, and TSCA. [ENUM-REF-CANDIDATE: flammable-liquid|corrosive|compressed-gas|oxidizer|toxic|non-hazmat|pyrophoric — promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOsatPartnerLocation rdf:type rdf:Property ;
    rdfs:label 'Is Osat Partner Location' ;
    rdfs:comment 'Indicates whether this storage location is physically situated at an OSAT (Outsourced Semiconductor Assembly and Test) partner facility rather than an internal company site. True for consignment stock locations at OSAT partners. Drives consignment inventory valuation, ownership tracking, and inter-company transfer accounting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kgdStorageCertified rdf:type rdf:Property ;
    rdfs:label 'Kgd Storage Certified' ;
    rdfs:comment 'Indicates whether this storage location is certified for KGD (Known Good Die) die bank storage, meeting requirements for ESD protection, nitrogen purge, temperature/humidity control, and access security. KGD storage certification is required for high-value tested dies awaiting packaging or shipment.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable descriptive name of the storage location (e.g., \'Bay 3 Shelf 12 — EUV Photomask Vault\', \'Cleanroom A Chemical Cabinet Row 5\'). Used in operational reports, MES screens, and inventory placement instructions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational lifecycle status of the storage location. \'active\' — available for inventory placement; \'blocked\' — temporarily unavailable due to maintenance, contamination, or audit hold; \'decommissioned\' — permanently retired from use. Controls whether new inventory can be assigned to this location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Max Capacity Units' ;
    rdfs:comment 'Maximum number of inventory units (wafer cassettes, chemical containers, photomask pods, chip trays, or die boxes) that can be physically stored at this location. Used for capacity planning, inventory placement optimization, and utilization reporting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Max Humidity Pct' ;
    rdfs:comment 'Maximum allowable relative humidity percentage (0–100%) for this storage location. Exceedance above maximum triggers MSD floor life reset, inventory quarantine, and environmental non-conformance reporting per IPC/JEDEC J-STD-033.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for this location. Defines the upper bound of the acceptable temperature range. Exceedance triggers inventory quarantine and environmental non-conformance reporting per ISO 14001 and SEMI C10 chemical storage guidelines.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Min Humidity Pct' ;
    rdfs:comment 'Minimum allowable relative humidity percentage (0–100%) for this storage location. Critical for MSD floor life management, photomask storage, and chemical stability. Exceedance below minimum may cause ESD risk or material degradation.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this location. Defines the lower bound of the acceptable temperature range for stored materials (chemicals, photoresists, gases, packaged devices). Used for environmental compliance monitoring and MSD (Moisture Sensitive Device) floor life management per IPC/JEDEC J-STD-033.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msdFloorLifeCapable rdf:type rdf:Property ;
    rdfs:label 'Msd Floor Life Capable' ;
    rdfs:comment 'Indicates whether this storage location is equipped and certified to manage MSD floor life tracking per IPC/JEDEC J-STD-033. True for nitrogen-purged cabinets, dry-storage cabinets, and controlled-humidity cleanroom locations. Enables automatic floor life clock suspension for stored MSDs.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msdSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Msd Sensitivity Level' ;
    rdfs:comment 'Maximum Moisture Sensitivity Level (MSL) of devices that can be safely stored at this location per IPC/JEDEC J-STD-020. MSL-1 (unlimited floor life at ≤30°C/85%RH) through MSL-5 (most sensitive, 24-hour floor life). Determines which packaged semiconductor devices are eligible for placement at this location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nitrogenPurgeCapable rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Purge Capable' ;
    rdfs:comment 'Indicates whether this storage location is equipped with nitrogen purge capability to maintain an inert, moisture-free atmosphere. True for nitrogen-cabinet and die-vault locations used for long-term KGD die storage, photomask preservation, and moisture-sensitive chemical storage. Drives MSD floor life management decisions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osatPartnerName rdf:type rdf:Property ;
    rdfs:label 'Osat Partner Name' ;
    rdfs:comment 'Name of the OSAT partner company at whose facility this storage location resides (e.g., \'ASE Group\', \'Amkor Technology\', \'JCET\'). Populated only when is_osat_partner_location is True. Used for consignment stock management, partner performance reporting, and supply chain visibility.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photomaskStorageCapable rdf:type rdf:Property ;
    rdfs:label 'Photomask Storage Capable' ;
    rdfs:comment 'Indicates whether this storage location meets the environmental and cleanliness requirements for photomask (reticle) storage, including ISO cleanroom class, nitrogen purge, and ESD protection. Photomasks are high-value assets used in EUV/DUV lithography and require specialized storage conditions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:row rdf:type rdf:Property ;
    rdfs:label 'Row' ;
    rdfs:comment 'Row designation within the bay for this storage location (e.g., \'R-12\', \'ROW-A\'). Provides granular physical addressing for inventory placement, pick-and-put-away operations, and automated storage/retrieval system (ASRS) integration.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelf rdf:type rdf:Property ;
    rdfs:label 'Shelf' ;
    rdfs:comment 'Shelf or bin designation within the row for this storage location (e.g., \'S-04\', \'BIN-002\'). Lowest level of the physical location hierarchy, enabling precise inventory placement and retrieval for wafer cassettes, chemical containers, photomasks, and packaged chip trays.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Tracking Enabled' ;
    rdfs:comment 'Indicates whether shelf life expiry tracking is enabled for materials stored at this location. True for chemical storage, photoresist storage, and gas cabinet locations where materials have defined shelf lives. Enables automated expiry alerts and FEFO (First Expired First Out) inventory management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum allowable total weight in kilograms for materials stored at this location. Critical for shelf structural integrity compliance, particularly for heavy chemical drums, gas cylinders, and bulk wafer cassette storage. Enforced per facility safety standards.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipStagingArea rdf:type rdf:Property ;
    rdfs:label 'Wip Staging Area' ;
    rdfs:comment 'Indicates whether this storage location is designated as a WIP (Work in Process) staging area for wafer lots between process steps. True for inter-bay buffers, equipment load ports, and process queue areas within the FAB cleanroom. Enables WIP flow tracking and cycle time analysis in the MES.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentMemoId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Memo Id' ;
    rdfs:comment 'Primary key for adjustment_memo' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Ar Invoice Id' ;
    rdfs:comment 'FK to invoice.ar_invoice.ar_invoice_id — Adjustment memos (credit/debit/correction) must reference the original invoice being adjusted. Required for AR reconciliation and audit trail.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:primaryAdjustmentArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Adjustment Ar Invoice Id' ;
    rdfs:comment 'Identifier of the invoice that this adjustment memo references.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:relatedContractCustomerContractId rdf:type rdf:Property ;
    rdfs:label 'Related Contract Customer Contract Id' ;
    rdfs:comment 'Identifier of the contract or agreement underlying the original invoice.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContract .

ind:tertiaryAdjustmentAppliedToInvoiceArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Adjustment Applied To Invoice Ar Invoice Id' ;
    rdfs:comment 'Identifier of the open receivable invoice to which this adjustment was applied.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:adjustmentCategory rdf:type rdf:Property ;
    rdfs:label 'Adjustment Category' ;
    rdfs:comment 'High-level category such as price_adjustment, return, overbilling_correction, yield_concession.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Memo Status' ;
    rdfs:comment 'Current workflow state of the adjustment memo.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'External business number assigned to the adjustment memo for tracking and reference.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentSubtype rdf:type rdf:Property ;
    rdfs:label 'Adjustment Subtype' ;
    rdfs:comment 'More granular subtype within the adjustment category, if applicable.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Indicates whether the memo reduces (credit), increases (debit), or formally corrects an invoice.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Portion of the adjustment amount that has been applied to the target invoice.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditUserCreated rdf:type rdf:Property ;
    rdfs:label 'Audit User Created' ;
    rdfs:comment 'System user who originally created the adjustment memo record.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditUserUpdated rdf:type rdf:Property ;
    rdfs:label 'Audit User Updated' ;
    rdfs:comment 'System user who performed the most recent update.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTaxIncluded rdf:type rdf:Property ;
    rdfs:label 'Is Tax Included' ;
    rdfs:comment 'Indicates whether tax is already included in the approved amount.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedReason rdf:type rdf:Property ;
    rdfs:label 'Last Modified Reason' ;
    rdfs:comment 'Reason text explaining why the memo was last modified.' ;
    rdfs:domain ind:AdjustmentMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Number' ;
    rdfs:comment 'Customer-visible invoice number that is being adjusted.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'Outstanding balance on the original invoice after applying this adjustment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date on which the adjustment was settled.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Indicates whether the adjustment has been settled against receivables.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arPaymentTermId rdf:type rdf:Property ;
    rdfs:label 'Ar Payment Term Id' ;
    rdfs:comment 'Foreign key linking to invoice.payment_term. Business justification: Invoices reference a payment-term master; adding payment_term_id FK normalizes payment terms and removes the redundant free-text payment_terms column.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:arPricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Ar Pricing Agreement Id' ;
    rdfs:comment 'FK to invoice.pricing_agreement.pricing_agreement_id — Invoices generated under negotiated pricing must reference the governing pricing agreement for price validation and audit.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingAgreement .

ind:billingAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Links invoice to a normalized address record for tax jurisdiction and export-control validation; required by regulatory reporting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:billingContactId rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Required for Accounts Receivable to send invoice notices to the designated billing contact; standard practice in semiconductor B2B invoicing.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:customerContractId rdf:type rdf:Property ;
    rdfs:label 'Customer Contract Id' ;
    rdfs:comment 'Identifier of the underlying contract or agreement (e.g., NRE milestone, royalty agreement).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContract .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'FK to invoice.payment_term.payment_term_id — Every invoice must reference its applicable payment terms to calculate due dates, discount windows, and penalty triggers.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:pkgAssemblyOrderId rdf:type rdf:Property ;
    rdfs:label 'Pkg Assembly Order Id' ;
    rdfs:comment 'Foreign key linking to packaging.assembly_order. Business justification: Required for the Packaging Service Billing Report, which matches each invoice to the underlying assembly order that generated the packaged product.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyOrder .

ind:toPaymentTermId rdf:type rdf:Property ;
    rdfs:label 'To Payment Term Id' ;
    rdfs:comment 'FK to invoice.payment_term.payment_term_id — Every invoice must reference its applicable payment terms to calculate due date and discount eligibility. Required for AR aging and cash forecasting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:toPricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'To Pricing Agreement Id' ;
    rdfs:comment 'FK to invoice.pricing_agreement.pricing_agreement_id — Invoices generated under negotiated pricing or rebate agreements must reference the governing agreement for price validation and rebate accrual.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingAgreement .

ind:arInvoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Status' ;
    rdfs:comment 'Current lifecycle state of the invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorNotes rdf:type rdf:Property ;
    rdfs:label 'Auditor Notes' ;
    rdfs:comment 'Comments added by internal auditors during review.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when the invoice was cancelled, if applicable.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current state of the collections process for the invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Legal name of the invoicing customer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount applied to the invoice (e.g., early-payment or volume discount).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyPaymentDiscount rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount' ;
    rdfs:comment 'Percentage discount offered for early settlement, if applicable.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecnClassification rdf:type rdf:Property ;
    rdfs:label 'Ecn Classification' ;
    rdfs:comment 'Classification used for export control compliance.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total amount before taxes, discounts, and adjustments.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'Customs classification code for the shipped product.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International commercial terms defining delivery responsibilities.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the invoice was generated and sent to the customer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'External business identifier assigned to the invoice by the billing system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCreditMemo rdf:type rdf:Property ;
    rdfs:label 'Is Credit Memo' ;
    rdfs:comment 'True if the document is a credit memo rather than a standard invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProforma rdf:type rdf:Property ;
    rdfs:label 'Is Proforma' ;
    rdfs:comment 'True if the document is a pro-forma invoice used for customs or advance payment.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'Penalty amount applied when payment is received after the due date.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Number of line items included on the invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Means by which the customer intends to settle the invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of payment collection for the invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Timestamp when the invoice was posted to the general ledger.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingAddress rdf:type rdf:Property ;
    rdfs:label 'Shipping Address' ;
    rdfs:comment 'Delivery location for the goods or services covered by the invoice.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldId rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Id' ;
    rdfs:comment 'System-generated unique identifier for the credit hold record.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCreditCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Customer Account Id' ;
    rdfs:comment 'Unique identifier of the customer to whom the credit hold applies.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryCreditEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Employee Id' ;
    rdfs:comment 'Identifier of the credit analyst who authorized the hold.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCustomerCreditLimitId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Credit Limit Id' ;
    rdfs:comment 'FK to invoice.customer_credit_limit.customer_credit_limit_id — Credit holds are triggered by credit limit breaches. The hold must reference the credit limit record that was exceeded for analyst review and release decisions.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerCreditLimit .

ind:blockLevel rdf:type rdf:Property ;
    rdfs:label 'Block Level' ;
    rdfs:comment 'Scope of the hold: order creation, delivery release, or billing.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Status' ;
    rdfs:comment 'Current lifecycle state of the credit hold.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount approved for the customer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdAmount rdf:type rdf:Property ;
    rdfs:label 'Hold Amount' ;
    rdfs:comment 'Monetary amount that is blocked due to the credit hold.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdCategory rdf:type rdf:Property ;
    rdfs:label 'Hold Category' ;
    rdfs:comment 'Classification of the hold based on its origin or purpose.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Indicates whether the customer has been notified of the hold.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCreditLimitId rdf:type rdf:Property ;
    rdfs:label 'Customer Credit Limit Id' ;
    rdfs:comment 'System-generated surrogate key uniquely identifying each credit limit record.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Organizational unit responsible for the customer relationship.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Currency' ;
    rdfs:comment 'Three-letter ISO currency code of the credit limit amount.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the customer\'s credit is currently on hold.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsuranceCoverage rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Coverage' ;
    rdfs:comment 'Level of insurance protection covering the credit exposure.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Provider' ;
    rdfs:comment 'Name of the insurer providing credit insurance, if any.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCreated rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Created' ;
    rdfs:comment 'Timestamp when the credit limit record was first created in the system.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditLimitLastUpdated rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Last Updated' ;
    rdfs:comment 'Timestamp of the most recent modification to the credit limit record.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditLimitNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Number' ;
    rdfs:comment 'Business identifier for the credit limit agreement, used in external communications and reporting.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Status' ;
    rdfs:comment 'Current lifecycle status of the credit limit record.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitType rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Type' ;
    rdfs:comment 'Classification of the credit limit (e.g., standard, NRE milestone, royalty, project-based).' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRiskClassification rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Classification' ;
    rdfs:comment 'Internal risk grade assigned to the customer based on financial health and payment history.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditUtilizationAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Utilization Amount' ;
    rdfs:comment 'Current total of outstanding receivables against the credit limit.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Limit Adjustment Reason' ;
    rdfs:comment 'Reason code or description for the most recent credit limit change.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitAdjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Limit Adjustment Timestamp' ;
    rdfs:comment 'Timestamp when the most recent credit limit adjustment was applied.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxOverdueDays rdf:type rdf:Property ;
    rdfs:label 'Max Overdue Days' ;
    rdfs:comment 'Maximum number of days any invoice has been overdue for this customer.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentHistoryScore rdf:type rdf:Property ;
    rdfs:label 'Payment History Score' ;
    rdfs:comment 'Aggregated score reflecting the customer\'s historical payment performance.' ;
    rdfs:domain ind:CustomerCreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningNoticeId rdf:type rdf:Property ;
    rdfs:label 'Dunning Notice Id' ;
    rdfs:comment 'System-generated unique identifier for the dunning notice record.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collection Agent Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Dunning notices are issued by a collection agent employee; needed for collection performance metrics and compliance reporting.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dunningArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Dunning Ar Invoice Id' ;
    rdfs:comment 'Identifier of the overdue invoice that triggered this dunning notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:primaryArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Invoice Id' ;
    rdfs:comment 'FK to invoice.ar_invoice.ar_invoice_id — Dunning notices reference specific overdue invoices. The collections process requires traceability from notice to outstanding billing documents.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:toArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'To Ar Invoice Id' ;
    rdfs:comment 'FK to invoice.ar_invoice.ar_invoice_id — Dunning notices reference the overdue invoices driving the collection action. Required for collections workflow and customer communication.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:collectionAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Code' ;
    rdfs:comment 'Identifier of the external collection agency handling the case, if any.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionAgencyEmail rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Email' ;
    rdfs:comment 'Email address of the collection agency contact.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAgencyPhone rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Phone' ;
    rdfs:comment 'Phone number of the collection agency contact.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Address' ;
    rdfs:comment 'Mailing address used when the delivery method is postal.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of days the invoice has been past its due date at the time of the notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Channel used to deliver the dunning notice to the customer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningCharge rdf:type rdf:Property ;
    rdfs:label 'Dunning Charge' ;
    rdfs:comment 'Fee applied for issuing the dunning notice, per collection policy.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningFeeApplied rdf:type rdf:Property ;
    rdfs:label 'Dunning Fee Applied' ;
    rdfs:comment 'Indicates whether a dunning fee has been applied to this notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Escalation stage of the notice, indicating how far the collection process has progressed.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningNoticeStatus rdf:type rdf:Property ;
    rdfs:label 'Dunning Notice Status' ;
    rdfs:comment 'Current lifecycle status of the dunning notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdExceeded rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Exceeded' ;
    rdfs:comment 'Indicates whether the overdue amount or days overdue have crossed a predefined escalation threshold.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'Interest accrued on the overdue amount as of the notice date.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRatePercent rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percent' ;
    rdfs:comment 'Annualized interest rate applied to the overdue amount, expressed as a percentage.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'True if the account is placed on legal hold due to collection actions.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextActionDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Date' ;
    rdfs:comment 'Planned date for the next collection activity (e.g., phone call, legal notice).' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'Timestamp when the dunning notice was generated and sent to the customer.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:noticeNumber rdf:type rdf:Property ;
    rdfs:label 'Notice Number' ;
    rdfs:comment 'Business identifier assigned to the dunning notice, used for tracking and communication with the customer.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalDueDate rdf:type rdf:Property ;
    rdfs:label 'Original Due Date' ;
    rdfs:comment 'The payment due date originally agreed for the invoice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Standard payment term code associated with the invoice (e.g., NET30).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Date on which the customer provided a response to the dunning notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Indicates whether the customer has responded to the notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDue rdf:type rdf:Property ;
    rdfs:label 'Total Due' ;
    rdfs:comment 'Sum of overdue principal, dunning charge, and interest, representing the total amount the customer must pay.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'System-generated unique identifier for each invoice dispute record.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Actual Settlement Date' ;
    rdfs:comment 'Date on which the settlement amount was actually paid.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attachedDocumentsFlag rdf:type rdf:Property ;
    rdfs:label 'Attached Documents Flag' ;
    rdfs:comment 'True if supporting documents are attached to the dispute record.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Timestamp when the dispute record was closed in the system.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'External reference number assigned to the dispute for tracking and communication.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeSource rdf:type rdf:Property ;
    rdfs:label 'Dispute Source' ;
    rdfs:comment 'Origin of the dispute entry within the organization.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle state of the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Category describing the nature of the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Total monetary amount being contested in the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Numeric level indicating how many times the dispute has been escalated.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Settlement Date' ;
    rdfs:comment 'Target date for completing the settlement.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Date and time when the dispute was initially recorded.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Outcome of the dispute after processing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the dispute was resolved.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Final monetary amount agreed upon to resolve the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'Currency used for the settlement amount.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyLotId rdf:type rdf:Property ;
    rdfs:label 'Assembly Lot Id' ;
    rdfs:comment 'Foreign key linking to packaging.assembly_lot. Business justification: Supports lot-based invoicing; each line item must reference the specific assembly lot shipped, enabling the Lot Shipment Billing report.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyLot .

ind:defectRecordId rdf:type rdf:Property ;
    rdfs:label 'Defect Record Id' ;
    rdfs:comment 'Foreign key linking to quality.defect_record. Business justification: Defect Charge-Back Reconciliation links each invoice line to the Defect Record that caused a customer charge-back or credit.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectRecord .

ind:finalTestRunId rdf:type rdf:Property ;
    rdfs:label 'Final Test Run Id' ;
    rdfs:comment 'Foreign key linking to test.final_test_run. Business justification: Final Test Run Billing Reconciliation – each invoice line for test services must reference the specific final_test_run to match revenue with test yield and satisfy audit requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinalTestRun .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to supply.goods_receipt. Business justification: Invoice verification against goods receipt ensures received quantity matches billed amount, required for compliance and financial reconciliation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: Inspection Result Posting requires each invoice line to reference the Inspection Lot that validated the wafer lot before billing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to supply.po_line. Business justification: Three-way match ties each invoice line to its specific purchase order line to validate quantities, pricing, and delivery dates.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:yieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Yield Record Id' ;
    rdfs:comment 'Foreign key linking to quality.yield_record. Business justification: Yield-Based Billing Report requires each invoice line to reference the Yield Record that determines the price adjustment for that wafer lot.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:YieldRecord .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'End date of the billing period covered by this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'Start date of the billing period covered by this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Category of the charge (e.g., product sale, service, NRE milestone, royalty, wafer lot, packaging).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'Financial GL account to which this line is posted.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDiscountApplied rdf:type rdf:Property ;
    rdfs:label 'Is Discount Applied' ;
    rdfs:comment 'True if a discount was applied to this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxExempt rdf:type rdf:Property ;
    rdfs:label 'Is Tax Exempt' ;
    rdfs:comment 'Indicates whether tax is exempt for this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Accounting treatment for revenue timing.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'Percentage rate applied for royalty-based charges.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Channel through which the sale was made.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nreBillingMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Nre Billing Milestone Id' ;
    rdfs:comment 'System-generated unique identifier for each NRE billing milestone record.' ;
    rdfs:domain ind:NreBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Nre Ar Invoice Id' ;
    rdfs:comment 'Identifier of the invoice generated for this milestone.' ;
    rdfs:domain ind:NreBillingMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:primaryNreEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Nre Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the milestone billing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billingFormula rdf:type rdf:Property ;
    rdfs:label 'Billing Formula' ;
    rdfs:comment 'Expression or rule used to calculate the milestone amount (e.g., fixed fee, percentage of NRE total).' ;
    rdfs:domain ind:NreBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingTriggerType rdf:type rdf:Property ;
    rdfs:label 'Billing Trigger Type' ;
    rdfs:comment 'Mechanism that initiates the billing event.' ;
    rdfs:domain ind:NreBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether the billing milestone repeats on a schedule.' ;
    rdfs:domain ind:NreBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneSequence rdf:type rdf:Property ;
    rdfs:label 'Milestone Sequence' ;
    rdfs:comment 'Ordinal position of the milestone within the project billing schedule.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreBillingMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Nre Billing Milestone Status' ;
    rdfs:comment 'Current lifecycle state of the billing milestone.' ;
    rdfs:domain ind:NreBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringInterval rdf:type rdf:Property ;
    rdfs:label 'Recurring Interval' ;
    rdfs:comment 'Time interval for recurring billing when is_recurring is true.' ;
    rdfs:domain ind:NreBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceiptId rdf:type rdf:Property ;
    rdfs:label 'Payment Receipt Id' ;
    rdfs:comment 'System-generated unique identifier for the payment receipt record.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Payment Ar Invoice Id' ;
    rdfs:comment 'Identifier of the primary invoice associated with the payment (if single).' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:processedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Payment receipt processing is performed by a treasury employee; audit logs require linking receipt to processing employee.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reversalReferencePaymentReceiptId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Payment Receipt Id' ;
    rdfs:comment 'Reference to the original payment receipt being reversed.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentReceipt .

ind:allocatedAmountTotal rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount Total' ;
    rdfs:comment 'Sum of amounts allocated to invoices from this payment.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReference rdf:type rdf:Property ;
    rdfs:label 'Bank Reference' ;
    rdfs:comment 'Reference number provided by the bank for the transaction.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Result of compliance checks (e.g., sanctions, AML) for the payment.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Timestamp' ;
    rdfs:comment 'Timestamp when compliance check was performed.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Payment amount converted to the company\'s functional currency.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfAllocations rdf:type rdf:Property ;
    rdfs:label 'Number Of Allocations' ;
    rdfs:comment 'Count of invoice allocations linked to this payment receipt.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onAccountPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'On Account Payment Flag' ;
    rdfs:comment 'True if the payment is recorded as an on-account credit not yet allocated to specific invoices.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overpaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Overpayment Flag' ;
    rdfs:comment 'Indicates if the payment amount exceeds the total invoiced amount.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partialPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Payment Flag' ;
    rdfs:comment 'Indicates if the payment only partially covers the invoiced amount.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Account Number' ;
    rdfs:comment 'Bank account number of the payer.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerBankCode rdf:type rdf:Property ;
    rdfs:label 'Payer Bank Code' ;
    rdfs:comment 'Identifier (e.g., SWIFT/BIC) of the payer\'s bank.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerName rdf:type rdf:Property ;
    rdfs:label 'Payer Name' ;
    rdfs:comment 'Legal name of the entity making the payment.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Channel through which the payment was processed.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date the payment was received.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'Exact timestamp when the payment was recorded in the system.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Indicates whether the payment is domestic or international.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Created Timestamp' ;
    rdfs:comment 'Timestamp when the receipt record was created in the system.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'External receipt number assigned by the finance system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the receipt record.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remittanceAdvice rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice' ;
    rdfs:comment 'Textual remittance information supplied by the payer.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualOpenAmount rdf:type rdf:Property ;
    rdfs:label 'Residual Open Amount' ;
    rdfs:comment 'Remaining unallocated amount after allocations.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toArInvoice rdf:type rdf:Property ;
    rdfs:label 'To Ar Invoice' ;
    rdfs:comment 'FK to invoice.ar_invoice.ar_invoice_id — Payment receipts must link to the invoices they clear. Required for cash application, AR aging, and bank reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableToCustomerType rdf:type rdf:Property ;
    rdfs:label 'Applicable To Customer Type' ;
    rdfs:comment 'Customer segment(s) to which this payment term applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User identifier who approved the payment term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountDays rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Days' ;
    rdfs:comment 'Number of days within which the early payment discount applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Percent' ;
    rdfs:comment 'Percentage discount offered for early payment.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Additional days after due date before penalties commence.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this term is the default for new customers.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentPenaltyDays rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Days' ;
    rdfs:comment 'Number of days after due date when the penalty starts to accrue.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latePaymentPenaltyPercent rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Percent' ;
    rdfs:comment 'Percentage penalty applied after the due date.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalReference rdf:type rdf:Property ;
    rdfs:label 'Legal Reference' ;
    rdfs:comment 'Reference to the legal document governing the payment term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:letterOfCreditRequired rdf:type rdf:Property ;
    rdfs:label 'Letter Of Credit Required' ;
    rdfs:comment 'Indicates whether a letter of credit is mandatory for this term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Max Discount Amount' ;
    rdfs:comment 'Cap on the monetary value of early payment discounts.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Max Penalty Amount' ;
    rdfs:comment 'Cap on the monetary value of late payment penalties.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netDays rdf:type rdf:Property ;
    rdfs:label 'Net Days' ;
    rdfs:comment 'Number of days after invoice date when payment is due (e.g., 30 for Net 30).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentMethodAllowed rdf:type rdf:Property ;
    rdfs:label 'Payment Method Allowed' ;
    rdfs:comment 'Payment instruments permitted for this term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Term Description' ;
    rdfs:comment 'Free-form description of the payment term and its business rationale.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Term Status' ;
    rdfs:comment 'Current lifecycle status of the payment term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInclusive rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive' ;
    rdfs:comment 'Specifies whether the amounts are tax-inclusive.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termCode rdf:type rdf:Property ;
    rdfs:label 'Term Code' ;
    rdfs:comment 'External code used to reference the payment term (e.g., NET30, 2/10NET30).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termName rdf:type rdf:Property ;
    rdfs:label 'Term Name' ;
    rdfs:comment 'Human-readable name of the payment term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Category of the payment term indicating its structure (net, discount, cash, etc.).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Id' ;
    rdfs:comment 'System-generated unique identifier for each pricing agreement.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingAgreement .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Financial treatment of rebates – either cash settlement or accrual accounting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Role or group that granted final approval for the agreement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'Name or identifier of the internal employee responsible for the agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'True if the pricing agreement provides exclusive supply rights to the customer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Commitment Amount' ;
    rdfs:comment 'Upper bound on total spend covered by the agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Amount' ;
    rdfs:comment 'Lowest total spend the customer must achieve to keep the agreement active.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Next Settlement Date' ;
    rdfs:comment 'Planned date for the upcoming rebate settlement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Price Unit Of Measure' ;
    rdfs:comment 'Metric that the base price applies to, such as per die, per watt, or per unit.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingAgreementDescription rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Description' ;
    rdfs:comment 'Narrative description providing context and purpose of the agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Status' ;
    rdfs:comment 'Lifecycle state of the agreement indicating whether it is in draft, active, suspended, terminated, or expired.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Accrued Amount' ;
    rdfs:comment 'Total rebate amount that has been accrued but not yet paid.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateRate rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate' ;
    rdfs:comment 'Percentage of rebate applied to qualifying purchases under the agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateSettledAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Settled Amount' ;
    rdfs:comment 'Cumulative amount of rebate that has been paid to the customer.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateType rdf:type rdf:Property ;
    rdfs:label 'Rebate Type' ;
    rdfs:comment 'Category of rebate, such as volume-based, growth-based, design-win, or market development fund.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'How often accrued rebates are settled with the customer.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIncluded rdf:type rdf:Property ;
    rdfs:label 'Tax Included' ;
    rdfs:comment 'True if the base price already incorporates applicable taxes.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeThreshold rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold' ;
    rdfs:comment 'Quantity level at which the agreement\'s pricing or rebate conditions change.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Unit' ;
    rdfs:comment 'Measurement unit for the volume threshold, e.g., dies, units, or watt.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Id' ;
    rdfs:comment 'System-generated unique identifier for the revenue recognition event record.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Accounting Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Revenue recognition events are reviewed/approved by an accounting employee; required for SOX audit trails.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Identifier of the performance obligation to which this revenue recognition event is linked.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:recognitionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Recognition Schedule Id' ;
    rdfs:comment 'Identifier of the schedule that defines how revenue is spread over time.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecognitionSchedule .

ind:revenueArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Revenue Ar Invoice Id' ;
    rdfs:comment 'Identifier of the invoice that generated this revenue recognition event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Fiscal period (e.g., FY2023Q2) to which the recognized revenue is booked.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfGoodsSoldAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold Amount' ;
    rdfs:comment 'Direct cost attributable to the recognized revenue for this event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Amount' ;
    rdfs:comment 'Portion of the invoice amount that remains deferred after this recognition event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReversed rdf:type rdf:Property ;
    rdfs:label 'Is Reversed' ;
    rdfs:comment 'Indicates whether the revenue recognition event has been reversed (true) or not (false).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the period over which revenue is recognized for this event.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profitAmount rdf:type rdf:Property ;
    rdfs:label 'Profit Amount' ;
    rdfs:comment 'Gross profit derived from the recognized revenue (revenue minus COGS).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'Method used to recognize revenue: point-in-time or over-time.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recognition Timestamp' ;
    rdfs:comment 'Date and time when the revenue was recognized according to the schedule.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Monetary amount of revenue recognized in this event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Business category of the revenue (e.g., product sale, service, IP licensing, royalty, maintenance).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionEventStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRevRecEventToArInvoice rdf:type rdf:Property ;
    rdfs:label 'Revenue Rev Rec Event To Ar Invoice' ;
    rdfs:comment 'FK to invoice.ar_invoice.ar_invoice_id — Revenue recognition events must reference the billing document (invoice) that triggered recognition. Required for ASC 606/IFRS 15 compliance audit.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceRecordKey rdf:type rdf:Property ;
    rdfs:label 'Source Record Key' ;
    rdfs:comment 'Unique key of the source record in the originating system.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBillingId rdf:type rdf:Property ;
    rdfs:label 'Royalty Billing Id' ;
    rdfs:comment 'System-generated unique identifier for the royalty billing record.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:royaltyArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Royalty Ar Invoice Id' ;
    rdfs:comment 'Identifier of the associated financial invoice record.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Sum of discounts, credits, or penalties applied to the gross royalty.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Reference to the detailed audit report document.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'Date the royalty invoice was issued to the licensee.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Number' ;
    rdfs:comment 'Business identifier for the royalty invoice, e.g., RB-20230101.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current lifecycle state of the royalty invoice.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'True if the royalty invoice is under dispute.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the reason for the royalty dispute.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateToUsd rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate To Usd' ;
    rdfs:comment 'Conversion rate from the invoice currency to US dollars for reporting.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRoyaltyExempt rdf:type rdf:Property ;
    rdfs:label 'Is Royalty Exempt' ;
    rdfs:comment 'True if the licensee is exempt from royalty for this period (e.g., promotional waiver).' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date the royalty payment was actually received.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Reference number or code provided by the payer for the royalty payment.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Indicates whether the royalty billing has been reconciled with payments.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyAmountGross rdf:type rdf:Property ;
    rdfs:label 'Royalty Amount Gross' ;
    rdfs:comment 'Total royalty calculated before any discounts, taxes, or adjustments.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyAmountNet rdf:type rdf:Property ;
    rdfs:label 'Royalty Amount Net' ;
    rdfs:comment 'Final royalty amount after adjustments, before tax.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Royalty Calculation Method' ;
    rdfs:comment 'Method used to derive the royalty amount.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Royalty Period End' ;
    rdfs:comment 'Last calendar date of the royalty reporting period.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Royalty Period Start' ;
    rdfs:comment 'First calendar date of the royalty reporting period.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyRate rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate' ;
    rdfs:comment 'Rate applied to calculate royalty – either a per-unit amount or a percentage (expressed as a decimal).' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyType rdf:type rdf:Property ;
    rdfs:label 'Royalty Type' ;
    rdfs:comment 'Indicates whether the royalty is calculated per shipped unit or as a percentage of revenue.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Tier classification that determines the royalty rate based on volume or other criteria.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitShipmentVolume rdf:type rdf:Property ;
    rdfs:label 'Unit Shipment Volume' ;
    rdfs:comment 'Number of licensed units (e.g., chips, dies) reported by the licensee for the period.' ;
    rdfs:domain ind:RoyaltyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxDeterminationId rdf:type rdf:Property ;
    rdfs:label 'Tax Determination Id' ;
    rdfs:comment 'System-generated unique identifier for each tax determination record.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Tax Ar Invoice Id' ;
    rdfs:comment 'Identifier of the invoice to which this tax determination belongs.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:taxOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tax Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Tax determination records must be signed off by a tax officer employee for regulatory compliance.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reverseChargeMechanism rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Mechanism' ;
    rdfs:comment 'Description of the reverse charge method used.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Method' ;
    rdfs:comment 'Method used to compute the tax amount.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Amount' ;
    rdfs:comment 'Monetary value of the tax credit, if applicable.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Eligible' ;
    rdfs:comment 'True if the line qualifies for a tax credit.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Currency' ;
    rdfs:comment 'Three-letter ISO currency code of the tax amount.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Document Number' ;
    rdfs:comment 'Reference number of supporting tax document (e.g., certificate, exemption letter).' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDocumentType rdf:type rdf:Property ;
    rdfs:label 'Tax Document Type' ;
    rdfs:comment 'Type of supporting tax document.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Reason' ;
    rdfs:comment 'Reason or code for tax exemption, if applicable.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIsReverseCharge rdf:type rdf:Property ;
    rdfs:label 'Tax Is Reverse Charge' ;
    rdfs:comment 'True if reverse charge mechanism applies.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Name' ;
    rdfs:comment 'Human-readable name of the tax jurisdiction.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Type' ;
    rdfs:comment 'Level of the jurisdiction that the tax applies to.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLiabilityParty rdf:type rdf:Property ;
    rdfs:label 'Tax Liability Party' ;
    rdfs:comment 'Entity responsible for remitting the tax.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLineDescription rdf:type rdf:Property ;
    rdfs:label 'Tax Line Description' ;
    rdfs:comment 'Free-form description of the tax line.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLineStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Line Status' ;
    rdfs:comment 'Current processing status of the tax line.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Effective Date' ;
    rdfs:comment 'Date from which the tax rate is applicable.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRateExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Expiration Date' ;
    rdfs:comment 'Date after which the tax rate is no longer valid.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRecordCreated rdf:type rdf:Property ;
    rdfs:label 'Tax Record Created' ;
    rdfs:comment 'Date-time when the tax determination record was created.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxRecordUpdated rdf:type rdf:Property ;
    rdfs:label 'Tax Record Updated' ;
    rdfs:comment 'Date-time of the most recent update to the tax record.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxRegionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Region Code' ;
    rdfs:comment 'Code representing the tax region within the jurisdiction.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period' ;
    rdfs:comment 'Fiscal period for which the tax is reported.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Tax Source System' ;
    rdfs:comment 'Originating ERP or tax engine that generated the record.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxSourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Tax Source System Code' ;
    rdfs:comment 'Unique identifier of the tax record in the source system.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Flag' ;
    rdfs:comment 'Indicates whether withholding tax applies to this line.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxableQuantity rdf:type rdf:Property ;
    rdfs:label 'Taxable Quantity' ;
    rdfs:comment 'Quantity of goods or services subject to tax.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Amount' ;
    rdfs:comment 'Calculated withholding tax amount.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Rate' ;
    rdfs:comment 'Withholding tax rate expressed as a percentage.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'System-generated unique identifier for the write-off record.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingEntryId rdf:type rdf:Property ;
    rdfs:label 'Accounting Entry Id' ;
    rdfs:comment 'Link to the corresponding general-ledger entry generated for the write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:primaryWriteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Write Employee Id' ;
    rdfs:comment 'Identifier of the employee or manager who approved the write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryWriteReversalUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Write Reversal User Employee Id' ;
    rdfs:comment 'User who performed the reversal of the write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWriteUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Write Updated By User Employee Id' ;
    rdfs:comment 'User who performed the most recent update to the write-off record.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:writeArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Write Ar Invoice Id' ;
    rdfs:comment 'Identifier of the invoice that is the subject of the write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:badDebtExpenseAccount rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Expense Account' ;
    rdfs:comment 'General Ledger account used to record the bad-debt expense.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReference rdf:type rdf:Property ;
    rdfs:label 'Batch Reference' ;
    rdfs:comment 'Identifier of the processing batch in which this write-off was loaded.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialPeriod rdf:type rdf:Property ;
    rdfs:label 'Financial Period' ;
    rdfs:comment 'Fiscal period (year and quarter) to which the write-off is allocated.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryAttempts rdf:type rdf:Property ;
    rdfs:label 'Recovery Attempts' ;
    rdfs:comment 'Number of collection attempts made after the write-off was posted.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Recovery Flag' ;
    rdfs:comment 'Indicates whether the write-off will be monitored for possible future recovery.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoveryStatus rdf:type rdf:Property ;
    rdfs:label 'Recovery Status' ;
    rdfs:comment 'Current status of any post-write-off recovery effort.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Code' ;
    rdfs:comment 'Code used for statutory reporting (e.g., SEC, SOX, CHIPS Act).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxEffectAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Effect Amount' ;
    rdfs:comment 'Tax component of the write-off amount, if applicable.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffCategory rdf:type rdf:Property ;
    rdfs:label 'Write Off Category' ;
    rdfs:comment 'High-level business domain that triggered the write-off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date on which the write-off was executed in the accounting system.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffMethod rdf:type rdf:Property ;
    rdfs:label 'Write Off Method' ;
    rdfs:comment 'Indicates whether the write-off was entered manually or generated by an automated rule.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'External reference number assigned to the write-off transaction for tracking and audit.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Write Off Status' ;
    rdfs:comment 'Current processing state of the write-off record.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffType rdf:type rdf:Property ;
    rdfs:label 'Write Off Type' ;
    rdfs:comment 'Classification of the write-off based on its financial nature.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Allocation Order Line Id' ;
    rdfs:comment 'Reference to the specific customer order line item against which this allocation is made. Links the allocation to the parent sales order line in the order-to-cash lifecycle.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:primaryOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Line Id' ;
    rdfs:comment 'FK to order.order_line.order_line_id — Allocations reserve inventory against specific order lines. This is the core link for constrained supply management.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'The actual date on which the allocated goods were shipped to the customer. Used for on-time delivery measurement and order fulfillment confirmation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity of units (dies, wafers, or packaged devices) reserved against the customer order line. Expressed in the unit of measure applicable to the lot type.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the allocation was created and the inventory or capacity was reserved against the order line. Principal business event date for this transaction.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this allocation record. Used in customer communications, ERP transactions, and supply chain coordination.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationSource rdf:type rdf:Property ;
    rdfs:label 'Allocation Source' ;
    rdfs:comment 'Identifies the inventory or capacity pool from which this allocation is drawn: \'finished_goods\' (packaged inventory), \'die_bank\' (singulated die inventory), \'wafer_lot\' (in-process wafer inventory), \'fab_capacity\' (reserved fab production capacity), \'mpw_pool\' (Multi-Project Wafer shared pool).' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Categorizes the nature of the allocation: \'hard\' (firm reservation of physical inventory), \'soft\' (provisional hold pending confirmation), \'tentative\' (preliminary planning hold), \'capacity\' (fab capacity reservation), \'die_bank\' (allocation from die bank inventory), \'mpw\' (Multi-Project Wafer run allocation). [ENUM-REF-CANDIDATE: hard|soft|tentative|capacity|die_bank|mpw — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backlogFlag rdf:type rdf:Property ;
    rdfs:label 'Backlog Flag' ;
    rdfs:comment 'Indicates whether this allocation record is part of the open order backlog (i.e., not yet shipped). Used for backlog management reporting and supply-demand balancing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason code or description explaining why this allocation was cancelled. Populated when assignment_status transitions to \'cancelled\'. Supports root cause analysis and supply planning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'The date on which the allocation was formally confirmed, transitioning from tentative or soft to confirmed status. Triggers downstream shipment scheduling.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'The quantity formally confirmed for shipment after quality disposition and availability verification. May differ from allocated_quantity due to yield loss, quality holds, or partial confirmations.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constrainedSupplyFlag rdf:type rdf:Property ;
    rdfs:label 'Constrained Supply Flag' ;
    rdfs:comment 'Indicates whether this allocation was made under constrained supply conditions, where demand exceeded available inventory or fab capacity. Triggers priority-based allocation logic.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endMarketSegment rdf:type rdf:Property ;
    rdfs:label 'End Market Segment' ;
    rdfs:comment 'Target end-market segment for the allocated product: \'automotive\', \'mobile\', \'computing\', \'iot\', \'aerospace\', \'industrial\', \'consumer\'. Drives allocation priority rules and regulatory traceability requirements (e.g., IATF 16949 for automotive). [ENUM-REF-CANDIDATE: automotive|mobile|computing|iot|aerospace|industrial|consumer — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryBatchCode rdf:type rdf:Property ;
    rdfs:label 'Inventory Batch Code' ;
    rdfs:comment 'SAP batch management identifier for the specific inventory batch being allocated. Enables batch-level traceability and quality disposition linkage within SAP S/4HANA MM.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osatSiteCode rdf:type rdf:Property ;
    rdfs:label 'Osat Site Code' ;
    rdfs:comment 'Code identifying the Outsourced Semiconductor Assembly and Test (OSAT) facility responsible for packaging and testing the allocated lot. Relevant for packaged goods lot allocations.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority rank assigned to this allocation record for constrained supply allocation decisions. Lower values indicate higher priority. Used during supply shortages to sequence allocation across competing customer orders.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityDisposition rdf:type rdf:Property ;
    rdfs:label 'Quality Disposition' ;
    rdfs:comment 'Quality disposition status of the allocated lot or inventory batch: \'accepted\' (meets all quality specifications), \'rejected\' (fails quality criteria), \'conditionally_accepted\' (accepted with documented deviations), \'under_review\' (quality evaluation in progress), \'scrapped\' (lot destroyed). Supports IATF 16949 lot-level quality traceability.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Quality Disposition Notes' ;
    rdfs:comment 'Free-text notes documenting lot-specific quality disposition findings, deviations, or conditions associated with this allocation. Supports automotive and aerospace traceability requirements.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the allocated quantity: \'EA\' (each, for packaged units), \'WFR\' (wafers), \'DIE\' (individual die), \'KPC\' (thousand pieces). Aligns with SAP base unit of measure.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Customer-requested shipment date for the allocated quantity. Used for delivery schedule management and on-time delivery performance tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledShipDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Ship Date' ;
    rdfs:comment 'Internally confirmed shipment date scheduled by supply chain planning for this allocation. May differ from requested_ship_date due to capacity or inventory constraints.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Actual quantity shipped against this allocation record. Populated upon delivery confirmation. Used for order fulfillment reconciliation and backlog management.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferStartAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Authorization Number' ;
    rdfs:comment 'Wafer Start Authorization number associated with this allocation, linking the allocation to the authorized fab production run. Relevant for capacity allocations and wafer lot allocations in the order-to-cash lifecycle.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Primary key for amendment' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Amendment Order Id' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Amendments modify existing orders. Each amendment must reference the order it modifies for audit trail integrity.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:amendmentSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Amendment Sales Order Id' ;
    rdfs:comment 'Reference to the parent sales order that this amendment modifies. Links the amendment to the original order header in the order-to-cash lifecycle.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:allocationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Allocation Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment triggers a reallocation of constrained wafer or die inventory across customer orders. True when the quantity or delivery date change affects the allocation pool managed in SAP SD or the MES.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendedFieldName rdf:type rdf:Property ;
    rdfs:label 'Amended Field Name' ;
    rdfs:comment 'The name of the specific order field that was changed (e.g., \'requested_delivery_date\', \'quantity\', \'unit_price\', \'product_code\'). Together with original_value and revised_value, provides a complete field-level audit trail for each amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'The business date on which the amendment was formally raised and submitted by the requester. Used as the effective date for revenue recognition adjustments and backlog recalculation.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle state of the amendment record within the change order management workflow. Transitions from draft through approval to applied or rejected. Drives revenue recognition timing and backlog reporting.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classifies the nature of the change applied to the sales order. Drives downstream workflow routing, revenue recognition treatment, and audit reporting. Allowed values: quantity_change, date_push_out, date_pull_in, cancellation, price_revision, product_substitution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'Date and time when the approved amendment was actually applied to the sales order in the system of record (SAP SD). Marks the point at which the order reflects the revised terms for fulfillment and revenue recognition.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'The authorization tier required and applied for this amendment based on the revenue impact and amendment type. Higher-value or cancellation amendments require escalated approval levels per the delegation of authority matrix.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Free-text explanation provided by the requester describing the business reason for the amendment (e.g., customer demand change, fab capacity constraint, end-market shift, design-win revision). Required for SOX audit trail and customer dispute resolution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized reason code for order cancellations, populated only when amendment_type is \'cancellation\'. Examples include: CUST_REQUEST, CAPACITY_CONSTRAINT, EOL_PRODUCT, DESIGN_WIN_LOST, DUPLICATE_ORDER. [ENUM-REF-CANDIDATE: CUST_REQUEST|CAPACITY_CONSTRAINT|EOL_PRODUCT|DESIGN_WIN_LOST|DUPLICATE_ORDER|PRICE_DISPUTE|EXPORT_HOLD — promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chipsActOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Chips Act Order Flag' ;
    rdfs:comment 'Indicates whether the parent sales order is associated with a CHIPS Act-eligible program. Amendments to CHIPS Act orders may require additional compliance review and reporting under US CHIPS and Science Act requirements.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Requested Flag' ;
    rdfs:comment 'Indicates whether the amendment was initiated by the customer (True) or internally by the semiconductor company (False). Distinguishes customer-driven changes from internal supply chain or capacity-driven adjustments for analytics and dispute resolution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDateOriginal rdf:type rdf:Property ;
    rdfs:label 'Delivery Date Original' ;
    rdfs:comment 'The confirmed delivery date on the sales order line before the amendment. Populated for date_push_out and date_pull_in amendment types. Used to measure schedule change impact and customer on-time delivery performance.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryDateRevised rdf:type rdf:Property ;
    rdfs:label 'Delivery Date Revised' ;
    rdfs:comment 'The new confirmed delivery date after the amendment is applied. Populated for date_push_out and date_pull_in amendment types. Drives updated production scheduling, wafer start authorization, and customer delivery commitments.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference Number' ;
    rdfs:comment 'Reference number of any associated customer dispute or claim raised in Salesforce CRM that prompted or resulted from this amendment. Links the amendment to the customer dispute resolution workflow for escalation tracking.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Export Control Review Required' ;
    rdfs:comment 'Indicates whether the amendment (particularly product substitution or destination change) requires re-review under export control regulations (EAR/ITAR). Ensures compliance with BIS/EAR and ITAR before the revised order is fulfilled.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalValue rdf:type rdf:Property ;
    rdfs:label 'Original Value' ;
    rdfs:comment 'The value of the amended field before the change was applied. Stored as STRING to accommodate heterogeneous amendment types (quantity, date, price, product code). Paired with revised_value and amended_field_name to form a complete before/after audit record.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOriginal rdf:type rdf:Property ;
    rdfs:label 'Quantity Original' ;
    rdfs:comment 'The ordered quantity on the sales order line before the amendment was applied. Populated specifically for quantity_change amendment types. Enables direct numeric comparison and delta calculation for backlog management and wafer start authorization adjustments.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRevised rdf:type rdf:Property ;
    rdfs:label 'Quantity Revised' ;
    rdfs:comment 'The ordered quantity on the sales order line after the amendment is applied. Populated for quantity_change amendment types. Used for backlog recalculation, wafer start authorization updates, and allocation management.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedBy rdf:type rdf:Property ;
    rdfs:label 'Requested By' ;
    rdfs:comment 'Name or user identifier of the individual (internal sales representative, customer service agent, or customer contact) who initiated the amendment request. Supports audit trail and dispute resolution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'The net change in order value resulting from this amendment, expressed in the order currency. Positive for upward revisions (pull-in, price increase), negative for reductions (push-out, cancellation, price decrease). Used directly in revenue recognition and backlog reporting.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionPeriod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Period' ;
    rdfs:comment 'The accounting period (YYYY-MM) in which the revenue impact of this amendment is recognized under ASC 606 / IFRS 15. Assigned by the finance team during amendment approval and used for period-close revenue reporting.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedValue rdf:type rdf:Property ;
    rdfs:label 'Revised Value' ;
    rdfs:comment 'The new value of the amended field after the change is applied. Stored as STRING to accommodate heterogeneous amendment types. Paired with original_value and amended_field_name to form a complete before/after audit record.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'So Line Item Number' ;
    rdfs:comment 'The specific line item number within the parent sales order that this amendment affects. An amendment may target a single line (e.g., quantity change on one SKU) or the entire order header (e.g., cancellation). Null if the amendment applies to the full order.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substituteProductCode rdf:type rdf:Property ;
    rdfs:label 'Substitute Product Code' ;
    rdfs:comment 'The product part number or material code of the replacement product, populated only when amendment_type is \'product_substitution\'. Captures the new IC, SoC, or packaged device being substituted in place of the original ordered product.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toSalesOrder rdf:type rdf:Property ;
    rdfs:label 'To Sales Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Amendments modify a specific sales order. Required for change management audit trail.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitPriceOriginal rdf:type rdf:Property ;
    rdfs:label 'Unit Price Original' ;
    rdfs:comment 'The unit selling price on the sales order line before the price revision amendment. Populated for price_revision amendment types. Supports revenue recognition delta calculation and customer dispute resolution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPriceRevised rdf:type rdf:Property ;
    rdfs:label 'Unit Price Revised' ;
    rdfs:comment 'The new unit selling price after the price revision amendment is applied. Populated for price_revision amendment types. Used for revenue recognition recalculation and updated order value reporting.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferStartImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment requires a corresponding update to the Wafer Start Authorization (WSA) in the fab. True when quantity changes or cancellations affect in-flight WIP lots in the fabrication facility.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backlogPositionId rdf:type rdf:Property ;
    rdfs:label 'Backlog Position Id' ;
    rdfs:comment 'Unique surrogate identifier for each backlog position snapshot record in the order-to-cash lifecycle. Primary key for the backlog_position data product.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backlogOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Backlog Order Line Id' ;
    rdfs:comment 'Reference to the specific order line item (schedule line) within the parent sales order that this backlog position tracks. Enables line-level backlog granularity.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Indicates the degree to which available inventory or production capacity has been allocated to fulfill this backlog position. Critical for backlog management and supply-demand balancing in constrained semiconductor supply environments.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backlogAgingDays rdf:type rdf:Property ;
    rdfs:label 'Backlog Aging Days' ;
    rdfs:comment 'Number of calendar days this order line has been in open backlog as of the snapshot date, calculated from order_entry_date. Used for customer escalation prioritization and aged backlog reporting.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backlogStatus rdf:type rdf:Property ;
    rdfs:label 'Backlog Status' ;
    rdfs:comment 'Current workflow state of this backlog position. \'open\' = unshipped committed order; \'committed\' = confirmed with delivery date; \'at_risk\' = delivery commitment in jeopardy; \'pushed_out\' = delivery date deferred; \'cancelled\' = order line cancelled; \'fulfilled\' = shipped and closed.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backlogValue rdf:type rdf:Property ;
    rdfs:label 'Backlog Value' ;
    rdfs:comment 'The monetary value of the unshipped committed backlog quantity, calculated as committed_quantity multiplied by the net selling price. Used for revenue forecasting, quarterly guidance, and book-to-bill ratio reporting.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelledQuantity rdf:type rdf:Property ;
    rdfs:label 'Cancelled Quantity' ;
    rdfs:comment 'Quantity cancelled from the original order line. Tracks cancellation impact on backlog coverage and book-to-bill ratio reporting.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'The unshipped quantity (in units) that remains committed in backlog for this order line as of the snapshot date. Core metric for backlog management and production planning.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentCommitDate rdf:type rdf:Property ;
    rdfs:label 'Current Commit Date' ;
    rdfs:comment 'The most recent confirmed delivery date committed to the customer, reflecting any push-outs or pull-ins from the original promise date. Used for revenue forecasting and quarterly close planning.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Part Number' ;
    rdfs:comment 'The customer\'s own part number or reference code for the ordered product. Required for customer-facing order confirmations and cross-referencing customer purchase orders with internal part numbers.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'The customer\'s purchase order number referencing this backlog position. Required for customer reconciliation, invoice matching, and accounts receivable processing.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designWinFlag rdf:type rdf:Property ;
    rdfs:label 'Design Win Flag' ;
    rdfs:comment 'Indicates whether this backlog position is associated with a strategic design-win account tracked in Salesforce CRM. Design-win orders receive elevated fulfillment priority to protect long-term revenue relationships.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Export License Number' ;
    rdfs:comment 'The export license number issued by the Bureau of Industry and Security (BIS) or State Department authorizing shipment of controlled semiconductor products. Required when export_control_flag is true.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdCode rdf:type rdf:Property ;
    rdfs:label 'Hold Code' ;
    rdfs:comment 'Code indicating the reason this backlog position is on hold and cannot be shipped. Examples include credit hold, export license pending, quality hold, or customer-requested hold. Null when no hold is active. [ENUM-REF-CANDIDATE: credit_hold|export_hold|quality_hold|customer_hold|compliance_hold|capacity_hold — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) code defining the delivery obligations, risk transfer point, and cost responsibilities between seller and buyer for this order line. Impacts revenue recognition timing. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Net Selling Price' ;
    rdfs:comment 'The agreed net unit selling price for this order line after all applicable discounts and price adjustments. Used to compute backlog value and support revenue recognition under ASC 606.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderEntryDate rdf:type rdf:Property ;
    rdfs:label 'Order Entry Date' ;
    rdfs:comment 'The date on which the customer order was originally entered into the order management system. Used to calculate backlog aging and time-in-backlog metrics.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Original Order Quantity' ;
    rdfs:comment 'The total quantity originally ordered by the customer on this order line. Used to calculate fulfillment percentage and track cancellation or reduction impacts on backlog.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalPromiseDate rdf:type rdf:Property ;
    rdfs:label 'Original Promise Date' ;
    rdfs:comment 'The initial delivery date committed to the customer at the time of order entry. Baseline for measuring push-outs and delivery performance against original commitment.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pushOutDays rdf:type rdf:Property ;
    rdfs:label 'Push Out Days' ;
    rdfs:comment 'Number of calendar days the current_commit_date has been deferred beyond the original_promise_date. Positive value indicates a push-out (delay); negative value indicates a pull-in (acceleration). Key metric for delivery performance and customer satisfaction.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pushOutReasonCode rdf:type rdf:Property ;
    rdfs:label 'Push Out Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the delivery commitment was pushed out or pulled in. Examples include wafer yield issue, capacity constraint, material shortage, customer request, or logistics delay. [ENUM-REF-CANDIDATE: yield_issue|capacity_constraint|material_shortage|customer_request|logistics_delay|design_change|export_hold — promote to reference product]' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Flag' ;
    rdfs:comment 'Indicates whether this backlog position meets the criteria for revenue recognition upon shipment under ASC 606 / IFRS 15. False indicates revenue deferral conditions apply (e.g., consignment, bill-and-hold arrangements).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country for shipment. Used for export control screening, logistics routing, and regional revenue reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The calendar date on which this point-in-time backlog position snapshot was captured. Enables time-series backlog trending, quarterly close reporting, and book-to-bill ratio calculation.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waferLotNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Lot Number' ;
    rdfs:comment 'The fabrication lot number of the wafer batch assigned to fulfill this backlog position. Links the backlog to the specific Work in Process (WIP) lot in the fab for production tracking and yield impact analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the blanket purchase agreement record in the Databricks Silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlanketOrder .

ind:agreedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Agreed Unit Price' ;
    rdfs:comment 'The contractually agreed price per unit for the product under this blanket order. May be a single fixed price or the base tier price when pricing tiers are defined. Expressed in the contract currency.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Numeric priority ranking (lower value = higher priority) used during constrained supply allocation to determine which blanket orders receive preferential wafer starts and finished goods inventory. Automotive and safety-critical programs typically receive highest priority.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether this blanket order agreement is configured to automatically renew for an additional contract period upon expiry if neither party issues a termination notice within the agreed notice window.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blanketOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Number' ;
    rdfs:comment 'Externally visible alphanumeric identifier for the blanket purchase agreement, used in customer-facing communications, SAP SD scheduling agreements, and ERP cross-references. Follows the BO- prefix convention.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calloffFrequency rdf:type rdf:Property ;
    rdfs:label 'Calloff Frequency' ;
    rdfs:comment 'The agreed cadence at which the customer issues individual release orders (call-offs) against this blanket agreement. Drives wafer start planning, fab scheduling, and inventory build strategy.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Months' ;
    rdfs:comment 'Total duration of the blanket order agreement expressed in calendar months. Standard semiconductor blanket agreements run 12 or 24 months; automotive long-term supply agreements may extend to 36 months.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerContractNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Contract Number' ;
    rdfs:comment 'The customer\'s own purchase contract or frame agreement reference number as provided on the customer\'s procurement documentation. Used for cross-referencing with the customer\'s ERP or procurement system.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'The sales channel through which this blanket order is fulfilled. Direct: sold directly to end customer; Distributor: fulfilled via authorized stocking distributor; Rep Firm: managed through manufacturer\'s representative; OEM: original equipment manufacturer direct program; EMS: electronics manufacturing services partner.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Release Date' ;
    rdfs:comment 'The date of the most recent call-off release order issued against this blanket agreement. Used to monitor customer ordering activity, identify dormant blankets, and trigger account management follow-up.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeWeeks rdf:type rdf:Property ;
    rdfs:label 'Lead Time Weeks' ;
    rdfs:comment 'The agreed manufacturing and delivery lead time in weeks from call-off release order placement to customer delivery. Encompasses wafer fab cycle time, assembly and test (OSAT), and logistics. Critical for wafer start authorization scheduling.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ncnrCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Ncnr Coverage Percentage' ;
    rdfs:comment 'The percentage of the committed quantity or blanket value that is subject to NCNR terms. A value of 100 means the entire commitment is NCNR; partial NCNR coverage is common in distributor agreements.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncnrFlag rdf:type rdf:Property ;
    rdfs:label 'Ncnr Flag' ;
    rdfs:comment 'Indicates whether the blanket order is subject to Non-Cancellable Non-Returnable (NCNR) terms. When True, the customer cannot cancel or return product once a release order is issued. Standard for automotive and high-volume OEM semiconductor supply agreements.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the blanket order agreement. Draft: under negotiation; Active: binding and open for call-offs; On Hold: temporarily suspended; Partially Released: some call-off orders issued; Fully Released: all committed quantity has been called off; Closed: contract period ended; Cancelled: terminated before expiry. [ENUM-REF-CANDIDATE: draft|active|on_hold|partially_released|fully_released|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTierStructure rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Structure' ;
    rdfs:comment 'Defines the pricing model applied to this blanket order. Fixed: single price for all quantities; Volume Tiered: unit price decreases at defined quantity thresholds; Time Tiered: price adjusts at defined calendar intervals; Milestone Tiered: price adjusts upon reaching program milestones such as design-in or production ramp.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseOrderToBlanket rdf:type rdf:Property ;
    rdfs:label 'Release Order To Blanket' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Individual sales orders (release orders) are created against blanket orders. The sales order must reference its parent blanket for volume tracking.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'Cumulative quantity that has been called off against this blanket order through individual release orders to date. Used to track consumption of the committed volume and compute remaining open quantity.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'The number of calendar days prior to the expiry date by which either party must provide written notice to prevent automatic renewal or to initiate renegotiation of the blanket agreement terms.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesOrderToBlanket rdf:type rdf:Property ;
    rdfs:label 'Sales Order To Blanket' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Individual sales orders are call-offs against blanket orders. This link is critical for blanket quantity consumption tracking and volume commitment management.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBlanketValue rdf:type rdf:Property ;
    rdfs:label 'Total Blanket Value' ;
    rdfs:comment 'The total monetary value of the blanket order agreement, calculated as committed_quantity multiplied by agreed_unit_price (or sum of tier values). Represents the maximum revenue commitment from this customer for the contract period. Used for revenue forecasting and SOX financial reporting.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Id' ;
    rdfs:comment 'Unique surrogate identifier for the delivery confirmation record in the Databricks Silver Layer. Primary key for the delivery_confirmation data product.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Reference to the parent shipment record for which this delivery confirmation is being captured. Links the proof of delivery (POD) event back to the originating shipment.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'The Advance Shipment Notice number from the customer\'s EDI 856 ASN acknowledgement message. Used to correlate the delivery confirmation with the inbound EDI transaction from the customer\'s warehouse management or ERP system.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPodReference rdf:type rdf:Property ;
    rdfs:label 'Carrier Pod Reference' ;
    rdfs:comment 'The carrier\'s own proof-of-delivery document reference number as provided in the carrier POD data feed. Used to reconcile the internal delivery confirmation with the carrier\'s logistics records and resolve freight disputes.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Number' ;
    rdfs:comment 'The carrier\'s shipment tracking number associated with this delivery confirmation. Enables direct lookup in carrier portals for POD document retrieval and dispute resolution.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationChannel rdf:type rdf:Property ;
    rdfs:label 'Confirmation Channel' ;
    rdfs:comment 'The communication channel through which the delivery confirmation was received from the customer or carrier. \'edi\' = Electronic Data Interchange (EDI 856/861); \'portal\' = customer self-service portal; \'api\' = direct API integration; \'email\' = email-based confirmation; \'manual\' = manually entered by customer service representative.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this delivery confirmation record. Communicated to customers and logistics partners as the official proof-of-delivery (POD) reference number. Format: DC- followed by 10 digits.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current workflow state of the delivery confirmation record. \'pending\' indicates awaiting customer acknowledgement; \'confirmed\' indicates full receipt acknowledged; \'disputed\' indicates customer raised a discrepancy; \'partially_confirmed\' indicates partial quantity acknowledged; \'cancelled\' indicates confirmation voided.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Receipt Date' ;
    rdfs:comment 'The actual calendar date on which the customer confirmed physical receipt of the semiconductor shipment at the destination facility. This is the principal business event date for the delivery confirmation and serves as the trigger date for invoice release and revenue recognition per ASC 606 / IFRS 15.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Receipt Timestamp' ;
    rdfs:comment 'Precise date and time at which the customer confirmed receipt of the shipment, including timezone offset. Used for SLA measurement, carrier performance analytics, and precise revenue recognition event logging.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Status' ;
    rdfs:comment 'The customer\'s formal acceptance decision for the delivered semiconductor product. \'accepted\' = unconditional acceptance; \'rejected\' = full rejection, return initiated; \'conditionally_accepted\' = accepted with noted discrepancy pending resolution; \'pending_inspection\' = customer incoming quality inspection in progress.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignoffName rdf:type rdf:Property ;
    rdfs:label 'Customer Signoff Name' ;
    rdfs:comment 'Name of the customer representative who signed off on the delivery confirmation at the receiving facility. Captured from carrier POD document or EDI 856 acknowledgement. Classified as confidential PII as it identifies an individual at the customer organization.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignoffReference rdf:type rdf:Property ;
    rdfs:label 'Customer Signoff Reference' ;
    rdfs:comment 'The reference identifier of the customer\'s authorized signoff on the delivery confirmation, such as a digital signature ID, customer dock receipt number, or customer ERP goods receipt document number. Required for invoice release authorization and revenue recognition event triggering.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysLate rdf:type rdf:Property ;
    rdfs:label 'Days Late' ;
    rdfs:comment 'Number of calendar days by which the confirmed receipt date exceeded the committed delivery date on the sales order. Negative values indicate early delivery. Zero indicates on-time delivery. Used for carrier performance scorecards and customer SLA compliance reporting.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryPerformanceCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Performance Code' ;
    rdfs:comment 'Classification of delivery performance relative to the confirmed delivery date on the sales order. \'on_time\' = delivered within the committed window; \'early\' = delivered before committed date; \'late\' = delivered after committed date; \'partial\' = partial quantity delivered; \'failed\' = delivery not completed. Used for OTIF (On-Time In-Full) KPI reporting.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceRevision rdf:type rdf:Property ;
    rdfs:label 'Device Revision' ;
    rdfs:comment 'The silicon revision or stepping of the delivered semiconductor device (e.g., A0, B1, C2). Captured at delivery confirmation to ensure the customer received the correct device revision as specified in the purchase order and product change notification (PCN).' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Free-text narrative description of the discrepancy reported by the customer. Captures details not covered by the discrepancy_type enumeration, such as specific damage descriptions, lot number mismatches, or partial damage to a reel. Used in quality notification and RMA processing.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Boolean indicator set to TRUE when the customer has reported any discrepancy between the shipment contents and the delivery confirmation. Triggers downstream discrepancy resolution workflow, quality notification in SAP QM, and potential RMA initiation.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the discrepancy reported by the customer. \'quantity_shortage\' = fewer units received than shipped; \'wrong_part\' = incorrect part number or device type received; \'damaged_goods\' = physical damage to ICs, packaging, or wafers; \'wrong_lot\' = incorrect lot number or traceability mismatch; \'labeling_error\' = incorrect label or marking; \'none\' = no discrepancy.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Verified Flag' ;
    rdfs:comment 'Boolean indicator set to TRUE when export control compliance has been verified for this delivery, confirming the shipment reached the authorized end-destination and end-user as specified in the export license. Required for BIS/EAR and ITAR compliance audit trails.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Document Number' ;
    rdfs:comment 'The customer\'s ERP goods receipt document number (e.g., SAP MIGO GR document) confirming the semiconductor shipment has been posted into the customer\'s inventory. Provides the strongest form of delivery confirmation for invoice matching and dispute resolution.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Release Flag' ;
    rdfs:comment 'Boolean indicator set to TRUE when this delivery confirmation has triggered the downstream invoice release event in SAP S/4HANA FI/SD. Enables monitoring of the order-to-cash cycle and identification of confirmed deliveries pending invoice generation.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Invoice Release Timestamp' ;
    rdfs:comment 'The date and time at which the invoice release event was triggered in SAP S/4HANA FI following delivery confirmation. Used for order-to-cash cycle time analytics and revenue recognition timing compliance under ASC 606 / IFRS 15.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageCountConfirmed rdf:type rdf:Property ;
    rdfs:label 'Package Count Confirmed' ;
    rdfs:comment 'The number of physical packages (boxes, reels, trays, tubes) confirmed as received by the customer. Compared against the shipped package count to identify missing packages in transit. Used for carrier claims and freight audit.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podSource rdf:type rdf:Property ;
    rdfs:label 'Pod Source' ;
    rdfs:comment 'The originating data source from which this delivery confirmation was captured. \'carrier_pod\' = carrier electronic POD feed; \'edi_856\' = customer EDI 856 ASN acknowledgement; \'customer_portal\' = customer self-service portal submission; \'manual\' = manually entered by customer service; \'email_confirmation\' = email-based confirmation.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The arithmetic difference between shipped_quantity and confirmed_quantity (shipped minus confirmed). A positive value indicates a shortage; a negative value indicates an overage. Used to trigger discrepancy workflows and credit/debit memo processing in SAP S/4HANA FI.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country where the semiconductor shipment was received. Used for export control compliance verification, trade compliance reporting, and geographic revenue analytics.' ;
    rdfs:domain ind:DeliveryConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Code' ;
    rdfs:comment 'The customer\'s facility or dock location code where the semiconductor shipment was physically received. Sourced from the customer EDI 856 ASN or carrier POD data. Used for logistics analytics and customer facility mapping.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Reference Number' ;
    rdfs:comment 'The Return Merchandise Authorization number issued when a discrepancy results in a product return. Populated only when discrepancy_flag is TRUE and a return has been authorized. Links the delivery confirmation to the downstream RMA and reverse logistics process.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for each delivery schedule line record in the SAP S/4HANA SD schedule line table (VBEP). Primary key for the delivery_schedule data product in the Silver layer.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Reference to the freight carrier or logistics service provider assigned to transport this shipment. Used for carrier performance tracking and freight cost allocation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:deliveryOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Line Id' ;
    rdfs:comment 'Reference to the specific sales order line item (order item) for which this delivery schedule line is created. A single order line may have multiple schedule lines representing different delivery windows.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:scheduleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Schedule Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Delivery schedule ownership is recorded for accountability in on-time delivery performance reports.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shipFromLocationId rdf:type rdf:Property ;
    rdfs:label 'Ship From Location Id' ;
    rdfs:comment 'Reference to the originating ship-from location for this delivery schedule line. May be a wafer fabrication facility (FAB), OSAT (Outsourced Semiconductor Assembly and Test) site, or finished goods warehouse.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:shipToLocationId rdf:type rdf:Property ;
    rdfs:label 'Ship To Location Id' ;
    rdfs:comment 'Reference to the customer\'s destination ship-to location (customer site, distribution center, or consignment hub) for this delivery schedule line.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:toOrderLineId rdf:type rdf:Property ;
    rdfs:label 'To Order Line Id' ;
    rdfs:comment 'FK to order.order_line.order_line_id — Delivery schedules define delivery windows per order line. delivery_schedule.order_line_id → order_line.order_line_id.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The date on which the shipment was confirmed as received at the customer\'s ship-to location. Used for on-time delivery (OTD) KPI calculation and customer satisfaction reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blanketOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Flag' ;
    rdfs:comment 'Indicates whether this delivery schedule line is part of a blanket (framework) order with periodic call-offs. Blanket orders are common for high-volume semiconductor customers with rolling delivery schedules.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callOffNumber rdf:type rdf:Property ;
    rdfs:label 'Call Off Number' ;
    rdfs:comment 'The specific call-off or release number issued by the customer against a blanket order for this delivery schedule line. Identifies the periodic release instruction within the blanket order framework.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the semiconductor manufacturer to the customer after availability check (ATP) and capacity validation. May differ from the requested date due to wafer fab cycle time or OSAT capacity constraints.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'The actual quantity of units shipped and delivered against this schedule line. Populated from goods issue and proof-of-delivery confirmation. Used to compute open backlog.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'SAP outbound delivery document number (SD delivery order) created against this schedule line. Links the schedule line to the physical goods issue and shipping execution documents.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieBankOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Die Bank Order Number' ;
    rdfs:comment 'Reference number for a die bank order when delivery is fulfilled from pre-tested Known Good Die (KGD) inventory rather than a new wafer start. Supports die bank fulfillment tracking in the order-to-cash lifecycle.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms code for this delivery schedule line (e.g., \'FOB Shanghai\', \'DAP Austin TX\'). Required by ICC Incoterms 2020 to complete the delivery terms specification.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRescheduleReason rdf:type rdf:Property ;
    rdfs:label 'Last Reschedule Reason' ;
    rdfs:comment 'Free-text or coded reason for the most recent rescheduling of this delivery schedule line (e.g., \'wafer yield shortfall\', \'OSAT capacity constraint\', \'customer push-out request\', \'export hold\'). Supports root cause analysis for delivery performance.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpwOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Mpw Order Flag' ;
    rdfs:comment 'Indicates whether this delivery schedule line is associated with a Multi-Project Wafer (MPW) order, where multiple customer designs share a single wafer run. MPW orders have distinct lead times and delivery constraints.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Net monetary value of the confirmed quantity on this delivery schedule line in the transaction currency. Calculated as confirmed quantity multiplied by the agreed unit price. Used for revenue recognition, backlog valuation, and SOX financial reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of semiconductor units (dies, packaged ICs, wafers) originally ordered by the customer on this schedule line. Expressed in the sales unit of measure (e.g., pieces, wafers).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapScheduleLineCategory rdf:type rdf:Property ;
    rdfs:label 'Sap Schedule Line Category' ;
    rdfs:comment 'SAP SD schedule line category code controlling the delivery and goods movement behavior of this schedule line (e.g., CP = standard delivery with transfer of requirements, CN = no goods movement). Sourced from SAP VBEP-ETTYP.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleLineNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Number' ;
    rdfs:comment 'Sequential line number of this delivery schedule entry within the parent order line item. Used to order multiple delivery windows for the same order line (e.g., line 1 = 500 units on date A, line 2 = 500 units on date B).' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleLineRevision rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Revision' ;
    rdfs:comment 'Revision counter tracking how many times this delivery schedule line has been modified (date changes, quantity adjustments, rescheduling). Supports audit trail requirements and customer change notification (PCN) tracking.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleLineStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Status' ;
    rdfs:comment 'Current fulfillment lifecycle status of this delivery schedule line. Drives backlog management, delivery performance reporting, and customer communication. \'blocked\' indicates an export control or credit hold.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Number' ;
    rdfs:comment 'External carrier-assigned tracking number (AWB, BOL, or parcel tracking ID) for the shipment associated with this delivery schedule line. Enables real-time shipment visibility and proof-of-delivery confirmation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieBankOrderId rdf:type rdf:Property ;
    rdfs:label 'Die Bank Order Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the die bank order record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieOrderId rdf:type rdf:Property ;
    rdfs:label 'Die Order Id' ;
    rdfs:comment 'FK to order.order.order_id — Die bank orders draw from pre-built inventory against a customer order for commercial and delivery tracking.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:dieSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Die Sales Order Id' ;
    rdfs:comment 'Reference to the parent SAP SD sales order document under which this die bank order is booked. Enables linkage to commercial terms, pricing, and order-to-cash financial reporting.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:allocatedDieQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Die Quantity' ;
    rdfs:comment 'Number of dies formally allocated from the die bank inventory against this order. May differ from requested quantity due to partial allocation, inventory constraints, or backlog management decisions.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieBankToOrder rdf:type rdf:Property ;
    rdfs:label 'Die Bank To Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Die bank drawdown orders are typically linked to a customer sales order that triggers the packaging/assembly run.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieBankToSalesOrder rdf:type rdf:Property ;
    rdfs:label 'Die Bank To Sales Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Die bank drawdown orders link to the customer sales order that triggered the drawdown request.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieForm rdf:type rdf:Property ;
    rdfs:label 'Die Form' ;
    rdfs:comment 'Physical form in which the die inventory is held in the die bank and will be delivered. Determines whether OSAT packaging conversion is required before shipment.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diePartNumber rdf:type rdf:Property ;
    rdfs:label 'Die Part Number' ;
    rdfs:comment 'Internal part number identifying the specific die type (IC design revision, process node, and configuration) being ordered from the die bank. Aligns with Oracle Agile PLM and SAP MM material master.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderValue rdf:type rdf:Property ;
    rdfs:label 'Order Value' ;
    rdfs:comment 'Total commercial value of the die bank order (unit price × allocated die quantity), in the transaction currency. Used for revenue backlog reporting, order-to-cash financial tracking, and SOX-compliant revenue recognition.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:osatWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Osat Work Order Number' ;
    rdfs:comment 'Work order or job number issued to the OSAT vendor for the packaging run triggered by this die bank order. Used for tracking assembly progress, yield, and delivery confirmation from the OSAT facility.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingInstructionCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Instruction Code' ;
    rdfs:comment 'Reference to the specific package conversion instruction document that defines the assembly process, substrate, wire bond or flip-chip specifications, and test requirements for the OSAT packaging run triggered by this order.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedDieQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Die Quantity' ;
    rdfs:comment 'Number of individual dies (Known Good Die units) requested by the customer or internal order for drawdown from the die bank. Drives OSAT packaging run sizing and inventory reservation.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipToCountry rdf:type rdf:Property ;
    rdfs:label 'Ship To Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country for the shipment. Critical for export control screening (ITAR/EAR), RoHS/REACH compliance declarations, and customs documentation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedDieQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Die Quantity' ;
    rdfs:comment 'Actual number of dies (post-packaging or in bare die form) confirmed as shipped to the customer. Used for fulfillment confirmation, revenue recognition, and DPPM tracking.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferFabSite rdf:type rdf:Property ;
    rdfs:label 'Wafer Fab Site' ;
    rdfs:comment 'Identifier of the wafer fabrication facility (FAB) where the source lot was manufactured. Relevant for quality traceability, site-specific yield analysis, and regulatory compliance (ITAR/EAR site-of-manufacture declarations).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderHoldId rdf:type rdf:Property ;
    rdfs:label 'Order Hold Id' ;
    rdfs:comment 'Unique surrogate identifier for each hold record placed on a sales order or order line within the SAP S/4HANA SD order block management module. Primary key for the order.hold data product.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOrderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Employee Id' ;
    rdfs:comment 'Reference to the employee or team responsible for managing and resolving this hold. Typically the credit analyst, export compliance officer, quality engineer, or customer service representative who initiated or owns the hold. Links to the workforce domain for accountability tracking.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOrderEscalationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Order Escalation Owner Employee Id' ;
    rdfs:comment 'Reference to the senior manager or compliance officer to whom the hold has been escalated. Null if not escalated. Enables accountability tracking for escalated holds and management reporting.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:chipsActReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Chips Act Review Required' ;
    rdfs:comment 'Indicates whether this hold requires a CHIPS Act compliance review, particularly for orders involving customers or end-uses that may conflict with CHIPS Act guardrail provisions restricting expansion of semiconductor manufacturing capacity in countries of concern.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure Amount' ;
    rdfs:comment 'The customer credit exposure amount in the order currency at the time the credit hold was placed. Applicable only for CREDIT hold type. Represents the outstanding accounts receivable balance plus open order value that triggered the credit block in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerRequestReference rdf:type rdf:Property ;
    rdfs:label 'Customer Request Reference' ;
    rdfs:comment 'Customer-provided reference number, purchase order amendment number, or communication reference that authorized or requested the hold. Applicable for CUSTOMER_REQUEST hold type. Enables traceability between the hold and the customer\'s formal request documentation in Salesforce CRM.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieBankImpacted rdf:type rdf:Property ;
    rdfs:label 'Die Bank Impacted' ;
    rdfs:comment 'Indicates whether this hold has blocked shipment from the die bank inventory associated with the sales order. True = die bank order is impacted; False = die bank order is not affected. Used for die bank inventory management and allocation planning.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dppmThreshold rdf:type rdf:Property ;
    rdfs:label 'Dppm Threshold' ;
    rdfs:comment 'The Defective Parts Per Million (DPPM) threshold that was exceeded and triggered the quality hold. Captures the specific quality metric breach driving the hold for QUALITY hold types. Used for quality performance analysis and customer quality reporting.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date and time when the hold was escalated to senior management or a compliance officer. Null if the hold has not been escalated. Used to measure escalation response time and management intervention frequency.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderValueAtRisk rdf:type rdf:Property ;
    rdfs:label 'Order Value At Risk' ;
    rdfs:comment 'Net value of the sales order or order line blocked by this hold, expressed in the order currency. Represents the revenue at risk due to the hold and is used for business impact assessment, management reporting, and prioritization of hold resolution efforts.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Business department responsible for resolving the hold. Drives workflow routing and SLA assignment. CREDIT_MGMT = credit and collections team; EXPORT_COMPLIANCE = trade compliance and ITAR/EAR team; QUALITY = quality assurance and reliability team; CUSTOMER_SERVICE = order management team; SUPPLY_CHAIN = allocation and inventory team; FINANCE = accounts receivable.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the employee or team responsible for managing and resolving this hold at the time it was placed. Denormalized for operational reporting and audit trail purposes without requiring a join to the workforce domain.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Disposition Status' ;
    rdfs:comment 'Current disposition decision status for the quality lot associated with a QUALITY hold. PENDING = disposition not yet determined; USE_AS_IS = lot approved for shipment as-is; REWORK = lot requires rework before shipment; SCRAP = lot scrapped, order must be re-sourced; RETURN_TO_SUPPLIER = material returned to supplier. Null for non-quality holds.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseApproverName rdf:type rdf:Property ;
    rdfs:label 'Release Approver Name' ;
    rdfs:comment 'Full name of the employee who approved the release of the hold at the time of release. Denormalized for audit trail and compliance reporting without requiring a join to the workforce domain.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseReason rdf:type rdf:Property ;
    rdfs:label 'Release Reason' ;
    rdfs:comment 'Narrative explanation of the resolution that enabled the hold to be released. Captures the specific action taken, such as credit limit increase approved, export license number obtained, quality lot disposition completed, or customer confirmation received. Free-text field for audit and compliance documentation.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Requested Release Date' ;
    rdfs:comment 'The date by which the hold is expected or requested to be released, as agreed with the customer or set by the hold owner. Used for proactive hold management, customer commitment tracking, and delivery schedule impact assessment.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Extended free-text notes documenting the full resolution process, including any corrective actions taken, approvals obtained, reference documents reviewed, and follow-up actions required. Supports post-hold analysis and process improvement initiatives.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the hold resolution exceeded the defined SLA target hours. True = SLA was breached; False = resolved within SLA. Used for order management performance reporting and customer escalation management.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target number of business hours within which the hold must be resolved per the order management SLA policy. Varies by hold type: credit holds typically 24 hours, export compliance holds 72 hours, quality holds 48 hours. Used for SLA compliance monitoring and customer commitment management.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemHoldReference rdf:type rdf:Property ;
    rdfs:label 'Source System Hold Reference' ;
    rdfs:comment 'The native hold or order block identifier as recorded in the originating operational system (e.g., SAP S/4HANA SD order block number). Enables reconciliation between the Silver layer data product and the source system of record for data lineage and audit purposes.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferStartImpacted rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Impacted' ;
    rdfs:comment 'Indicates whether this hold has blocked or delayed a wafer start authorization (WSA) associated with the sales order. True = wafer start is impacted; False = wafer start is not affected. Critical for fab capacity planning and WIP management in semiconductor manufacturing.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Lot Assignment Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a specific lot-to-order-line assignment record within the order-to-cash fulfillment process.' ;
    rdfs:domain ind:LotAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assignment Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Lot assignment ownership links a responsible employee to each wafer lot for traceability and quality audits.' ;
    rdfs:domain ind:LotAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedQuantity rdf:type rdf:Property ;
    rdfs:label 'Assigned Quantity' ;
    rdfs:comment 'The quantity of units from this lot assigned to the order line. For wafer lots this represents wafer count; for die lots this represents die count; for packaged goods lots this represents unit count. Must not exceed the available lot quantity.' ;
    rdfs:domain ind:LotAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The calendar date on which the lot was formally assigned to the customer order line. Used for backlog management, delivery schedule tracking, and IATF 16949 lot traceability audit trails.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'Indicates how the lot assignment was created. Manual indicates a planner manually assigned the lot; atp_auto indicates the SAP ATP (Available-to-Promise) engine automatically assigned it; allocation_run indicates it was created by a batch allocation run; planner_override indicates a planner overrode an automatic assignment; system_transfer indicates the assignment was transferred from another order.' ;
    rdfs:domain ind:LotAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfConformanceNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Conformance Number' ;
    rdfs:comment 'The certificate of conformance document number issued for this lot assignment, confirming the lot meets all specified quality and regulatory requirements. Required by automotive (IATF 16949) and aerospace customers.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedShipDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Ship Date' ;
    rdfs:comment 'The confirmed date on which the assigned lot is scheduled to ship to the customer. Drives delivery commitment and ATP (Available-to-Promise) calculations in SAP SD.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dppm rdf:type rdf:Property ;
    rdfs:label 'Dppm' ;
    rdfs:comment 'The defective parts per million rate measured for the assigned lot. Key quality metric reported to automotive customers under IATF 16949 and AIAG quality reporting requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'The SAP QM inspection lot number associated with the quality inspection results for this manufacturing lot. Links the lot assignment to the formal quality inspection record for audit traceability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Percent' ;
    rdfs:comment 'The die yield percentage of the assigned lot, representing the proportion of good dies per wafer that passed all test and inspection criteria. Critical quality metric for automotive and aerospace customers requiring lot-level quality data.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpwOrderId rdf:type rdf:Property ;
    rdfs:label 'Mpw Order Id' ;
    rdfs:comment 'Unique system-generated identifier for the MPW order record. Primary key for the mpw_order data product within the order domain.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mpwOrderSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Mpw Order Sales Order Id' ;
    rdfs:comment 'Foreign key linking to order.order. Business justification: MPW order belongs to a specific sales order; adding child-to-parent FK enables order-level reporting and removes duplicate order_number.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:dieQuantityDelivered rdf:type rdf:Property ;
    rdfs:label 'Die Quantity Delivered' ;
    rdfs:comment 'Actual number of known-good dies (KGD) delivered to the customer from this MPW order. May differ from die_quantity_ordered due to yield loss. Used for fulfillment reconciliation and yield-adjusted billing.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieQuantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Die Quantity Ordered' ;
    rdfs:comment 'Number of known-good dies (KGD) ordered by the customer from this MPW shuttle run. Used for delivery planning, yield-adjusted fulfillment, and revenue recognition.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itarFlag rdf:type rdf:Property ;
    rdfs:label 'Itar Flag' ;
    rdfs:comment 'Indicates whether this MPW order involves ITAR-controlled technology requiring State Department licensing and restricted handling. True = ITAR-controlled; False = not ITAR-controlled. Drives access controls and shipment documentation requirements.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mpwProgramType rdf:type rdf:Property ;
    rdfs:label 'Mpw Program Type' ;
    rdfs:comment 'Classification of the MPW shuttle program under which this order is placed. Determines pricing tiers, slot priority, NRE subsidies, and export control applicability (e.g., government programs may require ITAR review).' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpwToOrder rdf:type rdf:Property ;
    rdfs:label 'Mpw To Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — MPW orders may be linked to a parent sales order for billing and customer relationship tracking.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mpwToSalesOrder rdf:type rdf:Property ;
    rdfs:label 'Mpw To Sales Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — MPW orders are a specialized order type that should link back to the parent sales order for billing and customer relationship tracking.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreChargeUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Charge Usd' ;
    rdfs:comment 'One-time Non-Recurring Engineering charge billed to the customer for mask set preparation, reticle slot allocation, and design-in support for this MPW order. Expressed in US dollars. Shared proportionally among shuttle participants based on reticle slot area.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The calendar date on which the customer formally placed the MPW order. Represents the principal business event date for order-to-cash lifecycle tracking and backlog reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text field for capturing special instructions, customer-specific requirements, design constraints, or internal processing notes associated with this MPW order. Not used for structured data.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderValueUsd rdf:type rdf:Property ;
    rdfs:label 'Order Value Usd' ;
    rdfs:comment 'Total monetary value of this MPW order in US dollars, comprising NRE charges plus die unit price multiplied by ordered quantity. Used for backlog reporting, revenue forecasting, and SAP FI billing.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'Committed date by which the ordered dies are planned to be delivered to the customer after wafer fabrication, dicing, and optional packaging. Used for customer delivery scheduling and order-to-cash SLA tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Customer-issued purchase order number referencing this MPW order. Required for invoice matching, accounts receivable, and customer procurement compliance. Sourced from SAP S/4HANA SD order entry.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reticleSlotAreaMm2 rdf:type rdf:Property ;
    rdfs:label 'Reticle Slot Area Mm2' ;
    rdfs:comment 'Physical area in square millimeters allocated to this customer\'s design within the shared MPW reticle. Determines die size, die-per-wafer count, and proportional NRE cost allocation among shuttle participants.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reticleSlotNumber rdf:type rdf:Property ;
    rdfs:label 'Reticle Slot Number' ;
    rdfs:comment 'The specific slot number assigned to this customer\'s design on the shared MPW reticle. Each slot represents a distinct die area on the shared mask set. Slot allocation drives NRE cost sharing and die quantity calculations.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesRegionCode rdf:type rdf:Property ;
    rdfs:label 'Sales Region Code' ;
    rdfs:comment 'Geographic sales region code associated with this MPW order (e.g., AMER, EMEA, APAC, JAPAN). Used for regional revenue reporting, quota management, and export control jurisdiction determination.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutDeadline rdf:type rdf:Property ;
    rdfs:label 'Tapeout Deadline' ;
    rdfs:comment 'Contractual deadline by which the customer must submit the final GDSII design data (tapeout) to secure their reticle slot in the MPW shuttle run. Missing this date results in slot forfeiture and potential NRE penalty.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tapeoutReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Tapeout Received Date' ;
    rdfs:comment 'Actual date on which the customer\'s final GDSII tapeout data was received and accepted by the fab or design services team. Used to confirm slot lock and trigger wafer start authorization.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Unit Price Usd' ;
    rdfs:comment 'Per-die price charged to the customer for the ordered die quantity from this MPW run. Expressed in US dollars. Used for revenue recognition, invoice generation, and margin analysis.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferStartDateActual rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Date Actual' ;
    rdfs:comment 'Actual date on which wafer fabrication was initiated for this MPW shuttle run. Compared against planned wafer start date to measure schedule adherence and TTM performance.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waferStartDatePlanned rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Date Planned' ;
    rdfs:comment 'Planned date for initiating wafer fabrication (wafer start) for this MPW shuttle run at the fab site. Used for fab capacity scheduling, WIP planning, and customer delivery commitment.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yieldPct rdf:type rdf:Property ;
    rdfs:label 'Yield Pct' ;
    rdfs:comment 'Percentage of good dies produced relative to the total possible dies from the allocated wafer area in this MPW run. Expressed as a percentage (0.00–100.00). Used for quality reporting, customer communication, and yield improvement programs.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreOrderId rdf:type rdf:Property ;
    rdfs:label 'Nre Order Id' ;
    rdfs:comment 'Unique identifier for the NRE order record. Primary key for the NRE order entity.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Nre Sales Order Id' ;
    rdfs:comment 'Reference to the associated production sales order that this NRE order supports. Links NRE charges to the recurring product order.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Contractually defined criteria that must be met for customer acceptance of NRE deliverables. Used for milestone signoff and dispute resolution.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationClause rdf:type rdf:Property ;
    rdfs:label 'Cancellation Clause' ;
    rdfs:comment 'Contractual terms governing NRE order cancellation, including notice periods, cancellation fees, and work-in-progress settlement.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedMilestoneCount rdf:type rdf:Property ;
    rdfs:label 'Completed Milestone Count' ;
    rdfs:comment 'Number of milestones that have been completed and accepted by the customer. Used to calculate project completion percentage.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractDate rdf:type rdf:Property ;
    rdfs:label 'Contract Date' ;
    rdfs:comment 'Date when the NRE contract was signed and became legally binding. Establishes the start of contractual obligations.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Commercial structure of the NRE contract. Determines billing method and risk allocation between customer and supplier.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableList rdf:type rdf:Property ;
    rdfs:label 'Deliverable List' ;
    rdfs:comment 'Comprehensive list of engineering deliverables committed in the NRE contract. Includes design files, documentation, test reports, and IP cores.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Design Complexity Score' ;
    rdfs:comment 'Quantitative measure of IC design complexity based on gate count, IP blocks, and verification requirements. Used for NRE pricing and resource estimation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Cumulative amount invoiced to date across all completed milestones. Used to track billing progress and outstanding receivables.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipCoreList rdf:type rdf:Property ;
    rdfs:label 'Ip Core List' ;
    rdfs:comment 'List of third-party or internal IP cores integrated as part of this NRE engagement. Tracks IP licensing and royalty obligations.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of engineering milestones defined in this NRE contract. Used for progress tracking and billing schedule management.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Nre Order Number' ;
    rdfs:comment 'Human-readable business identifier for the NRE order. Externally communicated reference number used in contracts and invoices.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nreStatus rdf:type rdf:Property ;
    rdfs:label 'Nre Status' ;
    rdfs:comment 'Current lifecycle status of the NRE order. Tracks progression from contract approval through engineering completion and invoicing. [ENUM-REF-CANDIDATE: draft|approved|in_progress|milestone_review|completed|invoiced|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nreToSalesOrder rdf:type rdf:Property ;
    rdfs:label 'Nre To Sales Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — NRE orders are associated with a customer engagement that typically has a parent sales order or contract reference.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreType rdf:type rdf:Property ;
    rdfs:label 'Nre Type' ;
    rdfs:comment 'Classification of the NRE engagement by engineering deliverable category. Determines the type of one-time engineering work being performed.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Cumulative amount received from customer to date. Used to track payment status and outstanding balances.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Contractual penalties for late delivery or non-conformance to acceptance criteria. Defines financial consequences of schedule or quality failures.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date for engineering work to commence. Used for resource planning and project scheduling.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesDesignWinId rdf:type rdf:Property ;
    rdfs:label 'Sales Design Win Id' ;
    rdfs:comment 'Reference to the Salesforce CRM design-win opportunity that originated this sales order. Links the order to the customer design-in engagement, enabling design-win to revenue conversion tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesDesignWin .

ind:grossOrderValue rdf:type rdf:Property ;
    rdfs:label 'Gross Order Value' ;
    rdfs:comment 'Total gross value of the sales order before application of discounts, taxes, or surcharges, expressed in the order currency. Represents the sum of all line item gross values. Used for revenue forecasting and backlog valuation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Net value of the sales order after application of all discounts and pricing conditions but before tax. Represents the contractually agreed revenue amount. Corresponds to SAP VBAK.NETWR. Used for revenue recognition and financial reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreAmount rdf:type rdf:Property ;
    rdfs:label 'Nre Amount' ;
    rdfs:comment 'Non-Recurring Engineering (NRE) charges associated with this order, covering one-time design, mask set, and process development costs. Applicable for ASIC, custom IC, and MPW order types. Reported separately from unit product revenue.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'The channel or system through which the customer order was received and entered. Used for order entry efficiency analysis and digital transformation tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soNumber rdf:type rdf:Property ;
    rdfs:label 'So Number' ;
    rdfs:comment 'Externally visible sales order number as assigned by SAP S/4HANA SD module. Used in all customer-facing communications, shipping documents, and invoices. Corresponds to the VBELN field in SAP VBAK table.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferStartAuthorization rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Authorization' ;
    rdfs:comment 'Indicates whether this order has triggered a wafer start authorization in the fabrication facility (FAB). When True, the MES (Manufacturing Execution System) has been instructed to initiate wafer lot processing for this order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageTypeId rdf:type rdf:Property ;
    rdfs:label 'Package Type Id' ;
    rdfs:comment 'Foreign key linking to packaging.package_type. Business justification: Needed for Packaging Planning; order line specifies requested package type, linking to package_type enables yield, cost, and compliance analysis per packaging family.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:primarySalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Order Id' ;
    rdfs:comment 'Reference to the parent sales order header to which this line item belongs. Establishes the header-to-line relationship in the order-to-cash lifecycle. Corresponds to SAP S/4HANA SD VBELN (Sales Document Number).' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:quoteLineId rdf:type rdf:Property ;
    rdfs:label 'Quote Line Id' ;
    rdfs:comment 'Foreign key linking to sales.quote_line. Business justification: Each order line is derived from a quote line; needed for line-level margin and fulfillment analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteLine .

ind:dateEntered rdf:type rdf:Property ;
    rdfs:label 'Date Entered' ;
    rdfs:comment 'The business date on which this order line was entered into the SAP S/4HANA SD system. Represents the commercial event date for backlog aging calculations and order-to-cash cycle time measurement.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dieBankOrder rdf:type rdf:Property ;
    rdfs:label 'Die Bank Order' ;
    rdfs:comment 'Indicates whether this order line is to be fulfilled from the die bank (inventory of known good dies (KGD) awaiting packaging) rather than from finished goods or new wafer starts. True = die bank fulfillment; False = standard finished goods or new production.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'SAP SD item category classification for this order line, indicating the business nature of the line (e.g., standard product sale, consignment fill-up, customer return, engineering sample, NRE charge, MPW service, evaluation unit). Drives pricing, delivery, and billing behavior. [ENUM-REF-CANDIDATE: standard|consignment|returns|sample|nre|mpw|evaluation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpwOrder rdf:type rdf:Property ;
    rdfs:label 'Mpw Order' ;
    rdfs:comment 'Indicates whether this order line is associated with a Multi-Project Wafer (MPW) run, where multiple customer designs share a single wafer to reduce NRE costs. True = MPW order; False = dedicated production lot order.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partialShipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Allowed' ;
    rdfs:comment 'Indicates whether the customer permits partial shipments against this order line. True = partial shipments accepted; False = complete order line quantity must ship together. Drives delivery scheduling and backlog management decisions.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productRevision rdf:type rdf:Property ;
    rdfs:label 'Product Revision' ;
    rdfs:comment 'The silicon revision or stepping of the ordered semiconductor product (e.g., A0, B1, C2). Critical for tracking product change notifications (PCNs), errata management, and ensuring customers receive the correct silicon revision per their qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Line Item Number' ;
    rdfs:comment 'The native SAP S/4HANA SD six-digit item number (POSNR) for this order line, used for traceability back to the system of record and for EDI/customer portal reconciliation.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Code indicating special handling, storage, or shipping requirements for this order line (e.g., ESD-sensitive, moisture-sensitive level (MSL), controlled humidity, ITAR-controlled, hazmat). Drives warehouse and logistics instructions. [ENUM-REF-CANDIDATE: ESD|MSL1|MSL2|MSL3|ITAR|HAZMAT|CONTROLLED_TEMP|FRAGILE — promote to reference product]' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNreMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Order Nre Milestone Id' ;
    rdfs:comment 'Unique identifier for the NRE milestone record. Primary key for the order_nre_milestone product.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceSignoffReference rdf:type rdf:Property ;
    rdfs:label 'Acceptance Signoff Reference' ;
    rdfs:comment 'Reference to the formal customer acceptance document, email, or system record confirming milestone approval.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Flag' ;
    rdfs:comment 'Indicates whether this milestone has been modified from the original contract terms through a formal change order or amendment.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Date' ;
    rdfs:comment 'Date when the customer formally accepted the milestone deliverable, triggering payment and revenue recognition.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliverableLocation rdf:type rdf:Property ;
    rdfs:label 'Deliverable Location' ;
    rdfs:comment 'File path, document management system reference, or repository location where the milestone deliverable artifacts are stored.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyMilestones rdf:type rdf:Property ;
    rdfs:label 'Dependency Milestones' ;
    rdfs:comment 'Comma-separated list of prerequisite milestone numbers or identifiers that must be completed before this milestone can begin.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effortHoursActual rdf:type rdf:Property ;
    rdfs:label 'Effort Hours Actual' ;
    rdfs:comment 'Actual engineering effort in hours expended to complete this milestone, tracked for cost accounting and future estimation.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effortHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Effort Hours Planned' ;
    rdfs:comment 'Estimated engineering effort in hours required to complete this milestone, used for resource planning and cost estimation.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneAmount rdf:type rdf:Property ;
    rdfs:label 'Milestone Amount' ;
    rdfs:comment 'Contractual payment amount associated with this milestone in the order currency. Represents the revenue to be recognized upon milestone acceptance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Detailed description of the engineering deliverable, acceptance criteria, and scope of work associated with this milestone.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneNumber rdf:type rdf:Property ;
    rdfs:label 'Milestone Number' ;
    rdfs:comment 'Business identifier for the milestone within the NRE contract. Typically sequential or hierarchical (e.g., M1, M2.1, MS-001).' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationReference rdf:type rdf:Property ;
    rdfs:label 'Modification Reference' ;
    rdfs:comment 'Reference to the contract change order or amendment document that modified this milestone terms, scope, or payment.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment for this milestone is contractually due from the customer.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation provided by the customer if the milestone deliverable was rejected, including specific deficiencies or gaps.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Amount' ;
    rdfs:comment 'Actual amount of revenue recognized for this milestone, which may differ from milestone_amount due to contract modifications or adjustments.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Required Flag' ;
    rdfs:comment 'Indicates whether engineering rework is required to address customer feedback or rejection reasons.' ;
    rdfs:domain ind:OrderNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this milestone within the NRE order, defining the execution sequence and dependencies.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Primary key for rma' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureAnalysisReportId rdf:type rdf:Property ;
    rdfs:label 'Failure Analysis Report Id' ;
    rdfs:comment 'Reference to the failure analysis record if FA was performed. Links RMA to detailed root cause investigation and corrective action.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureAnalysisReport .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Reference to the quality inspector or technician who performed the incoming inspection of the returned material.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Reference to the manufacturing lot from which the returned units originated. Critical for traceability and yield impact analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:rmaOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Order Id' ;
    rdfs:comment 'FK to order.order.order_id — RMAs reference the original sales order for the returned product. rma.sales_order_id → order.sales_order_id.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:rmaReplacementOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Replacement Order Id' ;
    rdfs:comment 'Reference to the replacement sales order created to ship substitute product to the customer. Nullable if disposition is not replacement.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:rmaSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Sales Order Id' ;
    rdfs:comment 'Reference to the original sales order from which the returned product was shipped. Links RMA to the originating order transaction.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the RMA was fully closed after disposition action completed (credit issued, replacement shipped, or material scrapped).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Monetary value of the credit issued to the customer in the transaction currency. Nullable if no credit is issued.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Reference number of the credit memo issued to the customer for the returned material. Nullable if no credit is issued (e.g., customer error returns).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Email' ;
    rdfs:comment 'Email address of the customer contact for RMA correspondence, status updates, and resolution communication.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactName rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Name' ;
    rdfs:comment 'Name of the customer representative who initiated or is managing the RMA on the customer side. Used for communication and escalation.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number of the customer contact for urgent RMA inquiries or escalation.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Free-text description of the defect or issue reported by the customer. Captures detailed failure symptoms, visual observations, or functional anomalies.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'Action to be taken with the returned material. Determines downstream workflow (credit memo, replacement order, FA request, or scrap authorization).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dppmImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Dppm Impact Flag' ;
    rdfs:comment 'Indicates whether this RMA should be counted in DPPM calculations. True if the defect is attributable to manufacturing or design (excludes customer-induced damage).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureAnalysisRequested rdf:type rdf:Property ;
    rdfs:label 'Failure Analysis Requested' ;
    rdfs:comment 'Indicates whether a formal failure analysis (FA) has been requested for the returned units. True triggers FA workflow and lab assignment.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Outcome of the incoming inspection. Determines whether the return claim is valid and informs disposition and credit decisions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes and comments for cross-functional coordination (quality, engineering, customer service). Not shared with customer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Facility Code' ;
    rdfs:comment 'Code identifying the facility (FAB, OSAT, warehouse, or service center) where the returned material is received and inspected.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code categorizing the reason for the return. Used for root cause analysis, DPPM tracking, and warranty claim classification.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShippingCarrier rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Carrier' ;
    rdfs:comment 'Name of the logistics carrier used to ship the returned material (e.g., FedEx, UPS, DHL, regional freight forwarder).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Tracking Number' ;
    rdfs:comment 'Carrier tracking number for the return shipment. Used for shipment visibility and proof of receipt.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the RMA. Used in customer communications, shipping labels, and cross-system tracking.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the RMA. Tracks progression from customer request through receipt, inspection, and final disposition. [ENUM-REF-CANDIDATE: requested|approved|rejected|in_transit|received|inspected|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toOriginalOrder rdf:type rdf:Property ;
    rdfs:label 'To Original Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — RMAs reference the original sales order for the returned product. Required for credit processing and quality traceability.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether this RMA is being processed as a warranty claim. True if the return is within warranty period and defect is covered.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Shipment coordination role is tracked to ensure logistics responsibility and KPI reporting.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shipmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Shipment Order Id' ;
    rdfs:comment 'Reference to the parent sales order that initiated this shipment. Links the shipment back to the order-to-cash lifecycle.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:toOrderId rdf:type rdf:Property ;
    rdfs:label 'To Order Id' ;
    rdfs:comment 'FK to order.order.order_id — Shipments fulfill customer orders. shipment.sales_order_id → order.sales_order_id. Critical for order-to-cash traceability.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Confirmed date the shipment physically arrived at the customer receiving location. Populated from carrier proof of delivery (POD) or customer EDI 856 acknowledgement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the freight carrier or logistics service provider responsible for transporting the shipment (e.g., FedEx, DHL, UPS, Nippon Express). Used for carrier performance analytics and claims management.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Damaged Goods Flag' ;
    rdfs:comment 'Indicates whether the customer reported damaged goods upon delivery. Triggers carrier claims process, RMA initiation, and DPPM (Defective Parts Per Million) quality reporting.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Declared Value Usd' ;
    rdfs:comment 'Declared value of the shipment contents in US dollars for customs and insurance purposes. Required for import duty calculation and export documentation under EAR/ITAR.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Carrier-provided estimated date of arrival at the customer destination. Used for delivery scheduling, customer communication, and on-time delivery (OTD) performance tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCostUsd rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Usd' ;
    rdfs:comment 'Total freight and logistics cost for this shipment in US dollars. Used for cost allocation, customer billing (if freight is charged), and supply chain cost analytics.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms including packaging. Required for carrier freight billing, customs declarations, and dangerous goods compliance.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsTariffCode rdf:type rdf:Property ;
    rdfs:label 'Hs Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) tariff classification code for the semiconductor products in this shipment. Required for customs declarations, import duties, and cross-border trade compliance.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Certificate Number' ;
    rdfs:comment 'Reference number of the quality inspection certificate (Certificate of Conformance or Certificate of Analysis) accompanying the shipment. Required for automotive (IATF 16949) and aerospace customers.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiLeg rdf:type rdf:Property ;
    rdfs:label 'Is Multi Leg' ;
    rdfs:comment 'Indicates whether this shipment involves multiple transportation legs (e.g., fab to OSAT to customer, or cross-border transshipment). Enables multi-leg shipment tracking and compliance documentation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotNumbers rdf:type rdf:Property ;
    rdfs:label 'Lot Numbers' ;
    rdfs:comment 'Comma-separated list of manufacturing lot numbers (wafer lot IDs) included in this shipment. Enables full traceability from customer delivery back to wafer fabrication and process engineering records in Camstar MES.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Code' ;
    rdfs:comment 'Code identifying the origin facility from which the shipment departed — fab, OSAT, or distribution center. Used for multi-leg shipment traceability and supply chain analytics.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Total number of physical packages (boxes, reels, trays, tubes) included in this shipment. Used for carrier manifest, customs declaration, and receiving verification.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podConfirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Pod Confirmed Quantity' ;
    rdfs:comment 'Quantity confirmed as received by the customer at the delivery location per the proof of delivery (POD). Compared against shipped_quantity to identify shortages or overages.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Pod Receipt Date' ;
    rdfs:comment 'Date the customer confirmed receipt of the shipment as captured in the proof of delivery (POD). Triggers downstream invoice release and revenue recognition in SAP S/4HANA FI.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:podSignoffReference rdf:type rdf:Property ;
    rdfs:label 'Pod Signoff Reference' ;
    rdfs:comment 'Customer signoff reference or electronic signature identifier from the proof of delivery document. Serves as legal evidence of delivery completion for dispute resolution and revenue recognition.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityShortageFlag rdf:type rdf:Property ;
    rdfs:label 'Quantity Shortage Flag' ;
    rdfs:comment 'Indicates whether the customer reported a quantity shortage at delivery (POD confirmed quantity less than shipped quantity). Triggers discrepancy investigation and potential credit memo.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Carrier service tier selected for this shipment (e.g., overnight, express, standard ground). Determines transit time commitment and freight cost.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Actual date the shipment physically departed the origin facility (fab, OSAT, or distribution center). Principal business event date for the shipment transaction.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally visible, human-readable shipment identifier used in carrier communications, customer EDI 856 ASN, and logistics documentation. Sourced from SAP S/4HANA SD outbound delivery number.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle state of the shipment. Drives downstream processes including invoice release and revenue recognition upon delivery confirmation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wrongPartFlag rdf:type rdf:Property ;
    rdfs:label 'Wrong Part Flag' ;
    rdfs:comment 'Indicates whether the customer reported receipt of an incorrect part number or product. Triggers RMA process, root cause analysis, and corrective action in the quality management system.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentLineId rdf:type rdf:Property ;
    rdfs:label 'Shipment Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each shipment line record in the Silver Layer lakehouse. Primary key for the shipment_line data product.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryShipmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Shipment Id' ;
    rdfs:comment 'Reference to the parent shipment header record. Links this line to the physical shipment event (HEADER_REFERENCE per TRANSACTION_LINE role).' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:shipmentOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Shipment Order Line Id' ;
    rdfs:comment 'Reference to the customer order line that this shipment line fulfills. Enables traceability from physical shipment back to the originating sales order line in the order-to-cash lifecycle.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:toShipmentId rdf:type rdf:Property ;
    rdfs:label 'To Shipment Id' ;
    rdfs:comment 'FK to order.shipment.shipment_id — Fundamental header-to-line relationship. Every shipment line must belong to exactly one shipment.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:advanceShipNoticeNumber rdf:type rdf:Property ;
    rdfs:label 'Advance Ship Notice Number' ;
    rdfs:comment 'EDI Advance Ship Notice (ASN/856) document number transmitted to the customer prior to shipment. Enables customer receiving automation and inventory planning.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether this shipment line represents a partial fulfillment of a backordered quantity, where the full ordered quantity could not be shipped due to inventory allocation constraints.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Timestamp' ;
    rdfs:comment 'Precise timestamp when goods issue was posted in SAP, marking the transfer of ownership and triggering revenue recognition and inventory reduction. BUSINESS_EVENT_TIMESTAMP for this transaction line.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineNetValue rdf:type rdf:Property ;
    rdfs:label 'Line Net Value' ;
    rdfs:comment 'Total net value of this shipment line (shipped_quantity × unit_selling_price after applicable discounts). Used for revenue recognition, invoice generation, and SOX financial reporting.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Physical packaging configuration used for the shipped semiconductor units. Determines handling requirements, moisture sensitivity level (MSL), and customer SMT assembly compatibility.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialShipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Flag' ;
    rdfs:comment 'Indicates whether this line represents a partial shipment against the order line quantity. When true, additional shipment lines are expected to fulfill the remaining ordered quantity.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'Committed delivery date for this shipment line as agreed with the customer at order entry. Used for on-time delivery (OTD) performance measurement and customer SLA tracking.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionLevel rdf:type rdf:Property ;
    rdfs:label 'Revision Level' ;
    rdfs:comment 'Hardware or mask revision level of the shipped IC (e.g., A0, B1, C2). Critical for customer compatibility verification, PCN (Product Change Notification) compliance, and field failure analysis.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range End' ;
    rdfs:comment 'Ending serial number of the serialized unit range included in this shipment line. Used with serial_number_range_start to define the complete set of serialized units shipped.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range Start' ;
    rdfs:comment 'Starting serial number of the serialized unit range included in this shipment line. Applicable for high-value or security-sensitive ICs requiring individual unit traceability (e.g., automotive, military-grade).' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Selling Price' ;
    rdfs:comment 'Agreed selling price per unit for this shipment line as invoiced to the customer. LINE_VALUE_OR_RESULT per TRANSACTION_LINE role. Sensitive commercial pricing data.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldGrade rdf:type rdf:Property ;
    rdfs:label 'Yield Grade' ;
    rdfs:comment 'Quality or speed grade assigned to the shipped product based on wafer test (probe) results and final test binning. Indicates performance tier (e.g., commercial, industrial, automotive, military grade) for the shipped units.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Primary key for status_history' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statusOrderId rdf:type rdf:Property ;
    rdfs:label 'Status Order Id' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Status history records track transitions for a specific order. Must reference the parent order.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:statusSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Status Sales Order Id' ;
    rdfs:comment 'Reference to the parent sales order whose status changed. Links this history record to the order-to-cash lifecycle master record.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:cancellationType rdf:type rdf:Property ;
    rdfs:label 'Cancellation Type' ;
    rdfs:comment 'Classifies the reason for order cancellation when new_status is cancelled. Values: customer_request (customer-initiated), eol (End of Life product discontinuation), capacity (fab capacity unavailable), yield_fail (unacceptable yield), export_block (export compliance hold), duplicate (duplicate order entry). Null for non-cancellation transitions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Change Sequence Number' ;
    rdfs:comment 'Sequential integer representing the ordinal position of this status transition within the complete history of the sales order line. Sequence 1 is the initial entry event. Enables ordered reconstruction of the full order lifecycle.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieBankOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Die Bank Order Flag' ;
    rdfs:comment 'Indicates whether this order line is fulfilled from die bank inventory (pre-fabricated, unpackaged dies held in inventory) rather than a new wafer start. Die bank orders have a compressed status lifecycle bypassing wafer_started and in_fab states.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationInPriorStatusHours rdf:type rdf:Property ;
    rdfs:label 'Duration In Prior Status Hours' ;
    rdfs:comment 'The number of hours the order line spent in the prior_status before transitioning to new_status. Calculated at ingestion time from the difference between this transition_timestamp and the previous record\'s transition_timestamp. Supports cycle time and SLA analytics.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationPriority rdf:type rdf:Property ;
    rdfs:label 'Escalation Priority' ;
    rdfs:comment 'Priority level of the customer escalation active at the time of this status transition. P1 is highest urgency (e.g., automotive line-down risk), P4 is lowest. Populated only when escalation_flag is True.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentStatus rdf:type rdf:Property ;
    rdfs:label 'Is Current Status' ;
    rdfs:comment 'Indicates whether this record represents the most recent (current) status of the order line. True for the latest status transition record; False for all historical records. Enables efficient current-state queries without window functions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mpwFlag rdf:type rdf:Property ;
    rdfs:label 'Mpw Flag' ;
    rdfs:comment 'Indicates whether the order line is associated with a Multi-Project Wafer (MPW) run. MPW orders share wafer capacity across multiple customers and have distinct status transition rules compared to dedicated production orders.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Order Line Number' ;
    rdfs:comment 'The specific line item number within the sales order to which this status transition applies. A single sales order may have multiple lines (e.g., different part numbers or delivery dates) each with independent status histories.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachedFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breached Flag' ;
    rdfs:comment 'Indicates whether the duration in the prior status exceeded the SLA target hours, constituting an SLA breach. True when duration_in_prior_status_hours > sla_target_hours. Supports escalation triggering and customer reporting.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'The reference number of the source business document that triggered this status transition (e.g., a purchase order number, a delivery note number, an invoice number, or a MES lot release number). Provides cross-system traceability.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemEventReference rdf:type rdf:Property ;
    rdfs:label 'Source System Event Reference' ;
    rdfs:comment 'The unique event or change document identifier from the originating operational system (e.g., SAP Change Document number CDHDR.CHANGENR, Camstar transaction ID, or Salesforce case event ID). Enables end-to-end traceability from the Silver layer back to the system of record.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the status transition occurred. This is the principal business event time for this EVENT_LOG record, distinct from record audit timestamps.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transitionType rdf:type rdf:Property ;
    rdfs:label 'Transition Type' ;
    rdfs:comment 'Classifies the nature of the status transition: forward progression through the order lifecycle, backward reversal (e.g., re-open), cancellation, or data correction. Supports lifecycle analytics and anomaly detection.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredBySystem rdf:type rdf:Property ;
    rdfs:label 'Triggered By System' ;
    rdfs:comment 'The operational system of record that originated the status change event. Distinguishes between manual user-driven changes and automated system-driven transitions (e.g., MES wafer start confirmation triggering wafer_started status). [ENUM-REF-CANDIDATE: SAP_SD|MES_CAMSTAR|MES_SMARTFACTORY|SALESFORCE_CRM|AGILE_PLM|MANUAL|API_INTEGRATION — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabSiteId rdf:type rdf:Property ;
    rdfs:label 'Fab Site Id' ;
    rdfs:comment 'Reference to the fabrication facility (FAB) where the authorized wafer starts are to be executed. Determines routing of the demand signal to the correct MES instance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabSite .

ind:waferOrderId rdf:type rdf:Property ;
    rdfs:label 'Wafer Order Id' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Wafer start authorizations are triggered by customer orders. The WSA must reference the originating sales order for demand traceability.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:waferSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Wafer Sales Order Id' ;
    rdfs:comment 'Reference to the originating customer sales order that triggered this wafer start authorization. Links the order domain to the fabrication demand signal. Serves as the PARTY_REFERENCE / agreement anchor for this transaction.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the wafer start authorization, used across order management, MES, and fab planning systems. Typically formatted as WSA-{SITE}-{SEQUENCE}. This is the BUSINESS_IDENTIFIER category field for this TRANSACTION_HEADER entity.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle state of the wafer start authorization record, tracking progression from initial creation through fab release and completion. Fulfills the LIFECYCLE_STATUS minimum category for TRANSACTION_HEADER. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|released_to_fab|in_progress|completed|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedBy rdf:type rdf:Property ;
    rdfs:label 'Authorized By' ;
    rdfs:comment 'Name or employee identifier of the person who formally approved and issued the wafer start authorization. Required for SOX compliance and audit trail. Typically a fab planning manager or order management lead.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedWaferQty rdf:type rdf:Property ;
    rdfs:label 'Authorized Wafer Qty' ;
    rdfs:comment 'Number of wafers authorized to start fabrication under this authorization record. This is the primary quantitative demand signal passed from order management to the MES. Fulfills the QUANTITATIVE_RESULT minimum category for this non-monetary TRANSACTION_HEADER.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleTimeTargetDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Target Days' ;
    rdfs:comment 'Target number of calendar days from wafer start to wafer out (completion of all fab processing steps). Defined by process node and priority class. Hot lots have compressed cycle time targets. Used for delivery commit date calculation and fab performance measurement.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieBankReplenishmentCode rdf:type rdf:Property ;
    rdfs:label 'Die Bank Replenishment Code' ;
    rdfs:comment 'Reference to the die bank replenishment plan that triggered this authorization when the wafer start is driven by inventory replenishment rather than a direct customer sales order. Nullable when authorization originates from a sales order.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedGoodDieQty rdf:type rdf:Property ;
    rdfs:label 'Expected Good Die Qty' ;
    rdfs:comment 'Projected number of Known Good Dies (KGD) expected from this wafer start, calculated from authorized_wafer_qty, die per wafer count, and yield_target_pct. Used for order fulfillment planning and die bank replenishment forecasting.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Fab Work Order Number' ;
    rdfs:comment 'SAP PP production order or work order number generated in ERP when the wafer start authorization is released to manufacturing. Bridges the order management domain to the ERP manufacturing execution module for cost collection and WIP tracking.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMpw rdf:type rdf:Property ;
    rdfs:label 'Is Mpw' ;
    rdfs:comment 'Indicates whether this authorization is for a Multi-Project Wafer (MPW) run, where multiple customer designs share a single wafer to reduce NRE cost. MPW lots require special reticle set management and die allocation tracking.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNre rdf:type rdf:Property ;
    rdfs:label 'Is Nre' ;
    rdfs:comment 'Indicates whether this wafer start authorization is for a Non-Recurring Engineering (NRE) run, such as a first-time tapeout, process qualification, or engineering lot, as opposed to a production volume order. NRE lots have distinct cost accounting and yield expectations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processTechnologyCode rdf:type rdf:Property ;
    rdfs:label 'Process Technology Code' ;
    rdfs:comment 'Internal fab process technology identifier (e.g., N5P, N7FF+, HVM28LP) that maps to a specific process flow within the fabrication facility. More granular than process_node; used for exact MES routing and recipe assignment.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredShipDate rdf:type rdf:Property ;
    rdfs:label 'Required Ship Date' ;
    rdfs:comment 'Customer-committed or order-driven date by which finished product must ship. Used to back-calculate the wafer start date and validate that the planned_start_date supports on-time delivery. Key input to TTM (Time to Market) and delivery performance metrics.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'Native record identifier from the originating source system (e.g., SAP production order number, Camstar lot ID, Salesforce opportunity ID). Enables cross-system traceability and reconciliation between the lakehouse Silver Layer and operational systems.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferUnitCostUsd rdf:type rdf:Property ;
    rdfs:label 'Wafer Unit Cost Usd' ;
    rdfs:comment 'Standard cost per wafer in US dollars for the specified process node and fab site at the time of authorization. Used for cost of goods sold (COGS) estimation, margin analysis, and financial planning.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wsaToSalesOrder rdf:type rdf:Property ;
    rdfs:label 'Wsa To Sales Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Wafer start authorizations are triggered by sales orders. This link is essential for demand-to-supply traceability and is explicitly mentioned in the WSA description.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldTargetPct rdf:type rdf:Property ;
    rdfs:label 'Yield Target Pct' ;
    rdfs:comment 'Expected die yield percentage (good dies per wafer as a percentage of total die sites) for this wafer start, based on process node maturity and historical SPC data. Used to calculate expected good die output and validate order fulfillment feasibility.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assemblyChangeNoticeId rdf:type rdf:Property ;
    rdfs:label 'Assembly Change Notice Id' ;
    rdfs:comment 'Primary key for assembly_change_notice' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyChangeNotice .

ind:attachmentFlag rdf:type rdf:Property ;
    rdfs:label 'Attachment Flag' ;
    rdfs:comment 'Indicates whether supporting documentation is attached to the change notice.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attachmentReference rdf:type rdf:Property ;
    rdfs:label 'Attachment Reference' ;
    rdfs:comment 'Path or identifier of the attached document(s) in the DMS.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Change Approval Date' ;
    rdfs:comment 'Date the change was formally approved for implementation.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:changeOriginator rdf:type rdf:Property ;
    rdfs:label 'Change Originator' ;
    rdfs:comment 'Department or function that originated the change request.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOwnerName rdf:type rdf:Property ;
    rdfs:label 'Change Owner Name' ;
    rdfs:comment 'Full name of the change owner.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle status of the change notice.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Change Submission Date' ;
    rdfs:comment 'Date the change notice was submitted to the change control system.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Current status of the regulatory/compliance review for this change.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Status' ;
    rdfs:comment 'Current approval status from the customer regarding the change.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnDppm rdf:type rdf:Property ;
    rdfs:label 'Impact On Dppm' ;
    rdfs:comment 'Estimated change in DPPM metric due to the change.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactOnYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Impact On Yield Percent' ;
    rdfs:comment 'Estimated percentage change in wafer or die yield caused by the change.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:osatSiteTransfer rdf:type rdf:Property ;
    rdfs:label 'Osat Site Transfer' ;
    rdfs:comment 'Target OSAT site code if the change involves moving production to a different assembly facility.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageMaterial rdf:type rdf:Property ;
    rdfs:label 'Package Material' ;
    rdfs:comment 'Material composition of the package (e.g., epoxy, ceramic, organic).' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepChanged rdf:type rdf:Property ;
    rdfs:label 'Process Step Changed' ;
    rdfs:comment 'Specific manufacturing process step that is being modified.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationRequired rdf:type rdf:Property ;
    rdfs:label 'Qualification Required' ;
    rdfs:comment 'Indicates if the change requires a qualification or qualification run before implementation.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryImpactDetails rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Details' ;
    rdfs:comment 'Free-text description of the regulatory impact, including standards affected.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'True if the change has regulatory implications (e.g., RoHS, REACH, ITAR).' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedPcnNumber rdf:type rdf:Property ;
    rdfs:label 'Related Pcn Number' ;
    rdfs:comment 'Identifier of a related PCN, if this change is a follow-on or amendment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCount rdf:type rdf:Property ;
    rdfs:label 'Sku Count' ;
    rdfs:comment 'Number of distinct SKUs listed in the affected_sku field.' ;
    rdfs:domain ind:AssemblyChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assemblyDefectId rdf:type rdf:Property ;
    rdfs:label 'Assembly Defect Id' ;
    rdfs:comment 'Primary key for assembly_defect' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssemblyLotId rdf:type rdf:Property ;
    rdfs:label 'Primary Assembly Lot Id' ;
    rdfs:comment 'Identifier of the wafer lot where the defect was observed.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyLot .

ind:processStepId rdf:type rdf:Property ;
    rdfs:label 'Process Step Id' ;
    rdfs:comment 'Foreign key linking to process.process_process_step. Business justification: REQUIRED: Defect root-cause analysis links packaging defects back to the fab process step that introduced them.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessStep .

ind:qualityDefectRecordId rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Record Id' ;
    rdfs:comment 'Foreign key linking to quality.defect_record. Business justification: Enables Defect Traceability across wafer and package stages, required for Root Cause Analysis report that correlates wafer defects to package defects.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectRecord .

ind:assemblyDefectLotFk rdf:type rdf:Property ;
    rdfs:label 'Assembly Defect Lot Fk' ;
    rdfs:comment 'FK to packaging.assembly_lot.assembly_lot_id — Defects are identified on specific lots. Required for lot disposition decisions and DPPM calculations.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assemblyDefectStatus rdf:type rdf:Property ;
    rdfs:label 'Assembly Defect Status' ;
    rdfs:comment 'Current processing status of the defect record.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comment rdf:type rdf:Property ;
    rdfs:label 'Comment' ;
    rdfs:comment 'Free-form notes entered by the inspector.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCategory rdf:type rdf:Property ;
    rdfs:label 'Defect Category' ;
    rdfs:comment 'Higher-level category describing the nature of the defect.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectImageUri rdf:type rdf:Property ;
    rdfs:label 'Defect Image Uri' ;
    rdfs:comment 'Link to the image captured for the defect.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Classification of the defect observed during inspection.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionBatchCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Batch Code' ;
    rdfs:comment 'Identifier of the inspection batch (transaction header) to which this defect belongs.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionTool rdf:type rdf:Property ;
    rdfs:label 'Inspection Tool' ;
    rdfs:comment 'Name or model of the inspection tool used.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Unit Serial Number' ;
    rdfs:comment 'Serial number of the individual packaged unit (die) where the defect was detected.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyOrderId rdf:type rdf:Property ;
    rdfs:label 'Assembly Order Id' ;
    rdfs:comment 'FK to packaging.assembly_order.assembly_order_id — Assembly lots are created against assembly orders. This is the fundamental header-to-lot relationship enabling WIP tracking per order.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyOrder .

ind:assemblyOsatVendorId rdf:type rdf:Property ;
    rdfs:label 'Assembly Osat Vendor Id' ;
    rdfs:comment 'FK to packaging.osat_vendor.osat_vendor_id — Each lot is processed at a specific OSAT site. Required for site-level yield analysis and capacity tracking.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OsatVendor .

ind:customerOrderId rdf:type rdf:Property ;
    rdfs:label 'Customer Order Id' ;
    rdfs:comment 'External order number from the customer that triggered this assembly lot.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:lotManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lot Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Lot manager is recorded for WIP ownership, yield accountability, and shift hand-over documentation.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:packagingLineId rdf:type rdf:Property ;
    rdfs:label 'Packaging Line Id' ;
    rdfs:comment 'Foreign key linking to packaging.packaging_line. Business justification: An assembly lot is processed on a specific packaging line; linking the lot to the line provides traceability of line usage for yield and defect analysis.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingLine .

ind:primaryAssemblyOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Assembly Order Id' ;
    rdfs:comment 'FK to packaging.assembly_order.assembly_order_id — Assembly lots are created under an assembly order. This is the primary parent-child relationship for WIP tracking.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyOrder .

ind:assemblySite rdf:type rdf:Property ;
    rdfs:label 'Assembly Site' ;
    rdfs:comment 'Name of the OSAT vendor or internal fab where the lot is assembled.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
    rdfs:comment 'Estimated monetary cost of assembling the lot, expressed in US dollars.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Cumulative Yield Percent' ;
    rdfs:comment 'Overall percentage of good dies produced from the lot after each process step.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectDensity rdf:type rdf:Property ;
    rdfs:label 'Defect Density' ;
    rdfs:comment 'Number of defects per unit area (e.g., defects per cm²) observed on the lot.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieCount rdf:type rdf:Property ;
    rdfs:label 'Die Count' ;
    rdfs:comment 'Total number of individual dies contained in the assembly lot.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionFailCount rdf:type rdf:Property ;
    rdfs:label 'Inspection Fail Count' ;
    rdfs:comment 'Number of inspection points that failed during the latest quality check.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionPassCount rdf:type rdf:Property ;
    rdfs:label 'Inspection Pass Count' ;
    rdfs:comment 'Number of inspection points that passed during the latest quality check.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotName rdf:type rdf:Property ;
    rdfs:label 'Lot Name' ;
    rdfs:comment 'Human-readable name or label for the assembly lot, often used in reports and dashboards.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotPackageType rdf:type rdf:Property ;
    rdfs:label 'Lot Package Type' ;
    rdfs:comment 'FK to packaging.packaging_package_type.packaging_package_type_id — Each assembly lot is for a specific package type. Required for WIP reporting and routing.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotToOrder rdf:type rdf:Property ;
    rdfs:label 'Lot To Order' ;
    rdfs:comment 'FK to packaging.pkg_assembly_order.pkg_assembly_order_id — Assembly lots are created against assembly orders. This is the fundamental WIP-to-order traceability link.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageVersion rdf:type rdf:Property ;
    rdfs:label 'Package Version' ;
    rdfs:comment 'Version or revision identifier of the package design used for this lot.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Result of the most recent quality inspection for the lot.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyPackageTypeId rdf:type rdf:Property ;
    rdfs:label 'Assembly Package Type Id' ;
    rdfs:comment 'FK to packaging.package_type.package_type_id — Every assembly order specifies a package type. This FK is essential for filtering orders by package format, capacity planning, and routing to qualified OSAT sites.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:assemblyPackagingPackageTypeId rdf:type rdf:Property ;
    rdfs:label 'Assembly Packaging Package Type Id' ;
    rdfs:comment 'FK to packaging.package_type' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:orderOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Order Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sales order assignment to a sales rep is used in order-to-cash reporting and commission calculations.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryAssemblyProcessFlowId rdf:type rdf:Property ;
    rdfs:label 'Primary Assembly Process Flow Id' ;
    rdfs:comment 'FK to packaging.assembly_process_flow.assembly_process_flow_id — Each assembly order executes against a specific process flow revision. Required for traceability and change control.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyProcessFlow .

ind:substrateLotId rdf:type rdf:Property ;
    rdfs:label 'Substrate Lot Id' ;
    rdfs:comment 'Identifier of the substrate lot used in the packaging process.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialLot .

ind:actualYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Percent' ;
    rdfs:comment 'Yield percentage achieved after assembly completion.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assemblyOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Assembly Order Status' ;
    rdfs:comment 'Current lifecycle state of the assembly order.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyOsatVendorFk rdf:type rdf:Property ;
    rdfs:label 'Assembly Osat Vendor Fk' ;
    rdfs:comment 'FK to packaging.osat_vendor.osat_vendor_id — Assembly orders are issued to a specific OSAT vendor or internal site. This FK is essential for OSAT capacity planning, scorecard reporting, and order routing.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Adjustment Amount' ;
    rdfs:comment 'Any cost adjustments (e.g., discounts, fees) applied to the gross amount.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Gross Amount' ;
    rdfs:comment 'Estimated total cost before any adjustments.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costNetAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Net Amount' ;
    rdfs:comment 'Final cost after adjustments, representing the amount to be billed.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Placed Timestamp' ;
    rdfs:comment 'Timestamp when the assembly order was initially placed.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Number of die units requested for assembly.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Any additional instructions required for the assembly (e.g., cleanroom level, moisture sensitivity).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetShipDate rdf:type rdf:Property ;
    rdfs:label 'Target Ship Date' ;
    rdfs:comment 'Planned date for shipment of the completed assembly.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assemblyProcessFlowDescription rdf:type rdf:Property ;
    rdfs:label 'Assembly Process Flow Description' ;
    rdfs:comment 'Detailed free-text description of the flow, its purpose, and scope.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyProcessFlowStatus rdf:type rdf:Property ;
    rdfs:label 'Assembly Process Flow Status' ;
    rdfs:comment 'Current lifecycle status of the flow definition.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondType rdf:type rdf:Property ;
    rdfs:label 'Bond Type' ;
    rdfs:comment 'Primary interconnect technology employed in the flow.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Regulatory or industry standard that this flow must satisfy.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmConstraints rdf:type rdf:Property ;
    rdfs:label 'Dfm Constraints' ;
    rdfs:comment 'Free-text list of DFM rules or constraints that must be obeyed for this flow.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieAttachMethod rdf:type rdf:Property ;
    rdfs:label 'Die Attach Method' ;
    rdfs:comment 'Method used to attach the die to the substrate.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalInspectionType rdf:type rdf:Property ;
    rdfs:label 'Final Inspection Type' ;
    rdfs:comment 'Primary inspection technique performed after assembly completion.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowToPackageType rdf:type rdf:Property ;
    rdfs:label 'Flow To Package Type' ;
    rdfs:comment 'FK to packaging.packaging_package_type.packaging_package_type_id — Process flows are defined per package type. A package type may have multiple flow revisions but each flow targets a specific package format.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDefaultFlow rdf:type rdf:Property ;
    rdfs:label 'Is Default Flow' ;
    rdfs:comment 'Flag indicating whether this flow is the default for its package type.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markingMethod rdf:type rdf:Property ;
    rdfs:label 'Marking Method' ;
    rdfs:comment 'Method used to apply identification marks to the finished package.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moldingMaterial rdf:type rdf:Property ;
    rdfs:label 'Molding Material' ;
    rdfs:comment 'Encapsulation material applied during the molding step.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTimeTarget rdf:type rdf:Property ;
    rdfs:label 'Process Time Target' ;
    rdfs:comment 'Target total processing time for the flow, expressed in minutes.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processYieldTarget rdf:type rdf:Property ;
    rdfs:label 'Process Yield Target' ;
    rdfs:comment 'Target yield percentage for the flow (e.g., 98.75).' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:singulationMethod rdf:type rdf:Property ;
    rdfs:label 'Singulation Method' ;
    rdfs:comment 'Technique used to separate individual packages from the wafer or panel.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCount rdf:type rdf:Property ;
    rdfs:label 'Step Count' ;
    rdfs:comment 'Total count of discrete steps defined in the flow.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:underfillMaterial rdf:type rdf:Property ;
    rdfs:label 'Underfill Material' ;
    rdfs:comment 'Material used to fill the gap between die and substrate after bonding.' ;
    rdfs:domain ind:AssemblyProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyStepRecordId rdf:type rdf:Property ;
    rdfs:label 'Assembly Step Record Id' ;
    rdfs:comment 'System-generated unique identifier for each assembly step execution record.' ;
    rdfs:domain ind:AssemblyStepRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assemblyStepRecordLotFk rdf:type rdf:Property ;
    rdfs:label 'Assembly Step Record Lot Fk' ;
    rdfs:comment 'FK to packaging.assembly_lot.assembly_lot_id — Every step execution record references the lot being processed. This is the core traceability link from step-level data to lot identity.' ;
    rdfs:domain ind:AssemblyStepRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forceN rdf:type rdf:Property ;
    rdfs:label 'Force N' ;
    rdfs:comment 'Force applied (e.g., during die attach or bonding) expressed in newtons.' ;
    rdfs:domain ind:AssemblyStepRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPass rdf:type rdf:Property ;
    rdfs:label 'Is Pass' ;
    rdfs:comment 'True if the step passed all quality criteria; false otherwise.' ;
    rdfs:domain ind:AssemblyStepRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialQuantity rdf:type rdf:Property ;
    rdfs:label 'Material Quantity' ;
    rdfs:comment 'Quantity of material used in the step, expressed in the unit of measure defined for the material (e.g., grams, milliliters).' ;
