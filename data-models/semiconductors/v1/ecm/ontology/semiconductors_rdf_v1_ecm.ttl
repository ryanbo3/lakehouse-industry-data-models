    rdfs:range xsd:string .

ind:talentAcquisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Talent Acquisition Status' ;
    rdfs:comment 'Current lifecycle status of the requisition.' ;
    rdfs:domain ind:TalentAcquisition ;
