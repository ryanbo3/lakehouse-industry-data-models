    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterProfile rdf:type rdf:Property ;
    rdfs:label 'Parameter Profile' ;
    rdfs:comment 'JSON-encoded set of detailed process parameters (ramp rates, dwell times, etc.) captured for the step.' ;
    rdfs:domain ind:AssemblyStepRecord ;
    rdf:type owl:DatatypeProperty ;
