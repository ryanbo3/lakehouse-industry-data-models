ind:parametricAgainstLimit rdf:type rdf:Property ;
    rdfs:label 'Parametric Against Limit' ;
    rdfs:comment 'FK to test.test_limit.test_limit_id — Each parametric measurement is evaluated against a test limit specification. Required for pass/fail determination and SPC.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parametricCheckedAgainstLimit rdf:type rdf:Property ;
    rdfs:label 'Parametric Checked Against Limit' ;
    rdfs:comment 'FK to test.test_limit.test_limit_id — Each parametric measurement is evaluated against a test limit. This FK enables limit-vs-actual analysis and SPC trending.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testParameterName rdf:type rdf:Property ;
    rdfs:label 'Test Parameter Name' ;
    rdfs:comment 'Name of the specific parametric test parameter (e.g., Vth, Idsat).' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardName rdf:type rdf:Property ;
    rdfs:label 'Card Name' ;
    rdfs:comment 'Human-readable name of the probe card used for identification in test engineering.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costUsd rdf:type rdf:Property ;
