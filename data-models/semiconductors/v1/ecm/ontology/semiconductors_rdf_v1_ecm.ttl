    rdfs:range xsd:string .

ind:dppmActual rdf:type rdf:Property ;
    rdfs:label 'Dppm Actual' ;
    rdfs:comment 'Measured DPPM observed during qualification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'Outcome after program completion indicating product release eligibility.' ;
    rdfs:domain ind:QualityQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kgdCertificationRequired rdf:type rdf:Property ;
