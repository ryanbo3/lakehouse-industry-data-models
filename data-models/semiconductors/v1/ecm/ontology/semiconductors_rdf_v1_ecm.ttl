    rdfs:range ind:Account .

ind:primaryAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Id' ;
    rdfs:comment 'FK to customer.account.account_id — The parent_account_id in account_hierarchy must reference the account product. Without this FK, hierarchy records are orphaned.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:accountHierarchyDescription rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Description' ;
    rdfs:comment 'Free-text notes providing additional context about the parent-child relationship.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Status' ;
    rdfs:comment 'Current operational status of the hierarchy link.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of the child account within the corporate hierarchy (1 = top-level).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'True if the child account is the primary entity under the parent; otherwise false.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classification of the hierarchical relationship between parent and child accounts.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTeamId rdf:type rdf:Property ;
    rdfs:label 'Account Team Id' ;
    rdfs:comment 'Unique surrogate key for each account team assignment record.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the assignment (e.g., active, inactive, pending, terminated).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRegion rdf:type rdf:Property ;
    rdfs:label 'Coverage Region' ;
