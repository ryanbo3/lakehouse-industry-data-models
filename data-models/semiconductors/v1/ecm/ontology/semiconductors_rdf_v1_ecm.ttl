    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProhibitedInEu rdf:type rdf:Property ;
    rdfs:label 'Is Prohibited In Eu' ;
    rdfs:comment 'True if the substance is prohibited for use in the European Union.' ;
    rdfs:domain ind:SubstanceInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProhibitedInUs rdf:type rdf:Property ;
    rdfs:label 'Is Prohibited In Us' ;
    rdfs:comment 'True if the substance is prohibited for use in the United States.' ;
    rdfs:domain ind:SubstanceInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProp65 rdf:type rdf:Property ;
    rdfs:label 'Is Prop65' ;
    rdfs:comment 'True if the substance is listed under California Proposition 65.' ;
    rdfs:domain ind:SubstanceInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReachSvhc rdf:type rdf:Property ;
    rdfs:label 'Is Reach Svhc' ;
    rdfs:comment 'True if the substance is listed on the REACH SVHC list.' ;
    rdfs:domain ind:SubstanceInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRohsRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Rohs Restricted' ;
    rdfs:comment 'True if the substance is restricted under the EU RoHS directive.' ;
    rdfs:domain ind:SubstanceInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTscaActive rdf:type rdf:Property ;
    rdfs:label 'Is Tsca Active' ;
    rdfs:comment 'True if the substance appears in the US TSCA Active Inventory.' ;
    rdfs:domain ind:SubstanceInventory ;
