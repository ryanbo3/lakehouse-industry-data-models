ind:controlPlanId rdf:type rdf:Property ;
    rdfs:label 'Control Plan Id' ;
    rdfs:comment 'Identifier of the control plan that defines the SPC parameters for this chart.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
