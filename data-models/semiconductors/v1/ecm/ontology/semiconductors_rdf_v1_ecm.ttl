    rdfs:comment 'Reference identifier for the corrective action plan associated with this scorecard.' ;
    rdfs:domain ind:SupplierQualityScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiCostOfPoorQuality rdf:type rdf:Property ;
    rdfs:label 'Kpi Cost Of Poor Quality' ;
    rdfs:comment 'Monetary cost associated with defects, rework, and warranty claims for the period.' ;
    rdfs:domain ind:SupplierQualityScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiDeliveryConformance rdf:type rdf:Property ;
    rdfs:label 'Kpi Delivery Conformance' ;
    rdfs:comment 'Percentage of deliveries that meet agreed-upon quality criteria.' ;
    rdfs:domain ind:SupplierQualityScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiIncomingQualityRate rdf:type rdf:Property ;
