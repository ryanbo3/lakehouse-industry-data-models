    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binSortOrder rdf:type rdf:Property ;
    rdfs:label 'Bin Sort Order' ;
    rdfs:comment 'Display order for bins in reports and UI.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionRule rdf:type rdf:Property ;
    rdfs:label 'Disposition Rule' ;
    rdfs:comment 'Action to be taken for devices falling into this bin.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterSet rdf:type rdf:Property ;
    rdfs:label 'Parameter Set' ;
    rdfs:comment 'Set of parametric test parameters associated with the bin.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testLevel rdf:type rdf:Property ;
    rdfs:label 'Test Level' ;
    rdfs:comment 'Stage of testing where the bin is applied.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldImpactClassification rdf:type rdf:Property ;
    rdfs:label 'Yield Impact Classification' ;
    rdfs:comment 'Indicates how the bin affects overall wafer or lot yield.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correlationCoefficient rdf:type rdf:Property ;
    rdfs:label 'Correlation Coefficient' ;
    rdfs:comment 'Numeric coefficient (e.g., Pearson r) representing strength of correlation for each parameter.' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correlationMethodology rdf:type rdf:Property ;
    rdfs:label 'Correlation Methodology' ;
    rdfs:comment 'Statistical or analytical method used to derive the correlation.' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correlationStudyStatus rdf:type rdf:Property ;
    rdfs:label 'Correlation Study Status' ;
    rdfs:comment 'Current lifecycle status of the study.' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpkImpact rdf:type rdf:Property ;
    rdfs:label 'Cpk Impact' ;
    rdfs:comment 'Impact on process capability index (Cpk) resulting from the correlation adjustment.' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guardBandRecommendation rdf:type rdf:Property ;
    rdfs:label 'Guard Band Recommendation' ;
    rdfs:comment 'Suggested guard-band values for test limits based on study findings.' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insertionPair rdf:type rdf:Property ;
    rdfs:label 'Insertion Pair' ;
    rdfs:comment 'Description of the two test insertions being correlated (e.g., wafer-probe vs final-test).' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'External business code or identifier assigned to the study (e.g., SOP-CS-2024-001).' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'Human-readable name of the study used for reporting and search.' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Classification of the study methodology: parametric, functional, or combined.' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systematicOffset rdf:type rdf:Property ;
    rdfs:label 'Systematic Offset' ;
    rdfs:comment 'Measured systematic offset between the two test insertions.' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testPlatform rdf:type rdf:Property ;
    rdfs:label 'Test Platform' ;
    rdfs:comment 'Name or identifier of the ATE platform used (e.g., Advantest V93000).' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSite rdf:type rdf:Property ;
    rdfs:label 'Test Site' ;
    rdfs:comment 'Physical location or fab where the test was performed.' ;
    rdfs:domain ind:CorrelationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalTestProgramId rdf:type rdf:Property ;
    rdfs:label 'Final Test Program Id' ;
    rdfs:comment 'Foreign key linking to test.test_program. Business justification: Final test runs are generated by a specific test program; add FK to capture this relationship.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestProgram .

ind:ateName rdf:type rdf:Property ;
    rdfs:label 'Ate Name' ;
    rdfs:comment 'Name or model of the ATE system executing the test.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binDistribution rdf:type rdf:Property ;
    rdfs:label 'Bin Distribution' ;
    rdfs:comment 'Compact representation of test bin counts (e.g., JSON or delimited string).' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bootSuccessCount rdf:type rdf:Property ;
    rdfs:label 'Boot Success Count' ;
    rdfs:comment 'Number of devices that successfully booted during SLT.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failCount rdf:type rdf:Property ;
    rdfs:label 'Fail Count' ;
    rdfs:comment 'Number of devices that failed one or more test criteria.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalTestRunStatus rdf:type rdf:Property ;
    rdfs:label 'Final Test Run Status' ;
    rdfs:comment 'Current lifecycle status of the test run.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerName rdf:type rdf:Property ;
    rdfs:label 'Handler Name' ;
    rdfs:comment 'Identifier of the handler module that loads devices into the ATE.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parametricTestFail rdf:type rdf:Property ;
    rdfs:label 'Parametric Test Fail' ;
    rdfs:comment 'Count of parametric test points that failed.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parametricTestPass rdf:type rdf:Property ;
    rdfs:label 'Parametric Test Pass' ;
    rdfs:comment 'Count of parametric test points that passed.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passCount rdf:type rdf:Property ;
    rdfs:label 'Pass Count' ;
    rdfs:comment 'Number of devices that passed all test criteria.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sltBoardCode rdf:type rdf:Property ;
    rdfs:label 'Slt Board Code' ;
    rdfs:comment 'Identifier of the board used for system-level testing, if applicable.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socketCode rdf:type rdf:Property ;
    rdfs:label 'Socket Code' ;
    rdfs:comment 'Identifier of the socket used to hold the device during testing.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testShift rdf:type rdf:Property ;
    rdfs:label 'Test Shift' ;
    rdfs:comment 'Work shift during which the test run was executed.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSites rdf:type rdf:Property ;
    rdfs:label 'Total Sites' ;
    rdfs:comment 'Number of parallel test sites active on the ATE for this run.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parametricMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Parametric Measurement Id' ;
    rdfs:comment 'Unique surrogate key for each parametric measurement record.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieWaferId rdf:type rdf:Property ;
    rdfs:label 'Die Wafer Id' ;
    rdfs:comment 'Identifier of the individual die on which the measurement was performed.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wafer .

ind:parametricReviewUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Parametric Review User Employee Id' ;
    rdfs:comment 'Identifier of the user who performed the review.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryParametricEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Parametric Employee Id' ;
    rdfs:comment 'Identifier of the human operator overseeing the test run.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:testResultId rdf:type rdf:Property ;
    rdfs:label 'Test Result Id' ;
    rdfs:comment 'Identifier linking to the overall test result set for the die.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitTestResult .

ind:testStepId rdf:type rdf:Property ;
    rdfs:label 'Test Step Id' ;
    rdfs:comment 'Identifier of the specific test step within the program.' ;
