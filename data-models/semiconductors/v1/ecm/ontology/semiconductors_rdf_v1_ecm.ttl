ind:customerPackageTypeId rdf:type rdf:Property ;
    rdfs:label 'Customer Package Type Id' ;
    rdfs:comment 'FK to packaging.package_type.package_type_id — Customer requirements specify required package types. Required for design-win to assembly execution linkage.' ;
    rdfs:domain ind:CustomerRequirement ;
