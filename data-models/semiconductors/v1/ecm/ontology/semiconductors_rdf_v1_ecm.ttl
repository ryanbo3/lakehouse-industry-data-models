ind:tier2RatePercent rdf:type rdf:Property ;
    rdfs:label 'Tier2 Rate Percent' ;
    rdfs:comment 'Rebate percentage applied to revenue/units that fall within tier 2.' ;
    rdfs:domain ind:RebateProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2ThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tier2 Threshold Amount' ;
    rdfs:comment 'Minimum revenue or unit volume required to reach tier 2.' ;
    rdfs:domain ind:RebateProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesDesignRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Sales Design Registration Id' ;
    rdfs:comment 'Unique system-generated identifier for each design registration transaction.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySalesAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Account Id' ;
    rdfs:comment 'Unique identifier of the customer organization linked to the registration.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primarySalesChannelPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Channel Partner Id' ;
    rdfs:comment 'Unique identifier of the distributor or channel partner.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelPartner .

ind:primarySalesIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Ic Design Project Id' ;
    rdfs:comment 'Reference to the underlying IC design or IP core.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:salesChannelPartnerId rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Partner Id' ;
    rdfs:comment 'FK to sales.channel_partner.channel_partner_id — Design registrations are submitted BY channel partners to claim credit. The partner identity is essential for registration validation and conflict resolution.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelPartner .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Additional remarks or justification provided by the approver.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Unique internal identifier for the design-win claim.' ;
    rdfs:domain ind:SalesDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceItar rdf:type rdf:Property ;
    rdfs:label 'Compliance Itar' ;
    rdfs:comment 'True if the registration is governed by International Traffic in Arms Regulations.' ;
    rdfs:domain ind:SalesDesignRegistration ;
