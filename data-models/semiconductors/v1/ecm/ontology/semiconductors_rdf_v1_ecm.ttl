    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerSource rdf:type rdf:Property ;
    rdfs:label 'Trigger Source' ;
    rdfs:comment 'Origin that caused the maintenance event to be created.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeType rdf:type rdf:Property ;
    rdfs:label 'Upgrade Type' ;
    rdfs:comment 'Indicates whether the event involved a hardware, software, or firmware upgrade.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metrologyRunId rdf:type rdf:Property ;
    rdfs:label 'Metrology Run Id' ;
    rdfs:comment 'Unique surrogate key for each metrology run record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetrologyRun .

ind:metrologyFabToolId rdf:type rdf:Property ;
    rdfs:label 'Metrology Fab Tool Id' ;
    rdfs:comment 'Surrogate key of the equipment asset that performed the metrology run.' ;
