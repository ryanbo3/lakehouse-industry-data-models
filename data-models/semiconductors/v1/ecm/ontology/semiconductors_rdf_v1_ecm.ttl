    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:contactAccountId rdf:type rdf:Property ;
    rdfs:label 'Contact Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Connect contact to its parent customer account for hierarchy and reporting.' ;
