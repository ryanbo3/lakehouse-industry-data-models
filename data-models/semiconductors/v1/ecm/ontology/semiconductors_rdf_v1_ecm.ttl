    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burnInBoardCode rdf:type rdf:Property ;
    rdfs:label 'Burn In Board Code' ;
    rdfs:comment 'Identifier of the burn-in board or fixture used for the test.' ;
