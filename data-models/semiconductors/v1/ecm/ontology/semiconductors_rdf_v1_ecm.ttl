    rdfs:range xsd:boolean .

ind:physicalState rdf:type rdf:Property ;
    rdfs:label 'Physical State' ;
    rdfs:comment 'Physical state of the substance at standard conditions.' ;
    rdfs:domain ind:SubstanceInventory ;
