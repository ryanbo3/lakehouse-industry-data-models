ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Indicates whether the transaction should be eliminated during financial consolidation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercoToSendingCompany rdf:type rdf:Property ;
    rdfs:label 'Interco To Sending Company' ;
    rdfs:comment 'FK to finance.company_code.company_code_id — Intercompany transactions must identify sending and receiving company codes. Required for elimination and transfer pricing compliance.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intercompanyTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Description' ;
    rdfs:comment 'Free-text description of the transaction purpose or notes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionStatus rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingEntityCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Entity Code' ;
    rdfs:comment 'Company code or legal entity identifier of the receiver in the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'True if the transaction must be included in country-by-country (CbC) reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sendingEntityCode rdf:type rdf:Property ;
    rdfs:label 'Sending Entity Code' ;
    rdfs:comment 'Company code or legal entity identifier of the sender in the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business-visible transaction number assigned by the source ERP system.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the intercompany transaction was recorded in the source system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Category of the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Document Ref' ;
    rdfs:comment 'Reference identifier to the supporting OECD transfer-pricing documentation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMargin rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Margin' ;
    rdfs:comment 'Margin applied when the cost-plus method is used, expressed as a percentage.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'Method used to determine the arm\'s-length price for the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingRate rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Rate' ;
    rdfs:comment 'Rate (percentage or per-unit) applied under the selected transfer pricing method.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Internal Cost Center Id' ;
    rdfs:comment 'Identifier of the cost center responsible for the order\'s expenses.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:toCostCenterId rdf:type rdf:Property ;
    rdfs:label 'To Cost Center Id' ;
    rdfs:comment 'FK to finance.cost_center.cost_center_id — Internal orders are assigned to responsible cost centers for settlement and organizational reporting.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Total actual cost incurred against the internal order to date.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditorApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Auditor Approval Date' ;
    rdfs:comment 'Date on which the auditor provided approval for capitalization.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Auditor Approval Flag' ;
    rdfs:comment 'Indicates whether the internal order has been approved by the external auditor for capitalization.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalizationEligibility rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligibility' ;
    rdfs:comment 'Indicates whether the order meets criteria for R&D cost capitalization.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'Committed cost amount that cannot be exceeded without re-approval.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when the order reached technically complete status.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Internal Order Description' ;
    rdfs:comment 'Free-text description of the purpose and scope of the internal order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Internal Order Status' ;
    rdfs:comment 'Current lifecycle state of the internal order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastStatusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Status Change Timestamp' ;
    rdfs:comment 'Timestamp of the most recent status transition for the order.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net amount after any adjustments, taxes, or discounts applied to the order.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Created Timestamp' ;
    rdfs:comment 'Timestamp when the internal order was initially created in the source system.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business-visible identifier assigned to the internal order.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the order purpose (e.g., research & development, equipment maintenance, non-recurring engineering).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realIndicator rdf:type rdf:Property ;
    rdfs:label 'Real Indicator' ;
    rdfs:comment 'True if the order records real, incurred costs.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'Rule that determines how costs are settled (to an asset, cost center, or WBS element).' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalIndicator rdf:type rdf:Property ;
    rdfs:label 'Statistical Indicator' ;
    rdfs:comment 'True if the order is used for statistical cost allocation rather than actual cost tracking.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toCostCenter rdf:type rdf:Property ;
    rdfs:label 'To Cost Center' ;
    rdfs:comment 'FK to finance.cost_center.cost_center_id — Internal orders have a responsible cost center for settlement and organizational assignment. Required for cost collection and settlement processing.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trl rdf:type rdf:Property ;
    rdfs:label 'Trl' ;
    rdfs:comment 'Readiness level of the technology (1-9) at the time of order creation.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Work Breakdown Structure element code to which the order costs are assigned.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountBase rdf:type rdf:Property ;
    rdfs:label 'Amount Base' ;
    rdfs:comment 'Total amount of the entry converted to the corporate group currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocal rdf:type rdf:Property ;
    rdfs:label 'Amount Local' ;
    rdfs:comment 'Total amount of the entry in the document\'s currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Fixed-asset identifier for depreciation or acquisition postings.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'Higher-level grouping of profit centers for reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Organizational unit identifier for legal entity reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'Group identifier for consolidation adjustments.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the line is a debit or credit.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'External business identifier for the journal entry document.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Category of the financial document (e.g., vendor invoice, intercompany).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Functional area code for internal reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'True if the entry is part of an intercompany transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Description' ;
    rdfs:comment 'Free-text description of the journal entry purpose.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerAccount rdf:type rdf:Property ;
    rdfs:label 'Ledger Account' ;
    rdfs:comment 'General Ledger account number associated with the entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the accounting period for the entry.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'SAP posting key that determines debit/credit logic.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current processing status of the journal entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Exact date and time when the entry was posted to the ledger.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'Document number of the original entry being referenced.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date on which the reversal was posted.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Market or product segment for analytical reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line record.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingId rdf:type rdf:Property ;
    rdfs:label 'Booking Id' ;
    rdfs:comment 'Foreign key linking to sales.booking. Business justification: Revenue recognition report requires each journal entry line to map to its originating sales booking for reconciliation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Booking .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Foreign key linking to order.order_line. Business justification: Line-level journal entries need the order line ID to allocate revenue and cost precisely per SKU.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:primaryJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Entry Id' ;
    rdfs:comment 'Identifier of the parent journal entry header to which this line belongs.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:toJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'To Journal Entry Id' ;
    rdfs:comment 'FK to finance.journal_entry.journal_entry_id — Fundamental header-line relationship. Every journal entry line must reference its parent journal entry document. This is the most critical FK in the entire domain - without it, line items are orphaned' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:amountDocumentCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Document Currency' ;
    rdfs:comment 'Monetary amount of the line expressed in the document\'s currency.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'Monetary amount of the line converted to the company\'s local currency.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'User-defined field for additional cost allocation or tagging.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-text description of the line item.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential number of the line within the journal entry.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current processing status of the line.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toJournalEntry rdf:type rdf:Property ;
    rdfs:label 'To Journal Entry' ;
    rdfs:comment 'FK to finance.journal_entry.journal_entry_id — Header-line relationship is the most fundamental FK in any GL system. Every line item must reference its parent journal entry document. Without this, you cannot reconstruct a balanced journal entry.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeNreMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Finance Nre Milestone Id' ;
    rdfs:comment 'Unique identifier for the NRE milestone record.' ;
    rdfs:domain ind:FinanceNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFinanceNreAgreementId rdf:type rdf:Property ;
    rdfs:label 'Primary Finance Nre Agreement Id' ;
    rdfs:comment 'Identifier of the NRE agreement to which this milestone belongs.' ;
    rdfs:domain ind:FinanceNreMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceNreAgreement .

ind:billingTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Billing Trigger Event' ;
    rdfs:comment 'Event that triggers billing for the milestone.' ;
    rdfs:domain ind:FinanceNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseType rdf:type rdf:Property ;
    rdfs:label 'Expense Type' ;
    rdfs:comment 'Classification of the expense for accounting purposes.' ;
    rdfs:domain ind:FinanceNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeNreMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Finance Nre Milestone Status' ;
    rdfs:comment 'Current lifecycle status of the milestone.' ;
    rdfs:domain ind:FinanceNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current status of the invoice associated with the milestone.' ;
    rdfs:domain ind:FinanceNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRevenueRecognized rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Recognized' ;
    rdfs:comment 'Indicates whether revenue has been recognized for this milestone.' ;
    rdfs:domain ind:FinanceNreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue is recognized for the milestone per ASC 606.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Identifier of the immediate parent profit center in the hierarchy.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:actualSpend rdf:type rdf:Property ;
    rdfs:label 'Actual Spend' ;
    rdfs:comment 'Actual expenditures recorded against the profit center.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPercent rdf:type rdf:Property ;
    rdfs:label 'Allocation Percent' ;
    rdfs:comment 'Percentage of corporate overhead allocated to this profit center.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'ISO 4217 currency code of the budget amount, e.g., USD.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'Method used to allocate costs to the profit center.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabLocation rdf:type rdf:Property ;
    rdfs:label 'Fab Location' ;
    rdfs:comment 'Fabrication facility location associated with the profit center.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsolidated rdf:type rdf:Property ;
    rdfs:label 'Is Consolidated' ;
    rdfs:comment 'Indicates whether the profit center is included in corporate consolidation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Product family or line that the profit center supports.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Profit Center Category' ;
    rdfs:comment 'High-level category used for reporting and analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Free-form description providing context and business purpose.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Profit Center Group' ;
    rdfs:comment 'Higher-level grouping of profit centers for consolidated reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Human-readable name of the profit center, e.g., "Advanced Logic ASICs".' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current operational status of the profit center.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Category that defines the nature of the profit center.' ;
    rdfs:domain ind:ProfitCenter ;
