    rdfs:range xsd:integer .

ind:spcToSpec rdf:type rdf:Property ;
    rdfs:label 'Spc To Spec' ;
    rdfs:comment 'FK to quality.spec.spec_id — SPC control limits are derived from product/process specifications. The spec product defines the acceptance criteria that SPC monitors against. This link is essential for automated OOC detection.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierQualityScorecardId rdf:type rdf:Property ;
