    rdfs:range xsd:integer .

ind:estimatedFinancialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Amount' ;
    rdfs:comment 'Monetary estimate of the financial loss caused by the disruption.' ;
    rdfs:domain ind:DisruptionEvent ;
