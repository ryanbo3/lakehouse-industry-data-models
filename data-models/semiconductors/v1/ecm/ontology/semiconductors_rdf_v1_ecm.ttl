    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'End date of the period over which qualifying sales are measured.' ;
