    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isManual rdf:type rdf:Property ;
    rdfs:label 'Is Manual' ;
    rdfs:comment 'Indicates whether the screening was performed manually (True) or automatically (False).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchResult rdf:type rdf:Property ;
    rdfs:label 'Match Result' ;
    rdfs:comment 'Outcome of the screening indicating whether the party is clear, a potential match, or a confirmed match.' ;
    rdfs:domain ind:RestrictedPartyScreening ;
    rdf:type owl:DatatypeProperty ;
