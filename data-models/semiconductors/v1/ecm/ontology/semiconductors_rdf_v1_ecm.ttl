ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Label of the shift (e.g., A, B, C, D) during which the OEE data was collected.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateCurrent rdf:type rdf:Property ;
    rdfs:label 'State Current' ;
    rdfs:comment 'Equipment state at the end of the measurement period.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateLastChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'State Last Change Timestamp' ;
    rdfs:comment 'Timestamp of the most recent state transition within the period.' ;
    rdfs:domain ind:OeeRecord ;
