ind:substanceInventoryName rdf:type rdf:Property ;
    rdfs:label 'Substance Inventory Name' ;
    rdfs:comment 'Human-readable name of the chemical substance.' ;
    rdfs:domain ind:SubstanceInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceType rdf:type rdf:Property ;
    rdfs:label 'Substance Type' ;
    rdfs:comment 'Category of the substance (e.g., precursor, slurry, photoresist, etchant, dopant, carrier gas, solvent, polymer). [ENUM-REF-CANDIDATE: precursor|slurry|photoresist|etchant|dopant|carrier_gas|solvent|polymer — promote to reference product]' ;
    rdfs:domain ind:SubstanceInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyControlPlanId rdf:type rdf:Property ;
    rdfs:label 'Technology Control Plan Id' ;
    rdfs:comment 'Unique system-generated identifier for the Technology Control Plan.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnologyControlPlan .

ind:authorizedPersonnelEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorized Personnel Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Technology Control Plans list employees authorized to access controlled technology for security compliance.' ;
    rdfs:domain ind:TechnologyControlPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fabricationTechnologyNodeId rdf:type rdf:Property ;
    rdfs:label 'Fabrication Technology Node Id' ;
    rdfs:comment 'Foreign key linking to fabrication.technology_node. Business justification: Technology Control Plans are defined per technology node to ensure export/ITAR compliance; the plan must reference the specific node used in fab.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationTechnologyNode .

ind:processNodeId rdf:type rdf:Property ;
    rdfs:label 'Process Node Id' ;
    rdfs:comment 'Foreign key linking to product.process_node. Business justification: Technology Control Plans are defined per process node; linking ensures the plan applies to the correct manufacturing node.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessNode .

ind:technologyEccnClassificationId rdf:type rdf:Property ;
    rdfs:label 'Technology Eccn Classification Id' ;
    rdfs:comment 'Foreign key linking to compliance.eccn_classification. Business justification: Technology control plan references an ECCN; FK avoids duplication of ECCN data.' ;
    rdfs:domain ind:TechnologyControlPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EccnClassification .

ind:accessControlMeasures rdf:type rdf:Property ;
