    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disruptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Disruption End Date' ;
    rdfs:comment 'Date when the disruption was resolved or ended.' ;
