    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Categorical code indicating the type of packaging operation performed in this step (e.g., die attach, wire bonding).' ;
