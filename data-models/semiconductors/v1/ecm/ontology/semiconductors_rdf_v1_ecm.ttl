    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:needleReplacements rdf:type rdf:Property ;
    rdfs:label 'Needle Replacements' ;
    rdfs:comment 'Cumulative number of needle replacement events performed on the card.' ;
