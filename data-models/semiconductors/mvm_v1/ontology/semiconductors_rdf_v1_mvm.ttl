ind:forecastAccuracy rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy' ;
    rdfs:comment 'Percentage indicating forecast accuracy of the revenue estimate.' ;
    rdfs:domain ind:SalesDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedRampRatePerMonth rdf:type rdf:Property ;
    rdfs:label 'Forecasted Ramp Rate Per Month' ;
    rdfs:comment 'Projected increase in unit volume per month during the ramp period.' ;
