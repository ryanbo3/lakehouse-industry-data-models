ind:complianceRegulation rdf:type rdf:Property ;
    rdfs:label 'Compliance Regulation' ;
    rdfs:comment 'Regulatory framework applicable to the design win. [ENUM-REF-CANDIDATE: ITAR|EAR|RoHS|REACH|ISO9001|ISO14001|ISO45001 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Length of the contract in months.' ;
    rdfs:domain ind:SalesDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designWinNumber rdf:type rdf:Property ;
    rdfs:label 'Design Win Number' ;
    rdfs:comment 'Unique business identifier for the design win record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacedCompetitorCode rdf:type rdf:Property ;
    rdfs:label 'Displaced Competitor Code' ;
    rdfs:comment 'Identifier of the competitor whose device was displaced.' ;
