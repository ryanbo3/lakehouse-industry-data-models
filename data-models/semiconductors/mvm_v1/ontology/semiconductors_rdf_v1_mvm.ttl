    rdfs:comment 'Identifier of the material (part number) for which the forecast is generated.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primarySupplySupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Supply Supplier Id' ;
    rdfs:comment 'Identifier of the strategic supplier receiving the forecast.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:supplyMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Supply Material Master Id' ;
    rdfs:comment 'FK to supply.material_master.material_master_id — Forecasts specify quantities for specific materials.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:supplySupplierId rdf:type rdf:Property ;
    rdfs:label 'Supply Supplier Id' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — Purchase forecasts are communicated TO specific suppliers for capacity planning.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:forecastSource rdf:type rdf:Property ;
    rdfs:label 'Forecast Source' ;
    rdfs:comment 'Name of the ERP or planning system (e.g., SAP S/4HANA MM) that produced the forecast record.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Lifecycle state of the forecast (e.g., draft, released to supplier, approved, or rejected).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Specifies if the forecast quantity is a firm commitment (firm) or an indicative estimate (indicative).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:horizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Horizon End Date' ;
    rdfs:comment 'Last calendar date covered by the forecast horizon.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:horizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Horizon Start Date' ;
    rdfs:comment 'First calendar date covered by the forecast horizon.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isLtb rdf:type rdf:Property ;
    rdfs:label 'Is Ltb' ;
    rdfs:comment 'True if the forecast is used for planning a final purchase of an end-of-life material.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:period rdf:type rdf:Property ;
    rdfs:label 'Period' ;
    rdfs:comment 'Defines whether the forecast is expressed per week or per month.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit' ;
    rdfs:comment 'Estimated cost per unit of material for the forecast horizon.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorForecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Prior Forecast Quantity' ;
    rdfs:comment 'Forecast quantity from the immediately preceding version, used for variance calculations.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyMaterialFk rdf:type rdf:Property ;
    rdfs:label 'Supply Material Fk' ;
    rdfs:comment 'FK to supply.material_master.material_master_id — Forecasts are for specific materials. Required to link forecast quantities to procurable items.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplySupplierFk rdf:type rdf:Property ;
    rdfs:label 'Supply Supplier Fk' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — Forecasts are communicated to specific suppliers for capacity planning. Required for supplier collaboration.' ;
    rdfs:domain ind:SupplyForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Identifier of the marketing or design-win campaign linked to the opportunity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Opportunities are owned within a sales territory; FK replaces free-text field for data integrity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:competitiveLandscape rdf:type rdf:Property ;
    rdfs:label 'Competitive Landscape' ;
    rdfs:comment 'Free-text description of key competitors and market positioning for the opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Planned end or expiration date of the contract; nullable for open-ended agreements.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the contract if the opportunity is won.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the contract.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endMarket rdf:type rdf:Property ;
    rdfs:label 'End Market' ;
    rdfs:comment 'Primary market segment the opportunity addresses.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Projected date when the opportunity is expected to be closed (won or lost).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Discount Amount' ;
    rdfs:comment 'Estimated discount or rebate amount applied to the gross revenue.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Gross Amount' ;
    rdfs:comment 'Projected gross revenue before discounts, taxes, or adjustments.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedNetAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Net Amount' ;
    rdfs:comment 'Projected net revenue after discounts and adjustments.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name of the opportunity, often reflecting the target product or project.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Human-readable business identifier assigned to the opportunity (e.g., OPP-2024-00123).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Pricing structure applied to the opportunity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broad geographic region for the opportunity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Channel through which the sale is pursued.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current pipeline stage of the opportunity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stage Change Timestamp' ;
    rdfs:comment 'Timestamp when the opportunity last moved to its current stage.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetApplication rdf:type rdf:Property ;
    rdfs:label 'Target Application' ;
    rdfs:comment 'Intended end-use or application for the product (e.g., automotive ADAS, AI accelerator).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossDate rdf:type rdf:Property ;
    rdfs:label 'Win Loss Date' ;
    rdfs:comment 'Date on which the opportunity outcome (win or loss) was recorded.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:winLossReason rdf:type rdf:Property ;
    rdfs:label 'Win Loss Reason' ;
    rdfs:comment 'Narrative reason why the opportunity was won or lost.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'FK to sales.price_list.price_list_id — Quotes reference the applicable price list for base pricing. Essential for pricing compliance and margin analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Timestamp when the quote was converted to an order, if applicable.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConverted rdf:type rdf:Property ;
    rdfs:label 'Is Converted' ;
    rdfs:comment 'Indicates whether the quote has been converted to a sales order.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'Timestamp when the quote was issued to the customer.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quoteDescription rdf:type rdf:Property ;
    rdfs:label 'Quote Description' ;
    rdfs:comment 'Free-form text describing the scope, special conditions, or notes for the quote.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Human-readable business identifier for the quotation, often used in communications and tracking.' ;
