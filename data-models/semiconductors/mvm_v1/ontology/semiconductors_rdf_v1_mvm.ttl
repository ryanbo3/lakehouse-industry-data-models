    rdfs:label 'Test Program Name' ;
    rdfs:comment 'Human-readable name of the test program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testProgramStatus rdf:type rdf:Property ;
    rdfs:label 'Test Program Status' ;
    rdfs:comment 'Overall lifecycle state of the test program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Category of testing performed by the program (e.g., wafer probe, die sort, final test, burn-in, system level test).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the program version.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionDescription rdf:type rdf:Property ;
    rdfs:label 'Version Description' ;
    rdfs:comment 'Free-form description of changes introduced in this version.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFamilyId rdf:type rdf:Property ;
    rdfs:label 'Target Family Id' ;
    rdfs:comment 'Foreign key linking to product.family. Business justification: ATE platforms are often optimized for product families (shared test infrastructure). Test capacity planning, platform roadmaps, and capital equipment allocation require family-level ATE configuration ' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:ateConfigurationName rdf:type rdf:Property ;
    rdfs:label 'Ate Configuration Name' ;
    rdfs:comment 'Human-readable name identifying this ATE configuration.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binMappingVersion rdf:type rdf:Property ;
    rdfs:label 'Bin Mapping Version' ;
    rdfs:comment 'Version identifier for the binning map used in this configuration.' ;
    rdfs:domain ind:Test ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'Date by which the configuration must be re-calibrated.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current calibration state of the configuration.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceEarStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Ear Status' ;
    rdfs:comment 'Indicates whether the configuration complies with Export Administration Regulations.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceItarStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Itar Status' ;
    rdfs:comment 'Indicates whether the configuration complies with International Traffic in Arms Regulations.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Business identifier code used to reference the configuration in work orders and test plans.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareRevision rdf:type rdf:Property ;
    rdfs:label 'Hardware Revision' ;
    rdfs:comment 'Revision identifier for the ATE hardware bundle (e.g., Rev A, Rev B).' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentResourceAllocation rdf:type rdf:Property ;
    rdfs:label 'Instrument Resource Allocation' ;
    rdfs:comment 'List of instrument resources (e.g., power supplies, signal generators) allocated to this configuration.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCalibrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Timestamp' ;
    rdfs:comment 'Timestamp of the most recent calibration activity.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadBoardQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Load Board Qualification Status' ;
    rdfs:comment 'Current qualification status of the load board for production use.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadBoardRevision rdf:type rdf:Property ;
    rdfs:label 'Load Board Revision' ;
    rdfs:comment 'Revision identifier of the load board / Device Interface Board used.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWindow rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window' ;
    rdfs:comment 'Scheduled maintenance window description (e.g., weekly Saturday 02:00-04:00).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxParallelSiteCount rdf:type rdf:Property ;
    rdfs:label 'Max Parallel Site Count' ;
    rdfs:comment 'Maximum number of test sites that can be exercised simultaneously.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parametricTestSupported rdf:type rdf:Property ;
    rdfs:label 'Parametric Test Supported' ;
    rdfs:comment 'Indicates whether parametric testing is enabled for this configuration.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinElectronicsCardMap rdf:type rdf:Property ;
    rdfs:label 'Pin Electronics Card Map' ;
    rdfs:comment 'Mapping description of pin-to-electronics card assignments for the configuration.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'Type of test platform the configuration supports (wafer probe, final test, or reliability).' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedDeviceFamilies rdf:type rdf:Property ;
    rdfs:label 'Supported Device Families' ;
    rdfs:comment 'Comma-separated list of device families (e.g., ASIC, SoC, FPGA) that this configuration can test.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Test Coverage Percentage' ;
    rdfs:comment 'Percentage of functional test coverage provided by this configuration.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testYieldTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Test Yield Target Percentage' ;
    rdfs:comment 'Target yield percentage that the configuration aims to achieve during test runs.' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testerModel rdf:type rdf:Property ;
    rdfs:label 'Tester Model' ;
    rdfs:comment 'Model of the Automatic Test Equipment platform (e.g., Advantest V93000).' ;
    rdfs:domain ind:AteConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Target Ic Catalog Id' ;
    rdfs:comment 'Foreign key linking to product.ic_catalog. Business justification: Probe cards are designed for specific die layouts/pad configurations. Equipment planning, probe card qualification tracking, and maintenance scheduling require linking cards to target products. No exi' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:cardName rdf:type rdf:Property ;
    rdfs:label 'Card Name' ;
    rdfs:comment 'Human-readable name of the probe card used for identification in test engineering.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactResistanceOhm rdf:type rdf:Property ;
    rdfs:label 'Contact Resistance Ohm' ;
    rdfs:comment 'Measured electrical resistance of needle contacts in ohms.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Usd' ;
    rdfs:comment 'Acquisition cost of the probe card in US dollars.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieSiteLayout rdf:type rdf:Property ;
    rdfs:label 'Die Site Layout' ;
    rdfs:comment 'Description of the die site arrangement on the wafer for this probe card.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date when the probe card last underwent scheduled maintenance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Timestamp of the most recent test run that utilized the probe card.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maintenanceCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cycle Months' ;
    rdfs:comment 'Planned interval in months between preventive maintenance activities.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:needleCount rdf:type rdf:Property ;
    rdfs:label 'Needle Count' ;
    rdfs:comment 'Total number of probing needles/pins on the card.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:needleReplacements rdf:type rdf:Property ;
    rdfs:label 'Needle Replacements' ;
    rdfs:comment 'Cumulative number of needle replacement events performed on the card.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextMaintenanceDue rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due' ;
    rdfs:comment 'Planned date for the next preventive maintenance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pitchUm rdf:type rdf:Property ;
    rdfs:label 'Pitch Um' ;
    rdfs:comment 'Center-to-center spacing of needles in micrometers.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:probeCardDescription rdf:type rdf:Property ;
    rdfs:label 'Probe Card Description' ;
    rdfs:comment 'Free-form text describing special features, notes, or remarks about the probe card.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probeCardStatus rdf:type rdf:Property ;
    rdfs:label 'Probe Card Status' ;
    rdfs:comment 'Current lifecycle state of the probe card within test operations.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probeCardType rdf:type rdf:Property ;
    rdfs:label 'Probe Card Type' ;
    rdfs:comment 'Design classification of the probe card (e.g., cantilever, vertical, MEMS, advanced).' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchdownCount rdf:type rdf:Property ;
    rdfs:label 'Touchdown Count' ;
    rdfs:comment 'Number of successful needle contacts recorded per test cycle.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageHours rdf:type rdf:Property ;
    rdfs:label 'Usage Hours' ;
    rdfs:comment 'Total operational hours the probe card has been used in testing.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insertionId rdf:type rdf:Property ;
    rdfs:label 'Insertion Id' ;
    rdfs:comment 'Foreign key linking to test.insertion. Business justification: Bin definitions are often insertion-specific — wafer sort bins and final test bins differ. The bin_definition already has test_level (string) which suggests insertion-level differentiation. Linking bi' ;
    rdfs:domain ind:Test ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Insertion .

ind:binCategory rdf:type rdf:Property ;
    rdfs:label 'Bin Category' ;
    rdfs:comment 'Classification of the bin outcome according to JEDEC taxonomy.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Bin Definition Description' ;
    rdfs:comment 'Detailed free-text description of the bin purpose and usage.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Bin Definition Status' ;
    rdfs:comment 'Current lifecycle status of the bin definition.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binName rdf:type rdf:Property ;
    rdfs:label 'Bin Name' ;
    rdfs:comment 'Human-readable name describing the purpose of the bin.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binNumber rdf:type rdf:Property ;
    rdfs:label 'Bin Number' ;
    rdfs:comment 'Numeric identifier assigned to the test bin within a test program.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binSortOrder rdf:type rdf:Property ;
    rdfs:label 'Bin Sort Order' ;
    rdfs:comment 'Display order for bins in reports and UI.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceFamily rdf:type rdf:Property ;
    rdfs:label 'Device Family' ;
    rdfs:comment 'Product family or platform to which the bin definition applies.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionRule rdf:type rdf:Property ;
    rdfs:label 'Disposition Rule' ;
    rdfs:comment 'Action to be taken for devices falling into this bin.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Root cause or failure mechanism associated with the bin.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterSet rdf:type rdf:Property ;
    rdfs:label 'Parameter Set' ;
    rdfs:comment 'Set of parametric test parameters associated with the bin.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testLevel rdf:type rdf:Property ;
    rdfs:label 'Test Level' ;
    rdfs:comment 'Stage of testing where the bin is applied.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldImpactClassification rdf:type rdf:Property ;
    rdfs:label 'Yield Impact Classification' ;
    rdfs:comment 'Indicates how the bin affects overall wafer or lot yield.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWaferProbeCardId rdf:type rdf:Property ;
    rdfs:label 'Primary Wafer Probe Card Id' ;
    rdfs:comment 'Identifier of the probe card installed on the prober for this run.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProbeCard .

ind:primaryWaferTestProgramId rdf:type rdf:Property ;
    rdfs:label 'Primary Wafer Test Program Id' ;
    rdfs:comment 'Foreign key linking to test.test_program. Business justification: Wafer probe runs are executed under a specific test program; replace version string with FK to test_program.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:probeFabricationProcessStepId rdf:type rdf:Property ;
    rdfs:label 'Probe Fabrication Process Step Id' ;
    rdfs:comment 'Foreign key linking to fabrication.fabrication_process_step. Business justification: Wafer probe insertions occur at defined steps within the fabrication process flow (e.g., post-metal, final probe). Linking the probe run to the specific fabrication process step enables process engine' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessStep .

ind:probedWaferId rdf:type rdf:Property ;
    rdfs:label 'Probed Wafer Id' ;
    rdfs:comment 'Foreign key linking to fabrication.wafer. Business justification: Wafer probe runs are executed on individual wafers. Traceability from probe results to the specific fabrication wafer (substrate type, resistivity, epitaxial data) is essential for wafer-level yield a' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wafer .

ind:waferProbeCardId rdf:type rdf:Property ;
    rdfs:label 'Wafer Probe Card Id' ;
    rdfs:comment 'FK to test.probe_card.probe_card_id — Probe card assignment is critical for wafer probe operations — probe card condition directly impacts yield and contact quality.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProbeCard .

ind:ateConfiguration rdf:type rdf:Property ;
    rdfs:label 'Ate Configuration' ;
    rdfs:comment 'Configuration identifier for the Automatic Test Equipment used in the run.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binMapVersion rdf:type rdf:Property ;
    rdfs:label 'Bin Map Version' ;
    rdfs:comment 'Version identifier of the binning map used to classify die test results.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Contact Yield Percent' ;
    rdfs:comment 'Percentage of dies that made electrical contact during probing.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failDieCount rdf:type rdf:Property ;
    rdfs:label 'Fail Die Count' ;
    rdfs:comment 'Number of dies that failed one or more test criteria.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parametricTestDataAvailable rdf:type rdf:Property ;
    rdfs:label 'Parametric Test Data Available' ;
    rdfs:comment 'Indicates whether parametric test measurements were captured for this run.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passDieCount rdf:type rdf:Property ;
    rdfs:label 'Pass Die Count' ;
    rdfs:comment 'Number of dies that passed all test criteria.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-form notes or comments entered by the operator or quality engineer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Test Coverage Percent' ;
    rdfs:comment 'Proportion of functional tests executed relative to the total test plan.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDieCount rdf:type rdf:Property ;
    rdfs:label 'Total Die Count' ;
    rdfs:comment 'Total number of dies present on the wafer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferProbeRunStatus rdf:type rdf:Property ;
    rdfs:label 'Wafer Probe Run Status' ;
    rdfs:comment 'Current lifecycle status of the probe run.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Sequence Number' ;
    rdfs:comment 'Sequential number of the wafer within the lot.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitTestResultId rdf:type rdf:Property ;
    rdfs:label 'Unit Test Result Id' ;
    rdfs:comment 'Primary key for unit_test_result' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalTestRunId rdf:type rdf:Property ;
    rdfs:label 'Final Test Run Id' ;
    rdfs:comment 'FK to test.final_test_run.final_test_run_id — Package-level test results must link back to the final test run event. Required for lot disposition and DPPM tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinalTestRun .

ind:primaryBinDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Primary Bin Definition Id' ;
    rdfs:comment 'FK to test.bin_definition.bin_definition_id — Every unit test result is assigned a bin code from the bin_definition master. This is the core yield classification link.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinDefinition .

ind:testStepId rdf:type rdf:Property ;
    rdfs:label 'Test Step Id' ;
    rdfs:comment 'Foreign key linking to test.test_step. Business justification: Unit test results are produced at specific test steps within a test program. test_step defines individual steps including step_type, pass_fail_criteria, and measurement_unit. Linking unit_test_result ' ;
    rdfs:domain ind:Test ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestStep .

ind:testedSkuId rdf:type rdf:Property ;
    rdfs:label 'Tested Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Each tested unit is a specific SKU variant. RMA root cause analysis, customer quality reports, and traceability regulations require linking individual test results to the exact SKU tested. No existing' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:assemblyPosition rdf:type rdf:Property ;
    rdfs:label 'Assembly Position' ;
    rdfs:comment 'Position identifier for multi-die or chiplet assemblies.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Device Serial Number' ;
    rdfs:comment 'Serial number of the packaged device, if applicable.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardBinCode rdf:type rdf:Property ;
    rdfs:label 'Hard Bin Code' ;
    rdfs:comment 'Hard bin classification assigned to the unit based on test outcome.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSummary rdf:type rdf:Property ;
    rdfs:label 'Measurement Summary' ;
    rdfs:comment 'Concise summary of parametric measurement values for the unit.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnits rdf:type rdf:Property ;
    rdfs:label 'Measurement Units' ;
    rdfs:comment 'Units of the parametric measurements reported. [ENUM-REF-CANDIDATE: C|V|Ohm|nA|pF|%|dB — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parametricFlags rdf:type rdf:Property ;
    rdfs:label 'Parametric Flags' ;
    rdfs:comment 'Flags indicating which parametric tests were executed or passed.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFail rdf:type rdf:Property ;
    rdfs:label 'Pass Fail' ;
    rdfs:comment 'Overall pass or fail result for the unit.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestCount rdf:type rdf:Property ;
    rdfs:label 'Retest Count' ;
    rdfs:comment 'Number of times the unit has been retested.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retestIndicator rdf:type rdf:Property ;
    rdfs:label 'Retest Indicator' ;
    rdfs:comment 'Indicates whether the unit was retested after an initial failure.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:softBinCode rdf:type rdf:Property ;
    rdfs:label 'Soft Bin Code' ;
    rdfs:comment 'Soft bin classification for detailed failure analysis.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCondition rdf:type rdf:Property ;
    rdfs:label 'Test Condition' ;
    rdfs:comment 'Descriptive condition of the test environment.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultComment rdf:type rdf:Property ;
    rdfs:label 'Test Result Comment' ;
    rdfs:comment 'Free-text comments or notes associated with the test result.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultVersion rdf:type rdf:Property ;
    rdfs:label 'Test Result Version' ;
    rdfs:comment 'Version identifier of the test result format or schema.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStage rdf:type rdf:Property ;
    rdfs:label 'Test Stage' ;
    rdfs:comment 'Discriminator indicating the test insertion stage where the result was captured.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Test Temperature C' ;
    rdfs:comment 'Temperature at which the unit was tested, in degrees Celsius.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Test Time Seconds' ;
    rdfs:comment 'Total duration of the test execution for the unit, in seconds.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Timestamp' ;
    rdfs:comment 'Date and time when the test was performed.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testVoltageV rdf:type rdf:Property ;
    rdfs:label 'Test Voltage V' ;
    rdfs:comment 'Voltage level applied during testing, in volts.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testYieldFlag rdf:type rdf:Property ;
    rdfs:label 'Test Yield Flag' ;
    rdfs:comment 'Indicates if the unit is counted towards lot yield calculations.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitIdentifier rdf:type rdf:Property ;
    rdfs:label 'Unit Identifier' ;
    rdfs:comment 'Identifier of the tested unit, expressed as wafer X/Y coordinates for wafer-level or serial number for package-level.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFinalTestProgramId rdf:type rdf:Property ;
    rdfs:label 'Primary Final Test Program Id' ;
    rdfs:comment 'Foreign key linking to test.test_program. Business justification: Final test runs are generated by a specific test program; add FK to capture this relationship.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:ateName rdf:type rdf:Property ;
    rdfs:label 'Ate Name' ;
    rdfs:comment 'Name or model of the ATE system executing the test.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binDistribution rdf:type rdf:Property ;
    rdfs:label 'Bin Distribution' ;
    rdfs:comment 'Compact representation of test bin counts (e.g., JSON or delimited string).' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bootSuccessCount rdf:type rdf:Property ;
    rdfs:label 'Boot Success Count' ;
    rdfs:comment 'Number of devices that successfully booted during SLT.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failCount rdf:type rdf:Property ;
    rdfs:label 'Fail Count' ;
    rdfs:comment 'Number of devices that failed one or more test criteria.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalTestRunStatus rdf:type rdf:Property ;
    rdfs:label 'Final Test Run Status' ;
    rdfs:comment 'Current lifecycle status of the test run.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerName rdf:type rdf:Property ;
    rdfs:label 'Handler Name' ;
    rdfs:comment 'Identifier of the handler module that loads devices into the ATE.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parametricTestFail rdf:type rdf:Property ;
    rdfs:label 'Parametric Test Fail' ;
    rdfs:comment 'Count of parametric test points that failed.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parametricTestPass rdf:type rdf:Property ;
    rdfs:label 'Parametric Test Pass' ;
    rdfs:comment 'Count of parametric test points that passed.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passCount rdf:type rdf:Property ;
    rdfs:label 'Pass Count' ;
    rdfs:comment 'Number of devices that passed all test criteria.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sltBoardCode rdf:type rdf:Property ;
    rdfs:label 'Slt Board Code' ;
    rdfs:comment 'Identifier of the board used for system-level testing, if applicable.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socketCode rdf:type rdf:Property ;
    rdfs:label 'Socket Code' ;
    rdfs:comment 'Identifier of the socket used to hold the device during testing.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testLocation rdf:type rdf:Property ;
    rdfs:label 'Test Location' ;
    rdfs:comment 'Code of the laboratory or floor where the test was performed.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testRunCode rdf:type rdf:Property ;
    rdfs:label 'Test Run Code' ;
    rdfs:comment 'Business identifier assigned to the test run, used for tracking across systems.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testShift rdf:type rdf:Property ;
    rdfs:label 'Test Shift' ;
    rdfs:comment 'Work shift during which the test run was executed.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSites rdf:type rdf:Property ;
    rdfs:label 'Total Sites' ;
    rdfs:comment 'Number of parallel test sites active on the ATE for this run.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Percent' ;
    rdfs:comment 'Yield of the test run expressed as a percentage of passed devices.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parametricMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Parametric Measurement Id' ;
    rdfs:comment 'Unique surrogate key for each parametric measurement record.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationRecordId rdf:type rdf:Property ;
    rdfs:label 'Calibration Record Id' ;
    rdfs:comment 'Identifier of the calibration record applied to the equipment for this measurement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationRecord .

ind:parametricTestResultUnitTestResultId rdf:type rdf:Property ;
    rdfs:label 'Parametric Test Result Unit Test Result Id' ;
    rdfs:comment 'Identifier linking to the overall test result set for the die.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitTestResult .

ind:parametricUnitTestResultId rdf:type rdf:Property ;
    rdfs:label 'Parametric Unit Test Result Id' ;
    rdfs:comment 'FK to test.unit_test_result.unit_test_result_id — Parametric measurements are captured per unit under test. Must link to the parent unit result for traceability.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitTestResult .

ind:primaryParametricDieWaferId rdf:type rdf:Property ;
    rdfs:label 'Primary Parametric Die Wafer Id' ;
    rdfs:comment 'Identifier of the individual die on which the measurement was performed.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wafer .

ind:measurementAverageValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Average Value' ;
    rdfs:comment 'Average of repeated measurements for the parameter.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementComment rdf:type rdf:Property ;
    rdfs:label 'Measurement Comment' ;
    rdfs:comment 'Free-form comment entered by the operator or analyst.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementConditionFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Measurement Condition Frequency Mhz' ;
    rdfs:comment 'Frequency condition during the measurement, expressed in megahertz.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementConditionTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Measurement Condition Temperature C' ;
    rdfs:comment 'Temperature condition during the measurement, expressed in degrees Celsius.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementConditionVoltageMv rdf:type rdf:Property ;
    rdfs:label 'Measurement Condition Voltage Mv' ;
    rdfs:comment 'Voltage condition applied during the measurement, expressed in millivolts.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementEvaluatedAgainstLimit rdf:type rdf:Property ;
    rdfs:label 'Measurement Evaluated Against Limit' ;
    rdfs:comment 'FK to test.test_limit.test_limit_id — Each parametric measurement is evaluated against specification limits defined in test_limit. This link enables pass/fail determination and SPC analysis.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementFlagged rdf:type rdf:Property ;
    rdfs:label 'Measurement Flagged' ;
    rdfs:comment 'Indicates if the measurement was flagged for outlier review.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementForUnitResult rdf:type rdf:Property ;
    rdfs:label 'Measurement For Unit Result' ;
    rdfs:comment 'FK to test.die_test_result.die_test_result_id — Parametric measurements are captured for specific die/device test results. This is the detail-level link from measurement to the unit being tested.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementLocation rdf:type rdf:Property ;
    rdfs:label 'Measurement Location' ;
    rdfs:comment 'Physical location on the die where the measurement was taken.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Measurement Quality Flag' ;
    rdfs:comment 'Quality assessment of the measurement data.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementRepeatCount rdf:type rdf:Property ;
    rdfs:label 'Measurement Repeat Count' ;
    rdfs:comment 'Number of times the parameter was measured in this test cycle.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Review Status' ;
    rdfs:comment 'Current review status of the measurement.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Review Timestamp' ;
    rdfs:comment 'Timestamp when the measurement review was completed.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementSequence rdf:type rdf:Property ;
    rdfs:label 'Measurement Sequence' ;
    rdfs:comment 'Ordinal position of this measurement within the test program.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'Source of the measurement data, e.g., probe card or automatic test equipment.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStdDev rdf:type rdf:Property ;
    rdfs:label 'Measurement Std Dev' ;
    rdfs:comment 'Statistical standard deviation of repeated measurements.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementToolVersion rdf:type rdf:Property ;
    rdfs:label 'Measurement Tool Version' ;
    rdfs:comment 'Software/firmware version of the test tool that generated the measurement.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUncertainty rdf:type rdf:Property ;
    rdfs:label 'Measurement Uncertainty' ;
    rdfs:comment 'Estimated uncertainty of the measured value.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parametricAgainstLimit rdf:type rdf:Property ;
    rdfs:label 'Parametric Against Limit' ;
    rdfs:comment 'FK to test.test_limit.test_limit_id — Each parametric measurement is evaluated against a test limit specification. Required for pass/fail determination and SPC.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parametricCheckedAgainstLimit rdf:type rdf:Property ;
    rdfs:label 'Parametric Checked Against Limit' ;
    rdfs:comment 'FK to test.test_limit.test_limit_id — Each parametric measurement is evaluated against a test limit. This FK enables limit-vs-actual analysis and SPC trending.' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testParameterName rdf:type rdf:Property ;
    rdfs:label 'Test Parameter Name' ;
    rdfs:comment 'Name of the specific parametric test parameter (e.g., Vth, Idsat).' ;
    rdfs:domain ind:ParametricMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitId rdf:type rdf:Property ;
    rdfs:label 'Limit Id' ;
    rdfs:comment 'System-generated unique identifier for the test limit record.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByDepartment rdf:type rdf:Property ;
    rdfs:label 'Created By Department' ;
    rdfs:comment 'Organizational department responsible for creating the limit.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Origin of the measurement data used for the limit.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Classification of the semiconductor device (e.g., ASIC, SoC, FPGA) to which the limit applies.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitCategory rdf:type rdf:Property ;
    rdfs:label 'Limit Category' ;
    rdfs:comment 'High-level category of the limit.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitSource rdf:type rdf:Property ;
    rdfs:label 'Limit Source' ;
    rdfs:comment 'Origin of the limit definition.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'True if the limit is mandated by a regulatory requirement.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'Scheduled frequency for limit review.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalMethod rdf:type rdf:Property ;
    rdfs:label 'Statistical Method' ;
    rdfs:comment 'Statistical approach used to derive the limit.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testConditionSet rdf:type rdf:Property ;
    rdfs:label 'Test Condition Set' ;
    rdfs:comment 'Named set of test conditions (temperature, voltage, frequency) under which the limit is valid.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFlowName rdf:type rdf:Property ;
    rdfs:label 'Test Flow Name' ;
    rdfs:comment 'Name of the test flow or sequence where the limit is applied.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percent' ;
    rdfs:comment 'Allowed percentage deviation from the target value.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionHistory rdf:type rdf:Property ;
    rdfs:label 'Version History' ;
    rdfs:comment 'JSON or delimited text capturing historical versions of the limit.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageId rdf:type rdf:Property ;
    rdfs:label 'Coverage Id' ;
    rdfs:comment 'Unique surrogate key for each test coverage record.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageDeviceTypeIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Coverage Device Type Ic Catalog Id' ;
    rdfs:comment 'Surrogate key linking to the device type master data.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:coverageIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Coverage Ic Catalog Id' ;
    rdfs:comment 'Foreign key linking to product.ic_catalog. Business justification: Test coverage reports are generated per IC product to assess validation completeness before tape-out.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:correlationScore rdf:type rdf:Property ;
    rdfs:label 'Correlation Score' ;
    rdfs:comment 'Score indicating correlation between wafer-level and package-level test results.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageCategory rdf:type rdf:Property ;
    rdfs:label 'Coverage Category' ;
    rdfs:comment 'High-level category of coverage measured (functional, parametric, structural, timing).' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Date' ;
    rdfs:comment 'Calendar date on which the coverage metrics were measured.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageMethod rdf:type rdf:Property ;
    rdfs:label 'Coverage Method' ;
    rdfs:comment 'Method used to obtain coverage metrics.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current lifecycle status of the coverage record.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDensity rdf:type rdf:Property ;
    rdfs:label 'Defect Density' ;
    rdfs:comment 'Number of defects per unit area observed during testing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dftStructureCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Dft Structure Coverage Percent' ;
    rdfs:comment 'Coverage of DFT structures such as scan chains, BIST, and boundary-scan.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faultCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Fault Coverage Percent' ;
    rdfs:comment 'Overall percentage of detectable faults covered by the test program.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iddqCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Iddq Coverage Percent' ;
    rdfs:comment 'Percentage of IDDQ (quiescent current) tests covered.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isApproved rdf:type rdf:Property ;
    rdfs:label 'Is Approved' ;
    rdfs:comment 'Indicates whether the coverage record has been formally approved.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent formal review of the coverage data.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pathDelayCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Path Delay Coverage Percent' ;
    rdfs:comment 'Percentage of timing paths meeting delay specifications.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stuckAtFaultCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Stuck At Fault Coverage Percent' ;
    rdfs:comment 'Percentage of stuck-at faults covered.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tapeoutReady rdf:type rdf:Property ;
    rdfs:label 'Tapeout Ready' ;
    rdfs:comment 'True if the coverage meets the tapeout release criteria.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tool rdf:type rdf:Property ;
    rdfs:label 'Tool' ;
    rdfs:comment 'Name of the software tool used to generate coverage metrics.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFaults rdf:type rdf:Property ;
    rdfs:label 'Total Faults' ;
    rdfs:comment 'Total number of fault models considered for coverage analysis.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitionFaultCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Transition Fault Coverage Percent' ;
    rdfs:comment 'Percentage of transition-faults covered.' ;
    rdfs:domain ind:Coverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:units rdf:type rdf:Property ;
