    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCostId rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Id' ;
    rdfs:comment 'Unique surrogate key for each standard cost record.' ;
