    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Change Request Number' ;
    rdfs:comment 'Identifier of the change request that triggered the qualification (if PCN-driven).' ;
    rdfs:domain ind:QualityQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationLink rdf:type rdf:Property ;
    rdfs:label 'Documentation Link' ;
    rdfs:comment 'URL or path to the primary qualification program documentation.' ;
    rdfs:domain ind:QualityQualificationProgram ;
