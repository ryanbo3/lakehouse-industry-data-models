    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'True if incoming or in-process inspection is mandatory for the material.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serialManagement rdf:type rdf:Property ;
    rdfs:label 'Serial Management' ;
    rdfs:comment 'True if the material is tracked by serial numbers.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageHumidityMinPct rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Min Pct' ;
    rdfs:comment 'Lowest permissible relative humidity percentage for storage.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tscaCompliant rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliant' ;
    rdfs:comment 'True if the material is compliant with the US Toxic Substances Control Act (TSCA).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryPurchaseSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Supplier Id' ;
    rdfs:comment 'Unique identifier of the supplier (vendor) to which the purchase order is issued.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:complianceFlags rdf:type rdf:Property ;
    rdfs:label 'Compliance Flags' ;
    rdfs:comment 'Semicolon-separated list of compliance indicators (e.g., RoHS, REACH).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySchedule rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'Free-text description of delivery windows or milestones.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Monetary value of the discount applied.' ;
