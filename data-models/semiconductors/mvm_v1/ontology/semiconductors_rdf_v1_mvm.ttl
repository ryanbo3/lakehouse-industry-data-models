ind:equipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Required' ;
    rdfs:comment 'Identifier of the ATE or fixture needed to execute the step.' ;
    rdfs:domain ind:TestStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCategory rdf:type rdf:Property ;
    rdfs:label 'Step Category' ;
    rdfs:comment 'Phase of the overall test flow where the step occurs.' ;
    rdfs:domain ind:TestStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCode rdf:type rdf:Property ;
    rdfs:label 'Step Code' ;
    rdfs:comment 'Compact alphanumeric code that uniquely identifies the step within a test program.' ;
    rdfs:domain ind:TestStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepOrder rdf:type rdf:Property ;
    rdfs:label 'Step Order' ;
    rdfs:comment 'Zero-based sequence number indicating the step\'s position in the test program.' ;
    rdfs:domain ind:TestStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Category of the test step based on its functional purpose.' ;
    rdfs:domain ind:TestStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferRunRecordId rdf:type rdf:Property ;
    rdfs:label 'Wafer Run Record Id' ;
    rdfs:comment 'Unique identifier for this wafer run record. Primary key for the association.' ;
    rdfs:domain ind:WaferRunRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:perWaferMeasurementResult rdf:type rdf:Property ;
    rdfs:label 'Per Wafer Measurement Result' ;
    rdfs:comment 'Wafer-specific measurement or metrology result captured during or immediately after this equipment run. May contain structured JSON or delimited values for multiple measurement points. Enables wafer-level process control and yield correlation. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:WaferRunRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Process End Timestamp' ;
    rdfs:comment 'Timestamp when processing completed for this specific wafer within the equipment run. Used to calculate per-wafer cycle time and identify processing anomalies.' ;
    rdfs:domain ind:WaferRunRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Process Start Timestamp' ;
    rdfs:comment 'Timestamp when processing began for this specific wafer within the equipment run. May differ from equipment_run start time in sequential or batch processing scenarios.' ;
    rdfs:domain ind:WaferRunRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:waferDispositionInRun rdf:type rdf:Property ;
    rdfs:label 'Wafer Disposition In Run' ;
    rdfs:comment 'Disposition decision for this wafer based on the results of this specific equipment run. Determines whether the wafer proceeds to the next process step, is held for review, scrapped, or sent for rework. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:WaferRunRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferRunStatus rdf:type rdf:Property ;
    rdfs:label 'Wafer Run Status' ;
    rdfs:comment 'Per-wafer processing status for this equipment run. Captures whether this specific wafer completed successfully, was aborted, skipped, or failed during the run. Allows individual wafer failures within a batch run. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:WaferRunRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepWorkCenterQualificationId rdf:type rdf:Property ;
    rdfs:label 'Process Step Work Center Qualification Id' ;
    rdfs:comment 'Unique identifier for this process step to work center qualification record. Primary key.' ;
    rdfs:domain ind:ProcessStepWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastQualificationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Review Date' ;
    rdfs:comment 'Date when this qualification was last reviewed or revalidated. Used for periodic qualification maintenance and compliance.' ;
    rdfs:domain ind:ProcessStepWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Flag' ;
    rdfs:comment 'Boolean indicator of whether this work center is the preferred or primary choice for executing this process step. Dispatching systems prioritize preferred work centers when multiple qualified options exist. Sourced from detection phase relationship_data.' ;
    rdfs:domain ind:ProcessStepWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualifiedDate rdf:type rdf:Property ;
    rdfs:label 'Qualified Date' ;
    rdfs:comment 'Date when the work center was officially qualified to execute this process step. Used for audit trail and compliance tracking. Sourced from detection phase relationship_data.' ;
    rdfs:domain ind:ProcessStepWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcnImpactId rdf:type rdf:Property ;
    rdfs:label 'Pcn Impact Id' ;
    rdfs:comment 'Unique identifier for this PCN impact record. Primary key.' ;
    rdfs:domain ind:PcnImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of PCN implementation for this specific SKU. Tracks whether the change has been successfully implemented in production for this SKU variant.' ;
    rdfs:domain ind:PcnImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuSpecificImpactNotes rdf:type rdf:Property ;
    rdfs:label 'Sku Specific Impact Notes' ;
    rdfs:comment 'Additional notes or clarifications about how this PCN specifically affects this SKU, including any SKU-specific qualification requirements, customer notifications, or implementation considerations.' ;
    rdfs:domain ind:PcnImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
