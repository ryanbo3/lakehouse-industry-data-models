    rdfs:comment 'Code identifying the cost or profit center, division, or legal entity responsible for the budget.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Approval Timestamp' ;
    rdfs:comment 'Timestamp when the budget plan received final approval.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedAmountGroup rdf:type rdf:Property ;
    rdfs:label 'Planned Amount Group' ;
    rdfs:comment 'Budgeted monetary amount expressed in the corporate group reporting currency.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedAmountLocal rdf:type rdf:Property ;
    rdfs:label 'Planned Amount Local' ;
    rdfs:comment 'Budgeted monetary amount expressed in the local operating currency.' ;
