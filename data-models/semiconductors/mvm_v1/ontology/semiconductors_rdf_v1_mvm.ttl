    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Industry segment of the end product.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAdjustment rdf:type rdf:Property ;
    rdfs:label 'Revenue Adjustment' ;
    rdfs:comment 'Any discount, rebate, or adjustment applied to the gross revenue.' ;
    rdfs:domain ind:SalesDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRampEndDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Ramp End Date' ;
    rdfs:comment 'End date of the revenue ramp period.' ;
    rdfs:domain ind:SalesDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRampStartDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Ramp Start Date' ;
    rdfs:comment 'Start date of the revenue ramp period.' ;
    rdfs:domain ind:SalesDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesDesignWinStatus rdf:type rdf:Property ;
    rdfs:label 'Sales Design Win Status' ;
    rdfs:comment 'Current lifecycle status of the design win.' ;
    rdfs:domain ind:SalesDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTerritory rdf:type rdf:Property ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Geographic or market territory responsible for the design win.' ;
    rdfs:domain ind:SalesDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winSource rdf:type rdf:Property ;
    rdfs:label 'Win Source' ;
    rdfs:comment 'System or source where the design win was recorded.' ;
    rdfs:domain ind:SalesDesignWin ;
