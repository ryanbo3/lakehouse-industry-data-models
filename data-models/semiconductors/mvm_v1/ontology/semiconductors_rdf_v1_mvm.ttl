ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Category of the vendor based on its role in the semiconductor supply chain.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUom rdf:type rdf:Property ;
    rdfs:label 'Base Uom' ;
    rdfs:comment 'Standard unit of measure used for inventory and procurement transactions (e.g., kg, L, pcs).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagement rdf:type rdf:Property ;
    rdfs:label 'Batch Management' ;
    rdfs:comment 'True if the material is managed in batches for traceability.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date after which the material must not be used.' ;
