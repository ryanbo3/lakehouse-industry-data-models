ind:hazardousClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Classification' ;
    rdfs:comment 'Regulatory classification indicating the material\'s hazardous status under RoHS, REACH, and TSCA.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeQty rdf:type rdf:Property ;
    rdfs:label 'Lot Size Qty' ;
    rdfs:comment 'Standard production or procurement lot size for the material.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Detailed textual description of the material, including its purpose and key characteristics.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Human-readable name or title of the material.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the material by its functional role in semiconductor manufacturing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxOrderQty rdf:type rdf:Property ;
    rdfs:label 'Max Order Qty' ;
    rdfs:comment 'Largest quantity that can be ordered in a single purchase order.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
