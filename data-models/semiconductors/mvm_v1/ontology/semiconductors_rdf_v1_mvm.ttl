    rdfs:range xsd:string .

ind:taxRegime rdf:type rdf:Property ;
    rdfs:label 'Tax Regime' ;
    rdfs:comment 'Tax treatment applicable to the NRE agreement.' ;
    rdfs:domain ind:FinanceNreAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
