    rdfs:comment 'Foreign key linking to test.final_test_run. Business justification: Defects found at final test must link to the test run that detected them. Critical for test escape analysis, DPPM calculation, and final test program effectiveness evaluation.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinalTestRun .

ind:detectionToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Detection Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: Defects originate from specific chambers, not just tools. Chamber-level defect pareto analysis drives targeted maintenance and chamber matching. Essential for yield excursion response and chamber qual' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:detectionWaferProbeRunId rdf:type rdf:Property ;
    rdfs:label 'Detection Wafer Probe Run Id' ;
    rdfs:comment 'Foreign key linking to test.wafer_probe_run. Business justification: Defects detected during wafer probe must link to the specific probe run that identified them. Essential for yield analysis, test escape tracking, and probe card qualification.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferProbeRun .

ind:primaryWaferMapId rdf:type rdf:Property ;
    rdfs:label 'Primary Wafer Map Id' ;
    rdfs:comment 'FK to quality.wafer_map.wafer_map_id — Defects with X/Y coordinates must link to the wafer map for spatial analysis. This is critical for systematic defect pattern detection.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferMap .

ind:processRecipeId rdf:type rdf:Property ;
    rdfs:label 'Process Recipe Id' ;
    rdfs:comment 'Foreign key linking to process.recipe. Business justification: Defect analysis reports need the recipe used during the step to correlate process parameters with defect types.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recipe .

ind:binAssignment rdf:type rdf:Property ;
    rdfs:label 'Bin Assignment' ;
    rdfs:comment 'Pass/fail bin code assigned to the die (e.g., P, F1, F2).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectAreaUm2 rdf:type rdf:Property ;
    rdfs:label 'Defect Area Um2' ;
    rdfs:comment 'Calculated area of the defect in square micrometers.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectClassification rdf:type rdf:Property ;
    rdfs:label 'Defect Classification' ;
    rdfs:comment 'High-level classification of the defect (e.g., particle, patterning, etch).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDensityPerZone rdf:type rdf:Property ;
    rdfs:label 'Defect Density Per Zone' ;
    rdfs:comment 'Number of defects per unit area within the zone.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectLayer rdf:type rdf:Property ;
    rdfs:label 'Defect Layer' ;
    rdfs:comment 'Process layer where the defect was found.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSeverity rdf:type rdf:Property ;
    rdfs:label 'Defect Severity' ;
    rdfs:comment 'Severity rating indicating impact on yield.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectStatus rdf:type rdf:Property ;
    rdfs:label 'Defect Status' ;
    rdfs:comment 'Current workflow status of the defect record.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieX rdf:type rdf:Property ;
    rdfs:label 'Die X' ;
    rdfs:comment 'Column index of the die containing the defect on the wafer grid.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieY rdf:type rdf:Property ;
    rdfs:label 'Die Y' ;
    rdfs:comment 'Row index of the die containing the defect on the wafer grid.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:edgeExclusionZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Edge Exclusion Zone Flag' ;
    rdfs:comment 'Indicates whether the defect lies within the defined edge exclusion area.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flatNotchOrientation rdf:type rdf:Property ;
    rdfs:label 'Flat Notch Orientation' ;
    rdfs:comment 'Orientation of wafer flat or notch relative to the defect.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRecipe rdf:type rdf:Property ;
    rdfs:label 'Inspection Recipe' ;
    rdfs:comment 'Name of the inspection recipe or parameter set used.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Repeatability Flag' ;
    rdfs:comment 'True if the defect pattern repeats across multiple wafers.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:xCoordinate rdf:type rdf:Property ;
    rdfs:label 'X Coordinate' ;
    rdfs:comment 'Horizontal position of the defect on the wafer map (millimeters).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yCoordinate rdf:type rdf:Property ;
    rdfs:label 'Y Coordinate' ;
    rdfs:comment 'Vertical position of the defect on the wafer map (millimeters).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferMapId rdf:type rdf:Property ;
    rdfs:label 'Wafer Map Id' ;
    rdfs:comment 'Primary key for wafer_map' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferMap .

ind:binCountTotal rdf:type rdf:Property ;
    rdfs:label 'Bin Count Total' ;
    rdfs:comment 'Total number of distinct bins used in the map.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceIatf16949 rdf:type rdf:Property ;
    rdfs:label 'Compliance Iatf16949' ;
    rdfs:comment 'Flag indicating compliance with IATF 16949 for this wafer map.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectDensityPerSqmm rdf:type rdf:Property ;
    rdfs:label 'Defect Density Per Sqmm' ;
    rdfs:comment 'Average defect density across the wafer measured in defects per square millimeter.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectZone rdf:type rdf:Property ;
    rdfs:label 'Defect Zone' ;
    rdfs:comment 'Region of the wafer where defects are concentrated.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieGridColumns rdf:type rdf:Property ;
    rdfs:label 'Die Grid Columns' ;
    rdfs:comment 'Number of die columns in the wafer grid.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieGridRows rdf:type rdf:Property ;
    rdfs:label 'Die Grid Rows' ;
    rdfs:comment 'Number of die rows in the wafer grid.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Die Yield Percentage' ;
    rdfs:comment 'Yield percentage calculated from passing dies over total dies.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:edgeExclusionZoneMm rdf:type rdf:Property ;
    rdfs:label 'Edge Exclusion Zone Mm' ;
    rdfs:comment 'Width of the edge exclusion zone in millimeters where dies are not counted.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failBinCode rdf:type rdf:Property ;
    rdfs:label 'Fail Bin Code' ;
    rdfs:comment 'Bin code representing failing (defective) dies.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failingDieCount rdf:type rdf:Property ;
    rdfs:label 'Failing Die Count' ;
    rdfs:comment 'Number of dies classified as failing.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flatOrientation rdf:type rdf:Property ;
    rdfs:label 'Flat Orientation' ;
    rdfs:comment 'Orientation of the wafer flat/notch relative to the map coordinate system.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKgdCertified rdf:type rdf:Property ;
    rdfs:label 'Is Kgd Certified' ;
    rdfs:comment 'Indicates whether the wafer passed Known Good Die certification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kgdCertificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Kgd Certification Timestamp' ;
    rdfs:comment 'Timestamp when KGD certification was applied.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mapChecksum rdf:type rdf:Property ;
    rdfs:label 'Map Checksum' ;
    rdfs:comment 'Checksum (e.g., SHA-256) of the map file for integrity verification.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapFilePath rdf:type rdf:Property ;
    rdfs:label 'Map File Path' ;
    rdfs:comment 'File system path or URI where the wafer map image/file is stored.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Map Generation Timestamp' ;
    rdfs:comment 'Date and time when the wafer map was generated.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mapStatus rdf:type rdf:Property ;
    rdfs:label 'Map Status' ;
    rdfs:comment 'Current processing status of the wafer map.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapVersion rdf:type rdf:Property ;
    rdfs:label 'Map Version' ;
    rdfs:comment 'Version identifier of the map generation algorithm or software.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passBinCode rdf:type rdf:Property ;
    rdfs:label 'Pass Bin Code' ;
    rdfs:comment 'Bin code representing passing (good) dies.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingDieCount rdf:type rdf:Property ;
    rdfs:label 'Passing Die Count' ;
    rdfs:comment 'Number of dies classified as passing.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Yield Record Id' ;
    rdfs:comment 'System-generated unique identifier for the yield record.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binDistributionSummary rdf:type rdf:Property ;
    rdfs:label 'Bin Distribution Summary' ;
    rdfs:comment 'Compact representation (e.g., JSON) of die bin counts across test bins.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabLine rdf:type rdf:Property ;
    rdfs:label 'Fab Line' ;
    rdfs:comment 'Production line identifier within the fab.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSystem rdf:type rdf:Property ;
    rdfs:label 'Inspection System' ;
    rdfs:comment 'Name of the inspection/metrology system used (e.g., KLA ICOS).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotHumidityPercent rdf:type rdf:Property ;
    rdfs:label 'Lot Humidity Percent' ;
    rdfs:comment 'Relative humidity of the fab environment during measurement.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Lot Temperature C' ;
    rdfs:comment 'Average temperature of the wafer lot during measurement.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Measurement Accuracy Percent' ;
    rdfs:comment 'Stated accuracy of the measurement as a percentage.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementStage rdf:type rdf:Property ;
    rdfs:label 'Measurement Stage' ;
    rdfs:comment 'Quality gate at which the yield was measured.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Measurement Variance Percent' ;
    rdfs:comment 'Statistical variance observed across repeated measurements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityGate rdf:type rdf:Property ;
    rdfs:label 'Quality Gate' ;
    rdfs:comment 'Specific quality gate where the measurement was recorded.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Work shift during which the measurement was taken.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileName rdf:type rdf:Property ;
    rdfs:label 'Source File Name' ;
    rdfs:comment 'Name of the source file or data feed that supplied the measurement.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Tool Serial Number' ;
    rdfs:comment 'Serial number of the measurement tool.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldGapPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Gap Percent' ;
    rdfs:comment 'Difference between actual yield and target yield.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossCategory rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Category' ;
    rdfs:comment 'Root cause classification for yield loss.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Yield Record Status' ;
    rdfs:comment 'Current validation status of the yield record.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcChartId rdf:type rdf:Property ;
    rdfs:label 'Spc Chart Id' ;
    rdfs:comment 'Unique identifier for the SPC chart record. _canonical_skip_reason: Entity does not fit standard role categories and is modeled as a custom data product.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolFabToolId rdf:type rdf:Property ;
    rdfs:label 'Tool Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: SPC Dashboard links each chart to the Fab Tool that generated the data, enabling tool-level performance monitoring.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:assignableCauseCode rdf:type rdf:Property ;
    rdfs:label 'Assignable Cause Code' ;
    rdfs:comment 'Code representing the identified root cause for an out-of-control signal.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlLimitCenter rdf:type rdf:Property ;
    rdfs:label 'Control Limit Center' ;
    rdfs:comment 'Center line value (process mean) for the chart.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diePosition rdf:type rdf:Property ;
    rdfs:label 'Die Position' ;
    rdfs:comment 'Identifier of the individual die (chip) measured.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Baseline' ;
    rdfs:comment 'True if this chart serves as the baseline for comparative analysis.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementSubgroup rdf:type rdf:Property ;
    rdfs:label 'Measurement Subgroup' ;
    rdfs:comment 'Logical grouping identifier for the sample (e.g., lot number, wafer ID).' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTool rdf:type rdf:Property ;
    rdfs:label 'Measurement Tool' ;
    rdfs:comment 'Equipment or system that performed the measurement.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterUnit rdf:type rdf:Property ;
    rdfs:label 'Parameter Unit' ;
    rdfs:comment 'Unit of measure for the monitored parameter (e.g., nm, µm, %).' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcChartStatus rdf:type rdf:Property ;
    rdfs:label 'Spc Chart Status' ;
    rdfs:comment 'Operational status of the SPC chart record.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcToMetrology rdf:type rdf:Property ;
    rdfs:label 'Spc To Metrology' ;
    rdfs:comment 'FK to quality.metrology_measurement.metrology_measurement_id — SPC charts are populated by metrology measurements. This is the fundamental data flow from measurement to statistical control.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentFabToolId rdf:type rdf:Property ;
    rdfs:label 'Equipment Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: FMEA records document failure modes for process steps executed on specific tools. Tool-specific risk assessment drives preventive maintenance planning and equipment qualification requirements in semic' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:equipmentToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Equipment Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: Chamber-level failure modes (gas flow instability, temperature uniformity) require chamber-specific FMEA. Chamber-level risk prioritization drives chamber PM optimization and chamber matching programs' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:actionOwner rdf:type rdf:Property ;
    rdfs:label 'Action Owner' ;
    rdfs:comment 'Name or identifier of the person accountable for implementing the recommended action.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeOfFailure rdf:type rdf:Property ;
    rdfs:label 'Cause Of Failure' ;
    rdfs:comment 'Identified underlying cause(s) that could lead to the failure mode.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPlanReference rdf:type rdf:Property ;
    rdfs:label 'Control Plan Reference' ;
    rdfs:comment 'Identifier linking the FMEA to the relevant control plan document.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Identifier of the system user who entered the FMEA record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionRating rdf:type rdf:Property ;
    rdfs:label 'Detection Rating' ;
    rdfs:comment 'Numerical rating (1-10) indicating how likely the failure will be detected before it reaches the customer.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectionTechnique rdf:type rdf:Property ;
    rdfs:label 'Detection Technique' ;
    rdfs:comment 'Specific detection approach (e.g., visual inspection, automated metrology).' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Description' ;
    rdfs:comment 'Narrative describing how the failure can occur within the product or process.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaCode rdf:type rdf:Property ;
    rdfs:label 'Fmea Code' ;
    rdfs:comment 'Business-level code used to reference the FMEA in reports and change management systems.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaName rdf:type rdf:Property ;
    rdfs:label 'Fmea Name' ;
    rdfs:comment 'Human-readable name that identifies the FMEA, often reflecting the product or process it evaluates.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Fmea Record Status' ;
    rdfs:comment 'Lifecycle status of the FMEA record, tracking its progression from creation to retirement.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaScope rdf:type rdf:Property ;
    rdfs:label 'Fmea Scope' ;
    rdfs:comment 'Narrative defining the boundaries (product, process, geography) covered by the analysis.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaType rdf:type rdf:Property ;
    rdfs:label 'Fmea Type' ;
    rdfs:comment 'Indicates whether the record is a Design FMEA (DFMEA) or Process FMEA (PFMEA).' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Identifier of the system user who performed the most recent update.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceRating rdf:type rdf:Property ;
    rdfs:label 'Occurrence Rating' ;
    rdfs:comment 'Numerical rating (1-10) representing the probability that the failure mode will occur.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postActionRpn rdf:type rdf:Property ;
    rdfs:label 'Post Action Rpn' ;
    rdfs:comment 'Re-calculated risk priority number after corrective actions have been applied.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:potentialEffect rdf:type rdf:Property ;
    rdfs:label 'Potential Effect' ;
    rdfs:comment 'Explanation of the impact on the customer if the failure mode materializes.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Text describing the action(s) proposed to mitigate the identified failure mode.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential version identifier tracking changes to the FMEA over time.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskPriorityNumber rdf:type rdf:Property ;
    rdfs:label 'Risk Priority Number' ;
    rdfs:comment 'Calculated risk priority number derived from severity, occurrence, and detection ratings.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Numerical rating (1-10) of the seriousness of the failure effect on the end customer.' ;
    rdfs:domain ind:FmeaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reliabilityTestId rdf:type rdf:Property ;
    rdfs:label 'Reliability Test Id' ;
    rdfs:comment 'Unique identifier for the reliability test record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReliabilityTest .

ind:testMaintenancePlanId rdf:type rdf:Property ;
    rdfs:label 'Test Maintenance Plan Id' ;
    rdfs:comment 'Foreign key linking to equipment.maintenance_plan. Business justification: Reliability test equipment requires specific maintenance plans to ensure test validity. Test equipment maintenance plan compliance is a regulatory requirement for JEDEC reliability testing and custome' ;
    rdfs:domain ind:ReliabilityTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenancePlan .

ind:testToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Test Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: Reliability stress tests (HTOL, thermal cycling) run in specific chambers with controlled environments. Test validity and repeatability require chamber traceability. Chamber qualification status is ma' ;
    rdfs:domain ind:ReliabilityTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:analysisMethod rdf:type rdf:Property ;
    rdfs:label 'Analysis Method' ;
    rdfs:comment 'Technique used to analyze the failed device.' ;
    rdfs:domain ind:ReliabilityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableStandard rdf:type rdf:Property ;
    rdfs:label 'Applicable Standard' ;
    rdfs:comment 'Industry standard governing the qualification (e.g., AEC-Q100, JEDEC JESD47).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or role of the person/committee approving the qualification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceIatf16949 rdf:type rdf:Property ;
    rdfs:label 'Compliance Iatf 16949' ;
    rdfs:comment 'True if the test complies with automotive quality standard IATF 16949.' ;
    rdfs:domain ind:ReliabilityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceIso9001 rdf:type rdf:Property ;
    rdfs:label 'Compliance Iso 9001' ;
    rdfs:comment 'True if the test complies with ISO 9001 quality management requirements.' ;
    rdfs:domain ind:ReliabilityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceJedec rdf:type rdf:Property ;
    rdfs:label 'Compliance Jedec' ;
    rdfs:comment 'True if the test follows applicable JEDEC reliability standards.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureMechanism rdf:type rdf:Property ;
    rdfs:label 'Failure Mechanism' ;
    rdfs:comment 'Physical mechanism responsible for the failure.' ;
