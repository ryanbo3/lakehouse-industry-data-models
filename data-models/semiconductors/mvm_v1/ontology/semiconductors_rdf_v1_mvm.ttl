    rdfs:range xsd:string .

ind:dppmRecordId rdf:type rdf:Property ;
    rdfs:label 'Dppm Record Id' ;
    rdfs:comment 'System-generated unique identifier for the DPPM record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DppmRecord .

ind:sourceFabToolId rdf:type rdf:Property ;
    rdfs:label 'Source Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: DPPM tracking by equipment enables equipment-related quality trending. Equipment performance scorecarding for supplier management and equipment qualification decisions depend on equipment-level DPPM t' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:sourceToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Source Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: Chamber-level DPPM tracking enables chamber matching and qualification decisions. Chamber-specific quality performance monitoring is essential for chamber utilization optimization and chamber certific' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:auditCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Created Timestamp' ;
    rdfs:comment 'Timestamp when the DPPM record was first created in the system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the DPPM record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Current closure state of the quality notification.' ;
