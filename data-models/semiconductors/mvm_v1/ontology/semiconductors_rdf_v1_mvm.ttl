ind:laborHoursPerWafer rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Per Wafer' ;
    rdfs:comment 'Total labor hours required to process a single wafer.' ;
    rdfs:domain ind:WaferCostModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborRateUsdPerHour rdf:type rdf:Property ;
