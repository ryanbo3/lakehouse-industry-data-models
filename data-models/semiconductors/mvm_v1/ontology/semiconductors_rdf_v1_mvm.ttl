    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Timestamp' ;
    rdfs:comment 'Date-time when the customer notification was sent.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionPoint rdf:type rdf:Property ;
    rdfs:label 'Detection Point' ;
    rdfs:comment 'Process step or system where the non-conformance was first detected.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieRange rdf:type rdf:Property ;
    rdfs:label 'Die Range' ;
    rdfs:comment 'Range of die numbers on the wafer affected (e.g., "100-200").' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionActionRequired rdf:type rdf:Property ;
    rdfs:label 'Disposition Action Required' ;
    rdfs:comment 'Specific actions required to implement the chosen disposition.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final decision on how the non-conforming material will be treated.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Initiated Timestamp' ;
    rdfs:comment 'Date-time when the quality hold was placed.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReleaseCondition rdf:type rdf:Property ;
    rdfs:label 'Hold Release Condition' ;
    rdfs:comment 'Condition(s) that must be satisfied to release the hold.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Released Timestamp' ;
    rdfs:comment 'Date-time when the quality hold was lifted (null if still active).' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impactAmount rdf:type rdf:Property ;
    rdfs:label 'Impact Amount' ;
    rdfs:comment 'Estimated monetary impact of the non-conformance.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the financial impact.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerImpact rdf:type rdf:Property ;
    rdfs:label 'Is Customer Impact' ;
    rdfs:comment 'Indicates whether the non-conformance impacts a customer.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrbDecision rdf:type rdf:Property ;
    rdfs:label 'Mrb Decision' ;
    rdfs:comment 'Decision made by the MRB regarding the non-conformance.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceDescription rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Description' ;
    rdfs:comment 'Narrative description of the deviation from specification.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceReportStatus rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Report Status' ;
    rdfs:comment 'Current lifecycle status of the report.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Business-visible identifier (NCR number) assigned to the report.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Timestamp' ;
    rdfs:comment 'Date-time when the non-conformance was initially recorded.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specificationViolated rdf:type rdf:Property ;
    rdfs:label 'Specification Violated' ;
    rdfs:comment 'Name or code of the specification that was not met.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedFabToolId rdf:type rdf:Property ;
    rdfs:label 'Audited Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Quality audits (ISO9001, IATF16949) include equipment qualification status verification. Audit finding closure tied to specific equipment is standard practice. Equipment certification status is a comm' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:auditedToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Audited Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: Chamber qualification audits require chamber-level traceability. Chamber certification status verification during audits is mandatory for process qualification and customer audits in semiconductor man' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Calendar date when the audit was completed.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Reference' ;
    rdfs:comment 'Identifier of the certification issued (if any) as a result of the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsTotal rdf:type rdf:Property ;
    rdfs:label 'Findings Total' ;
    rdfs:comment 'Aggregate number of findings recorded for the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:majorNonconformances rdf:type rdf:Property ;
    rdfs:label 'Major Nonconformances' ;
    rdfs:comment 'Count of major non-conformances identified.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNonconformances rdf:type rdf:Property ;
    rdfs:label 'Minor Nonconformances' ;
    rdfs:comment 'Count of minor non-conformances identified.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observations rdf:type rdf:Property ;
    rdfs:label 'Observations' ;
    rdfs:comment 'Number of observations (non-conformance but not a defect).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opportunitiesForImprovement rdf:type rdf:Property ;
    rdfs:label 'Opportunities For Improvement' ;
    rdfs:comment 'Count of OFI (Opportunity for Improvement) findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Final outcome of the audit after evaluation of all findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocument rdf:type rdf:Property ;
    rdfs:label 'Plan Document' ;
    rdfs:comment 'Reference (e.g., file name or URL) to the detailed audit plan.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned calendar date for the audit to commence.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:team rdf:type rdf:Property ;
    rdfs:label 'Team' ;
    rdfs:comment 'Comma-separated list of auditor identifiers or names participating in the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFabToolId rdf:type rdf:Property ;
    rdfs:label 'Measurement Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Specification Measurement Traceability links each spec to the Fab Tool that performs the measurement, required for ISO 9001 compliance.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Level of the product hierarchy the spec applies to.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Link to the detailed specification document.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Technique used to inspect or measure the parameter.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValidatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Validated Date' ;
    rdfs:comment 'Date of the most recent validation activity.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowerLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Limit' ;
    rdfs:comment 'Minimum acceptable value for the parameter.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominalValue rdf:type rdf:Property ;
    rdfs:label 'Nominal Value' ;
    rdfs:comment 'Target nominal value for the parameter.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualitySpecStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Spec Status' ;
    rdfs:comment 'Current lifecycle state of the specification.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specCode rdf:type rdf:Property ;
    rdfs:label 'Spec Code' ;
    rdfs:comment 'Unique business code assigned to the specification.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specName rdf:type rdf:Property ;
    rdfs:label 'Spec Name' ;
    rdfs:comment 'Human-readable name of the quality specification.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specType rdf:type rdf:Property ;
    rdfs:label 'Spec Type' ;
    rdfs:comment 'Category of the specification such as electrical, dimensional, visual, or reliability.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Limit' ;
    rdfs:comment 'Maximum acceptable value for the parameter.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validatedFlag rdf:type rdf:Property ;
    rdfs:label 'Validated Flag' ;
    rdfs:comment 'Indicates whether the specification has been validated against actual parts.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analysisFabToolId rdf:type rdf:Property ;
    rdfs:label 'Analysis Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: FA reports document equipment-related failure mechanisms. Equipment improvement recommendations from FA findings drive equipment modification and preventive maintenance optimization in semiconductor m' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:analysisToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Analysis Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: Chamber-level failure analysis (chamber-induced defects) requires chamber traceability. Chamber-specific failure mechanism documentation drives chamber PM optimization and chamber matching programs.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:primaryFailureNonconformanceReportId rdf:type rdf:Property ;
    rdfs:label 'Primary Failure Nonconformance Report Id' ;
    rdfs:comment 'FK to quality.nonconformance_report.nonconformance_report_id — FA reports are triggered by non-conformances. FA description explicitly states \'Links to... nonconformance_report\'. This is a critical investigation-to-disposition link.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NonconformanceReport .

ind:analysisEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis End Timestamp' ;
    rdfs:comment 'Timestamp when the failure analysis investigation was completed.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analysisStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Start Timestamp' ;
    rdfs:comment 'Timestamp when the failure analysis investigation began.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analysisTechnique rdf:type rdf:Property ;
    rdfs:label 'Analysis Technique' ;
    rdfs:comment 'Primary analytical method(s) employed during the failure investigation.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureAnalysisReportStatus rdf:type rdf:Property ;
    rdfs:label 'Failure Analysis Report Status' ;
    rdfs:comment 'Current lifecycle status of the report.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureSeverity rdf:type rdf:Property ;
    rdfs:label 'Failure Severity' ;
    rdfs:comment 'Severity rating assigned to the failure based on impact and recurrence risk.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureSiteLocation rdf:type rdf:Property ;
    rdfs:label 'Failure Site Location' ;
    rdfs:comment 'Physical location on the die/wafer where the failure was observed (e.g., metal layer 3, die X12Y7).' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTitle rdf:type rdf:Property ;
    rdfs:label 'Report Title' ;
    rdfs:comment 'Human-readable title of the failure analysis report.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Category indicating the origin of the failure analysis request.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDescription rdf:type rdf:Property ;
    rdfs:label 'Sample Description' ;
    rdfs:comment 'Brief description of the physical sample(s) examined (e.g., wafer lot, die coordinates, package type).' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingEvidenceRefs rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence Refs' ;
    rdfs:comment 'Comma-separated list of file paths or identifiers for images, data files, and test logs that support the analysis.' ;
    rdfs:domain ind:FailureAnalysisReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Identifier of the immediate parent cost center in the hierarchy.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate costs (e.g., headcount, fab utilization, revenue, custom).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Planned budget amount allocated to the cost center for the fiscal year.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetYear rdf:type rdf:Property ;
    rdfs:label 'Budget Year' ;
    rdfs:comment 'Fiscal year for which the budget amount applies.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'Controlling area to which the cost center belongs for internal reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Category classification such as expense, investment, or overhead.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Free-form description providing additional context about the cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group' ;
    rdfs:comment 'Logical grouping of cost centers for reporting (e.g., fab group, R&D group).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Human-readable name of the cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center (e.g., fab, R&D, corporate, support).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElement rdf:type rdf:Property ;
    rdfs:label 'Cost Element' ;
    rdfs:comment 'Cost element code associated with the cost center for expense categorization.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Code of the department to which the cost center belongs.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Indicates whether the cost center contains confidential financial information.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:naturalAccount rdf:type rdf:Property ;
    rdfs:label 'Natural Account' ;
    rdfs:comment 'General ledger natural account linked to the cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingLine rdf:type rdf:Property ;
    rdfs:label 'Reporting Line' ;
    rdfs:comment 'Organizational reporting line identifier for the cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibilityCenterCode rdf:type rdf:Property ;
    rdfs:label 'Responsibility Center Code' ;
    rdfs:comment 'Code of the responsibility center linked to the cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subdepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Subdepartment Code' ;
    rdfs:comment 'Code of the sub-department within the department.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toCompanyCode rdf:type rdf:Property ;
    rdfs:label 'To Company Code' ;
    rdfs:comment 'FK to finance.company_code.company_code_id — Cost centers belong to a specific company code/controlling area. Required for organizational hierarchy and reporting boundaries.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validityFlag rdf:type rdf:Property ;
    rdfs:label 'Validity Flag' ;
    rdfs:comment 'True if the cost center is within its validity period; false otherwise.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'Date when the cost center ceases to be effective (null if open-ended).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'Secondary classification such as operating, non-operating, or statutory.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'Business identifier used in the chart of accounts; often alphanumeric (e.g., 4000, 5-200).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Group identifier used for reporting aggregation (e.g., 4-Revenue, 5-COGS).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLevel rdf:type rdf:Property ;
    rdfs:label 'Account Level' ;
    rdfs:comment 'Hierarchical level of the account within the chart of accounts (e.g., 1-5).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSubgroup rdf:type rdf:Property ;
    rdfs:label 'Account Subgroup' ;
    rdfs:comment 'Sub-group within an account group for finer granularity.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amortizationFlag rdf:type rdf:Property ;
    rdfs:label 'Amortization Flag' ;
    rdfs:comment 'Indicates whether the account is subject to amortization (e.g., intangible assets).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'Balance of the account at the end of the fiscal year.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Method used to calculate depreciation for asset-type accounts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationRate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Rate' ;
    rdfs:comment 'Annual depreciation rate expressed as a percentage.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialStatement rdf:type rdf:Property ;
    rdfs:label 'Financial Statement' ;
    rdfs:comment 'Financial statement where the account is reported.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountDescription rdf:type rdf:Property ;
    rdfs:label 'Gl Account Description' ;
    rdfs:comment 'Extended textual description of the account purpose and usage.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Account Status' ;
    rdfs:comment 'Current lifecycle state of the account record.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBudgetControlled rdf:type rdf:Property ;
    rdfs:label 'Is Budget Controlled' ;
    rdfs:comment 'Indicates whether the account is subject to budgetary controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConsolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Is Consolidation Account' ;
    rdfs:comment 'Indicates whether the account participates in legal entity consolidation.' ;
