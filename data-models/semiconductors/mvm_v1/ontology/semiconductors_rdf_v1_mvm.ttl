    rdfs:comment 'Projected gross revenue per year from the design win before discounts or adjustments.' ;
    rdfs:domain ind:SalesDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualRevenueNet rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue Net' ;
    rdfs:comment 'Projected net revenue after adjustments.' ;
