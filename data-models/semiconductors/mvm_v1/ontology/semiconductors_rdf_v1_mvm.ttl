    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseClassification rdf:type rdf:Property ;
    rdfs:label 'Root Cause Classification' ;
    rdfs:comment 'High-level classification of the root cause.' ;
