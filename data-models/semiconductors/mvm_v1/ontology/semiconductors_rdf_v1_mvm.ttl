ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Human-readable name describing the cost model (e.g., "7nm High-Yield Model").' ;
    rdfs:domain ind:WaferCostModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siliconWaferCostUsd rdf:type rdf:Property ;
