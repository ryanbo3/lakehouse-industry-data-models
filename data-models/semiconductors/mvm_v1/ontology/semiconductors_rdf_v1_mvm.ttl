ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Name of the technician who ran the test.' ;
    rdfs:domain ind:ReliabilityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Status' ;
    rdfs:comment 'Current lifecycle status of the qualification program.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailCriteria rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Criteria' ;
    rdfs:comment 'Business rule defining pass or fail for the test (e.g., max failure rate).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Qualification Plan Version' ;
    rdfs:comment 'Version identifier of the qualification plan document.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityGrade rdf:type rdf:Property ;
