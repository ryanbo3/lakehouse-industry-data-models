    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'Reference to external documentation or audit trail (e.g., audit report ID).' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential order of the line within the depreciation run.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postedDate rdf:type rdf:Property ;
    rdfs:label 'Posted Date' ;
    rdfs:comment 'Date on which the depreciation entry was posted to the ledger.' ;
