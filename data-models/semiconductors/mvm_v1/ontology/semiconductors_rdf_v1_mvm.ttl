ind:waferCostModelStatus rdf:type rdf:Property ;
    rdfs:label 'Wafer Cost Model Status' ;
    rdfs:comment 'Current lifecycle status of the cost model.' ;
    rdfs:domain ind:WaferCostModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractVersion rdf:type rdf:Property ;
    rdfs:label 'Contract Version' ;
    rdfs:comment 'Version identifier for the NRE contract document.' ;
    rdfs:domain ind:FinanceNreAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeNreAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Finance Nre Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the NRE agreement.' ;
    rdfs:domain ind:FinanceNreAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMilestoneSchedule rdf:type rdf:Property ;
