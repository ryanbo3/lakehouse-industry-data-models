    rdfs:range xsd:string .

ind:costPerGoodDie rdf:type rdf:Property ;
    rdfs:label 'Cost Per Good Die' ;
    rdfs:comment 'Yield-adjusted cost allocated to each functional die.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Status' ;
    rdfs:comment 'Current lifecycle status of the cost record.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Indicates whether the cost is a standard, actual, or forecast figure.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVersion rdf:type rdf:Property ;
    rdfs:label 'Cost Version' ;
    rdfs:comment 'Version label of the cost record, typically reflecting fiscal period or revision cycle.' ;
