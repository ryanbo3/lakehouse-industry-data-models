    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:processToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Process Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: Inspection lots processed through specific chambers require chamber traceability for lot disposition decisions. Chamber hold/release decisions based on inspection results are standard semiconductor qu' ;
    rdfs:domain ind:Quality ;
