    rdfs:range xsd:decimal .

ind:impairmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator' ;
    rdfs:comment 'Flag indicating whether an impairment test has been performed and resulted in a loss.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationBay rdf:type rdf:Property ;
    rdfs:label 'Location Bay' ;
    rdfs:comment 'Specific bay or cleanroom area within the building housing the asset.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationBuilding rdf:type rdf:Property ;
    rdfs:label 'Location Building' ;
    rdfs:comment 'Name or code of the building where the asset is installed.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Maintenance Contract Number' ;
    rdfs:comment 'Contract identifier for the service agreement covering preventive maintenance.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Asset\'s carrying amount after subtracting accumulated depreciation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'Estimated remaining economic life of the asset, expressed in years.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Organizational department that owns or manages the asset.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Average operational utilization of the asset expressed as a percentage of its capacity.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetDepreciationId rdf:type rdf:Property ;
    rdfs:label 'Asset Depreciation Id' ;
    rdfs:comment 'System-generated unique identifier for each depreciation posting record.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Fixed Asset Id' ;
    rdfs:comment 'Unique identifier of the fab equipment or infrastructure asset being depreciated.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:assetDepreciationStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Depreciation Status' ;
    rdfs:comment 'Current processing status of the depreciation line.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'Accounting area for the depreciation amount – book (GAAP), tax, or IFRS.' ;
