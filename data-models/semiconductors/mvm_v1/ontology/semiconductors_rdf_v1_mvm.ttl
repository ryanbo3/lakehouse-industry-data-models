    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDescription rdf:type rdf:Property ;
    rdfs:label 'Allocation Description' ;
    rdfs:comment 'Free-form text describing the purpose or notes for the allocation.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRate rdf:type rdf:Property ;
    rdfs:label 'Allocation Rate' ;
    rdfs:comment 'Rate applied per unit of the allocation base (e.g., cost per machine hour).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Status' ;
    rdfs:comment 'Current processing status of the allocation record.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
