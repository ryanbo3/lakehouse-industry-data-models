    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weibullShapeParameter rdf:type rdf:Property ;
    rdfs:label 'Weibull Shape Parameter' ;
    rdfs:comment 'Shape parameter of the Weibull reliability model.' ;
