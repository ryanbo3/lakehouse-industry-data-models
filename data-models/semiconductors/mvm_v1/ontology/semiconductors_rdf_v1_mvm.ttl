# RDFS Schema for Business: Semiconductors

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/semiconductors#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Semiconductors ---
ind:Semiconductors rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Semiconductors' ;
    rdfs:comment 'Semiconductor is a high-technology industry that designs and fabricates advanced integrated circuits, processors, and chips powering computing, mobile, automotive, AI, and IoT applications across the digital economy.' .

# --- Domain Classes ---
ind:Fabrication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Fabrication' ;
    rdfs:comment 'Core wafer fabrication and processing domain governing all FAB operations including FEOL, MOL, and BEOL process steps. Owns wafer lot tracking, WIP management, process recipe execution, and fab line scheduling across CVD, PVD, ALD, CMP, ion implantation, and EUV/DUV lithography operations. Authoritative source for wafer genealogy and lot disposition via MES integration.' .

ind:Design rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Design' ;
    rdfs:comment 'IC design and architecture lifecycle from RTL specification through GDS/GDSII tapeout. Manages IP cores, PDK libraries, EDA tool flows, DFM and DFT rule sets, logic synthesis, physical design, timing closure data, and MPW shuttle assignments. Integrates with Cadence Virtuoso, Synopsys Design Compiler, and PrimeTime for design data provenance.' .

ind:Process rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Process' ;
    rdfs:comment 'Process engineering data for all semiconductor manufacturing process flows including photolithography, etch, diffusion, implant, deposition, and metrology steps. Manages SPC control charts, process capability indices, OPC rule sets, MEEF parameters, process qualification, yield optimization, and technology node readiness.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Product' ;
    rdfs:comment 'Authoritative semiconductor product catalog encompassing ICs, SoCs, ASICs, FPGAs, IP cores, and discrete devices. SSOT for product specifications, SKUs, BOM, process node assignments, PPA metrics, product lifecycle status (NPI through EOL), PCN management, and LTB notifications. Integrates with PLM systems.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all customer identity, account hierarchy, and relationship data. Manages OEM, fabless design house, ODM, distributor, and automotive customer profiles, contacts, segmentation, design-win engagement records, and customer qualification status. Integrates with Salesforce CRM.' .

ind:Sales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Sales' ;
    rdfs:comment 'Sales pipeline, opportunities, quotes, design-win campaigns, NRE agreements, pricing, and customer contracts. Manages sales territories, account assignments, forecast accuracy, revenue targets by product family, end market, and geography. Integrates with Salesforce CRM and SAP SD.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Order' ;
    rdfs:comment 'Customer orders, order fulfillment, delivery schedules, and shipment tracking. SSOT for order-to-cash lifecycle including order entry, wafer start authorizations, die bank orders, allocation, backlog management, and delivery confirmation. Manages MPW orders and production lot assignments.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Quality' ;
    rdfs:comment 'Quality assurance, reliability testing, defect inspection, metrology, DPPM tracking, FMEA, and qualification programs. Manages KGD certification, yield analysis, customer quality notifications, and compliance with ISO 9001, IATF 16949, and JEDEC reliability standards. Integrates with KLA ICOS inspection systems.' .

ind:Test rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Test' ;
    rdfs:comment 'Wafer probing, die sort, final test, and reliability testing operations. Manages ATPG programs, ATE configurations, test coverage, bin mapping, test yield, parametric test data, and correlation studies between wafer-level and package-level test. Distinct from quality domain which focuses on QMS and compliance.' .

ind:Equipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Equipment' ;
    rdfs:comment 'Semiconductor manufacturing equipment assets including lithography scanners, deposition systems, etchers, CMP tools, ATE platforms, and metrology/inspection systems. Manages equipment qualification, utilization, preventive/corrective maintenance schedules, calibration, and tool performance metrics supporting OEE.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Inventory management for WIP wafer lots, raw materials (silicon wafers, chemicals, gases, photomasks), finished goods (packaged chips), die banks, and consignment stock at OSAT partners. Tracks lot traceability, KGD status, bin classifications, shelf life, storage conditions, and inventory valuation.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Supply' ;
    rdfs:comment 'End-to-end semiconductor supply chain including supplier master data, raw material procurement, subcontractor management, OSAT vendor relationships, and inbound logistics. Owns supplier qualification records, approved vendor lists, lead time data, supply risk assessments, and material planning.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Corporate financial management including general ledger, cost center accounting, capital expenditure tracking for fab equipment, R&D capitalization, budget planning, financial consolidation, NRE cost recovery, wafer cost modeling, and fab utilization-based cost allocation. Supports SOX-compliant financial reporting.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Regulatory compliance including export controls (EAR, ITAR), environmental regulations (RoHS, REACH, TSCA), trade compliance, CHIPS Act reporting, and industry standards adherence (SEMI, JEDEC, ISO). Manages compliance audits, certifications, product substance declarations, export license records, and regulatory filings.' .

# --- Data Product Classes (Tables) ---
ind:IcDesignProject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Ic Design Project' ;
    rdfs:comment 'Master record for an IC design project lifecycle from RTL specification through GDS/GDSII tapeout. Captures project identity, target process node, design type (ASIC, SoC, FPGA), PPA targets (power budget, clock frequency, die area), tapeout milestone dates, NRE budget, design team assignments, EDA tool suite version, hierarchical block decomposition, and PLM integration references. SSOT for all design project metadata including block-level partitioning. Managed in Siemens Teamcenter PLM and Oracle Agile PLM.' .

ind:DesignIpCore rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Design Ip Core' ;
    rdfs:comment 'Master catalog of reusable Intellectual Property (IP) cores available for integration into IC designs. Tracks IP type (hard macro, soft IP, firm IP), function category (CPU, GPU, NPU, SerDes, PHY, memory controller, analog, RF), process node compatibility matrix, PPA characterization data, licensing terms and royalty structure, version history, silicon-proven status, EDA tool compatibility, and compliance with industry interface standards (AMBA, PCIe, USB). Sourced from internal IP library and third-party vendors (ARM, Synopsys DesignWare, Cadence Tensilica). SSOT for IP core definitions used across design projects.' .

ind:Pdk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Pdk' ;
    rdfs:comment 'Process Design Kit (PDK) master record defining the foundry-specific design rules, device models, standard cell libraries, and technology files required for IC design at a given process node. Captures PDK version, foundry name, process node (e.g., 3nm, 5nm, 7nm), SPICE model sets, DRC/LVS rule decks, layer stack definitions, and EDA tool compatibility matrix. SSOT for PDK versioning used in Cadence Virtuoso and Synopsys Design Compiler flows.' .

ind:RtlSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Rtl Specification' ;
    rdfs:comment 'Register Transfer Level (RTL) design specification and source record capturing the functional hardware description of a design block, IP subsystem, or full chip. Tracks RTL module hierarchy, HDL language (VHDL, Verilog, SystemVerilog, Chisel), design intent documentation, clock domain definitions and CDC boundary annotations, reset strategy, interface protocols (AXI, AHB, APB, Wishbone), power domain definitions (UPF/CPF), functional coverage model targets, lint rule compliance status, and linkage to the parent IC design project. For analog/mixed-signal blocks, captures behavioral model references (Verilog-AMS, VHDL-AMS) and links to transistor-level schematic source in Cadence Virtuoso where applicable. For FPGA targets, captures synthesis constraints, pin assignments, and target device family. Managed as a versioned artifact in revision control (Git, Perforce) with provenance tracking through Siemens Teamcenter PLM.' .

ind:Netlist rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Netlist' ;
    rdfs:comment 'Synthesized netlist artifact produced by logic synthesis tools (Synopsys Design Compiler) from RTL. Captures netlist type (pre-synthesis, post-synthesis, post-layout), gate count, cell library version, synthesis constraints file reference, timing slack summary, power estimate, and linkage to the RTL specification and PDK version used. Tracks netlist versions across design iterations for design provenance.' .

ind:TimingAnalysisRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Timing Analysis Run' ;
    rdfs:comment 'Static Timing Analysis (STA) run record produced by Synopsys PrimeTime capturing timing closure status for a design at a specific design stage. Tracks worst negative slack (WNS), total negative slack (TNS), setup/hold violations count, operating corner (PVT), clock frequency targets, analysis mode (pre-CTS, post-CTS, post-route), and pass/fail status. Enables timing closure tracking across design iterations.' .

ind:PhysicalLayout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Physical Layout' ;
    rdfs:comment 'Physical design layout record representing the floorplan, placement, clock tree, and routing state of an IC design at a specific stage in the physical implementation flow. Captures die dimensions and core area, cell utilization percentage, routing congestion metrics by metal layer, DRC violation count and categories, LVS clean status, metal layer stack usage and fill density, power grid IR-drop analysis results, clock tree synthesis (CTS) metrics (skew, insertion delay), electromigration compliance status, antenna rule violations, and GDS/GDSII or OASIS file reference. Tracks physical design iterations from initial floorplan through final tapeout-ready layout in Cadence Innovus, Synopsys ICC2, or Siemens Aprisa. SSOT for physical design state at each iteration checkpoint.' .

ind:Tapeout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Tapeout' ;
    rdfs:comment 'Tapeout event record capturing the final design submission milestone for manufacturing. Records tapeout date, GDS/GDSII file version, mask set identifier, foundry submission reference, PDK version used, final DRC/LVS clean status, OPC/RET processing status, design sign-off checklist completion, NRE cost committed, and MPW shuttle assignment if applicable. SSOT for tapeout provenance linking design to fabrication domain.' .

ind:MpwShuttle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Mpw Shuttle' ;
    rdfs:comment 'Multi-Project Wafer (MPW) shuttle record managing shared wafer runs where multiple IC designs are fabricated together to reduce NRE costs. Captures shuttle name, foundry, process node, scheduled tapeout date, wafer start date, participating design projects, allocated die area per project, shuttle coordinator, cost-sharing terms, and shuttle status. Bridges design domain to fabrication domain for low-volume prototype runs.' .

ind:EdaTool rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Eda Tool' ;
    rdfs:comment 'EDA (Electronic Design Automation) tool master record cataloging all licensed design automation tools used across the IC design flow. Captures tool name, vendor (Cadence, Synopsys, Siemens EDA, Ansys), tool category (synthesis, simulation, formal verification, place-and-route, STA, DRC/LVS, parasitic extraction, power analysis, signal integrity), version, license type (node-locked, floating, subscription), license count, supported process nodes, flow integration points, and license utilization metrics. SSOT for EDA tool inventory, version management, and license compliance.' .

ind:RuleSet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Rule Set' ;
    rdfs:comment 'Design rule set master record defining collections of DFM (Design for Manufacturability), DFT (Design for Testability), and custom design rules beyond the base PDK rule deck. Captures rule set type (supplemental DRC, project-specific LVS, ERC, DFM recommended rules, DFT scan insertion rules, antenna rules, density rules), rule version, foundry source or internal engineering team, applicable PDK version baseline, rule count, severity classification, waiver policy and approved waiver log, tool compatibility (Calibre, IC Validator, Pegasus), and deviation approval workflow. Enables project-specific rule customization, rule evolution tracking, and consistent enforcement across design teams beyond the foundry-standard PDK rules.' .

ind:SimulationRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Simulation Run' ;
    rdfs:comment 'Verification and checking execution record capturing all pre-silicon verification run results including functional simulation (RTL, gate-level, SPICE, mixed-signal AMS co-simulation), design rule checking (DRC, LVS, ERC), formal verification (equivalence checking, model checking, property checking, CDC analysis, RDC analysis), power integrity analysis (IR-drop, EM), signal integrity analysis, and reliability checking (electromigration, self-heating). Tracks run type, EDA tool and version used, rule deck or stimulus/testbench reference, functional/code/toggle/assertion coverage achieved, violation count and severity breakdown, overall pass/fail status, compute resources consumed (CPU hours, memory peak), run duration, operating corner conditions (PVT - process, voltage, temperature), design stage (pre-synthesis, post-synthesis, post-layout), regression suite membership, and linkage to the specific netlist, RTL, or physical layout version verified. Provides the complete audit trail for design verification closure and tapeout sign-off compliance.' .

ind:Milestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Milestone' ;
    rdfs:comment 'Design milestone and gate review record tracking key lifecycle checkpoints and formal sign-off events in an IC design project. Captures milestone type (RTL freeze, design freeze, netlist freeze, floorplan complete, timing closure, DRC/LVS clean, tapeout readiness), planned and actual dates, sign-off authority, gate criteria met/failed, review participants, findings and action items, approval disposition (approved, conditionally approved, rejected), outstanding waivers with justifications, and blockers. SSOT for design schedule adherence, quality governance, and tapeout authorization audit trail.' .

ind:VerificationPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Verification Plan' ;
    rdfs:comment 'Design verification plan master record defining the pre-silicon verification strategy for an IC design project. Captures verification methodology (UVM, formal, emulation, FPGA prototyping), coverage goals (functional, code, toggle, assertion), testbench architecture, simulation environment configuration, DFT strategy (ATPG, BIST, scan chain, boundary scan), verification milestones and schedule, tool assignments, regression suite definitions, bug tracking integration, and sign-off criteria. For automotive and safety-critical designs, captures ISO 26262 functional safety verification requirements including ASIL decomposition, safety mechanism coverage targets, fault injection campaign plans, and FMEDA linkage. Ensures systematic verification coverage and regulatory compliance before tapeout.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order' ;
    rdfs:comment 'Master record for all customer sales orders in the semiconductor order-to-cash lifecycle. Captures order header information including customer identity, order type (standard IC, ASIC, FPGA, MPW, NRE), order date, requested delivery date, priority, incoterms, payment terms, currency, total order value, and order status. SSOT for all customer-placed orders including wafer start authorizations, die bank orders, and production lot assignments. Sourced from SAP S/4HANA SD module.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Line' ;
    rdfs:comment 'Individual line items within a customer sales order, each representing a distinct semiconductor product SKU, quantity, unit price, requested ship date, confirmed ship date, and line-level status. Captures product configuration details such as package type, speed grade, temperature range, and special handling requirements. Supports partial shipments and line-level allocation tracking. Sourced from SAP S/4HANA SD order line items.' .

ind:WaferStartAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Wafer Start Authorization' ;
    rdfs:comment 'Formal authorization record that triggers wafer fabrication starts in the FAB for a specific customer order or forecast commit. Captures authorized wafer quantity, target process node, fab site, planned start date, priority class (hot lot, standard, MPW), NRE flag, and linkage to the originating sales order or die bank replenishment plan. SSOT for wafer start demand signals passed from order management to manufacturing execution (MES). Bridges order domain to fabrication domain.' .

ind:MpwOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Mpw Order' ;
    rdfs:comment 'Multi-Project Wafer (MPW) order record managing shared wafer shuttle runs where multiple customer designs are co-fabricated on a single wafer. Captures shuttle run ID, process node, fab site, reticle slot assignments per customer, die quantity per design, NRE charges, tapeout deadline, planned wafer start date, and delivery schedule. Supports fabless customers and design houses participating in MPW programs. Distinct from standard production orders due to shared-reticle economics and slot-based allocation.' .

ind:DieBankOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Die Bank Order' ;
    rdfs:comment 'Order record for drawing down inventory from a customer-specific or generic die bank (KGD inventory held in wafer or singulated die form). Captures die bank source lot, requested die quantity, die type, package conversion instructions, requested delivery date, and fulfillment status. Supports just-in-time packaging and assembly workflows where die inventory is pre-built and orders trigger OSAT packaging runs. Distinct from wafer start orders as no new fab starts are required.' .

ind:DeliverySchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'Planned and confirmed delivery schedule for customer orders, capturing multiple delivery windows per order line. Records scheduled delivery date, confirmed quantity, ship-from location (fab, OSAT, warehouse), ship-to customer location, carrier, incoterms, and schedule line status. Supports rolling delivery schedules for high-volume customers with blanket orders and periodic call-offs. Sourced from SAP S/4HANA SD schedule lines.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Physical shipment record tracking the outbound movement of semiconductor products from origin (fab, OSAT, distribution center) to customer destination. Header captures shipment number, carrier, tracking number, ship date, estimated and actual arrival dates, package count, gross weight, HS tariff codes, export license reference, and shipment status. Line-level detail captures shipped quantity per order line, lot numbers, wafer lot IDs, package types, serial numbers, unit of measure, and inspection certificate references. Delivery confirmation section captures proof of delivery (POD) including confirmed receipt date, receiving location, confirmed quantity, customer PO reference, discrepancy flags (quantity shortage, wrong part, damaged goods), and customer signoff reference. POD receipt triggers downstream invoice release and revenue recognition. Supports multi-leg shipments, cross-border trade compliance (EAR, ITAR), RMA dispute resolution, and full traceability from order line through physical delivery. Sourced from SAP S/4HANA SD outbound delivery, carrier POD data, and customer EDI 856 ASN acknowledgements.' .

ind:ShipmentLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Shipment Line' ;
    rdfs:comment 'Line-level detail of a shipment record, linking specific order lines and quantities to a physical shipment. Captures shipped quantity, unit of measure, lot number, wafer lot ID, package type, serial numbers (where applicable), and inspection certificate references. Enables traceability from customer order line to physical shipment and supports RMA and quality dispute resolution.' .

ind:BacklogPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Backlog Position' ;
    rdfs:comment 'Point-in-time snapshot of open order backlog for a specific order line, capturing unshipped committed quantity, backlog value, original promise date, current commit date, and backlog aging in days. Used for backlog management, revenue forecasting, customer escalation prioritization, and quarterly book-to-bill ratio reporting. Tracks push-outs, pull-ins, and cancellations affecting committed backlog. Critical for semiconductor revenue recognition, quarterly close processes, and investor guidance on backlog coverage.' .

ind:AllocationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Allocation Record' ;
    rdfs:comment 'Inventory, capacity, and lot allocation record that reserves specific wafer lots, die bank inventory, finished goods, or fab capacity against a customer order line. Captures allocated quantity, allocation type (hard/soft), allocated lot or inventory batch, lot number, lot type (wafer lot, die lot, packaged goods lot), assignment status (tentative, confirmed, shipped), assignment date, lot-specific quality disposition notes, allocation expiry date, and priority rank. SSOT for all allocation and lot-to-order assignment decisions in the order fulfillment process. Manages constrained supply allocation across competing customer orders during supply shortages. Supports automotive (IATF 16949) and aerospace lot-level traceability requirements from order through shipment.' .

ind:NreOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Nre Order' ;
    rdfs:comment 'Non-Recurring Engineering (NRE) order record capturing one-time engineering charges associated with custom IC design, mask set fabrication, or process qualification for a specific customer. Captures NRE type (mask NRE, design NRE, qualification NRE), total NRE amount, deliverable list, acceptance criteria, and linkage to the associated production order or design project. Includes milestone records defining specific engineering deliverables and payment triggers: milestone name, description, planned completion date, actual completion date, milestone amount, billing status, customer acceptance date, and acceptance signoff reference. Supports milestone-based revenue recognition for NRE contracts and tracks engineering project progress against contractual commitments. Distinct from recurring product orders due to milestone-based billing and engineering deliverable tracking.' .

ind:NreMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Nre Milestone' ;
    rdfs:comment 'Individual milestone record within an NRE order, defining specific engineering deliverables and associated payment triggers. Captures milestone name, description, planned completion date, actual completion date, milestone amount, billing status, customer acceptance date, and acceptance signoff reference. Supports milestone-based revenue recognition for NRE contracts and tracks engineering project progress against contractual commitments.' .

ind:Rma rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Rma' ;
    rdfs:comment 'RMA (Return Material Authorization) record managing customer returns of semiconductor products for quality issues, shipping damage, or end-of-life returns. Captures RMA number, return reason code, defect description, returned product and quantity, original order reference, disposition instruction (scrap, rework, credit, replacement), credit memo reference, and failure analysis request flag. SSOT for customer return workflows and DPPM tracking inputs.' .

ind:BlanketOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Blanket Order' ;
    rdfs:comment 'Long-term blanket purchase agreement with a customer defining total committed quantity, pricing tiers, and delivery cadence over a contract period (typically 12-24 months). Captures blanket order value, product mix, agreed unit prices, minimum order quantities, call-off frequency, remaining open quantity, and NCNR (non-cancellable non-returnable) terms. Supports high-volume OEM, automotive Tier-1, and distributor relationships where customers commit to annual volumes with periodic release orders against the blanket.' .

ind:InventoryWaferLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Wafer Lot' ;
    rdfs:comment 'Master record for a wafer lot (batch of wafers) moving through the FAB as work-in-process inventory. Tracks lot ID, wafer count, process node, product code, lot type (production/engineering/qualification), priority class, current operation step, WIP status (active/hold/complete/scrapped), start date, target completion date, hold flags, cumulative scrap count, good wafer count, and MES lot reference. SSOT for WIP lot identity and traceability across FEOL, MOL, and BEOL process stages within the inventory domain.' .

ind:RawMaterial rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Raw Material' ;
    rdfs:comment 'Master record for raw materials consumed in semiconductor manufacturing including silicon wafers (bare and epitaxial), process chemicals, specialty gases, photomasks, CMP slurries, and ALD precursors. Captures material code, description, material class, unit of measure, supplier part number, shelf life, storage temperature range, hazard classification (RoHS/REACH), reorder point, and safety stock level. SSOT for raw material identity in the inventory domain.' .

ind:FinishedGood rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Finished Good' ;
    rdfs:comment 'Master record for packaged semiconductor finished goods held in inventory including ICs, SoCs, ASICs, FPGAs, and discrete devices in final package form. Tracks SKU, product family, package type (WLCSP, BGA, QFN, CoWoS), device marking, date code, lot traceability code, HTS classification, RoHS compliance status, ECCN number for export control, and shelf life. Links to product domain SKU catalog.' .

ind:DieBank rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Die Bank' ;
    rdfs:comment 'Master record for die bank inventory — singulated known-good dies (KGD) stored in waffle packs, gel packs, or tape-and-reel awaiting packaging or direct shipment. Tracks die bank ID, product code, process node, die revision, KGD certification status, bin classification, quantity available, storage location, storage temperature, wafer lot origin, tapeout version, and die bank creation date. Critical for fabless and OSAT-model inventory management.' .

ind:PhotomaskAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Photomask Asset' ;
    rdfs:comment 'Master record for photomasks (reticles) used in photolithography patterning steps. Tracks mask ID, mask set name, layer name, technology node, EUV/DUV classification, mask generation (tapeout version), OPC version, MEEF value, mask vendor, mask type (binary/attPSM/altPSM), inspection status, defect count, usage count, maximum usage limit, storage location, and retirement date. Masks are high-value, reusable inventory assets.' .

ind:StorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Master record for physical and logical storage locations within FAB cleanrooms, chemical warehouses, gas cabinets, die bank vaults, and OSAT partner facilities. Captures location code, location name, facility type (cleanroom/warehouse/cold-storage/gas-cabinet/nitrogen-cabinet/die-vault), building, bay, row, shelf, temperature range, humidity range, ESD protection class, nitrogen purge capability, hazmat classification, maximum capacity, current utilization, and location status (active/blocked/decommissioned). Enables precise inventory placement, environmental compliance tracking, and MSD floor life management.' .

ind:StockBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Balance' ;
    rdfs:comment 'Transactional snapshot of on-hand inventory quantities by material, storage location, lot, and stock type (unrestricted, quality inspection, blocked, consignment). Captures quantity on hand, quantity available (unreserved), quantity reserved (linked to active inventory_reservation records), quantity in transit, quantity in WIP, unit of measure, last physical count date, and stock aging days. Supports real-time inventory visibility, ATP calculations, and production planning decisions. Financial valuation fields are maintained in stock_valuation.' .

ind:GoodsMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Goods Movement' ;
    rdfs:comment 'Transactional record for every inventory movement event: goods receipts from suppliers, goods issues to production, inter-location transfers, scrap disposals, returns, and posting reversals. Captures movement type, date, material, quantity, UoM, source/destination locations, reference document (PO/production order/delivery note), posting date, and document number. Provides the complete inventory audit trail required for SOX Section 404 controls, IATF 16949 traceability, and real-time stock balance updates.' .

ind:InventoryLotHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Lot Hold' ;
    rdfs:comment 'Transactional record capturing hold events placed on wafer lots or finished goods inventory. Tracks hold ID, lot reference, hold type (engineering/quality/customer/export-control), hold reason code, hold initiator, hold date, release date, release authority, hold disposition (rework/scrap/release/return), and associated quality notification or FMEA reference. Critical for quality management and regulatory compliance workflows.' .

ind:PhysicalInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Physical Inventory' ;
    rdfs:comment 'Transactional record of physical inventory count events including cycle counts, annual wall-to-wall counts, and triggered counts (post-movement discrepancy or system exception). Captures count document number, count date, material/lot reference, storage location, system book quantity, physically counted quantity, variance quantity, variance value, count status (planned/in-progress/completed/posted), recount flag, counter ID, supervisor approval, and posting date. Supports SOX Section 404 financial controls, IATF 16949 inventory accuracy requirements, and ISO 9001 documented evidence of stock verification.' .

ind:ConsignmentStock rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Consignment Stock' ;
    rdfs:comment 'Master record for inventory consigned to OSAT assembly/test partners or customer vendor-managed inventory (VMI) hubs where ownership transfers upon consumption or shipment. Tracks consignment agreement ID, OSAT partner reference, material/die bank reference, consigned quantity, consumed quantity, returned quantity, in-transit quantity, ownership transfer trigger (consumption/shipment/time-based), valuation currency, reconciliation frequency (weekly/monthly), last reconciliation date, settlement document reference, and liability aging. Enables monthly consignment settlement with OSAT partners, VMI replenishment automation, and accurate liability reporting for finance.' .

ind:StockValuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Valuation' ;
    rdfs:comment 'Transactional record capturing the financial valuation of inventory positions including WIP wafer lots, raw materials, die banks, and finished goods. Tracks valuation date, material or lot reference, valuation class, valuation method (standard cost/moving average/FIFO), standard price, moving average price, total stock value, WIP cost accumulation, NRE cost allocation, currency, and cost center. Supports SAP CO-PC product costing and SOX financial reporting.' .

ind:FabricationWaferLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Fabrication Wafer Lot' ;
    rdfs:comment 'Core master entity representing a wafer lot (batch of wafers) tracked through the FAB from wafer start to lot disposition. Authoritative source for lot identity, wafer count, lot type (production, engineering, qualification, MPW), process node, technology node, product code, priority class, WIP status, hold flags, and genealogy linkage. Sourced from Camstar MES and Applied Materials SmartFactory MES. SSOT for all WIP lot tracking across FEOL, MOL, and BEOL operations. Quality and metrology data for this lot is owned by the quality domain and referenced via cross-domain FK.' .

ind:Wafer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Wafer' ;
    rdfs:comment 'Individual silicon wafer entity within a lot, tracking wafer number, substrate type, diameter, orientation, resistivity, epitaxial layer specs, and current disposition. Enables per-wafer genealogy and yield tracking across all FAB process steps. Sourced from Camstar MES wafer tracking module.' .

ind:FabricationProcessRecipe rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Fabrication Process Recipe' ;
    rdfs:comment 'Master record for a validated process recipe defining the exact sequence of process parameters, tool settings, gas flows, temperatures, pressures, and timing for a specific FAB operation (CVD, PVD, ALD, CMP, implant, etch, lithography). Includes recipe version history, approval status, change control reference, qualification status, and effective date range. Versioning managed within this entity via version number and effective dates. Sourced from Applied Materials SmartFactory MES recipe management and integrated with engineering change order workflow.' .

ind:ProcessStep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Individual process step definition within a process flow routing, specifying step sequence number, operation type (FEOL/MOL/BEOL), process category (lithography, etch, deposition, CMP, implant, anneal, clean, wet clean), target recipe reference, equipment class constraint, SPC control plan linkage, rework loop indicators, and step-level cycle time targets. Forms the authoritative step catalog for all FAB routing and is the granular unit of WIP tracking. Aligned with SEMI E40 process management standard for step-level definition.' .

ind:ProcessFlow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Process Flow' ;
    rdfs:comment 'Ordered sequence of process steps defining the complete manufacturing route for a product on a given technology node. Captures flow revision, node generation (e.g., 5nm, 7nm, 28nm), flow type (standard, MPW, engineering), effective dates, and approval status. SSOT for FAB routing and WIP scheduling. Aligned with SEMI E40 process management standard for flow-level routing definition.' .

ind:LotMove rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Lot Move' ;
    rdfs:comment 'Transactional record of each WIP lot movement through a process step in the FAB, capturing move-in timestamp, move-out timestamp, operator ID, equipment used, recipe executed, actual process parameters, pass/fail disposition, and quantity in/out. Core MES transaction sourced from Camstar MES and SmartFactory MES. Enables cycle time analysis and WIP genealogy.' .

ind:WaferStart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Wafer Start' ;
    rdfs:comment 'Transactional record authorizing and recording the initiation of a new wafer lot into the FAB line, capturing wafer start date, authorized quantity, product code, technology node, priority class, customer order reference, and wafer start type (production, engineering, qualification, MPW). SSOT for FAB capacity consumption and WIP entry.' .

ind:FabricationLotHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Fabrication Lot Hold' ;
    rdfs:comment 'Transactional record capturing all hold events placed on a wafer lot, including hold reason code, hold type (engineering, quality, process excursion, customer), initiating system or operator, hold placement timestamp, release timestamp, and disposition action taken. Enables hold cycle time tracking and excursion management.' .

ind:LotDisposition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Lot Disposition' ;
    rdfs:comment 'Transactional record of final or interim lot disposition decisions including scrap, rework, accept, downgrade, or ship-as-is. Captures disposition type, disposition authority, disposition date, affected wafer count, yield impact, and root cause classification. Authoritative record for lot closure and yield accounting.' .

ind:FabRunCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Fab Run Card' ;
    rdfs:comment 'Master traveler document associated with a wafer lot defining the approved process flow, special instructions, engineering deviations, customer-specific requirements, and step-level notes for a given lot run. Captures run card version, approval status, deviation flags, and associated engineering change orders. Sourced from Camstar MES and Oracle Agile PLM.' .

ind:EquipmentRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Equipment Run' ;
    rdfs:comment 'Transactional record of a specific equipment tool run (chamber run, process run) executed on a wafer lot or wafer set. Captures tool ID, chamber ID, run start/end timestamps, recipe name and version, process type discriminator (CVD, PVD, ALD, CMP, implant, etch, lithography, anneal, clean, wet clean), actual vs. target parameter deviations, run status, and wafers processed. Process-type-specific parameters stored as structured attributes: implant (species, dose, energy, tilt, twist, beam current), deposition (film material, thickness, rate, precursor flows, uniformity), CMP (slurry type, removal rate, WIWNU, endpoint detection), lithography (reticle ID, exposure dose, focus offset, overlay, CD measurement). Unified model aligned with SEMI E10/E142 equipment event patterns. SSOT for all FAB process execution records.' .

ind:Photomask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Photomask' ;
    rdfs:comment 'Master record for photomasks (reticles) used in EUV and DUV lithography operations, capturing mask set ID, layer name, technology node, mask type (binary, PSM, EUV pellicle), OPC version, MEEF value, mask generation, pellicle status, inspection history summary, usage count, cleaning cycle count, and retirement threshold. SSOT for mask inventory, lithography step qualification, and reticle lifecycle management within the FAB.' .

ind:FabricationTechnologyNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Fabrication Technology Node' ;
    rdfs:comment 'Reference master for semiconductor technology nodes supported in the FAB, capturing node name (e.g., 5nm, 7nm, 28nm, 65nm), node generation, transistor architecture (planar, FinFET, GAA), minimum feature size, metal layer count, PDK version reference, qualification status, and production readiness date. SSOT for node-level process and product classification.' .

ind:FabYieldRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Fab Yield Record' ;
    rdfs:comment 'Transactional record capturing wafer-level and lot-level yield outcomes at key FAB inline checkpoints (post-FEOL, post-MOL, post-BEOL, pre-probe), recording gross die count, good die count, yield percentage, yield loss pareto by category (process, design, random defect, systematic), bin-level yield breakdown, and yield excursion flags. SSOT for FAB inline yield data distinct from final test yield (owned by test domain) and distinct from SPC/metrology analysis (owned by quality domain).' .

ind:IcCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Ic Catalog' ;
    rdfs:comment 'Master record for all semiconductor products (ICs, SoCs, ASICs, FPGAs, discretes, licensable IP cores). SSOT for product identity, internal/external part numbers, product family assignment, process node, target market, and lifecycle state with full NPI→qualification→production→EOL transition history. Golden record integrated with PLM. Each entry represents a unique silicon design with one or more orderable SKU variants.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock-keeping unit records representing orderable, shippable variants of catalog products. Each SKU captures the specific combination of package type, speed grade, temperature range, voltage variant, and qualification level (commercial, industrial, automotive AEC-Q100/Q101) that constitutes a distinct orderable item. Links to ic_catalog for the parent product definition and to inventory for stock tracking.' .

ind:Family rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Family' ;
    rdfs:comment 'Hierarchical grouping of related IC products into product families and sub-families (e.g., Cortex-class SoCs, automotive MCU family, RF transceiver family). Manages the multi-level product taxonomy used for roadmap planning, pricing strategy, and customer design-in targeting. Supports up to five levels of hierarchy: portfolio → family → sub-family → product → variant.' .

ind:ProcessNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Process Node' ;
    rdfs:comment 'Reference master for semiconductor process technology nodes (e.g., 3nm GAA, 5nm FinFET, 7nm EUV, 28nm HKMG, 180nm BCD). Captures node name, lithography generation (EUV/DUV), foundry source, PDK version, minimum feature size, metal layer count, and qualification status. Used to assign products to manufacturing process capabilities and to track node-level yield and cost baselines.' .

ind:ProductSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Spec' ;
    rdfs:comment 'Detailed electrical, functional, and PPA (Power-Performance-Area) specifications for each IC product at given operating condition corners. Covers operating voltage range, temperature range, I/O count, interface protocols, memory configuration, security features, functional safety ratings (ISO 26262 ASIL, IEC 61508 SIL), plus target and achieved values for dynamic power, leakage power, maximum frequency, and die area. Supports multi-corner characterization and competitive PPA benchmarking.' .

ind:Bom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bom' ;
    rdfs:comment 'Bill of Materials header records defining the hierarchical component structure of each IC product assembly. Captures BOM revision, effectivity dates, BOM type (engineering, manufacturing, service), approval status, and overall RoHS/REACH compliance rollup. Parent entity for bom_line detail records. Integrates with PLM and ERP systems for manufacturing execution and change management.' .

ind:BomLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bom Line' ;
    rdfs:comment 'Line items within a product BOM, each representing a component or sub-assembly. Captures component part number, quantity per assembly, UoM, component type (die, package substrate, passive, interposer), approved substitutes, lead time, and compliance attributes (RoHS, REACH, conflict minerals). Supports multi-level BOM explosion for cost rollup and supply chain risk analysis.' .

ind:Pcn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Pcn' ;
    rdfs:comment 'Product Change Notification records documenting all planned changes to product specifications, materials, manufacturing processes, or package configurations. Captures PCN number, change type (process, material, package, test), affected SKUs, change rationale, qualification plan, customer notification list, JEDEC JESD46 compliance status, and implementation timeline. Integrates with Oracle Agile PLM change management workflow.' .

ind:LtbNotification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Ltb Notification' ;
    rdfs:comment 'Last Time Buy notification records issued when a product reaches EOL, specifying the final order date, final shipment date, recommended replacement product, minimum order quantity for LTB, and customer acknowledgment tracking. Manages the formal LTB process per JEDEC JESD48 standard, ensuring customers have adequate notice to qualify replacement parts or place bridge inventory orders.' .

ind:ProductIpCore rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Ip Core' ;
    rdfs:comment 'Intellectual Property core catalog for reusable silicon IP blocks available for integration into SoC and ASIC designs, including hard IPs (PHYs, memory compilers, analog blocks) and soft IPs (processor cores, interface controllers, security engines). Captures IP name, version, process node compatibility, licensing model (royalty-free, per-unit royalty, NRE), PPA characteristics, verification status, and EDA tool compatibility.' .

ind:ProductQualificationProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Qualification Program' ;
    rdfs:comment 'Product qualification program records defining the reliability and environmental test plan required before production release gate. Captures qualification standard (JEDEC JESD47, AEC-Q100/Q101/Q104, MIL-STD-883, customer-specific), test matrix, sample plan, stress conditions (HTOL, HAST, TC, ESD, latch-up), duration, pass/fail criteria, qualification status, completion date, and any deviations or waivers granted. Gate-keeps product lifecycle transition from NPI to volume production.' .

ind:ComplianceCert rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Compliance Cert' ;
    rdfs:comment 'Product compliance certification records tracking regulatory and standards certifications obtained for each product or SKU, including RoHS, REACH, TSCA, AEC-Q100/Q101, ISO 26262, IEC 61508, UL, CE, FCC, and ITAR classification. Captures certification body, certificate number, issue date, expiry date, applicable markets/regions, and re-certification trigger events. Supports export control screening and customer compliance documentation requests.' .

ind:Errata rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Errata' ;
    rdfs:comment 'Product errata records documenting known silicon bugs, functional deviations, and workarounds for released IC products. Captures errata ID, affected product and revision, silicon stepping, errata title, functional impact description, affected use cases, workaround availability, fix target (next silicon revision or software workaround), customer disclosure status, and severity classification. Critical for customer technical support and design-in risk management.' .

ind:Flow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Flow' ;
    rdfs:comment 'Master definition of a semiconductor manufacturing process flow (recipe sequence) for a given technology node. Captures the ordered sequence of unit process steps from FEOL through MOL and BEOL, including process node designation (e.g., 5nm, 3nm, 28nm), flow revision, qualification status, applicable device families, and PDK linkage. SSOT for all process flow definitions used in wafer fabrication.' .

ind:Step rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Step' ;
    rdfs:comment 'Individual unit process step within a process flow, representing a discrete manufacturing operation such as photolithography exposure, CVD deposition, CMP planarization, ion implantation, dry etch, wet clean, or metrology measurement. Captures step sequence number, operation type, tool class, target layer, nominal recipe parameters, and step classification (FEOL/MOL/BEOL). Owned by the process domain as the atomic building block of all process flows.' .

ind:Recipe rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Recipe' ;
    rdfs:comment 'Detailed equipment-level process recipe defining all controllable parameters for a specific unit process step on a specific tool class. Captures recipe name, version, tool class, chamber configuration, and all process parameter setpoints organized by process type: implant conditions (species, energy, dose, tilt, twist, beam current, anneal recipe), deposition conditions (method such as LPCVD/PECVD/ALD/PVD/EPI, target material, thickness, temperature, pressure, precursor flows, RF power, deposition rate, uniformity spec), etch conditions (type, chemistry, gas flows, pressure, RF source/bias power, etch rate, selectivity, CD bias, endpoint detection), CMP conditions (slurry, pad, platen pressure, carrier speed, table speed, endpoint detection, removal target, post-CMP clean, uniformity spec), and lithography conditions (scanner, wavelength, NA, sigma, illumination mode, resist type/thickness, exposure dose, focus offset, develop process, bake temperatures, OPC rule set reference). Includes recipe approval status, effective date range, qualification linkage, and full revision history. Sourced from Applied Materials SmartFactory MES and Camstar MES recipe management modules. SSOT for ALL equipment-level process parameters and conditions; no separate condition products exist — all process-type-specific parameters are attributes within this unified recipe entity.' .

ind:LotProcessRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Lot Process Run' ;
    rdfs:comment 'Transactional record of a wafer lot executing a specific process step on a specific piece of equipment. Captures lot ID reference, process step reference, equipment ID, operator ID, actual start and end timestamps, actual recipe used, chamber ID, lot disposition (pass/hold/scrap), and any in-line measurement results collected at that step. This is the core WIP tracking event for process engineering analysis. SSOT boundary: process domain owns the process-step-level execution record for engineering analysis; fabrication domain owns the lot lifecycle (lot creation, split, merge, hold, scrap, ship) and overall WIP status. Sourced from Camstar MES and Applied SmartFactory MES lot history.' .

ind:SpcControlChart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Spc Control Chart' ;
    rdfs:comment 'Statistical Process Control (SPC) control chart definition and complete measurement history for a monitored process parameter at a specific process step. Chart definition captures chart type (Xbar-R, Xbar-S, EWMA, CUSUM, IMR), monitored parameter name, control limits (UCL, LCL, UWL, LWL), target value, sample size, sampling frequency, chart owner, and current chart status. Measurement detail (header+line pattern) captures all individual data points: measured value, measurement timestamp, lot reference, wafer number, site coordinates, measurement tool ID, chart rule violations triggered (Western Electric rules, Nelson rules), and resulting process action (none, warning, OCAP triggered). Implements SEMI E10 and JEDEC SPC guidelines. Sourced from KLA ICOS and in-line metrology tools. SSOT for all SPC monitoring definitions and measurement data in the process domain.' .

ind:SpcMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Spc Measurement' ;
    rdfs:comment 'Individual SPC data point recorded against a control chart for a specific lot or wafer at a process step. Captures the measured value, measurement timestamp, lot reference, wafer number, site coordinates, measurement tool ID, chart rule violations triggered (Western Electric rules, Nelson rules), and resulting process action (none, warning, out-of-control action plan triggered). Primary transactional feed for real-time SPC monitoring sourced from KLA ICOS and in-line metrology tools.' .

ind:Capability rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Capability' ;
    rdfs:comment 'Process capability index record for a monitored parameter at a specific process step over a defined evaluation period. Captures Cp, Cpk, Pp, Ppk indices, mean, standard deviation, sample count, evaluation window start/end dates, specification limits (USL, LSL), target value, capability status (capable/marginal/incapable), and trend direction. Used for technology node readiness assessments and continuous improvement tracking per IATF 16949 and ISO 9001 requirements.' .

ind:OpcRuleSet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Opc Rule Set' ;
    rdfs:comment 'Optical Proximity Correction (OPC) rule set and MEEF characterization record for a specific lithography layer and technology node. Captures OPC model version, target layer name, technology node, lithography wavelength (EUV/DUV), scanner NA, illumination mode, rule set file reference, process bias tables, assist feature rules, qualification status, and complete MEEF characterization (MEEF value per feature type, pitch, CD target, process window DOF/EL, sigma illumination, NA, wavelength, measurement methodology). MEEF parameters are integral attributes of the OPC rule set as they characterize mask-to-wafer CD transfer fidelity within the OPC model context. Managed in conjunction with Synopsys and Cadence EDA OPC flows. SSOT for all OPC, MEEF, and lithography proximity correction data used in mask data preparation and CD tolerance specification.' .

ind:Qualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Qualification' ;
    rdfs:comment 'Process qualification program record tracking the formal qualification of a new process flow, process step, or process change against defined acceptance criteria. Captures qualification type (new process, process change, tool qualification, node readiness), qualification plan reference, start date, target completion date, actual completion date, qualification status (in-progress, passed, failed, waived), sign-off engineer, and disposition. Sourced from Oracle Agile PLM and Siemens Teamcenter PLM qualification workflows.' .

ind:ChangeNotification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Change Notification' ;
    rdfs:comment 'Process Change Notification (PCN) record documenting a planned or executed change to a qualified process flow, recipe, material, or equipment configuration that may affect product performance or reliability. Captures PCN number, change type (process, material, equipment, design), affected products, change description, risk assessment, customer notification requirements, implementation date, and approval status. Managed through Oracle Agile PLM and SAP QM change management workflows.' .

ind:YieldLossEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Yield Loss Event' ;
    rdfs:comment 'Transactional record of a yield loss event identified at a specific process step or inspection point for a wafer lot. Captures lot reference, process step, yield loss mode (parametric, systematic, random, electrical), defect density, affected die count, estimated yield impact, root cause category, corrective action reference, and resolution status. Primary input to yield optimization workflows and SPC out-of-control action plans (OCAPs).' .

ind:DefectInspectionResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Defect Inspection Result' ;
    rdfs:comment 'Wafer-level defect inspection result record from in-line inspection tools (KLA brightfield/darkfield scanners, e-beam inspection) captured at process engineering inspection steps for process monitoring and excursion detection. Captures wafer lot reference, inspection step, tool ID, inspection recipe, total defect count, defect density (defects/cm²), defect map file reference, defect classification breakdown by type and size, nuisance filter applied, and disposition. SSOT boundary: process domain owns in-line defect inspection results used for process monitoring, SPC, and excursion detection during manufacturing; quality domain owns outgoing quality inspection, reliability defect analysis, and customer-reported defect records. Sourced from KLA 29xx/39xx series and Applied Materials SEMVision.' .

ind:MetrologyMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Metrology Measurement' ;
    rdfs:comment 'In-line metrology measurement record capturing critical dimension (CD), overlay, film thickness, resistivity, or other physical parameter measurements taken on a wafer at a specific process step. Captures measurement type (CD-SEM, OCD, XRF, ellipsometry, overlay), tool ID, wafer lot reference, wafer number, measurement site map, per-site values, mean, 3-sigma, range, and pass/fail disposition against spec limits. Sourced from KLA ICOS and in-line metrology tools.' .

ind:ProcessTechnologyNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Process Technology Node' ;
    rdfs:comment 'Reference master for semiconductor technology nodes (process generations) supported by the fab. Captures node name (e.g., 5nm, 3nm, 28nm, 65nm), node generation, device architecture (planar, FinFET, GAA), minimum metal pitch, gate pitch, DRAM half-pitch, introduction year, production readiness status, and associated PDK version. Serves as the top-level classification anchor for process flows, OPC rule sets, and process capability records.' .

ind:Excursion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Process ;
    rdfs:label 'Excursion' ;
    rdfs:comment 'Process excursion record capturing any significant out-of-spec, out-of-control, or yield-impacting condition detected during wafer manufacturing that requires formal engineering investigation. Encompasses all yield loss events as a unified excursion type. Captures excursion detection source (SPC, inspection, metrology, electrical test), affected lot list, process step, excursion severity (minor/major/critical), yield loss mode (parametric, systematic, random, electrical), defect density, affected die count, estimated yield impact, detection timestamp, containment actions taken, root cause category, corrective action reference, investigation status, and final disposition. Serves as the single parent investigation record for all process-related yield and excursion events. Distinct from individual OCAP actions which are the immediate corrective responses. SSOT for process excursion and yield loss tracking; quality domain owns outgoing quality excursions and customer returns.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all semiconductor supply chain vendors including raw material suppliers, chemical suppliers, gas suppliers, photomask vendors, OSAT partners, and subcontractors. Captures supplier identity, classification (Tier 1/2/3), business registration, DUNS number, geographic footprint, financial health rating, strategic importance, and ITAR/EAR export control classification. SSOT for supplier identity across the supply domain. Sourced from SAP S/4HANA MM Vendor Master.' .

ind:ApprovedVendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Approved Vendor' ;
    rdfs:comment 'Approved Vendor List (AVL) records establishing which suppliers are qualified and authorized to supply specific material categories, chemical families, or process inputs to the fab. Tracks qualification status, approval date, expiry date, approved commodity scope, quality tier, and the engineering/procurement authority who granted approval. Supports DFM and process qualification gating. Sourced from Oracle Agile PLM and SAP MM.' .

ind:MaterialMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Material Master' ;
    rdfs:comment 'Authoritative master record for all procured materials used in semiconductor manufacturing: silicon wafer substrates, process chemicals (slurries, etchants, photoresists), specialty gases (silane, nitrogen, argon), photomasks, packaging substrates, lead frames, bonding wire, and consumables. Captures material number, description, material type, base unit of measure, hazardous material classification (RoHS/REACH/TSCA), storage conditions, shelf life, procurement lead time, safety stock levels, reorder points, and lot sizing parameters. SSOT for material identity and procurement parameters within the supply domain.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Procurement purchase orders issued to qualified suppliers for raw materials, process chemicals, gases, photomasks, equipment spare parts, and subcontracted services (OSAT assembly/test). Captures PO number, supplier, line items, ordered quantities, agreed unit price, currency, delivery schedule, Incoterms, payment terms, and export control classification (EAR/ITAR). Represents the legally binding procurement commitment. Sourced from SAP S/4HANA MM (EKKO/EKPO).' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Individual line items within a purchase order, each representing a distinct material or service being procured. Captures line number, material number, ordered quantity, unit of measure, net price, delivery date, plant/storage location destination, account assignment (cost center or WBS element), and goods receipt status. Enables granular tracking of multi-material POs and partial deliveries. Sourced from SAP S/4HANA MM (EKPO).' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Records the physical receipt of materials and goods at the fab or warehouse against a purchase order. Captures GR document number, posting date, received quantity, unit of measure, storage location, batch number, quality inspection lot reference, and movement type. Triggers inventory update and initiates incoming quality inspection. Sourced from SAP S/4HANA MM (MSEG/MKPF — movement type 101).' .

ind:SupplierQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Qualification' ;
    rdfs:comment 'Formal supplier qualification lifecycle records encompassing the full assessment, audit, and approval process for onboarding new suppliers or re-qualifying existing ones. Captures qualification program type (initial, periodic, change-triggered), assessment scope (quality system audit, process capability, material certification review), on-site and remote audit execution details (audit type — initial qualification, surveillance, for-cause; audit team composition; findings by severity — critical/major/minor; corrective action plans and closure tracking; overall audit rating), qualification criteria and pass/fail results, validity period, and approving engineer. SSOT for all supplier audit and qualification activity within the supply domain. Supports IATF 16949, ISO 9001, and SEMI standards supplier approval requirements.' .

ind:SupplierAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Audit' ;
    rdfs:comment 'Records of on-site and remote quality system audits conducted at supplier facilities. Captures audit type (initial qualification, surveillance, for-cause), audit date, audit team, scope of audit (ISO 9001, IATF 16949, SEMI standards), findings count by severity (critical, major, minor), corrective action plan status, and overall audit rating. Drives supplier performance management and AVL maintenance decisions.' .

ind:RiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Comprehensive supply risk management combining prospective risk assessments and actual disruption event records. Captures risk evaluations (risk category — single-source, geopolitical, financial, natural disaster, export control; probability, impact severity, risk score, mitigation strategy, buffer stock targets, alternate supplier identification, review cadence) and realized disruption incidents (disruption ID, event type — supplier factory shutdown, natural disaster, logistics delay, customs hold, quality hold, geopolitical trade restriction; affected supplier and materials, disruption start and end dates, impacted PO quantities, estimated fab impact in wafer starts at risk, escalation level, mitigation actions taken, resolution outcome). SSOT for all supply risk evaluation and disruption tracking within the supply domain. Supports supply chain resilience planning, CHIPS Act compliance reporting, and executive supply chain risk dashboards.' .

ind:SourcingContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Sourcing Contract' ;
    rdfs:comment 'End-to-end sourcing lifecycle records from initial solicitation through executed supply agreement. Covers RFQ issuance (commodity description, target quantity, technical specifications, evaluation criteria, submission deadline), supplier quotation responses (quoted unit price, currency, delivery lead time, MOQ, technical deviations), comparative evaluation and award decisions, and executed contract terms (contract number, supplier, commodity scope, effective and expiry dates, minimum order quantities, volume rebate tiers, price escalation clauses, force majeure terms, PCN notification obligations, quality requirements, and supply continuity obligations). SSOT for the complete RFQ-to-contract sourcing lifecycle within the supply domain. Distinct from customer-facing sales contracts owned by the sales domain.' .

ind:MaterialRequirementPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Material Requirement Plan' ;
    rdfs:comment 'Material Requirements Planning (MRP) run outputs defining planned procurement quantities and timing for all fab materials based on production schedules, wafer start plans, safety stock levels, and reorder points. Captures planning run date, material, plant, planned order quantity, planned delivery date, MRP type, lot sizing procedure, and exception messages (shortfall, excess, rescheduling). Sourced from SAP S/4HANA PP-MRP (MDKP/MDTB).' .

ind:InboundShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Shipment' ;
    rdfs:comment 'Inbound logistics records tracking the physical movement of procured materials from supplier origin to fab or warehouse destination. Captures shipment number, carrier, mode of transport (air, sea, road, courier), origin country, destination plant, estimated and actual arrival dates, freight cost, customs declaration number, Incoterms, hazardous goods classification, and cold chain requirements for temperature-sensitive chemicals. Supports landed cost calculation and supply continuity monitoring.' .

ind:SupplierScorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Scorecard' ;
    rdfs:comment 'Unified supplier performance management, corrective action, and continuous improvement records. Captures periodic scorecard assessments (scoring period, overall rating, on-time delivery rate, incoming quality rejection rate in DPPM, PCN compliance, strategic tier), plus formal Supplier Corrective Action Requests (SCARs) issued for quality escapes, inspection failures, delivery non-conformances, or audit findings. SCAR records include SCAR number, triggering event, defect description, 8D problem-solving steps (containment, root cause, corrective action, preventive action), supplier response due dates, verification status, and closure dates. SSOT for all supplier performance measurement and corrective action within the supply domain. Drives AVL status decisions, preferred supplier designations, FMEA-driven quality improvement, DPPM reduction programs, and annual supplier business reviews.' .

ind:OsatWorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Osat Work Order' ;
    rdfs:comment 'Work orders issued to OSAT (Outsourced Semiconductor Assembly and Test) subcontractors for backend services including die packaging, wire bonding, flip-chip assembly, wafer-level packaging (WLCSP, InFO, CoWoS), and final test. Captures work order number, OSAT vendor, package type, die quantity, substrate type, assembly process specification, target cycle time, NRE charges, unit assembly cost, delivery commit date, and shipment tracking. Primary transactional record for managing outsourced backend operations within the supply domain.' .

ind:SupplierCorrectiveAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Corrective Action' ;
    rdfs:comment 'Formal Supplier Corrective Action Requests (SCARs) issued to suppliers following quality escapes, incoming inspection failures, delivery non-conformances, or audit findings. Captures SCAR number, triggering event, defect description, 8D problem-solving steps (containment, root cause, corrective action, preventive action), supplier response due date, verification status, and closure date. Supports FMEA-driven quality improvement and DPPM reduction programs.' .

ind:MaterialCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Material Certification' ;
    rdfs:comment 'Supplier-originated material compliance documents including quality certifications and product change notifications. Captures Certificate of Conformance (CoC), Certificate of Analysis (CoA), RoHS compliance declarations, REACH SVHC declarations, TSCA certifications, and Product Change Notifications (PCNs). For certifications: certification type, issuing supplier, material lot number, test results, compliance standard, issue date, expiry date, and document reference. For PCNs: PCN number, supplier, affected material or component, change type (process, material, site, EOL), change description, effective date, impact assessment, required customer notification obligation, and re-qualification decision. SSOT for all supplier-originated material compliance and change documentation within the supply domain. Required for regulatory compliance, incoming quality release, process stability, and customer PCN pass-through obligations.' .

ind:SupplyForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supply Forecast' ;
    rdfs:comment 'Forward-looking supply demand forecasts communicated to strategic suppliers as rolling purchase forecasts (typically 12-52 week horizon) to enable supplier capacity planning and material pre-positioning. Captures forecast period, material, supplier, forecasted quantity by week/month, firm vs. indicative horizon split, forecast version, and variance from prior forecast. Supports supplier capacity reservation and LTB (Last Time Buy) planning for EOL materials.' .

ind:Opportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Opportunity' ;
    rdfs:comment 'Master record: Core sales opportunity tracking design-win campaigns, pipeline stages (Prospecting→Design-In→Design-Win→Production Ramp→Won/Lost), probability, and expected revenue for semiconductor IC, SoC, ASIC, and FPGA engagements. Sourced from Salesforce CRM Opportunity object. Captures end market (automotive, mobile, AI, IoT, computing), product family, target application, competitive landscape, NRE potential, design-win status, campaign grouping (campaign type, target segment, effectiveness metrics), and stage transition history for pipeline velocity analysis. SSOT for all sales pipeline activity including campaign-level aggregation for design-in programs, product launches, and competitive displacement initiatives.' .

ind:Quote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote' ;
    rdfs:comment 'Transaction record: Commercial price quotation issued to a customer or prospect for semiconductor products including ICs, packaged devices, wafer-level products, and IP licensing. Captures quoted unit price, volume tiers, lead time, validity period, incoterms, currency, and SAP SD quotation reference. Tracks quote-to-order conversion and win/loss outcomes.' .

ind:QuoteLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote Line' ;
    rdfs:comment 'Detail record: Individual line item within a sales quotation specifying a single semiconductor SKU, die, or IP core with its quoted quantity, unit price, discount, package type, lead time, and applicable pricing tier. Supports multi-line quotes covering mixed product families and end-market configurations.' .

ind:SalesDesignWin rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Design Win' ;
    rdfs:comment 'Transaction record: Confirmed design-win record capturing the moment a customer selects a semiconductor device for integration into their end product (PCB, module, or SoC platform). Records the winning device, customer design reference, target application, estimated annual unit volume (AUV), revenue ramp timeline, and competitive displacement details (displaced competitor, displaced device, displacement reason). Critical KPI for semiconductor commercial teams. Represents the key conversion event from opportunity to committed design.' .

ind:SalesNreAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Nre Agreement' ;
    rdfs:comment 'Master record: Non-Recurring Engineering (NRE) agreement governing custom IC or ASIC development engagements. Captures NRE fee structure, milestone payment schedule with individual billing/delivery milestones (RTL freeze, tapeout, first silicon, qualification), deliverables (RTL, GDS, PDK, tapeout), IP ownership terms, exclusivity clauses, and SAP SD contract reference. Contains milestone detail records tracking milestone name, planned/actual completion dates, milestone amounts, invoice trigger flags, approval status, and completion workflow. Enables NRE revenue recognition scheduling and project tracking. SSOT for all NRE commercial terms and milestone execution.' .

ind:PriceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Price List' ;
    rdfs:comment 'Master record: Master pricing repository defining standard and customer-specific pricing for semiconductor products by product family, package type, volume tier, and end market. Supports list price, distributor price, OEM price, and spot price variants. Contains price adjustment records capturing negotiated deviations, special bids, volume rebate adjustments, design-win incentives, and distributor markdowns with adjustment type, approved deviation amount, approval authority, validity windows, and SAP SD pricing condition override references. Integrates with SAP SD condition records and Salesforce CRM pricing engine. Tracks effective dates, supersession history, and full adjustment audit trail. SSOT for all semiconductor product pricing and price deviations.' .

ind:CustomerContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Customer Contract' ;
    rdfs:comment 'Master record: Long-term commercial contract with a semiconductor customer covering supply commitments, pricing agreements, volume guarantees, last-time-buy (LTB) provisions, product change notification (PCN) obligations, and end-of-life (EOL) terms. Distinct from NRE agreements — governs ongoing product supply rather than development services. Linked to SAP SD outline agreements.' .

ind:Territory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Master record: Sales territory definition and quota management assigning geographic regions, end markets, or named accounts to sales representatives and field application engineers (FAEs). Captures territory code, region hierarchy (global→regional→country→district), assigned sales rep, FAE coverage, revenue and unit targets by fiscal period (quarterly, half-year, annual), quota amounts, stretch targets, attainment tracking, and effective dates. Includes account-to-territory assignment details with assignment type (direct, distribution, rep firm), primary/secondary coverage flags, channel tier, and multi-rep coverage models. Supports territory realignment, overlay models (product specialists, strategic account managers), quota assignment workflows, and sales performance management common in semiconductor distribution channels. Used for compensation planning and quarterly business review (QBR) reporting.' .

ind:SalesForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Forecast' ;
    rdfs:comment 'Transaction record: Sales demand forecast capturing expected unit volume and revenue by product family, customer, end market, geography, and fiscal period. Supports rolling 12-month and 18-month forecast horizons used in semiconductor S&OP and wafer-start authorization processes. Tracks forecast version (commit, upside, best-case), submission date, confidence level, and variance against actuals. Integrates with SAP APO/IBP demand planning. Enables forecast accuracy KPI tracking (MAPE, bias) critical for fab capacity planning decisions.' .

ind:Booking rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Booking' ;
    rdfs:comment 'Transaction record: Confirmed sales booking representing a firm customer purchase order commitment for semiconductor devices. Captures booking date, booked revenue, booked units, device part number, customer account, ship-to location, requested delivery date, backlog status, and SAP SD sales order reference. Represents the commercial booking event — distinct from shipment or invoice. SSOT for bookings-to-billings (B2B) ratio, book-to-ship analysis, and revenue waterfall reporting critical to semiconductor quarterly earnings.' .

ind:Lead rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Lead' ;
    rdfs:comment 'Transaction record: Early-stage sales lead representing an unqualified potential customer or design opportunity. Captures lead source, contact information, target application, device interest, estimated opportunity size, lead status, and conversion outcome. Sourced from Salesforce CRM Lead object. Tracks lead-to-opportunity conversion funnel for semiconductor design-in campaigns.' .

ind:ChannelPartner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Channel Partner' ;
    rdfs:comment 'Master record: Authorized semiconductor sales channel partner including distributors (Arrow, Avnet, WPG), rep firms, value-added resellers (VARs), and system integrators. Captures partner type, authorized product lines, territory coverage, tier classification (authorized, preferred, elite), contract status, inventory reporting obligations (stock on hand, weeks of supply, sell-through, hub/consignment levels), and SAP SD partner function reference. SSOT for channel partner identity and distributor inventory visibility within the sales domain. Supports ship-from-stock-and-debit (SFSD) processing and price protection claim management.' .

ind:SalesDesignRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Design Registration' ;
    rdfs:comment 'Transaction record: Formal design registration submitted by a distributor or rep firm to claim sales credit and price protection for a specific customer design opportunity. Captures registered device, customer, end application, estimated annual volume, registration status (pending, approved, rejected, expired), approval date, and protected pricing terms. Prevents channel conflict and double-claiming in semiconductor distribution channels.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Program' ;
    rdfs:comment 'Master record for ATPG-generated and manually authored test programs used on ATE platforms, with full version lifecycle management. Captures program name, target device family, test type (wafer probe, die sort, final test, burn-in, SLT), ATE platform compatibility, ATPG tool used, coverage targets, and program lifecycle status. Includes version-level tracking: version number, change description, changed test flows or limits, validation status, release date, approved-by engineer, associated PCN/ECO reference, and change impact assessment. SSOT for all test program definitions and their complete evolution history across test operations.' .

ind:AteConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Ate Configuration' ;
    rdfs:comment 'Master configuration record for Automatic Test Equipment (ATE) platform setups used across wafer probe and final test operations. Captures tester model and platform type (e.g., Advantest V93000, Teradyne UltraFlex), hardware configuration revision, pin electronics card map, load board/DIB (Device Interface Board) revision and qualification status, instrument resource allocation, calibration status and due date, supported device families, maximum parallel site count, and configuration effective dates. SSOT for ATE setup definitions that test runs reference for full equipment traceability. Links to equipment domain for physical asset and maintenance tracking.' .

ind:ProbeCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Probe Card' ;
    rdfs:comment 'Master record for probe cards used in wafer probing operations, owned by test engineering for qualification, assignment, and performance tracking. Captures probe card type (cantilever, vertical, MEMS, advanced), needle/pin count, pitch, technology node compatibility, die site layout, touchdown count, maintenance cycle, current condition status, and assigned prober tool. Tracks probe card lifecycle from incoming qualification through active use to retirement, including needle replacement history and contact resistance trending. Links to equipment domain for physical asset management while test domain owns operational qualification and assignment decisions.' .

ind:BinDefinition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Bin Definition' ;
    rdfs:comment 'Reference master defining all test bin codes used in wafer sort and final test. Captures bin number, bin name, bin category (pass, functional fail, parametric fail, contact fail, leakage fail), disposition rule (ship, scrap, rework, hold), yield impact classification, and associated failure mode. Provides standardized bin taxonomy across all test programs and device families per JEDEC and internal standards.' .

ind:WaferProbeRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Wafer Probe Run' ;
    rdfs:comment 'Transactional record capturing each wafer probing execution event. Records wafer lot ID, wafer sequence number, probe card used, ATE configuration, test program version, prober tool, start and end timestamps, total die count, pass die count, fail die count, contact yield, gross die count, and operator ID. Core operational event for wafer-level electrical test and die sort operations.' .

ind:UnitTestResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Unit Test Result' ;
    rdfs:comment 'Transactional record capturing individual unit-level test results from all test insertions including wafer probing, die sort, final test, and system-level test (SLT). Records unit identifier (X/Y die coordinates for wafer-level or device serial/unit position for package-level), test insertion stage discriminator, assigned hard-bin and soft-bin codes per bin_definition, pass/fail status, total test time, parametric measurement summary flags, retest indicator and retest count, KGD (Known Good Die) qualification status, multi-die/chiplet assembly position, and test temperature/voltage condition. Serves as the single source of truth for all unit-level test outcomes across the entire test flow, enabling wafer map generation, unit-level yield analysis, full lot traceability, and die-to-package correlation. Aligns with STDF PTR/FTR/MPR record concepts.' .

ind:FinalTestRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Final Test Run' ;
    rdfs:comment 'Transactional record for package-level test execution events on ATE including final test and system-level test (SLT). Captures device lot ID, package type, test type discriminator (final_test, SLT), test configuration (socket, ATE, handler, SLT board), test program version, test temperature, test time, pass/fail counts, bin distribution, power consumption (SLT), boot success (SLT), and test site count. Covers all post-packaging test operations distinct from wafer-level probing.' .

ind:ParametricMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Parametric Measurement' ;
    rdfs:comment 'Transactional record storing individual parametric test measurements captured during wafer probe and final test. Records test parameter name, measured value, lower specification limit (LSL), upper specification limit (USL), pass/fail status, measurement unit, test condition (voltage, temperature, frequency), and associated die or device result. Enables SPC analysis, parametric yield optimization, and process-test correlation studies.' .

ind:Limit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Limit' ;
    rdfs:comment 'Master record defining parametric test limits for each test parameter by device type, product revision, and test condition. Captures parameter name, LSL, USL, target value, measurement unit, test condition set, limit revision history, effective date, and approval status. SSOT for all test specification limits used across ATPG programs and ATE test flows. Supports limit change management and PCN-driven limit updates.' .

ind:Coverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Coverage' ;
    rdfs:comment 'Master record tracking test coverage metrics for each test program version by device type. Captures fault coverage percentage, stuck-at fault coverage, transition fault coverage, path delay coverage, IDDQ coverage, DFT structure coverage (scan chains, BIST, boundary scan), and untestable fault count. Links test program to design DFT intent and supports tapeout readiness reviews.' .

ind:ReliabilityTestRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Reliability Test Run' ;
    rdfs:comment 'Transactional record for reliability, qualification, and burn-in stress screening test executions. Covers HTOL, HAST, ESD, latch-up, electromigration, and burn-in stress screens. Captures test type, stress conditions (temperature, voltage, humidity, bias), duration, sample size, device lot, burn-in board ID, failure count, acceleration factor, pre/post-stress test results, infant mortality rate, screen effectiveness, and qualification status per JEDEC standards. Consolidates all reliability and stress screening operations into a single transactional record.' .

ind:Insertion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Insertion' ;
    rdfs:comment 'Reference master defining the complete test insertion architecture for each device type within the manufacturing flow. Captures insertion name (wafer probe, die sort, pre-burn-in, burn-in, post-burn-in, final test, SLT, outgoing QA), sequence order in the flow, mandatory vs. optional vs. conditional flag, assigned test program reference, required ATE platform type, handler/prober requirement, yield gate criteria (minimum pass rate to proceed), test time budget allocation, cost per unit at this insertion, and insertion-level skip rules. SSOT for the test flow architecture governing which tests are performed at which manufacturing stage, in what sequence, and under what conditions. Critical for test cost modeling and flow optimization.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account' ;
    rdfs:comment 'Master record for all customer accounts in the semiconductor ecosystem, including OEMs, fabless design houses, ODMs, distributors, and automotive Tier-1 suppliers. SSOT for customer identity, legal entity name, DUNS number, account type, industry vertical, revenue tier, strategic classification, credit rating, payment terms, export control classification (EAR/ITAR), account status, preferred communication settings, packaging/labeling requirements, and Salesforce CRM account ID. Integrates with SAP S/4HANA SD module and Salesforce CRM Account object.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual contact persons associated with customer accounts, including design engineers, procurement managers, FAE (Field Application Engineers) counterparts, and executive sponsors. Captures full name, title, department, role type (technical, commercial, executive), email, phone, preferred communication channel, LinkedIn profile, GDPR consent status, and active/inactive status. Maps to Salesforce CRM Contact object.' .

ind:AccountHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Hierarchy' ;
    rdfs:comment 'Defines parent-child corporate hierarchy relationships between customer accounts, enabling roll-up of revenue, design-wins, and engagement metrics across global enterprise accounts. Captures parent account, child account, hierarchy level, relationship type (subsidiary, division, affiliate, distributor branch), effective date, and end date. Critical for global OEM and distributor account management.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Reference data defining market segmentation classifications for customer accounts. Each segment represents a strategic grouping used for go-to-market planning, pricing strategy, and resource allocation. Attributes include segment code, segment name (e.g., Hyperscaler, Automotive Tier-1, Consumer Electronics OEM, Industrial IoT, Government/Defense), vertical market, sub-vertical, strategic priority tier, TAM band, and assigned sales motion. Managed by sales strategy and marketing teams as controlled vocabulary.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical and mailing addresses associated with customer accounts and contacts, including headquarters, ship-to, bill-to, and design center locations. Captures address type, street lines, city, state/province, postal code, country (ISO 3166), region, time zone, and geolocation coordinates. Supports multi-site global accounts with multiple address records per account. Used for logistics, tax jurisdiction, and export control screening.' .

ind:CustomerDesignWin rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Customer Design Win' ;
    rdfs:comment 'Unified record tracking the full design-in lifecycle from initial registration through confirmed design-win for semiconductor products selected by customers. SSOT for the complete design-in pipeline from early registration through revenue forecasting — distinct from sales-domain opportunity records which track revenue probability and sales stage. Captures design project name, target end product/application (e.g., smartphone SoC, ADAS ECU, AI accelerator), platform generation, process node, package type, device/part number selected, design-win stage (registered, evaluating, sampling, won, lost, on-hold), registration date, design-win confirmation date, tapeout target date, production ramp date, estimated annual unit volume (AUV), estimated annual revenue, competitive displacement flag, associated distributor (if channel-sourced), FAE owner, and NRE requirements. Integrates with Salesforce CRM Opportunity.' .

ind:CustomerDesignRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Customer Design Registration' ;
    rdfs:comment 'Formal registration of a customer design project that uses a specific semiconductor product, capturing the design project name, target application, platform generation, process node, package type, design start date, tapeout target date, production target date, design registration status, and associated distributor (if applicable). Enables early pipeline visibility and NRE planning. Precedes and feeds into design_win records.' .

ind:QualificationStatus rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Tracks the qualification and approval status of a customer account or specific customer site for purchasing and receiving semiconductor products, including automotive PPAP (Production Part Approval Process) qualification, AEC-Q100/Q101 compliance acknowledgment, IATF 16949 certification status, customer-specific qualification requirements, qualification start date, qualification completion date, qualified product families, and qualification expiry date. Critical for automotive and industrial customer management.' .

ind:NdaAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Nda Agreement' ;
    rdfs:comment 'Non-Disclosure Agreement records between the semiconductor company and customer accounts, capturing NDA type (mutual, one-way), execution date, expiry date, covered scope (product roadmap, process technology, pricing), signatory contacts, legal entity names, NDA status (active, expired, under renewal), and document reference ID. Required before sharing roadmap, PDK, or pre-production device information with customers.' .

ind:AccountTeam rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Team' ;
    rdfs:comment 'Assignment of internal sales, FAE, and support personnel to customer accounts, defining the account coverage team structure. Captures team member employee ID, account ID, role (Account Manager, FAE, Regional Sales Manager, Application Engineer, Customer Success Manager), territory, assignment start date, assignment end date, primary contact flag, and coverage region. Enables account ownership tracking and workload management.' .

ind:DistributorAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Distributor Agreement' ;
    rdfs:comment 'Master records of distribution agreements between the semiconductor company and authorized distributor accounts, capturing distributor tier (authorized, preferred, elite), geographic territory coverage, product line authorizations, stock rotation rights, price protection terms, marketing development fund (MDF) entitlements, agreement effective date, expiry date, and agreement status. Distinct from direct customer accounts — distributors resell to end customers.' .

ind:CreditProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Credit Profile' ;
    rdfs:comment 'Customer-facing credit and financial risk profile maintained by the customer domain as SSOT for customer creditworthiness assessment. Captures credit limit, credit rating (internal and external Dun & Bradstreet), payment terms (Net 30, Net 60, prepay), credit hold status, credit review date, outstanding balance, overdue amount, credit utilization percentage, currency, and credit analyst notes. Distinct from finance-domain AR aging and collections records — this product owns the customer\'s credit posture used for real-time order-to-cash credit checks. Integrates with SAP S/4HANA FI-AR (Accounts Receivable).' .

ind:SampleRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Sample Request' ;
    rdfs:comment 'Customer requests for engineering samples, evaluation kits, and pre-production devices prior to volume purchase. Captures requesting contact, account, part number requested, quantity, application description, sample purpose (evaluation, design-in, qualification), requested delivery date, shipping address, approval status, approving FAE, sample cost (if charged), and fulfillment status. Tracks the early-stage design-in funnel from sample to design registration to design-win.' .

ind:PriceAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Price Agreement' ;
    rdfs:comment 'Customer-specific pricing agreements and special price authorizations (SPAs) negotiated for specific part numbers. SSOT for customer-negotiated prices distinct from sales-domain standard list pricing and discount schedules. Captures agreed unit price, currency, minimum order quantity (MOQ), volume tiers, effective date, expiry date, approval chain, SPA reference number, and associated design-win or contract. These are customer-committed prices that flow into order entry — not sales pipeline pricing assumptions. Integrates with SAP S/4HANA SD pricing conditions.' .

ind:InspectionLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Lot' ;
    rdfs:comment 'Master record for a quality inspection lot representing a batch of wafers, dies, or packaged units submitted for quality inspection at any stage. Covers all inspection types: incoming material (IQC for raw wafers, chemicals, photomasks, gases, OSAT subassemblies with supplier and PO reference), in-process (FEOL, BEOL, packaging), and final outgoing. Captures lot origin, supplier ID (for IQC), inspection type, inspection stage, lot size, sampling plan parameters (AQL, sample size, acceptance/rejection numbers), inspection results, measured parameters, and disposition decision (accept, reject, hold, rework). Integrates with SAP QM and Camstar MES for lot status management and goods receipt inspection. SSOT for all quality inspection activities across the fab-to-finish flow including incoming quality control.' .

ind:DefectRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Defect Record' ;
    rdfs:comment 'Transactional record capturing individual defect events, wafer-level defect maps, and spatial bin distributions detected during wafer inspection, die sort, or final test. At the defect event level: stores defect classification code, defect coordinates (X/Y on wafer map), defect size, defect layer (FEOL/MOL/BEOL), detection method (KLA ICOS optical, e-beam, SEM), severity rating, and disposition (scrap, rework, accept). At the wafer map level: captures per-wafer die grid coordinates, per-die pass/fail bin assignment, defect density per zone, edge exclusion zone, flat/notch orientation, and map generation timestamp. Enables yield spatial analysis, systematic defect pattern detection (repeater analysis, cluster detection), and wafer-level bin map visualization. Integrates directly with KLA ICOS inspection system output and ATE wafer probing systems. SSOT for all defect events, spatial defect analysis, and wafer-level quality maps.' .

ind:WaferMap rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Wafer Map' ;
    rdfs:comment 'Spatial defect and bin distribution map for an individual wafer within an inspection lot. Captures wafer ID, lot ID, die grid coordinates, per-die pass/fail bin assignment, defect density per zone, edge exclusion zone, flat/notch orientation, and map generation timestamp. Sourced from KLA ICOS and ATE wafer probing systems. Enables yield spatial analysis and systematic defect pattern detection.' .

ind:YieldRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Yield Record' ;
    rdfs:comment 'Transactional record capturing yield measurement outcomes at each quality gate: wafer probe (die sort yield), final test yield, and packaged unit yield. Stores wafer lot ID, process node, product SKU, total die count, good die count, yield percentage, bin distribution summary, yield loss category (random defect, systematic, parametric, test escape), and measurement timestamp. SSOT for yield tracking across the fab-to-finish flow.' .

ind:SpcChart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Spc Chart' ;
    rdfs:comment 'Statistical Process Control record encompassing both the control plan definition and ongoing chart measurements for a specific process step and tool combination. Captures control plan parameters (monitored parameters, chart type, sampling frequency, sample size, reaction plan), control chart data (X-bar/R, CUSUM, EWMA values), UCL/LCL/CL values, out-of-control signal flags, assignable cause codes, and corrective action references. Supports IATF 16949 and ISO 9001 SPC requirements for process stability monitoring. SSOT for SPC configuration and measurement tracking.' .

ind:FmeaRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Fmea Record' ;
    rdfs:comment 'Failure Mode and Effects Analysis record documenting potential failure modes for a product design or manufacturing process step. Captures failure mode description, potential effect on end customer, severity rating (S), occurrence probability (O), detection rating (D), RPN (Risk Priority Number = S×O×D), recommended actions, responsible owner, target completion date, and post-action revised RPN. Supports IATF 16949 DFMEA and PFMEA requirements.' .

ind:ReliabilityTest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Reliability Test' ;
    rdfs:comment 'Master record for reliability qualification programs and individual test execution, encompassing program definition, test planning, stress test execution, and failure event tracking. At the program level: captures qualification type (new product, process change, OSAT qualification, PCN-driven), applicable standards (AEC-Q100, JEDEC JESD47, ISO 9001), qualification plan version, milestone schedule, overall qualification status, and approval authority. At the test level: captures test type (HTOL, HAST, TC, ESD, JEDEC stress tests), test conditions (temperature, voltage, humidity, duration), sample size, device type, pass/fail criteria, and individual failure details including failed unit serial number, failure time (hours), failure mode, failure analysis method (SEM, FIB, EMMI, curve trace), root cause classification, and failure mechanism (electromigration, TDDB, HCI, NBTI). SSOT for JEDEC JESD47 and AEC-Q100/Q101 qualification lifecycle from program initiation through test execution to final disposition, FIT rate calculations, and Weibull reliability modeling.' .

ind:QualityQualificationProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Quality Qualification Program' ;
    rdfs:comment 'Master record for a product or process qualification program governing the full set of qualification activities required before production release. Captures qualification type (new product, process change, OSAT qualification, PCN-driven), applicable standards (AEC-Q100, JEDEC JESD47, ISO 9001), qualification plan version, milestone schedule, overall qualification status, approval authority, and final disposition. Links to reliability tests, FMEA records, and PCN events.' .

ind:KgdCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Kgd Certification' ;
    rdfs:comment 'Known Good Die certification record attesting that a specific die lot has passed all required electrical, parametric, and reliability screens for bare-die shipment to customers. Captures die lot ID, product part number, certification standard (JEDEC JESD49), test coverage percentage, burn-in status, parametric screen results, certification date, expiry date, certifying engineer, and customer-specific KGD requirements. Critical for advanced packaging and MCM customers.' .

ind:DppmRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Dppm Record' ;
    rdfs:comment 'Customer quality performance and communication record encompassing DPPM tracking, formal quality notifications (8D, SCAR, customer complaints), field return management, and customer-facing quality communications. Captures product part number, customer account, shipment period, total units shipped, defective units returned, DPPM value, notification type, failure description, containment actions, root cause, corrective/preventive actions, 8D report reference, response due date, and closure status. SSOT for all customer-facing quality metrics, notifications, and communications per IATF 16949 customer satisfaction monitoring. Integrates with Salesforce CRM for customer communication tracking.' .

ind:CapaRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Capa Record' ;
    rdfs:comment 'Corrective and Preventive Action record managing the full lifecycle of a quality improvement action triggered by a defect, customer complaint, audit finding, or reliability failure. Captures problem statement, root cause analysis method (5-Why, Ishikawa, FTA), root cause description, corrective action plan, preventive action plan, implementation owner, target and actual completion dates, effectiveness verification criteria, and closure approval. Supports ISO 9001 clause 10.2 and IATF 16949 CAPA requirements.' .

ind:NonconformanceReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Nonconformance Report' ;
    rdfs:comment 'Non-Conformance Report (NCR) and quality hold management record documenting product or process deviations from specification, managing lot hold/release lifecycle, and tracking material review board dispositions. Captures NCR number, affected lot/wafer/unit range, non-conformance description, specification violated, detection point, hold type (process excursion, SPC out-of-control, customer complaint, reliability failure), hold initiation and release timestamps, hold reason, hold release conditions with approver, disposition decision (use-as-is, rework, scrap, return to supplier), material review board (MRB) decision, responsible quality engineer, required disposition actions, and financial impact assessment. SSOT for all in-process quality escapes, quality holds, MRB dispositions, and lot release management. Integrates with Camstar MES and SAP QM for lot status management.' .

ind:Audit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Audit' ;
    rdfs:comment 'Master record for quality management system audit events and their findings, covering internal, customer-conducted, and third-party certification body audits. At the audit level: captures audit program reference, audit type (system, process, product), audit scope, applicable standard (ISO 9001, IATF 16949, JEDEC), lead auditor, audit team, scheduled and actual dates, audit plan document reference, overall audit result, and certificate reference. At the finding level: captures individual observations, non-conformances, and opportunities for improvement with finding classification (major NC, minor NC, observation, OFI), finding description, applicable standard clause, corrective action linkage, responsible owner, due date, and closure status. SSOT for all quality audit planning, execution, and finding management per ISO 19011 and IATF 16949 clause 9.2.' .

ind:QualitySpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Quality Spec' ;
    rdfs:comment 'Master record defining the quality specification for a product SKU or process step, including all acceptance criteria, parametric limits, visual inspection standards, and test coverage requirements. Captures spec version, applicable product family, process node, specification type (electrical, dimensional, visual, reliability), parameter name, nominal value, upper and lower spec limits, measurement units, and approval status. SSOT for quality acceptance criteria referenced by inspection lots and test programs.' .

ind:FailureAnalysisReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Failure Analysis Report' ;
    rdfs:comment 'Formal failure analysis report documenting the investigation of a failed device, wafer, or component. Captures FA request source (reliability test, customer return, in-process failure), sample description, analysis techniques used (SEM, FIB cross-section, EMMI, TEM, EDX), failure site location, identified failure mechanism, root cause conclusion, supporting evidence references, analyst name, and report approval status. Links to reliability_failure, nonconformance_report, and capa_record.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Authoritative master record for all SAP CO cost centers used in semiconductor operations. Captures fab cost centers (FEOL, BEOL, CMP, lithography), R&D cost centers, engineering support centers, and corporate overhead pools. Includes cost center hierarchy, responsible manager, controlling area, currency, validity periods, and budget allocation type. SSOT for cost center identity used across all financial postings.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger chart of accounts master for the semiconductor enterprise. Covers P&L accounts (wafer cost, NRE revenue, R&D expense, depreciation), balance sheet accounts (fab equipment assets, WIP inventory, receivables), and statistical accounts. Includes account type, financial statement version assignment, tax category, reconciliation account flag, and SOX control classification. Sourced from SAP FI chart of accounts.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'SAP EC-PCA profit center master representing autonomous business segments for internal profitability reporting. Covers product lines (SoC, ASIC, FPGA, discrete), technology nodes (5nm, 7nm, 28nm), and geographic segments. Includes profit center hierarchy, responsible manager, controlling area assignment, and transfer pricing indicator. Enables margin analysis by product family and technology generation.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core SAP FI general ledger journal entry capturing all financial postings across the semiconductor enterprise including consolidation adjustments. Document types include vendor invoice, customer payment, asset depreciation, accrual, intercompany, and consolidation entries (intercompany elimination, minority interest adjustment, currency translation adjustment, goodwill amortization). Captures posting date, fiscal period, company code, currency, exchange rate, consolidation unit/group (for group entries), consolidation method, and SOX-relevant reversal indicator. Covers fab cost postings, NRE revenue recognition, R&D capitalization entries, period-end accruals, and group-level consolidation adjustments for SOX-compliant financial reporting under US GAAP or IFRS. Primary transactional record and audit trail for all financial activity.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual debit/credit line items within a SAP FI journal entry document. Each line captures GL account, cost center, profit center, WBS element, functional area, amount in document and local currency, tax code, and assignment field. Supports granular cost allocation to fab process steps, equipment depreciation lines, and NRE milestone revenue lines. Essential for drill-down financial analysis and SOX audit trails.' .

ind:CapexRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Capex Request' ;
    rdfs:comment 'Capital expenditure request and approval record for semiconductor fab equipment investments. Captures investment type (lithography scanner, CMP tool, CVD/PVD/ALD system, ATE platform, metrology tool), requested amount, business justification, technology node applicability, expected useful life, depreciation method, and multi-level approval workflow status. Tracks NRE vs. recurring capex classification and CHIPS Act funding eligibility. Links to SAP IM investment program.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'SAP FI-AA fixed asset master and full depreciation lifecycle for semiconductor manufacturing equipment and infrastructure. Covers EUV/DUV lithography scanners, deposition systems (CVD/PVD/ALD), etch tools, CMP equipment, ATE platforms, cleanroom infrastructure, and IT assets. Master attributes include asset class, acquisition cost, capitalization date, useful life, depreciation key, location (fab building/bay), technology node assignment, and CHIPS Act grant tracking. Depreciation records capture each periodic posting: run date, fiscal period, depreciation area (book/tax/IFRS), depreciation amount, accumulated depreciation, net book value, and remaining useful life. Supports fab utilization-based depreciation adjustments, technology node retirement accounting, asset impairment testing, and disposal/transfer processing. SSOT for the complete asset register from acquisition through disposal including all depreciation schedules. Generated by SAP FI-AA depreciation run (AFAB).' .

ind:AssetDepreciation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Asset Depreciation' ;
    rdfs:comment 'Periodic depreciation posting records for semiconductor fab equipment and infrastructure assets. Captures depreciation run date, fiscal period, asset, depreciation area (book, tax, IFRS), depreciation amount, accumulated depreciation to date, and remaining useful life. Supports fab utilization-based depreciation adjustments and technology node retirement accounting. Generated by SAP FI-AA depreciation run (AFAB).' .

ind:InternalOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'SAP CO internal order master for collecting, tracking, settling, and capitalizing costs of specific semiconductor initiatives. Covers R&D capitalization orders (process node development, IP core development, EDA tool evaluation), fab equipment maintenance campaign orders, customer-specific NRE execution orders, and corporate initiative orders. Includes order type, status lifecycle (created/released/technically complete/closed), responsible cost center, settlement rule (to asset, cost center, or WBS), overall budget, commitment value, actual cost, and statistical/real indicator. Full R&D capitalization lifecycle: tracks technology readiness level, capitalization eligibility assessment per ASC 730/IAS 38, original expense amounts, capitalized amounts, capitalization date, asset under construction reference, and auditor approval. Enables end-to-end cost collection from initial R&D expense through capitalization event to intangible asset creation. Sourced from SAP CO-OM/CO-PC.' .

ind:WbsElement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Work Breakdown Structure element master from SAP PS for semiconductor R&D and capital projects. Structures complex multi-phase projects such as new process node development (PDK creation, process qualification, yield ramp), fab expansion programs, and EUV lithography integration. Captures WBS code, project definition, responsible manager, planned/actual dates, budget, and billing element flag for NRE milestone invoicing. Enables hierarchical project cost tracking and R&D capitalization.' .

ind:CostAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Allocation' ;
    rdfs:comment 'Periodic cost allocation, assessment, and distribution cycle records for semiconductor fab overhead and shared service costs. Captures allocation cycle ID, sender cost center (fab overhead pool, shared services), receiver cost centers or orders, allocation method (activity-based using machine hours or wafer passes, statistical key figure, fixed percentage), allocation base quantity, allocated amount, fiscal period, and reversal indicator. Supports wafer cost modeling by distributing equipment depreciation, utilities, cleanroom maintenance, and indirect labor to process steps based on fab utilization rates and activity drivers. Enables accurate product costing and profitability analysis.' .

ind:WaferCostModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Wafer Cost Model' ;
    rdfs:comment 'Semiconductor-specific wafer cost model master defining the standard cost build-up for a wafer lot at a given technology node and process flow. Captures process node, wafer diameter, die size, target yield, mask set cost amortization, direct material cost (silicon wafer, chemicals, gases), direct labor rate, equipment depreciation per wafer pass, fab overhead rate, and fully-loaded cost per wafer out. Used for product pricing, NRE recovery planning, and fab utilization-based cost allocation. Unique to semiconductor manufacturing finance.' .

ind:FinanceNreAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Finance Nre Agreement' ;
    rdfs:comment 'Non-Recurring Engineering cost recovery agreement master tracking NRE contracts with fabless customers for ASIC/SoC design services, mask set costs, and process qualification. Captures NRE type (mask NRE, design NRE, qualification NRE), total NRE amount, payment milestone schedule, recovery method (upfront, volume-based royalty, hybrid), customer, product design reference, and revenue recognition method per ASC 606/IFRS 15. SSOT for NRE financial obligations distinct from recurring product sales.' .

ind:BudgetPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget Plan' ;
    rdfs:comment 'Annual and multi-year financial budget plan with granular line-item detail for the semiconductor enterprise. Header captures planning version, fiscal year, budget type (operating expense, capital expenditure, R&D investment, headcount), organizational unit (cost center, profit center, company code), planning method, and approval status. Line items (owned within this product) specify GL account/cost element, cost center or WBS element, fiscal period distribution, planned quantity (wafer starts, headcount FTEs, machine hours), planned amount in local and group currency, and variance to prior year. Supports fab capacity-based opex planning, technology node R&D investment roadmaps, CHIPS Act grant-aligned capex budgets, rolling forecasts, and period-level budget vs. actual variance analysis. Enables drill-down from plan header to individual cost element allocations. Sourced from SAP BPC/CO planning cycles.' .

ind:StandardCost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard cost master for semiconductor products defining the pre-determined cost build-up for wafers, dies, and packaged chips at each technology node and process flow. Encompasses full wafer cost modeling: process node, wafer diameter, die size, target yield, mask set cost amortization, direct materials (silicon wafers, chemicals, gases, photomasks), direct labor rate, machine cost (equipment depreciation per wafer pass, maintenance allocation), fab overhead rate (utilities, cleanroom, indirect labor), and fully-loaded cost per wafer out. Calculates yield-adjusted cost per good die and packaging cost for finished product costing. Used as the basis for inventory valuation (ASC 330), COGS determination, manufacturing variance analysis (price/usage/efficiency/yield), product pricing decisions, NRE recovery planning, and fab utilization-based cost allocation. Updated each fiscal year during standard cost roll with quarterly variance reviews. Sourced from SAP CO-PC product costing.' .

ind:TransferPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Transfer Price' ;
    rdfs:comment 'Transfer pricing master records governing intercompany pricing of wafers, dies, IP royalties, and shared services between semiconductor group entities. Captures transfer pricing method (cost-plus, comparable uncontrolled price, resale price, TNMM), applicable entity pair, product or service category, price or margin rate, validity period, and OECD documentation reference. Supports tax-compliant intercompany transactions and country-by-country reporting under BEPS Action 13.' .

ind:FabTool rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Fab Tool' ;
    rdfs:comment 'Master record for all semiconductor manufacturing equipment assets including lithography scanners (EUV/DUV), CVD/PVD/ALD deposition systems, etch chambers, CMP tools, ion implanters, ATE platforms, and metrology/inspection systems. Authoritative SSOT for tool identity, classification, OEM specifications, process node compatibility, FAB location, install date, and asset lifecycle status. Sourced from Applied Materials SmartFactory MES and SAP S/4HANA Fixed Assets.' .

ind:ToolChamber rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Tool Chamber' ;
    rdfs:comment 'Individual process chamber or module within a multi-chamber fab tool (e.g., a CVD cluster tool with 4 deposition chambers, or an etch system with multiple etch modules). Tracks chamber-level qualification status, process recipe assignments, chamber-specific utilization, and maintenance history independently from the parent tool. Essential for chamber-level SPC and yield correlation in multi-chamber tools.' .

ind:ToolQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Tool Qualification' ;
    rdfs:comment 'Qualification and certification records for fab tools and chambers against specific process nodes, recipes, and product families. Captures qualification type (initial qual, re-qual, process change qual), qualification protocol, pass/fail criteria, baseline metrology results, approving process engineer, and qualification validity period. A tool must be qualified before it can run production wafer lots. Sourced from Oracle Agile PLM and SmartFactory MES.' .

ind:PmSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Pm Schedule' ;
    rdfs:comment 'Preventive maintenance (PM) schedule master defining planned PM activities for each fab tool or chamber. Specifies PM type (daily, weekly, monthly, wafer-count-based, run-count-based), PM procedure reference, estimated downtime window, required spare parts, required technician skill level, and scheduling constraints relative to production WIP. Drives the PM work order generation cadence in SAP PM module.' .

ind:MaintenanceEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Maintenance Event' ;
    rdfs:comment 'Transactional record of every maintenance activity executed on a fab tool or chamber, including preventive maintenance (PM), corrective maintenance (CM), emergency breakdown repair, engineering-driven modifications, tool upgrades/retrofits, and hardware/software modifications. Captures event type, trigger (scheduled PM, alarm, operator-reported, FDC event, ECO), start/end timestamps, actual downtime duration, root cause classification (5-why, fishbone), repair actions taken, spare parts and consumables consumed (part ID, quantity, unit cost, planned vs unplanned), technician IDs, upgrade/retrofit details (upgrade type, ECO reference, pre/post configuration, performance improvement targets, baseline change flag), and return-to-service sign-off including re-qualification requirements. SSOT for tool downtime attribution, MTTR/MTBF calculation, parts consumption tracking, upgrade history, and total cost of ownership. Sourced from SAP S/4HANA PM and SmartFactory MES.' .

ind:ToolDowntime rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Tool Downtime' ;
    rdfs:comment 'Granular downtime records for each fab tool and chamber classified per SEMI E10 equipment state model (Productive, Standby, Engineering, Scheduled Downtime, Unscheduled Downtime, Non-Scheduled). Captures state transition timestamps, downtime reason code, responsible party (maintenance, engineering, facilities, scheduling), and impact on WIP lots. Feeds OEE (Overall Equipment Effectiveness) calculation and capacity planning models.' .

ind:CalibrationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Calibration Record' ;
    rdfs:comment 'Calibration and metrology verification records for fab tools and measurement instruments. Tracks calibration type (in-situ, offline, periodic), calibration standard used, measured vs. nominal values, calibration pass/fail result, calibration interval, next due date, calibrating technician, and traceability to NIST or SEMI standards. Mandatory for ISO 9001 and IATF 16949 compliance. Sourced from KLA ICOS and SmartFactory MES calibration modules.' .

ind:EquipmentProcessRecipe rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Equipment Process Recipe' ;
    rdfs:comment 'Master and execution records for process recipes on fab tools. Defines complete recipe parameters (temperature, pressure, gas flows, RF power, spin speed, exposure dose, focus offset, etc.) for each process step and tool type, including recipe name, version, process node target, tool compatibility, recipe owner, approval status, and effective date range. Also captures each recipe execution instance linking a specific wafer lot run to the recipe version used, actual as-run vs as-set parameter values, execution start/end timestamps, operator ID, chamber used, and pass/fail outcome. SSOT for recipe configuration, version management, recipe execution history, and recipe-to-yield correlation analysis. Sourced from SmartFactory MES and Camstar recipe management.' .

ind:RecipeExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Recipe Execution' ;
    rdfs:comment 'Transactional record of each process recipe execution on a fab tool or chamber, linking a specific wafer lot run to the recipe version used, actual process parameter values recorded (as-run vs. as-set), execution start/end timestamps, operator ID, and pass/fail outcome. Enables recipe-to-yield correlation analysis and supports SPC control chart population. Sourced from SmartFactory MES and Camstar lot history.' .

ind:SparePart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Spare Part' ;
    rdfs:comment 'Master record for spare parts and consumables inventory specific to fab tool maintenance, including critical spare parts (e.g., focus rings, edge rings, quartz liners, lamp assemblies, pump kits), their OEM part numbers, compatible tool types, minimum stock levels, lead times, and storage location in the FAB stockroom. Supports PM planning and emergency repair readiness. Sourced from SAP S/4HANA MM module.' .

ind:MetrologyRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Metrology Run' ;
    rdfs:comment 'Metrology and inspection run records capturing in-line and off-line measurement results from metrology tools (CD-SEM, OCD, ellipsometer, profilometer) and inspection systems (KLA ICOS, brightfield/darkfield inspection). Records measurement recipe, wafer lot and site map, measured parameter (CD, film thickness, overlay, defect density), measured values per site, mean/3-sigma statistics, and pass/fail disposition against spec limits. SSOT for process control metrology data. Sourced from KLA ICOS and SmartFactory MES.' .

ind:ExportLicense rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Export License' ;
    rdfs:comment 'Master record for all export authorizations, registrations, and supporting end-use documentation under EAR (BIS) and ITAR (DDTC) governing semiconductor ICs, SoCs, ASICs, IP cores, and controlled technology. Captures authorization type (individual validated license, distribution license, deemed export license, ITAR registration, license exception, TAA), issuing authority, license/registration number, authorized scope (commodities, destinations, end-users, USML categories), validity period, value ceiling, conditions, and renewal status. For ITAR registrations: registration category (manufacturer, exporter, broker), USML categories covered, empowered official, and compliance agreements. For end-use documentation: certificate type (end-user statement, import certificate, delivery verification certificate), customer/end-user details, authorized/prohibited end-use descriptions, and verification status. SSOT for all export control authorizations, ITAR registrations, and supporting end-use certificates.' .

ind:ExportLicenseUsage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Export License Usage' ;
    rdfs:comment 'Transactional record tracking individual shipment drawdowns against an export license. Captures the shipment reference, export license consumed, commodity ECCN/USML category, quantity shipped, declared value, destination country, consignee, end-user, export date, and cumulative license utilization. Enables real-time license balance monitoring and BIS/DDTC reporting compliance.' .

ind:EccnClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Eccn Classification' ;
    rdfs:comment 'Master record for Export Control Classification Number (ECCN) assignments applied to semiconductor products, IP cores, technology, and software. Captures ECCN code (e.g., 3A001, 3E001), classification rationale, controlling parameter (performance level, technology generation, process node), classification date, classifying engineer, review cycle, and applicable EAR controls (AT, NS, MT, CB, RS, SS, UN, EI). SSOT for product-level export control classification.' .

ind:RestrictedPartyScreening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Restricted Party Screening' ;
    rdfs:comment 'Transactional record capturing the results of restricted party list screening performed against customers, distributors, end-users, and suppliers. Captures screened entity name, screening date, lists checked (SDN, DPL, Entity List, Unverified List, OFAC, EU/UK sanctions), match result (clear, potential match, confirmed match), match score, disposition (approved, blocked, escalated), and analyst review notes. Mandatory pre-shipment and onboarding compliance control.' .

ind:ReachSvhcDeclaration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Reach Svhc Declaration' ;
    rdfs:comment 'Master record for all environmental substance compliance declarations covering RoHS restricted substances (lead, mercury, cadmium, hexavalent chromium, PBB, PBDE, DEHP, BBP, DBP, DIBP), REACH SVHCs (candidate list substances above 0.1% w/w threshold), TSCA reportable chemicals, California Prop 65 listed substances, and halogen-free declarations for semiconductor products and packaging. Captures product SKU, declaration type (RoHS compliance statement, REACH SVHC notification, full material declaration, halogen-free declaration), regulatory framework, substance list with CAS numbers, measured concentrations vs thresholds, exemption codes (RoHS Annex III/IV), declaration date, validity period, signatory authority, and customer-facing declaration format (IPC-1752A, IEC 62474, chemSHERPA). Unified SSOT for all product-level environmental substance declarations required for global market access including EU, US, China RoHS, and customer-specific substance restrictions.' .

ind:SubstanceInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Substance Inventory' ;
    rdfs:comment 'Master record for chemical substances and materials used in semiconductor fabrication (CVD/ALD precursors, CMP slurries, photoresists, etchants, dopants, carrier gases, solvents) and packaging materials. Captures substance name, CAS number, chemical formula, SDS reference, regulatory list memberships (REACH SVHC, TSCA Active Inventory, RoHS restricted, Prop 65, ITAR-controlled, PFAS designation), annual usage volume by FAB site, supplier, hazard classification, and disposal classification. Supports TSCA CDR reporting, REACH registration, and PFAS regulatory compliance. Distinct from substance_declaration which tracks product-level declarations to customers.' .

ind:Certification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Certification' ;
    rdfs:comment 'Master record for industry standard certifications and quality management system certifications held by the organization or specific FAB/OSAT sites. Captures certification type (ISO 9001, IATF 16949, ISO 14001, ISO 45001, ISO 27001, SEMI S2, SEMI S8, AEC-Q100, AEC-Q104, AEC-Q200, IECQ, TL 9000), certifying body, scope of certification (site, product line, process), certificate number, issue date, expiry date, surveillance audit schedule, recertification requirements, and current status (active, suspended, withdrawn, expired). SSOT for all third-party certifications demonstrating compliance to customers, regulators, and industry bodies.' .

ind:RegulatoryFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Filing' ;
    rdfs:comment 'Master record for regulatory filings, submissions, voluntary disclosures, and regulatory change tracking for semiconductor compliance. Covers outbound filings (CHIPS Act reports, BIS self-classification, TSCA CDR, SEC conflict minerals, ITAR registration renewals, voluntary disclosures to BIS/DDTC) and inbound regulatory change monitoring (EAR/ITAR amendments, REACH SVHC candidate list updates, RoHS exemption renewals, AI chip export restrictions, entity list additions). For filings: filing type, jurisdiction, agency, submission date, acknowledgment, status. For regulatory changes: change type (new requirement, amendment, repeal, guidance update), publication/effective dates, impacted product lines, impact severity, required response actions, implementation deadline, and implementation evidence. SSOT for all regulatory interactions, horizon scanning, and compliance change management.' .

ind:ChipsActObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Chips Act Obligation' ;
    rdfs:comment 'Master record tracking obligations and commitments arising from US CHIPS and Science Act funding awards and incentive programs. Captures award reference, obligation type (domestic production commitment, workforce training requirement, childcare provision, guardrail restriction on China capacity expansion, clawback condition), obligation description, compliance metric, target value, measurement frequency, reporting period, current status, and evidence of compliance. Critical for CHIPS Act grant recipients.' .

ind:ConflictMineralsDeclaration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Conflict Minerals Declaration' ;
    rdfs:comment 'Master record for conflict minerals (3TG: tantalum, tin, tungsten, gold) compliance declarations required under SEC Rule 13p-1 (Dodd-Frank Section 1502). Captures reporting year, product scope, smelter/refiner list (SOR), country of origin determination, RCOI (Reasonable Country of Origin Inquiry) methodology, CMRT (Conflict Minerals Reporting Template) version, DRC conflict-free status, independent private sector audit reference, and SEC filing date.' .

ind:TradeComplianceHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Trade Compliance Hold' ;
    rdfs:comment 'Transactional record capturing trade compliance holds placed on shipments, orders, or customer accounts pending export control review. Captures hold reference, hold type (license required determination, restricted party match, end-use concern, country embargo, technology transfer review, deemed export violation), triggering transaction reference, hold placed date, hold placed by, review status, resolution action (release, block, refer to legal, apply license exception), resolution date, resolution rationale, and escalation history. Enables audit trail for export compliance decisions and supports BIS voluntary disclosure documentation.' .

ind:ObligationRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Obligation Register' ;
    rdfs:comment 'Master record defining individual regulatory and standards compliance obligations applicable to the organization, specific sites, or product lines, including periodic compliance assessment history. Captures obligation source (regulation, standard, customer contract, industry code, CHIPS Act award), obligation description, applicable scope (global, regional, site-specific, product-specific), responsible function, compliance control owner, assessment frequency, current compliance status, next review date. For periodic assessments: assessment date, method (self-assessment, desk review, site inspection), assessor, compliance status (compliant, partially compliant, non-compliant), gap description, risk rating, remediation plan, and target remediation date. Serves as the unified compliance obligation register and assessment tracker underpinning the ISO 37301 compliance management framework.' .

ind:ConfigurationRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Configuration Rule' ;
    rdfs:comment 'Rules defining valid combinations of package, speed grade, temperature range, voltage variant, and qualification level for orderable SKU creation. Captures constraint expressions, option dependencies, and effectivity dates. Prevents invalid SKU proliferation and powers customer-facing configurator tools for ASIC/FPGA option selection.' .

ind:TaxProvision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Tax Provision' ;
    rdfs:comment 'Tax provision and deferred tax asset/liability tracking for the semiconductor enterprise. Captures current tax expense, deferred tax positions arising from temporary differences (accelerated depreciation on fab equipment, R&D credit carryforwards, CHIPS Act incentive tax treatment, unrealized intercompany profits), effective tax rate reconciliation, uncertain tax positions (ASC 740/IAS 12), and country-by-country tax allocation. Essential for semiconductor companies with global operations, significant R&D tax credits, and complex transfer pricing structures.' .

ind:TechnologyControlPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Technology Control Plan' ;
    rdfs:comment 'Master record for Technology Control Plans (TCPs) governing access to export-controlled semiconductor technology, source code, and technical data within facilities employing foreign nationals. Captures TCP scope (process node, IP block, design methodology), controlled technology description, ECCN classification, access control measures (physical barriers, IT access restrictions, clean-team protocols), authorized personnel list, foreign national nationalities excluded, TCP effective date, review cycle, and responsible export control officer. Critical for EAR deemed export compliance in multinational semiconductor R&D and FAB environments.' .

ind:Reservation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Reservation' ;
    rdfs:comment 'Transactional record for inventory allocation and reservation events that earmark specific quantities of WIP lots, die bank dies, raw materials, or finished goods for a designated demand source (customer order, production order, packaging run, engineering sample request). Captures reservation ID, material/lot reference, reserved quantity, UoM, demand source type and ID, reservation date, requested delivery date, priority, reservation status (active/consumed/cancelled/expired), consuming goods_movement reference, and reserving user. Enables ATP (available-to-promise) calculations, prevents double-allocation of scarce KGD inventory, and supports OSAT packaging run scheduling.' .

ind:Revision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Master reference table for design_revision. Referenced by design_revision_id.' .

ind:MaskSet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Mask Set' ;
    rdfs:comment 'Master reference table for mask_set. Referenced by mask_set_id.' .

ind:MaintenancePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Maintenance Plan' ;
    rdfs:comment 'Master reference table for maintenance_plan. Referenced by maintenance_plan_id.' .

ind:FabFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Fab Facility' ;
    rdfs:comment 'Master reference table for fab_facility. Referenced by fab_facility_id.' .

ind:WorkCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'Master reference table for work_center. Referenced by work_center_id.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master reference table for legal_entity. Referenced by legal_entity_id.' .

ind:Case rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Case' ;
    rdfs:comment 'Master reference table for test_case. Referenced by test_case_id.' .

ind:QualificationReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Qualification Report' ;
    rdfs:comment 'Master reference table for qualification_report. Referenced by qualification_report_id.' .

ind:CustomerComplaint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Customer Complaint' ;
    rdfs:comment 'Master reference table for customer_complaint. Referenced by related_customer_complaint_id.' .

ind:TestPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Test Plan' ;
    rdfs:comment 'Master reference table for test_plan. Referenced by related_test_plan_id.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Master reference table for campaign. Referenced by campaign_id.' .

ind:TestStep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Test Step' ;
    rdfs:comment 'Master reference table for test_step. Referenced by test_step_id.' .

ind:WaferRunRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Wafer Run Record' ;
    rdfs:comment 'This association product represents the operational record of an individual wafer processed during a specific equipment run. In semiconductor FAB operations, equipment runs process multiple wafers simultaneously (batch processing), and each wafer undergoes multiple equipment runs throughout its fabrication lifecycle. This junction entity captures per-wafer process execution data including slot position in the equipment chamber, wafer-specific measurement results, per-wafer run status, and disposition outcomes. Essential for wafer-level yield correlation analysis, process genealogy tracking, and root cause analysis of defects. Replaces the anti-pattern denormalized wafer_slot_map string attribute on equipment_run. Aligned with SEMI E10/E142 MES data model patterns for wafer-level process tracking.. Existence Justification: In semiconductor FAB operations, equipment runs process multiple wafers in batch mode (one equipment run processes 25-50 wafers simultaneously in a chamber), and each wafer undergoes hundreds of equipment runs throughout its fabrication lifecycle (CVD, etch, lithography, implant, CMP, etc.). The wafer_run_record is a recognized MES operational entity that captures per-wafer process execution data including slot position, per-wafer measurements, and disposition outcomes. This is essential for wafer-level yield analysis and process genealogy tracking.' .

ind:ProcessStepWorkCenterQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Process Step Work Center Qualification' ;
    rdfs:comment 'This association product represents the qualification matrix between fabrication process steps and work centers in semiconductor FAB operations. It captures which work centers are qualified and authorized to execute specific process steps, enabling FAB dispatching systems to route WIP lots to appropriate equipment. Each record links one process step to one qualified work center with qualification status, capacity constraints, preference indicators, and effective date ranges that exist only in the context of this qualification relationship. This is the authoritative source for step-to-tool routing decisions in manufacturing execution systems (MES) and advanced planning systems (APS).. Existence Justification: In semiconductor FAB operations, the process step to work center qualification matrix is a foundational operational concept managed by manufacturing engineering and used continuously by MES dispatching systems. A single process step (e.g., \'Litho EUV Layer 5\') can be qualified to execute on multiple work centers (e.g., ASML Tool 1, ASML Tool 2, ASML Tool 3), and a single work center can be qualified to execute multiple process steps across different product families and layers. The business actively manages these qualifications with approval workflows, effective dates, capacity constraints, and preference flags—this is not a derived correlation but an operational master data set that determines which lots can be routed to which equipment.' .

ind:PcnImpact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Pcn Impact' ;
    rdfs:comment 'This association product represents the impact relationship between a Product Change Notification (PCN) and the specific SKUs affected by that change. It captures the per-SKU implementation timeline, customer response requirements, and transition dates that exist only in the context of a specific PCN affecting a specific SKU. Each record links one PCN to one affected SKU with attributes governing how and when that particular SKU transitions to the new specification.. Existence Justification: In semiconductor PLM operations, PCNs routinely affect multiple SKUs (a process change may impact an entire product family with dozens of orderable variants), and each SKU accumulates multiple PCNs over its lifecycle (process improvements, material changes, package updates). The business actively manages PCN Impact as a distinct operational entity with per-SKU implementation timelines, customer response tracking, and transition dates that cannot be stored on either the PCN or SKU alone.' .

# --- Attribute Properties ---
ind:icDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Ic Design Project Id' ;
    rdfs:comment 'Unique surrogate identifier for the IC design project record in the Databricks Silver Layer. Primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Required for project accounting and billing reports linking each design project to the commissioning customer account.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Project cost accounting requires linking each design project to a cost center for monthly expense reporting and budget control.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:customerDesignWinId rdf:type rdf:Property ;
    rdfs:label 'Customer Design Win Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_design_win. Business justification: A design project is commercially authorized by a customer design win. This FK enables design-to-revenue traceability, NRE recovery reporting against the design win, and customer program management das' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerDesignWin .

ind:exportLicenseId rdf:type rdf:Property ;
    rdfs:label 'Export License Id' ;
    rdfs:comment 'Foreign key linking to compliance.export_license. Business justification: Export license required for each design project before international shipment; regulatory export-control process mandates linking project to its license.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExportLicense .

ind:fabricationTechnologyNodeId rdf:type rdf:Property ;
    rdfs:label 'Fabrication Technology Node Id' ;
    rdfs:comment 'Foreign key linking to fabrication.fabrication_technology_node. Business justification: An IC design project targets a specific fabrication technology node. Design program planning, NRE budgeting, and foundry selection all require the fab-specific technology node entity (with qualificati' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationTechnologyNode .

ind:flowId rdf:type rdf:Property ;
    rdfs:label 'Flow Id' ;
    rdfs:comment 'Identifier of the foundry-specific Process Design Kit (PDK) used for this project (e.g., \'TSMC N5P\', \'Samsung SF3E\'). Links to the PDK library version in the EDA tool environment and governs all DRC/LVS rule sets.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Flow .

ind:foundrySupplierId rdf:type rdf:Property ;
    rdfs:label 'Foundry Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Foundry selection contract for each design project; required for manufacturing cost tracking and compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:icCatalogId rdf:type rdf:Property ;
    rdfs:label 'Ic Catalog Id' ;
    rdfs:comment 'Foreign key linking to product.ic_catalog. Business justification: Required for Product Lifecycle Management: design project outcome is recorded as a catalog entry for sales, production planning, and compliance reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:internalOrderId rdf:type rdf:Property ;
    rdfs:label 'Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Internal orders track project-specific capital expenditures and commitments in the ERP system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:pdkId rdf:type rdf:Property ;
    rdfs:label 'Pdk Id' ;
    rdfs:comment 'FK to design.pdk.pdk_id — Every IC design project targets a specific PDK version. This determines all design rules, standard cells, and device models available. Fundamental design constraint.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pdk .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Profitability analysis assigns each design project to a profit center to capture revenue and cost allocation for product line P&L.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Foreign key linking to finance.wbs_element. Business justification: Linking to a WBS element enables detailed work-breakdown-structure budgeting and progress reporting for the design project.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:blockCount rdf:type rdf:Property ;
    rdfs:label 'Block Count' ;
    rdfs:comment 'Number of top-level hierarchical design blocks (partitions) in the IC design. Reflects the block decomposition strategy used for parallel design team assignments and hierarchical physical design in Cadence Innovus.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the IC design project record was first created in the system of record (Siemens Teamcenter PLM or Oracle Agile PLM), propagated to the Databricks Silver Layer. Supports audit trail and data lineage requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:designPhase rdf:type rdf:Property ;
    rdfs:label 'Design Phase' ;
    rdfs:comment 'Indicates the primary fabrication phase scope of the design: Front End of Line (FEOL), Middle of Line (MOL), Back End of Line (BEOL), or full-flow. Governs which process modules and DFM rules are active.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designType rdf:type rdf:Property ;
    rdfs:label 'Design Type' ;
    rdfs:comment 'Classification of the integrated circuit design type. Drives NRE cost structure, EDA tool selection, and tapeout process. [ENUM-REF-CANDIDATE: ASIC|SoC|FPGA|ASSP|MCU|GPU|DSP|RFIC|MEMS|Analog — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmRuleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Dfm Rule Set Version' ;
    rdfs:comment 'Version identifier of the Design for Manufacturability (DFM) rule set applied to this project. Governs OPC recipe selection, MEEF corrections, and yield-enhancement layout guidelines provided by the foundry PDK.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftEnabled rdf:type rdf:Property ;
    rdfs:label 'Dft Enabled' ;
    rdfs:comment 'Indicates whether Design for Testability (DFT) structures (scan chains, BIST, boundary scan) are included in this design. Drives ATPG flow activation, ATE program generation, and KGD qualification planning.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edaToolSuite rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Suite' ;
    rdfs:comment 'Primary EDA tool suite vendor used for this IC design project (e.g., Cadence Virtuoso/Innovus, Synopsys Design Compiler/PrimeTime, Siemens EDA). Governs tool license allocation and design flow configuration.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edaToolVersion rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Version' ;
    rdfs:comment 'Version string of the primary EDA tool suite certified for this project (e.g., \'Cadence Innovus 21.1\', \'Synopsys DC 2022.03\'). Ensures design reproducibility and supports audit trails for sign-off certification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlClassification rdf:type rdf:Property ;
    rdfs:label 'Export Control Classification' ;
    rdfs:comment 'Export control classification of the IC design project under US Export Administration Regulations (EAR) or International Traffic in Arms Regulations (ITAR). Governs technology transfer restrictions, foreign national access controls, and license requirements. [ENUM-REF-CANDIDATE: EAR99|ECCN_3E001|ECCN_3E002|ECCN_3E003|ITAR|no_restriction — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCountTargetK rdf:type rdf:Property ;
    rdfs:label 'Gate Count Target K' ;
    rdfs:comment 'Target logic gate count in thousands of equivalent gates (Kilo-Gates) for the design. Used for complexity estimation, EDA tool capacity planning, and synthesis runtime forecasting in Synopsys Design Compiler.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdsFilePath rdf:type rdf:Property ;
    rdfs:label 'Gds File Path' ;
    rdfs:comment 'Storage path or URI of the final GDS/GDSII design database file submitted for tapeout. Provides traceability to the authoritative design artifact in the EDA data management system.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatfAutomotiveGrade rdf:type rdf:Property ;
    rdfs:label 'Iatf Automotive Grade' ;
    rdfs:comment 'Indicates whether this IC design project targets automotive-grade qualification per IATF 16949 and AEC-Q100/Q101 standards. Triggers additional FMEA, reliability testing, and DPPM requirements in the quality management workflow.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipCoreCount rdf:type rdf:Property ;
    rdfs:label 'Ip Core Count' ;
    rdfs:comment 'Total number of licensed or internally developed Intellectual Property (IP) cores integrated into this IC design project. Drives IP license cost tracking, third-party IP compliance review, and BOM management in Oracle Agile PLM.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the IC design project record in the source system of record. Used for incremental data pipeline processing, change detection, and audit compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lithographyType rdf:type rdf:Property ;
    rdfs:label 'Lithography Type' ;
    rdfs:comment 'Primary lithography technology used for critical layer patterning: Extreme Ultraviolet (EUV), Deep Ultraviolet (DUV), multi-patterning DUV, or nanoimprint. Impacts mask cost, OPC complexity, and MEEF considerations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metalLayerCount rdf:type rdf:Property ;
    rdfs:label 'Metal Layer Count' ;
    rdfs:comment 'Number of metal interconnect layers in the BEOL stack for this design. Determines routing resource availability, RC parasitics, and mask set cost. Specified in the PDK and foundry process design rules.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreActualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Actual Spend Usd' ;
    rdfs:comment 'Cumulative actual NRE expenditure incurred to date for the IC design project in US dollars, as recorded in SAP S/4HANA FI/CO. Compared against nre_budget_usd for variance analysis and financial reporting.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Budget Usd' ;
    rdfs:comment 'Total approved Non-Recurring Engineering (NRE) budget for the IC design project in US dollars. Covers EDA tool licensing, mask set costs, engineering labor, and MPW shuttle fees. Managed in SAP S/4HANA CO cost center planning.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Target die packaging technology for this IC design project (e.g., WLCSP, BGA, CoWoS, InFO, flip-chip). Influences die size constraints, I/O pad ring design, and OSAT partner selection. [ENUM-REF-CANDIDATE: WLCSP|BGA|QFN|CoWoS|InFO|flip_chip|TSV|SiP|LGA — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdkVersion rdf:type rdf:Property ;
    rdfs:label 'Pdk Version' ;
    rdfs:comment 'Version of the Process Design Kit (PDK) certified for use in this IC design project. Ensures reproducibility of design rule checks (DRC), layout versus schematic (LVS) verification, and parasitic extraction across the design lifecycle.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmItemReference rdf:type rdf:Property ;
    rdfs:label 'Plm Item Reference' ;
    rdfs:comment 'Native item/object identifier in Siemens Teamcenter PLM or Oracle Agile PLM for this IC design project. Enables bidirectional traceability between the Databricks Silver Layer and the authoritative PLM system of record.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known alphanumeric project identifier assigned at project initiation in Siemens Teamcenter PLM and Oracle Agile PLM. Used across EDA tool flows, NRE contracts, and cross-functional communications as the canonical project reference.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Free-text description of the IC design project scope, target application domain (e.g., AI accelerator, automotive MCU, IoT SoC), and key design objectives. Supports search, discovery, and executive reporting.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name of the IC design project (e.g., \'Orion SoC Rev2\'). Used in PLM dashboards, design reviews, and executive reporting.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Official start date of the IC design project, corresponding to project kick-off and initial resource allocation in Siemens Teamcenter PLM and SAP S/4HANA CO.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle state of the IC design project from concept through GDS/GDSII tapeout. Drives milestone tracking, resource allocation, and PLM workflow gates. [ENUM-REF-CANDIDATE: concept|rtl_design|synthesis|physical_design|verification|tapeout|post_tapeout|cancelled — promote to reference product]' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachSvhcAssessed rdf:type rdf:Property ;
    rdfs:label 'Reach Svhc Assessed' ;
    rdfs:comment 'Indicates whether a REACH Substances of Very High Concern (SVHC) assessment has been completed for materials used in this IC design and packaging. Required for EU chemical safety compliance and customer disclosure obligations.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revision rdf:type rdf:Property ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Design revision identifier (e.g., \'A\', \'B1\', \'C\') tracking major design iterations managed through Oracle Agile PLM change control. Incremented upon significant design changes, ECO incorporation, or re-tapeout events.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsCompliant rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant' ;
    rdfs:comment 'Indicates whether the IC design and associated packaging materials comply with the EU RoHS Directive (2011/65/EU) restricting hazardous substances. Required for EU market access and customer compliance declarations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtlFreezeDate rdf:type rdf:Property ;
    rdfs:label 'Rtl Freeze Date' ;
    rdfs:comment 'Planned or actual date on which the Register Transfer Level (RTL) specification is frozen and handed off to logic synthesis. A key milestone in the IC design schedule tracked in Siemens Teamcenter PLM.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP S/4HANA CO Work Breakdown Structure (WBS) element code assigned to this IC design project for NRE cost collection, budget tracking, and financial reporting under SOX controls.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutActualDate rdf:type rdf:Property ;
    rdfs:label 'Tapeout Actual Date' ;
    rdfs:comment 'Actual date on which the final GDS/GDSII design database was submitted to the foundry for mask generation. Compared against tapeout_target_date to measure schedule adherence and Time to Market (TTM) performance.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tapeoutTargetDate rdf:type rdf:Property ;
    rdfs:label 'Tapeout Target Date' ;
    rdfs:comment 'Planned date for final GDS/GDSII tapeout submission to the foundry. Drives the master project schedule, NRE milestone payments, and MPW shuttle slot reservations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetClockFreqMhz rdf:type rdf:Property ;
    rdfs:label 'Target Clock Freq Mhz' ;
    rdfs:comment 'Target operating clock frequency in megahertz (MHz) as defined in the Power Performance Area (PPA) specification. Used by Synopsys Design Compiler and PrimeTime for timing closure constraints and sign-off.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDieAreaMm2 rdf:type rdf:Property ;
    rdfs:label 'Target Die Area Mm2' ;
    rdfs:comment 'Target silicon die area in square millimeters (mm²) as defined in the PPA specification. Constrains floorplanning, block partitioning, and IP core placement in Cadence Innovus physical design flow.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPowerBudgetMw rdf:type rdf:Property ;
    rdfs:label 'Target Power Budget Mw' ;
    rdfs:comment 'Maximum allowable total power consumption in milliwatts (mW) as specified in the PPA targets. Drives power-aware synthesis, clock gating strategies, and multi-voltage domain planning in Cadence Innovus and Synopsys Design Compiler.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tsvRequired rdf:type rdf:Property ;
    rdfs:label 'Tsv Required' ;
    rdfs:comment 'Indicates whether Through-Silicon Via (TSV) interconnects are required for 3D stacking or advanced packaging (e.g., CoWoS, HBM integration). Triggers specialized process module planning and OSAT coordination.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designIpCoreId rdf:type rdf:Property ;
    rdfs:label 'Design Ip Core Id' ;
    rdfs:comment 'Unique surrogate identifier for each IP core record in the master catalog. Primary key for the ip_core data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DesignIpCore .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.certification. Business justification: Commercial IP cores require ISO 26262 (automotive functional safety), AEC-Q100 (automotive qualification), or DO-254 (avionics) certifications. Certification evidence required for customer qualificati' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:eccnClassificationId rdf:type rdf:Property ;
    rdfs:label 'Eccn Classification Id' ;
    rdfs:comment 'Foreign key linking to compliance.eccn_classification. Business justification: ECCN classification determines export restrictions for IP cores; needed for generating export licenses and compliance reports.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EccnClassification .

ind:fabToolId rdf:type rdf:Property ;
    rdfs:label 'Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: IP core silicon_proven status is established on a specific fab tool run. IP qualification and reuse decisions require knowing which fab tool the IP was proven on. The denormalized foundry_compatibilit' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Purchased IP cores (license_fee_usd tracked) are capitalized intangible assets requiring amortization over useful life. Finance tracks acquisition cost, amortization schedule, and net book value for r' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:processTechnologyNodeId rdf:type rdf:Property ;
    rdfs:label 'Process Technology Node Id' ;
    rdfs:comment 'Foreign key linking to process.process_technology_node. Business justification: IP cores are qualified and silicon-proven on specific process technology nodes — silicon_proven_date, timing model availability, and DFM compliance are all node-specific. Foundry compatibility and IP ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessTechnologyNode .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: IP core licensing vendor relationship; needed for royalty tracking, compliance, and supplier risk assessment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:areaUm2 rdf:type rdf:Property ;
    rdfs:label 'Area Um2' ;
    rdfs:comment 'Physical silicon area occupied by the IP core in square micrometers (µm²) for the characterized process node. Part of the PPA characterization data used for die size estimation and floorplanning in Cadence Innovus.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:datasheetUrl rdf:type rdf:Property ;
    rdfs:label 'Datasheet Url' ;
    rdfs:comment 'URL link to the official IP core datasheet or technical reference manual stored in the PLM document management system or vendor portal. Provides design teams with access to integration guidelines, timing specifications, and interface documentation.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designIpCoreName rdf:type rdf:Property ;
    rdfs:label 'Design Ip Core Name' ;
    rdfs:comment 'Human-readable name of the IP core as used in design documentation, EDA tool libraries, and vendor datasheets (e.g., \'Cortex-A55 CPU Cluster\', \'DesignWare PCIe Gen5 Controller\').' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmCompliant rdf:type rdf:Property ;
    rdfs:label 'Dfm Compliant' ;
    rdfs:comment 'Indicates whether the IP core has passed Design for Manufacturability (DFM) rule checks for the target process node (True = DFM-compliant; False = DFM issues present or not checked). DFM compliance reduces yield risk during wafer fabrication.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dftCompliant rdf:type rdf:Property ;
    rdfs:label 'Dft Compliant' ;
    rdfs:comment 'Indicates whether the IP core includes Design for Testability (DFT) structures (scan chains, BIST, boundary scan) compliant with the project\'s DFT architecture (True = DFT-compliant; False = not compliant or not applicable). Affects ATPG test coverage and ATE test time.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edaToolCompatibility rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Compatibility' ;
    rdfs:comment 'Comma-separated list of EDA tools and versions with which this IP core has been validated (e.g., \'Cadence Virtuoso 23.1, Synopsys DC 2023.03, Cadence Innovus 22.1\'). Ensures design teams select compatible tool versions for integration.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionCategory rdf:type rdf:Property ;
    rdfs:label 'Function Category' ;
    rdfs:comment 'Functional classification of the IP core indicating its primary design purpose (e.g., CPU, GPU, NPU, SerDes, PHY, memory_controller, analog, RF, security, interconnect, IO). Used for IP portfolio management and design-in selection. [ENUM-REF-CANDIDATE: CPU|GPU|NPU|SerDes|PHY|memory_controller|analog|RF|security|interconnect|IO|other — promote to reference product]' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalDescription rdf:type rdf:Property ;
    rdfs:label 'Functional Description' ;
    rdfs:comment 'Detailed technical description of the IP core\'s functionality, architecture, and key features as documented in the IP datasheet. Provides design engineers with the information needed to evaluate IP suitability for a given SoC design.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCount rdf:type rdf:Property ;
    rdfs:label 'Gate Count' ;
    rdfs:comment 'Equivalent gate count of the IP core representing its logic complexity, expressed in number of 2-input NAND gate equivalents. Used for die area estimation, synthesis resource planning, and complexity benchmarking in Synopsys Design Compiler.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdsAvailable rdf:type rdf:Property ;
    rdfs:label 'Gds Available' ;
    rdfs:comment 'Indicates whether a GDSII (Graphic Data System II) physical layout file is available for this IP core (True = GDSII provided; False = not available). GDSII availability is required for hard macro integration and tapeout submission.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interfaceStandard rdf:type rdf:Property ;
    rdfs:label 'Interface Standard' ;
    rdfs:comment 'Industry interface protocol standards supported by this IP core (e.g., AMBA AXI4, PCIe Gen5, USB 3.2, DDR5, MIPI CSI-2). Ensures interoperability with SoC interconnect fabric and system-level integration. [ENUM-REF-CANDIDATE: AMBA_AXI4|PCIe_Gen5|USB3.2|DDR5|MIPI_CSI2|Ethernet|CAN|I2C|SPI|other — promote to reference product]' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCoreCode rdf:type rdf:Property ;
    rdfs:label 'Ip Core Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the IP core in the internal IP library and vendor catalogs (e.g., ARM Cortex-A55, SNPS-PCIE-GEN5). Used as the business key across EDA tool flows, PLM, and design project references.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipType rdf:type rdf:Property ;
    rdfs:label 'Ip Type' ;
    rdfs:comment 'Classification of the IP core by its delivery form: hard_macro (fixed physical layout, process-specific GDS), soft_ip (synthesizable RTL, process-portable), or firm_ip (partially optimized netlist, semi-portable). Determines integration methodology and EDA tool flow requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lefAvailable rdf:type rdf:Property ;
    rdfs:label 'Lef Available' ;
    rdfs:comment 'Indicates whether a Library Exchange Format (LEF) abstract view is available for this IP core (True = LEF provided; False = not available). LEF files are required for place-and-route integration in Cadence Innovus and Synopsys IC Compiler.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date on which the IP core license agreement expires or must be renewed. Null for perpetual licenses. Critical for license renewal planning and ensuring design projects do not use expired IP licenses.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseFeeUsd rdf:type rdf:Property ;
    rdfs:label 'License Fee Usd' ;
    rdfs:comment 'One-time or annual license fee paid to the IP vendor in US Dollars (USD). Represents the NRE or access cost component of the IP licensing agreement. Null for open-source or internally developed IP.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Type of licensing arrangement governing use of this IP core: perpetual (one-time fee, unlimited use), subscription (time-limited access), royalty_bearing (per-unit royalty on shipped products), royalty_free (no per-unit royalty after license fee), open_source (governed by open-source license terms). Drives financial planning and legal compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the IP core in the catalog: active (available for new designs), deprecated (supported but not recommended for new designs), obsolete (no longer supported), under_development (not yet released), qualification (in silicon validation). Drives IP selection eligibility and EOL planning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Max Frequency Mhz' ;
    rdfs:comment 'Maximum achievable operating frequency of the IP core in megahertz (MHz) at the characterized process corner (typical/worst-case) for the target process node. Part of the PPA characterization data used for timing closure planning in Synopsys Design Compiler and PrimeTime.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpwEligible rdf:type rdf:Property ;
    rdfs:label 'Mpw Eligible' ;
    rdfs:comment 'Indicates whether this IP core is eligible for inclusion in Multi-Project Wafer (MPW) shuttle runs for cost-effective silicon validation (True = MPW eligible; False = not eligible, e.g., due to NDA restrictions or hard macro size constraints).' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaRequired rdf:type rdf:Property ;
    rdfs:label 'Nda Required' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) must be in place before design teams can access the IP core documentation, RTL source, or GDSII files (True = NDA required; False = no NDA required). Governs IP access control and legal compliance.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerUw rdf:type rdf:Property ;
    rdfs:label 'Power Uw' ;
    rdfs:comment 'Characterized typical power consumption of the IP core in microwatts (µW) at the nominal operating voltage and frequency for the target process node. Part of the Power-Performance-Area (PPA) characterization data used for SoC power budget analysis.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current qualification status of the IP core against the target process node and foundry: not_started, in_progress (characterization underway), qualified (passed all qualification criteria), failed (qualification failed, remediation required). Distinct from silicon_proven status.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which this version of the IP core was officially released and made available for design-in use in the internal IP library or vendor catalog. Used for version history tracking and design project planning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Pct' ;
    rdfs:comment 'Per-unit royalty rate expressed as a percentage of the net selling price of the end product incorporating this IP core. Applicable only for royalty_bearing license types. Used for royalty accrual and financial reporting in SAP S/4HANA.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtlLanguage rdf:type rdf:Property ;
    rdfs:label 'Rtl Language' ;
    rdfs:comment 'Hardware description language used for the RTL source code of the IP core (Verilog, SystemVerilog, VHDL, or mixed). Relevant only for soft IP and firm IP types. Determines EDA tool compatibility and synthesis flow requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Scan Coverage Pct' ;
    rdfs:comment 'Percentage of internal logic nodes covered by scan-based DFT test structures, as reported by ATPG tools. Higher coverage reduces DPPM risk. Null if DFT is not applicable (e.g., analog IP).' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siliconProven rdf:type rdf:Property ;
    rdfs:label 'Silicon Proven' ;
    rdfs:comment 'Indicates whether this IP core has been successfully validated in a fabricated silicon device (True = silicon-proven; False = simulation-only or pre-silicon). Silicon-proven status is a critical risk factor in IP selection for production designs.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siliconProvenDate rdf:type rdf:Property ;
    rdfs:label 'Silicon Proven Date' ;
    rdfs:comment 'Date on which the IP core achieved silicon-proven status through successful tape-out and functional validation in fabricated silicon. Null if not yet silicon-proven.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Indicates whether the IP core originates from the internal IP development team, a third-party vendor (e.g., ARM, Synopsys DesignWare, Cadence Tensilica), or an open-source library. Determines licensing obligations, support model, and NRE cost applicability.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportTier rdf:type rdf:Property ;
    rdfs:label 'Support Tier' ;
    rdfs:comment 'Level of technical support available for this IP core: standard (community/documentation support), premium (dedicated FAE support with SLA), end_of_support (no active support, use at own risk). Influences design-in risk assessment and vendor engagement planning.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timingModelAvailable rdf:type rdf:Property ;
    rdfs:label 'Timing Model Available' ;
    rdfs:comment 'Indicates whether Liberty (.lib) timing models are available for this IP core for static timing analysis (True = Liberty models provided; False = not available). Required for timing closure analysis in Synopsys PrimeTime and Cadence Tempus.' ;
    rdfs:domain ind:DesignIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when this IP core record was most recently modified in the master catalog (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports change tracking, data lineage, and incremental ETL processing in the Databricks Lakehouse.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the third-party IP vendor or licensor (e.g., ARM Holdings, Synopsys, Cadence Design Systems, CEVA). Null for internally developed IP cores. Used for vendor management, license tracking, and procurement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier of the IP core release following semantic versioning (e.g., 2.1.0, r0p4). Tracks revision history and ensures design projects reference the correct IP release.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opcRuleSetId rdf:type rdf:Property ;
    rdfs:label 'Opc Rule Set Id' ;
    rdfs:comment 'Foreign key linking to process.opc_rule_set. Business justification: PDK qualification bundles the OPC rule set for the target lithography process — pdk has opc_rule_deck_version as a plain string but no FK to the actual opc_rule_set. PDK release notes and foundry cert' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpcRuleSet .

ind:productProcessNodeId rdf:type rdf:Property ;
    rdfs:label 'Product Process Node Id' ;
    rdfs:comment 'Foreign key linking to product.process_node. Business justification: Ensures alignment of PDKs with official process-node definitions for compliance, cost, and yield analysis in engineering reports.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessNode .

ind:agilePlmPartNumber rdf:type rdf:Property ;
    rdfs:label 'Agile Plm Part Number' ;
    rdfs:comment 'Part number assigned to this PDK in Oracle Agile PLM for product data and change management. Used to track PDK-related Engineering Change Orders (ECOs) and Product Change Notifications (PCNs).' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Checksum Sha256' ;
    rdfs:comment 'SHA-256 cryptographic hash of the PDK distribution archive. Used to verify PDK file integrity after download or transfer, ensuring no corruption or unauthorized modification of foundry-provided design rule files.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecationDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Date' ;
    rdfs:comment 'Date on which this PDK version was deprecated and superseded by a newer release. Designs in progress must migrate to the active version by this date. Null if the PDK is still active.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dftRuleDeckVersion rdf:type rdf:Property ;
    rdfs:label 'Dft Rule Deck Version' ;
    rdfs:comment 'Version of the Design for Testability (DFT) rule deck included in this PDK. DFT rules govern scan chain insertion, ATPG (Automatic Test Pattern Generation) compatibility, and boundary scan requirements for post-fabrication testing.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drcRuleDeckVersion rdf:type rdf:Property ;
    rdfs:label 'Drc Rule Deck Version' ;
    rdfs:comment 'Version identifier of the Design Rule Check (DRC) rule deck included in this PDK. The DRC rule deck enforces foundry-mandated physical design rules to ensure manufacturability. Used in Cadence Innovus and KLA ICOS inspection correlation.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Canonical file system or object storage path to the PDK installation directory or archive (e.g., \'/pdk/tsmc/n5/v1.3.2\' or \'s3://pdk-repo/tsmc/n5/v1.3.2\'). Used by EDA tool setup scripts to locate PDK assets in Cadence Virtuoso and Synopsys Design Compiler environments.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsFormat rdf:type rdf:Property ;
    rdfs:label 'Gds Format' ;
    rdfs:comment 'Layout data format supported by this PDK for tapeout submission to the foundry. GDSII (Graphic Data System II) is the legacy industry standard; OASIS is the modern compressed alternative. Determines the final tapeout file format.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioLibraryName rdf:type rdf:Property ;
    rdfs:label 'Io Library Name' ;
    rdfs:comment 'Name of the I/O pad cell library included in this PDK, providing ESD-protected interface cells for chip-to-package signal routing. Required for full-chip physical design and package co-design.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipLibraryVersion rdf:type rdf:Property ;
    rdfs:label 'Ip Library Version' ;
    rdfs:comment 'Version of the foundry-provided hard IP library (e.g., PLLs, SerDes, PHYs) bundled with this PDK. IP cores are pre-characterized and validated for the specific process node.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:layerStackDefinition rdf:type rdf:Property ;
    rdfs:label 'Layer Stack Definition' ;
    rdfs:comment 'Identifier or reference name for the metal layer stack definition included in this PDK, specifying the number of metal layers, dielectric materials, and interconnect hierarchy (FEOL/MOL/BEOL). Governs routing resources available to physical design tools.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lvsRuleDeckVersion rdf:type rdf:Property ;
    rdfs:label 'Lvs Rule Deck Version' ;
    rdfs:comment 'Version identifier of the Layout Versus Schematic (LVS) rule deck included in this PDK. LVS verifies that the physical layout matches the circuit schematic. Mandatory for tapeout sign-off in Cadence Virtuoso flows.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSupplyVoltageV rdf:type rdf:Property ;
    rdfs:label 'Max Supply Voltage V' ;
    rdfs:comment 'Maximum operating supply voltage (Vdd) in volts supported by this process node as defined in the PDK. Exceeding this value risks device reliability and oxide breakdown.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memoryCompilerSupported rdf:type rdf:Property ;
    rdfs:label 'Memory Compiler Supported' ;
    rdfs:comment 'Indicates whether this PDK includes or is compatible with a foundry-provided memory compiler for generating SRAM, ROM, or register file macros. True = memory compiler available; False = memory macros must be sourced separately.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minSupplyVoltageV rdf:type rdf:Property ;
    rdfs:label 'Min Supply Voltage V' ;
    rdfs:comment 'Minimum operating supply voltage (Vdd) in volts supported by this process node as defined in the PDK. Used for low-power design optimization and multi-voltage domain planning.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpwShuttleSupported rdf:type rdf:Property ;
    rdfs:label 'Mpw Shuttle Supported' ;
    rdfs:comment 'Indicates whether this PDK version is qualified and approved for use in Multi-Project Wafer (MPW) shuttle runs, enabling cost-shared prototyping across multiple design projects on a single wafer.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nominalSupplyVoltageV rdf:type rdf:Property ;
    rdfs:label 'Nominal Supply Voltage V' ;
    rdfs:comment 'Nominal (typical) operating supply voltage in volts for this process node as specified in the PDK. Used as the reference voltage for standard timing and power characterization.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opcRuleDeckVersion rdf:type rdf:Property ;
    rdfs:label 'Opc Rule Deck Version' ;
    rdfs:comment 'Version of the Optical Proximity Correction (OPC) rule deck included in this PDK. OPC rules compensate for photolithographic distortions during mask writing, critical for sub-10nm nodes using EUV or DUV lithography.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temp Max C' ;
    rdfs:comment 'Maximum junction operating temperature in degrees Celsius for which the PDK device models and timing libraries are characterized. Defines the hot corner for timing sign-off and reliability qualification.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTempMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temp Min C' ;
    rdfs:comment 'Minimum junction operating temperature in degrees Celsius for which the PDK device models and timing libraries are characterized. Defines the cold corner for timing sign-off.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdkCode rdf:type rdf:Property ;
    rdfs:label 'Pdk Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this PDK release, as assigned by the foundry or internal PDK management team (e.g., TSMC_N5_PDK_2023Q4). Used as the business-facing identifier in Cadence Virtuoso and Synopsys Design Compiler tool configurations.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdkDescription rdf:type rdf:Property ;
    rdfs:label 'Pdk Description' ;
    rdfs:comment 'Free-text description of the PDK, including key features, intended use cases, known limitations, and any special design guidelines. Provides context for design engineers selecting the appropriate PDK for a new IC design project.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdkName rdf:type rdf:Property ;
    rdfs:label 'Pdk Name' ;
    rdfs:comment 'Human-readable descriptive name of the PDK (e.g., \'TSMC 5nm N5 PDK v1.3\'). Used in EDA tool selection menus, design review documentation, and PLM records in Siemens Teamcenter.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdkStatus rdf:type rdf:Property ;
    rdfs:label 'Pdk Status' ;
    rdfs:comment 'Current lifecycle state of the PDK version. \'draft\' = under development; \'active\' = qualified and approved for production design starts; \'deprecated\' = superseded by newer version but still supported; \'retired\' = no longer supported; \'restricted\' = limited access pending NDA or export control review.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCornerSet rdf:type rdf:Property ;
    rdfs:label 'Process Corner Set' ;
    rdfs:comment 'Comma-separated list of process corners (PVT corners) defined in this PDK for timing and power sign-off (e.g., \'TT, FF, SS, FS, SF\'). Each corner represents a combination of process, voltage, and temperature variation for worst/best-case analysis in Synopsys PrimeTime.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFamily rdf:type rdf:Property ;
    rdfs:label 'Process Family' ;
    rdfs:comment 'Foundry-specific process family or platform name within a node (e.g., \'N5\', \'N5P\', \'N4\', \'SF3E\'). Distinguishes performance-optimized, power-optimized, or cost-optimized variants within the same technology node.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date on which the PDK version was internally qualified and approved for production IC design starts at Semiconductors. Distinct from the foundry release date; reflects internal DRC/LVS and SPICE model validation completion.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseNotesUrl rdf:type rdf:Property ;
    rdfs:label 'Release Notes Url' ;
    rdfs:comment 'URL pointing to the official PDK release notes document, detailing changes, bug fixes, and known issues relative to the previous version. Essential for design teams evaluating PDK upgrade impact on in-progress designs.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spiceModelSet rdf:type rdf:Property ;
    rdfs:label 'Spice Model Set' ;
    rdfs:comment 'Identifier or name of the SPICE (Simulation Program with Integrated Circuit Emphasis) device model set bundled with this PDK (e.g., \'BSIM-CMG v110\', \'PSP v103\'). Used by Synopsys PrimeTime and Cadence Virtuoso for circuit simulation and timing analysis.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spiceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Spice Model Version' ;
    rdfs:comment 'Version identifier of the SPICE model set included in this PDK. Critical for simulation reproducibility and sign-off correlation between design teams and the foundry.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stdCellLibraryName rdf:type rdf:Property ;
    rdfs:label 'Std Cell Library Name' ;
    rdfs:comment 'Name of the primary standard cell library bundled with this PDK (e.g., \'SC9MC_HD\', \'SC7P5T_HD\'). Standard cell libraries provide pre-characterized logic gates used in RTL-to-GDS synthesis flows in Synopsys Design Compiler.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stdCellLibraryVersion rdf:type rdf:Property ;
    rdfs:label 'Std Cell Library Version' ;
    rdfs:comment 'Version of the standard cell library included in this PDK release. Version changes may affect timing, power, and area (PPA) characteristics of synthesized designs.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamcenterItemReference rdf:type rdf:Property ;
    rdfs:label 'Teamcenter Item Reference' ;
    rdfs:comment 'Item identifier assigned to this PDK record in Siemens Teamcenter PLM, enabling traceability between the PDK master record and associated design projects, change orders, and release workflows.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transistorArchitecture rdf:type rdf:Property ;
    rdfs:label 'Transistor Architecture' ;
    rdfs:comment 'Transistor architecture type used in this process node (e.g., FinFET, Gate-All-Around (GAA), Planar, FDSOI). Determines device modeling approach, SPICE model complexity, and applicable EDA tool flows.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtlSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Rtl Specification Id' ;
    rdfs:comment 'Unique surrogate identifier for the RTL specification record in the lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtlSpecification .

ind:mpwShuttleId rdf:type rdf:Property ;
    rdfs:label 'Mpw Shuttle Id' ;
    rdfs:comment 'Reference to the Multi-Project Wafer (MPW) shuttle run assigned for prototype fabrication of this RTL design. MPW shuttles allow multiple designs to share a single wafer to reduce NRE costs for early silicon validation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpwShuttle .

ind:primaryIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Ic Design Project Id' ;
    rdfs:comment 'FK to design.ic_design_project.ic_design_project_id — RTL specifications are created within the context of an IC design project. This is a mandatory parent-child relationship required for design hierarchy navigation.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:productSpecId rdf:type rdf:Property ;
    rdfs:label 'Product Spec Id' ;
    rdfs:comment 'Foreign key linking to product.product_spec. Business justification: Supports validation and regulatory compliance: ties each RTL spec to the authoritative product specification used in safety and performance certification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSpec .

ind:toIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'To Ic Design Project Id' ;
    rdfs:comment 'FK to design.ic_design_project.ic_design_project_id — Every RTL specification belongs to exactly one IC design project. This is the fundamental parent-child relationship for design artifacts. Engineers navigate from project to RTL modules daily.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:amsBehavioralModelRef rdf:type rdf:Property ;
    rdfs:label 'Ams Behavioral Model Ref' ;
    rdfs:comment 'Reference identifier or path to the Verilog-AMS or VHDL-AMS behavioral model associated with this analog/mixed-signal RTL block. Populated only when is_analog_mixed_signal is True. Links to the Cadence Virtuoso schematic source.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdcAnnotationStatus rdf:type rdf:Property ;
    rdfs:label 'Cdc Annotation Status' ;
    rdfs:comment 'Completion status of Clock Domain Crossing (CDC) boundary annotations within the RTL specification. CDC annotation is mandatory for multi-clock designs prior to synthesis sign-off to prevent metastability failures.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockDomainCount rdf:type rdf:Property ;
    rdfs:label 'Clock Domain Count' ;
    rdfs:comment 'Number of distinct clock domains defined within this RTL design block. Drives Clock Domain Crossing (CDC) analysis requirements and verification complexity estimation.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitHash rdf:type rdf:Property ;
    rdfs:label 'Commit Hash' ;
    rdfs:comment 'The specific commit hash or changelist number in the revision control system corresponding to the approved version of this RTL specification. Provides immutable provenance linkage to the exact source snapshot.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designBlockName rdf:type rdf:Property ;
    rdfs:label 'Design Block Name' ;
    rdfs:comment 'Human-readable name of the RTL design block, IP subsystem, or full-chip entity described by this specification (e.g., \'USB3_PHY_Controller\', \'DDR5_Memory_Interface\', \'Top_Level_SoC\'). Serves as the primary identity label for the design artifact.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designBlockType rdf:type rdf:Property ;
    rdfs:label 'Design Block Type' ;
    rdfs:comment 'Classification of the RTL design block scope. Determines applicable design rules, verification methodology, and integration requirements. \'ip_core\' blocks are subject to IP licensing tracking; \'fpga_target\' blocks require device-specific synthesis constraints. [ENUM-REF-CANDIDATE: full_chip|subsystem|ip_core|interface_block|analog_mixed_signal|fpga_target — promote to reference product]' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designIntentDescription rdf:type rdf:Property ;
    rdfs:label 'Design Intent Description' ;
    rdfs:comment 'Narrative description of the functional design intent, architectural decisions, and key requirements captured in this RTL specification. Provides context for design reviews, IP reuse assessments, and new engineer onboarding.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftStrategy rdf:type rdf:Property ;
    rdfs:label 'Dft Strategy' ;
    rdfs:comment 'Design for Testability (DFT) methodology applied to this RTL block. Defines the test insertion approach used to enable Automatic Test Pattern Generation (ATPG) and silicon test coverage on Automatic Test Equipment (ATE).' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earEccnCode rdf:type rdf:Property ;
    rdfs:label 'Ear Eccn Code' ;
    rdfs:comment 'Export Control Classification Number (ECCN) assigned to this RTL specification under the Export Administration Regulations (EAR). Determines export licensing requirements for cross-border transfer of design data.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpgaDeviceFamily rdf:type rdf:Property ;
    rdfs:label 'Fpga Device Family' ;
    rdfs:comment 'Target FPGA device family for synthesis and implementation (e.g., \'Xilinx Ultrascale+\', \'Intel Agilex\', \'Lattice ECP5\'). Populated only when is_fpga_target is True. Determines device-specific synthesis constraints and IP primitives.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Functional Coverage Target Pct' ;
    rdfs:comment 'Target functional coverage percentage defined in the verification plan for this RTL specification. Expressed as a percentage (0.00–100.00). Used to gate simulation sign-off and tapeout readiness reviews.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hdlLanguage rdf:type rdf:Property ;
    rdfs:label 'Hdl Language' ;
    rdfs:comment 'Primary Hardware Description Language used to author the RTL source code for this design block. Determines EDA tool compatibility, lint rule sets, and synthesis flow configuration in Synopsys Design Compiler.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interfaceProtocols rdf:type rdf:Property ;
    rdfs:label 'Interface Protocols' ;
    rdfs:comment 'Comma-separated list of hardware interface protocols implemented in this RTL block (e.g., \'AXI4, AHB5, APB3, Wishbone, PCIe, USB3\'). Used for integration compatibility checks and IP reuse assessments.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipReuseSource rdf:type rdf:Property ;
    rdfs:label 'Ip Reuse Source' ;
    rdfs:comment 'Origin classification of the IP content in this RTL specification. \'licensed_third_party\' requires IP license compliance tracking; \'open_source\' requires license obligation management (e.g., GPL, Apache); \'internal\' indicates proprietary reuse. Classified confidential due to IP licensing sensitivity.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnalogMixedSignal rdf:type rdf:Property ;
    rdfs:label 'Is Analog Mixed Signal' ;
    rdfs:comment 'Indicates whether this RTL specification includes analog or mixed-signal content requiring behavioral model references (Verilog-AMS, VHDL-AMS) and linkage to transistor-level schematic source in Cadence Virtuoso.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFpgaTarget rdf:type rdf:Property ;
    rdfs:label 'Is Fpga Target' ;
    rdfs:comment 'Indicates whether this RTL specification is intended for FPGA implementation rather than ASIC tapeout. When True, synthesis constraints, pin assignments, and target device family fields are applicable.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itarControlled rdf:type rdf:Property ;
    rdfs:label 'Itar Controlled' ;
    rdfs:comment 'Indicates whether this RTL specification is subject to International Traffic in Arms Regulations (ITAR) export controls. When True, access must be restricted to authorized US persons and export license requirements apply.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this RTL specification record. Used for change tracking, incremental data pipeline processing, and audit compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lintComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Lint Compliance Status' ;
    rdfs:comment 'Status of RTL lint rule compliance checks for this specification. Lint tools (e.g., Synopsys SpyGlass, Cadence HAL) enforce coding guidelines and detect potential design errors. \'clean\' is required before synthesis sign-off.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logicGateCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Logic Gate Count Estimate' ;
    rdfs:comment 'Estimated number of equivalent logic gates for this RTL design block, derived from synthesis estimation runs in Synopsys Design Compiler. Used for area budgeting, floorplanning, and Power-Performance-Area (PPA) target setting.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreCostUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Cost Usd' ;
    rdfs:comment 'Estimated Non-Recurring Engineering (NRE) cost in US dollars associated with developing this RTL specification. Used for project budgeting, customer design-in pricing, and financial reporting in SAP S/4HANA CO module.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsolescenceDate rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Date' ;
    rdfs:comment 'Date on which this RTL specification was marked obsolete, typically superseded by a newer version or upon product End of Life (EOL). Supports Product Change Notification (PCN) and Last Time Buy (LTB) processes.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:powerDomainCount rdf:type rdf:Property ;
    rdfs:label 'Power Domain Count' ;
    rdfs:comment 'Number of distinct power domains defined in the Unified Power Format (UPF) or Common Power Format (CPF) specification for this RTL block. Drives low-power verification and power intent analysis.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerIntentFormat rdf:type rdf:Property ;
    rdfs:label 'Power Intent Format' ;
    rdfs:comment 'Standard format used to specify power intent for this RTL design block. UPF (IEEE 1801) and CPF (Cadence) are the two industry standards. \'none\' indicates no multi-voltage power management is implemented.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repositoryPath rdf:type rdf:Property ;
    rdfs:label 'Repository Path' ;
    rdfs:comment 'Full path or URL to the revision control repository location where the RTL source files for this specification are stored (e.g., Git remote URL or Perforce depot path). Classified confidential as it reveals internal IP infrastructure.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resetStrategy rdf:type rdf:Property ;
    rdfs:label 'Reset Strategy' ;
    rdfs:comment 'Reset architecture employed in this RTL design block. Defines whether resets are synchronous, asynchronous, or mixed, which impacts timing closure, DFT scan insertion, and silicon reliability.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionControlSystem rdf:type rdf:Property ;
    rdfs:label 'Revision Control System' ;
    rdfs:comment 'Version control system in which the RTL source files for this specification are managed. Enables provenance tracking and audit trail for design changes.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Specification Approved Date' ;
    rdfs:comment 'Date on which this RTL specification was formally approved through the PLM design review process. Marks the effective start of the specification as a binding design baseline. Required for ISO 9001 and IATF 16949 design record compliance.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the RTL specification artifact as tracked in Siemens Teamcenter PLM and revision control systems (Git, Perforce). Used for cross-system traceability and design review references.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Specification Released Date' ;
    rdfs:comment 'Date on which this RTL specification was released for downstream use (synthesis, physical design, verification). Distinct from approval date; release may follow approval after additional sign-off steps.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle state of the RTL specification artifact within the PLM workflow. Controls downstream design activities: \'draft\' allows edits; \'approved\' gates synthesis; \'released\' permits tapeout submission; \'obsolete\' marks superseded versions.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClockFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Target Clock Frequency Mhz' ;
    rdfs:comment 'Target operating clock frequency in megahertz (MHz) for the primary clock domain of this RTL design block. Drives timing constraint definition in Synopsys PrimeTime and synthesis optimization targets.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'Semantic version label of this RTL specification revision (e.g., \'v1.0\', \'v2.3.1\'). Tracks design evolution through revision control (Git, Perforce) and PLM change management. Incremented on each approved change.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netlistId rdf:type rdf:Property ;
    rdfs:label 'Netlist Id' ;
    rdfs:comment 'Unique surrogate identifier for the synthesized netlist artifact record in the design domain. Primary key for this data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Netlist .

ind:edaToolId rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Id' ;
    rdfs:comment 'Foreign key linking to design.eda_tool. Business justification: Netlist is produced by a specific EDA tool; adding eda_tool_id creates a proper reference and removes tool name/version duplication.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdaTool .

ind:netlistIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Netlist Ic Design Project Id' ;
    rdfs:comment 'Reference to the parent IC design project or block to which this netlist belongs. Links the netlist artifact to its design hierarchy context within the PLM system.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:netlistPdkId rdf:type rdf:Property ;
    rdfs:label 'Netlist Pdk Id' ;
    rdfs:comment 'Reference to the Process Design Kit (PDK) version used during logic synthesis. The PDK defines the standard cell library, design rules, and technology parameters for the target fabrication process node.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pdk .

ind:netlistRtlSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Netlist Rtl Specification Id' ;
    rdfs:comment 'Reference to the RTL specification artifact from which this netlist was synthesized. Establishes design provenance traceability from RTL source to synthesized gate-level netlist.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtlSpecification .

ind:toPdkId rdf:type rdf:Property ;
    rdfs:label 'To Pdk Id' ;
    rdfs:comment 'FK to design.pdk.pdk_id — Synthesis uses PDK standard cell libraries. The netlist must reference which PDK version was used for synthesis.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pdk .

ind:toRtlSpecificationId rdf:type rdf:Property ;
    rdfs:label 'To Rtl Specification Id' ;
    rdfs:comment 'FK to design.rtl_specification.rtl_specification_id — A netlist is synthesized from an RTL specification. This is the core design flow linkage (RTL -> synthesis -> netlist) required for design provenance.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtlSpecification .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the netlist was formally approved for promotion to the next design stage. Supports design review audit trails and milestone tracking for tapeout schedule management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:areaEstimateUm2 rdf:type rdf:Property ;
    rdfs:label 'Area Estimate Um2' ;
    rdfs:comment 'Estimated silicon area of the synthesized netlist in square micrometers (µm²) as reported by the synthesis tool. Represents the combinational and sequential cell area before physical placement. A key PPA (Power-Performance-Area) metric.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellInstanceCount rdf:type rdf:Property ;
    rdfs:label 'Cell Instance Count' ;
    rdfs:comment 'Total number of standard cell instances instantiated in the synthesized netlist. Distinct from gate count — counts actual cell placements including sequential elements (flip-flops, latches) and combinational cells.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellLibraryName rdf:type rdf:Property ;
    rdfs:label 'Cell Library Name' ;
    rdfs:comment 'Name of the standard cell library used during logic synthesis (e.g., \'TSMC_N5_SC_HD_v1.2\'). Defines the set of logic gates, flip-flops, and combinational cells mapped during synthesis from the PDK.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellLibraryVersion rdf:type rdf:Property ;
    rdfs:label 'Cell Library Version' ;
    rdfs:comment 'Version identifier of the standard cell library used during synthesis. Critical for design reproducibility and provenance — different library versions may have different timing, power, or area characteristics.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationalCellCount rdf:type rdf:Property ;
    rdfs:label 'Combinational Cell Count' ;
    rdfs:comment 'Number of combinational logic cells (AND, OR, MUX, inverters, etc.) in the synthesized netlist. Used for area estimation and logic optimization analysis during PPA (Power-Performance-Area) evaluation.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constraintsFileRef rdf:type rdf:Property ;
    rdfs:label 'Constraints File Ref' ;
    rdfs:comment 'File path or repository reference to the Synopsys Design Constraints (SDC) file used during synthesis. The SDC file specifies timing constraints, clock definitions, input/output delays, and false paths that govern synthesis optimization.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathDelayPs rdf:type rdf:Property ;
    rdfs:label 'Critical Path Delay Ps' ;
    rdfs:comment 'Propagation delay of the longest (critical) timing path in the synthesized netlist, measured in picoseconds (ps). Determines the maximum achievable operating frequency and is a key PPA (Power-Performance-Area) metric for design optimization.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designIteration rdf:type rdf:Property ;
    rdfs:label 'Design Iteration' ;
    rdfs:comment 'Sequential iteration counter for synthesis runs on the same design block. Increments with each new synthesis attempt, enabling tracking of design convergence progress and comparison of PPA metrics across iterations.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dfmRuleCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Dfm Rule Check Status' ;
    rdfs:comment 'Status of Design for Manufacturability (DFM) rule checks applied to this netlist. DFM rules ensure the synthesized design is compatible with the target fabrication process constraints to maximize yield.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftScanCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Dft Scan Coverage Pct' ;
    rdfs:comment 'Percentage of sequential elements covered by DFT (Design for Testability) scan chains in the synthesized netlist. Higher coverage improves defect detection during Automatic Test Equipment (ATE) testing. Target is typically ≥95% for production designs.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPowerMw rdf:type rdf:Property ;
    rdfs:label 'Dynamic Power Mw' ;
    rdfs:comment 'Estimated dynamic (switching) power consumption in milliwatts (mW) from the synthesis power analysis report. Represents power consumed by logic transitions and is activity-dependent. Used for thermal and battery life analysis.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'File format of the synthesized netlist artifact (e.g., Verilog gate-level netlist, VHDL, SPICE, EDIF, Liberty). Determines compatibility with downstream EDA tools for physical design, simulation, and verification flows.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leakagePowerUw rdf:type rdf:Property ;
    rdfs:label 'Leakage Power Uw' ;
    rdfs:comment 'Estimated static leakage power consumption in microwatts (µW) from the synthesis power analysis report. Represents power consumed when the circuit is idle due to sub-threshold leakage currents. Critical for low-power and IoT product designs.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netlistName rdf:type rdf:Property ;
    rdfs:label 'Netlist Name' ;
    rdfs:comment 'Human-readable name assigned to the netlist artifact, typically reflecting the design block name and synthesis iteration (e.g., \'cpu_core_top_postsyn_v3\'). Used for identification in EDA tool flows and design review sessions.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netlistType rdf:type rdf:Property ;
    rdfs:label 'Netlist Type' ;
    rdfs:comment 'Classification of the netlist stage in the IC design flow: pre_synthesis (RTL-level functional netlist before synthesis), post_synthesis (gate-level netlist after logic synthesis by Synopsys Design Compiler), or post_layout (netlist annotated with parasitic extraction data after physical design in Cadence Innovus).' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequentialCellCount rdf:type rdf:Property ;
    rdfs:label 'Sequential Cell Count' ;
    rdfs:comment 'Number of sequential logic cells (flip-flops, latches, registers) in the synthesized netlist. Used for Design for Testability (DFT) scan chain planning and power analysis of dynamic switching activity.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:synthesisRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Synthesis Run Timestamp' ;
    rdfs:comment 'Date and time when the logic synthesis run that produced this netlist was executed. Provides the principal business event timestamp for design provenance, audit trails, and design iteration tracking.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:synthesisRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Synthesis Runtime Minutes' ;
    rdfs:comment 'Wall-clock runtime of the synthesis job in minutes. Used for EDA compute resource planning, license utilization tracking, and identifying synthesis runs that exceed expected runtimes due to design complexity or tool issues.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:synthesisStatus rdf:type rdf:Property ;
    rdfs:label 'Synthesis Status' ;
    rdfs:comment 'Current lifecycle status of the netlist artifact within the design flow. Tracks progression from initial synthesis run through completion, failure, archival, or supersession by a newer version.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timingClosureAchieved rdf:type rdf:Property ;
    rdfs:label 'Timing Closure Achieved' ;
    rdfs:comment 'Indicates whether timing closure has been achieved for this netlist (True = all timing paths meet constraints with non-negative slack; False = timing violations remain). A prerequisite gate for advancing to physical design and tapeout.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timingSlackHoldPs rdf:type rdf:Property ;
    rdfs:label 'Timing Slack Hold Ps' ;
    rdfs:comment 'Worst-case hold timing slack in picoseconds (ps) across all timing paths in the synthesized netlist, as reported by Synopsys PrimeTime. Negative hold slack indicates a hold violation requiring buffer insertion or path adjustment.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timingSlackSetupPs rdf:type rdf:Property ;
    rdfs:label 'Timing Slack Setup Ps' ;
    rdfs:comment 'Worst-case setup timing slack in picoseconds (ps) across all timing paths in the synthesized netlist, as reported by Synopsys PrimeTime. Negative slack indicates a timing violation (setup violation) that must be resolved before tapeout. Critical PPA metric.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timingViolationCount rdf:type rdf:Property ;
    rdfs:label 'Timing Violation Count' ;
    rdfs:comment 'Total number of timing path violations (setup and hold combined) reported in the synthesis timing analysis. A value of zero indicates timing closure has been achieved. Used to track synthesis convergence progress across iterations.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPowerEstimateMw rdf:type rdf:Property ;
    rdfs:label 'Total Power Estimate Mw' ;
    rdfs:comment 'Estimated total power consumption of the synthesized netlist in milliwatts (mW), as reported by the synthesis tool. Includes dynamic switching power and static leakage power. A key PPA (Power-Performance-Area) metric for product qualification.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timingAnalysisRunId rdf:type rdf:Property ;
    rdfs:label 'Timing Analysis Run Id' ;
    rdfs:comment 'Unique surrogate identifier for each Static Timing Analysis (STA) run record in the Databricks Silver Layer. Primary key for the timing_analysis_run data product.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalLayoutId rdf:type rdf:Property ;
    rdfs:label 'Physical Layout Id' ;
    rdfs:comment 'FK to design.physical_layout.physical_layout_id — Post-route STA runs reference a specific physical layout version for parasitic-annotated timing. Critical for post-layout timing closure.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PhysicalLayout .

ind:primaryTimingIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Timing Ic Design Project Id' ;
    rdfs:comment 'Reference to the IC design or SoC/ASIC design entity for which this STA run was executed. Links the timing analysis result to the parent design record managed in Cadence Virtuoso/Innovus or Siemens Teamcenter PLM.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:timingIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Timing Ic Design Project Id' ;
    rdfs:comment 'FK to design.ic_design_project.ic_design_project_id — Timing runs belong to a project for aggregated timing closure tracking across design iterations.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:analysisMode rdf:type rdf:Property ;
    rdfs:label 'Analysis Mode' ;
    rdfs:comment 'Timing analysis mode applied in this STA run. Setup checks for maximum path delay violations; hold checks for minimum path delay violations; OCV (On-Chip Variation), AOCV (Advanced OCV), and POCV (Parametric OCV) modes apply statistical derating for silicon variation modeling. Determines which slack metrics are applicable.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockFrequencyTargetMhz rdf:type rdf:Property ;
    rdfs:label 'Clock Frequency Target Mhz' ;
    rdfs:comment 'Target clock frequency in megahertz (MHz) specified for this STA run, representing the design\'s PPA (Power Performance Area) performance goal. Used to evaluate whether timing closure is achieved at the required operating frequency.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clockPeriodTargetPs rdf:type rdf:Property ;
    rdfs:label 'Clock Period Target Ps' ;
    rdfs:comment 'Target clock period in picoseconds (ps) corresponding to the clock frequency target. Directly used by Synopsys PrimeTime as the timing constraint for setup/hold analysis. Derived from clock_frequency_target_mhz but stored independently as the authoritative STA constraint value.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalPathCount rdf:type rdf:Property ;
    rdfs:label 'Critical Path Count' ;
    rdfs:comment 'Number of critical timing paths (paths with negative or near-zero slack) identified in this STA run. Used by design engineers to prioritize optimization efforts in Synopsys Design Compiler or Cadence Innovus for timing closure.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deratingFactorHold rdf:type rdf:Property ;
    rdfs:label 'Derating Factor Hold' ;
    rdfs:comment 'On-Chip Variation (OCV) derating factor applied to hold timing paths in this STA run. Represents the percentage by which cell delays are derated for hold analysis. Typically different from setup derating to model the asymmetric nature of process variation effects on min/max paths.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deratingFactorSetup rdf:type rdf:Property ;
    rdfs:label 'Derating Factor Setup' ;
    rdfs:comment 'On-Chip Variation (OCV) derating factor applied to setup timing paths in this STA run. Represents the percentage by which cell delays are derated to model process variation (e.g., 0.95 = 5% derating). Used in OCV/AOCV/POCV analysis modes for silicon-accurate sign-off.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designStage rdf:type rdf:Property ;
    rdfs:label 'Design Stage' ;
    rdfs:comment 'Physical design stage at which this STA run was performed, reflecting the state of the netlist and parasitics. Values: pre_synthesis (RTL-level), post_synthesis (gate-level), pre_cts (before Clock Tree Synthesis), post_cts (after CTS), post_route (after detailed routing), signoff (final tapeout signoff). Drives interpretation of WNS/TNS results.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designVersion rdf:type rdf:Property ;
    rdfs:label 'Design Version' ;
    rdfs:comment 'Version or revision label of the IC design netlist or GDS/GDSII database at the time this STA run was executed (e.g., \'v2.3.1\', \'tapeout_rc2\'). Enables timing closure tracking across design iterations and correlates with PLM change records.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdViolationCount rdf:type rdf:Property ;
    rdfs:label 'Hold Violation Count' ;
    rdfs:comment 'Total number of hold timing violations (negative hold slack endpoints) reported by Synopsys PrimeTime in this STA run. A value of zero indicates full hold timing closure. Critical for designs with multi-cycle paths, clock domain crossings, and post-CTS analysis.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMultiCornerRun rdf:type rdf:Property ;
    rdfs:label 'Is Multi Corner Run' ;
    rdfs:comment 'Indicates whether this STA run covers multiple PVT corners simultaneously (True) or a single corner (False). Multi-corner runs are used for comprehensive sign-off coverage across all operating conditions required by the PDK and target application specifications.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignoffRun rdf:type rdf:Property ;
    rdfs:label 'Is Signoff Run' ;
    rdfs:comment 'Indicates whether this STA run is designated as an official tapeout signoff run (True) or an intermediate/exploratory analysis run (False). Signoff runs are subject to formal design review, PLM change control, and foundry submission requirements.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:libertyLibraryVersion rdf:type rdf:Property ;
    rdfs:label 'Liberty Library Version' ;
    rdfs:comment 'Version of the Liberty (.lib) timing library files used in this STA run. Liberty libraries contain cell timing models, power models, and operating condition data from the PDK. Library version directly affects timing analysis accuracy and sign-off validity.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCapacitanceViolationCount rdf:type rdf:Property ;
    rdfs:label 'Max Capacitance Violation Count' ;
    rdfs:comment 'Number of maximum capacitance violations reported in this STA run. Capacitance violations indicate nets with excessive load that degrade timing and signal integrity. Must be resolved through buffer insertion or net splitting before tapeout.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTransitionViolationCount rdf:type rdf:Property ;
    rdfs:label 'Max Transition Violation Count' ;
    rdfs:comment 'Number of maximum transition time violations reported in this STA run. Transition violations indicate signal edges that are too slow, potentially causing functional failures or increased power consumption. Must be resolved before tapeout signoff per PDK design rules.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primetimeVersion rdf:type rdf:Property ;
    rdfs:label 'Primetime Version' ;
    rdfs:comment 'Version of Synopsys PrimeTime used to execute this STA run (e.g., \'PrimeTime 2023.12-SP3\'). Critical for result reproducibility, audit trails, and identifying version-specific timing model differences that may affect sign-off validity.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processNodeNm rdf:type rdf:Property ;
    rdfs:label 'Process Node Nm' ;
    rdfs:comment 'Semiconductor process technology node in nanometers at which the design is implemented (e.g., \'5nm\', \'7nm\', \'28nm\'). Determines PDK library characteristics, timing model accuracy, and applicable EUV/DUV lithography constraints relevant to STA sign-off.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvtCorner rdf:type rdf:Property ;
    rdfs:label 'Pvt Corner' ;
    rdfs:comment 'Operating corner (Process-Voltage-Temperature) under which this STA run was performed (e.g., \'ss_0p72v_125c\' for slow-slow worst-case, \'ff_1p08v_m40c\' for fast-fast best-case). Defined by the PDK (Process Design Kit) and critical for sign-off coverage across all operating conditions.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the STA run results were formally reviewed and approved by the responsible design engineer or timing closure lead. Null if the run has not yet been reviewed. Required for tapeout sign-off audit trail.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Username or employee identifier of the senior design engineer or timing closure lead who reviewed and approved the results of this STA run. Required for signoff runs as part of the formal design review process before tapeout submission.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Completion Timestamp' ;
    rdfs:comment 'Date and time when this Static Timing Analysis run completed execution in Synopsys PrimeTime. Used to calculate run duration and assess EDA compute resource utilization. Null if the run is still in progress or was aborted.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Run Duration Seconds' ;
    rdfs:comment 'Wall-clock duration of this STA run in seconds, from job submission to completion. Used for EDA compute resource planning, license utilization tracking, and identifying unusually long runs that may indicate tool or design issues.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runIdentifier rdf:type rdf:Property ;
    rdfs:label 'Run Identifier' ;
    rdfs:comment 'Externally-known alphanumeric run identifier assigned by the EDA tool flow or MES integration (e.g., \'PT-RUN-20240315-0042\'). Used for cross-referencing with Synopsys PrimeTime job logs, Cadence Innovus signoff reports, and Siemens Teamcenter PLM design records.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runIteration rdf:type rdf:Property ;
    rdfs:label 'Run Iteration' ;
    rdfs:comment 'Sequential iteration number of this STA run within the current design stage and PVT corner. Enables tracking of timing closure convergence across multiple optimization-analysis cycles (e.g., iteration 1 through N until timing closure is achieved).' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runName rdf:type rdf:Property ;
    rdfs:label 'Run Name' ;
    rdfs:comment 'Human-readable name or label assigned to this Static Timing Analysis run, typically encoding the design name, corner, and iteration (e.g., \'soc_top_ss_0p72v_125c_postroute_iter3\'). Used for identification in Synopsys PrimeTime run logs and design review meetings.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the design engineer describing the purpose, context, or key findings of this STA run (e.g., \'Post-ECO run after fixing 3 critical paths in clock tree\', \'Baseline run for tapeout corner coverage\'). Supports design review and knowledge transfer.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Execution lifecycle status of this STA run job in the EDA tool flow. \'submitted\' indicates the job is queued, \'running\' indicates active execution, \'completed\' indicates successful completion, \'failed\' indicates tool error or license failure, \'aborted\' indicates user-cancelled run. Distinct from timing_closure_status which reflects the timing result.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'Date and time when this Static Timing Analysis run was initiated in Synopsys PrimeTime. Represents the principal business event timestamp for this record. Used for tracking timing closure progress over time and correlating with design iteration milestones.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sdcConstraintsVersion rdf:type rdf:Property ;
    rdfs:label 'Sdc Constraints Version' ;
    rdfs:comment 'Version or identifier of the Synopsys Design Constraints (SDC) file used in this STA run. SDC files define clock definitions, input/output delays, and timing exceptions. Versioning ensures traceability of constraint changes across design iterations.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupViolationCount rdf:type rdf:Property ;
    rdfs:label 'Setup Violation Count' ;
    rdfs:comment 'Total number of setup timing violations (negative setup slack endpoints) reported by Synopsys PrimeTime in this STA run. A value of zero indicates full setup timing closure. Tracked across iterations to measure convergence progress toward tapeout readiness.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spefVersion rdf:type rdf:Property ;
    rdfs:label 'Spef Version' ;
    rdfs:comment 'Version or identifier of the SPEF (Standard Parasitic Exchange Format) file used for parasitic extraction in this STA run. SPEF files contain RC parasitics from the routed layout and directly impact timing accuracy. Null for pre-route analysis stages.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyVoltageV rdf:type rdf:Property ;
    rdfs:label 'Supply Voltage V' ;
    rdfs:comment 'Nominal supply voltage in volts (V) applied for this STA run\'s PVT corner. Defined by the PDK operating conditions and UPF (Unified Power Format) power intent. Directly impacts cell delay models and timing analysis results.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Operating temperature in degrees Celsius (°C) for this STA run\'s PVT corner. Temperature affects transistor characteristics and cell delays. Typical corners range from -40°C (automotive cold) to 125°C (worst-case hot). Defined by the PDK and target application requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timingClosureStatus rdf:type rdf:Property ;
    rdfs:label 'Timing Closure Status' ;
    rdfs:comment 'Overall timing closure pass/fail status for this STA run. \'pass\' indicates all setup and hold violations are resolved and the design meets timing at the specified PVT corner and clock frequency. \'waived\' indicates known violations accepted with engineering sign-off. \'pending_review\' indicates results awaiting design team review. Primary KPI for tapeout readiness.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHoldNegativeSlackPs rdf:type rdf:Property ;
    rdfs:label 'Total Hold Negative Slack Ps' ;
    rdfs:comment 'Total Hold Negative Slack (THNS) in picoseconds — the sum of all negative hold slack values across all violating hold endpoints in this STA run. Complements TNS (setup) to provide a complete picture of hold timing closure status.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNegativeSlackPs rdf:type rdf:Property ;
    rdfs:label 'Total Negative Slack Ps' ;
    rdfs:comment 'Total Negative Slack (TNS) in picoseconds — the sum of all negative slack values across all violating timing endpoints in this STA run. Indicates the overall magnitude of timing violations in the design. Used alongside WNS to assess timing closure convergence across design iterations.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverCount rdf:type rdf:Property ;
    rdfs:label 'Waiver Count' ;
    rdfs:comment 'Number of timing violations formally waived with engineering sign-off in this STA run. Waivers are granted for violations on non-critical paths, test-mode-only paths, or paths with functional justification. Tracked for tapeout risk assessment and compliance with design review processes.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:worstHoldSlackPs rdf:type rdf:Property ;
    rdfs:label 'Worst Hold Slack Ps' ;
    rdfs:comment 'Worst Hold Slack (WHS) in picoseconds for hold timing analysis in this STA run. Represents the most critical hold violation — the largest shortfall in minimum path delay. Negative values indicate hold violations that must be fixed before tapeout. Applicable when analysis_mode includes hold or setup_hold.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:worstNegativeSlackPs rdf:type rdf:Property ;
    rdfs:label 'Worst Negative Slack Ps' ;
    rdfs:comment 'Worst Negative Slack (WNS) in picoseconds reported by Synopsys PrimeTime for this STA run. Represents the most critical timing violation — the largest shortfall between required and actual signal arrival time. A value of 0 or positive indicates no setup/hold violation on the worst path. Key metric for timing closure tracking.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentProcessRecipeId rdf:type rdf:Property ;
    rdfs:label 'Equipment Process Recipe Id' ;
    rdfs:comment 'Foreign key linking to equipment.equipment_process_recipe. Business justification: DFM sign-off requires validating physical layout against the specific equipment process recipe governing layer parameters, etch depths, and lithography settings. Process integration engineers explicit' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentProcessRecipe .

ind:layoutMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Layout Material Master Id' ;
    rdfs:comment 'Foreign key linking to supply.material_master. Business justification: Completed physical layouts (GDS files) are tracked as material items for configuration management, costing, and deliverable tracking. Links design output to material master for BOM management, cost ro' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:physicalIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Physical Ic Design Project Id' ;
    rdfs:comment 'FK to design.ic_design_project.ic_design_project_id — Physical layouts belong to a specific IC design project. Required for design artifact management.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:primaryPhysicalIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Physical Ic Design Project Id' ;
    rdfs:comment 'Reference to the parent IC design record for which this physical layout iteration was produced. Links the layout to its originating design project.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:antennaViolationCount rdf:type rdf:Property ;
    rdfs:label 'Antenna Violation Count' ;
    rdfs:comment 'Number of antenna rule violations detected in the layout. Antenna violations occur when metal segments accumulate charge during plasma etching that can damage gate oxide. Must be resolved or mitigated with antenna diodes before tapeout.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Cell Utilization Pct' ;
    rdfs:comment 'Percentage of the core area occupied by placed standard cells, expressed as a decimal percentage (e.g., 72.500 = 72.5%). High utilization (>85%) may indicate routing congestion risk; low utilization (<50%) may indicate oversized floorplan.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coreAreaMm2 rdf:type rdf:Property ;
    rdfs:label 'Core Area Mm2' ;
    rdfs:comment 'Area of the core logic region in square millimeters (mm²), excluding I/O ring, power ring, and seal ring. Used to assess logic density and available routing resources.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctsInsertionDelayPs rdf:type rdf:Property ;
    rdfs:label 'Cts Insertion Delay Ps' ;
    rdfs:comment 'Clock insertion delay in picoseconds (ps) from the clock source to the farthest clock sink in the clock tree. Impacts setup timing margin and must be accounted for in static timing analysis (STA).' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctsSkewPs rdf:type rdf:Property ;
    rdfs:label 'Cts Skew Ps' ;
    rdfs:comment 'Clock skew in picoseconds (ps) achieved by the Clock Tree Synthesis (CTS) engine at this layout iteration. Measures the maximum difference in clock arrival times across all sink flip-flops. Lower skew improves timing closure margin.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dfmScore rdf:type rdf:Property ;
    rdfs:label 'Dfm Score' ;
    rdfs:comment 'Quantitative DFM (Design for Manufacturability) score assigned to this layout iteration by the DFM analysis tool (e.g., Mentor Calibre YieldAnalyzer). Higher scores indicate better manufacturability and expected yield; used to guide layout optimization before tapeout.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dftCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Dft Coverage Pct' ;
    rdfs:comment 'Fault coverage percentage achieved by the DFT (Design for Testability) implementation at this layout stage, as reported by ATPG (Automatic Test Pattern Generation) tools. Typically required to exceed 95% for production test qualification.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieAreaMm2 rdf:type rdf:Property ;
    rdfs:label 'Die Area Mm2' ;
    rdfs:comment 'Total die area in square millimeters (mm²) computed from the floorplan boundary. A primary PPA (Power, Performance, Area) metric used for cost estimation, yield modeling, and competitive benchmarking.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieHeightUm rdf:type rdf:Property ;
    rdfs:label 'Die Height Um' ;
    rdfs:comment 'Height of the die boundary in micrometers (µm) as defined in the physical layout floorplan. Together with die width, determines die area for yield and cost analysis.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieWidthUm rdf:type rdf:Property ;
    rdfs:label 'Die Width Um' ;
    rdfs:comment 'Width of the die boundary in micrometers (µm) as defined in the physical layout floorplan. Used for package selection, wafer yield estimation, and cost modeling.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drcCriticalViolationCount rdf:type rdf:Property ;
    rdfs:label 'Drc Critical Violation Count' ;
    rdfs:comment 'Number of DRC violations classified as critical (yield-impacting or functionality-blocking) as opposed to waivable violations. Critical DRC violations must be resolved before tapeout; waivable violations may be accepted with foundry approval.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drcViolationCount rdf:type rdf:Property ;
    rdfs:label 'Drc Violation Count' ;
    rdfs:comment 'Total number of Design Rule Check (DRC) violations detected in this layout iteration by the signoff DRC tool (e.g., Mentor Calibre, Synopsys IC Validator). A value of zero is required for tapeout approval.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emCompliant rdf:type rdf:Property ;
    rdfs:label 'Em Compliant' ;
    rdfs:comment 'Indicates whether all metal interconnects in the layout comply with electromigration (EM) current density limits specified by the foundry PDK. TRUE = EM compliant; FALSE = EM violations present requiring wire widening or rerouting.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsFileChecksum rdf:type rdf:Property ;
    rdfs:label 'Gds File Checksum' ;
    rdfs:comment 'SHA-256 cryptographic checksum of the GDSII/OASIS layout file for integrity verification. Used to confirm that the submitted tapeout file has not been corrupted or tampered with during transfer to the foundry.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsFileFormat rdf:type rdf:Property ;
    rdfs:label 'Gds File Format' ;
    rdfs:comment 'Format of the layout database file referenced in gds_file_path. GDSII is the traditional foundry submission format; OASIS (Open Artwork System Interchange Standard) is the modern compressed alternative; LEF/DEF is used for abstract/physical exchange.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStage rdf:type rdf:Property ;
    rdfs:label 'Implementation Stage' ;
    rdfs:comment 'Current stage in the physical implementation flow for this layout iteration. Stages progress from initial floorplan through placement, clock tree synthesis (CTS), routing, signoff, and final tapeout submission. [ENUM-REF-CANDIDATE: floorplan|placement|cts|routing|signoff|tapeout — promote to reference product if additional stages are needed]' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irDropMaxMv rdf:type rdf:Property ;
    rdfs:label 'Ir Drop Max Mv' ;
    rdfs:comment 'Maximum static IR drop in millivolts (mV) observed in the power grid analysis at this layout iteration. Excessive IR drop degrades circuit performance and reliability; must remain within foundry-specified limits for tapeout approval.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iterationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Iteration Timestamp' ;
    rdfs:comment 'Timestamp when this physical layout iteration checkpoint was captured and committed to the design database. Represents the principal business event time for this layout record, enabling chronological tracking of design progress.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:layoutName rdf:type rdf:Property ;
    rdfs:label 'Layout Name' ;
    rdfs:comment 'Human-readable name identifying this physical layout iteration, typically including the design name and iteration label (e.g., \'SoC_v3_floorplan_iter2\'). Used in Cadence Innovus and Synopsys ICC2 project naming conventions.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:layoutStatus rdf:type rdf:Property ;
    rdfs:label 'Layout Status' ;
    rdfs:comment 'Lifecycle status of this physical layout record. Tracks whether the layout is actively being worked on, under design review, approved for next stage, rejected requiring rework, or archived as a historical iteration.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:layoutVersion rdf:type rdf:Property ;
    rdfs:label 'Layout Version' ;
    rdfs:comment 'Version identifier for this physical layout iteration following semantic versioning (e.g., \'1.0.0\', \'2.3.1\'). Tracks incremental changes through the physical implementation flow from floorplan to tapeout.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lvsClean rdf:type rdf:Property ;
    rdfs:label 'Lvs Clean' ;
    rdfs:comment 'Indicates whether the physical layout passes Layout Versus Schematic (LVS) verification with zero errors, confirming that the layout netlist matches the schematic netlist. TRUE = LVS clean (required for tapeout); FALSE = LVS errors present.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metalFillDensityPct rdf:type rdf:Property ;
    rdfs:label 'Metal Fill Density Pct' ;
    rdfs:comment 'Average metal fill density percentage across all metal layers after dummy metal fill insertion. Foundry CMP (Chemical Mechanical Planarization) processes require metal density to remain within specified min/max bounds to ensure planar surfaces.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes capturing design decisions, known issues, waiver justifications, or iteration-specific observations recorded by the physical design engineer. Supports design review documentation and knowledge transfer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerConsumptionMw rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Mw' ;
    rdfs:comment 'Estimated total power consumption in milliwatts (mW) from power analysis at this layout iteration, including dynamic switching power and static leakage power. A key PPA (Power, Performance, Area) metric for product specification compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingCongestionLayer rdf:type rdf:Property ;
    rdfs:label 'Routing Congestion Layer' ;
    rdfs:comment 'Metal layer identifier (e.g., \'M4\', \'M7\') where the maximum routing congestion was observed. Used to guide targeted floorplan or placement adjustments to relieve congestion on the most constrained layer.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingCongestionMaxPct rdf:type rdf:Property ;
    rdfs:label 'Routing Congestion Max Pct' ;
    rdfs:comment 'Maximum routing congestion percentage observed across all metal layers in the layout, expressed as overflow percentage. Values above 5% typically indicate routing closure risk requiring floorplan or placement adjustment.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tapeoutDate rdf:type rdf:Property ;
    rdfs:label 'Tapeout Date' ;
    rdfs:comment 'Date on which the final GDSII/OASIS layout was submitted to the foundry for mask generation (tapeout). A critical milestone in the IC design lifecycle tracked against the product TTM (Time to Market) schedule.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tnsPs rdf:type rdf:Property ;
    rdfs:label 'Tns Ps' ;
    rdfs:comment 'Total Negative Slack (TNS) in picoseconds (ps), representing the sum of all negative slack values across all timing paths. Indicates the overall magnitude of timing violations in the design; must reach zero for tapeout signoff.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCellCount rdf:type rdf:Property ;
    rdfs:label 'Total Cell Count' ;
    rdfs:comment 'Total number of standard cells placed in the core area at this layout iteration. Includes combinational logic, sequential elements, buffers, and inverters. Used to assess design complexity and placement density.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wnsPs rdf:type rdf:Property ;
    rdfs:label 'Wns Ps' ;
    rdfs:comment 'Worst Negative Slack (WNS) in picoseconds (ps) from static timing analysis at this layout iteration. Negative values indicate timing violations; zero or positive values indicate timing closure. A key metric for tapeout readiness.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tapeoutId rdf:type rdf:Property ;
    rdfs:label 'Tapeout Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the tapeout event record. Primary key for the tapeout data product in the design domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tapeout .

ind:chipsActObligationId rdf:type rdf:Property ;
    rdfs:label 'Chips Act Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.chips_act_obligation. Business justification: CHIPS Act reporting obligations are tied to each tapeout; linking supports mandatory compliance reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChipsActObligation .

ind:customerDesignRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Customer Design Registration Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_design_registration. Business justification: A tapeout event fulfills a customer\'s registered design project. This link enables the vendor to update customer_design_registration qualification_status and production_target_date upon tapeout comple' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerDesignRegistration .

ind:maskPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Mask Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_order. Business justification: Tapeout triggers mask set procurement via PO to foundry. Direct business process linking design milestone to procurement transaction. Essential for tracking mask costs, delivery schedules, and foundry' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:qualificationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Id' ;
    rdfs:comment 'Foreign key linking to process.process_qualification. Business justification: Tapeout approval requires process qualification sign-off — foundries mandate that the process flow used for a tapeout has completed qualification before GDS submission is accepted. This traceability i' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Qualification .

ind:tapeoutIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Tapeout Ic Design Project Id' ;
    rdfs:comment 'Reference to the parent IC design record from which this tapeout was generated. Links tapeout provenance back to the design lifecycle in the design domain.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:designName rdf:type rdf:Property ;
    rdfs:label 'Design Name' ;
    rdfs:comment 'Human-readable name of the IC design being taped out (e.g., product code name or internal design designation). Used for identification in design review meetings and foundry communications.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designRevision rdf:type rdf:Property ;
    rdfs:label 'Design Revision' ;
    rdfs:comment 'Revision identifier of the design at the time of tapeout (e.g., A0, B1, C2). Distinguishes successive tapeout iterations of the same design, critical for mask set versioning and silicon bring-up tracking.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieSizeMm2 rdf:type rdf:Property ;
    rdfs:label 'Die Size Mm2' ;
    rdfs:comment 'Physical area of the die in square millimeters as defined in the final GDS layout at tapeout. A key Power-Performance-Area (PPA) metric used for cost modeling, yield estimation, and wafer utilization planning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drcClean rdf:type rdf:Property ;
    rdfs:label 'Drc Clean' ;
    rdfs:comment 'Indicates whether the final GDS layout passed all Design Rule Check (DRC) violations with zero errors at the time of tapeout submission. A TRUE value is a mandatory tapeout sign-off criterion per foundry requirements.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ercClean rdf:type rdf:Property ;
    rdfs:label 'Erc Clean' ;
    rdfs:comment 'Indicates whether the design passed Electrical Rule Check (ERC) with no violations at tapeout. ERC validates electrical connectivity integrity including floating nodes, antenna violations, and electromigration rules.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedYieldPct rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Pct' ;
    rdfs:comment 'Predicted die yield percentage (good dies per wafer as a percentage of total dies per wafer) at the time of tapeout, based on DFM analysis and process node historical yield data. Used for production planning and cost-per-die estimation.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foundryName rdf:type rdf:Property ;
    rdfs:label 'Foundry Name' ;
    rdfs:comment 'Name of the semiconductor fabrication facility (FAB) or foundry to which the tapeout was submitted (e.g., TSMC, Samsung Foundry, GlobalFoundries, Intel Foundry Services). Used for supply chain and vendor management reporting.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsFileVersion rdf:type rdf:Property ;
    rdfs:label 'Gds File Version' ;
    rdfs:comment 'Version identifier of the final GDS/GDSII layout file submitted for tapeout. Provides design data provenance linking the physical layout file to the tapeout event. Sourced from Cadence Virtuoso or equivalent EDA tool.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipSignOffComplete rdf:type rdf:Property ;
    rdfs:label 'Ip Sign Off Complete' ;
    rdfs:comment 'Indicates whether all third-party and internal Intellectual Property (IP) cores integrated in the design have received sign-off approval for inclusion in the tapeout. Ensures IP licensing compliance and integration verification are complete.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maskCostUsd rdf:type rdf:Property ;
    rdfs:label 'Mask Cost Usd' ;
    rdfs:comment 'Cost of the photolithography mask set fabrication for this tapeout in US dollars. A major component of NRE cost, tracked separately for cost accounting and foundry invoice reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maskCount rdf:type rdf:Property ;
    rdfs:label 'Mask Count' ;
    rdfs:comment 'Total number of photolithography masks in the mask set for this tapeout. Directly drives NRE mask cost and is a key input to tapeout cost modeling. Includes FEOL, MOL, and BEOL layers.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opcRetStatus rdf:type rdf:Property ;
    rdfs:label 'Opc Ret Status' ;
    rdfs:comment 'Processing status of Optical Proximity Correction (OPC) and Resolution Enhancement Technology (RET) applied to the GDS data prior to mask tape-out. OPC/RET is mandatory for sub-28nm nodes to compensate for photolithographic distortion effects.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signoffChecklistComplete rdf:type rdf:Property ;
    rdfs:label 'Signoff Checklist Complete' ;
    rdfs:comment 'Indicates whether all items on the design sign-off checklist have been completed and approved prior to tapeout submission. The checklist covers DRC, LVS, ERC, timing closure, power analysis, DFT, and IP sign-off milestones.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tapeoutNumber rdf:type rdf:Property ;
    rdfs:label 'Tapeout Number' ;
    rdfs:comment 'Externally-known business identifier for the tapeout event, used in communications with the foundry, mask house, and internal design teams. Follows the format TO-<DESIGN_CODE>-<YEAR>.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutStatus rdf:type rdf:Property ;
    rdfs:label 'Tapeout Status' ;
    rdfs:comment 'Current lifecycle state of the tapeout event. Tracks progression from internal preparation through foundry acceptance or rejection. [ENUM-REF-CANDIDATE: draft|pending_signoff|submitted|accepted|rejected|cancelled — promote to reference product if additional states are needed]' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutType rdf:type rdf:Property ;
    rdfs:label 'Tapeout Type' ;
    rdfs:comment 'Classification of the tapeout run type. Distinguishes full custom dedicated wafer tapeouts, Multi-Project Wafer (MPW) shuttle runs, engineering sample tapeouts, and production tapeouts. Drives cost allocation and foundry scheduling.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketSegment rdf:type rdf:Property ;
    rdfs:label 'Target Market Segment' ;
    rdfs:comment 'Primary market segment for which the taped-out IC is designed. Used for business reporting, revenue forecasting, and strategic portfolio analysis. [ENUM-REF-CANDIDATE: mobile|automotive|datacenter|IoT|industrial|consumer|aerospace_defense|networking — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTapeoutDate rdf:type rdf:Property ;
    rdfs:label 'Target Tapeout Date' ;
    rdfs:comment 'Originally planned tapeout date as committed in the project schedule. Used to measure schedule adherence and Time to Market (TTM) variance against the actual tapeout date.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waferCountOrdered rdf:type rdf:Property ;
    rdfs:label 'Wafer Count Ordered' ;
    rdfs:comment 'Number of wafers ordered from the foundry for this tapeout run. Used for production planning, yield forecasting, and supply chain management. Applicable for dedicated tapeouts; for MPW runs, this reflects the allocated wafer share.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shuttleExportLicenseId rdf:type rdf:Property ;
    rdfs:label 'Shuttle Export License Id' ;
    rdfs:comment 'Foreign key linking to compliance.export_license. Business justification: MPW shuttles aggregate designs from multiple entities including foreign participants. Export license required when shuttle includes ITAR/EAR-controlled technology. Real process: shuttle export complia' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExportLicense .

ind:shuttlePurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Shuttle Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_order. Business justification: MPW shuttle participation requires PO for shuttle slot and wafer allocation. Direct procurement relationship linking shuttle reservation to foundry order. Essential for cost tracking, payment processi' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:shuttleSourcingContractId rdf:type rdf:Property ;
    rdfs:label 'Shuttle Sourcing Contract Id' ;
    rdfs:comment 'Foreign key linking to supply.sourcing_contract. Business justification: MPW shuttles operate under master service agreements with foundries defining pricing, terms, and shuttle schedules. Links shuttle to governing contract for pricing verification, terms compliance, and ' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingContract .

ind:actualDieReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Die Release Date' ;
    rdfs:comment 'Actual date on which fabricated dies were released by the foundry. Compared against scheduled_die_release_date to assess foundry delivery performance and downstream packaging schedule impact.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualTapeoutDate rdf:type rdf:Property ;
    rdfs:label 'Actual Tapeout Date' ;
    rdfs:comment 'Actual date on which the final GDS/GDSII data package was submitted to the foundry for mask generation. Compared against scheduled_tapeout_date to measure tapeout schedule adherence and TTM performance.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualWaferStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Wafer Start Date' ;
    rdfs:comment 'Actual date on which the foundry commenced wafer processing for this MPW shuttle lot. Used to measure foundry schedule adherence and to calculate actual cycle time.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocatedProjectCount rdf:type rdf:Property ;
    rdfs:label 'Allocated Project Count' ;
    rdfs:comment 'Number of distinct IC design projects participating in and allocated die area within this MPW shuttle run. Tracks shuttle utilization and cost-sharing distribution.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chipsActEligible rdf:type rdf:Property ;
    rdfs:label 'Chips Act Eligible' ;
    rdfs:comment 'Indicates whether this MPW shuttle run qualifies for US CHIPS and Science Act incentives or subsidies based on domestic fabrication requirements, technology node, and participating project criteria.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerMm2Usd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Mm2 Usd' ;
    rdfs:comment 'Unit cost in US Dollars per square millimeter of die area on this shuttle. Used to calculate each participating project\'s cost share based on their allocated die area. Derived from foundry pricing and total reticle area.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costSharingModel rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Model' ;
    rdfs:comment 'Method used to allocate the total shuttle cost among participating design projects. Proportional area charges each project based on die area consumed; fixed slot assigns equal shares; tiered applies volume-based rates; negotiated uses custom terms.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all monetary amounts recorded in this shuttle record (e.g., USD, EUR, TWD). Ensures consistent financial reporting and multi-currency reconciliation in SAP S/4HANA FI.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Dft Requirement Flag' ;
    rdfs:comment 'Indicates whether participating designs in this shuttle are required to implement Design for Testability (DFT) structures (e.g., scan chains, BIST) as a condition of shuttle participation. True if DFT is mandatory.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foundryAccountManager rdf:type rdf:Property ;
    rdfs:label 'Foundry Account Manager' ;
    rdfs:comment 'Name of the foundry-side account manager or technical program manager responsible for this MPW shuttle engagement. Used for escalation and commercial relationship management.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsSubmissionFormat rdf:type rdf:Property ;
    rdfs:label 'Gds Submission Format' ;
    rdfs:comment 'File format required for final design data submission to the foundry for this shuttle. GDSII is the legacy industry standard; OASIS is the modern compressed alternative; LEF/DEF is used for certain digital flows.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipNdaRequired rdf:type rdf:Property ;
    rdfs:label 'Ip Nda Required' ;
    rdfs:comment 'Indicates whether participating design projects are required to execute a Non-Disclosure Agreement (NDA) to protect IP confidentiality within the shared MPW shuttle environment. Relevant for multi-company shuttle participation.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lithographyTechnology rdf:type rdf:Property ;
    rdfs:label 'Lithography Technology' ;
    rdfs:comment 'Photolithography technology used for patterning in this shuttle run. Extreme Ultraviolet (EUV) is used for leading-edge nodes; Deep Ultraviolet (DUV) for mature nodes. Impacts mask cost, cycle time, and OPC complexity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskSetCostUsd rdf:type rdf:Property ;
    rdfs:label 'Mask Set Cost Usd' ;
    rdfs:comment 'Cost in US Dollars for the full photomask set required for this shuttle run. Mask costs are a major NRE component, especially for EUV processes, and are shared across participating projects proportionally.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Nre Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA CO cost center code to which the NRE and shuttle fabrication costs are initially booked before being allocated to participating design projects. Supports financial controlling and budget tracking.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processDesignKitVersion rdf:type rdf:Property ;
    rdfs:label 'Process Design Kit Version' ;
    rdfs:comment 'Version identifier of the Process Design Kit (PDK) provided by the foundry and used for all participating designs in this shuttle. Ensures all designs comply with the same design rules, device models, and layout constraints.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDieReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Die Release Date' ;
    rdfs:comment 'Planned date for the foundry to complete fabrication and release diced wafers or Known Good Dies (KGD) to the customer or OSAT partner for packaging and assembly.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledTapeoutDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Tapeout Date' ;
    rdfs:comment 'Planned date by which all participating design projects must submit final GDS/GDSII data for the shuttle. Tapeout is the final design submission milestone triggering mask fabrication and wafer processing.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledWaferStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Wafer Start Date' ;
    rdfs:comment 'Planned date for the foundry to begin wafer processing (lot start) for this MPW shuttle. Marks the transition from design domain to fabrication domain in the IC development lifecycle.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shuttleCode rdf:type rdf:Property ;
    rdfs:label 'Shuttle Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned by the foundry or shuttle service provider to uniquely identify this MPW run. Used for cross-referencing with foundry purchase orders, lot tracking systems, and Camstar MES wafer lot records.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shuttleDescription rdf:type rdf:Property ;
    rdfs:label 'Shuttle Description' ;
    rdfs:comment 'Free-text description of the MPW shuttle run, including its primary purpose, target applications, special process options (e.g., embedded non-volatile memory, RF options, high-voltage), and any notable constraints or conditions.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shuttleName rdf:type rdf:Property ;
    rdfs:label 'Shuttle Name' ;
    rdfs:comment 'Human-readable name or label assigned to the MPW shuttle run, typically including foundry code, process node, and run sequence (e.g., TSMC-N5-MPW-2024Q3-01). Used as the primary business identifier across design and fabrication teams.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shuttleStatus rdf:type rdf:Property ;
    rdfs:label 'Shuttle Status' ;
    rdfs:comment 'Current lifecycle state of the MPW shuttle run. Tracks progression from initial planning through tapeout submission, wafer start, active fabrication, and final completion or cancellation. [ENUM-REF-CANDIDATE: planning|open|tapeout_submitted|wafer_started|fabrication|completed|cancelled — promote to reference product]' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shuttleType rdf:type rdf:Property ;
    rdfs:label 'Shuttle Type' ;
    rdfs:comment 'Classification of the shuttle run by its purpose and risk profile. Standard MPW is a fully shared cost run; engineering run is for process validation; risk production is a pre-production volume run; prototype is a single-project low-volume run.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProcessOptions rdf:type rdf:Property ;
    rdfs:label 'Special Process Options' ;
    rdfs:comment 'Comma-separated list of optional process modules or specialty layers enabled for this shuttle run (e.g., eNVM, RF, HV, MIM capacitor, thick metal). Participating designs must declare which options they require.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) by which all participating projects must submit their final GDS/GDSII data and sign-off documentation to the shuttle coordinator. Hard deadline; late submissions result in exclusion from the shuttle.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalReticleAreaMm2 rdf:type rdf:Property ;
    rdfs:label 'Total Reticle Area Mm2' ;
    rdfs:comment 'Total usable reticle (mask field) area in square millimeters available for allocation across all participating design projects in this shuttle. Constrains the sum of all individual project die area allocations.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalShuttleCostUsd rdf:type rdf:Property ;
    rdfs:label 'Total Shuttle Cost Usd' ;
    rdfs:comment 'Total Non-Recurring Engineering (NRE) and fabrication cost in US Dollars for the entire MPW shuttle run, including mask set costs, wafer processing fees, and foundry service charges. Basis for cost-sharing allocation across participating projects.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWaferCount rdf:type rdf:Property ;
    rdfs:label 'Total Wafer Count' ;
    rdfs:comment 'Total number of wafers allocated to this MPW shuttle run across all participating design projects. Determines total silicon area available for die allocation and directly impacts per-project die yield.' ;
    rdfs:domain ind:MpwShuttle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Wafer Diameter Mm' ;
    rdfs:comment 'Diameter of the silicon wafer substrate in millimeters used in this shuttle run (e.g., 200mm, 300mm, 450mm). Determines total die area per wafer and influences cost-per-die calculations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSupplierId rdf:type rdf:Property ;
    rdfs:label 'Vendor Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: EDA tools (Synopsys, Cadence, Mentor) are licensed from vendors tracked as suppliers. Essential for license procurement, maintenance renewals, support contracts, and vendor management. Links tool to i' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:annualLicenseCostUsd rdf:type rdf:Property ;
    rdfs:label 'Annual License Cost Usd' ;
    rdfs:comment 'Annual cost of the EDA tool license in US Dollars as contracted with the vendor. For perpetual licenses, represents the annual maintenance and support fee. Used for R&D cost allocation, NRE budgeting, and design cost-per-project analysis in SAP S/4HANA CO.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedUserGroups rdf:type rdf:Property ;
    rdfs:label 'Approved User Groups' ;
    rdfs:comment 'Comma-separated list of authorized engineering groups or organizational units permitted to use this EDA tool (e.g., \'IC_Design,Physical_Design,DFT_Engineering\'). Used for access control enforcement, license allocation governance, and ITAR/EAR user screening compliance.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computePlatformType rdf:type rdf:Property ;
    rdfs:label 'Compute Platform Type' ;
    rdfs:comment 'Deployment model for this EDA tool: \'on_premise\' = installed on internal compute farm; \'cloud\' = deployed on cloud EDA platform (e.g., AWS, Azure, Cadence Cloud); \'hybrid\' = split between on-premise and cloud burst. Drives infrastructure cost allocation and data sovereignty compliance.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concurrentUsersPeak rdf:type rdf:Property ;
    rdfs:label 'Concurrent Users Peak' ;
    rdfs:comment 'Maximum number of concurrent users or license checkouts observed for this tool during peak design activity periods (e.g., pre-tapeout crunch). Used to assess license adequacy, identify bottlenecks, and justify license pool expansion requests.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designFlowStage rdf:type rdf:Property ;
    rdfs:label 'Design Flow Stage' ;
    rdfs:comment 'Primary IC design flow stage at which this EDA tool is deployed. Maps to the standard front-to-back design flow: rtl_design (RTL coding and simulation), logic_synthesis (RTL-to-netlist via Design Compiler), physical_design (place-and-route via Innovus), signoff (STA/DRC/LVS/PEX), verification (formal/functional), packaging (assembly design), other. [ENUM-REF-CANDIDATE: rtl_design|logic_synthesis|physical_design|signoff|verification|packaging|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Dft Support Flag' ;
    rdfs:comment 'Indicates whether this EDA tool includes or supports DFT capabilities such as ATPG, scan insertion, BIST, or boundary scan (IEEE 1149.1 JTAG). True = DFT-capable; False = no DFT support. Used to determine tool eligibility for DFT-required design projects.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:euvProcessSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Euv Process Support Flag' ;
    rdfs:comment 'Indicates whether this EDA tool version is validated for use with EUV lithography process nodes (typically sub-7nm). True = EUV-qualified. Relevant for OPC, mask synthesis, and DRC tools where EUV-specific rule decks are required.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flowIntegrationPoint rdf:type rdf:Property ;
    rdfs:label 'Flow Integration Point' ;
    rdfs:comment 'Description of how this tool integrates into the enterprise EDA design flow, including upstream and downstream tool handoffs (e.g., \'Receives synthesized netlist from Synopsys DC; outputs DEF/LEF to Cadence Innovus; interfaces with PrimeTime for timing constraints\'). Used for flow documentation and tool dependency management.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formalVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Formal Verification Flag' ;
    rdfs:comment 'Indicates whether this EDA tool supports formal verification methodologies (equivalence checking, model checking, property verification). True = formal verification capable. Used to classify tools for safety-critical design flows (automotive ISO 26262, IEC 61508).' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationPath rdf:type rdf:Property ;
    rdfs:label 'Installation Path' ;
    rdfs:comment 'File system path or network mount point where this EDA tool version is installed on the compute infrastructure (e.g., \'/tools/synopsys/dc/2023.09\'). Used by design flow scripts, Makefiles, and environment setup modules to locate the correct tool binary.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itarControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Itar Controlled Flag' ;
    rdfs:comment 'Indicates whether this EDA tool is subject to ITAR controls, restricting its use, transfer, or disclosure to foreign persons without a license. True = ITAR-controlled; False = not ITAR-controlled. Mandatory for compliance with US State Department ITAR regulations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Most recent date on which a license checkout was recorded for this EDA tool version. Used to identify dormant or underutilized tools for license reclamation, cost optimization, and EOL planning decisions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseCount rdf:type rdf:Property ;
    rdfs:label 'License Count' ;
    rdfs:comment 'Total number of license seats or tokens procured for this EDA tool version. For floating licenses, represents the maximum concurrent user count. For node-locked, represents the number of authorized hosts. Used for license compliance audits and capacity planning.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseServerHost rdf:type rdf:Property ;
    rdfs:label 'License Server Host' ;
    rdfs:comment 'Hostname or IP address of the FlexLM/RLM license server managing floating license pools for this tool. Null for node-locked or cloud-based licenses. Required for license server failover planning and network access control configuration.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'Date on which the current EDA tool license agreement becomes effective. Defines the start of the licensed usage period for subscription and term-based licenses. Used alongside license_expiry_date to determine the active license window for compliance reporting.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'License Utilization Pct' ;
    rdfs:comment 'Average license utilization rate expressed as a percentage of total licensed seats consumed over the most recent reporting period (e.g., 78.50 = 78.5%). Calculated as (average concurrent checkouts / total license count) × 100. Used for license optimization, rightsizing, and vendor negotiation.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Maintenance Renewal Date' ;
    rdfs:comment 'Date by which the annual maintenance and support contract for this EDA tool must be renewed to maintain access to patches, updates, and vendor support. Triggers procurement renewal workflow in SAP S/4HANA MM. Distinct from license_expiry_date for perpetual licenses.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pdkCompatibilityVersion rdf:type rdf:Property ;
    rdfs:label 'Pdk Compatibility Version' ;
    rdfs:comment 'Specific PDK version string with which this EDA tool version has been validated for correct DRC, LVS, and parasitic extraction results (e.g., \'TSMC_N5_PDK_v1.3\', \'Samsung_SF3_PDK_v2.0\'). Ensures design rule compliance and sign-off accuracy for tapeout submissions.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedBy rdf:type rdf:Property ;
    rdfs:label 'Qualified By' ;
    rdfs:comment 'Name or employee ID of the CAD/EDA engineer or team responsible for qualifying this tool version. Provides accountability for the qualification sign-off and is referenced in design methodology documentation and audit packages.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this EDA tool record was first created in the master catalog. Provides audit trail for tool onboarding and is used for data lineage tracking in the Databricks Silver Layer. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this EDA tool record in the master catalog. Used for change tracking, data freshness monitoring, and incremental ETL processing in the Databricks Silver Layer. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this EDA tool record was sourced or is mastered (e.g., \'oracle_agile_plm\', \'siemens_teamcenter\', \'sap_s4hana\', \'manual\'). Supports data lineage, reconciliation, and master data management governance in the lakehouse.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedOsPlatforms rdf:type rdf:Property ;
    rdfs:label 'Supported Os Platforms' ;
    rdfs:comment 'Comma-separated list of operating system platforms on which this EDA tool version is certified to run (e.g., \'RHEL7,RHEL8,CentOS7,SLES15\'). Required for IT infrastructure planning, compute farm provisioning, and tool qualification sign-off.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedProcessNodes rdf:type rdf:Property ;
    rdfs:label 'Supported Process Nodes' ;
    rdfs:comment 'Comma-separated list of semiconductor process technology nodes (in nanometers) for which this EDA tool version is qualified and PDK-validated (e.g., \'3nm,5nm,7nm,12nm,28nm\'). Determines tool eligibility for specific tapeout projects. Validated against PDK release notes from foundry partners.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolCategory rdf:type rdf:Property ;
    rdfs:label 'Tool Category' ;
    rdfs:comment 'Functional classification of the EDA tool within the IC design flow. Drives tool selection, flow integration, and license budgeting. Valid categories: synthesis (logic synthesis), simulation (functional/timing simulation), formal_verification, place_and_route (physical implementation), sta (Static Timing Analysis), drc_lvs (Design Rule Check / Layout vs. Schematic), parasitic_extraction, power_analysis, signal_integrity, other. [ENUM-REF-CANDIDATE: synthesis|simulation|formal_verification|place_and_route|sta|drc_lvs|parasitic_extraction|power_analysis|signal_integrity|other — promote to reference product]' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolCode rdf:type rdf:Property ;
    rdfs:label 'Tool Code' ;
    rdfs:comment 'Externally-known, human-readable unique business identifier for the EDA tool (e.g., \'SYNOPSYS-DC-2023\', \'CADENCE-INNOVUS-22\'). Used as the canonical reference code across PLM, procurement, and license management systems. Maps to the tool catalog number in Oracle Agile PLM.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolDescription rdf:type rdf:Property ;
    rdfs:label 'Tool Description' ;
    rdfs:comment 'Free-text description of the EDA tool\'s functional capabilities, primary use cases, and design flow role. Provides context for engineers selecting tools for new projects and for onboarding documentation. Sourced from vendor product documentation and internal CAD team notes.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolName rdf:type rdf:Property ;
    rdfs:label 'Tool Name' ;
    rdfs:comment 'Full commercial name of the EDA tool as published by the vendor (e.g., \'Synopsys Design Compiler\', \'Cadence Innovus Implementation System\', \'Siemens Calibre DRC\'). Primary human-readable label used in design flow documentation and license agreements.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolStatus rdf:type rdf:Property ;
    rdfs:label 'Tool Status' ;
    rdfs:comment 'Current lifecycle state of the EDA tool in the enterprise design environment. \'active\' = qualified and in production use; \'deprecated\' = superseded but still permitted for legacy projects; \'evaluation\' = under qualification testing; \'retired\' = no longer licensed or supported; \'pending_qualification\' = awaiting PDK and flow validation sign-off.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolVersion rdf:type rdf:Property ;
    rdfs:label 'Tool Version' ;
    rdfs:comment 'Specific release version string of the EDA tool as provided by the vendor (e.g., \'2023.09\', \'v22.1\', \'21.1.0.1\'). Critical for design reproducibility, PDK compatibility validation, and regression testing. Tracked in Siemens Teamcenter PLM for design provenance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContractNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Number' ;
    rdfs:comment 'Vendor-assigned or internally-assigned contract reference number for the EDA tool license agreement. Links this tool record to the corresponding procurement contract in SAP S/4HANA MM for spend tracking, renewal management, and audit compliance.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSupportTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Support Tier' ;
    rdfs:comment 'Level of vendor technical support contracted for this EDA tool (e.g., \'standard\' = business-hours support; \'premium\' = 24/7 with dedicated TAM; \'elite\' = on-site engineering support; \'end_of_support\' = vendor no longer provides patches or fixes). Impacts risk assessment for production tapeout use.' ;
    rdfs:domain ind:EdaTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetId rdf:type rdf:Property ;
    rdfs:label 'Rule Set Id' ;
    rdfs:comment 'Unique surrogate identifier for the design rule set record in the semiconductor design domain. Primary key for the design_rule_set data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RuleSet .

ind:parentRuleSetId rdf:type rdf:Property ;
    rdfs:label 'Parent Rule Set Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent rule set from which this rule set was derived or branched. Supports hierarchical rule set structures where project-specific rule sets inherit from a foundry-standard base deck.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RuleSet .

ind:primarySupersededByRuleSetId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Rule Set Id' ;
    rdfs:comment 'Reference to the design_rule_set_id of the newer rule set version that replaces this one when status is Superseded. Enables forward navigation of the rule set version chain for design migration planning.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RuleSet .

ind:applicableDesignPhase rdf:type rdf:Property ;
    rdfs:label 'Applicable Design Phase' ;
    rdfs:comment 'IC design lifecycle phase during which this rule set is enforced. RTL = register-transfer level; Synthesis = logic synthesis; Floorplan = physical planning; Place-and-Route = physical implementation; Signoff = pre-tapeout verification; Tapeout = final GDS/GDSII submission check.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which this rule set version received formal engineering approval and was cleared for production use. Distinct from effective_from_date; approval may precede the effective date to allow design teams preparation time.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedWaiverCount rdf:type rdf:Property ;
    rdfs:label 'Approved Waiver Count' ;
    rdfs:comment 'Number of currently active, formally approved waivers against rules in this rule set. Provides a quick quality signal; high waiver counts may indicate rule set misalignment with design intent or process capability.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authoredByTeam rdf:type rdf:Property ;
    rdfs:label 'Authored By Team' ;
    rdfs:comment 'Name of the internal engineering team or external foundry group responsible for authoring and maintaining this rule set. Examples: DFM-Engineering, DFT-Architecture, Foundry-PDK-Team, Process-Integration. Used for ownership tracking and escalation routing.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Formal change control number assigned by Oracle Agile PLM or Siemens Teamcenter when this rule set version was created or modified through the engineering change management process. Provides full audit traceability to the change record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationApprovalWorkflow rdf:type rdf:Property ;
    rdfs:label 'Deviation Approval Workflow' ;
    rdfs:comment 'Defines the change control workflow required to approve deviations or modifications to this rule set. None = no formal workflow; Single-Approver = one designated approver; Dual-Approver = two independent approvers required; Change-Control-Board = full CCB review required per Oracle Agile PLM change management process.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this rule set version is binding and enforceable in design flows. Designs initiated on or after this date must comply with this version. Supports temporal rule set management across concurrent design projects.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date after which this rule set version is no longer valid for new design starts. Null indicates the rule set is open-ended with no planned expiry. Enables orderly transition to superseding rule set versions.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feolBeolScope rdf:type rdf:Property ;
    rdfs:label 'Feol Beol Scope' ;
    rdfs:comment 'Indicates which portion of the wafer fabrication stack the rules in this set govern. FEOL = transistor-level rules (gate, diffusion, well); BEOL = interconnect and metal layer rules; MOL = middle-of-line contact and via rules; Full-Stack = rules spanning all layers; Not-Applicable = for non-physical rule sets such as DFT scan rules.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundrySource rdf:type rdf:Property ;
    rdfs:label 'Foundry Source' ;
    rdfs:comment 'Name of the semiconductor foundry or internal engineering team that authored or supplied this rule set. Examples: TSMC, Samsung Foundry, GlobalFoundries, Internal-DFM-Team. Establishes provenance and accountability for rule content.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipClassification rdf:type rdf:Property ;
    rdfs:label 'Ip Classification' ;
    rdfs:comment 'Intellectual property ownership classification of the rule set content. Proprietary = owned by the company; Foundry-Confidential = supplied under NDA by the foundry; Third-Party-Licensed = licensed from an EDA vendor or IP provider; Open-Standard = based on publicly available standards. Governs distribution and usage rights.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpwCompatible rdf:type rdf:Property ;
    rdfs:label 'Mpw Compatible' ;
    rdfs:comment 'Indicates whether this rule set is certified for use in Multi-Project Wafer (MPW) shuttle runs, where multiple customer designs share a single wafer. MPW-compatible rule sets must satisfy additional density and boundary isolation requirements.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nreImpact rdf:type rdf:Property ;
    rdfs:label 'Nre Impact' ;
    rdfs:comment 'Indicates whether violations of this rule set have Non-Recurring Engineering (NRE) cost implications, such as requiring mask re-spins or additional foundry qualification runs. Used in project risk and cost management reporting.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opcRequired rdf:type rdf:Property ;
    rdfs:label 'Opc Required' ;
    rdfs:comment 'Indicates whether Optical Proximity Correction (OPC) must be applied to layouts before this rule set\'s DRC checks are considered valid. True = OPC is a prerequisite for rule compliance; False = rules apply to pre-OPC geometry.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Summary of changes, additions, and deletions introduced in this version of the rule set relative to the previous version. Enables design teams to assess migration impact when upgrading to a new rule set version.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCount rdf:type rdf:Property ;
    rdfs:label 'Rule Count' ;
    rdfs:comment 'Total number of individual design rules contained within this rule set. Used for completeness validation, rule coverage reporting, and comparison across rule set versions to detect additions or deletions.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleDeckChecksum rdf:type rdf:Property ;
    rdfs:label 'Rule Deck Checksum' ;
    rdfs:comment 'SHA-256 cryptographic hash of the rule deck file, used to verify integrity and detect unauthorized modifications. Enables audit trail compliance and ensures the exact rule deck used at tapeout is reproducible.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDeckFilePath rdf:type rdf:Property ;
    rdfs:label 'Rule Deck File Path' ;
    rdfs:comment 'Canonical file system or object storage path to the rule deck source file(s) for this rule set. Stored in the design data repository (e.g., Cadence Design Intent or Teamcenter vault). Classified confidential as it reveals internal IP and design infrastructure topology.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Set Category' ;
    rdfs:comment 'Categorizes the origin and scope of the rule set relative to the base PDK rule deck. Supplemental rules extend the foundry PDK; Project-Specific rules apply only to a named design project; Foundry-Standard rules are delivered directly by the foundry; Internal-Engineering rules are authored by the IC design team; Customer-Mandated rules are imposed by an end customer.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetCode rdf:type rdf:Property ;
    rdfs:label 'Rule Set Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this rule set across design teams, EDA tools, and foundry interfaces. Used as the business key in Cadence Virtuoso, Synopsys IC Validator, and Siemens Calibre configurations. Example: DRS-DFM-N5-2024-R3.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Set Description' ;
    rdfs:comment 'Free-text narrative description of the rule set\'s purpose, scope, and key engineering rationale. Provides context for design engineers selecting rule sets and for auditors reviewing tapeout compliance packages.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetName rdf:type rdf:Property ;
    rdfs:label 'Rule Set Name' ;
    rdfs:comment 'Human-readable descriptive name of the design rule set, used in PLM and EDA tool dashboards. Example: \'N5 DFM Supplemental Rules Rev3\' or \'TSMC 7nm Antenna Rule Deck\'.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Set Status' ;
    rdfs:comment 'Current lifecycle state of the rule set governing its usability in active design flows. Draft = under authoring; Under-Review = pending engineering sign-off; Approved = cleared for use; Active = currently enforced in production flows; Deprecated = no longer recommended; Superseded = replaced by a newer version.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetType rdf:type rdf:Property ;
    rdfs:label 'Rule Set Type' ;
    rdfs:comment 'Classification of the rule set by its engineering function. DRC = Design Rule Check (geometric), LVS = Layout vs. Schematic, ERC = Electrical Rule Check, DFM = Design for Manufacturability recommended rules, DFT = Design for Testability scan insertion rules, Antenna = metal antenna effect rules, Density = metal/poly fill density rules, Custom = project-specific overrides. [ENUM-REF-CANDIDATE: DRC|LVS|ERC|DFM|DFT|Antenna|Density|Custom — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'Default severity level assigned to violations of rules within this rule set. Error = must be resolved before tapeout; Warning = requires engineering review; Advisory = informational, no blocking action; Waivable = can be formally waived with approval. Individual rules may override this default.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyFamily rdf:type rdf:Property ;
    rdfs:label 'Technology Family' ;
    rdfs:comment 'Semiconductor device technology family for which this rule set is applicable. Examples: FinFET, GAA (Gate All Around), Planar CMOS, BiCMOS, SiGe, GaN. Determines the physical and electrical rule paradigms encoded in the rule set.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverPolicy rdf:type rdf:Property ;
    rdfs:label 'Waiver Policy' ;
    rdfs:comment 'Defines the approval authority required to grant a waiver for violations of rules in this set. No-Waiver = violations are never waivable; Engineering-Approval = design engineering lead sign-off required; Management-Approval = director or VP sign-off required; Foundry-Approval = foundry must co-sign the waiver.' ;
    rdfs:domain ind:RuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulationRunId rdf:type rdf:Property ;
    rdfs:label 'Simulation Run Id' ;
    rdfs:comment 'Unique system-generated identifier for each simulation or verification run record. Primary key for the simulation_run data product.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assertionCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Assertion Coverage Pct' ;
    rdfs:comment 'Percentage of SystemVerilog Assertions (SVA) or PSL assertions that were triggered and evaluated during this simulation run. Measures the effectiveness of assertion-based verification.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codeCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Code Coverage Pct' ;
    rdfs:comment 'Percentage of RTL or gate-level code coverage achieved by this simulation run, aggregating line, branch, condition, expression, and FSM coverage metrics. Indicates structural completeness of verification.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:computeCluster rdf:type rdf:Property ;
    rdfs:label 'Compute Cluster' ;
    rdfs:comment 'Name or identifier of the compute farm, LSF cluster, or cloud compute environment on which this simulation run was executed. Supports infrastructure cost allocation and capacity utilization analysis.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpuHoursConsumed rdf:type rdf:Property ;
    rdfs:label 'Cpu Hours Consumed' ;
    rdfs:comment 'Total CPU compute hours consumed by this simulation run across all parallel processes. Used for compute cost allocation, capacity planning, and NRE (Non-Recurring Engineering) cost tracking.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Date and time when the simulation or verification run completed, failed, or was aborted. Used together with start_timestamp to compute run duration for capacity planning and SLA tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:functionalCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Functional Coverage Pct' ;
    rdfs:comment 'Percentage of functional coverage points (covergroups, coverpoints, cross-coverage) exercised by this simulation run. Measures how thoroughly the design specification has been verified. Applicable to functional simulation runs.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Overall verification outcome of the simulation run indicating whether the design passed all checks, failed one or more checks, had violations waived by engineering sign-off, or produced an inconclusive result. Critical for tapeout sign-off compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakMemoryGb rdf:type rdf:Property ;
    rdfs:label 'Peak Memory Gb' ;
    rdfs:comment 'Maximum RAM memory consumed in gigabytes during this simulation run. Critical for compute infrastructure sizing, job scheduling, and identifying memory-intensive verification tasks.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processCorner rdf:type rdf:Property ;
    rdfs:label 'Process Corner' ;
    rdfs:comment 'Process corner of the PVT (Process, Voltage, Temperature) operating condition under which this simulation run was executed. Defines the transistor performance variation (e.g., TT=typical-typical, FF=fast-fast, SS=slow-slow, FS=fast-slow, SF=slow-fast). [ENUM-REF-CANDIDATE: tt|ff|ss|fs|sf|typical|fast|slow — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regressionSuiteName rdf:type rdf:Property ;
    rdfs:label 'Regression Suite Name' ;
    rdfs:comment 'Name of the regression test suite or verification plan to which this simulation run belongs. Enables grouping of runs for regression tracking, coverage closure, and sign-off milestone reporting.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDeckName rdf:type rdf:Property ;
    rdfs:label 'Rule Deck Name' ;
    rdfs:comment 'Name of the design rule deck, constraint file, or property specification used for this run (e.g., DRC rule deck, LVS rule file, CDC constraint file, formal property set). Identifies the specific rule set version applied for compliance checking.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDeckVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Deck Version' ;
    rdfs:comment 'Version identifier of the rule deck or constraint file applied in this run. Tracks which revision of foundry DRC/LVS rules or EDA property specifications was used, supporting audit and regression analysis.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Run Duration Minutes' ;
    rdfs:comment 'Total elapsed wall-clock time in minutes from run start to completion or termination. Supports compute resource planning, bottleneck identification, and EDA tool performance benchmarking.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runSubtype rdf:type rdf:Property ;
    rdfs:label 'Run Subtype' ;
    rdfs:comment 'Further classification of the simulation run within its run_type, specifying the abstraction level or scope (e.g., RTL functional simulation, gate-level simulation, post-layout SPICE, mixed-signal AMS co-simulation). [ENUM-REF-CANDIDATE: rtl|gate_level|post_layout|spice|mixed_signal|full_chip|block_level|subsystem — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the verification or checking run by methodology. Indicates the primary verification technique applied. [ENUM-REF-CANDIDATE: functional_simulation|drc|lvs|erc|formal_equivalence|model_checking|property_checking|cdc_analysis|rdc_analysis|spice_simulation|ams_cosimulation|ir_drop|em_analysis|signal_integrity|electromigration|timing_analysis|atpg — promote to reference product]' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signoffApproved rdf:type rdf:Property ;
    rdfs:label 'Signoff Approved' ;
    rdfs:comment 'Indicates whether this simulation run has been formally approved as part of the design verification sign-off process for tapeout clearance. True when an authorized engineer has reviewed and accepted the run results.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signoff Timestamp' ;
    rdfs:comment 'Date and time when the formal verification sign-off approval was granted for this simulation run. Establishes the audit timestamp for tapeout compliance documentation.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the simulation or verification run was initiated on the compute infrastructure. Used for run duration calculation, scheduling analysis, and compute resource utilization reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tapeoutMilestone rdf:type rdf:Property ;
    rdfs:label 'Tapeout Milestone' ;
    rdfs:comment 'Design milestone context in which this simulation run was executed, indicating whether it was part of pre-tapeout verification, tapeout freeze sign-off, post-tapeout validation, or an MPW (Multi-Project Wafer) shuttle submission.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testbenchName rdf:type rdf:Property ;
    rdfs:label 'Testbench Name' ;
    rdfs:comment 'Name of the simulation testbench or stimulus file used for functional simulation runs (RTL, gate-level, SPICE, AMS co-simulation). Identifies the verification environment applied to exercise the design under test.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toggleCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Toggle Coverage Pct' ;
    rdfs:comment 'Percentage of signal toggle coverage achieved in this simulation run, measuring how many design signals transitioned both 0-to-1 and 1-to-0 during simulation. Supports DFT (Design for Testability) analysis.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:violationCountError rdf:type rdf:Property ;
    rdfs:label 'Violation Count Error' ;
    rdfs:comment 'Number of violations classified at error severity level in this run. Error-level violations typically block tapeout sign-off and require mandatory resolution before design release.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:violationCountTotal rdf:type rdf:Property ;
    rdfs:label 'Violation Count Total' ;
    rdfs:comment 'Total number of violations, errors, or failures detected across all severity levels in this simulation or verification run. Primary quantitative outcome metric for DRC, LVS, ERC, formal, and functional runs.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:violationCountWaived rdf:type rdf:Property ;
    rdfs:label 'Violation Count Waived' ;
    rdfs:comment 'Number of violations formally waived by engineering sign-off in this run. Waived violations are acknowledged exceptions documented for tapeout compliance audit trail.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:violationCountWarning rdf:type rdf:Property ;
    rdfs:label 'Violation Count Warning' ;
    rdfs:comment 'Number of violations classified at warning severity level in this run. Warning-level violations require engineering review and documented disposition but may be waived with justification.' ;
    rdfs:domain ind:SimulationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Unique surrogate identifier for each design milestone or gate review record in the IC design lifecycle. Primary key for the design_milestone data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:milestoneIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Milestone Ic Design Project Id' ;
    rdfs:comment 'FK to design.ic_design_project.ic_design_project_id — Design milestones belong to a specific IC design project. Required for project schedule tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:primaryDesignProjectIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Design Project Ic Design Project Id' ;
    rdfs:comment 'Reference to the parent IC design project to which this milestone belongs. Links the milestone to the overall design program, enabling schedule tracking and gate governance at the project level.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'Calendar date on which the design milestone was actually achieved and formally signed off. Null if the milestone has not yet been completed. Compared against planned_date to compute schedule variance for TTM reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalDisposition rdf:type rdf:Property ;
    rdfs:label 'Approval Disposition' ;
    rdfs:comment 'Formal outcome decision rendered at the gate review for this milestone. approved = unconditional sign-off; conditionally_approved = sign-off with mandatory action items; rejected = milestone failed, rework required; deferred = review postponed to a later date; waived = milestone formally bypassed with documented justification. Distinct from milestone_status which tracks workflow state.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockerCount rdf:type rdf:Property ;
    rdfs:label 'Blocker Count' ;
    rdfs:comment 'Number of critical blocking issues preventing milestone achievement or sign-off at the time of review. Blockers are issues that must be fully resolved before the milestone can be approved, distinct from action items which may be post-approval.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockerDescription rdf:type rdf:Property ;
    rdfs:label 'Blocker Description' ;
    rdfs:comment 'Narrative description of critical blocking issues preventing milestone sign-off. Details the nature of each blocker (e.g., unresolved DRC violations, failing timing paths, missing PDK sign-off) and the responsible owner for resolution.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmSignOff rdf:type rdf:Property ;
    rdfs:label 'Dfm Sign Off' ;
    rdfs:comment 'Boolean flag indicating whether DFM (Design for Manufacturability) analysis has been completed and signed off at this milestone. True = DFM rules verified and approved by the process engineering team; False = DFM sign-off pending or not applicable for this milestone type.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dftSignOff rdf:type rdf:Property ;
    rdfs:label 'Dft Sign Off' ;
    rdfs:comment 'Boolean flag indicating whether DFT (Design for Testability) implementation and ATPG (Automatic Test Pattern Generation) coverage requirements have been met and signed off at this milestone. True = DFT sign-off complete; False = DFT sign-off pending.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Narrative summary of key findings, observations, and issues identified during the gate review. Captures design quality concerns, DRC/LVS violations, timing closure gaps, DFM/DFT issues, and other technical findings that inform the approval disposition.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCriteriaMet rdf:type rdf:Property ;
    rdfs:label 'Gate Criteria Met' ;
    rdfs:comment 'Boolean flag indicating whether all formally defined entry and exit criteria for this gate milestone were satisfied at the time of review. True = all criteria met; False = one or more criteria failed or outstanding. Drives approval disposition and tapeout authorization decisions.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gateReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gate Review Timestamp' ;
    rdfs:comment 'Precise date and time at which the formal gate review meeting or sign-off event occurred. Serves as the principal business event timestamp for this transaction record, enabling audit trail and tapeout authorization traceability.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdsVersion rdf:type rdf:Property ;
    rdfs:label 'Gds Version' ;
    rdfs:comment 'Version identifier of the GDS (Graphic Data System) or GDSII layout file submitted or reviewed at this milestone. Provides design data provenance for tapeout authorization and enables traceability between the milestone record and the physical layout database.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipClearanceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Ip Clearance Confirmed' ;
    rdfs:comment 'Boolean flag indicating whether all third-party IP (Intellectual Property) cores used in the design have been cleared for use at this milestone, including license verification and export control review under ITAR and EAR regulations.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lvsViolationCount rdf:type rdf:Property ;
    rdfs:label 'Lvs Violation Count' ;
    rdfs:comment 'Number of unresolved Layout Versus Schematic (LVS) violations present in the design at the time of this milestone review. LVS violations indicate discrepancies between the physical layout and the circuit schematic. Must be zero for tapeout authorization.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this milestone within the design project (e.g., MS-RTL-001, MS-TAPEOUT-003). Used as the business-facing reference in PLM and project management systems. Serves as the BUSINESS_IDENTIFIER for this transaction.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name of the design milestone or gate review event (e.g., RTL Freeze, Design Freeze, Netlist Freeze, Floorplan Complete, Timing Closure, DRC/LVS Clean, Tapeout Readiness). Provides the identity label for the milestone record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current workflow state of the design milestone gate review. planned = milestone scheduled but review not yet initiated; in_review = gate review meeting in progress or findings under evaluation; approved = all gate criteria met and sign-off granted; conditionally_approved = sign-off granted subject to outstanding action items or waivers; rejected = gate criteria not met, design must remediate before re-review; waived = milestone bypassed under formal waiver authority.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone representing the specific lifecycle checkpoint in the IC design flow. Values: rtl_freeze (Register Transfer Level code locked), design_freeze (all design changes halted), netlist_freeze (synthesized netlist locked), floorplan_complete (physical floorplan approved), timing_closure (all timing constraints met per PrimeTime signoff), drc_lvs_clean (Design Rule Check and Layout Versus Schematic violations resolved), tapeout_readiness (GDS/GDSII submission authorized). [ENUM-REF-CANDIDATE: rtl_freeze|design_freeze|netlist_freeze|floorplan_complete|timing_closure|drc_lvs_clean|tapeout_readiness — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrePhase rdf:type rdf:Property ;
    rdfs:label 'Nre Phase' ;
    rdfs:comment 'NRE (Non-Recurring Engineering) lifecycle phase to which this milestone belongs. Categorizes the milestone within the broader IC development investment phases from concept through post-silicon validation. [ENUM-REF-CANDIDATE: concept|architecture|rtl_design|physical_design|verification|tapeout|post_silicon — promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openActionItemCount rdf:type rdf:Property ;
    rdfs:label 'Open Action Item Count' ;
    rdfs:comment 'Number of unresolved action items identified during the gate review that must be closed before or after milestone sign-off. A non-zero value with conditionally_approved disposition indicates outstanding obligations tracked in PLM.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openWaiverCount rdf:type rdf:Property ;
    rdfs:label 'Open Waiver Count' ;
    rdfs:comment 'Number of active design rule, timing, or quality waivers outstanding at the time of this milestone review. Waivers represent formally accepted deviations from standard gate criteria, each requiring documented justification and risk acceptance.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Originally scheduled calendar date for achieving this design milestone as defined in the project plan. Used for schedule adherence tracking and TTM (Time to Market) analysis.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:powerBudgetMw rdf:type rdf:Property ;
    rdfs:label 'Power Budget Mw' ;
    rdfs:comment 'Total power consumption budget in milliwatts (mW) for the IC design as defined at this milestone checkpoint. Part of the PPA (Power, Performance, Area) triad tracked across design milestones. Compared against actual power estimates from EDA tools.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewIteration rdf:type rdf:Property ;
    rdfs:label 'Review Iteration' ;
    rdfs:comment 'Iteration count for this milestone gate review, incremented each time the milestone is re-reviewed following a rejection or conditional approval. A value greater than 1 indicates the design required rework cycles, which is a quality and schedule risk indicator.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Review Meeting Date' ;
    rdfs:comment 'Calendar date on which the formal gate review meeting was convened with all required participants. May differ from gate_review_timestamp if the sign-off decision was rendered after the meeting concluded.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewParticipantList rdf:type rdf:Property ;
    rdfs:label 'Review Participant List' ;
    rdfs:comment 'Comma-separated list of names or employee IDs of individuals who participated in the gate review meeting. Includes design engineers, DFM/DFT leads, physical design leads, and program management. Supports audit trail and quorum validation.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedTargetDate rdf:type rdf:Property ;
    rdfs:label 'Revised Target Date' ;
    rdfs:comment 'Updated target date for milestone completion following a formal schedule re-baseline or change control event. Captures the most recent approved schedule revision, distinct from the original planned_date.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Number of calendar days by which the actual milestone date deviates from the planned date (actual_date minus planned_date). Positive values indicate delay; negative values indicate early completion. Used for TTM (Time to Market) schedule adherence analytics.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Ordinal sequence number defining the order of this milestone within the IC design project lifecycle. Enables chronological ordering of milestones for schedule visualization, critical path analysis, and gate governance reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tapeoutAuthorized rdf:type rdf:Property ;
    rdfs:label 'Tapeout Authorized' ;
    rdfs:comment 'Boolean flag indicating whether this milestone record constitutes or contributes to formal tapeout authorization for GDS/GDSII submission to the fabrication facility (FAB). True = tapeout authorized; False = tapeout not yet authorized. Critical for the tapeout readiness audit trail.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timingSlackWorstPs rdf:type rdf:Property ;
    rdfs:label 'Timing Slack Worst Ps' ;
    rdfs:comment 'Worst-case setup timing slack in picoseconds (ps) across all timing paths in the design as reported by Synopsys PrimeTime at the time of this milestone. Negative values indicate timing violations. Zero or positive values indicate timing closure. Critical metric for timing_closure milestone sign-off.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Documented rationale for any waivers granted at this milestone, explaining why the deviation from standard gate criteria is acceptable and what risk mitigation measures are in place. Required for compliance with ISO 9001 and IATF 16949 non-conformance management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationPlanId rdf:type rdf:Property ;
    rdfs:label 'Verification Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the design verification plan record within the Databricks Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VerificationPlan .

ind:budgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Id' ;
    rdfs:comment 'Foreign key linking to finance.budget_plan. Business justification: Verification plan costs are planned in a budget plan; linking allows variance analysis between planned and actual spend.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlan .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to test.test_program. Business justification: A verification plan specifies the test methodology and references the ATE test program that implements it. For ISO 26262 ASIL decomposition and JEDEC qualification, the verification plan must be trace' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:qualificationStatusId rdf:type rdf:Property ;
    rdfs:label 'Qualification Status Id' ;
    rdfs:comment 'Foreign key linking to customer.qualification_status. Business justification: In automotive semiconductor programs, verification plans must align with customer qualification requirements (AEC-Q, IATF 16949, PPAP). This FK links the verification plan\'s signoff criteria directly ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualificationStatus .

ind:revisionId rdf:type rdf:Property ;
    rdfs:label 'Revision Id' ;
    rdfs:comment 'Reference to the specific RTL or netlist design revision under verification. Ensures the verification plan is tied to a precise design snapshot, supporting traceability from verification results back to the design state at time of sign-off.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Revision .

ind:testPlanId rdf:type rdf:Property ;
    rdfs:label 'Test Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.test_plan. Business justification: Design verification plans reference quality test plans to align functional verification coverage with quality acceptance criteria. Semiconductor DV engineers coordinate with quality teams to ensure ve' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestPlan .

ind:assertionCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Assertion Coverage Target Pct' ;
    rdfs:comment 'Target percentage of SystemVerilog Assertions (SVA) or PSL assertions that must be exercised and pass during simulation. Assertion coverage is a key metric for protocol compliance and corner-case verification completeness.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bugTrackingProjectKey rdf:type rdf:Property ;
    rdfs:label 'Bug Tracking Project Key' ;
    rdfs:comment 'Project key or identifier in the bug tracking system corresponding to this verification plan (e.g., \'SOC-X5-VER\'). Used to hyperlink verification failures to the defect management workflow.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bugTrackingSystem rdf:type rdf:Property ;
    rdfs:label 'Bug Tracking System' ;
    rdfs:comment 'Name of the defect/bug tracking system integrated with this verification plan for logging simulation failures and RTL bugs (e.g., \'Jira\', \'Bugzilla\', \'Synopsys Serenity\'). Enables traceability from verification failures to RTL fixes.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Code Coverage Target Pct' ;
    rdfs:comment 'Target code coverage closure percentage (line, branch, condition, expression, FSM) required for sign-off. Complements functional coverage to ensure structural completeness of the RTL simulation. Tracked against EDA tool-reported actuals.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emulationPlatform rdf:type rdf:Property ;
    rdfs:label 'Emulation Platform' ;
    rdfs:comment 'Hardware emulation platform used for pre-silicon software bring-up and system-level verification (e.g., \'Cadence Palladium Z2\', \'Synopsys ZeBu\', \'Mentor Veloce\'). Null if emulation is not in scope for this plan.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Fault Coverage Target Pct' ;
    rdfs:comment 'Target stuck-at and transition fault coverage percentage for ATPG-generated test patterns. Typically 99%+ for automotive/safety-critical designs per IATF 16949 and ISO 26262. Drives DFT insertion effort and scan chain architecture decisions.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faultInjectionCampaignPlanned rdf:type rdf:Property ;
    rdfs:label 'Fault Injection Campaign Planned' ;
    rdfs:comment 'Indicates whether a structured fault injection campaign is planned as part of this verification plan to validate safety mechanisms per ISO 26262. True for ASIL-B and above designs. Drives resource allocation for fault simulation infrastructure.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmedaDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Fmeda Document Reference' ;
    rdfs:comment 'Reference identifier of the linked FMEDA document in the PLM system. The FMEDA quantifies diagnostic coverage and safe failure fraction for ISO 26262 hardware metrics compliance. Null for non-safety designs.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formalVerificationTool rdf:type rdf:Property ;
    rdfs:label 'Formal Verification Tool' ;
    rdfs:comment 'EDA tool used for formal property checking and equivalence checking (e.g., \'Synopsys VC Formal\', \'Cadence JasperGold\', \'OneSpin 360\'). Null if formal verification is not part of the plan methodology.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpgaPrototypePlatform rdf:type rdf:Property ;
    rdfs:label 'Fpga Prototype Platform' ;
    rdfs:comment 'FPGA prototyping board or platform used for early software validation and system integration testing (e.g., \'Xilinx VCU128\', \'Intel Stratix 10 GX\', \'Aldec HES-US-440\'). Null if FPGA prototyping is not in scope.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipReuseCount rdf:type rdf:Property ;
    rdfs:label 'Ip Reuse Count' ;
    rdfs:comment 'Number of third-party or internal IP cores integrated into this design that require verification waivers or pre-verified IP sign-off. Impacts the scope of the verification plan and the testbench architecture for IP interface compliance.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iso26262AsilDecomposition rdf:type rdf:Property ;
    rdfs:label 'Iso26262 Asil Decomposition' ;
    rdfs:comment 'Description of the ASIL decomposition strategy applied to this design per ISO 26262 Part 9. Documents how a higher ASIL requirement is decomposed into two independent lower-ASIL sub-elements (e.g., \'ASIL D decomposed to ASIL B + ASIL B\'). Mandatory for automotive safety-critical IC designs.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Planned completion date for all verification activities and sign-off, aligned with the tapeout schedule. A key TTM (Time to Market) planning date. Slippage triggers NRE (Non-Recurring Engineering) cost impact analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive human-readable name for the verification plan, typically including the IC design project name and verification phase (e.g., \'SoC-X5 Full-Chip Functional Verification Plan v2.1\'). Used in dashboards, reports, and PLM document management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known, human-readable identifier for the verification plan, typically assigned by the PLM system (e.g., Oracle Agile PLM or Siemens Teamcenter). Format: DVP-<PROJECT_CODE>-<YEAR>-<SEQ>. Used in cross-functional communications, tapeout checklists, and audit trails.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Planned start date for verification activities as defined in the project schedule. Used for milestone tracking, resource planning, and TTM (Time to Market) analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the verification plan document. Drives workflow approvals and tapeout gate readiness. [ENUM-REF-CANDIDATE: draft|in_review|approved|active|on_hold|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the verification plan document following semantic versioning (e.g., \'1.0\', \'2.3\', \'3.1.2\'). Incremented upon each approved revision cycle in the PLM system. Critical for traceability to tapeout sign-off.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regressionRunFrequency rdf:type rdf:Property ;
    rdfs:label 'Regression Run Frequency' ;
    rdfs:comment 'Planned frequency at which the regression suite is executed. Continuous integration runs on every RTL commit; nightly runs are scheduled overnight; milestone-triggered runs occur at defined project gates; on-demand runs are manually initiated.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Criticality Level' ;
    rdfs:comment 'Functional safety classification of the IC design per ISO 26262 (automotive ASIL) or IEC 61508 (industrial SIL). Drives the rigor of fault injection campaigns, FMEDA linkage, and safety mechanism coverage targets within the verification plan. Non-safety designs are tagged \'non_safety\'. [ENUM-REF-CANDIDATE: ASIL_A|ASIL_B|ASIL_C|ASIL_D|SIL_1|SIL_2|SIL_3|non_safety — promote to reference product]' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyMechanismCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Safety Mechanism Coverage Target Pct' ;
    rdfs:comment 'Target percentage of identified safety mechanisms that must be verified through simulation, formal analysis, or fault injection campaigns. Required for ISO 26262 hardware verification sign-off. Null for non-safety designs.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scanChainCount rdf:type rdf:Property ;
    rdfs:label 'Scan Chain Count' ;
    rdfs:comment 'Number of scan chains defined in the DFT architecture for this design. Determines ATPG test time, test data volume, and ATE (Automatic Test Equipment) channel requirements. A key DFT planning parameter.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signoffCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Signoff Criteria Description' ;
    rdfs:comment 'Textual description of the complete set of criteria that must be satisfied before verification sign-off is granted and tapeout is authorized. Includes coverage closure thresholds, zero-open-critical-bug requirement, regression pass rate, and formal proof completion.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signoffDate rdf:type rdf:Property ;
    rdfs:label 'Signoff Date' ;
    rdfs:comment 'Actual date on which verification sign-off was formally approved. Null until sign-off is granted. Used for tapeout readiness confirmation and post-silicon correlation analysis.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:simulationTool rdf:type rdf:Property ;
    rdfs:label 'Simulation Tool' ;
    rdfs:comment 'Primary EDA simulation tool assigned for RTL and gate-level simulation (e.g., \'Synopsys VCS\', \'Cadence Xcelium\', \'Mentor Questa\'). Determines the simulation environment configuration, license requirements, and regression infrastructure.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testbenchArchitecture rdf:type rdf:Property ;
    rdfs:label 'Testbench Architecture' ;
    rdfs:comment 'Structural architecture of the simulation testbench. UVM_layered follows the standard UVM agent/scoreboard/coverage hierarchy; directed uses manually written test vectors; constrained_random uses SystemVerilog randomization; cocotb uses Python-based co-simulation; SystemC uses transaction-level modeling. [ENUM-REF-CANDIDATE: UVM_layered|directed|constrained_random|hybrid|cocotb|SystemC — promote to reference product]' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toggleCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Toggle Coverage Target Pct' ;
    rdfs:comment 'Target toggle coverage percentage for all RTL signals, ensuring each net transitions both 0→1 and 1→0 during simulation. Used as a DFT readiness indicator and a structural verification completeness metric.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationMethodology rdf:type rdf:Property ;
    rdfs:label 'Verification Methodology' ;
    rdfs:comment 'Primary pre-silicon verification methodology employed for this plan. UVM (Universal Verification Methodology) is the industry-standard constrained-random simulation approach; formal uses mathematical property checking; emulation uses hardware accelerators; FPGA_prototyping uses field-programmable gate arrays for early software bring-up. [ENUM-REF-CANDIDATE: UVM|formal|emulation|FPGA_prototyping|hybrid|mixed_signal — promote to reference product]' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Primary key for order' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:blanketOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Id' ;
    rdfs:comment 'Foreign key linking to order.blanket_order. Business justification: An order may be covered by a blanket purchase agreement; adding FK from order to blanket_order captures this relationship without creating a cycle.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlanketOrder .

ind:channelPartnerId rdf:type rdf:Property ;
    rdfs:label 'Channel Partner Id' ;
    rdfs:comment 'Foreign key linking to sales.channel_partner. Business justification: Orders may be placed via channel partners; the FK enables partner-attributed revenue and commission reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelPartner .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Order Management requires a primary sales contact for each order; the Order Confirmation Report pulls contact details, making this link essential.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Order creation originates from a closed-won opportunity; linking enables opportunity-to-order conversion reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:priceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Price Agreement Id' ;
    rdfs:comment 'Foreign key linking to customer.price_agreement. Business justification: Pricing Governance applies a specific price agreement to an order; the Pricing Audit Report and revenue recognition rely on this relationship.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceAgreement .

ind:qualityQualificationProgramId rdf:type rdf:Property ;
    rdfs:label 'Quality Qualification Program Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_qualification_program. Business justification: Customer orders for automotive (IATF 16949) and aerospace applications require qualification program compliance tracking. Orders must reference the applicable qualification program to ensure all deliv' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityQualificationProgram .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Foreign key linking to sales.quote. Business justification: Orders are generated from accepted quotes; the link supports quote-to-order tracking and pricing audit.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:restrictedPartyScreeningId rdf:type rdf:Property ;
    rdfs:label 'Restricted Party Screening Id' ;
    rdfs:comment 'Foreign key linking to compliance.restricted_party_screening. Business justification: Trade compliance hold process records the screening result for the customer/account on the order.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RestrictedPartyScreening .

ind:salesDesignWinId rdf:type rdf:Property ;
    rdfs:label 'Sales Design Win Id' ;
    rdfs:comment 'Reference to the Salesforce CRM design-win opportunity that originated this sales order. Links the order to the customer design-in engagement, enabling design-win to revenue conversion tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesDesignWin .

ind:shippingAddressId rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Shipping Execution process stores the exact customer address for each order; the Shipping Manifest and compliance checks depend on this link.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The actual date on which the ordered products were delivered to the customer or ship-to location. Used for on-time delivery (OTD) performance analysis and customer satisfaction reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current inventory or production capacity allocation status of the order. Indicates whether sufficient die, wafer, or finished goods inventory has been reserved to fulfill the order. Critical for backlog management and supply-demand balancing.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backlogFlag rdf:type rdf:Property ;
    rdfs:label 'Backlog Flag' ;
    rdfs:comment 'Indicates whether this order is currently included in the active order backlog. True when the order is open and not yet fully shipped or invoiced. Used for backlog valuation, revenue forecasting, and capacity planning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Business reason code or description for order cancellation. Populated only when order_status is CANCELLED. Used for lost revenue analysis, demand forecasting accuracy, and customer relationship management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the semiconductor manufacturer based on production capacity, wafer fab scheduling, and logistics. May differ from the requested delivery date. Used for backlog management and customer commitment tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'The purchase order number provided by the customer at the time of order placement. Used for cross-referencing with the customer\'s procurement system and required for invoice matching. Corresponds to SAP VBAK.BSTNK.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'The sales channel through which the order was placed. Determines pricing tiers, commission structures, and revenue reporting by channel. Corresponds to SAP VBAK.VTWEG.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endMarketSegment rdf:type rdf:Property ;
    rdfs:label 'End Market Segment' ;
    rdfs:comment 'The end-market application segment for which the ordered semiconductor products are destined. Used for market segmentation analysis, revenue reporting by vertical, and strategic planning. [ENUM-REF-CANDIDATE: COMPUTING|MOBILE|AUTOMOTIVE|AI_ML|IOT|INDUSTRIAL|NETWORKING|CONSUMER|DEFENSE|MEDICAL — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Export License Required' ;
    rdfs:comment 'Indicates whether an export license is required for this order based on the destination country, end-user, and product ECCN classification. True triggers export compliance review workflow before shipment authorization.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossOrderValue rdf:type rdf:Property ;
    rdfs:label 'Gross Order Value' ;
    rdfs:comment 'Total gross value of the sales order before application of discounts, taxes, or surcharges, expressed in the order currency. Represents the sum of all line item gross values. Used for revenue forecasting and backlog valuation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Reason code or description for placing the order on hold. Populated when order_status is ON_HOLD. Common reasons include credit hold, export compliance review, customer request, or supply shortage.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining the responsibilities of buyer and seller for delivery, risk transfer, and cost allocation. Corresponds to SAP VBAK.INCO1. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms code, specifying where risk and cost transfer between buyer and seller (e.g., \'Shanghai Port\', \'Customer Dock\'). Corresponds to SAP VBAK.INCO2.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Net value of the sales order after application of all discounts and pricing conditions but before tax. Represents the contractually agreed revenue amount. Corresponds to SAP VBAK.NETWR. Used for revenue recognition and financial reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreAmount rdf:type rdf:Property ;
    rdfs:label 'Nre Amount' ;
    rdfs:comment 'Non-Recurring Engineering (NRE) charges associated with this order, covering one-time design, mask set, and process development costs. Applicable for ASIC, custom IC, and MPW order types. Reported separately from unit product revenue.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The calendar date on which the customer placed the sales order. Represents the principal business event date for the order-to-cash lifecycle. Corresponds to SAP VBAK.AUDAT.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'The channel or system through which the customer order was received and entered. Used for order entry efficiency analysis and digital transformation tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the sales order within the order-to-cash process. Drives workflow routing, backlog reporting, and revenue recognition. [ENUM-REF-CANDIDATE: DRAFT|OPEN|IN_FULFILLMENT|SHIPPED|DELIVERED|CLOSED|CANCELLED|ON_HOLD — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the sales order by product or engagement type. Determines order processing rules, pricing, and fulfillment workflow. Values include: STANDARD_IC (standard integrated circuit), ASIC (Application-Specific Integrated Circuit), FPGA (Field-Programmable Gate Array), MPW (Multi-Project Wafer), NRE (Non-Recurring Engineering), DIE_BANK (die bank pull order), WAFER_START (wafer start authorization). [ENUM-REF-CANDIDATE: STANDARD_IC|ASIC|FPGA|MPW|NRE|DIE_BANK|WAFER_START — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP payment terms key defining the payment due date, early payment discount conditions, and cash discount percentages applicable to this order. Corresponds to SAP VBAK.ZTERM (e.g., NT30, NT60, 2/10NET30).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority level assigned to the order, influencing production scheduling, wafer start queue position, and allocation decisions. Critical orders may trigger expedite fees or override standard allocation rules.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachCompliant rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant' ;
    rdfs:comment 'Indicates whether the products ordered comply with the EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) Regulation. Required for EU market access and supply chain chemical safety reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the customer has requested delivery of the ordered products. Used for delivery scheduling, wafer start planning, and on-time delivery (OTD) performance measurement. Corresponds to SAP VBAK.VDATU.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country for shipment. Critical for export compliance screening (EAR/ITAR/BIS), trade sanctions checks, and logistics routing. Corresponds to SAP ship-to party country.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soNumber rdf:type rdf:Property ;
    rdfs:label 'So Number' ;
    rdfs:comment 'Externally visible sales order number as assigned by SAP S/4HANA SD module. Used in all customer-facing communications, shipping documents, and invoices. Corresponds to the VBELN field in SAP VBAK table.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount applicable to the sales order, including VAT, GST, or other applicable taxes, expressed in the order currency. Required for tax reporting and financial compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferStartAuthorization rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Authorization' ;
    rdfs:comment 'Indicates whether this order has triggered a wafer start authorization in the fabrication facility (FAB). When True, the MES (Manufacturing Execution System) has been instructed to initiate wafer lot processing for this order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each order line item within the Databricks Silver Layer. Serves as the primary key for the order_line data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:primarySalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Order Id' ;
    rdfs:comment 'Reference to the parent sales order header to which this line item belongs. Establishes the header-to-line relationship in the order-to-cash lifecycle. Corresponds to SAP S/4HANA SD VBELN (Sales Document Number).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:qualitySpecId rdf:type rdf:Property ;
    rdfs:label 'Quality Spec Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_spec. Business justification: Order lines must reference applicable quality specifications for acceptance criteria. Each order line commits to specific quality parameters (yield, defect density, reliability) that are defined in qu' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualitySpec .

ind:quoteLineId rdf:type rdf:Property ;
    rdfs:label 'Quote Line Id' ;
    rdfs:comment 'Foreign key linking to sales.quote_line. Business justification: Each order line is derived from a quote line; needed for line-level margin and fulfillment analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteLine .

ind:reachSvhcDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Reach Svhc Declaration Id' ;
    rdfs:comment 'Foreign key linking to compliance.reach_svhc_declaration. Business justification: REACH SVHC Declaration is required per SKU on an order line to certify hazardous substance compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReachSvhcDeclaration .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Reference to the semiconductor product (IC, SoC, ASIC, FPGA, or discrete device) being ordered on this line. Links to the product master for SKU-level configuration details including package type, speed grade, and temperature range.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'The date on which the semiconductor units for this order line were physically shipped from the warehouse or OSAT facility. Populated upon goods issue posting in SAP S/4HANA. Used for on-time delivery (OTD) performance measurement.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the supply allocation method applied to this order line. Standard = normal backlog allocation; Priority = customer-priority or design-win protected allocation; Strategic = long-term agreement allocation; Spot = spot market fulfillment; Buffer = safety stock draw.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'The quantity of semiconductor units confirmed by supply chain for delivery on this order line, reflecting available inventory, wafer start authorizations, and die bank allocations. May differ from ordered quantity due to allocation constraints.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedShipDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Ship Date' ;
    rdfs:comment 'The date confirmed by supply chain and manufacturing for shipment of this order line, based on available inventory, die bank status, and OSAT packaging capacity. May differ from requested ship date due to supply constraints.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the country where the semiconductor product was manufactured (FAB location). Required for customs declarations, trade compliance, tariff classification, and CHIPS Act domestic content reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Part Number' ;
    rdfs:comment 'The customer\'s own internal part number or cross-reference number for the ordered semiconductor product. Critical for design-win tracking, customer portal integration, and order acknowledgment matching. Sourced from Salesforce CRM design-win records.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateEntered rdf:type rdf:Property ;
    rdfs:label 'Date Entered' ;
    rdfs:comment 'The business date on which this order line was entered into the SAP S/4HANA SD system. Represents the commercial event date for backlog aging calculations and order-to-cash cycle time measurement.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dieBankOrder rdf:type rdf:Property ;
    rdfs:label 'Die Bank Order' ;
    rdfs:comment 'Indicates whether this order line is to be fulfilled from the die bank (inventory of known good dies (KGD) awaiting packaging) rather than from finished goods or new wafer starts. True = die bank fulfillment; False = standard finished goods or new production.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'SAP SD item category classification for this order line, indicating the business nature of the line (e.g., standard product sale, consignment fill-up, customer return, engineering sample, NRE charge, MPW service, evaluation unit). Drives pricing, delivery, and billing behavior. [ENUM-REF-CANDIDATE: standard|consignment|returns|sample|nre|mpw|evaluation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential position number of this line item within the parent sales order. Used for ordering, display, and reference in customer-facing documents. Corresponds to SAP S/4HANA SD POSNR (Item Number of the SD Document).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current workflow status of this order line item within the order-to-cash lifecycle. Drives backlog management, allocation decisions, and revenue recognition. Corresponds to SAP S/4HANA SD overall delivery status at item level.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'The manufacturing lot number assigned to the production batch fulfilling this order line. Enables traceability from customer order back to wafer fabrication lot, die bank lot, and OSAT packaging lot. Sourced from Camstar MES lot tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material number (MATNR) identifying the specific semiconductor product SKU ordered on this line. Includes full part number with package, speed grade, and temperature range encoded per internal part numbering convention.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpwOrder rdf:type rdf:Property ;
    rdfs:label 'Mpw Order' ;
    rdfs:comment 'Indicates whether this order line is associated with a Multi-Project Wafer (MPW) run, where multiple customer designs share a single wafer to reduce NRE costs. True = MPW order; False = dedicated production lot order.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Total net value of this order line calculated as confirmed quantity multiplied by unit price in the transaction currency. Used for backlog reporting, revenue forecasting, and SOX-compliant revenue recognition. Corresponds to SAP S/4HANA SD NETWR (Net Value of the Order Item).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of semiconductor units (dies, packaged ICs, wafers, or reels) requested by the customer on this order line. Expressed in the sales unit of measure (e.g., pieces, wafers, reels). Corresponds to SAP S/4HANA SD KWMENG (Cumulative Order Quantity).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialShipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Allowed' ;
    rdfs:comment 'Indicates whether the customer permits partial shipments against this order line. True = partial shipments accepted; False = complete order line quantity must ship together. Drives delivery scheduling and backlog management decisions.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productRevision rdf:type rdf:Property ;
    rdfs:label 'Product Revision' ;
    rdfs:comment 'The silicon revision or stepping of the ordered semiconductor product (e.g., A0, B1, C2). Critical for tracking product change notifications (PCNs), errata management, and ensuring customers receive the correct silicon revision per their qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'The date on which the customer has requested shipment of this order line. Drives production scheduling, wafer start authorization timelines, and OSAT packaging commitments. Corresponds to SAP S/4HANA SD WUNSK (Customer\'s Requested Delivery Date at Item Level).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Line Item Number' ;
    rdfs:comment 'The native SAP S/4HANA SD six-digit item number (POSNR) for this order line, used for traceability back to the system of record and for EDI/customer portal reconciliation.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountry rdf:type rdf:Property ;
    rdfs:label 'Ship To Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the destination country of this order line shipment. Used for export control screening, customs documentation, tariff determination, and trade compliance reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Cumulative quantity of semiconductor units actually shipped against this order line across all partial shipments. Used for backlog calculation and revenue recognition. Sourced from SAP S/4HANA SD delivery documents.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Code indicating special handling, storage, or shipping requirements for this order line (e.g., ESD-sensitive, moisture-sensitive level (MSL), controlled humidity, ITAR-controlled, hazmat). Drives warehouse and logistics instructions. [ENUM-REF-CANDIDATE: ESD|MSL1|MSL2|MSL3|ITAR|HAZMAT|CONTROLLED_TEMP|FRAGILE — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedGrade rdf:type rdf:Property ;
    rdfs:label 'Speed Grade' ;
    rdfs:comment 'The speed or performance grade of the ordered semiconductor product, indicating the maximum operating frequency or timing specification (e.g., -1, -2, -3 for FPGAs; 3200MHz, 4800MHz for memory). Differentiates SKUs within the same product family.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureGrade rdf:type rdf:Property ;
    rdfs:label 'Temperature Grade' ;
    rdfs:comment 'Operating temperature range classification for the ordered semiconductor product. Commercial (0°C to 70°C), Industrial (-40°C to 85°C), Automotive (-40°C to 125°C, AEC-Q100), Military (-55°C to 125°C). Determines qualification standard and pricing tier.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toSalesOrder rdf:type rdf:Property ;
    rdfs:label 'To Sales Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Fundamental header-to-line relationship. Every order line must belong to exactly one sales order. This is the most critical FK in the domain — without it, order lines are orphaned.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Sales unit of measure for the ordered semiconductor product. EA = Each (individual packaged IC), WFR = Wafer, REEL = Tape-and-reel packaging, TRAY = JEDEC tray, TUBE = Tube packaging. Corresponds to SAP S/4HANA SD VRKME (Sales Unit).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Agreed net unit selling price for the semiconductor product on this order line, expressed in the transaction currency. Reflects negotiated pricing, volume discounts, and design-win pricing agreements. Corresponds to SAP S/4HANA SD NETPR (Net Price).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferStartAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Authorization Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a wafer start authorization record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferStartAuthorization .

ind:primaryFabToolId rdf:type rdf:Property ;
    rdfs:label 'Primary Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Wafer start authorizations specify the primary fab tool for wafer processing. Critical for manufacturing capacity planning, tool loading schedules, and fab resource allocation. Semiconductor fabs must' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:primaryWaferOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Wafer Order Id' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Wafer start authorizations are triggered by customer orders. The WSA must reference the originating sales order for demand traceability.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:processNodeId rdf:type rdf:Property ;
    rdfs:label 'Process Node Id' ;
    rdfs:comment 'Foreign key linking to product.process_node. Business justification: Wafer start authorizations must specify process technology node for fab capacity allocation, cycle time planning, and technology-specific manufacturing routing. Replaces denormalized process_node stri' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessNode .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual calendar date on which wafer fabrication commenced at the fab site, as recorded by the MES. Compared against planned_start_date to measure schedule adherence and on-time start performance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Organizational approval tier required and applied for this wafer start authorization. Higher-value or hot-lot authorizations may require director or VP approval. Supports SOX internal controls and delegation-of-authority compliance.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the wafer start authorization, used across order management, MES, and fab planning systems. Typically formatted as WSA-{SITE}-{SEQUENCE}. This is the BUSINESS_IDENTIFIER category field for this TRANSACTION_HEADER entity.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle state of the wafer start authorization record, tracking progression from initial creation through fab release and completion. Fulfills the LIFECYCLE_STATUS minimum category for TRANSACTION_HEADER. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|released_to_fab|in_progress|completed|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'Date and time when the wafer start authorization was formally approved and issued. This is the principal BUSINESS_EVENT_TIMESTAMP for this TRANSACTION_HEADER — the moment the authorization became binding and the demand signal was created.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorizedBy rdf:type rdf:Property ;
    rdfs:label 'Authorized By' ;
    rdfs:comment 'Name or employee identifier of the person who formally approved and issued the wafer start authorization. Required for SOX compliance and audit trail. Typically a fab planning manager or order management lead.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedWaferQty rdf:type rdf:Property ;
    rdfs:label 'Authorized Wafer Qty' ;
    rdfs:comment 'Number of wafers authorized to start fabrication under this authorization record. This is the primary quantitative demand signal passed from order management to the MES. Fulfills the QUANTITATIVE_RESULT minimum category for this non-monetary TRANSACTION_HEADER.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP cost center to which the wafer fabrication costs for this authorization are allocated. Used for internal cost accounting, NRE cost recovery, and fab P&L reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleTimeTargetDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Target Days' ;
    rdfs:comment 'Target number of calendar days from wafer start to wafer out (completion of all fab processing steps). Defined by process node and priority class. Hot lots have compressed cycle time targets. Used for delivery commit date calculation and fab performance measurement.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieBankReplenishmentCode rdf:type rdf:Property ;
    rdfs:label 'Die Bank Replenishment Code' ;
    rdfs:comment 'Reference to the die bank replenishment plan that triggered this authorization when the wafer start is driven by inventory replenishment rather than a direct customer sales order. Nullable when authorization originates from a sales order.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diePerWafer rdf:type rdf:Property ;
    rdfs:label 'Die Per Wafer' ;
    rdfs:comment 'Number of individual die sites on each wafer for the specified product and process node. Determined by die size and wafer diameter. Used in conjunction with yield_target_pct to compute expected_good_die_qty.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedGoodDieQty rdf:type rdf:Property ;
    rdfs:label 'Expected Good Die Qty' ;
    rdfs:comment 'Projected number of Known Good Dies (KGD) expected from this wafer start, calculated from authorized_wafer_qty, die per wafer count, and yield_target_pct. Used for order fulfillment planning and die bank replenishment forecasting.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Fab Work Order Number' ;
    rdfs:comment 'SAP PP production order or work order number generated in ERP when the wafer start authorization is released to manufacturing. Bridges the order management domain to the ERP manufacturing execution module for cost collection and WIP tracking.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMpw rdf:type rdf:Property ;
    rdfs:label 'Is Mpw' ;
    rdfs:comment 'Indicates whether this authorization is for a Multi-Project Wafer (MPW) run, where multiple customer designs share a single wafer to reduce NRE cost. MPW lots require special reticle set management and die allocation tracking.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNre rdf:type rdf:Property ;
    rdfs:label 'Is Nre' ;
    rdfs:comment 'Indicates whether this wafer start authorization is for a Non-Recurring Engineering (NRE) run, such as a first-time tapeout, process qualification, or engineering lot, as opposed to a production volume order. NRE lots have distinct cost accounting and yield expectations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nreChargeUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Charge Usd' ;
    rdfs:comment 'Non-Recurring Engineering fee in US dollars associated with this wafer start authorization, applicable for first-time tapeouts, mask set fabrication, and engineering qualification lots. Populated when is_nre is True. Used for customer invoicing and cost recovery tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Expected date by which wafer fabrication (FEOL through BEOL) is planned to be completed and wafers released for wafer test and probing. Drives downstream packaging and delivery commit date calculations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled calendar date on which wafer fabrication is planned to begin at the fab site. Used for fab capacity planning, WIP (Work in Process) scheduling, and order commit date calculations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityClass rdf:type rdf:Property ;
    rdfs:label 'Priority Class' ;
    rdfs:comment 'Fabrication priority classification assigned to this wafer start authorization. Hot lots receive highest fab priority and cycle time targets; MPW (Multi-Project Wafer) lots share wafer capacity across multiple designs; NRE pilot lots are for non-recurring engineering qualification runs.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredShipDate rdf:type rdf:Property ;
    rdfs:label 'Required Ship Date' ;
    rdfs:comment 'Customer-committed or order-driven date by which finished product must ship. Used to back-calculate the wafer start date and validate that the planned_start_date supports on-time delivery. Key input to TTM (Time to Market) and delivery performance metrics.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifier of the operational system of record from which this wafer start authorization record originated (e.g., SAP S/4HANA PP, Camstar MES, Applied Materials SmartFactory, Salesforce CRM design-win). Supports data lineage and Silver Layer reconciliation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'Native record identifier from the originating source system (e.g., SAP production order number, Camstar lot ID, Salesforce opportunity ID). Enables cross-system traceability and reconciliation between the lakehouse Silver Layer and operational systems.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferSizeMm rdf:type rdf:Property ;
    rdfs:label 'Wafer Size Mm' ;
    rdfs:comment 'Diameter of the silicon wafer substrate in millimeters (e.g., 200mm, 300mm, 450mm). Determines equipment compatibility and fab line routing at the fabrication facility.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferUnitCostUsd rdf:type rdf:Property ;
    rdfs:label 'Wafer Unit Cost Usd' ;
    rdfs:comment 'Standard cost per wafer in US dollars for the specified process node and fab site at the time of authorization. Used for cost of goods sold (COGS) estimation, margin analysis, and financial planning.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wsaToSalesOrder rdf:type rdf:Property ;
    rdfs:label 'Wsa To Sales Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Wafer start authorizations are triggered by sales orders. This link is essential for demand-to-supply traceability and is explicitly mentioned in the WSA description.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldTargetPct rdf:type rdf:Property ;
    rdfs:label 'Yield Target Pct' ;
    rdfs:comment 'Expected die yield percentage (good dies per wafer as a percentage of total die sites) for this wafer start, based on process node maturity and historical SPC data. Used to calculate expected good die output and validate order fulfillment feasibility.' ;
    rdfs:domain ind:WaferStartAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpwOrderId rdf:type rdf:Property ;
    rdfs:label 'Mpw Order Id' ;
    rdfs:comment 'Unique system-generated identifier for the MPW order record. Primary key for the mpw_order data product within the order domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpwOrder .

ind:customerContractId rdf:type rdf:Property ;
    rdfs:label 'Customer Contract Id' ;
    rdfs:comment 'Reference to the master agreement or NRE contract governing this MPW order, including pricing, IP ownership, and delivery terms. Links to the contract master in SAP S/4HANA or Oracle Agile PLM.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContract .

ind:primaryMpwSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Mpw Sales Order Id' ;
    rdfs:comment 'Foreign key linking to order.order. Business justification: MPW order belongs to a specific sales order; adding child-to-parent FK enables order-level reporting and removes duplicate order_number.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:dieQuantityDelivered rdf:type rdf:Property ;
    rdfs:label 'Die Quantity Delivered' ;
    rdfs:comment 'Actual number of known-good dies (KGD) delivered to the customer from this MPW order. May differ from die_quantity_ordered due to yield loss. Used for fulfillment reconciliation and yield-adjusted billing.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieQuantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Die Quantity Ordered' ;
    rdfs:comment 'Number of known-good dies (KGD) ordered by the customer from this MPW shuttle run. Used for delivery planning, yield-adjusted fulfillment, and revenue recognition.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabSiteCode rdf:type rdf:Property ;
    rdfs:label 'Fab Site Code' ;
    rdfs:comment 'Identifier for the wafer fabrication facility (FAB) where this MPW shuttle run is manufactured (e.g., internal fab or OSAT partner site code). Used for capacity planning, yield tracking, and export compliance (ITAR/EAR).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itarFlag rdf:type rdf:Property ;
    rdfs:label 'Itar Flag' ;
    rdfs:comment 'Indicates whether this MPW order involves ITAR-controlled technology requiring State Department licensing and restricted handling. True = ITAR-controlled; False = not ITAR-controlled. Drives access controls and shipment documentation requirements.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mpwProgramType rdf:type rdf:Property ;
    rdfs:label 'Mpw Program Type' ;
    rdfs:comment 'Classification of the MPW shuttle program under which this order is placed. Determines pricing tiers, slot priority, NRE subsidies, and export control applicability (e.g., government programs may require ITAR review).' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpwToOrder rdf:type rdf:Property ;
    rdfs:label 'Mpw To Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — MPW orders may be linked to a parent sales order for billing and customer relationship tracking.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mpwToSalesOrder rdf:type rdf:Property ;
    rdfs:label 'Mpw To Sales Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — MPW orders are a specialized order type that should link back to the parent sales order for billing and customer relationship tracking.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text field for capturing special instructions, customer-specific requirements, design constraints, or internal processing notes associated with this MPW order. Not used for structured data.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderValueUsd rdf:type rdf:Property ;
    rdfs:label 'Order Value Usd' ;
    rdfs:comment 'Total monetary value of this MPW order in US dollars, comprising NRE charges plus die unit price multiplied by ordered quantity. Used for backlog reporting, revenue forecasting, and SAP FI billing.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Semiconductor package type requested for the delivered dies (e.g., bare die/KGD, WLCSP, BGA, QFN, flip-chip). Determines OSAT engagement, packaging cost, and delivery lead time. [ENUM-REF-CANDIDATE: bare_die|WLCSP|BGA|QFN|flip_chip|CSP — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'Committed date by which the ordered dies are planned to be delivered to the customer after wafer fabrication, dicing, and optional packaging. Used for customer delivery scheduling and order-to-cash SLA tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Customer-issued purchase order number referencing this MPW order. Required for invoice matching, accounts receivable, and customer procurement compliance. Sourced from SAP S/4HANA SD order entry.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to this MPW order for slot allocation, fab scheduling, and customer support escalation. Critical orders receive expedited processing and dedicated account management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reticleSlotAreaMm2 rdf:type rdf:Property ;
    rdfs:label 'Reticle Slot Area Mm2' ;
    rdfs:comment 'Physical area in square millimeters allocated to this customer\'s design within the shared MPW reticle. Determines die size, die-per-wafer count, and proportional NRE cost allocation among shuttle participants.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reticleSlotNumber rdf:type rdf:Property ;
    rdfs:label 'Reticle Slot Number' ;
    rdfs:comment 'The specific slot number assigned to this customer\'s design on the shared MPW reticle. Each slot represents a distinct die area on the shared mask set. Slot allocation drives NRE cost sharing and die quantity calculations.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesRegionCode rdf:type rdf:Property ;
    rdfs:label 'Sales Region Code' ;
    rdfs:comment 'Geographic sales region code associated with this MPW order (e.g., AMER, EMEA, APAC, JAPAN). Used for regional revenue reporting, quota management, and export control jurisdiction determination.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutDeadline rdf:type rdf:Property ;
    rdfs:label 'Tapeout Deadline' ;
    rdfs:comment 'Contractual deadline by which the customer must submit the final GDSII design data (tapeout) to secure their reticle slot in the MPW shuttle run. Missing this date results in slot forfeiture and potential NRE penalty.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tapeoutReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Tapeout Received Date' ;
    rdfs:comment 'Actual date on which the customer\'s final GDSII tapeout data was received and accepted by the fab or design services team. Used to confirm slot lock and trigger wafer start authorization.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Unit Price Usd' ;
    rdfs:comment 'Per-die price charged to the customer for the ordered die quantity from this MPW run. Expressed in US dollars. Used for revenue recognition, invoice generation, and margin analysis.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferQuantity rdf:type rdf:Property ;
    rdfs:label 'Wafer Quantity' ;
    rdfs:comment 'Number of wafers allocated to this customer\'s design within the MPW shuttle run. Determines the maximum achievable die yield and is used for fab capacity reservation and WIP tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferStartDateActual rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Date Actual' ;
    rdfs:comment 'Actual date on which wafer fabrication was initiated for this MPW shuttle run. Compared against planned wafer start date to measure schedule adherence and TTM performance.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waferStartDatePlanned rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Date Planned' ;
    rdfs:comment 'Planned date for initiating wafer fabrication (wafer start) for this MPW shuttle run at the fab site. Used for fab capacity scheduling, WIP planning, and customer delivery commitment.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yieldPct rdf:type rdf:Property ;
    rdfs:label 'Yield Pct' ;
    rdfs:comment 'Percentage of good dies produced relative to the total possible dies from the allocated wafer area in this MPW run. Expressed as a percentage (0.00–100.00). Used for quality reporting, customer communication, and yield improvement programs.' ;
    rdfs:domain ind:MpwOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieBankOrderId rdf:type rdf:Property ;
    rdfs:label 'Die Bank Order Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the die bank order record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieBankId rdf:type rdf:Property ;
    rdfs:label 'Die Bank Id' ;
    rdfs:comment 'Reference to the specific die bank (customer-specific or generic KGD inventory pool) from which this order draws down inventory. Identifies the source die bank record in the inventory management system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DieBank .

ind:inventoryWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Inventory Wafer Lot Id' ;
    rdfs:comment 'Reference to the specific wafer fabrication lot from which the die bank inventory was sourced. Enables full traceability from die bank order back to the originating fab lot for quality and yield analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryWaferLot .

ind:primaryDieOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Die Order Id' ;
    rdfs:comment 'FK to order.order.order_id — Die bank orders draw from pre-built inventory against a customer order for commercial and delivery tracking.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:allocatedDieQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Die Quantity' ;
    rdfs:comment 'Number of dies formally allocated from the die bank inventory against this order. May differ from requested quantity due to partial allocation, inventory constraints, or backlog management decisions.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieBankToOrder rdf:type rdf:Property ;
    rdfs:label 'Die Bank To Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Die bank drawdown orders are typically linked to a customer sales order that triggers the packaging/assembly run.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieBankToSalesOrder rdf:type rdf:Property ;
    rdfs:label 'Die Bank To Sales Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Die bank drawdown orders link to the customer sales order that triggered the drawdown request.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieForm rdf:type rdf:Property ;
    rdfs:label 'Die Form' ;
    rdfs:comment 'Physical form in which the die inventory is held in the die bank and will be delivered. Determines whether OSAT packaging conversion is required before shipment.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diePartNumber rdf:type rdf:Property ;
    rdfs:label 'Die Part Number' ;
    rdfs:comment 'Internal part number identifying the specific die type (IC design revision, process node, and configuration) being ordered from the die bank. Aligns with Oracle Agile PLM and SAP MM material master.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieRevision rdf:type rdf:Property ;
    rdfs:label 'Die Revision' ;
    rdfs:comment 'Design revision or stepping identifier of the die (e.g., A0, B1, C2) as tracked in the PLM system. Critical for ensuring the correct silicon revision is pulled from the die bank, especially when multiple steppings coexist.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'ICC Incoterms rule governing delivery obligations, risk transfer, and cost responsibility between seller and buyer for this die bank order shipment. Captured in SAP SD delivery terms. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kgdGrade rdf:type rdf:Property ;
    rdfs:label 'Kgd Grade' ;
    rdfs:comment 'Quality grade of the Known Good Die (KGD) inventory being drawn from the die bank. Grade A represents fully tested, production-qualified die; Grade B may have minor parametric deviations; Engineering grade is for internal use only.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderValue rdf:type rdf:Property ;
    rdfs:label 'Order Value' ;
    rdfs:comment 'Total commercial value of the die bank order (unit price × allocated die quantity), in the transaction currency. Used for revenue backlog reporting, order-to-cash financial tracking, and SOX-compliant revenue recognition.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:osatWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Osat Work Order Number' ;
    rdfs:comment 'Work order or job number issued to the OSAT vendor for the packaging run triggered by this die bank order. Used for tracking assembly progress, yield, and delivery confirmation from the OSAT facility.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingInstructionCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Instruction Code' ;
    rdfs:comment 'Reference to the specific package conversion instruction document that defines the assembly process, substrate, wire bond or flip-chip specifications, and test requirements for the OSAT packaging run triggered by this order.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedDieQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Die Quantity' ;
    rdfs:comment 'Number of individual dies (Known Good Die units) requested by the customer or internal order for drawdown from the die bank. Drives OSAT packaging run sizing and inventory reservation.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Number' ;
    rdfs:comment 'Carrier-assigned tracking number for the outbound shipment of packaged dies. Enables end-to-end shipment visibility and proof-of-delivery confirmation for order fulfillment closure.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedDieQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Die Quantity' ;
    rdfs:comment 'Actual number of dies (post-packaging or in bare die form) confirmed as shipped to the customer. Used for fulfillment confirmation, revenue recognition, and DPPM tracking.' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferFabSite rdf:type rdf:Property ;
    rdfs:label 'Wafer Fab Site' ;
    rdfs:comment 'Identifier of the wafer fabrication facility (FAB) where the source lot was manufactured. Relevant for quality traceability, site-specific yield analysis, and regulatory compliance (ITAR/EAR site-of-manufacture declarations).' ;
    rdfs:domain ind:DieBankOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for each delivery schedule line record in the SAP S/4HANA SD schedule line table (VBEP). Primary key for the delivery_schedule data product in the Silver layer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliverySchedule .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: Scheduled deliveries cannot ship without passing inspection lot disposition. Delivery schedule lines must reference the inspection lot to enforce quality gates, prevent shipment of non-conforming mate' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:primaryDeliveryOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Order Line Id' ;
    rdfs:comment 'Reference to the specific sales order line item (order item) for which this delivery schedule line is created. A single order line may have multiple schedule lines representing different delivery windows.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:primaryDeliveryShipToLocationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Ship To Location Storage Location Id' ;
    rdfs:comment 'Reference to the customer\'s destination ship-to location (customer site, distribution center, or consignment hub) for this delivery schedule line.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:toOrderLineId rdf:type rdf:Property ;
    rdfs:label 'To Order Line Id' ;
    rdfs:comment 'FK to order.order_line.order_line_id — Delivery schedules define delivery windows per order line. delivery_schedule.order_line_id → order_line.order_line_id.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Numeric priority rank assigned to this delivery schedule line during constrained supply allocation. Lower values indicate higher priority. Used by supply chain planners to allocate limited wafer or die inventory across competing customer orders.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blanketOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Flag' ;
    rdfs:comment 'Indicates whether this delivery schedule line is part of a blanket (framework) order with periodic call-offs. Blanket orders are common for high-volume semiconductor customers with rolling delivery schedules.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callOffNumber rdf:type rdf:Property ;
    rdfs:label 'Call Off Number' ;
    rdfs:comment 'The specific call-off or release number issued by the customer against a blanket order for this delivery schedule line. Identifies the periodic release instruction within the blanket order framework.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'The actual quantity of units shipped and delivered against this schedule line. Populated from goods issue and proof-of-delivery confirmation. Used to compute open backlog.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'SAP outbound delivery document number (SD delivery order) created against this schedule line. Links the schedule line to the physical goods issue and shipping execution documents.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieBankOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Die Bank Order Number' ;
    rdfs:comment 'Reference number for a die bank order when delivery is fulfilled from pre-tested Known Good Die (KGD) inventory rather than a new wafer start. Supports die bank fulfillment tracking in the order-to-cash lifecycle.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eccnCode rdf:type rdf:Property ;
    rdfs:label 'Eccn Code' ;
    rdfs:comment 'Export Control Classification Number assigned to the semiconductor product on this schedule line per the US Commerce Control List (CCL). Determines applicable export license requirements. Examples: 3A001 (electronic components), 3E001 (technology for IC design).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlStatus rdf:type rdf:Property ;
    rdfs:label 'Export Control Status' ;
    rdfs:comment 'Export control compliance status for this delivery schedule line. Semiconductor shipments may be subject to EAR (Export Administration Regulations), ITAR (International Traffic in Arms Regulations), or CHIPS Act restrictions. \'blocked\' prevents shipment until clearance is obtained.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the shipment for this delivery schedule line contains hazardous materials (e.g., certain chemical compounds in semiconductor packaging). Triggers special handling, labeling, and documentation requirements per RoHS and REACH regulations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRescheduleReason rdf:type rdf:Property ;
    rdfs:label 'Last Reschedule Reason' ;
    rdfs:comment 'Free-text or coded reason for the most recent rescheduling of this delivery schedule line (e.g., \'wafer yield shortfall\', \'OSAT capacity constraint\', \'customer push-out request\', \'export hold\'). Supports root cause analysis for delivery performance.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpwOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Mpw Order Flag' ;
    rdfs:comment 'Indicates whether this delivery schedule line is associated with a Multi-Project Wafer (MPW) order, where multiple customer designs share a single wafer run. MPW orders have distinct lead times and delivery constraints.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for all quantity fields on this schedule line. Common semiconductor units include PC (pieces/individual ICs), WF (wafers), KGD (Known Good Die), LOT (production lot), REEL (tape-and-reel packaging), TRAY (tray packaging).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant Flag' ;
    rdfs:comment 'Indicates whether the semiconductor product being delivered on this schedule line is compliant with the EU Restriction of Hazardous Substances (RoHS) Directive. Required for shipments to EU customers and increasingly mandated globally.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapScheduleLineCategory rdf:type rdf:Property ;
    rdfs:label 'Sap Schedule Line Category' ;
    rdfs:comment 'SAP SD schedule line category code controlling the delivery and goods movement behavior of this schedule line (e.g., CP = standard delivery with transfer of requirements, CN = no goods movement). Sourced from SAP VBEP-ETTYP.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleLineNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Number' ;
    rdfs:comment 'Sequential line number of this delivery schedule entry within the parent order line item. Used to order multiple delivery windows for the same order line (e.g., line 1 = 500 units on date A, line 2 = 500 units on date B).' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleLineRevision rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Revision' ;
    rdfs:comment 'Revision counter tracking how many times this delivery schedule line has been modified (date changes, quantity adjustments, rescheduling). Supports audit trail requirements and customer change notification (PCN) tracking.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleLineStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Status' ;
    rdfs:comment 'Current fulfillment lifecycle status of this delivery schedule line. Drives backlog management, delivery performance reporting, and customer communication. \'blocked\' indicates an export control or credit hold.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledShipDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Ship Date' ;
    rdfs:comment 'The planned date on which the shipment is expected to leave the ship-from location (fab, OSAT, or warehouse). Calculated by subtracting transit lead time from the confirmed delivery date.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waferStartAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Authorization Number' ;
    rdfs:comment 'Wafer Start Authorization number linking this delivery schedule line to the authorized wafer fab start that will produce the units for this delivery. Critical for semiconductor order-to-cash lifecycle management and fab capacity planning.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Unique system-generated identifier for the shipment record. Primary key for the shipment data product in the order domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:originStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Shipments originate from specific warehouse/storage locations for logistics tracking, inventory depletion, and compliance documentation. Origin_facility_code is denormalized; proper FK enables accurat' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:shipmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Shipment Order Id' ;
    rdfs:comment 'Reference to the parent sales order that initiated this shipment. Links the shipment back to the order-to-cash lifecycle.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:toOrderId rdf:type rdf:Property ;
    rdfs:label 'To Order Id' ;
    rdfs:comment 'FK to order.order.order_id — Shipments fulfill customer orders. shipment.sales_order_id → order.sales_order_id. Critical for order-to-cash traceability.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Confirmed date the shipment physically arrived at the customer receiving location. Populated from carrier proof of delivery (POD) or customer EDI 856 acknowledgement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Advance Shipment Notice (ASN) number transmitted to the customer via EDI 856 prior to physical delivery. Enables customer warehouse receiving preparation and automated goods receipt.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the freight carrier or logistics service provider responsible for transporting the shipment (e.g., FedEx, DHL, UPS, Nippon Express). Used for carrier performance analytics and claims management.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Number' ;
    rdfs:comment 'Carrier-assigned tracking number for the shipment. Enables real-time shipment visibility and customer self-service tracking via carrier portals.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Damaged Goods Flag' ;
    rdfs:comment 'Indicates whether the customer reported damaged goods upon delivery. Triggers carrier claims process, RMA initiation, and DPPM (Defective Parts Per Million) quality reporting.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Declared Value Usd' ;
    rdfs:comment 'Declared value of the shipment contents in US dollars for customs and insurance purposes. Required for import duty calculation and export documentation under EAR/ITAR.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the customer delivery destination. Required for export compliance screening under EAR and ITAR regulations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Carrier-provided estimated date of arrival at the customer destination. Used for delivery scheduling, customer communication, and on-time delivery (OTD) performance tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCostUsd rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Usd' ;
    rdfs:comment 'Total freight and logistics cost for this shipment in US dollars. Used for cost allocation, customer billing (if freight is charged), and supply chain cost analytics.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms including packaging. Required for carrier freight billing, customs declarations, and dangerous goods compliance.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsTariffCode rdf:type rdf:Property ;
    rdfs:label 'Hs Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) tariff classification code for the semiconductor products in this shipment. Required for customs declarations, import duties, and cross-border trade compliance.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Certificate Number' ;
    rdfs:comment 'Reference number of the quality inspection certificate (Certificate of Conformance or Certificate of Analysis) accompanying the shipment. Required for automotive (IATF 16949) and aerospace customers.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiLeg rdf:type rdf:Property ;
    rdfs:label 'Is Multi Leg' ;
    rdfs:comment 'Indicates whether this shipment involves multiple transportation legs (e.g., fab to OSAT to customer, or cross-border transshipment). Enables multi-leg shipment tracking and compliance documentation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotNumbers rdf:type rdf:Property ;
    rdfs:label 'Lot Numbers' ;
    rdfs:comment 'Comma-separated list of manufacturing lot numbers (wafer lot IDs) included in this shipment. Enables full traceability from customer delivery back to wafer fabrication and process engineering records in Camstar MES.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Total number of physical packages (boxes, reels, trays, tubes) included in this shipment. Used for carrier manifest, customs declaration, and receiving verification.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podConfirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Pod Confirmed Quantity' ;
    rdfs:comment 'Quantity confirmed as received by the customer at the delivery location per the proof of delivery (POD). Compared against shipped_quantity to identify shortages or overages.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Pod Receipt Date' ;
    rdfs:comment 'Date the customer confirmed receipt of the shipment as captured in the proof of delivery (POD). Triggers downstream invoice release and revenue recognition in SAP S/4HANA FI.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:podSignoffReference rdf:type rdf:Property ;
    rdfs:label 'Pod Signoff Reference' ;
    rdfs:comment 'Customer signoff reference or electronic signature identifier from the proof of delivery document. Serves as legal evidence of delivery completion for dispute resolution and revenue recognition.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityShortageFlag rdf:type rdf:Property ;
    rdfs:label 'Quantity Shortage Flag' ;
    rdfs:comment 'Indicates whether the customer reported a quantity shortage at delivery (POD confirmed quantity less than shipped quantity). Triggers discrepancy investigation and potential credit memo.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Code' ;
    rdfs:comment 'Code identifying the specific customer receiving dock, warehouse, or facility where the shipment was delivered. Used for multi-site customer delivery routing and POD reconciliation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Reference Number' ;
    rdfs:comment 'Return Merchandise Authorization (RMA) number associated with this shipment if a return or dispute has been initiated. Links shipment to the RMA and reverse logistics process.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Carrier service tier selected for this shipment (e.g., overnight, express, standard ground). Determines transit time commitment and freight cost.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Actual date the shipment physically departed the origin facility (fab, OSAT, or distribution center). Principal business event date for the shipment transaction.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally visible, human-readable shipment identifier used in carrier communications, customer EDI 856 ASN, and logistics documentation. Sourced from SAP S/4HANA SD outbound delivery number.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle state of the shipment. Drives downstream processes including invoice release and revenue recognition upon delivery confirmation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wrongPartFlag rdf:type rdf:Property ;
    rdfs:label 'Wrong Part Flag' ;
    rdfs:comment 'Indicates whether the customer reported receipt of an incorrect part number or product. Triggers RMA process, root cause analysis, and corrective action in the quality management system.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentLineId rdf:type rdf:Property ;
    rdfs:label 'Shipment Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each shipment line record in the Silver Layer lakehouse. Primary key for the shipment_line data product.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finishedGoodId rdf:type rdf:Property ;
    rdfs:label 'Finished Good Id' ;
    rdfs:comment 'Foreign key linking to inventory.finished_good. Business justification: Finished goods shipments must link to specific inventory lots for lot traceability, date code tracking, and quality issue containment. Critical for customer notifications, field returns correlation, a' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinishedGood .

ind:primaryShipmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Shipment Id' ;
    rdfs:comment 'Reference to the parent shipment header record. Links this line to the physical shipment event (HEADER_REFERENCE per TRANSACTION_LINE role).' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:primaryShipmentOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Primary Shipment Order Line Id' ;
    rdfs:comment 'Reference to the customer order line that this shipment line fulfills. Enables traceability from physical shipment back to the originating sales order line in the order-to-cash lifecycle.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:toShipmentId rdf:type rdf:Property ;
    rdfs:label 'To Shipment Id' ;
    rdfs:comment 'FK to order.shipment.shipment_id — Fundamental header-to-line relationship. Every shipment line must belong to exactly one shipment.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:advanceShipNoticeNumber rdf:type rdf:Property ;
    rdfs:label 'Advance Ship Notice Number' ;
    rdfs:comment 'EDI Advance Ship Notice (ASN/856) document number transmitted to the customer prior to shipment. Enables customer receiving automation and inventory planning.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether this shipment line represents a partial fulfillment of a backordered quantity, where the full ordered quantity could not be shipped due to inventory allocation constraints.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfConformanceNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Conformance Number' ;
    rdfs:comment 'Document number of the Certificate of Conformance issued by quality assurance, attesting that the shipped product meets all specified requirements. Required for automotive (IATF 16949) and aerospace customers.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateCode rdf:type rdf:Property ;
    rdfs:label 'Date Code' ;
    rdfs:comment 'Manufacturing date code in YYWW format (year + work week) indicating when the product was fabricated or assembled. Required for shelf-life management, FIFO inventory rotation, and customer quality audits.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Timestamp' ;
    rdfs:comment 'Precise timestamp when goods issue was posted in SAP, marking the transfer of ownership and triggering revenue recognition and inventory reduction. BUSINESS_EVENT_TIMESTAMP for this transaction line.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineNetValue rdf:type rdf:Property ;
    rdfs:label 'Line Net Value' ;
    rdfs:comment 'Total net value of this shipment line (shipped_quantity × unit_selling_price after applicable discounts). Used for revenue recognition, invoice generation, and SOX financial reporting.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Moisture Sensitivity Level' ;
    rdfs:comment 'JEDEC moisture sensitivity level classification for the shipped packaged IC. Determines floor life, storage, and baking requirements at the customer\'s SMT assembly facility.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Physical packaging configuration used for the shipped semiconductor units. Determines handling requirements, moisture sensitivity level (MSL), and customer SMT assembly compatibility.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'Manufacturer part number (MPN) for the shipped semiconductor product as listed in the product catalog and on the shipping documentation. Used for customer identification and BOM matching.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialShipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Flag' ;
    rdfs:comment 'Indicates whether this line represents a partial shipment against the order line quantity. When true, additional shipment lines are expected to fulfill the remaining ordered quantity.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'Committed delivery date for this shipment line as agreed with the customer at order entry. Used for on-time delivery (OTD) performance measurement and customer SLA tracking.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionLevel rdf:type rdf:Property ;
    rdfs:label 'Revision Level' ;
    rdfs:comment 'Hardware or mask revision level of the shipped IC (e.g., A0, B1, C2). Critical for customer compatibility verification, PCN (Product Change Notification) compliance, and field failure analysis.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range End' ;
    rdfs:comment 'Ending serial number of the serialized unit range included in this shipment line. Used with serial_number_range_start to define the complete set of serialized units shipped.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range Start' ;
    rdfs:comment 'Starting serial number of the serialized unit range included in this shipment line. Applicable for high-value or security-sensitive ICs requiring individual unit traceability (e.g., automotive, military-grade).' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Selling Price' ;
    rdfs:comment 'Agreed selling price per unit for this shipment line as invoiced to the customer. LINE_VALUE_OR_RESULT per TRANSACTION_LINE role. Sensitive commercial pricing data.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldGrade rdf:type rdf:Property ;
    rdfs:label 'Yield Grade' ;
    rdfs:comment 'Quality or speed grade assigned to the shipped product based on wafer test (probe) results and final test binning. Indicates performance tier (e.g., commercial, industrial, automotive, military grade) for the shipped units.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backlogPositionId rdf:type rdf:Property ;
    rdfs:label 'Backlog Position Id' ;
    rdfs:comment 'Unique surrogate identifier for each backlog position snapshot record in the order-to-cash lifecycle. Primary key for the backlog_position data product.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Line Id' ;
    rdfs:comment 'FK to order.order_line.order_line_id — Backlog positions track unshipped quantities for specific order lines. Without this FK, backlog cannot be reconciled to orders.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity from available inventory or in-process production lots that has been formally allocated to fulfill this backlog position. May be less than committed_quantity in constrained supply scenarios.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backlogAgingDays rdf:type rdf:Property ;
    rdfs:label 'Backlog Aging Days' ;
    rdfs:comment 'Number of calendar days this order line has been in open backlog as of the snapshot date, calculated from order_entry_date. Used for customer escalation prioritization and aged backlog reporting.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backlogStatus rdf:type rdf:Property ;
    rdfs:label 'Backlog Status' ;
    rdfs:comment 'Current workflow state of this backlog position. \'open\' = unshipped committed order; \'committed\' = confirmed with delivery date; \'at_risk\' = delivery commitment in jeopardy; \'pushed_out\' = delivery date deferred; \'cancelled\' = order line cancelled; \'fulfilled\' = shipped and closed.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backlogValue rdf:type rdf:Property ;
    rdfs:label 'Backlog Value' ;
    rdfs:comment 'The monetary value of the unshipped committed backlog quantity, calculated as committed_quantity multiplied by the net selling price. Used for revenue forecasting, quarterly guidance, and book-to-bill ratio reporting.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelledQuantity rdf:type rdf:Property ;
    rdfs:label 'Cancelled Quantity' ;
    rdfs:comment 'Quantity cancelled from the original order line. Tracks cancellation impact on backlog coverage and book-to-bill ratio reporting.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'The unshipped quantity (in units) that remains committed in backlog for this order line as of the snapshot date. Core metric for backlog management and production planning.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentCommitDate rdf:type rdf:Property ;
    rdfs:label 'Current Commit Date' ;
    rdfs:comment 'The most recent confirmed delivery date committed to the customer, reflecting any push-outs or pull-ins from the original promise date. Used for revenue forecasting and quarterly close planning.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designWinFlag rdf:type rdf:Property ;
    rdfs:label 'Design Win Flag' ;
    rdfs:comment 'Indicates whether this backlog position is associated with a strategic design-win account tracked in Salesforce CRM. Design-win orders receive elevated fulfillment priority to protect long-term revenue relationships.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportControlFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Flag' ;
    rdfs:comment 'Indicates whether this order line is subject to export control regulations (EAR/ITAR). When true, shipment requires validated export license or license exception before fulfillment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Export License Number' ;
    rdfs:comment 'The export license number issued by the Bureau of Industry and Security (BIS) or State Department authorizing shipment of controlled semiconductor products. Required when export_control_flag is true.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdCode rdf:type rdf:Property ;
    rdfs:label 'Hold Code' ;
    rdfs:comment 'Code indicating the reason this backlog position is on hold and cannot be shipped. Examples include credit hold, export license pending, quality hold, or customer-requested hold. Null when no hold is active. [ENUM-REF-CANDIDATE: credit_hold|export_hold|quality_hold|customer_hold|compliance_hold|capacity_hold — promote to reference product]' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Net Selling Price' ;
    rdfs:comment 'The agreed net unit selling price for this order line after all applicable discounts and price adjustments. Used to compute backlog value and support revenue recognition under ASC 606.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderEntryDate rdf:type rdf:Property ;
    rdfs:label 'Order Entry Date' ;
    rdfs:comment 'The date on which the customer order was originally entered into the order management system. Used to calculate backlog aging and time-in-backlog metrics.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Original Order Quantity' ;
    rdfs:comment 'The total quantity originally ordered by the customer on this order line. Used to calculate fulfillment percentage and track cancellation or reduction impacts on backlog.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalPromiseDate rdf:type rdf:Property ;
    rdfs:label 'Original Promise Date' ;
    rdfs:comment 'The initial delivery date committed to the customer at the time of order entry. Baseline for measuring push-outs and delivery performance against original commitment.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking assigned to this backlog position for allocation and fulfillment sequencing. Lower values indicate higher priority. Used during supply-constrained periods to prioritize strategic customers and design-win accounts.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pushOutDays rdf:type rdf:Property ;
    rdfs:label 'Push Out Days' ;
    rdfs:comment 'Number of calendar days the current_commit_date has been deferred beyond the original_promise_date. Positive value indicates a push-out (delay); negative value indicates a pull-in (acceleration). Key metric for delivery performance and customer satisfaction.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pushOutReasonCode rdf:type rdf:Property ;
    rdfs:label 'Push Out Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the delivery commitment was pushed out or pulled in. Examples include wafer yield issue, capacity constraint, material shortage, customer request, or logistics delay. [ENUM-REF-CANDIDATE: yield_issue|capacity_constraint|material_shortage|customer_request|logistics_delay|design_change|export_hold — promote to reference product]' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Flag' ;
    rdfs:comment 'Indicates whether this backlog position meets the criteria for revenue recognition upon shipment under ASC 606 / IFRS 15. False indicates revenue deferral conditions apply (e.g., consignment, bill-and-hold arrangements).' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesRegion rdf:type rdf:Property ;
    rdfs:label 'Sales Region' ;
    rdfs:comment 'Geographic sales region associated with this backlog position (e.g., Americas, EMEA, Japan, Greater China, Rest of APAC). Used for regional backlog reporting and revenue forecasting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The calendar date on which this point-in-time backlog position snapshot was captured. Enables time-series backlog trending, quarterly close reporting, and book-to-bill ratio calculation.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waferLotNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Lot Number' ;
    rdfs:comment 'The fabrication lot number of the wafer batch assigned to fulfill this backlog position. Links the backlog to the specific Work in Process (WIP) lot in the fab for production tracking and yield impact analysis.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRecordId rdf:type rdf:Property ;
    rdfs:label 'Allocation Record Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a single inventory, capacity, or lot allocation record within the order fulfillment process.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedFabToolId rdf:type rdf:Property ;
    rdfs:label 'Allocated Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Allocations may be tool-specific when fab capacity is constrained by particular equipment bottlenecks. Enables tool-level capacity allocation decisions, supports constrained capacity management, and t' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Reference to the parent sales order header under which this allocation record is created. Supports backlog management and order-to-cash reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the allocation was created and the inventory or capacity was reserved against the order line. Principal business event date for this transaction.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this allocation record. Used in customer communications, ERP transactions, and supply chain coordination.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationSource rdf:type rdf:Property ;
    rdfs:label 'Allocation Source' ;
    rdfs:comment 'Identifies the inventory or capacity pool from which this allocation is drawn: \'finished_goods\' (packaged inventory), \'die_bank\' (singulated die inventory), \'wafer_lot\' (in-process wafer inventory), \'fab_capacity\' (reserved fab production capacity), \'mpw_pool\' (Multi-Project Wafer shared pool).' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the allocation assignment: \'tentative\' (preliminary hold), \'confirmed\' (firm allocation committed to order), \'shipped\' (goods dispatched against this allocation), \'cancelled\' (allocation voided), \'expired\' (allocation lapsed past expiry date), \'on_hold\' (allocation suspended pending resolution). [ENUM-REF-CANDIDATE: tentative|confirmed|shipped|cancelled|expired|on_hold — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'The date on which the allocation was formally confirmed, transitioning from tentative or soft to confirmed status. Triggers downstream shipment scheduling.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constrainedSupplyFlag rdf:type rdf:Property ;
    rdfs:label 'Constrained Supply Flag' ;
    rdfs:comment 'Indicates whether this allocation was made under constrained supply conditions, where demand exceeded available inventory or fab capacity. Triggers priority-based allocation logic.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date after which this allocation record is no longer valid and reserved inventory or capacity is released back to available supply. Critical for managing soft allocations and tentative holds.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryBatchCode rdf:type rdf:Property ;
    rdfs:label 'Inventory Batch Code' ;
    rdfs:comment 'SAP batch management identifier for the specific inventory batch being allocated. Enables batch-level traceability and quality disposition linkage within SAP S/4HANA MM.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Classifies the type of manufacturing lot being allocated: \'wafer_lot\' (silicon wafer lot at fab), \'die_lot\' (singulated die inventory), \'packaged_goods_lot\' (finished packaged semiconductor units), \'mpw_lot\' (Multi-Project Wafer shared lot).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osatSiteCode rdf:type rdf:Property ;
    rdfs:label 'Osat Site Code' ;
    rdfs:comment 'Code identifying the Outsourced Semiconductor Assembly and Test (OSAT) facility responsible for packaging and testing the allocated lot. Relevant for packaged goods lot allocations.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDisposition rdf:type rdf:Property ;
    rdfs:label 'Quality Disposition' ;
    rdfs:comment 'Quality disposition status of the allocated lot or inventory batch: \'accepted\' (meets all quality specifications), \'rejected\' (fails quality criteria), \'conditionally_accepted\' (accepted with documented deviations), \'under_review\' (quality evaluation in progress), \'scrapped\' (lot destroyed). Supports IATF 16949 lot-level quality traceability.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Quality Disposition Notes' ;
    rdfs:comment 'Free-text notes documenting lot-specific quality disposition findings, deviations, or conditions associated with this allocation. Supports automotive and aerospace traceability requirements.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the allocated quantity: \'EA\' (each, for packaged units), \'WFR\' (wafers), \'DIE\' (individual die), \'KPC\' (thousand pieces). Aligns with SAP base unit of measure.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nreOrderId rdf:type rdf:Property ;
    rdfs:label 'Nre Order Id' ;
    rdfs:comment 'Unique identifier for the NRE order record. Primary key for the NRE order entity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NreOrder .

ind:financeNreAgreementId rdf:type rdf:Property ;
    rdfs:label 'Finance Nre Agreement Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_nre_agreement. Business justification: NRE orders must link to financial agreements for revenue recognition, milestone billing, and contract compliance. Finance tracks NRE revenue against contractual milestones; this link enables reconcili' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceNreAgreement .

ind:primaryNreSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Nre Sales Order Id' ;
    rdfs:comment 'Reference to the associated production sales order that this NRE order supports. Links NRE charges to the recurring product order.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:targetFabToolId rdf:type rdf:Property ;
    rdfs:label 'Target Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: NRE orders frequently target specific fab tools for process development, tool qualification, or technology node enablement. Essential for NRE project planning, tool reservation, and tracking which equ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:technologyControlPlanId rdf:type rdf:Property ;
    rdfs:label 'Technology Control Plan Id' ;
    rdfs:comment 'Foreign key linking to compliance.technology_control_plan. Business justification: NRE projects involving controlled technology must reference approved TCP for access control, clean team protocols, and foreign national restrictions. Regulatory mandate for deemed exports.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnologyControlPlan .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Contractually defined criteria that must be met for customer acceptance of NRE deliverables. Used for milestone signoff and dispute resolution.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when all NRE deliverables were completed and accepted. Triggers final milestone billing and project closure.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationClause rdf:type rdf:Property ;
    rdfs:label 'Cancellation Clause' ;
    rdfs:comment 'Contractual terms governing NRE order cancellation, including notice periods, cancellation fees, and work-in-progress settlement.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedMilestoneCount rdf:type rdf:Property ;
    rdfs:label 'Completed Milestone Count' ;
    rdfs:comment 'Number of milestones that have been completed and accepted by the customer. Used to calculate project completion percentage.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Classification of confidentiality requirements for NRE deliverables and design information. Determines access controls and disclosure restrictions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDate rdf:type rdf:Property ;
    rdfs:label 'Contract Date' ;
    rdfs:comment 'Date when the NRE contract was signed and became legally binding. Establishes the start of contractual obligations.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Commercial structure of the NRE contract. Determines billing method and risk allocation between customer and supplier.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableList rdf:type rdf:Property ;
    rdfs:label 'Deliverable List' ;
    rdfs:comment 'Comprehensive list of engineering deliverables committed in the NRE contract. Includes design files, documentation, test reports, and IP cores.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Design Complexity Score' ;
    rdfs:comment 'Quantitative measure of IC design complexity based on gate count, IP blocks, and verification requirements. Used for NRE pricing and resource estimation.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Cumulative amount invoiced to date across all completed milestones. Used to track billing progress and outstanding receivables.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipCoreList rdf:type rdf:Property ;
    rdfs:label 'Ip Core List' ;
    rdfs:comment 'List of third-party or internal IP cores integrated as part of this NRE engagement. Tracks IP licensing and royalty obligations.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of engineering milestones defined in this NRE contract. Used for progress tracking and billing schedule management.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Nre Order Number' ;
    rdfs:comment 'Human-readable business identifier for the NRE order. Externally communicated reference number used in contracts and invoices.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nreStatus rdf:type rdf:Property ;
    rdfs:label 'Nre Status' ;
    rdfs:comment 'Current lifecycle status of the NRE order. Tracks progression from contract approval through engineering completion and invoicing. [ENUM-REF-CANDIDATE: draft|approved|in_progress|milestone_review|completed|invoiced|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nreToSalesOrder rdf:type rdf:Property ;
    rdfs:label 'Nre To Sales Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — NRE orders are associated with a customer engagement that typically has a parent sales order or contract reference.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreType rdf:type rdf:Property ;
    rdfs:label 'Nre Type' ;
    rdfs:comment 'Classification of the NRE engagement by engineering deliverable category. Determines the type of one-time engineering work being performed.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Cumulative amount received from customer to date. Used to track payment status and outstanding balances.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Contractual penalties for late delivery or non-conformance to acceptance criteria. Defines financial consequences of schedule or quality failures.' ;
    rdfs:domain ind:NreOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Accounting method used to recognize NRE revenue. Determines timing of revenue booking based on contract structure and completion criteria.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalNreAmount rdf:type rdf:Property ;
    rdfs:label 'Total Nre Amount' ;
    rdfs:comment 'Total contracted value of the NRE engagement across all milestones. Represents the full one-time engineering charge.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Nre Milestone Id' ;
    rdfs:comment 'Unique identifier for the NRE milestone record. Primary key for the order_nre_milestone product.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceSignoffBy rdf:type rdf:Property ;
    rdfs:label 'Acceptance Signoff By' ;
    rdfs:comment 'Name or identifier of the customer representative who provided formal acceptance signoff for the milestone.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceSignoffReference rdf:type rdf:Property ;
    rdfs:label 'Acceptance Signoff Reference' ;
    rdfs:comment 'Reference to the formal customer acceptance document, email, or system record confirming milestone approval.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current billing and payment status of the milestone, tracking progression from acceptance through payment receipt.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Flag' ;
    rdfs:comment 'Indicates whether this milestone has been modified from the original contract terms through a formal change order or amendment.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Date' ;
    rdfs:comment 'Date when the customer formally accepted the milestone deliverable, triggering payment and revenue recognition.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliverableLocation rdf:type rdf:Property ;
    rdfs:label 'Deliverable Location' ;
    rdfs:comment 'File path, document management system reference, or repository location where the milestone deliverable artifacts are stored.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyMilestones rdf:type rdf:Property ;
    rdfs:label 'Dependency Milestones' ;
    rdfs:comment 'Comma-separated list of prerequisite milestone numbers or identifiers that must be completed before this milestone can begin.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effortHoursActual rdf:type rdf:Property ;
    rdfs:label 'Effort Hours Actual' ;
    rdfs:comment 'Actual engineering effort in hours expended to complete this milestone, tracked for cost accounting and future estimation.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effortHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Effort Hours Planned' ;
    rdfs:comment 'Estimated engineering effort in hours required to complete this milestone, used for resource planning and cost estimation.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date when the invoice for this milestone was issued to the customer.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Reference to the invoice document generated for this milestone billing.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneAmount rdf:type rdf:Property ;
    rdfs:label 'Milestone Amount' ;
    rdfs:comment 'Contractual payment amount associated with this milestone in the order currency. Represents the revenue to be recognized upon milestone acceptance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Detailed description of the engineering deliverable, acceptance criteria, and scope of work associated with this milestone.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationReference rdf:type rdf:Property ;
    rdfs:label 'Modification Reference' ;
    rdfs:comment 'Reference to the contract change order or amendment document that modified this milestone terms, scope, or payment.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment for this milestone is contractually due from the customer.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Actual date when payment for this milestone was received from the customer.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation provided by the customer if the milestone deliverable was rejected, including specific deficiencies or gaps.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Amount' ;
    rdfs:comment 'Actual amount of revenue recognized for this milestone, which may differ from milestone_amount due to contract modifications or adjustments.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date when revenue for this milestone was recognized in the financial system, typically aligned with customer acceptance date per ASC 606.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reworkRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Required Flag' ;
    rdfs:comment 'Indicates whether engineering rework is required to address customer feedback or rejection reasons.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of technical or schedule risk associated with achieving this milestone on time and meeting acceptance criteria.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this milestone within the NRE order, defining the execution sequence and dependencies.' ;
    rdfs:domain ind:NreMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Primary key for rma' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerComplaintId rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Id' ;
    rdfs:comment 'Foreign key linking to quality.customer_complaint. Business justification: RMAs are frequently initiated by customer complaints. Linking RMA to the originating customer complaint enables root cause tracking, DPPM impact analysis, and closed-loop corrective action verificatio' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerComplaint .

ind:fabricationWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Fabrication Wafer Lot Id' ;
    rdfs:comment 'Reference to the manufacturing lot from which the returned units originated. Critical for traceability and yield impact analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:failureAnalysisReportId rdf:type rdf:Property ;
    rdfs:label 'Failure Analysis Report Id' ;
    rdfs:comment 'Reference to the failure analysis record if FA was performed. Links RMA to detailed root cause investigation and corrective action.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureAnalysisReport .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: RMA credit memos and warranty claims post to specific GL accounts for financial statement accuracy and audit trail. Month-end close requires RMA reserve reconciliation against GL for ASC 606 complianc' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:nonconformanceReportId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Report Id' ;
    rdfs:comment 'Foreign key linking to quality.nonconformance_report. Business justification: RMA disposition triggers nonconformance report workflow for root cause analysis and corrective action. Semiconductor quality systems require NCR linkage to track material disposition, containment acti' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NonconformanceReport .

ind:originalShipmentId rdf:type rdf:Property ;
    rdfs:label 'Original Shipment Id' ;
    rdfs:comment 'Foreign key linking to order.shipment. Business justification: An RMA is triggered by a specific outbound shipment that contained defective or incorrect product. Linking rma to the originating shipment enables full traceability from return to original dispatch, s' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:receivingStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: RMA returns must be received into specific quarantine/inspection storage locations for failure analysis, disposition decisions, and inventory reconciliation. Receiving_facility_code is denormalized; F' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:rmaOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Order Id' ;
    rdfs:comment 'FK to order.order.order_id — RMAs reference the original sales order for the returned product. rma.sales_order_id → order.sales_order_id.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:rmaReplacementOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Replacement Order Id' ;
    rdfs:comment 'Reference to the replacement sales order created to ship substitute product to the customer. Nullable if disposition is not replacement.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:rmaSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Sales Order Id' ;
    rdfs:comment 'Reference to the original sales order from which the returned product was shipped. Links RMA to the originating order transaction.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the RMA was fully closed after disposition action completed (credit issued, replacement shipped, or material scrapped).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether a formal corrective action (CAPA) is required based on the RMA findings. True triggers CAPA workflow per ISO 9001 and IATF 16949.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Monetary value of the credit issued to the customer in the transaction currency. Nullable if no credit is issued.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Reference number of the credit memo issued to the customer for the returned material. Nullable if no credit is issued (e.g., customer error returns).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Email' ;
    rdfs:comment 'Email address of the customer contact for RMA correspondence, status updates, and resolution communication.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactName rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Name' ;
    rdfs:comment 'Name of the customer representative who initiated or is managing the RMA on the customer side. Used for communication and escalation.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number of the customer contact for urgent RMA inquiries or escalation.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Free-text description of the defect or issue reported by the customer. Captures detailed failure symptoms, visual observations, or functional anomalies.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'Action to be taken with the returned material. Determines downstream workflow (credit memo, replacement order, FA request, or scrap authorization).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dppmImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Dppm Impact Flag' ;
    rdfs:comment 'Indicates whether this RMA should be counted in DPPM calculations. True if the defect is attributable to manufacturing or design (excludes customer-induced damage).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureAnalysisRequested rdf:type rdf:Property ;
    rdfs:label 'Failure Analysis Requested' ;
    rdfs:comment 'Indicates whether a formal failure analysis (FA) has been requested for the returned units. True triggers FA workflow and lab assignment.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Outcome of the incoming inspection. Determines whether the return claim is valid and informs disposition and credit decisions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes and comments for cross-functional coordination (quality, engineering, customer service). Not shared with customer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when the returned material was physically received at the receiving facility or OSAT partner. Nullable until material arrives.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the customer initiated the RMA request. Principal business event timestamp for the RMA lifecycle.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code categorizing the reason for the return. Used for root cause analysis, DPPM tracking, and warranty claim classification.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShippingCarrier rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Carrier' ;
    rdfs:comment 'Name of the logistics carrier used to ship the returned material (e.g., FedEx, UPS, DHL, regional freight forwarder).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Tracking Number' ;
    rdfs:comment 'Carrier tracking number for the return shipment. Used for shipment visibility and proof of receipt.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Number of units (dies, packaged chips, or wafers) returned under this RMA. Used for DPPM calculation and inventory adjustment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the RMA. Used in customer communications, shipping labels, and cross-system tracking.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the RMA. Tracks progression from customer request through receipt, inspection, and final disposition. [ENUM-REF-CANDIDATE: requested|approved|rejected|in_transit|received|inspected|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorization of the root cause identified during inspection or FA. Used for DPPM trending and corrective action prioritization.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toOriginalOrder rdf:type rdf:Property ;
    rdfs:label 'To Original Order' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — RMAs reference the original sales order for the returned product. Required for credit processing and quality traceability.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether this RMA is being processed as a warranty claim. True if the return is within warranty period and defect is covered.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the warranty coverage for the returned product expires. Used to validate warranty claim eligibility.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Agreed Unit Price' ;
    rdfs:comment 'The contractually agreed price per unit for the product under this blanket order. May be a single fixed price or the base tier price when pricing tiers are defined. Expressed in the contract currency.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the blanket order agreement type. Scheduling agreements define delivery cadence; quantity contracts commit to total volume; value contracts commit to total spend; MPW (Multi-Project Wafer) blankets cover shuttle run commitments; distributor frame agreements govern stocking distributor relationships.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The timestamp when the blanket order agreement was formally approved by the authorized signatory (e.g., VP of Sales or Finance Controller) and transitioned from draft to active status. Required for SOX revenue recognition controls.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether this blanket order agreement is configured to automatically renew for an additional contract period upon expiry if neither party issues a termination notice within the agreed notice window.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blanketOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Number' ;
    rdfs:comment 'Externally visible alphanumeric identifier for the blanket purchase agreement, used in customer-facing communications, SAP SD scheduling agreements, and ERP cross-references. Follows the BO- prefix convention.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calloffFrequency rdf:type rdf:Property ;
    rdfs:label 'Calloff Frequency' ;
    rdfs:comment 'The agreed cadence at which the customer issues individual release orders (call-offs) against this blanket agreement. Drives wafer start planning, fab scheduling, and inventory build strategy.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Months' ;
    rdfs:comment 'Total duration of the blanket order agreement expressed in calendar months. Standard semiconductor blanket agreements run 12 or 24 months; automotive long-term supply agreements may extend to 36 months.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerContractNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Contract Number' ;
    rdfs:comment 'The customer\'s own purchase contract or frame agreement reference number as provided on the customer\'s procurement documentation. Used for cross-referencing with the customer\'s ERP or procurement system.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which the blanket order agreement becomes legally binding and call-off releases may begin. Marks the start of the contract period, typically aligned with the customer\'s fiscal year or program start.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Release Date' ;
    rdfs:comment 'The date of the most recent call-off release order issued against this blanket agreement. Used to monitor customer ordering activity, identify dormant blankets, and trigger account management follow-up.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeWeeks rdf:type rdf:Property ;
    rdfs:label 'Lead Time Weeks' ;
    rdfs:comment 'The agreed manufacturing and delivery lead time in weeks from call-off release order placement to customer delivery. Encompasses wafer fab cycle time, assembly and test (OSAT), and logistics. Critical for wafer start authorization scheduling.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum quantity per individual call-off release order as agreed in the blanket contract. Enforces production lot efficiency and wafer start economics. Expressed in the same unit of measure as committed_quantity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncnrCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Ncnr Coverage Percentage' ;
    rdfs:comment 'The percentage of the committed quantity or blanket value that is subject to NCNR terms. A value of 100 means the entire commitment is NCNR; partial NCNR coverage is common in distributor agreements.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncnrFlag rdf:type rdf:Property ;
    rdfs:label 'Ncnr Flag' ;
    rdfs:comment 'Indicates whether the blanket order is subject to Non-Cancellable Non-Returnable (NCNR) terms. When True, the customer cannot cancel or return product once a release order is issued. Standard for automotive and high-volume OEM semiconductor supply agreements.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingTierStructure rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Structure' ;
    rdfs:comment 'Defines the pricing model applied to this blanket order. Fixed: single price for all quantities; Volume Tiered: unit price decreases at defined quantity thresholds; Time Tiered: price adjusts at defined calendar intervals; Milestone Tiered: price adjusts upon reaching program milestones such as design-in or production ramp.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productPartNumber rdf:type rdf:Property ;
    rdfs:label 'Product Part Number' ;
    rdfs:comment 'The Semiconductors internal part number (device identifier) for the IC, SoC, ASIC, or FPGA product covered by this blanket order. Aligns with the product master in SAP MM and Oracle Agile PLM.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseOrderToBlanket rdf:type rdf:Property ;
    rdfs:label 'Release Order To Blanket' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Individual sales orders (release orders) are created against blanket orders. The sales order must reference its parent blanket for volume tracking.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'Cumulative quantity that has been called off against this blanket order through individual release orders to date. Used to track consumption of the committed volume and compute remaining open quantity.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'The number of calendar days prior to the expiry date by which either party must provide written notice to prevent automatic renewal or to initiate renegotiation of the blanket agreement terms.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesOrderToBlanket rdf:type rdf:Property ;
    rdfs:label 'Sales Order To Blanket' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — Individual sales orders are call-offs against blanket orders. This link is critical for blanket quantity consumption tracking and volume commitment management.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBlanketValue rdf:type rdf:Property ;
    rdfs:label 'Total Blanket Value' ;
    rdfs:comment 'The total monetary value of the blanket order agreement, calculated as committed_quantity multiplied by agreed_unit_price (or sum of tier values). Represents the maximum revenue commitment from this customer for the contract period. Used for revenue forecasting and SOX financial reporting.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCertId rdf:type rdf:Property ;
    rdfs:label 'Compliance Cert Id' ;
    rdfs:comment 'Foreign key linking to product.compliance_cert. Business justification: Wafer lots may require compliance certifications (ITAR, REACH, RoHS) for export/shipment. Cert status tracking for trade compliance and regulatory reporting requires this link.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceCert .

ind:errataId rdf:type rdf:Property ;
    rdfs:label 'Errata Id' ;
    rdfs:comment 'Foreign key linking to product.errata. Business justification: Wafer lots may be affected by errata (silicon bugs). Errata impact on WIP for disposition, customer notification, and workaround implementation requires this link.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Errata .

ind:familyId rdf:type rdf:Property ;
    rdfs:label 'Family Id' ;
    rdfs:comment 'Foreign key linking to product.family. Business justification: Wafer lots produce die for specific product families. Revenue forecasting, capacity allocation, and family-level WIP tracking require this link for business planning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Wafer lot ownership by legal entity required for transfer pricing, customs valuation, intercompany transactions, and consolidated financial reporting in multi-entity semiconductor operations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:ltbNotificationId rdf:type rdf:Property ;
    rdfs:label 'Ltb Notification Id' ;
    rdfs:comment 'Foreign key linking to product.product_ltb_notification. Business justification: Wafer lots may be affected by LTB notifications (product discontinuance). LTB impact on WIP for disposition, customer notification, and last-time-buy planning requires this link.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LtbNotification .

ind:pcnId rdf:type rdf:Property ;
    rdfs:label 'Pcn Id' ;
    rdfs:comment 'Foreign key linking to product.pcn. Business justification: Wafer lots may be affected by PCNs (process changes). PCN impact on WIP for disposition decisions, customer notification, and change management requires this link.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pcn .

ind:processFlowId rdf:type rdf:Property ;
    rdfs:label 'Process Flow Id' ;
    rdfs:comment 'Identifier of the MES process route (flow plan) assigned to this wafer lot, defining the ordered sequence of operations from wafer start through final FAB step. Determines which process steps, equipment, and recipes apply to the lot.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessFlow .

ind:productQualificationProgramId rdf:type rdf:Property ;
    rdfs:label 'Product Qualification Program Id' ;
    rdfs:comment 'Foreign key linking to product.product_qualification_program. Business justification: Wafer lots may be part of qualification programs (reliability testing, customer qual). Qual program participation tracking for certification and production release requires this link.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductQualificationProgram .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: WIP wafer lots are physically stored in specific cleanroom storage locations within the FAB. The existing storage_location_code (STRING) is a denormalized reference that should be replaced by a proper' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Reference to the SAP work center or MES equipment group where the lot is currently queued or being processed. Enables WIP queue analysis and bottleneck identification across FEOL, MOL, and BEOL process stages.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:currentOperationStep rdf:type rdf:Property ;
    rdfs:label 'Current Operation Step' ;
    rdfs:comment 'The current process operation step name or code at which the wafer lot is positioned in the process flow (e.g., \'FEOL_Gate_Oxide\', \'MOL_Contact_Etch\', \'BEOL_Metal1_CVD\'). Sourced from the MES process flow definition. Critical for WIP traceability and cycle time analysis.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodWaferCount rdf:type rdf:Property ;
    rdfs:label 'Good Wafer Count' ;
    rdfs:comment 'Number of wafers in the lot that have passed all in-line inspection and metrology checks to date. Represents the current count of wafers expected to yield good die. Updated after each inspection or disposition event.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Indicates whether the wafer lot is currently placed on hold and cannot proceed to the next process step. A True value means the lot is blocked pending engineering review, quality disposition, or management approval. Sourced from MES hold management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Coded reason for the current or most recent hold placed on the wafer lot (e.g., \'PROCESS_EXCURSION\', \'EQUIPMENT_FAILURE\', \'YIELD_LOSS\', \'CUSTOMER_REQUEST\', \'ENGINEERING_REVIEW\'). Populated when hold_flag is True. Used for hold disposition tracking and FMEA analysis. [ENUM-REF-CANDIDATE: PROCESS_EXCURSION|EQUIPMENT_FAILURE|YIELD_LOSS|CUSTOMER_REQUEST|ENGINEERING_REVIEW|MATERIAL_SHORTAGE|QUALITY_DISPOSITION — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Timestamp' ;
    rdfs:comment 'Date and time when the most recent hold was placed on the wafer lot. Null if the lot has never been placed on hold. Used for hold duration tracking and SPC (Statistical Process Control) excursion response time measurement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Amount' ;
    rdfs:comment 'Current standard cost valuation of the wafer lot in the inventory ledger, expressed in the functional currency. Calculated based on the number of wafers and the standard cost per wafer at the current process step. Used for WIP inventory valuation in SAP FI/CO and financial reporting under SOX.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotStartDate rdf:type rdf:Property ;
    rdfs:label 'Lot Start Date' ;
    rdfs:comment 'Calendar date on which the wafer lot was officially started (wafer start authorization executed) in the FAB. Used for cycle time measurement, WIP aging analysis, and on-time delivery tracking. This is the BUSINESS_EVENT_TIMESTAMP (date precision) category field.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle state of the wafer lot within the FAB WIP flow. \'active\' indicates the lot is progressing through process steps; \'on_hold\' indicates a hold flag is set pending disposition; \'completed\' indicates all process steps are finished; \'scrapped\' indicates the lot has been disposed; \'cancelled\' indicates the lot was terminated before completion. This is the LIFECYCLE_STATUS category field.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesLotReference rdf:type rdf:Property ;
    rdfs:label 'Mes Lot Reference' ;
    rdfs:comment 'Native lot reference number as recorded in the Applied Materials SmartFactory or Camstar MES system. Enables direct cross-reference to the operational system of record for lot tracking, dispatch, and WIP management.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStage rdf:type rdf:Property ;
    rdfs:label 'Process Stage' ;
    rdfs:comment 'High-level semiconductor fabrication stage classification: FEOL (Front End of Line) covers transistor formation; MOL (Middle of Line) covers local interconnects; BEOL (Back End of Line) covers metal interconnect layers. Used for WIP stage-gate reporting and cycle time decomposition.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeVersion rdf:type rdf:Property ;
    rdfs:label 'Route Version' ;
    rdfs:comment 'Version identifier of the process route assigned to this lot. Tracks which revision of the process flow was active at lot start, supporting process change impact analysis and PCN (Product Change Notification) traceability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapWaferCount rdf:type rdf:Property ;
    rdfs:label 'Scrap Wafer Count' ;
    rdfs:comment 'Cumulative number of wafers scrapped from this lot since lot creation. Includes wafers scrapped due to process excursions, equipment failures, or quality dispositions. Used for yield loss analysis and DPPM (Defective Parts Per Million) reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the wafer lot is expected to complete all FAB process steps and be ready for wafer probe/test. Derived from the process flow cycle time and lot start date. Used for delivery commitment and capacity planning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the inventory valuation amount (e.g., USD, EUR, JPY, TWD). Required for multi-currency financial reporting and SOX compliance.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferCountCurrent rdf:type rdf:Property ;
    rdfs:label 'Wafer Count Current' ;
    rdfs:comment 'Current number of wafers remaining in the lot after accounting for any scrapped or split wafers during processing. Reflects real-time WIP inventory quantity for this lot.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferCountStart rdf:type rdf:Property ;
    rdfs:label 'Wafer Count Start' ;
    rdfs:comment 'Number of wafers in the lot at the time of lot creation (wafer start). Typically 25 wafers per FOUP/cassette for standard lots. Used as the baseline denominator for yield and scrap rate calculations. This is the QUANTITATIVE_RESULT / principal measured quantity for this WIP transaction.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Raw Material Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a raw material master record in the semiconductor inventory domain. Primary key for the raw_material product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Foreign key linking to supply.material_master. Business justification: Raw_material (physical inventory) must link to material_master (supply chain master data) to inherit procurement parameters, quality specifications, lead times, compliance attributes, and valuation ru' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:substanceInventoryId rdf:type rdf:Property ;
    rdfs:label 'Substance Inventory Id' ;
    rdfs:comment 'Foreign key linking to compliance.substance_inventory. Business justification: Raw materials must link to substance inventory for REACH SVHC tracking, RoHS compliance verification, conflict minerals reporting, and hazardous material safety data sheet management required by EU an' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubstanceInventory .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The primary unit of measure in which the raw material is stocked and consumed (e.g., EA for each wafer, KG for chemicals, L for liquids, M2 for photomasks). Corresponds to SAP MARA.MEINS (base unit of measure). [ENUM-REF-CANDIDATE: EA|KG|L|M2|M3|PC|SHT|BOX|DRUM|CYLINDER — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManaged rdf:type rdf:Property ;
    rdfs:label 'Batch Managed' ;
    rdfs:comment 'Indicates whether the raw material is managed at the batch/lot level in SAP inventory management. Batch management is mandatory for silicon wafers, photomasks, and shelf-life-controlled chemicals to enable full lot traceability from receipt through consumption. Corresponds to SAP MARA.XCHPF.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which the raw material is scheduled to be discontinued or reaches end-of-life (EOL). Triggers last-time-buy (LTB) procurement actions and product change notification (PCN) processes. Null if the material is not scheduled for discontinuation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixedLotQty rdf:type rdf:Property ;
    rdfs:label 'Fixed Lot Qty' ;
    rdfs:comment 'Fixed order quantity used when lot_size_type is \'fixed\'. Represents the standard purchase order quantity per replenishment cycle, often aligned with supplier minimum order quantities or packaging units. Corresponds to SAP MARC.BSTFE.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'GHS/UN hazard classification of the raw material for safe storage, handling, and transport. Drives storage location assignment, PPE requirements, and emergency response procedures. [ENUM-REF-CANDIDATE: non_hazardous|flammable|corrosive|toxic|oxidizer|pyrophoric|compressed_gas|carcinogen — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether incoming quality inspection (IQC) is mandatory upon goods receipt for this raw material. When true, received lots are placed in quality inspection stock in SAP QM before being released to unrestricted use. Corresponds to SAP MARC.QKZUL.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Planned procurement lead time in calendar days from purchase order placement to goods receipt. Used by SAP MRP for replenishment scheduling and safety stock calculations. Corresponds to SAP MARC.PLIFZ (planned delivery time).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeType rdf:type rdf:Property ;
    rdfs:label 'Lot Size Type' ;
    rdfs:comment 'SAP MRP lot-sizing procedure that determines how replenishment quantities are calculated. \'fixed\' orders a fixed quantity, \'lot_for_lot\' orders exact requirement, \'min_max\' uses min/max boundaries, \'periodic\' groups requirements by period. Corresponds to SAP MARC.DISMM.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Maximum allowable inventory quantity for the raw material, used to prevent overstocking of hazardous materials, shelf-life-limited chemicals, or high-cost items. Corresponds to SAP MARC.MABST (maximum stock level).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Min Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum number of days of remaining shelf life required at the time of goods receipt for the material to be accepted into inventory. Materials received with less than this remaining shelf life are rejected or placed in restricted use. Corresponds to SAP MARA.MHDLP.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movingAvgPrice rdf:type rdf:Property ;
    rdfs:label 'Moving Avg Price' ;
    rdfs:comment 'Current moving average price per base unit of measure, recalculated with each goods receipt based on actual purchase prices. Used for inventory valuation under the moving average price control method. Corresponds to SAP MBEW.VERPR.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceControlType rdf:type rdf:Property ;
    rdfs:label 'Price Control Type' ;
    rdfs:comment 'Determines the inventory valuation method for the material: \'standard\' uses a fixed standard price, \'moving_average\' recalculates price with each goods movement. Corresponds to SAP MBEW.VPRSV (price control indicator: S or V).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the standard price and moving average price fields (e.g., USD, EUR, JPY, TWD). Required for multi-currency financial reporting and SOX compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purityPct rdf:type rdf:Property ;
    rdfs:label 'Purity Pct' ;
    rdfs:comment 'Chemical purity of the raw material expressed as a percentage (e.g., 99.9999 for 6N-grade specialty gases, 99.99 for ultra-high-purity chemicals). Critical quality specification for process chemicals, specialty gases, and ALD precursors where trace contamination causes yield loss.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachSvhcFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Svhc Flag' ;
    rdfs:comment 'Indicates whether the raw material contains or is classified as a Substance of Very High Concern (SVHC) under the EU REACH Regulation. Triggers mandatory disclosure obligations when SVHC concentration exceeds 0.1% w/w in articles.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Inventory level at which a replenishment purchase requisition is automatically triggered in SAP MRP. When on-hand stock falls to or below this quantity, procurement is initiated to prevent production line stoppages. Corresponds to SAP MARC.MINBE (reorder point).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resistivityOhmCm rdf:type rdf:Property ;
    rdfs:label 'Resistivity Ohm Cm' ;
    rdfs:comment 'Electrical resistivity of the silicon wafer substrate in Ohm·cm, indicating doping concentration and conductivity type. Critical specification for FEOL process compatibility and device electrical performance. Null for non-wafer materials.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Minimum buffer stock quantity maintained to protect against supply disruptions, demand variability, and supplier lead time uncertainty. Represents the floor below which inventory should not fall under normal operating conditions. Corresponds to SAP MARC.EISBE (safety stock).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialized rdf:type rdf:Property ;
    rdfs:label 'Serialized' ;
    rdfs:comment 'Indicates whether individual units of the raw material are tracked by unique serial number. Applicable to high-value items such as photomasks and reticles where individual unit traceability is required for defect root cause analysis and reticle qualification tracking.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days the raw material can be stored from the date of manufacture or receipt before it is considered expired and must be quarantined or disposed of. Critical for photoresists, ALD precursors, and specialty chemicals with time-sensitive stability. Corresponds to SAP MARA.MHDRZ (shelf life in days).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Standard cost price per base unit of measure used for inventory valuation in SAP CO (Controlling) and FI (Financial Accounting). Used for WIP costing, variance analysis, and financial reporting. Corresponds to SAP MBEW.STPRS (standard price).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Categorical storage environment required for the raw material. Drives warehouse location assignment and storage area classification. Examples: cleanroom for bare silicon wafers, refrigerated for certain photoresists, nitrogen_purge for moisture-sensitive ALD precursors. [ENUM-REF-CANDIDATE: ambient|refrigerated|frozen|cleanroom|nitrogen_purge|dark_storage|fireproof_cabinet — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageHumidityMaxPct rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Max Pct' ;
    rdfs:comment 'Maximum allowable relative humidity percentage for storage of the raw material. Particularly critical for silicon wafers, photomasks, and hygroscopic chemicals where moisture exposure causes defects or degradation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temp Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for the raw material. Exceeding this threshold may degrade material quality, trigger safety hazards, or invalidate process qualification. Used for warehouse environmental compliance monitoring.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTempMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temp Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for the raw material. Used to configure environmental monitoring alerts in the warehouse management system and ensure compliance with material safety data sheet (SDS) requirements.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferType rdf:type rdf:Property ;
    rdfs:label 'Wafer Type' ;
    rdfs:comment 'Specifies the silicon wafer substrate type: bare_silicon (polished CZ), epitaxial (epi-layer deposited), soi (Silicon-on-Insulator), fz (Float Zone), or cz (Czochralski). Determines process compatibility and electrical characteristics. Null for non-wafer materials.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationRuleId rdf:type rdf:Property ;
    rdfs:label 'Configuration Rule Id' ;
    rdfs:comment 'Foreign key linking to product.configuration_rule. Business justification: Finished goods are configured instances (speed grade, voltage, package). Configuration tracking for order fulfillment, pricing, and product variant management requires this link.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConfigurationRule .

ind:conflictMineralsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Declaration Id' ;
    rdfs:comment 'Foreign key linking to compliance.conflict_minerals_declaration. Business justification: Finished products require conflict minerals declarations for SEC filing compliance, customer supply chain transparency requirements, and responsible sourcing audits. Mandatory for publicly-traded semi' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictMineralsDeclaration .

ind:aecQQualified rdf:type rdf:Property ;
    rdfs:label 'Aec Q Qualified' ;
    rdfs:comment 'Indicates whether the finished good has been qualified to AEC-Q100 (IC), AEC-Q101 (discrete), or AEC-Q200 (passive) automotive reliability standards. Required for automotive supply chain design-in.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binCode rdf:type rdf:Property ;
    rdfs:label 'Bin Code' ;
    rdfs:comment 'Test bin classification code assigned during wafer sort or final test indicating the performance and quality tier of the die/device. Bin codes map to specific product SKUs and determine commercial grade.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceMarking rdf:type rdf:Property ;
    rdfs:label 'Device Marking' ;
    rdfs:comment 'Alphanumeric marking laser-inscribed or printed on the physical package surface. Includes part number, speed grade, temperature grade, and manufacturer code. Used for traceability and counterfeit detection.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dppmTarget rdf:type rdf:Property ;
    rdfs:label 'Dppm Target' ;
    rdfs:comment 'Quality target expressed as Defective Parts Per Million (DPPM) for outgoing quality of this finished good. Used in customer quality agreements and SPC monitoring. Automotive-grade typically requires <10 DPPM.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eolDate rdf:type rdf:Property ;
    rdfs:label 'Eol Date' ;
    rdfs:comment 'Announced End of Life (EOL) date after which the finished good will no longer be manufactured or sold. Triggers Last Time Buy (LTB) notifications to customers per JEDEC JESD48 standard.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:htsCode rdf:type rdf:Property ;
    rdfs:label 'Hts Code' ;
    rdfs:comment 'Harmonized Tariff Schedule (HTS) classification code used for customs declaration, import/export duty determination, and trade statistics reporting. Follows the 10-digit US HTS format.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current inventory disposition status of the finished good lot. \'available\' indicates unrestricted stock; \'quarantine\' indicates pending quality review; \'reserved\' indicates allocated to an order; \'consignment\' indicates stock held at OSAT or customer site; \'hold\' indicates engineering or compliance hold.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Accounting method used to value this finished good inventory in the general ledger. \'standard\' = standard cost; \'moving_average\' = moving average price (MAP); \'fifo\' = First In First Out; \'lifo\' = Last In First Out.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kgdStatus rdf:type rdf:Property ;
    rdfs:label 'Kgd Status' ;
    rdfs:comment 'Indicates whether the die used in this finished good has been verified as a Known Good Die (KGD) through wafer-level testing prior to packaging. Critical for advanced packaging (CoWoS, InFO, chiplet) and high-reliability applications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotTraceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Code' ;
    rdfs:comment 'Unique lot or batch identifier linking the finished good back to the wafer fabrication lot, enabling full forward and backward traceability through the manufacturing supply chain. Aligns with Camstar MES lot number.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msdLevel rdf:type rdf:Property ;
    rdfs:label 'Msd Level' ;
    rdfs:comment 'Moisture Sensitivity Level (MSL) classification per IPC/JEDEC J-STD-020 indicating the device\'s sensitivity to ambient moisture during storage and handling. Level 1 = unlimited floor life; Level 6 = must be baked immediately before use. [ENUM-REF-CANDIDATE: 1|2|2a|3|4|5|5a|6 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageBodySizeMm rdf:type rdf:Property ;
    rdfs:label 'Package Body Size Mm' ;
    rdfs:comment 'Physical body dimensions of the semiconductor package expressed as length x width in millimeters (e.g., \'10x10\', \'5.5x5.5\'). Used for PCB design, handling equipment setup, and storage tray selection.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinCount rdf:type rdf:Property ;
    rdfs:label 'Pin Count' ;
    rdfs:comment 'Total number of electrical pins, balls, or leads on the finished good package. Critical for PCB design compatibility, socket selection, and ATE (Automatic Test Equipment) configuration.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical inventory quantity of this finished good in units (individual packaged devices). Reflects unrestricted stock available for order fulfillment as tracked in SAP MM inventory management.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiry Date' ;
    rdfs:comment 'Calculated date on which the shelf life of this finished good lot expires, derived from the manufacturing date code plus shelf life days. Triggers re-bake or scrap workflow in SAP MM.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard cost per unit of the finished good in the functional currency as maintained in SAP CO (Controlling) for inventory valuation, cost of goods sold calculation, and variance analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for this finished good. Exceeding this threshold may degrade device reliability or void qualification. Used to configure warehouse environmental monitoring alerts.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryDieStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Die Storage Location Id' ;
    rdfs:comment 'Reference to the physical storage location (warehouse bin, cold storage unit, or OSAT vault) where the die bank is currently stored. Managed in SAP WM/EWM.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:probeCardId rdf:type rdf:Property ;
    rdfs:label 'Probe Card Id' ;
    rdfs:comment 'Identifier of the probe card used during wafer sort for the parent wafer lot. Enables correlation of test results to probe card condition and supports yield excursion root cause analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProbeCard .

ind:waferId rdf:type rdf:Property ;
    rdfs:label 'Wafer Id' ;
    rdfs:comment 'Foreign key linking to fabrication.wafer. Business justification: KGD (Known Good Die) traceability requires linking die inventory back to the specific source wafer for failure analysis, IATF 16949 lot genealogy, and customer quality reports. A semiconductor domain ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wafer .

ind:binClass rdf:type rdf:Property ;
    rdfs:label 'Bin Class' ;
    rdfs:comment 'FK to inventory.bin_classification.bin_classification_id — Every die bank entry is classified by bin (speed grade, power class, pass/fail). This FK drives KGD allocation and customer shipment decisions.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binClassification rdf:type rdf:Property ;
    rdfs:label 'Bin Classification' ;
    rdfs:comment 'Electrical test bin classification assigned during wafer probe/sort (e.g., Bin1=Full-speed pass, Bin2=Speed-binned, Bin3=Partial-function, Bin99=Fail). Determines product grade, pricing tier, and eligible end markets. [ENUM-REF-CANDIDATE: bin1|bin2|bin3|bin4|bin5|bin6|bin99|scrap — promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Physical carrier medium in which the singulated dies are stored (e.g., waffle pack, gel pack, tape-and-reel, JEDEC tray). Determines handling requirements, automated pick-and-place compatibility, and storage density.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieBankCode rdf:type rdf:Property ;
    rdfs:label 'Die Bank Code' ;
    rdfs:comment 'Human-readable, externally-known unique business identifier for the die bank lot, used in MES, ERP, and OSAT partner communications. Follows internal lot numbering conventions.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieBankStatus rdf:type rdf:Property ;
    rdfs:label 'Die Bank Status' ;
    rdfs:comment 'Current lifecycle status of the die bank inventory record. \'Available\' indicates dies are ready for allocation; \'Reserved\' indicates committed to an order; \'Consumed\' indicates fully used in packaging; \'Quarantined\' indicates hold pending quality investigation; \'Scrapped\' indicates disposed; \'Expired\' indicates shelf life exceeded.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieStorageLocationFk rdf:type rdf:Property ;
    rdfs:label 'Die Storage Location Fk' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Die banks are stored at specific locations (cleanroom storage, cold storage). Location tracking is critical for environmental compliance and retrieval.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esdSensitivityClass rdf:type rdf:Property ;
    rdfs:label 'Esd Sensitivity Class' ;
    rdfs:comment 'JEDEC Human Body Model (HBM) or Charged Device Model (CDM) ESD sensitivity classification for the dies. Determines handling precautions, packaging requirements, and ESD-protected area (EPA) storage mandates.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsignment rdf:type rdf:Property ;
    rdfs:label 'Is Consignment' ;
    rdfs:comment 'Indicates whether this die bank is held as consignment stock at an OSAT partner or customer site (True) versus owned and stored at an internal facility (False). Affects inventory ownership, liability, and financial reporting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEngineeringSample rdf:type rdf:Property ;
    rdfs:label 'Is Engineering Sample' ;
    rdfs:comment 'Indicates whether the dies in this bank are engineering samples (True) or production-qualified silicon (False). Engineering samples may have restricted use, limited warranty, and different pricing terms.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent physical or visual inspection of the die bank, including carrier integrity check, quantity verification, and storage condition audit. Required for periodic quality surveillance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotOrigin rdf:type rdf:Property ;
    rdfs:label 'Lot Origin' ;
    rdfs:comment 'FK to inventory.wafer_lot.wafer_lot_id — Die banks trace back to their source wafer lot for genealogy and quality traceability. Critical for IATF 16949.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldReason rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Reason' ;
    rdfs:comment 'Free-text or coded reason for placing this die bank on quality hold or quarantine status. Populated when die_bank_status is \'quarantined\'. Examples: parametric excursion, contamination event, ESD damage suspected.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Current count of dies available for allocation or shipment in this die bank record. Decremented upon reservation or consumption. Expressed in units of individual dies.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityInitial rdf:type rdf:Property ;
    rdfs:label 'Quantity Initial' ;
    rdfs:comment 'Original count of dies placed into this die bank at the time of creation, before any consumption, scrap, or reservation. Used as the baseline for yield and consumption tracking.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Count of dies in this die bank that are currently reserved against open orders or packaging work orders but not yet physically consumed. Supports ATP (Available-to-Promise) calculations.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityScrapped rdf:type rdf:Property ;
    rdfs:label 'Quantity Scrapped' ;
    rdfs:comment 'Cumulative count of dies from this die bank that have been scrapped due to handling damage, quality failures, or shelf life expiry. Used for loss tracking and yield analysis.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this die bank. Violations may cause electrostatic or material degradation. Enforced by warehouse management system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testProgramVersion rdf:type rdf:Property ;
    rdfs:label 'Test Program Version' ;
    rdfs:comment 'Version identifier of the ATE (Automatic Test Equipment) test program used during wafer probe/sort to classify and bin the dies in this die bank. Critical for test traceability and re-test qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard or moving average cost per individual die in the die bank, expressed in the functional currency. Used for inventory valuation, cost of goods sold, and transfer pricing to OSAT partners.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferProbeYieldPct rdf:type rdf:Property ;
    rdfs:label 'Wafer Probe Yield Pct' ;
    rdfs:comment 'Electrical test yield percentage from wafer probe/sort for the parent wafer lot, representing the fraction of dies that passed all probe tests. Expressed as a decimal percentage (e.g., 92.5000). Used for cost modeling and quality benchmarking.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Business date on which this die bank record was created, representing when the singulated dies were formally received into die bank inventory following wafer dicing and initial inspection.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:photomaskAssetId rdf:type rdf:Property ;
    rdfs:label 'Photomask Asset Id' ;
    rdfs:comment 'Primary key for photomask_asset' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maskSetId rdf:type rdf:Property ;
    rdfs:label 'Mask Set Id' ;
    rdfs:comment 'Foreign key linking to fabrication.mask_set. Business justification: photomask_asset is the physical inventory record of a reticle; mask_set is the engineering definition. Linking them enables mask set utilization tracking, reticle lifecycle management, and fab schedul' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaskSet .

ind:photomaskId rdf:type rdf:Property ;
    rdfs:label 'Photomask Id' ;
    rdfs:comment 'Externally-known unique identifier assigned to the photomask by the mask vendor or internal mask management system. Used for cross-system traceability and vendor communication.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Photomask .

ind:primaryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — High-value photomasks must track their storage location for retrieval and environmental control.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:assetValuationUsd rdf:type rdf:Property ;
    rdfs:label 'Asset Valuation Usd' ;
    rdfs:comment 'Financial book value of the photomask asset in US dollars as recorded in the fixed asset or inventory valuation module. EUV masks can cost $500K–$1M+; DUV masks range from $10K–$100K. Used for inventory valuation, depreciation, and insurance purposes.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdUniformityNm rdf:type rdf:Property ;
    rdfs:label 'Cd Uniformity Nm' ;
    rdfs:comment 'Measured critical dimension (CD) uniformity across the mask in nanometers, as determined during mask inspection. A key quality metric indicating pattern fidelity; tighter CD uniformity is required at advanced nodes.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects detected on the photomask surface during the most recent inspection cycle. Compared against the maximum allowable defect specification to determine pass/fail disposition. Tracked per KLA ICOS inspection records.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Result of the most recent mask inspection performed by metrology equipment (e.g., KLA ICOS). Indicates whether the mask meets defect density and CD uniformity specifications for continued production use.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMpwMask rdf:type rdf:Property ;
    rdfs:label 'Is Mpw Mask' ;
    rdfs:comment 'Indicates whether this photomask was manufactured as part of a Multi-Project Wafer (MPW) shuttle run, where multiple designs share a single mask set to reduce NRE costs. MPW masks have shared ownership and usage constraints.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:layerName rdf:type rdf:Property ;
    rdfs:label 'Layer Name' ;
    rdfs:comment 'Name of the photolithography process layer this mask patterns (e.g., POLY, METAL1, VIA2, DIFFUSION). Identifies the specific fabrication step in the FEOL/MOL/BEOL stack.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date on which the photomask was manufactured and released by the mask vendor. Used for age-based shelf life tracking and vendor lead time analysis.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maskGeneration rdf:type rdf:Property ;
    rdfs:label 'Mask Generation' ;
    rdfs:comment 'Version or generation identifier of the mask corresponding to the tapeout revision (e.g., v1.0, v2.1, ECO_rev3). Tracks which design tapeout iteration this mask was manufactured from, enabling traceability to the GDS/GDSII submission.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskSizeMm rdf:type rdf:Property ;
    rdfs:label 'Mask Size Mm' ;
    rdfs:comment 'Physical size of the photomask substrate in millimeters (e.g., 152mm for standard 6-inch reticle). Determines compatibility with the lithography scanner chuck and handling equipment.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maskStatus rdf:type rdf:Property ;
    rdfs:label 'Mask Status' ;
    rdfs:comment 'Current lifecycle status of the photomask asset. Active masks are available for production use; quarantined masks are held pending defect review; retired masks have exceeded usage limits or been superseded; scrapped masks have been physically destroyed. [ENUM-REF-CANDIDATE: active|quarantined|retired|in_inspection|pending_qualification|scrapped — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskSubstrateMaterial rdf:type rdf:Property ;
    rdfs:label 'Mask Substrate Material' ;
    rdfs:comment 'Material of the photomask substrate. Fused silica and quartz are standard for DUV masks; Low Thermal Expansion Material (LTEM) and Ultra-Low Expansion (ULE) glass are used for EUV masks to minimize thermal distortion.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskType rdf:type rdf:Property ;
    rdfs:label 'Mask Type' ;
    rdfs:comment 'Physical mask type classification: binary (chrome-on-glass), attenuated phase-shifting mask (attPSM), alternating phase-shifting mask (altPSM), chromeless phase lithography (CPL), or EUV reflective mask. Determines optical proximity correction (OPC) strategy and imaging performance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDefectLimit rdf:type rdf:Property ;
    rdfs:label 'Max Defect Limit' ;
    rdfs:comment 'Specification-defined maximum number of defects permitted on the photomask before it must be quarantined or retired. Established during mask qualification per process node requirements.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxUsageLimit rdf:type rdf:Property ;
    rdfs:label 'Max Usage Limit' ;
    rdfs:comment 'Manufacturer- or process-qualified maximum number of exposure shots allowed before mandatory retirement or re-qualification of the photomask. Exceeding this limit triggers automatic quarantine in the MES.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meefValue rdf:type rdf:Property ;
    rdfs:label 'Meef Value' ;
    rdfs:comment 'Mask Error Enhancement Factor (MEEF) quantifying how mask CD (critical dimension) errors are amplified onto the wafer. A MEEF > 1 indicates that mask errors are magnified; used in process window analysis and mask specification setting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date by which the next mandatory mask inspection must be completed, based on usage count thresholds or calendar-based inspection intervals defined in the mask management plan.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opcVersion rdf:type rdf:Property ;
    rdfs:label 'Opc Version' ;
    rdfs:comment 'Version identifier of the Optical Proximity Correction (OPC) recipe applied during mask data preparation. OPC compensates for diffraction effects in photolithography; version tracking ensures reproducibility and supports yield analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pelliclePresent rdf:type rdf:Property ;
    rdfs:label 'Pellicle Present' ;
    rdfs:comment 'Indicates whether a protective pellicle membrane is currently mounted on the photomask. Pellicles protect the mask pattern from particle contamination during exposure. EUV masks use specialized EUV-transparent pellicles.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pellicleType rdf:type rdf:Property ;
    rdfs:label 'Pellicle Type' ;
    rdfs:comment 'Type of pellicle membrane mounted on the photomask. Standard pellicles are used for DUV masks; EUV pellicles are specialized thin-film membranes for EUV lithography. None indicates no pellicle is installed.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationErrorNm rdf:type rdf:Property ;
    rdfs:label 'Registration Error Nm' ;
    rdfs:comment 'Measured overlay registration error of the mask pattern in nanometers, indicating how accurately the mask features are positioned relative to the design intent. Critical for multi-layer overlay budget management.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reticlePodCode rdf:type rdf:Property ;
    rdfs:label 'Reticle Pod Code' ;
    rdfs:comment 'Identifier of the Reticle Storage Pod (RSP) or reticle SMIF pod in which this photomask is currently housed. RSP tracking is critical for contamination prevention and automated mask library management.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date on which the photomask was retired from production use, either due to exceeding usage limits, excessive defect count, design obsolescence, or end-of-life (EOL) of the associated product. Nullable for active masks.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scannerModel rdf:type rdf:Property ;
    rdfs:label 'Scanner Model' ;
    rdfs:comment 'Model identifier of the lithography scanner (stepper/scanner) for which this photomask is qualified (e.g., ASML NXT:2000i, ASML NXE:3600D). Masks are qualified to specific scanner models due to optical system compatibility.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Pct' ;
    rdfs:comment 'Required relative humidity percentage for photomask storage environment. Controlled humidity prevents electrostatic discharge damage and contamination on the mask substrate.' ;
    rdfs:domain ind:PhotomaskAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature C' ;
    rdfs:comment 'Required storage temperature in degrees Celsius for this photomask. EUV masks and phase-shifting masks may have tighter temperature requirements to prevent pellicle degradation or substrate stress.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Cumulative number of wafer exposure shots (uses) this photomask has undergone since manufacture or last qualification. Tracked by the MES to manage mask wear and schedule preventive inspection.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Physical access control level for this storage location. unrestricted — open access; badge-access — requires valid facility badge; authorized-personnel — restricted to named personnel list (e.g., for ITAR-controlled materials); security-vault — highest security for KGD die banks, photomask vaults, and ITAR-controlled IP. Supports ITAR/EAR export control compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bay rdf:type rdf:Property ;
    rdfs:label 'Bay' ;
    rdfs:comment 'Bay designation within the building or cleanroom where this storage location is physically situated (e.g., \'BAY-03\', \'A-WEST\'). Used for precise physical navigation, equipment layout planning, and cleanroom zone management per SEMI E187.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Identifier for the physical building within the facility where this storage location resides (e.g., \'FAB1\', \'CHEM-WH-B\', \'OSAT-PKG-C\'). Supports facility layout mapping, emergency response planning, and environmental zone management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure used to express the maximum capacity and current utilization of this storage location. Varies by facility type: cassette (wafer storage), pod (photomask storage), tray (packaged chip storage), container (chemical storage), box (die bank storage), pallet (bulk warehouse storage).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanroomIsoClass rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Iso Class' ;
    rdfs:comment 'ISO 14644-1 cleanroom classification for this storage location, defining the maximum allowable airborne particulate concentration. Critical for wafer, photomask, and KGD die storage compliance. Applicable only to cleanroom facility types; null for non-cleanroom locations. Values: ISO-1 (cleanest) through ISO-6.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date on which this storage location was formally commissioned and made available for inventory use. Marks the start of the location\'s operational lifecycle. Used for asset age tracking, depreciation scheduling, and facility capacity planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the country where this storage location is physically situated (e.g., \'USA\', \'TWN\', \'KOR\', \'JPN\'). Critical for ITAR/EAR export control jurisdiction determination, REACH/RoHS regulatory applicability, and multi-national inventory reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentUtilizationUnits rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Units' ;
    rdfs:comment 'Current number of inventory units occupying this storage location at the time of last inventory update. Compared against max_capacity_units to compute utilization percentage for capacity planning and inventory placement decisions. Updated by MES and SAP MM inventory movements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date on which this storage location was permanently decommissioned and removed from active inventory use. Populated only when location_status is \'decommissioned\'. Supports facility lifecycle management and historical inventory traceability.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esdProtectionClass rdf:type rdf:Property ;
    rdfs:label 'Esd Protection Class' ;
    rdfs:comment 'ESD protection classification of this storage location per ANSI/ESD S20.20 and JEDEC JESD625 standards. Determines suitability for storing ESD-sensitive devices (ICs, dies, packaged chips). class-0 (most sensitive, <250V HBM) through class-3 (>2000V HBM); unprotected for non-ESD-controlled areas.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the physical facility type housing this storage location. Drives environmental compliance rules, MSD floor life management, and hazmat handling procedures. Valid values: cleanroom (ISO-classified FAB area), warehouse (general materials storage), cold-storage (temperature-controlled for chemicals/biologics), gas-cabinet (pressurized specialty gas storage), nitrogen-cabinet (nitrogen-purged dry storage for moisture-sensitive devices), die-vault (secure KGD die bank storage).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Type' ;
    rdfs:comment 'Type of fire suppression system installed at this storage location. Critical for chemical warehouse and gas cabinet locations storing flammable or reactive materials. Drives emergency response planning and insurance compliance. Values: sprinkler, halon (legacy), fm200 (clean agent), co2, dry-powder, none.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoLatitude rdf:type rdf:Property ;
    rdfs:label 'Geo Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84 decimal degrees) of the facility where this storage location resides. Used for multi-site supply chain mapping, emergency response planning, and regulatory jurisdiction determination for ITAR/EAR export control compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoLongitude rdf:type rdf:Property ;
    rdfs:label 'Geo Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84 decimal degrees) of the facility where this storage location resides. Used in conjunction with geo_latitude for multi-site supply chain mapping and regulatory jurisdiction determination.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'UN/DOT hazardous materials classification code applicable to materials stored at this location (e.g., \'UN1170\' for ethanol, \'UN2014\' for hydrogen peroxide, \'FLAMMABLE-LIQUID\', \'CORROSIVE\', \'COMPRESSED-GAS\', \'NON-HAZMAT\'). Governs storage segregation, emergency response, and regulatory reporting under REACH, RoHS, and TSCA. [ENUM-REF-CANDIDATE: flammable-liquid|corrosive|compressed-gas|oxidizer|toxic|non-hazmat|pyrophoric — promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOsatPartnerLocation rdf:type rdf:Property ;
    rdfs:label 'Is Osat Partner Location' ;
    rdfs:comment 'Indicates whether this storage location is physically situated at an OSAT (Outsourced Semiconductor Assembly and Test) partner facility rather than an internal company site. True for consignment stock locations at OSAT partners. Drives consignment inventory valuation, ownership tracking, and inter-company transfer accounting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kgdStorageCertified rdf:type rdf:Property ;
    rdfs:label 'Kgd Storage Certified' ;
    rdfs:comment 'Indicates whether this storage location is certified for KGD (Known Good Die) die bank storage, meeting requirements for ESD protection, nitrogen purge, temperature/humidity control, and access security. KGD storage certification is required for high-value tested dies awaiting packaging or shipment.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the storage location, aligned with SAP S/4HANA MM storage location key (LGORT) and Camstar MES location identifiers. Used for lot traceability, WIP tracking, and inventory placement across FAB, warehouse, and OSAT partner facilities.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable descriptive name of the storage location (e.g., \'Bay 3 Shelf 12 — EUV Photomask Vault\', \'Cleanroom A Chemical Cabinet Row 5\'). Used in operational reports, MES screens, and inventory placement instructions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational lifecycle status of the storage location. \'active\' — available for inventory placement; \'blocked\' — temporarily unavailable due to maintenance, contamination, or audit hold; \'decommissioned\' — permanently retired from use. Controls whether new inventory can be assigned to this location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Max Capacity Units' ;
    rdfs:comment 'Maximum number of inventory units (wafer cassettes, chemical containers, photomask pods, chip trays, or die boxes) that can be physically stored at this location. Used for capacity planning, inventory placement optimization, and utilization reporting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Max Humidity Pct' ;
    rdfs:comment 'Maximum allowable relative humidity percentage (0–100%) for this storage location. Exceedance above maximum triggers MSD floor life reset, inventory quarantine, and environmental non-conformance reporting per IPC/JEDEC J-STD-033.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for this location. Defines the upper bound of the acceptable temperature range. Exceedance triggers inventory quarantine and environmental non-conformance reporting per ISO 14001 and SEMI C10 chemical storage guidelines.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Min Humidity Pct' ;
    rdfs:comment 'Minimum allowable relative humidity percentage (0–100%) for this storage location. Critical for MSD floor life management, photomask storage, and chemical stability. Exceedance below minimum may cause ESD risk or material degradation.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this location. Defines the lower bound of the acceptable temperature range for stored materials (chemicals, photoresists, gases, packaged devices). Used for environmental compliance monitoring and MSD (Moisture Sensitive Device) floor life management per IPC/JEDEC J-STD-033.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msdFloorLifeCapable rdf:type rdf:Property ;
    rdfs:label 'Msd Floor Life Capable' ;
    rdfs:comment 'Indicates whether this storage location is equipped and certified to manage MSD floor life tracking per IPC/JEDEC J-STD-033. True for nitrogen-purged cabinets, dry-storage cabinets, and controlled-humidity cleanroom locations. Enables automatic floor life clock suspension for stored MSDs.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msdSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Msd Sensitivity Level' ;
    rdfs:comment 'Maximum Moisture Sensitivity Level (MSL) of devices that can be safely stored at this location per IPC/JEDEC J-STD-020. MSL-1 (unlimited floor life at ≤30°C/85%RH) through MSL-5 (most sensitive, 24-hour floor life). Determines which packaged semiconductor devices are eligible for placement at this location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nitrogenPurgeCapable rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Purge Capable' ;
    rdfs:comment 'Indicates whether this storage location is equipped with nitrogen purge capability to maintain an inert, moisture-free atmosphere. True for nitrogen-cabinet and die-vault locations used for long-term KGD die storage, photomask preservation, and moisture-sensitive chemical storage. Drives MSD floor life management decisions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osatPartnerName rdf:type rdf:Property ;
    rdfs:label 'Osat Partner Name' ;
    rdfs:comment 'Name of the OSAT partner company at whose facility this storage location resides (e.g., \'ASE Group\', \'Amkor Technology\', \'JCET\'). Populated only when is_osat_partner_location is True. Used for consignment stock management, partner performance reporting, and supply chain visibility.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photomaskStorageCapable rdf:type rdf:Property ;
    rdfs:label 'Photomask Storage Capable' ;
    rdfs:comment 'Indicates whether this storage location meets the environmental and cleanliness requirements for photomask (reticle) storage, including ISO cleanroom class, nitrogen purge, and ESD protection. Photomasks are high-value assets used in EUV/DUV lithography and require specialized storage conditions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP S/4HANA plant identifier to which this storage location belongs. Represents the manufacturing or distribution facility (FAB, OSAT partner site, or warehouse) in the enterprise organizational hierarchy. Enables multi-plant inventory management and inter-plant transfer tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:row rdf:type rdf:Property ;
    rdfs:label 'Row' ;
    rdfs:comment 'Row designation within the bay for this storage location (e.g., \'R-12\', \'ROW-A\'). Provides granular physical addressing for inventory placement, pick-and-put-away operations, and automated storage/retrieval system (ASRS) integration.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelf rdf:type rdf:Property ;
    rdfs:label 'Shelf' ;
    rdfs:comment 'Shelf or bin designation within the row for this storage location (e.g., \'S-04\', \'BIN-002\'). Lowest level of the physical location hierarchy, enabling precise inventory placement and retrieval for wafer cassettes, chemical containers, photomasks, and packaged chip trays.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Tracking Enabled' ;
    rdfs:comment 'Indicates whether shelf life expiry tracking is enabled for materials stored at this location. True for chemical storage, photoresist storage, and gas cabinet locations where materials have defined shelf lives. Enables automated expiry alerts and FEFO (First Expired First Out) inventory management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum allowable total weight in kilograms for materials stored at this location. Critical for shelf structural integrity compliance, particularly for heavy chemical drums, gas cylinders, and bulk wafer cassette storage. Enforced per facility safety standards.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipStagingArea rdf:type rdf:Property ;
    rdfs:label 'Wip Staging Area' ;
    rdfs:comment 'Indicates whether this storage location is designated as a WIP (Work in Process) staging area for wafer lots between process steps. True for inter-bay buffers, equipment load ports, and process queue areas within the FAB cleanroom. Enables WIP flow tracking and cycle time analysis in the MES.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockBalanceId rdf:type rdf:Property ;
    rdfs:label 'Stock Balance Id' ;
    rdfs:comment 'Unique surrogate identifier for each stock balance snapshot record in the inventory management system. Primary key for the stock_balance data product.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStockMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Material Master Id' ;
    rdfs:comment 'Reference to the material master record representing the specific semiconductor material, component, or product (e.g., silicon wafer, photomask, packaged IC, chemical) for which this stock balance is recorded.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryStockRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Raw Material Id' ;
    rdfs:comment 'Foreign key linking to inventory.raw_material. Business justification: raw_material is a master for raw materials; linking stock_balance to raw_material via raw_material_id replaces generic material_master references and enables direct lookup of raw material attributes.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:primaryStockStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Storage Location Id' ;
    rdfs:comment 'Reference to the physical or logical storage location (e.g., FAB cleanroom bay, chemical storage vault, finished goods warehouse, OSAT consignment location) where this inventory is held.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_order. Business justification: INVENTORY RECEIPT: Stock balance must be tied to the PO that supplied the material for traceability and financial reconciliation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:stockRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Stock Raw Material Id' ;
    rdfs:comment 'FK to inventory.raw_material.raw_material_id — Stock balance for raw materials must reference the raw_material master record. This is the core master-transaction relationship for material inventory visibility.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:batchClassification rdf:type rdf:Property ;
    rdfs:label 'Batch Classification' ;
    rdfs:comment 'Quality grade classification of the wafer or material batch. \'prime\' = meets all specifications for production; \'test\' = test wafers used for process qualification; \'engineering\' = engineering samples not for production; \'monitor\' = process monitor wafers; \'reject\' = failed quality inspection and not usable.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Consignment Partner Code' ;
    rdfs:comment 'Identifier of the Outsourced Semiconductor Assembly and Test (OSAT) partner or external consignee at whose facility this consignment stock is physically held. Populated only for stock_type = \'consignment\'. Used for consignment reconciliation and OSAT partner performance tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Issue Date' ;
    rdfs:comment 'Date of the most recent goods issue (GI) posting for this material from this storage location. Used to identify dormant inventory, assess consumption velocity, and support slow-moving inventory analysis.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt (GR) posting for this material at this storage location. Used to calculate stock aging, assess replenishment lead times, and support FIFO/FEFO inventory consumption sequencing.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count performed for this material at this storage location. Used to assess inventory accuracy, schedule next count, and support SOX financial reporting requirements for inventory valuation.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qtyAvailable rdf:type rdf:Property ;
    rdfs:label 'Qty Available' ;
    rdfs:comment 'Quantity of unrestricted stock that is not committed to any open reservation or production order. Represents the net available quantity for Available-to-Promise (ATP) calculations and new production planning decisions. Computed as unrestricted stock minus open reservations.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyBlocked rdf:type rdf:Property ;
    rdfs:label 'Qty Blocked' ;
    rdfs:comment 'Quantity of material placed in blocked stock due to quality rejection, ITAR/EAR export control restrictions, supplier non-conformance, or regulatory hold. Blocked stock is not available for production or shipment until formally released.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyInTransit rdf:type rdf:Property ;
    rdfs:label 'Qty In Transit' ;
    rdfs:comment 'Quantity of material that has been shipped from a source location but has not yet been received at the destination location. Includes inter-plant transfers, OSAT shipments, and inbound supplier deliveries in transit.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyInWip rdf:type rdf:Property ;
    rdfs:label 'Qty In Wip' ;
    rdfs:comment 'Quantity of material currently consumed into active production orders and undergoing fabrication processing (e.g., wafer lots in FEOL/BEOL processing, die in packaging). Tracked by the MES and reflected in SAP PP WIP accounts.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyOnHand rdf:type rdf:Property ;
    rdfs:label 'Qty On Hand' ;
    rdfs:comment 'Total physical quantity of the material present at the storage location across all stock types, expressed in the base unit of measure. Represents the gross inventory position before reservations or quality holds are considered.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyQualityInspection rdf:type rdf:Property ;
    rdfs:label 'Qty Quality Inspection' ;
    rdfs:comment 'Quantity of material currently held in SAP QM quality inspection stock, pending disposition decision (accept, reject, rework). Includes incoming inspection lots, in-process inspection holds, and post-process quality holds.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyReserved rdf:type rdf:Property ;
    rdfs:label 'Qty Reserved' ;
    rdfs:comment 'Total quantity committed to active inventory reservations linked to open production orders, sales orders, or transfer orders. Corresponds to open inventory_reservation records and reduces the available quantity for new demand.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slowMovingFlag rdf:type rdf:Property ;
    rdfs:label 'Slow Moving Flag' ;
    rdfs:comment 'Indicates whether this stock balance has been flagged as slow-moving (True) based on the stock_aging_days exceeding the material-specific slow-moving threshold. Used for inventory write-down risk assessment, EOL (End of Life) planning, and LTB (Last Time Buy) decision support.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The principal business event timestamp indicating when this stock balance snapshot was captured from the source system (SAP MM or MES). Represents the point-in-time inventory position and is the primary temporal key for real-time inventory visibility and ATP calculations.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'SAP special stock indicator identifying non-standard stock ownership or custody arrangements. \'E\' = sales order stock; \'K\' = consignment stock at customer; \'Q\' = project stock; \'W\' = consignment stock from vendor; \'O\' = stock at subcontractor (OSAT). Empty value indicates standard own stock.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockAgingDays rdf:type rdf:Property ;
    rdfs:label 'Stock Aging Days' ;
    rdfs:comment 'Number of days the current on-hand stock has been held at this storage location since the oldest receipt date. Used for slow-moving inventory identification, shelf-life monitoring, and obsolescence risk assessment. Critical for chemicals, gases, and photoresists with defined shelf lives.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockStorageLocationFk rdf:type rdf:Property ;
    rdfs:label 'Stock Storage Location Fk' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Stock balance is always held AT a specific storage location. This is a fundamental dimension of inventory position — you cannot have a meaningful stock balance without knowing WHERE the stock is. Day-' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'SAP stock category indicating the usability status of the inventory. \'unrestricted\' is available for production or shipment; \'quality_inspection\' is under QM hold pending disposition; \'blocked\' is rejected or quarantined; \'consignment\' is held at OSAT partner sites; \'restricted\' is subject to export control or ITAR/EAR restrictions.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Code' ;
    rdfs:comment 'Required storage environment classification for this material. Drives warehouse management system (WMS) slotting and compliance with SEMI, REACH, and OSHA storage requirements. \'nitrogen_purge\' for moisture-sensitive devices (MSD); \'cold_storage\' for temperature-sensitive chemicals; \'cleanroom_class1/10\' for wafers and photomasks; \'hazmat\' for regulated chemicals.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unrestrictedUseFlag rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Use Flag' ;
    rdfs:comment 'Indicates whether this stock balance record represents inventory that is fully available for unrestricted use in production or shipment (True), or whether it is subject to any hold, restriction, or quality disposition (False). Derived from stock_type but maintained as an explicit flag for rapid ATP query performance.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'SAP valuation class code that determines the general ledger (GL) accounts to which inventory postings are made for this material. Links inventory movements to the correct balance sheet accounts for financial reporting. Detailed financial valuation fields are maintained in the stock_valuation data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferProcessNode rdf:type rdf:Property ;
    rdfs:label 'Wafer Process Node' ;
    rdfs:comment 'The semiconductor process technology node at which the wafer lot or die was fabricated (e.g., \'7nm\', \'14nm\', \'28nm\', \'180nm\'). Critical for inventory segregation, process compatibility checks, and customer design-in alignment.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementId rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Id' ;
    rdfs:comment 'Unique identifier for the goods movement transaction. Primary key for the goods movement record.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exportLicenseUsageId rdf:type rdf:Property ;
    rdfs:label 'Export License Usage Id' ;
    rdfs:comment 'Foreign key linking to compliance.export_license_usage. Business justification: Each goods movement (shipment) must record the specific export license usage to satisfy license utilization reporting and audit trails.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExportLicenseUsage .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to supply.goods_receipt. Business justification: Goods movements receiving material from suppliers must reference the originating goods_receipt to maintain full ERP traceability from PO→GR→goods movement→stock balance. Standard material flow in semi' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry_line. Business justification: Goods movements generate journal entry lines for inventory accounting postings - direct operational link for goods receipt, issue, and transfer transactions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntryLine .

ind:primaryGoodsMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Material Master Id' ;
    rdfs:comment 'Identifier of the material being moved. References the material master record for silicon wafers, chemicals, gases, photomasks, packaged chips, or die banks.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryGoodsStockBalanceId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Stock Balance Id' ;
    rdfs:comment 'FK to inventory.stock_balance.stock_balance_id — Every goods movement posting updates the stock balance. This is the fundamental inventory equation: stock_balance = sum(goods_movements). Critical for reconciliation and audit.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockBalance .

ind:primaryGoodsStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Every goods movement must reference source location for audit trail and inventory reconciliation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:sourceStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Every goods movement has a source location (for issues, transfers) or destination location (for receipts). Location reference is mandatory for movement posting and audit trail.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Batch or lot number for batch-managed materials such as chemicals, gases, or raw wafers. Distinct from wafer lot number; used for supplier batch traceability and shelf-life management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Delivery note or packing slip number from the supplier or shipping carrier. Used for goods receipt matching and three-way match (PO, goods receipt, invoice) reconciliation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPlantCode rdf:type rdf:Property ;
    rdfs:label 'Destination Plant Code' ;
    rdfs:comment 'Plant or FAB site code where the material was moved to. Used for inter-plant transfers and multi-site inventory tracking. Critical for global supply chain visibility.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location' ;
    rdfs:comment 'Storage location code where the material was moved to. Represents warehouse, stockroom, or FAB storage area. Empty for goods issues to external customers or scrap.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLineItem rdf:type rdf:Property ;
    rdfs:label 'Document Line Item' ;
    rdfs:comment 'Line item number within the material document. Supports multi-line goods movement documents where multiple materials or lots are moved in a single transaction.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Unique material document number generated by the ERP system for this goods movement. Primary business identifier for the transaction, used for audit trail and reversal references.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementDate rdf:type rdf:Property ;
    rdfs:label 'Movement Date' ;
    rdfs:comment 'Date when the physical goods movement occurred. Business event date for inventory transaction, distinct from posting date. Critical for SOX Section 404 audit trail and inventory valuation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the inventory movement transaction: goods receipt from supplier, goods issue to production, inter-location transfer, scrap disposal, return from production, or posting reversal. Aligns with SAP MM movement type codes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Date when the goods movement was posted to the financial ledger. Used for period-end closing and financial reporting. May differ from movement date for backdated or delayed postings.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'Production order number for goods issues to manufacturing or goods receipts from production. Links inventory movements to wafer fabrication, die packaging, or assembly operations.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of material moved in this transaction. Positive for receipts and transfers-in, negative for issues and transfers-out. Precision supports wafer counts, die counts, and chemical volumes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Code indicating the business reason for the goods movement: quality hold, scrap due to defect, return to vendor, obsolescence, cycle count adjustment, or other operational reason. Required for scrap and adjustment transactions.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentLineItem rdf:type rdf:Property ;
    rdfs:label 'Reference Document Line Item' ;
    rdfs:comment 'Line item number within the reference document. Provides precise linkage to the specific line of the purchase order, production order, or delivery note.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'Number of the source document that triggered this goods movement. Links to purchase order, production order, delivery note, or other originating transaction for full traceability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that triggered this goods movement: purchase order (PO) for receipts, production order for manufacturing issues/receipts, delivery note for shipments, transfer order for inter-location moves, sales order for customer shipments, or reservation for planned consumption.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Material reservation number for planned goods issues. Links to production order or maintenance order reservations for material requirements planning (MRP) and allocation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this goods movement is a reversal of a previous transaction. True for cancellation or correction postings. Used for audit trail and error correction tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'Material document number of the original transaction being reversed. Populated only when reversal_indicator is true. Provides linkage for audit trail and reconciliation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Serial number for serialized inventory items such as high-value equipment parts or Known Good Die (KGD) units. Enables unit-level traceability for critical components.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Date' ;
    rdfs:comment 'Expiration date for time-sensitive materials such as photoresists, chemicals, or adhesives. Used for shelf-life management and FIFO (First In First Out) inventory control.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourcePlantCode rdf:type rdf:Property ;
    rdfs:label 'Source Plant Code' ;
    rdfs:comment 'Plant or FAB site code where the material originated. Used for inter-plant transfers and multi-site inventory tracking. Aligns with SEMI E120 traceability requirements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location' ;
    rdfs:comment 'Storage location code where the material was moved from. Represents warehouse, stockroom, or FAB storage area. Empty for goods receipts from external suppliers.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Precise date and time when the goods movement transaction was recorded in the system. Used for audit trail, sequence verification, and real-time inventory updates.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Total monetary value of the goods movement in company currency. Calculated as quantity multiplied by material standard cost or moving average price. Used for inventory valuation and financial reporting.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenter rdf:type rdf:Property ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'Work center or production resource where the material was issued or received. Identifies specific FAB equipment, packaging line, or assembly station for process traceability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryLotHoldId rdf:type rdf:Property ;
    rdfs:label 'Inventory Lot Hold Id' ;
    rdfs:comment 'Unique identifier for the inventory lot hold record. Primary key for the inventory lot hold transaction.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaRecordId rdf:type rdf:Property ;
    rdfs:label 'Capa Record Id' ;
    rdfs:comment 'Identifier of the corrective action plan or CAPA (Corrective and Preventive Action) record associated with this hold. Links the hold to the formal corrective action process.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapaRecord .

ind:fmeaRecordId rdf:type rdf:Property ;
    rdfs:label 'Fmea Record Id' ;
    rdfs:comment 'Reference to the FMEA document or record associated with this hold. Links the hold to the failure mode analysis that identified the risk or defect mode.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FmeaRecord .

ind:processStepId rdf:type rdf:Property ;
    rdfs:label 'Process Step Id' ;
    rdfs:comment 'Identifier of the manufacturing process step where the hold was triggered. References the specific operation or stage in the fabrication flow (e.g., lithography, etch, CMP).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessStep .

ind:supplierCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Supplier Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier_corrective_action. Business justification: When supplier quality issues (incoming defects, contamination) trigger inventory lot holds, the hold must reference the SCAR to track containment actions, root cause analysis, and release criteria. Co' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierCorrectiveAction .

ind:tradeComplianceHoldId rdf:type rdf:Property ;
    rdfs:label 'Trade Compliance Hold Id' ;
    rdfs:comment 'Foreign key linking to compliance.trade_compliance_hold. Business justification: Lot holds often stem from trade compliance issues; linking hold records to the underlying trade compliance hold provides traceability for release decisions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeComplianceHold .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Description of the immediate containment action taken to prevent further impact. Details the steps taken to isolate the affected lot and prevent similar issues in other lots.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieQuantity rdf:type rdf:Property ;
    rdfs:label 'Die Quantity' ;
    rdfs:comment 'Total number of die (individual chips) in the lot subject to this hold. Applicable for finished goods or die bank inventory holds.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dppmValue rdf:type rdf:Property ;
    rdfs:label 'Dppm Value' ;
    rdfs:comment 'Calculated defect rate in parts per million for the lot under hold. Quality metric indicating the severity of the defect condition.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdComments rdf:type rdf:Property ;
    rdfs:label 'Hold Comments' ;
    rdfs:comment 'Additional free-text comments or notes related to the hold. Provides supplementary information, investigation findings, or disposition rationale.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdDate rdf:type rdf:Property ;
    rdfs:label 'Hold Date' ;
    rdfs:comment 'Date and time when the hold was placed on the lot. Represents the principal business event timestamp when the lot became restricted from further processing or shipment.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdDisposition rdf:type rdf:Property ;
    rdfs:label 'Hold Disposition' ;
    rdfs:comment 'Final disposition decision for the lot after hold investigation. Indicates the action taken: rework (reprocess the lot), scrap (discard the lot), release (approve for continued flow), return (send back to supplier or customer), quarantine (extended hold pending further review), or retest (re-inspect or re-qualify).' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Hold Expiration Date' ;
    rdfs:comment 'Date and time when the hold automatically expires if not explicitly released. Null if no expiration is set. Used for time-limited holds that auto-release after a defined period.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdInitiatorName rdf:type rdf:Property ;
    rdfs:label 'Hold Initiator Name' ;
    rdfs:comment 'Full name of the person or system that initiated the hold. Provides human-readable identification of the hold originator.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Business identifier for the hold event. Externally-known unique code assigned to this hold transaction for tracking and reference purposes.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdPriority rdf:type rdf:Property ;
    rdfs:label 'Hold Priority' ;
    rdfs:comment 'Priority level assigned to the hold. Indicates the urgency and business impact of the hold (critical for safety or regulatory issues, high for customer impact, medium for process improvement, low for administrative holds).' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the hold reason. Provides context and specifics beyond the hold reason code, including root cause details, defect description, or customer complaint reference.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Hold Release Authority Name' ;
    rdfs:comment 'Full name of the person or system that released the hold. Provides human-readable identification of the release authority.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'Date and time when the hold was released or lifted. Null if the hold is still active. Marks the point when the lot was cleared for continued processing or shipment.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle state of the hold. Indicates whether the hold is currently active (lot is restricted), released (hold lifted and lot available), expired (hold auto-released after time limit), or cancelled (hold invalidated).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the hold event. Indicates the functional area or business reason category that triggered the hold (engineering investigation, quality issue, customer request, export control compliance, process deviation, equipment failure, or material defect). [ENUM-REF-CANDIDATE: engineering|quality|customer|export_control|process|equipment|material — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryHold rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Hold' ;
    rdfs:comment 'Flag indicating whether the hold is mandated by regulatory compliance requirements (e.g., export control, environmental, safety). True if the hold is regulatory-driven, false otherwise.' ;
    rdfs:domain ind:InventoryLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code representing the identified root cause of the issue that triggered the hold. Maps to internal root cause taxonomy (e.g., MATERIAL_DEFECT, PROCESS_DRIFT, EQUIPMENT_FAILURE, OPERATOR_ERROR).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalInventoryId rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Id' ;
    rdfs:comment 'Unique identifier for the physical inventory count event record.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookQuantity rdf:type rdf:Property ;
    rdfs:label 'Book Quantity' ;
    rdfs:comment 'System-recorded inventory quantity (book quantity) at the time of the physical count, representing the expected quantity per ERP records.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Consignment Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this inventory is consignment stock held at an OSAT (Outsourced Semiconductor Assembly and Test) partner or customer location, owned by the company but physically located off-site.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Completion Timestamp' ;
    rdfs:comment 'Timestamp when the physical count activity was completed and submitted for review.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The date on which the physical inventory count was performed or is scheduled to be performed.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Count Document Number' ;
    rdfs:comment 'Externally-known unique document number assigned to this physical inventory count event for traceability and audit purposes.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNotes rdf:type rdf:Property ;
    rdfs:label 'Count Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the counter or supervisor regarding count conditions, discrepancies observed, damaged goods, or other relevant observations.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Timestamp when the physical count activity began for this inventory event.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the physical inventory count event: planned (scheduled but not started), in-progress (counting underway), completed (count finished awaiting approval), posted (variance posted to system), cancelled, or on-hold.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the physical inventory count event: cycle count (periodic rotation), annual wall-to-wall (full facility), triggered count (post-movement discrepancy or system exception), spot check, variance recount, or regulatory audit.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Physically counted quantity recorded by the counter during the inventory count event.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period (month or quarter) within the fiscal year when the count was performed, supporting periodic financial close and inventory valuation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year in which the physical inventory count was performed, supporting annual financial reporting and SOX compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freezeFlag rdf:type rdf:Property ;
    rdfs:label 'Freeze Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether inventory movements were frozen (blocked) during the count period to ensure accuracy and prevent discrepancies.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryCategory rdf:type rdf:Property ;
    rdfs:label 'Inventory Category' ;
    rdfs:comment 'High-level classification of the inventory being counted: raw material (silicon wafers, chemicals, gases, photomasks), WIP (Work in Process wafer lots), finished goods (packaged chips), die bank, consignment stock, or spare parts.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this count is a recount of a previously counted item due to variance exceeding tolerance thresholds or supervisor request.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountReason rdf:type rdf:Property ;
    rdfs:label 'Recount Reason' ;
    rdfs:comment 'Reason code for why a recount was triggered: variance exceeds threshold, supervisor request, system discrepancy, damaged goods, quality hold, or initial count error.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostUsd rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Usd' ;
    rdfs:comment 'Standard cost per unit of the material at the time of count, used for variance valuation and financial reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceExceedsToleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Exceeds Tolerance Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether the calculated variance exceeds the defined tolerance threshold, requiring investigation or recount per quality management procedures.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Calculated difference between counted quantity and book quantity (counted minus book), representing inventory discrepancy. Positive values indicate surplus, negative values indicate shortage.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Pct' ;
    rdfs:comment 'Acceptable variance tolerance percentage for this count event, beyond which a recount or investigation is triggered. Typically set per material category and value class.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Variance Value Usd' ;
    rdfs:comment 'Financial value of the inventory variance in US dollars, calculated as variance quantity multiplied by standard cost or moving average price. Critical for SOX Section 404 financial controls and inventory valuation accuracy.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentStockId rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Id' ;
    rdfs:comment 'Unique identifier for the consignment stock record. Primary key.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryConsignmentDieBankId rdf:type rdf:Property ;
    rdfs:label 'Primary Consignment Die Bank Id' ;
    rdfs:comment 'Reference to the die bank if the consignment stock consists of Known Good Die (KGD) awaiting packaging.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DieBank .

ind:primaryConsignmentStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Consignment Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Consignment stock must reference the OSAT/partner storage location for reconciliation and ownership transfer.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Quantity of consigned material currently available at the OSAT partner location for consumption.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin or rack location within the OSAT partner warehouse where the consignment stock is stored.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consigned Quantity' ;
    rdfs:comment 'Total quantity of material consigned to the OSAT partner or VMI hub under this agreement.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consignment Expiry Date' ;
    rdfs:comment 'Date when the consignment agreement expires or when the material must be consumed, returned, or settled.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Consignment Start Date' ;
    rdfs:comment 'Date when the material was first consigned to the OSAT partner or VMI hub under this agreement.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Consignment Status' ;
    rdfs:comment 'Current lifecycle status of the consignment stock record.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentType rdf:type rdf:Property ;
    rdfs:label 'Consignment Type' ;
    rdfs:comment 'Type of consignment arrangement: OSAT assembly, OSAT test, vendor-managed inventory hub, or customer consignment.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumed Quantity' ;
    rdfs:comment 'Quantity of consigned material that has been consumed or used by the OSAT partner, triggering ownership transfer.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity of consigned material currently in transit to or from the OSAT partner or VMI hub.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date of the most recent consignment stock reconciliation between the semiconductor company and the OSAT partner.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Last Settlement Date' ;
    rdfs:comment 'Date of the most recent financial settlement for consumed consignment stock with the OSAT partner.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityAgingDays rdf:type rdf:Property ;
    rdfs:label 'Liability Aging Days' ;
    rdfs:comment 'Number of days the consignment stock has been at the OSAT partner location, used for aging analysis and liability reporting.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextReconciliationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reconciliation Due Date' ;
    rdfs:comment 'Scheduled date for the next consignment stock reconciliation based on the reconciliation frequency.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipTransferTrigger rdf:type rdf:Property ;
    rdfs:label 'Ownership Transfer Trigger' ;
    rdfs:comment 'Event that triggers ownership transfer from the semiconductor company to the OSAT partner: consumption, shipment, time-based, or withdrawal.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'Frequency at which consignment stock levels are reconciled between the semiconductor company and the OSAT partner.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Document Reference' ;
    rdfs:comment 'Reference number of the most recent settlement document or invoice generated for consumed consignment stock.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Valuation Amount' ;
    rdfs:comment 'Total monetary value of the consigned stock at the OSAT partner location, calculated as available quantity times standard cost.' ;
    rdfs:domain ind:ConsignmentStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockValuationId rdf:type rdf:Property ;
    rdfs:label 'Stock Valuation Id' ;
    rdfs:comment 'Primary key for stock_valuation' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Stock revaluations post to journal entries for inventory adjustments, variance accounting, and period-end inventory valuation corrections.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:primaryStockBalanceId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Balance Id' ;
    rdfs:comment 'FK to inventory.stock_balance.stock_balance_id — Financial valuation must reference the quantity position it values. Links financial and physical inventory views.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockBalance .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'The direct labor cost component allocated to the inventory valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastValuationDate rdf:type rdf:Property ;
    rdfs:label 'Last Valuation Date' ;
    rdfs:comment 'The date of the previous valuation calculation for this inventory position, enabling period-over-period variance analysis.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialCost rdf:type rdf:Property ;
    rdfs:label 'Material Cost' ;
    rdfs:comment 'The direct material cost component of the valuation (silicon wafers, chemicals, gases, photomasks, packaging materials).' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'The moving average price per unit, recalculated with each goods receipt when using moving average valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreCostAllocation rdf:type rdf:Property ;
    rdfs:label 'Nre Cost Allocation' ;
    rdfs:comment 'The allocated portion of NRE costs (design, tapeout, mask set, PDK licensing) amortized into the inventory valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadCost rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost' ;
    rdfs:comment 'The manufacturing overhead cost component (facility, equipment depreciation, utilities) allocated to the inventory valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Indicates whether this valuation record is subject to SOX financial reporting controls and audit requirements.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'The total financial value of the inventory position (quantity × unit price), representing the balance sheet valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The date on which the inventory valuation was calculated and recorded. Principal business event timestamp for this financial snapshot.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The inventory costing method applied: standard cost, moving average price, FIFO (First In First Out), LIFO (Last In First Out), or weighted average.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'The current status of the inventory valuation: active (available for use), blocked (restricted), quality hold (pending inspection), obsolete (end of life), or scrapped.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Classification of the valuation split (e.g., unrestricted use, quality inspection, blocked stock, consignment).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationVariance rdf:type rdf:Property ;
    rdfs:label 'Valuation Variance' ;
    rdfs:comment 'The variance between current and previous valuation amounts, highlighting inventory value changes for management review.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipCostAccumulation rdf:type rdf:Property ;
    rdfs:label 'Wip Cost Accumulation' ;
    rdfs:comment 'The accumulated manufacturing costs for WIP wafer lots, including FEOL (Front End of Line), MOL (Middle of Line), and BEOL (Back End of Line) processing costs.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldImpactFactor rdf:type rdf:Property ;
    rdfs:label 'Yield Impact Factor' ;
    rdfs:comment 'A factor representing the yield percentage impact on valuation, used to adjust WIP and die bank valuations based on expected good die yield.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabFacilityId rdf:type rdf:Property ;
    rdfs:label 'Fab Facility Id' ;
    rdfs:comment 'Foreign key linking to fabrication.fab_facility. Business justification: fabrication_wafer_lot tracks which fab facility is processing the lot via a denormalized string code (fab_facility_code). Adding a proper FK to fab_facility normalizes this relationship, enabling refe' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabFacility .

ind:parentLotFabricationWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Parent Lot Fabrication Wafer Lot Id' ;
    rdfs:comment 'Reference to the parent lot from which this lot was split or derived. Null for original lots. Enables wafer genealogy tracking and traceability.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Date and time when the lot completed all FAB processing operations and was dispositioned. Null for lots still in WIP.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentOperationName rdf:type rdf:Property ;
    rdfs:label 'Current Operation Name' ;
    rdfs:comment 'Descriptive name of the current process operation (e.g., CVD_OXIDE_DEP, EUV_LITHO, CMP_POLISH). Provides human-readable context for lot location.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentOperationNumber rdf:type rdf:Property ;
    rdfs:label 'Current Operation Number' ;
    rdfs:comment 'Sequential operation step number in the process route where the lot is currently located. Used for tracking lot position in the manufacturing flow.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentProcessArea rdf:type rdf:Property ;
    rdfs:label 'Current Process Area' ;
    rdfs:comment 'High-level FAB area classification where the lot is currently located: FEOL (front-end-of-line transistor formation), MOL (middle-of-line contacts), BEOL (back-end-of-line interconnect), metrology (inspection), or test (electrical probe).' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleTimeDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Days' ;
    rdfs:comment 'Total elapsed time in days from wafer start to lot completion. Key performance metric for manufacturing efficiency and customer responsiveness.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Target completion date for the lot to meet customer delivery commitments. Used for scheduling and on-time-delivery tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialWaferCount rdf:type rdf:Property ;
    rdfs:label 'Initial Wafer Count' ;
    rdfs:comment 'Original number of wafers when the lot was started. Used to calculate yield loss and scrap rate during processing.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isHotLot rdf:type rdf:Property ;
    rdfs:label 'Is Hot Lot' ;
    rdfs:comment 'Indicates whether this lot is designated as a hot lot requiring expedited processing and priority resource allocation. True for urgent customer orders.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Created Timestamp' ;
    rdfs:comment 'Date and time when the lot record was first created in the MES system. May precede wafer start for planning purposes.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotDisposition rdf:type rdf:Property ;
    rdfs:label 'Lot Disposition' ;
    rdfs:comment 'Final disposition decision for the completed lot: pass (released to next stage), fail (rejected), partial (some wafers pass), rework (reprocess), scrap (discard), or engineering_hold (pending review).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNotes rdf:type rdf:Property ;
    rdfs:label 'Lot Notes' ;
    rdfs:comment 'Free-text field for operators and engineers to record important observations, special handling instructions, or process deviations for this lot.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOnNode rdf:type rdf:Property ;
    rdfs:label 'Lot On Node' ;
    rdfs:comment 'FK to fabrication.technology_node.technology_node_id — Every lot is manufactured on a specific technology node. This is fundamental for WIP classification and routing.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Updated Timestamp' ;
    rdfs:comment 'Date and time when the lot record was last modified in the MES system. Tracks most recent status or attribute change.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mesSystemSource rdf:type rdf:Property ;
    rdfs:label 'Mes System Source' ;
    rdfs:comment 'Identifies the source MES system that created and manages this lot record: Camstar MES, Applied Materials SmartFactory MES, or other. Used for data lineage and system integration.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTimeHours rdf:type rdf:Property ;
    rdfs:label 'Process Time Hours' ;
    rdfs:comment 'Cumulative time in hours the lot has spent in active processing on equipment. Excludes queue and hold time. Used for capacity planning.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queueTimeHours rdf:type rdf:Property ;
    rdfs:label 'Queue Time Hours' ;
    rdfs:comment 'Cumulative time in hours the lot has spent waiting in queue between operations. Excludes active processing time. Used to identify bottlenecks.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkCount rdf:type rdf:Property ;
    rdfs:label 'Rework Count' ;
    rdfs:comment 'Number of times the lot has been reworked or reprocessed through specific operations. Tracks process stability and quality issues.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingPlanCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan Code' ;
    rdfs:comment 'Code identifying the quality sampling and inspection plan applied to this lot. Defines which wafers are sampled and at which operations for metrology and defect inspection.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Split Sequence Number' ;
    rdfs:comment 'Sequential number assigned when a lot is split into multiple child lots. Used with parent_lot_id to track lot genealogy and wafer provenance.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferCount rdf:type rdf:Property ;
    rdfs:label 'Wafer Count' ;
    rdfs:comment 'Current number of wafers in the lot. May decrease due to scraps, breakage, or sampling during processing. Initial count typically 25 wafers per lot for standard production.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Timestamp' ;
    rdfs:comment 'Date and time when the wafer lot was officially started in the FAB and entered WIP tracking. Represents the beginning of the lot\'s manufacturing lifecycle.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wipStatus rdf:type rdf:Property ;
    rdfs:label 'Wip Status' ;
    rdfs:comment 'Current lifecycle status of the wafer lot in the FAB workflow. Tracks lot progression from queue through processing to final disposition.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:belongsToLot rdf:type rdf:Property ;
    rdfs:label 'Belongs To Lot' ;
    rdfs:comment 'FK to fabrication.fabrication_wafer_lot.fabrication_wafer_lot_id — Every wafer must reference its parent lot. This is the most fundamental relationship in FAB WIP tracking - wafers are always tracked within the context of their lot.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Timestamp when the wafer completed all FAB (Fabrication Facility) process steps and is ready for wafer probing or shipment to OSAT (Outsourced Semiconductor Assembly and Test). Null for in-process wafers.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:criticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Count' ;
    rdfs:comment 'Number of critical defects that are likely to cause die failure. Subset of total defect count, used for yield prediction and SPC (Statistical Process Control).' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crystalOrientation rdf:type rdf:Property ;
    rdfs:label 'Crystal Orientation' ;
    rdfs:comment 'Crystallographic orientation of the silicon wafer surface, specified using Miller indices. <100> is most common for CMOS (Complementary Metal-Oxide-Semiconductor) fabrication.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentProcessStep rdf:type rdf:Property ;
    rdfs:label 'Current Process Step' ;
    rdfs:comment 'Name or code of the current fabrication process step the wafer is at or has completed. Examples: lithography, CVD (Chemical Vapor Deposition), CMP (Chemical Mechanical Planarization), ion implantation.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diameterMm rdf:type rdf:Property ;
    rdfs:label 'Diameter Mm' ;
    rdfs:comment 'Diameter of the wafer in millimeters. Standard sizes include 150mm (6 inch), 200mm (8 inch), and 300mm (12 inch). Larger diameters enable more dies per wafer.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current disposition status of the wafer in the FAB (Fabrication Facility) workflow. Tracks lifecycle state from WIP (Work in Process) through completion or scrap.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dopingType rdf:type rdf:Property ;
    rdfs:label 'Doping Type' ;
    rdfs:comment 'Electrical doping type of the substrate. P-type (boron-doped) or N-type (phosphorus/arsenic-doped) determines the majority carrier type. Intrinsic wafers are undoped.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epitaxialLayerFlag rdf:type rdf:Property ;
    rdfs:label 'Epitaxial Layer Flag' ;
    rdfs:comment 'Indicates whether the wafer has an epitaxial layer grown on the substrate. Epitaxial wafers have a thin crystalline layer with controlled properties for advanced device fabrication.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epitaxialResistivityOhmCm rdf:type rdf:Property ;
    rdfs:label 'Epitaxial Resistivity Ohm Cm' ;
    rdfs:comment 'Electrical resistivity of the epitaxial layer in ohm-centimeters, if present. Null for non-epitaxial wafers. Often differs from substrate resistivity.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epitaxialThicknessUm rdf:type rdf:Property ;
    rdfs:label 'Epitaxial Thickness Um' ;
    rdfs:comment 'Thickness of the epitaxial layer in micrometers, if present. Null for non-epitaxial wafers. Typical range: 1-20 micrometers.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedDieCount rdf:type rdf:Property ;
    rdfs:label 'Expected Die Count' ;
    rdfs:comment 'Expected number of dies (individual chips) on this wafer based on die size and wafer diameter. Used for yield calculation and planning.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genealogyPath rdf:type rdf:Property ;
    rdfs:label 'Genealogy Path' ;
    rdfs:comment 'Hierarchical path tracking the wafer lineage from ingot to lot to wafer. Enables traceability for quality investigations and compliance. Format varies by MES (Manufacturing Execution System).' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodDieCount rdf:type rdf:Property ;
    rdfs:label 'Good Die Count' ;
    rdfs:comment 'Actual number of dies that passed electrical testing and quality inspection. Populated after wafer probing and testing. Used to calculate wafer yield.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Timestamp of the most recent defect inspection or metrology measurement performed on this wafer. Null if no inspection has been performed yet.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastProcessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Process Timestamp' ;
    rdfs:comment 'Timestamp of the most recent process step or operation performed on this wafer. Used for WIP (Work in Process) tracking and cycle time analysis.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notchOrientationDegrees rdf:type rdf:Property ;
    rdfs:label 'Notch Orientation Degrees' ;
    rdfs:comment 'Angular position of the wafer notch in degrees, used for wafer alignment and orientation during automated processing. Standard is 0 degrees for <110> direction.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scrapReasonCode rdf:type rdf:Property ;
    rdfs:label 'Scrap Reason Code' ;
    rdfs:comment 'Code indicating the reason for wafer scrap, if applicable. Examples: excessive defects, process excursion, handling damage, contamination. Null for non-scrapped wafers.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotPosition rdf:type rdf:Property ;
    rdfs:label 'Slot Position' ;
    rdfs:comment 'Physical slot position of the wafer within the carrier or cassette during processing. Used for tracking and automation.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substrateType rdf:type rdf:Property ;
    rdfs:label 'Substrate Type' ;
    rdfs:comment 'Material composition of the wafer substrate. Silicon is most common, but compound semiconductors like GaAs (Gallium Arsenide), SiC (Silicon Carbide), and GaN (Gallium Nitride) are used for specialized applications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thicknessUm rdf:type rdf:Property ;
    rdfs:label 'Thickness Um' ;
    rdfs:comment 'Thickness of the wafer in micrometers. Typical range is 500-800 micrometers depending on diameter and application. Critical for mechanical stability and process control.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Number' ;
    rdfs:comment 'Business identifier for the wafer within its lot. Typically a sequential number or alphanumeric code assigned during lot creation.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricationProcessRecipeId rdf:type rdf:Property ;
    rdfs:label 'Fabrication Process Recipe Id' ;
    rdfs:comment 'Unique identifier for the fabrication process recipe. Primary key for this entity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationProcessRecipe .

ind:stepId rdf:type rdf:Property ;
    rdfs:label 'Step Id' ;
    rdfs:comment 'Foreign key linking to process.process_step. Business justification: Recipe qualification and change control require tracing which engineering process step the fabrication recipe implements. Semiconductor process engineers use this link for recipe-to-step qualification' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Step .

ind:targetMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Target Material Master Id' ;
    rdfs:comment 'Foreign key linking to supply.material_master. Business justification: Process recipes specify target materials (process gases, chemicals, slurries, films) that must be procured and stocked. Linking recipe to material_master enables MRP-driven procurement planning based ' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Engineering approval status indicating whether the recipe has been reviewed and authorized for use by process engineering and quality teams.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the process engineer or quality manager who approved this recipe for production use.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chamberConfiguration rdf:type rdf:Property ;
    rdfs:label 'Chamber Configuration' ;
    rdfs:comment 'Specific chamber or module configuration within the equipment where the recipe is executed, enabling multi-chamber tool recipe management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlReference rdf:type rdf:Property ;
    rdfs:label 'Change Control Reference' ;
    rdfs:comment 'Reference to the Engineering Change Order (ECO) or Product Change Notification (PCN) that authorized the creation or modification of this recipe.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDensityTargetPerCm2 rdf:type rdf:Property ;
    rdfs:label 'Defect Density Target Per Cm2' ;
    rdfs:comment 'Target defect density in defects per square centimeter for wafers processed with this recipe, critical for yield management.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this recipe version is superseded or retired. Null indicates the recipe is currently active with no planned end date.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this recipe version becomes effective and available for production use.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this recipe complies with environmental regulations including RoHS, REACH, and TSCA for chemical usage and emissions.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type or model of fabrication equipment (tool) for which this recipe is designed, such as Applied Materials Centura, Lam Research Flex, or ASML NXT scanner.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaReference rdf:type rdf:Property ;
    rdfs:label 'Fmea Reference' ;
    rdfs:comment 'Reference to the Failure Mode and Effects Analysis (FMEA) document that identifies potential failure modes and mitigation strategies for this recipe.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gasFlowParameters rdf:type rdf:Property ;
    rdfs:label 'Gas Flow Parameters' ;
    rdfs:comment 'Detailed gas flow settings including gas types, flow rates (sccm), and ratios for CVD, PVD, ALD, and etch processes. Stored as structured text or JSON.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerSettingsWatts rdf:type rdf:Property ;
    rdfs:label 'Power Settings Watts' ;
    rdfs:comment 'RF or DC power settings in watts for plasma-based processes such as PVD, etch, and plasma-enhanced CVD.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Process Duration Seconds' ;
    rdfs:comment 'Total duration in seconds for the recipe execution from start to completion.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processLayerType rdf:type rdf:Property ;
    rdfs:label 'Process Layer Type' ;
    rdfs:comment 'Fabrication layer classification: Front End of Line (FEOL) for transistor formation, Middle of Line (MOL) for contacts, or Back End of Line (BEOL) for interconnects.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processOperationType rdf:type rdf:Property ;
    rdfs:label 'Process Operation Type' ;
    rdfs:comment 'Type of FAB operation this recipe defines: Chemical Vapor Deposition (CVD), Physical Vapor Deposition (PVD), Atomic Layer Deposition (ALD), Chemical Mechanical Planarization (CMP), etch, lithography (EUV/DUV), ion implantation, diffusion, oxidation, annealing, or cleaning. [ENUM-REF-CANDIDATE: CVD|PVD|ALD|CMP|etch|lithography|ion_implantation|diffusion|oxidation|annealing|cleaning — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processPressureTorr rdf:type rdf:Property ;
    rdfs:label 'Process Pressure Torr' ;
    rdfs:comment 'Target chamber pressure in Torr for the recipe execution, critical for CVD, PVD, and ALD processes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Process Temperature Celsius' ;
    rdfs:comment 'Target process temperature in degrees Celsius for the recipe execution.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'Product family or IC design family for which this recipe is optimized (e.g., mobile processors, automotive chips, AI accelerators).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeCode rdf:type rdf:Property ;
    rdfs:label 'Recipe Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the recipe for system identification and traceability across MES and ERP systems.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeDescription rdf:type rdf:Property ;
    rdfs:label 'Recipe Description' ;
    rdfs:comment 'Detailed textual description of the recipes purpose, process objectives, and special considerations for operators and engineers.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeName rdf:type rdf:Property ;
    rdfs:label 'Recipe Name' ;
    rdfs:comment 'Human-readable name of the process recipe used for identification and reference by FAB operators and process engineers.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeStatus rdf:type rdf:Property ;
    rdfs:label 'Recipe Status' ;
    rdfs:comment 'Current lifecycle status of the recipe: draft (under development), under_review (pending approval), approved (validated but not yet active), active (in production use), suspended (temporarily disabled), or obsolete (retired).' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeVersion rdf:type rdf:Property ;
    rdfs:label 'Recipe Version' ;
    rdfs:comment 'Version identifier for the recipe enabling change control and traceability of recipe evolution over time.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requalificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Requalification Due Date' ;
    rdfs:comment 'Date by which the recipe must be requalified to remain in active production status, per quality management requirements.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Safety classification indicating special handling requirements: standard, hazardous_material, high_temperature, high_pressure, or toxic_gas.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcControlPlanReference rdf:type rdf:Property ;
    rdfs:label 'Spc Control Plan Reference' ;
    rdfs:comment 'Reference to the Statistical Process Control (SPC) plan that monitors this recipes performance and detects process drift.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepSequenceDefinition rdf:type rdf:Property ;
    rdfs:label 'Step Sequence Definition' ;
    rdfs:comment 'Ordered sequence of process steps within the recipe, including step names, durations, and parameter transitions. Stored as structured text or JSON.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThicknessNm rdf:type rdf:Property ;
    rdfs:label 'Target Thickness Nm' ;
    rdfs:comment 'Target thickness in nanometers for deposition or remaining thickness after etch/CMP operations.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uniformityTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Uniformity Target Percent' ;
    rdfs:comment 'Target uniformity percentage for thickness, composition, or other critical parameters across the wafer surface.' ;
    rdfs:domain ind:FabricationProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Target Percent' ;
    rdfs:comment 'Target yield percentage for wafers processed using this recipe, used for performance monitoring and continuous improvement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processReworkTargetStepId rdf:type rdf:Property ;
    rdfs:label 'Process Rework Target Step Id' ;
    rdfs:comment 'Reference to the target process step to which lots are routed when rework is triggered from this step. Null if no rework loop exists.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Step .

ind:toolQualificationId rdf:type rdf:Property ;
    rdfs:label 'Tool Qualification Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_qualification. Business justification: Each process step requires certified qualified tools before production dispatch. MES dispatching rules, IATF 16949 compliance audits, and new tool introduction (NTI) protocols all depend on knowing wh' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolQualification .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Number of wafers or lots that can be processed together in a single batch at this step. Null for single-wafer processing steps.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalStepFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Step Flag' ;
    rdfs:comment 'Boolean flag indicating whether this step is critical to product quality or yield. Critical steps require enhanced monitoring, control, and approval workflows.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentClass rdf:type rdf:Property ;
    rdfs:label 'Equipment Class' ;
    rdfs:comment 'Constraint specifying the class or type of equipment required to execute this process step. Used by MES for equipment qualification and dispatching.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether inline inspection or metrology is required after this step. True if inspection is mandatory before proceeding to the next step.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier of the person who last modified this process step record. Used for accountability and audit trails.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxQueueTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Max Queue Time Minutes' ;
    rdfs:comment 'Maximum allowable queue time in minutes before the step must be processed or the lot is flagged for hold. Critical for time-sensitive processes.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minBatchSize rdf:type rdf:Property ;
    rdfs:label 'Min Batch Size' ;
    rdfs:comment 'Minimum number of wafers or lots required to start processing at this step. Used for batch tool optimization and scheduling.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'High-level classification of the process step into Front End of Line (FEOL), Middle of Line (MOL), or Back End of Line (BEOL) manufacturing phases.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCategory rdf:type rdf:Property ;
    rdfs:label 'Process Category' ;
    rdfs:comment 'Detailed classification of the process step by operation category such as lithography, etch, deposition (CVD/PVD/ALD), Chemical Mechanical Planarization (CMP), ion implant, thermal anneal, clean, wet clean, inspection, or metrology. [ENUM-REF-CANDIDATE: lithography|etch|deposition|CMP|implant|anneal|clean|wet_clean|inspection|metrology — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processSubcategory rdf:type rdf:Property ;
    rdfs:label 'Process Subcategory' ;
    rdfs:comment 'Granular subcategory within the process category, such as EUV lithography, DUV lithography, plasma etch, reactive ion etch, CVD, PVD, ALD, etc. Provides detailed process technology classification.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkLoopIndicator rdf:type rdf:Property ;
    rdfs:label 'Rework Loop Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this step is part of a rework loop. True if the step can route back to an earlier step for defect correction or reprocessing.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingRatePercent rdf:type rdf:Property ;
    rdfs:label 'Sampling Rate Percent' ;
    rdfs:comment 'Percentage of lots or wafers that must be sampled for inspection or metrology at this step. Used for statistical quality control.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skipAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Skip Allowed Flag' ;
    rdfs:comment 'Boolean flag indicating whether this step can be skipped under certain conditions (e.g., engineering wafers, test lots). True if skip is permitted.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardQueueTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Queue Time Minutes' ;
    rdfs:comment 'Expected queue time in minutes before the step begins processing. Used for scheduling and WIP prediction.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepCostPerWafer rdf:type rdf:Property ;
    rdfs:label 'Step Cost Per Wafer' ;
    rdfs:comment 'Standard cost per wafer for executing this process step. Used for product costing, yield analysis, and financial planning. Business-confidential financial data.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepDescription rdf:type rdf:Property ;
    rdfs:label 'Step Description' ;
    rdfs:comment 'Detailed textual description of the process step, including purpose, key parameters, and special handling instructions for operators and engineers.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Step Sequence Number' ;
    rdfs:comment 'Sequential ordering of this step within the process flow routing. Determines the execution order of operations in the FAB.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepStatus rdf:type rdf:Property ;
    rdfs:label 'Step Status' ;
    rdfs:comment 'Current lifecycle status of the process step definition. Active steps are in production use; inactive or obsolete steps are retired; engineering steps are under development; pending approval steps await qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Cycle Time Minutes' ;
    rdfs:comment 'Step-level target cycle time in minutes. Used for capacity planning, scheduling, and WIP flow optimization.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version identifier for the process step definition. Incremented with each engineering change. Supports change control and traceability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beolStepCount rdf:type rdf:Property ;
    rdfs:label 'Beol Step Count' ;
    rdfs:comment 'Number of process steps in the Back End Of Line (BEOL) phase covering metal interconnect layers and passivation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalClassification rdf:type rdf:Property ;
    rdfs:label 'Environmental Classification' ;
    rdfs:comment 'Environmental and chemical safety classification for materials and processes used in this flow (e.g., RoHS compliant, REACH registered).' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCycleTimeDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Cycle Time Days' ;
    rdfs:comment 'Estimated total manufacturing cycle time in days for a wafer lot to complete this entire process flow under normal conditions.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricationProcessFlowDescription rdf:type rdf:Property ;
    rdfs:label 'Fabrication Process Flow Description' ;
    rdfs:comment 'Detailed textual description of the process flow including its purpose, key characteristics, and intended applications.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feolStepCount rdf:type rdf:Property ;
    rdfs:label 'Feol Step Count' ;
    rdfs:comment 'Number of process steps in the Front End Of Line (FEOL) phase covering transistor formation and active device fabrication.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flowRevision rdf:type rdf:Property ;
    rdfs:label 'Flow Revision' ;
    rdfs:comment 'Revision identifier tracking version changes to the process flow definition.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowStatus rdf:type rdf:Property ;
    rdfs:label 'Flow Status' ;
    rdfs:comment 'Current lifecycle status of the process flow indicating its approval and usage state in FAB operations.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowType rdf:type rdf:Property ;
    rdfs:label 'Flow Type' ;
    rdfs:comment 'Classification of the process flow indicating its purpose: standard production, Multi-Project Wafer (MPW), engineering evaluation, qualification, or research and development (R&D).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Customer Specific' ;
    rdfs:comment 'Boolean flag indicating whether this process flow is customized for a specific customer or represents a standard foundry offering.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:molStepCount rdf:type rdf:Property ;
    rdfs:label 'Mol Step Count' ;
    rdfs:comment 'Number of process steps in the Middle Of Line (MOL) phase covering contact formation and local interconnect.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Completion Date' ;
    rdfs:comment 'Date when the process flow successfully completed qualification testing and was certified for production use.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresNre rdf:type rdf:Property ;
    rdfs:label 'Requires Nre' ;
    rdfs:comment 'Boolean flag indicating whether this process flow requires Non-Recurring Engineering (NRE) investment for setup and qualification.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Target Yield Percent' ;
    rdfs:comment 'Target yield percentage (good dies per wafer) expected for wafer lots processed through this flow. Business-sensitive manufacturing performance metric.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProcessSteps rdf:type rdf:Property ;
    rdfs:label 'Total Process Steps' ;
    rdfs:comment 'Total number of discrete process steps defined in this flow spanning FEOL, MOL, and BEOL operations.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotMoveId rdf:type rdf:Property ;
    rdfs:label 'Lot Move Id' ;
    rdfs:comment 'Unique identifier for the lot move transaction. Primary key for this WIP (Work in Process) lot movement event through a FAB (Fabrication Facility) process step.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atFabricationProcessStepId rdf:type rdf:Property ;
    rdfs:label 'At Fabrication Process Step Id' ;
    rdfs:comment 'Foreign key linking to fabrication.fabrication_process_step. Business justification: lot_move has an \'at_step\' BIGINT column that semantically represents the fabrication process step at which the lot move occurred. This is a clear in-domain FK to fabrication_process_step. The existing' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessStep .

ind:equipmentRunId rdf:type rdf:Property ;
    rdfs:label 'Equipment Run Id' ;
    rdfs:comment 'FK to fabrication.equipment_run.equipment_run_id — Each lot move through a process step is executed via an equipment run. Links WIP tracking to process execution for traceability.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentRun .

ind:lotProcessRunId rdf:type rdf:Property ;
    rdfs:label 'Lot Process Run Id' ;
    rdfs:comment 'Foreign key linking to process.lot_process_run. Business justification: MES traceability links lot moves to process run records for complete lot history and yield analysis. Semiconductor MES systems record a lot_process_run for each lot_move through a process step; this l' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotProcessRun .

ind:operationProcessStepId rdf:type rdf:Property ;
    rdfs:label 'Operation Process Step Id' ;
    rdfs:comment 'Foreign key linking to process.process_process_step. Business justification: Lot move corresponds to a specific process step; linking supports operation tracking and step-level performance reporting.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Step .

ind:primaryFabricationWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Primary Fabrication Wafer Lot Id' ;
    rdfs:comment 'Unique identifier for the WIP (Work in Process) lot being moved. References the wafer lot entity tracked through the FAB (Fabrication Facility).' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:recipeId rdf:type rdf:Property ;
    rdfs:label 'Recipe Id' ;
    rdfs:comment 'Identifier for the process recipe executed during this lot move. Defines the specific parameter set, process conditions, and control settings used for this operation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recipe .

ind:toolChamberId rdf:type rdf:Property ;
    rdfs:label 'Tool Chamber Id' ;
    rdfs:comment 'Identifier for the specific process chamber or module within the equipment used for this lot move. Relevant for multi-chamber tools (e.g., CVD (Chemical Vapor Deposition), PVD (Physical Vapor Deposition), ALD (Atomic Layer Deposition) systems).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Identifier for the manufacturing work order or production order associated with this lot move. Links to ERP (Enterprise Resource Planning) or MES (Manufacturing Execution System) work order master data.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:actualFlowRateSccm rdf:type rdf:Property ;
    rdfs:label 'Actual Flow Rate Sccm' ;
    rdfs:comment 'Actual gas flow rate in SCCM (Standard Cubic Centimeters per Minute) for process gases during this lot move. Critical parameter for deposition and etch processes.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPowerWatts rdf:type rdf:Property ;
    rdfs:label 'Actual Power Watts' ;
    rdfs:comment 'Actual RF (Radio Frequency) or DC power in watts applied during this lot move. Critical parameter for plasma processes (etch, PVD (Physical Vapor Deposition), PECVD (Plasma-Enhanced Chemical Vapor Deposition)).' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPressureTorr rdf:type rdf:Property ;
    rdfs:label 'Actual Pressure Torr' ;
    rdfs:comment 'Actual process chamber pressure in Torr recorded during this lot move. Critical parameter for vacuum processes (PVD (Physical Vapor Deposition), CVD (Chemical Vapor Deposition), etch, implant).' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Actual Temperature C' ;
    rdfs:comment 'Actual process temperature in degrees Celsius recorded during this lot move. Critical parameter for thermal processes (CVD (Chemical Vapor Deposition), diffusion, anneal, oxidation).' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes entered by the operator or engineer regarding this lot move. Captures contextual information, issues, or special handling instructions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlJobCode rdf:type rdf:Property ;
    rdfs:label 'Control Job Code' ;
    rdfs:comment 'Identifier for the MES (Manufacturing Execution System) control job that orchestrated this lot move. Links to the higher-level job or batch execution context in Camstar MES or SmartFactory MES.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Quality disposition or pass/fail outcome of the lot move. Determines whether the lot proceeds to the next step, requires rework, is scrapped, or is placed on hold for further inspection.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the measurement_value field (e.g., nm (nanometers), um (micrometers), angstrom, ohm-cm (resistivity), percent, ppm (parts per million)).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Value' ;
    rdfs:comment 'Primary metrology measurement value captured during this lot move (e.g., film thickness, CD (Critical Dimension), overlay, resistivity). Unit of measure is context-dependent on the operation type.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moveInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Move In Timestamp' ;
    rdfs:comment 'Timestamp when the lot was moved into the process step or equipment. Marks the start of processing for this operation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:moveOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Move Out Timestamp' ;
    rdfs:comment 'Timestamp when the lot was moved out of the process step or equipment. Marks the completion of processing for this operation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:moveStatus rdf:type rdf:Property ;
    rdfs:label 'Move Status' ;
    rdfs:comment 'Current lifecycle status of the lot move transaction. Indicates whether the move completed successfully, is still in progress, was aborted, held for review, or skipped.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Scheduling priority level for this lot move. Hot and expedite lots receive preferential processing to meet urgent customer commitments or TTM (Time to Market) targets.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processLayer rdf:type rdf:Property ;
    rdfs:label 'Process Layer' ;
    rdfs:comment 'Manufacturing layer classification for this process step. FEOL (Front End of Line) covers transistor formation, MOL (Middle of Line) covers contacts, BEOL (Back End of Line) covers interconnects and metallization.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processModule rdf:type rdf:Property ;
    rdfs:label 'Process Module' ;
    rdfs:comment 'High-level process module category for this operation (e.g., lithography, etch, deposition, ion implantation, CMP (Chemical Mechanical Planarization), diffusion, metrology, inspection, test). [ENUM-REF-CANDIDATE: lithography|etch|deposition|implant|CMP|diffusion|metrology|inspection|test — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Process Time Seconds' ;
    rdfs:comment 'Actual processing time in seconds for this lot move, calculated as the duration between move-in and move-out timestamps. Used for cycle time analysis and equipment utilization tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityIn rdf:type rdf:Property ;
    rdfs:label 'Quantity In' ;
    rdfs:comment 'Number of wafers or units in the lot at move-in. Represents the starting quantity before processing.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOut rdf:type rdf:Property ;
    rdfs:label 'Quantity Out' ;
    rdfs:comment 'Number of wafers or units in the lot at move-out. Represents the ending quantity after processing. May differ from quantity_in due to scrap, breakage, or sampling.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:queueTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Queue Time Seconds' ;
    rdfs:comment 'Time in seconds the lot spent waiting in queue before move-in. Measures WIP (Work in Process) wait time and identifies bottlenecks in the FAB (Fabrication Facility) flow.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Boolean flag indicating whether this lot move is a rework operation (True) or a first-pass operation (False). Rework lots are reprocessed due to defects or out-of-spec conditions.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingFlag rdf:type rdf:Property ;
    rdfs:label 'Sampling Flag' ;
    rdfs:comment 'Boolean flag indicating whether wafers were sampled from this lot during this move (True) for destructive testing, metrology, or inspection. False if no sampling occurred.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Number of wafers or units scrapped during this lot move due to breakage, defects, or process failures. Used for yield loss tracking and DPPM (Defective Parts Per Million) calculation.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tracksLot rdf:type rdf:Property ;
    rdfs:label 'Tracks Lot' ;
    rdfs:comment 'FK to fabrication.wafer_lot.wafer_lot_id — Every lot move transaction must reference the lot being moved. Core MES transaction integrity — cannot track WIP without this FK.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferStartId rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Id' ;
    rdfs:comment 'Unique identifier for the wafer start transaction. Primary key for the wafer start record.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createsFabricationWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Creates Fabrication Wafer Lot Id' ;
    rdfs:comment 'Foreign key linking to fabrication.fabrication_wafer_lot. Business justification: wafer_start is the authorization record that initiates a new wafer lot into the FAB line. It has two BIGINT columns \'creates_lot\' and \'start_creates_lot\' that both semantically reference the fabricati' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:fabricationPhotomaskId rdf:type rdf:Property ;
    rdfs:label 'Fabrication Photomask Id' ;
    rdfs:comment 'Identifier for the photomask set (reticle set) used for lithography steps in this wafer lot. Links to the physical layout and GDS data.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Photomask .

ind:sourcingContractId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Contract Id' ;
    rdfs:comment 'Foreign key linking to supply.sourcing_contract. Business justification: Foundry capacity contracts govern wafer start authorizations, specifying committed volumes, pricing tiers, and technology access rights. Linking wafer_start to the governing sourcing_contract enables ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingContract .

ind:earClassification rdf:type rdf:Property ;
    rdfs:label 'Ear Classification' ;
    rdfs:comment 'Export Control Classification Number (ECCN) under EAR for this product. Format: 5-character code (e.g., 3A001). Null if not export-controlled.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentLotNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Lot Number' ;
    rdfs:comment 'Lot number of the parent lot if this wafer start is a split or rework from an existing lot. Null for original starts. Enables wafer genealogy tracking.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLine rdf:type rdf:Property ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Specific production line or bay within the FAB facility assigned to this wafer start. Determines equipment set and process capability.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Date and time when the wafer lot was physically released into the FAB line and began processing. Marks the start of cycle time measurement.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for any special handling instructions, process deviations, or notes that operators and engineers should be aware of for this wafer lot.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitReason rdf:type rdf:Property ;
    rdfs:label 'Split Reason' ;
    rdfs:comment 'Free-text explanation of why this lot was split from a parent lot, if applicable. Examples: process experiment, capacity balancing, quality segregation.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferStartDate rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Date' ;
    rdfs:comment 'Calendar date when the wafer lot was authorized and initiated into the FAB line. Principal business event timestamp for capacity planning and WIP tracking.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waferStartNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Number' ;
    rdfs:comment 'Business identifier for the wafer start transaction, externally visible and used for tracking and reporting. Format: WS followed by 10 digits.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferStartStatus rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Status' ;
    rdfs:comment 'Current lifecycle status of the wafer start transaction. Authorized: approved but not yet released; Released: entered FAB line; In Process: active WIP; Completed: all steps finished; Cancelled: terminated before completion; On Hold: temporarily suspended.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferStartType rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Type' ;
    rdfs:comment 'Classification of the wafer start purpose: production (customer orders), engineering (process development), qualification (product validation), MPW (multi-project wafer), pilot (pre-production), or rework (reprocessing).' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricationLotHoldId rdf:type rdf:Property ;
    rdfs:label 'Fabrication Lot Hold Id' ;
    rdfs:comment 'Unique identifier for the fabrication lot hold event record.' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionId rdf:type rdf:Property ;
    rdfs:label 'Excursion Id' ;
    rdfs:comment 'Foreign key linking to process.excursion. Business justification: OCAP workflow requires linking lot holds to the triggering process excursion for root cause investigation and CAPA tracking. Semiconductor quality engineers expect holds to reference the excursion tha' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Excursion .

ind:materialSupplierId rdf:type rdf:Property ;
    rdfs:label 'Material Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Lot holds triggered by incoming material quality failures (contaminated substrates, off-spec chemicals) must reference the responsible supplier to initiate supplier corrective actions (SCARs) and upda' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:spcControlChartId rdf:type rdf:Property ;
    rdfs:label 'Spc Control Chart Id' ;
    rdfs:comment 'Foreign key linking to process.spc_control_chart. Business justification: OCAP workflow requires linking lot holds to the specific SPC control chart whose rule was violated. fabrication_lot_hold has spc_rule_violation boolean; the spc_control_chart_id identifies which chart' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpcControlChart .

ind:triggeringGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Triggering Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to supply.goods_receipt. Business justification: When a lot hold is caused by suspect incoming material, the specific goods receipt of that material must be referenced for quarantine, SCAR initiation, and lot genealogy traceability. Semiconductor qu' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:triggeringWaferProbeRunId rdf:type rdf:Property ;
    rdfs:label 'Triggering Wafer Probe Run Id' ;
    rdfs:comment 'Foreign key linking to test.wafer_probe_run. Business justification: Lot holds are frequently triggered by probe yield excursions falling below threshold. The MES workflow requires the hold record to reference the triggering probe run for root cause investigation and C' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferProbeRun .

ind:yieldLossEventId rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Event Id' ;
    rdfs:comment 'Foreign key linking to process.yield_loss_event. Business justification: Quality investigation workflow links lot holds to yield loss events for CAPA tracking. When a yield loss event triggers a lot hold, the hold record must reference the yield_loss_event for complete inv' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:YieldLossEvent .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicator whether management or engineering approval is required before the hold can be released.' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required' ;
    rdfs:comment 'Indicator whether the customer must be notified of this hold event per contractual or quality agreement terms.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Date and time when the customer was notified of the hold event.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectDensityThresholdExceeded rdf:type rdf:Property ;
    rdfs:label 'Defect Density Threshold Exceeded' ;
    rdfs:comment 'Indicator whether the hold was triggered by defect density exceeding acceptable limits.' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Action taken upon hold release or closure (resume normal processing, rework, scrap, quarantine, return to customer, engineering review).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Disposition Notes' ;
    rdfs:comment 'Free-text notes documenting the disposition decision, corrective actions taken, or investigation findings.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicator whether the hold has been escalated to senior engineering or management for resolution.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdCycleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Hold Cycle Time Hours' ;
    rdfs:comment 'Duration in hours between hold placement and release, used for cycle time tracking and excursion management KPIs.' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdExpirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Expiration Timestamp' ;
    rdfs:comment 'Date and time when the hold automatically expires if not explicitly released or extended, used for time-bound holds.' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdPlacementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Placement Timestamp' ;
    rdfs:comment 'Date and time when the hold was placed on the lot, representing the principal business event timestamp.' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Release Timestamp' ;
    rdfs:comment 'Date and time when the hold was released and the lot was cleared to resume processing. Null if hold is still active.' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:initiatingSystem rdf:type rdf:Property ;
    rdfs:label 'Initiating System' ;
    rdfs:comment 'Name or identifier of the system that triggered the hold event (e.g., MES, SPC, ATE, manual entry).' ;
    rdfs:domain ind:FabricationLotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Code' ;
    rdfs:comment 'Unique transaction identifier from the MES system that recorded this hold event.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcRuleViolation rdf:type rdf:Property ;
    rdfs:label 'Spc Rule Violation' ;
    rdfs:comment 'Specific SPC rule that was violated and triggered the hold (e.g., Western Electric Rule 1, 2, 3, 4).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotDispositionId rdf:type rdf:Property ;
    rdfs:label 'Lot Disposition Id' ;
    rdfs:comment 'Unique identifier for the lot disposition record. Primary key for the lot disposition entity.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferProbeRunId rdf:type rdf:Property ;
    rdfs:label 'Wafer Probe Run Id' ;
    rdfs:comment 'Foreign key linking to test.wafer_probe_run. Business justification: Lot disposition decisions (scrap, rework, use-as-is) in the fab are directly driven by wafer probe yield results. Disposition engineers reference the probe run data when making disposition calls. This' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferProbeRun .

ind:affectedWaferCount rdf:type rdf:Property ;
    rdfs:label 'Affected Wafer Count' ;
    rdfs:comment 'Number of wafers in the lot subject to this disposition decision. Represents the quantity of wafers impacted by the disposition action.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerApprovalReceived rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Received' ;
    rdfs:comment 'Flag indicating whether customer approval has been received for ship-as-is or downgrade dispositions. Applicable when customer notification is required.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized defect classification code from the fab defect taxonomy. Links to the defect type reference table for detailed defect characteristics.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDieCount rdf:type rdf:Property ;
    rdfs:label 'Defect Die Count' ;
    rdfs:comment 'Total number of defective or failing die across all wafers in the lot at the time of disposition. Used for yield loss analysis.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionAuthority rdf:type rdf:Property ;
    rdfs:label 'Disposition Authority' ;
    rdfs:comment 'Name or identifier of the person, role, or system that authorized the disposition decision. Typically a quality engineer, production supervisor, or automated MES rule.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Disposition Authority Role' ;
    rdfs:comment 'Organizational role of the disposition authority. Defines the level of authorization for the disposition decision.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date when the disposition decision was made. Business event date for the disposition action.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionNumber rdf:type rdf:Property ;
    rdfs:label 'Disposition Number' ;
    rdfs:comment 'Externally-known business identifier for the disposition decision. Format: DISP-YYYYMMDD-XXXXXX where YYYYMMDD is date and XXXXXX is sequence.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionOfLot rdf:type rdf:Property ;
    rdfs:label 'Disposition Of Lot' ;
    rdfs:comment 'FK to fabrication.wafer_lot.wafer_lot_id — Disposition decisions reference the lot being dispositioned. Required for lot closure and yield accounting.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'Precise timestamp when the disposition decision was recorded in the Manufacturing Execution System (MES). Captures exact moment of disposition event.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionType rdf:type rdf:Property ;
    rdfs:label 'Disposition Type' ;
    rdfs:comment 'Type of disposition decision applied to the lot. Accept: lot meets specifications and proceeds. Scrap: lot is discarded. Rework: lot requires reprocessing. Downgrade: lot is reassigned to lower grade. Hold: lot is quarantined pending review. Ship-as-is: lot ships with known deviations under waiver.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedBy rdf:type rdf:Property ;
    rdfs:label 'Executed By' ;
    rdfs:comment 'Name or identifier of the person or system that executed the disposition action. Captures who performed the physical disposition.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Executed Timestamp' ;
    rdfs:comment 'Timestamp when the disposition action was physically executed. Represents the moment when the lot was scrapped, moved to rework, or released.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated financial impact of the disposition decision in USD. Includes scrap cost, rework cost, or revenue loss from downgrade. Used for cost accounting and yield loss reporting.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Lot Yield Percent' ;
    rdfs:comment 'Calculated yield percentage for the lot at disposition time. Represents the ratio of good die to total die, expressed as a percentage.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when the disposition record was last modified. Audit field for change tracking and data lineage.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause analysis findings. Captures the specific failure mode, contributing factors, and technical details.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverNumber rdf:type rdf:Property ;
    rdfs:label 'Waiver Number' ;
    rdfs:comment 'Engineering waiver authorization number if disposition type is ship-as-is. Format: WVR-YYYYMMDD-XXXX. Authorizes shipment of lot with known deviations.' ;
    rdfs:domain ind:LotDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabRunCardId rdf:type rdf:Property ;
    rdfs:label 'Fab Run Card Id' ;
    rdfs:comment 'Unique identifier for the fabrication run card. Primary key for the fab run card entity.' ;
    rdfs:domain ind:FabRunCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Detailed description of any engineering deviations, process exceptions, or non-standard procedures authorized for this run card. Null if no deviations exist.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Boolean indicator of whether this run card contains any approved engineering deviations from the standard process flow. True indicates deviations are present.' ;
    rdfs:domain ind:FabRunCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecoNumber rdf:type rdf:Property ;
    rdfs:label 'Eco Number' ;
    rdfs:comment 'Reference number of the Engineering Change Order (ECO) associated with this run card, if applicable. Links to formal change management documentation.' ;
    rdfs:domain ind:FabRunCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnNumber rdf:type rdf:Property ;
    rdfs:label 'Pcn Number' ;
    rdfs:comment 'Product Change Notification (PCN) number if this run card implements a customer-notified product change. Ensures traceability to customer communications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'Quality and reliability grade for this run card: automotive (IATF 16949 compliant), industrial (extended temperature/reliability), commercial (standard), or consumer (cost-optimized).' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCardFollowsFlow rdf:type rdf:Property ;
    rdfs:label 'Run Card Follows Flow' ;
    rdfs:comment 'FK to fabrication.process_flow.process_flow_id — Run cards define the approved process flow for a lot run.' ;
    rdfs:domain ind:FabRunCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runCardForLot rdf:type rdf:Property ;
    rdfs:label 'Run Card For Lot' ;
    rdfs:comment 'FK to fabrication.fabrication_wafer_lot.fabrication_wafer_lot_id — Run cards (travelers) are associated with specific lots as their manufacturing instructions.' ;
    rdfs:domain ind:FabRunCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runCardNumber rdf:type rdf:Property ;
    rdfs:label 'Run Card Number' ;
    rdfs:comment 'The externally-known business identifier for this run card. Human-readable traveler document number used by operators and engineers to reference this specific run card.' ;
    rdfs:domain ind:FabRunCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCardSpecifiesFlow rdf:type rdf:Property ;
    rdfs:label 'Run Card Specifies Flow' ;
    rdfs:comment 'FK to fabrication.process_flow.process_flow_id — Run card defines the approved process flow for the lot. Required for routing compliance verification.' ;
    rdfs:domain ind:FabRunCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runCardStatus rdf:type rdf:Property ;
    rdfs:label 'Run Card Status' ;
    rdfs:comment 'Current lifecycle status of the run card: draft (being prepared), approved (ready for use), active (lot in process), on_hold (temporarily suspended), completed (lot finished), or cancelled (run card voided).' ;
    rdfs:domain ind:FabRunCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCardType rdf:type rdf:Property ;
    rdfs:label 'Run Card Type' ;
    rdfs:comment 'Classification of the run card based on its purpose: production (standard manufacturing), engineering (experimental or test lots), qualification (product validation), rework (reprocessing), pilot (pre-production), or development (process development).' ;
    rdfs:domain ind:FabRunCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCardVersion rdf:type rdf:Property ;
    rdfs:label 'Run Card Version' ;
    rdfs:comment 'Version number of the run card document. Tracks revisions and updates to the process flow or instructions for this lot.' ;
    rdfs:domain ind:FabRunCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abortReason rdf:type rdf:Property ;
    rdfs:label 'Abort Reason' ;
    rdfs:comment 'Reason code or description if the run was aborted or failed. Used for root cause analysis and yield improvement.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Actual Temperature Celsius' ;
    rdfs:comment 'Actual measured process temperature in degrees Celsius during the run. Used for process control and deviation analysis.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmCount rdf:type rdf:Property ;
    rdfs:label 'Alarm Count' ;
    rdfs:comment 'Number of equipment alarms triggered during this run. Indicator of process stability and equipment health.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmpRemovalRateAngstromPerMin rdf:type rdf:Property ;
    rdfs:label 'Cmp Removal Rate Angstrom Per Min' ;
    rdfs:comment 'Material removal rate during CMP in Angstroms per minute. Critical parameter for planarization control and endpoint detection.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmpSlurryType rdf:type rdf:Property ;
    rdfs:label 'Cmp Slurry Type' ;
    rdfs:comment 'Type of slurry used in CMP process (e.g., oxide slurry, tungsten slurry, copper slurry). Applicable only when process_type is CMP.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmpWiwnuPercent rdf:type rdf:Property ;
    rdfs:label 'Cmp Wiwnu Percent' ;
    rdfs:comment 'Within-wafer non-uniformity percentage for CMP process. Measures variation in material removal across the wafer surface. Lower values indicate better planarization quality.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionFilmMaterial rdf:type rdf:Property ;
    rdfs:label 'Deposition Film Material' ;
    rdfs:comment 'Material deposited during CVD, PVD, or ALD runs (e.g., SiO2, Si3N4, TiN, Tungsten, Copper). Applicable for deposition process types.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositionRateAngstromPerMin rdf:type rdf:Property ;
    rdfs:label 'Deposition Rate Angstrom Per Min' ;
    rdfs:comment 'Film deposition rate in Angstroms per minute. Used for process control and cycle time optimization.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionThicknessAngstrom rdf:type rdf:Property ;
    rdfs:label 'Deposition Thickness Angstrom' ;
    rdfs:comment 'Target or measured film thickness in Angstroms deposited during the run. Critical parameter for film uniformity and device performance.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionUniformityPercent rdf:type rdf:Property ;
    rdfs:label 'Deposition Uniformity Percent' ;
    rdfs:comment 'Film thickness uniformity across the wafer expressed as a percentage. Lower values indicate better uniformity. Critical quality metric for deposition processes.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantDoseAtomsPerCm2 rdf:type rdf:Property ;
    rdfs:label 'Implant Dose Atoms Per Cm2' ;
    rdfs:comment 'Total ion dose implanted in atoms per square centimeter. Critical parameter for doping concentration control in ion implantation processes.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantEnergyKev rdf:type rdf:Property ;
    rdfs:label 'Implant Energy Kev' ;
    rdfs:comment 'Ion beam energy in kiloelectron volts (keV) for ion implantation. Determines the depth of ion penetration into the wafer substrate.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantSpecies rdf:type rdf:Property ;
    rdfs:label 'Implant Species' ;
    rdfs:comment 'Ion species implanted during ion implantation runs (e.g., Boron, Phosphorus, Arsenic, BF2). Applicable only when process_type is implant.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implantTiltAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Implant Tilt Angle Degrees' ;
    rdfs:comment 'Wafer tilt angle in degrees during ion implantation. Used to control channeling effects and implant profile.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantTwistAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Implant Twist Angle Degrees' ;
    rdfs:comment 'Wafer twist (rotation) angle in degrees during ion implantation. Used in conjunction with tilt to control channeling effects.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithographyCdMeasurementNm rdf:type rdf:Property ;
    rdfs:label 'Lithography Cd Measurement Nm' ;
    rdfs:comment 'Measured critical dimension (CD) in nanometers after lithography exposure and development. Key quality metric for pattern fidelity.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithographyExposureDoseMjPerCm2 rdf:type rdf:Property ;
    rdfs:label 'Lithography Exposure Dose Mj Per Cm2' ;
    rdfs:comment 'Exposure energy dose in millijoules per square centimeter for lithography. Critical parameter for pattern transfer and critical dimension (CD) control.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithographyFocusOffsetNm rdf:type rdf:Property ;
    rdfs:label 'Lithography Focus Offset Nm' ;
    rdfs:comment 'Focus offset in nanometers applied during lithography exposure. Used for depth-of-focus optimization and process window control.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithographyOverlayXNm rdf:type rdf:Property ;
    rdfs:label 'Lithography Overlay X Nm' ;
    rdfs:comment 'Measured overlay error in the X-axis direction in nanometers. Indicates alignment accuracy between successive lithography layers.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithographyOverlayYNm rdf:type rdf:Property ;
    rdfs:label 'Lithography Overlay Y Nm' ;
    rdfs:comment 'Measured overlay error in the Y-axis direction in nanometers. Indicates alignment accuracy between successive lithography layers.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processType rdf:type rdf:Property ;
    rdfs:label 'Process Type' ;
    rdfs:comment 'Discriminator identifying the category of fabrication process executed in this run. Determines which process-specific parameters are relevant. CVD=Chemical Vapor Deposition, PVD=Physical Vapor Deposition, ALD=Atomic Layer Deposition, CMP=Chemical Mechanical Planarization. [ENUM-REF-CANDIDATE: CVD|PVD|ALD|CMP|implant|etch|lithography|anneal|clean|wet_clean|diffusion|oxidation|metrology — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processesLot rdf:type rdf:Property ;
    rdfs:label 'Processes Lot' ;
    rdfs:comment 'FK to fabrication.wafer_lot.wafer_lot_id — Equipment run must reference the lot/wafers being processed. Core traceability requirement for process parameter linkage to product.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run End Timestamp' ;
    rdfs:comment 'Timestamp when the equipment run completed processing. Marks the end of the process execution cycle.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business identifier for this equipment run, typically assigned by the Manufacturing Execution System (MES). Used for operational tracking and traceability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runProcessesLot rdf:type rdf:Property ;
    rdfs:label 'Run Processes Lot' ;
    rdfs:comment 'FK to fabrication.fabrication_wafer_lot.fabrication_wafer_lot_id — Equipment runs are executed on wafer lots. This is the core tool-to-WIP linkage.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Start Timestamp' ;
    rdfs:comment 'Timestamp when the equipment run started processing. Marks the beginning of the process execution cycle.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runUsesRecipe rdf:type rdf:Property ;
    rdfs:label 'Run Uses Recipe' ;
    rdfs:comment 'FK to fabrication.process_recipe.process_recipe_id — Every equipment run executes a specific process recipe. Critical for recipe traceability, excursion investigation, and process control.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetPressureTorr rdf:type rdf:Property ;
    rdfs:label 'Target Pressure Torr' ;
    rdfs:comment 'Target chamber pressure in Torr as specified by the recipe. Critical control parameter for vacuum and deposition processes.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Celsius' ;
    rdfs:comment 'Target process temperature in degrees Celsius as specified by the recipe. Critical control parameter for thermal processes.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usesRecipe rdf:type rdf:Property ;
    rdfs:label 'Uses Recipe' ;
    rdfs:comment 'FK to fabrication.process_recipe.process_recipe_id — Every equipment run executes a specific recipe. Required for recipe-to-outcome traceability and process capability analysis.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferSlotMap rdf:type rdf:Property ;
    rdfs:label 'Wafer Slot Map' ;
    rdfs:comment 'Mapping of wafer identifiers to slot positions within the carrier or chamber. Structured representation of wafer placement during processing.' ;
    rdfs:domain ind:EquipmentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total cost paid to acquire this photomask including mask fabrication, OPC, inspection, and shipping. Denominated in USD. Used for asset valuation and depreciation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdUniformitySpecification rdf:type rdf:Property ;
    rdfs:label 'Cd Uniformity Specification' ;
    rdfs:comment 'Maximum allowed CD variation across the mask field in nanometers (3-sigma). Tighter specifications required for advanced nodes. Typical range 1-5nm.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningCycleCount rdf:type rdf:Property ;
    rdfs:label 'Cleaning Cycle Count' ;
    rdfs:comment 'Number of times this mask has undergone wet or dry cleaning to remove particles and contamination. Excessive cleaning can damage mask patterns.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalDimensionTargetNm rdf:type rdf:Property ;
    rdfs:label 'Critical Dimension Target Nm' ;
    rdfs:comment 'Target critical dimension (minimum feature size) for this mask layer in nanometers. Used to verify mask pattern fidelity and wafer print quality.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeExposureHours rdf:type rdf:Property ;
    rdfs:label 'Cumulative Exposure Hours' ;
    rdfs:comment 'Total hours this mask has been exposed to lithography light source (EUV or DUV). Tracks photochemical degradation and pellicle aging.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeUsageCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Usage Count' ;
    rdfs:comment 'Total number of wafer exposures performed with this mask since first use. Primary metric for mask wear tracking and lifecycle management.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectRetirementThreshold rdf:type rdf:Property ;
    rdfs:label 'Defect Retirement Threshold' ;
    rdfs:comment 'Maximum critical defect count allowed before mask must be retired or sent for repair. Typically 1-5 defects depending on technology node and layer criticality.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCleaningDate rdf:type rdf:Property ;
    rdfs:label 'Last Cleaning Date' ;
    rdfs:comment 'Date when the mask was last cleaned. Used to schedule preventive cleaning and correlate defect growth with cleaning intervals.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lithographyWavelength rdf:type rdf:Property ;
    rdfs:label 'Lithography Wavelength' ;
    rdfs:comment 'Exposure wavelength for which this mask is optimized: EUV (13.5nm), DUV ArF (193nm), DUV KrF (248nm), or i-line (365nm).' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Mask Serial Number' ;
    rdfs:comment 'Unique serial number assigned by the mask shop vendor for traceability and warranty purposes. Engraved on the reticle substrate.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pellicleInstallationDate rdf:type rdf:Property ;
    rdfs:label 'Pellicle Installation Date' ;
    rdfs:comment 'Date when the current pellicle was installed on the mask. Used to track pellicle aging and replacement cycles.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pellicleStatus rdf:type rdf:Property ;
    rdfs:label 'Pellicle Status' ;
    rdfs:comment 'Current status of the protective pellicle membrane: installed (protecting mask surface), removed (for inspection or repair), damaged (requires replacement), or not applicable (EUV masks without pellicle).' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number under which this mask was procured. Links mask asset to procurement and financial records.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationErrorSpecificationNm rdf:type rdf:Property ;
    rdfs:label 'Registration Error Specification Nm' ;
    rdfs:comment 'Maximum allowed pattern placement error relative to alignment marks in nanometers. Critical for layer-to-layer overlay accuracy. Typical range 2-10nm.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Primary reason for mask retirement: usage limit reached, defect limit exceeded, pattern revision required, process obsolescence, physical damage, or lost/missing.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Code identifying the physical storage location (reticle pod, SMIF pod, or automated reticle storage system slot) where the mask is currently stored when not in use.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRetirementThreshold rdf:type rdf:Property ;
    rdfs:label 'Usage Retirement Threshold' ;
    rdfs:comment 'Maximum cumulative usage count allowed before mask must be retired from production. Defined per technology node and mask type to ensure yield protection.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this technology node record is currently active and available for use in manufacturing and design operations. False indicates archived or deprecated nodes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designRuleComplexity rdf:type rdf:Property ;
    rdfs:label 'Design Rule Complexity' ;
    rdfs:comment 'Complexity level of Design for Manufacturability (DFM) rules required for this node. Higher complexity nodes require more sophisticated Optical Proximity Correction (OPC) and restricted design rules.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dfm Enabled Flag' ;
    rdfs:comment 'Indicates whether Design for Manufacturability (DFM) checks and optimizations are mandatory for designs targeting this node. True for advanced nodes requiring OPC, dummy fill, and restricted design rules.' ;
    rdfs:domain ind:FabricationTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dftEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dft Enabled Flag' ;
    rdfs:comment 'Indicates whether Design for Testability (DFT) structures (scan chains, BIST, ATPG patterns) are required for designs on this node. Ensures adequate test coverage for quality assurance.' ;
    rdfs:domain ind:FabricationTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eolAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Eol Announcement Date' ;
    rdfs:comment 'Date when the technology node was officially announced for end-of-life phase-out. Triggers Product Change Notification (PCN) and Last Time Buy (LTB) processes for customers.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iatf16949CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iatf16949 Certified Flag' ;
    rdfs:comment 'Indicates whether this technology node is certified under IATF 16949 Automotive Quality Management standards, required for automotive-grade semiconductor production.' ;
    rdfs:domain ind:FabricationTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the manufacturing process for this technology node is certified under ISO 9001 Quality Management System standards.' ;
    rdfs:domain ind:FabricationTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumFeatureSizeNm rdf:type rdf:Property ;
    rdfs:label 'Minimum Feature Size Nm' ;
    rdfs:comment 'The smallest feature dimension that can be reliably manufactured in this technology node, measured in nanometers. Critical dimension for lithography and patterning capability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Identifier of the user or system process that last modified this technology node record. Supports audit trail and accountability requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Internal alphanumeric code used to uniquely identify the technology node in manufacturing execution systems and product lifecycle management systems.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeGeneration rdf:type rdf:Property ;
    rdfs:label 'Node Generation' ;
    rdfs:comment 'Generation classification of the node (e.g., Leading Edge, Mature, Legacy). Indicates the relative maturity and market positioning of the process technology.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name of the technology node (e.g., 5nm, 7nm, 14nm, 28nm, 65nm, 90nm). Industry-standard designation for the process generation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nreCostEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Cost Estimate Usd' ;
    rdfs:comment 'Estimated Non-Recurring Engineering (NRE) cost in US dollars for a typical design tapeout on this technology node. Includes mask set costs, design services, and qualification expenses. Business-confidential pricing data.' ;
    rdfs:domain ind:FabricationTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerPerformanceAreaRating rdf:type rdf:Property ;
    rdfs:label 'Power Performance Area Rating' ;
    rdfs:comment 'Qualitative or quantitative assessment of the node\'s Power, Performance, and Area (PPA) characteristics relative to prior generations. Critical metric for competitive positioning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFlowVersion rdf:type rdf:Property ;
    rdfs:label 'Process Flow Version' ;
    rdfs:comment 'Version identifier of the manufacturing process flow (sequence of FEOL, MOL, BEOL steps) defined for this technology node. Tracks process recipe evolution and engineering changes.' ;
    rdfs:domain ind:FabricationTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionReadinessDate rdf:type rdf:Property ;
    rdfs:label 'Production Readiness Date' ;
    rdfs:comment 'Date when the technology node was certified as production-ready and available for high-volume manufacturing (HVM). Null if still in development or qualification.' ;
    rdfs:domain ind:FabricationTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reachCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant Flag' ;
    rdfs:comment 'Indicates whether the chemicals and materials used in this technology node comply with EU REACH Regulation for chemical safety and substance registration.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportedApplicationTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Application Types' ;
    rdfs:comment 'Comma-separated list of target application domains optimized for this node (e.g., Mobile, Automotive, AI/ML, IoT, High-Performance Computing, Networking). Guides product design-in decisions.' ;
    rdfs:domain ind:FabricationTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabYieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Fab Yield Record Id' ;
    rdfs:comment 'Unique identifier for the FAB yield record. Primary key for this transactional yield capture event.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Bin Definition Id' ;
    rdfs:comment 'Foreign key linking to test.bin_definition. Business justification: Fab yield records track bin_1_die_count, bin_2_die_count, bin_3_die_count which correspond directly to test bin definitions. Linking to bin_definition enables yield management systems to interpret bin' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinDefinition .

ind:primaryFabWaferId rdf:type rdf:Property ;
    rdfs:label 'Primary Fab Wafer Id' ;
    rdfs:comment 'Reference to the specific wafer for which yield is being recorded. Links to the wafer master record in the fabrication domain.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wafer .

ind:qualityYieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Quality Yield Record Id' ;
    rdfs:comment 'Foreign key linking to quality.yield_record. Business justification: fab_yield_record (MES) and yield_record (QMS) represent the same business concept from different system perspectives. A direct FK enables yield reconciliation between MES and QMS systems — a standard ' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:YieldRecord .

ind:bin1DieCount rdf:type rdf:Property ;
    rdfs:label 'Bin 1 Die Count' ;
    rdfs:comment 'Number of die classified into bin 1 (typically highest quality/performance bin). Part of bin-level yield breakdown.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bin2DieCount rdf:type rdf:Property ;
    rdfs:label 'Bin 2 Die Count' ;
    rdfs:comment 'Number of die classified into bin 2 (typically second-tier quality/performance bin). Part of bin-level yield breakdown.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bin3DieCount rdf:type rdf:Property ;
    rdfs:label 'Bin 3 Die Count' ;
    rdfs:comment 'Number of die classified into bin 3 (typically third-tier quality/performance bin). Part of bin-level yield breakdown.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkpointCode rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Code' ;
    rdfs:comment 'The FAB inline checkpoint at which this yield measurement was captured. Distinguishes FEOL, MOL, BEOL, and pre-probe stages. [ENUM-REF-CANDIDATE: POST_FEOL|POST_MOL|POST_BEOL|PRE_PROBE|POST_CMP|POST_LITHO|POST_ETCH|POST_IMPLANT|INLINE_INSPECTION — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlLimitLower rdf:type rdf:Property ;
    rdfs:label 'Control Limit Lower' ;
    rdfs:comment 'Lower control limit for yield percentage at this checkpoint. Part of Statistical Process Control (SPC) monitoring.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Control Limit Upper' ;
    rdfs:comment 'Upper control limit for yield percentage at this checkpoint. Part of Statistical Process Control (SPC) monitoring.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designLossDieCount rdf:type rdf:Property ;
    rdfs:label 'Design Loss Die Count' ;
    rdfs:comment 'Number of die lost due to design-related issues (DFM violations, timing failures, functional failures). Part of yield loss pareto analysis.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Excursion Severity Level' ;
    rdfs:comment 'Severity classification of the yield excursion event. Determines escalation path and response urgency.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossDieCount rdf:type rdf:Property ;
    rdfs:label 'Gross Die Count' ;
    rdfs:comment 'Total number of die on the wafer before yield screening. Represents the theoretical maximum die count based on wafer size and die layout.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The date and time when the yield measurement was captured at the inline checkpoint. Represents the business event time of the yield observation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processLossDieCount rdf:type rdf:Property ;
    rdfs:label 'Process Loss Die Count' ;
    rdfs:comment 'Number of die lost due to process-related defects (CVD, PVD, ALD, CMP, etch, implant issues). Part of yield loss pareto analysis.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:randomDefectDieCount rdf:type rdf:Property ;
    rdfs:label 'Random Defect Die Count' ;
    rdfs:comment 'Number of die lost due to random defects (particles, contamination, handling damage). Part of yield loss pareto analysis.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectBinDieCount rdf:type rdf:Property ;
    rdfs:label 'Reject Bin Die Count' ;
    rdfs:comment 'Number of die classified into reject bins (failed die that do not meet minimum specifications). Part of bin-level yield breakdown.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scrapFlag rdf:type rdf:Property ;
    rdfs:label 'Scrap Flag' ;
    rdfs:comment 'Boolean indicator that this wafer should be scrapped based on yield results. Triggers scrap disposition and cost accounting.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationLimitLower rdf:type rdf:Property ;
    rdfs:label 'Specification Limit Lower' ;
    rdfs:comment 'Lower specification limit for yield percentage at this checkpoint. Represents minimum acceptable yield threshold.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systematicDefectDieCount rdf:type rdf:Property ;
    rdfs:label 'Systematic Defect Die Count' ;
    rdfs:comment 'Number of die lost due to systematic defects (OPC errors, MEEF issues, lithography hotspots). Part of yield loss pareto analysis.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldExcursionFlag rdf:type rdf:Property ;
    rdfs:label 'Yield Excursion Flag' ;
    rdfs:comment 'Boolean indicator that this yield record represents an excursion event (yield below control limits or specification). Triggers root cause analysis and corrective action.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldForLot rdf:type rdf:Property ;
    rdfs:label 'Yield For Lot' ;
    rdfs:comment 'FK to fabrication.fabrication_wafer_lot.fabrication_wafer_lot_id — Yield records are captured at lot level at key FAB checkpoints.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Calculated yield percentage at this checkpoint (good_die_count / gross_die_count * 100). Primary yield metric for FAB inline performance tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldRecordForLot rdf:type rdf:Property ;
    rdfs:label 'Yield Record For Lot' ;
    rdfs:comment 'FK to fabrication.wafer_lot.wafer_lot_id — Yield records reference the lot measured. Required for lot-level yield tracking and excursion detection.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characterizationFabToolId rdf:type rdf:Property ;
    rdfs:label 'Characterization Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Product characterization and qualification require tracking which fab tool was used for electrical/physical parameter validation. Critical for yield correlation analysis, process transfer, and manufac' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:primaryIcProcessNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ic Process Node Id' ;
    rdfs:comment 'FK to product.process_node.process_node_id — Every IC product is manufactured on a specific process node. This is a fundamental product attribute that references the process node master.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessNode .

ind:aecQualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Aec Qualification Level' ;
    rdfs:comment 'Specific AEC qualification standard met. Q100: ICs, Q101: Discretes, Q102: Optoelectronics, Q200: Passives. Set to NA if not automotive qualified.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automotiveQualified rdf:type rdf:Property ;
    rdfs:label 'Automotive Qualified' ;
    rdfs:comment 'Indicates whether the product has passed automotive-grade qualification testing per AEC-Q standards. Required for automotive market. Includes extended temperature, reliability, and quality requirements.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catalogToFamily rdf:type rdf:Property ;
    rdfs:label 'Catalog To Family' ;
    rdfs:comment 'FK to product.product_family.product_family_id — Every IC product belongs to a product family in the taxonomy hierarchy. This is the primary classification FK.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalPartNumber rdf:type rdf:Property ;
    rdfs:label 'External Part Number' ;
    rdfs:comment 'Customer-facing orderable part number published in datasheets and used for commercial transactions. May differ from internal part number for marketing or legacy reasons.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstSiliconDate rdf:type rdf:Property ;
    rdfs:label 'First Silicon Date' ;
    rdfs:comment 'Date when first fabricated silicon wafers were received from the fab for initial testing and validation. Marks start of silicon bring-up phase.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalPartNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Part Number' ;
    rdfs:comment 'Company-assigned unique part number for internal identification, tracking, and PLM integration. Primary business identifier for the IC design.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this catalog entry is currently active and available for business operations. False indicates archived or soft-deleted record retained for historical reference.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastShipDate rdf:type rdf:Property ;
    rdfs:label 'Last Ship Date' ;
    rdfs:comment 'Final date when product shipments will be made. Marks complete discontinuation of the product. Typically 6-12 months after last-time-buy date to allow for manufacturing lead time.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTimeBuyDate rdf:type rdf:Property ;
    rdfs:label 'Last Time Buy Date' ;
    rdfs:comment 'Final date for customers to place orders before product is discontinued. Typically 6-12 months after EOL announcement. After this date, no new orders are accepted.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadFreeCompliant rdf:type rdf:Property ;
    rdfs:label 'Lead Free Compliant' ;
    rdfs:comment 'Indicates whether the product meets RoHS (Restriction of Hazardous Substances) lead-free requirements. True if compliant with EU RoHS Directive for lead-free solder and materials.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npiPhase rdf:type rdf:Property ;
    rdfs:label 'Npi Phase' ;
    rdfs:comment 'Detailed phase within NPI lifecycle for products in pre-production stages. Tracks progress from concept through design, tapeout, silicon bring-up, and qualification. Set to NA for production products. [ENUM-REF-CANDIDATE: Concept|Design|Tapeout|Silicon_Validation|Qualification|Ramp|Production|NA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingFrequencyMaxMhz rdf:type rdf:Property ;
    rdfs:label 'Operating Frequency Max Mhz' ;
    rdfs:comment 'Maximum clock frequency in MHz at which the IC can reliably operate. Key performance metric for processors, SoCs, and high-speed digital circuits. Part of PPA metrics.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageMaxV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage Max V' ;
    rdfs:comment 'Maximum supply voltage in volts for safe operation. Defines upper bound of operating voltage range. Exceeding this may cause device damage or reliability issues.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageMinV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage Min V' ;
    rdfs:comment 'Minimum supply voltage in volts for guaranteed operation. Defines lower bound of operating voltage range for power optimization and battery operation.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerMaxMw rdf:type rdf:Property ;
    rdfs:label 'Power Max Mw' ;
    rdfs:comment 'Maximum power consumption in milliwatts under worst-case operating conditions. Used for thermal design, power supply sizing, and system integration planning.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerTypicalMw rdf:type rdf:Property ;
    rdfs:label 'Power Typical Mw' ;
    rdfs:comment 'Typical operating power consumption in milliwatts under nominal conditions. Critical PPA metric for mobile, IoT, and battery-powered applications. Measured at specified voltage and frequency.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processTechnology rdf:type rdf:Property ;
    rdfs:label 'Process Technology' ;
    rdfs:comment 'Underlying semiconductor process technology architecture. Examples: CMOS (Complementary Metal-Oxide-Semiconductor), FinFET (Fin Field-Effect Transistor), GAA (Gate All Around), BiCMOS (Bipolar CMOS). [ENUM-REF-CANDIDATE: CMOS|FinFET|GAA|BiCMOS|SOI|GaN|SiGe — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable marketing name of the IC product used in customer communications, datasheets, and sales collateral.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level classification of the semiconductor product type. Determines design flow, manufacturing process, and business model (silicon vs. licensable IP). [ENUM-REF-CANDIDATE: IC|SoC|ASIC|FPGA|IP_Core|Discrete|Memory|Analog|Mixed_Signal|RF — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Production Release Date' ;
    rdfs:comment 'Date when product was officially released to production status and made available for volume manufacturing and customer orders. Marks end of qualification phase.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'Primary market segment or application domain for which the IC is designed. Determines qualification requirements, reliability standards, and regulatory compliance needs. [ENUM-REF-CANDIDATE: Automotive|Consumer|Industrial|Medical|Aerospace|Defense|Telecom|Computing|IoT|AI_ML — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transistorCount rdf:type rdf:Property ;
    rdfs:label 'Transistor Count' ;
    rdfs:comment 'Total number of transistors on the die. Key complexity metric for digital ICs and SoCs. Used for design effort estimation and manufacturing complexity assessment.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementSkuId rdf:type rdf:Property ;
    rdfs:label 'Replacement Sku Id' ;
    rdfs:comment 'Reference to the recommended replacement SKU for customers when this SKU reaches end of life. Facilitates design migration and continuity planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:skuIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Sku Ic Catalog Id' ;
    rdfs:comment 'Reference to the parent product definition in the IC catalog. Links this SKU to the base product design and specification.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:toIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'To Ic Catalog Id' ;
    rdfs:comment 'FK to product.ic_catalog.ic_catalog_id — Every SKU is an orderable variant of a catalog product. This is the most fundamental FK in the domain — without it, SKUs are orphaned from their parent product definition.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:halogenFree rdf:type rdf:Property ;
    rdfs:label 'Halogen Free' ;
    rdfs:comment 'Indicates whether this SKU is manufactured without halogen-containing materials (chlorine, bromine compounds). Required for certain environmental certifications.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:introductionDate rdf:type rdf:Property ;
    rdfs:label 'Introduction Date' ;
    rdfs:comment 'Date when this SKU was first made available for customer orders. Marks the transition from NPI to Active lifecycle status.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listPriceUsd rdf:type rdf:Property ;
    rdfs:label 'List Price Usd' ;
    rdfs:comment 'Published list price in US dollars for this SKU at 1000-unit quantity. Actual transaction prices subject to volume discounts and customer agreements.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Official manufacturer part number assigned to this SKU. Used for cross-reference with distributor catalogs and customer Bill of Materials (BOM).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderableFlag rdf:type rdf:Property ;
    rdfs:label 'Orderable Flag' ;
    rdfs:comment 'Indicates whether this SKU is currently available for new customer orders. May be false during allocation, quality holds, or phase-out periods.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcnRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pcn Required Flag' ;
    rdfs:comment 'Indicates whether any changes to this SKU specification, manufacturing process, or supply chain require formal Product Change Notification (PCN) to customers per contractual or regulatory requirements.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Qualification Level' ;
    rdfs:comment 'Reliability and qualification standard met by this SKU. AEC-Q100 for automotive ICs, AEC-Q101 for discrete automotive, MIL-STD-883 for military/aerospace.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippableFlag rdf:type rdf:Property ;
    rdfs:label 'Shippable Flag' ;
    rdfs:comment 'Indicates whether this SKU is currently authorized for shipment. May be false during quality holds, regulatory blocks, or export restrictions.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Externally-facing unique alphanumeric code identifying this orderable SKU variant. Used in customer orders, invoices, and supply chain documentation.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardPackQuantity rdf:type rdf:Property ;
    rdfs:label 'Standard Pack Quantity' ;
    rdfs:comment 'Number of units in a standard shipping container (tape and reel, tray, tube). Orders are typically placed in multiples of this quantity.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRange rdf:type rdf:Property ;
    rdfs:label 'Temperature Range' ;
    rdfs:comment 'Qualified operating temperature range classification. Commercial (0-70C), Industrial (-40-85C), Automotive (-40-125C), Military (-55-125C), Extended (-40-105C).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitWeightGrams rdf:type rdf:Property ;
    rdfs:label 'Unit Weight Grams' ;
    rdfs:comment 'Weight of a single packaged unit in grams. Used for shipping cost calculation and logistics planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voltageVariant rdf:type rdf:Property ;
    rdfs:label 'Voltage Variant' ;
    rdfs:comment 'Core or I/O voltage specification variant for this SKU. Defines power supply requirements and compatibility with system voltage rails.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Parent Family Id' ;
    rdfs:comment 'Reference to the parent product family in the hierarchy. Supports multi-level taxonomy: portfolio → family → sub-family → product → variant. Null for top-level portfolio entries.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:activePcnCount rdf:type rdf:Property ;
    rdfs:label 'Active Pcn Count' ;
    rdfs:comment 'Number of active PCNs currently in effect for this product family. Indicates ongoing changes to process, materials, or design that require customer notification and approval.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationDomain rdf:type rdf:Property ;
    rdfs:label 'Application Domain' ;
    rdfs:comment 'Specific application domain or use case this product family addresses (e.g., Advanced Driver Assistance Systems, Edge AI Inference, 5G Baseband Processing). Used for technical marketing and customer solution mapping.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Business unit or division responsible for this product family (e.g., Automotive Solutions, Mobile Computing, IoT and Embedded). Aligns with organizational structure and P&L responsibility.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCenterLocation rdf:type rdf:Property ;
    rdfs:label 'Design Center Location' ;
    rdfs:comment 'Primary design center location responsible for this product family (e.g., San Jose CA, Austin TX, Bangalore India). Used for resource planning and IP ownership tracking.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Dft Coverage Percent' ;
    rdfs:comment 'Design for Testability coverage percentage indicating the proportion of circuit nodes accessible for ATPG (Automatic Test Pattern Generation). Higher coverage enables better defect detection during wafer test.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:familyCode rdf:type rdf:Property ;
    rdfs:label 'Family Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the product family in external systems and customer communications. Used in PLM, ERP, and CRM systems for product taxonomy navigation.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyDescription rdf:type rdf:Property ;
    rdfs:label 'Family Description' ;
    rdfs:comment 'Detailed description of the product family including target applications, key features, and market positioning. Used for technical documentation and sales enablement.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Business name of the product family (e.g., Cortex-M Series, Automotive MCU Family, RF Transceiver Family). Used in roadmap planning, marketing materials, and customer design-in targeting.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'Classification of the product family by semiconductor device type. Aligns with industry standard device categories for design, fabrication, and test planning. [ENUM-REF-CANDIDATE: IC|SoC|ASIC|FPGA|IP_Core|Discrete|Mixed_Signal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level in the product family hierarchy (1=portfolio, 2=family, 3=sub-family, 4=product, 5=variant). Supports up to five levels of product taxonomy as defined in the product domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ltbDate rdf:type rdf:Property ;
    rdfs:label 'Ltb Date' ;
    rdfs:comment 'Final date for customers to place orders before product family is discontinued. Part of EOL process and customer lifecycle management.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npiStartDate rdf:type rdf:Property ;
    rdfs:label 'Npi Start Date' ;
    rdfs:comment 'Date when this product family entered NPI phase. Marks the beginning of qualification, ramp, and early customer shipments. Used for TTM (Time to Market) tracking.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:osatPartner rdf:type rdf:Property ;
    rdfs:label 'Osat Partner' ;
    rdfs:comment 'Name of the OSAT partner responsible for packaging and final test of this product family. Critical for supply chain planning and quality management.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineManager rdf:type rdf:Property ;
    rdfs:label 'Product Line Manager' ;
    rdfs:comment 'Name of the product line manager responsible for roadmap, positioning, and lifecycle management of this product family. Business owner for strategic decisions.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStandard rdf:type rdf:Property ;
    rdfs:label 'Qualification Standard' ;
    rdfs:comment 'Industry qualification standard this product family must meet (e.g., AEC-Q100 for automotive, MIL-STD-883 for military, JEDEC JESD47 for stress testing). Defines reliability testing requirements.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPerformanceMetric rdf:type rdf:Property ;
    rdfs:label 'Target Performance Metric' ;
    rdfs:comment 'Key performance metric and target value for this product family (e.g., 3.5 GHz clock frequency, 100 TOPS AI performance, 10 Gbps throughput). Used for competitive analysis and roadmap planning.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPowerMw rdf:type rdf:Property ;
    rdfs:label 'Target Power Mw' ;
    rdfs:comment 'Target typical power consumption in milliwatts for this product family. Part of PPA (Power Performance Area) metrics used for competitive positioning and customer design-in evaluation.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalDieSizeMm2 rdf:type rdf:Property ;
    rdfs:label 'Typical Die Size Mm2' ;
    rdfs:comment 'Representative die size in square millimeters for products in this family. Used for wafer yield modeling, cost estimation, and capacity planning. Actual die sizes may vary by specific product variant.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeProductionDate rdf:type rdf:Property ;
    rdfs:label 'Volume Production Date' ;
    rdfs:comment 'Date when this product family achieved volume production status (Active lifecycle). Indicates full manufacturing qualification and capacity availability.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeProductCount rdf:type rdf:Property ;
    rdfs:label 'Active Product Count' ;
    rdfs:comment 'Current count of active product SKUs (ICs, SoCs, ASICs, FPGAs) assigned to this process node. Used for capacity planning and node utilization analysis.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Baseline Yield Percent' ;
    rdfs:comment 'Expected baseline yield percentage (good dies per wafer) for this process node under standard manufacturing conditions. Used for cost modeling and capacity planning. Confidential manufacturing metric.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerWaferUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Wafer Usd' ;
    rdfs:comment 'Standard manufacturing cost per wafer in USD for this process node. Includes FEOL (Front End of Line), MOL (Middle of Line), and BEOL (Back End of Line) processing costs. Confidential financial data used for product costing and NRE (Non-Recurring Engineering) estimation.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Status' ;
    rdfs:comment 'Compliance status with environmental regulations including RoHS (Restriction of Hazardous Substances), REACH (Registration Evaluation Authorization and Restriction of Chemicals), and TSCA (Toxic Substances Control Act). Compliant indicates full adherence; Non-Compliant indicates violations; Under Review indicates pending assessment.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current lifecycle stage of the process node. NPI (New Product Introduction) indicates initial ramp; Growth indicates volume expansion; Mature indicates stable production; Decline indicates phasing out; EOL (End of Life) indicates discontinued with LTB (Last Time Buy) notifications issued.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltbDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Ltb Deadline Date' ;
    rdfs:comment 'Final date for customers to place orders for products manufactured on this process node before complete discontinuation. Null if node is not in EOL status.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:multiPatterningLayers rdf:type rdf:Property ;
    rdfs:label 'Multi Patterning Layers' ;
    rdfs:comment 'Number of critical layers requiring multi-patterning techniques (double, triple, or quad patterning) to achieve target feature sizes. Zero indicates single-exposure capability. Higher counts increase mask costs and cycle time.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opcRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Opc Required Flag' ;
    rdfs:comment 'Indicates whether OPC (Optical Proximity Correction) is mandatory for mask preparation at this process node. True for advanced nodes where lithography effects require computational correction.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdkReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Pdk Release Date' ;
    rdfs:comment 'Date when the current PDK version was officially released and made available to design teams. Tracks PDK maturity and design enablement timeline.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportedDeviceTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Device Types' ;
    rdfs:comment 'Comma-separated list of device types and IP (Intellectual Property Core) categories supported by this process node (e.g., Logic, SRAM, Analog, RF, High-Voltage, IO). Defines the breadth of design capabilities.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Technology Readiness Level' ;
    rdfs:comment 'TRL score from 1 (basic research) to 9 (full production deployment) indicating the maturity of the process node technology. Used for R&D planning and risk assessment.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProductIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Product Ic Catalog Id' ;
    rdfs:comment 'Reference to the parent product (IC, SoC, ASIC, FPGA, IP core, or discrete device) for which this specification applies.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:productIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Product Ic Catalog Id' ;
    rdfs:comment 'FK to product.ic_catalog.ic_catalog_id — Product specifications describe a specific IC product. Must reference the catalog entry.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:automotiveGrade rdf:type rdf:Property ;
    rdfs:label 'Automotive Grade' ;
    rdfs:comment 'AEC-Q100 automotive qualification grade indicating temperature range and reliability requirements (Grade 0: -40°C to 150°C, Grade 1: -40°C to 125°C, Grade 2: -40°C to 105°C, Grade 3: -40°C to 85°C).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterizationDate rdf:type rdf:Property ;
    rdfs:label 'Characterization Date' ;
    rdfs:comment 'Date when this specification was characterized and validated through silicon testing or simulation.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Data Retention Years' ;
    rdfs:comment 'Guaranteed data retention period in years for non-volatile memory components at specified temperature.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieAreaAchievedMm2 rdf:type rdf:Property ;
    rdfs:label 'Die Area Achieved Mm2' ;
    rdfs:comment 'Actual measured silicon die area in square millimeters (mm²) from physical layout. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieAreaTargetMm2 rdf:type rdf:Property ;
    rdfs:label 'Die Area Target Mm2' ;
    rdfs:comment 'Target silicon die area in square millimeters (mm²). Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPowerAchievedMw rdf:type rdf:Property ;
    rdfs:label 'Dynamic Power Achieved Mw' ;
    rdfs:comment 'Actual measured or characterized dynamic power consumption in milliwatts (mW) during active switching operation at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPowerTargetMw rdf:type rdf:Property ;
    rdfs:label 'Dynamic Power Target Mw' ;
    rdfs:comment 'Target dynamic power consumption in milliwatts (mW) during active switching operation at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enduranceCycles rdf:type rdf:Property ;
    rdfs:label 'Endurance Cycles' ;
    rdfs:comment 'Number of program/erase cycles guaranteed for non-volatile memory components (applicable to flash, EEPROM).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esdProtectionLevelKv rdf:type rdf:Property ;
    rdfs:label 'Esd Protection Level Kv' ;
    rdfs:comment 'Electrostatic discharge protection rating in kilovolts (kV) per JEDEC standards (e.g., HBM, CDM models).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Functional Safety Rating' ;
    rdfs:comment 'Functional safety certification level achieved by the product. ISO 26262 ASIL (Automotive Safety Integrity Level) A through D for automotive applications; IEC 61508 SIL (Safety Integrity Level) 1 through 4 for industrial applications. [ENUM-REF-CANDIDATE: none|iso_26262_asil_a|iso_26262_asil_b|iso_26262_asil_c|iso_26262_asil_d|iec_61508_sil_1|iec_61508_sil_2|iec_61508_sil_3|iec_61508_sil_4 — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioCount rdf:type rdf:Property ;
    rdfs:label 'Io Count' ;
    rdfs:comment 'Total number of input/output pins or pads available on the integrated circuit for signal connectivity.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leakagePowerAchievedMw rdf:type rdf:Property ;
    rdfs:label 'Leakage Power Achieved Mw' ;
    rdfs:comment 'Actual measured or characterized static leakage power consumption in milliwatts (mW) when the circuit is idle at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leakagePowerTargetMw rdf:type rdf:Property ;
    rdfs:label 'Leakage Power Target Mw' ;
    rdfs:comment 'Target static leakage power consumption in milliwatts (mW) when the circuit is idle at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxFrequencyAchievedMhz rdf:type rdf:Property ;
    rdfs:label 'Max Frequency Achieved Mhz' ;
    rdfs:comment 'Actual measured or characterized maximum operating frequency in megahertz (MHz) at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxFrequencyTargetMhz rdf:type rdf:Property ;
    rdfs:label 'Max Frequency Target Mhz' ;
    rdfs:comment 'Target maximum operating frequency in megahertz (MHz) at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memoryConfiguration rdf:type rdf:Property ;
    rdfs:label 'Memory Configuration' ;
    rdfs:comment 'Description of on-chip memory architecture including SRAM, cache, ROM, and embedded flash sizes and organization (e.g., 256KB L2 Cache, 2MB SRAM, 512KB ROM).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingConditionCorner rdf:type rdf:Property ;
    rdfs:label 'Operating Condition Corner' ;
    rdfs:comment 'Process-voltage-temperature (PVT) corner at which this specification is characterized. Typical represents nominal conditions; best/worst case represent performance extremes; slow/fast combinations represent process variation corners. [ENUM-REF-CANDIDATE: typical|best_case|worst_case|slow_slow|fast_fast|slow_fast|fast_slow — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Max C' ;
    rdfs:comment 'Maximum junction temperature in degrees Celsius at which the product is guaranteed to function within specification.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Min C' ;
    rdfs:comment 'Minimum junction temperature in degrees Celsius at which the product is guaranteed to function within specification.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageNominalV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage Nominal V' ;
    rdfs:comment 'Nominal (typical) operating voltage in volts (V) for standard operation.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityFeatures rdf:type rdf:Property ;
    rdfs:label 'Security Features' ;
    rdfs:comment 'Comma-separated list of implemented hardware security features (e.g., Secure Boot, TrustZone, AES-256, SHA-256, Hardware Root of Trust, Anti-Tamper).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specStatus rdf:type rdf:Property ;
    rdfs:label 'Spec Status' ;
    rdfs:comment 'Current lifecycle status of this product specification (Draft: under development, Preliminary: pre-silicon or early silicon, Final: production-qualified, Obsolete: superseded by newer version).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Unique identifier for the bill of materials header record. Primary key for the BOM entity.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Bom Ic Catalog Id' ;
    rdfs:comment 'Reference to the parent IC product or assembly that this BOM defines. Links to the product master catalog.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The quantity of the parent product that this BOM defines. Typically 1 for single-unit BOMs, but may be higher for batch or lot-based manufacturing. All component quantities in BOM lines are relative to this base quantity.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, typically a human-readable code used across PLM and ERP systems for tracking and reference.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Draft indicates work in progress, in_review indicates pending approval, approved indicates ready for use, active indicates currently in production, frozen indicates locked for manufacturing, obsolete indicates no longer valid, superseded indicates replaced by newer revision. [ENUM-REF-CANDIDATE: draft|in_review|approved|active|frozen|obsolete|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM by its intended use: engineering BOM (EBOM) for design, manufacturing BOM (MBOM) for production, service BOM for maintenance, planning BOM for forecasting, as-designed for original specification, or as-built for actual production configuration.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Compliant Flag' ;
    rdfs:comment 'Indicates whether the BOM and all its components are free from conflict minerals (tin, tantalum, tungsten, gold) sourced from conflict regions, per Dodd-Frank Act Section 1502 requirements.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the total material cost. Typically USD for semiconductor industry but may vary by region.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Material Flag' ;
    rdfs:comment 'Indicates whether this BOM contains components classified as critical materials (long lead time, single source, strategic importance). Used for supply chain risk management.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineeringChangeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Order Number' ;
    rdfs:comment 'Reference to the engineering change order that created or last modified this BOM revision. Critical for change traceability and audit compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:explosionType rdf:type rdf:Property ;
    rdfs:label 'Explosion Type' ;
    rdfs:comment 'Defines how the BOM should be exploded for planning and costing: single-level shows only immediate children, multi-level shows full hierarchy, summarized shows consolidated component totals.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalBomReference rdf:type rdf:Property ;
    rdfs:label 'External Bom Reference' ;
    rdfs:comment 'Original BOM identifier from the source PLM or ERP system. Maintains traceability to upstream systems and enables cross-system reconciliation.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Standard production lot size for which this BOM is optimized. Used in material requirements planning (MRP) and capacity planning calculations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltbNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Ltb Notification Date' ;
    rdfs:comment 'Date when Last Time Buy notification was issued for this BOM, indicating the product is approaching end-of-life and customers should place final orders.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'Production version identifier linking this BOM to a specific routing or process flow. Enables coordination between BOM and manufacturing process definitions.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'Expected scrap or yield loss percentage at the BOM level. Used to adjust material requirements and costing. Typical semiconductor yield losses are factored here.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalComponentCount rdf:type rdf:Property ;
    rdfs:label 'Total Component Count' ;
    rdfs:comment 'Total number of distinct component line items in this BOM. Provides quick visibility into BOM complexity without querying detail records.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Total Material Cost' ;
    rdfs:comment 'Rolled-up total material cost for all components in this BOM, calculated from component costs and quantities. Used for product costing and margin analysis.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usage rdf:type rdf:Property ;
    rdfs:label 'Usage' ;
    rdfs:comment 'Intended usage context for this BOM: production for manufacturing execution, costing for financial analysis, engineering for design reference, maintenance for service operations, or sales for customer quotations.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the BOM line entity.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Component Ic Catalog Id' ;
    rdfs:comment 'Foreign key linking to product.ic_catalog. Business justification: BOM line items in semiconductor design frequently reference other ICs from the product catalog as sub-components (e.g., a SoC BOM may include memory ICs, power management ICs, or interface chips from ' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:parentLineBomLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Line Bom Line Id' ;
    rdfs:comment 'Reference to the parent BOM line in a multi-level BOM structure. Null for top-level components. Enables recursive BOM explosion and indented BOM reports.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomLine .

ind:primaryBomId rdf:type rdf:Property ;
    rdfs:label 'Primary Bom Id' ;
    rdfs:comment 'Reference to the parent BOM header that this line belongs to. Links the line item to the overall product BOM structure.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:toBomId rdf:type rdf:Property ;
    rdfs:label 'To Bom Id' ;
    rdfs:comment 'FK to product.bom.bom_id — Classic header-line relationship. BOM lines are meaningless without their parent BOM header.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:approvedSubstitutePartNumbers rdf:type rdf:Property ;
    rdfs:label 'Approved Substitute Part Numbers' ;
    rdfs:comment 'Comma-separated list of approved alternate or substitute part numbers that can be used in place of the primary component. Supports supply chain flexibility and risk mitigation.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyProcessCode rdf:type rdf:Property ;
    rdfs:label 'Assembly Process Code' ;
    rdfs:comment 'Code identifying the assembly or packaging process used to integrate this component (e.g., wirebond, flip-chip, CoWoS, InFO). Links to process routing and manufacturing execution.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'The hierarchical level of this component in the multi-level BOM structure. Level 0 is the finished product, level 1 is direct sub-assembly, level 2 is sub-component of level 1, and so on. Supports BOM explosion for cost rollup and supply chain analysis.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed textual description of the component, including technical specifications, material properties, and functional purpose within the assembly.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPartNumber rdf:type rdf:Property ;
    rdfs:label 'Component Part Number' ;
    rdfs:comment 'The unique part number or SKU of the component material used in this BOM line. May reference die, package substrate, passive components, interposer, or other materials.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component by its functional role in the semiconductor assembly. Includes die (silicon chip), package substrate, passive components (resistors, capacitors), interposer, leadframe, wirebond, solder ball, underfill material, and mold compound. [ENUM-REF-CANDIDATE: die|package_substrate|passive|interposer|leadframe|wirebond|solder_ball|underfill|mold_compound — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Status' ;
    rdfs:comment 'Compliance status for conflict minerals (tin, tantalum, tungsten, gold) sourcing per Dodd-Frank Act Section 1502. Tracks whether component supply chain is free from conflict region sourcing.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical to product functionality, quality, or supply chain continuity. Used for risk assessment and inventory planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity End Date' ;
    rdfs:comment 'The date on which this BOM line becomes obsolete or is replaced. Null for currently active components. Supports phase-in/phase-out scenarios and Product Change Notification (PCN) tracking.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Start Date' ;
    rdfs:comment 'The date from which this BOM line becomes effective. Supports date-based BOM versioning and engineering change management.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makeOrBuyIndicator rdf:type rdf:Property ;
    rdfs:label 'Make Or Buy Indicator' ;
    rdfs:comment 'Indicates whether the component is manufactured in-house (make), procured externally (buy), or transferred from another plant (transfer). Drives procurement and production planning logic.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'The name of the original equipment manufacturer (OEM) or component manufacturer. May differ from the supplier if purchased through distributors.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phantomBomFlag rdf:type rdf:Property ;
    rdfs:label 'Phantom Bom Flag' ;
    rdfs:comment 'Indicates whether this is a phantom or transient sub-assembly that is not stocked or tracked as inventory. Phantom BOMs are exploded through during MRP but not manufactured as discrete items.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'The typical lead time in days required to procure this component from suppliers. Used for material requirements planning (MRP) and supply chain risk analysis.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityPerAssembly rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Assembly' ;
    rdfs:comment 'The quantity of this component required to produce one unit of the parent assembly. Supports fractional quantities for materials measured by weight or volume.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDesignator rdf:type rdf:Property ;
    rdfs:label 'Reference Designator' ;
    rdfs:comment 'The reference designator or location identifier for the component on the physical layout or assembly drawing (e.g., U1, C23, R45). Links BOM to physical design.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percent' ;
    rdfs:comment 'Expected scrap or yield loss percentage for this component during manufacturing. Used to calculate net material requirements accounting for process losses.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:singleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Single Source Flag' ;
    rdfs:comment 'Indicates whether this component is available from only one supplier, representing a supply chain risk. Triggers dual-sourcing initiatives and risk mitigation strategies.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedProductSpecId rdf:type rdf:Property ;
    rdfs:label 'Affected Product Spec Id' ;
    rdfs:comment 'Foreign key linking to product.product_spec. Business justification: Product Change Notifications document changes to product specifications. Linking pcn.affected_product_spec_id → product_spec.product_spec_id establishes a direct traceability path from a PCN to the sp' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSpec .

ind:changeNotificationId rdf:type rdf:Property ;
    rdfs:label 'Change Notification Id' ;
    rdfs:comment 'Unique identifier from Oracle Agile PLM system linking this PCN to the formal engineering change order (ECO) or manufacturing change order (MCO) that implements the change.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeNotification .

ind:pcnIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Pcn Ic Catalog Id' ;
    rdfs:comment 'Foreign key linking to product.ic_catalog. Business justification: pcn records are change notifications for specific IC products; linking pcn to ic_catalog provides parent relationship and enables traceability.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:affectedCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Customer Count' ;
    rdfs:comment 'Total number of customers who have active orders, design-ins, or inventory of the affected products and must be notified of the change.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedProductList rdf:type rdf:Property ;
    rdfs:label 'Affected Product List' ;
    rdfs:comment 'Comma-separated or structured list of product SKUs, part numbers, or device families impacted by this change. May reference specific die revisions, package codes, or product lines.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the executive or manager who provided final approval for the PCN, typically a VP of Engineering, Quality Director, or Product Line Manager.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automotiveQualificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Automotive Qualification Required Flag' ;
    rdfs:comment 'Indicates whether the change requires re-qualification under automotive quality standards such as IATF 16949 or AEC-Q100/Q200, applicable when affected products are used in automotive applications.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Severity classification of the change: major (requires customer qualification), minor (limited impact, may require notification), or notification_only (informational, no action required).' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed technical description of the product change, including what is being modified, the scope of the change, and technical specifications affected.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Change Owner Email' ;
    rdfs:comment 'Email address of the change owner for customer inquiries and internal coordination regarding the PCN.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOwnerName rdf:type rdf:Property ;
    rdfs:label 'Change Owner Name' ;
    rdfs:comment 'Name of the engineer, product manager, or business owner responsible for driving the PCN through approval, customer notification, and implementation.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRationale rdf:type rdf:Property ;
    rdfs:label 'Change Rationale' ;
    rdfs:comment 'Business and technical justification for the change, including reasons such as cost reduction, yield improvement, supply chain continuity, obsolescence mitigation, or performance enhancement.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:comment 'Brief descriptive title summarizing the nature of the product change for quick identification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalCount rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Count' ;
    rdfs:comment 'Number of customers who explicitly approved or acknowledged acceptance of the proposed change.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Required Flag' ;
    rdfs:comment 'Indicates whether explicit customer approval or acknowledgment is required before implementing the change, typically true for major changes affecting form, fit, or function.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerObjectionCount rdf:type rdf:Property ;
    rdfs:label 'Customer Objection Count' ;
    rdfs:comment 'Number of customers who formally objected to or raised concerns about the proposed change during the notification period.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerResponseDeadline rdf:type rdf:Property ;
    rdfs:label 'Customer Response Deadline' ;
    rdfs:comment 'Date by which customers must provide feedback, objections, or approval for the proposed change. After this date, silence may be interpreted as acceptance per JEDEC guidelines.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electricalImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Electrical Impact Assessment' ;
    rdfs:comment 'Engineering assessment of how the change affects electrical characteristics such as timing, power consumption, signal integrity, or parametric specifications.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Impact' ;
    rdfs:comment 'Assessment of whether the change affects environmental compliance status, including RoHS, REACH, halogen-free, or conflict minerals declarations.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formFitFunctionImpact rdf:type rdf:Property ;
    rdfs:label 'Form Fit Function Impact' ;
    rdfs:comment 'Classification of whether the change affects form (physical dimensions/appearance), fit (mechanical interchangeability), function (electrical/performance characteristics), multiple aspects, or none. Critical for customer qualification scope determination.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Actual date when the product change was implemented in production and new shipments began reflecting the change. May differ from planned effective_date.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jedecComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Jedec Compliance Status' ;
    rdfs:comment 'Indicates whether the PCN process and content comply with JEDEC JESD46 standard requirements for product change notification in the semiconductor industry.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newSpecification rdf:type rdf:Property ;
    rdfs:label 'New Specification' ;
    rdfs:comment 'Technical specification, process parameters, material composition, or design revision identifier for the product after the change. Defines the target state.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date when the PCN was officially communicated to affected customers, typically via email, customer portal, or formal letter.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oldSpecification rdf:type rdf:Property ;
    rdfs:label 'Old Specification' ;
    rdfs:comment 'Technical specification, process parameters, material composition, or design revision identifier for the product before the change. Provides baseline for comparison.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnStatus rdf:type rdf:Property ;
    rdfs:label 'Pcn Status' ;
    rdfs:comment 'Current lifecycle state of the PCN: draft (being prepared), pending_approval (awaiting internal review), approved (ready for customer notification), customer_notification_sent (communicated to affected customers), in_qualification (customers testing), implemented (change is live in production), cancelled (change abandoned), or superseded (replaced by newer PCN). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|customer_notification_sent|in_qualification|implemented|cancelled|superseded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnType rdf:type rdf:Property ;
    rdfs:label 'Pcn Type' ;
    rdfs:comment 'Classification of the change being notified: process change (fab process modification), material change (substrate or compound change), package change (assembly or form factor), test change (ATE or test flow), design change (die revision), or specification change (datasheet update).' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationPlan rdf:type rdf:Property ;
    rdfs:label 'Qualification Plan' ;
    rdfs:comment 'Description of the testing and validation activities required to qualify the changed product, including reliability tests, electrical characterization, and compatibility verification per JEDEC standards.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Reliability Impact Assessment' ;
    rdfs:comment 'Engineering assessment of how the change affects product reliability, including MTBF, failure modes, stress test results, and long-term performance predictions.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequestDeadline rdf:type rdf:Property ;
    rdfs:label 'Sample Request Deadline' ;
    rdfs:comment 'Last date by which customers can request evaluation samples of the changed product for their own qualification testing.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:samplesAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Samples Available Flag' ;
    rdfs:comment 'Indicates whether product samples manufactured with the new change are available for customer evaluation and qualification testing.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByPcnNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Pcn Number' ;
    rdfs:comment 'PCN number that replaces or supersedes this PCN, used when a newer change notification obsoletes or modifies a previous one.' ;
    rdfs:domain ind:Pcn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltbEccnClassificationId rdf:type rdf:Property ;
    rdfs:label 'Ltb Eccn Classification Id' ;
    rdfs:comment 'Foreign key linking to compliance.eccn_classification. Business justification: Last-Time-Buy notifications must include current ECCN classification so customers can assess export compliance impact of product discontinuance and plan for replacement part licensing. Critical for de' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EccnClassification .

ind:primaryReplacementProductIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Replacement Product Ic Catalog Id' ;
    rdfs:comment 'Reference to the recommended replacement product in the product catalog. Identifies the form-fit-function equivalent or next-generation product that customers should transition to. May be null if no direct replacement exists.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:actualLtbRevenue rdf:type rdf:Property ;
    rdfs:label 'Actual Ltb Revenue' ;
    rdfs:comment 'Actual revenue realized from LTB orders. Captured after the final order date to measure forecast accuracy and assess the financial impact of the product discontinuance.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLtbUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Ltb Units' ;
    rdfs:comment 'Actual unit volume of LTB orders received. Captured after the final order date to measure demand forecast accuracy and assess inventory disposition requirements.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancelledBy rdf:type rdf:Property ;
    rdfs:label 'Cancelled By' ;
    rdfs:comment 'Name or identifier of the business authority who cancelled the LTB notification. Populated only if the notification is cancelled before completion, typically due to business strategy changes or supply chain recovery.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the LTB notification was cancelled. Establishes the audit trail for notification lifecycle changes and supports customer communication of discontinuance reversals.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerAcknowledgmentDeadline rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledgment Deadline' ;
    rdfs:comment 'Date by which customers must acknowledge the LTB notification if acknowledgment is required. Ensures timely customer response and enables proactive follow-up for non-responsive accounts.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerAcknowledgmentRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledgment Required' ;
    rdfs:comment 'Indicates whether customers are required to formally acknowledge receipt and understanding of the LTB notification. True for high-value or strategic customers; false for standard commercial notifications.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuanceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discontinuance Reason Code' ;
    rdfs:comment 'Primary business reason for product discontinuance and LTB issuance. Categorizes the strategic, operational, or compliance driver behind the End of Life (EOL) decision.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuanceReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Discontinuance Reason Description' ;
    rdfs:comment 'Detailed explanation of the business rationale for product discontinuance. Provides context for customers and internal stakeholders on the strategic or operational factors driving the EOL decision.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLtbRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Ltb Revenue' ;
    rdfs:comment 'Projected revenue from LTB orders during the notification period. Used for financial planning, production capacity allocation, and business impact assessment of the product discontinuance.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLtbUnits rdf:type rdf:Property ;
    rdfs:label 'Estimated Ltb Units' ;
    rdfs:comment 'Projected unit volume of LTB orders. Used for production planning, wafer start authorization, and supply chain capacity allocation during the LTB period.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalOrderDate rdf:type rdf:Property ;
    rdfs:label 'Final Order Date' ;
    rdfs:comment 'Last date on which customers may place orders for the discontinued product. After this date, no new orders will be accepted. Critical milestone for customers planning bridge inventory or transitioning to replacement products.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Final Shipment Date' ;
    rdfs:comment 'Last date on which the discontinued product will be shipped to customers. Represents the absolute end of product availability and marks the transition to replacement product or alternative sourcing.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuedBy rdf:type rdf:Property ;
    rdfs:label 'Issued By' ;
    rdfs:comment 'Name or identifier of the individual who issued the LTB notification to customers. Typically a product marketing manager, customer communications specialist, or PCN coordinator.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when the LTB notification was issued to customers. Marks the official start of the notification period and triggers customer acknowledgment and ordering timelines.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity that may be ordered during the LTB period. Caps total available inventory to prevent over-commitment and ensure fair allocation across customer base.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'Primary communication channel used to deliver the LTB notification to customers. Tracks the method of notification delivery for compliance and audit purposes.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationIssueDate rdf:type rdf:Property ;
    rdfs:label 'Notification Issue Date' ;
    rdfs:comment 'Date when the LTB notification was formally issued to customers. Marks the start of the official notification period and triggers customer acknowledgment requirements per JEDEC JESD48 standard.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationLanguage rdf:type rdf:Property ;
    rdfs:label 'Notification Language' ;
    rdfs:comment 'Primary language in which the LTB notification was issued. Supports multi-lingual customer communication requirements and regulatory compliance in international markets.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Business identifier for the LTB notification. Externally communicated reference number used in customer correspondence and Product Change Notifications (PCN).' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the LTB notification. Tracks progression from draft through issuance, customer acknowledgment, and final expiration or cancellation.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Classification of the LTB notification based on timeline and business circumstances. Standard LTB follows normal discontinuance timelines; expedited LTB has shortened notice periods; extended LTB provides longer lead times; emergency discontinuance addresses immediate supply chain or compliance issues.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required' ;
    rdfs:comment 'Indicates whether the product discontinuance requires regulatory approval or notification in specific jurisdictions. True for products subject to ITAR, EAR, or industry-specific regulations; false for standard commercial products.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current status of regulatory approval for the product discontinuance. Tracks compliance with export control, defense, or industry-specific regulations that govern product lifecycle changes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementProductQualificationRequired rdf:type rdf:Property ;
    rdfs:label 'Replacement Product Qualification Required' ;
    rdfs:comment 'Indicates whether the replacement product requires customer qualification and design-in activities. True if the replacement is not a drop-in substitute and requires engineering validation; false if it is form-fit-function compatible.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCustomersAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Total Customers Acknowledged' ;
    rdfs:comment 'Count of customers who have formally acknowledged the LTB notification. Enables tracking of acknowledgment completion rate and identification of customers requiring follow-up.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCustomersNotified rdf:type rdf:Property ;
    rdfs:label 'Total Customers Notified' ;
    rdfs:comment 'Count of unique customers who received the LTB notification. Tracks the breadth of customer impact and supports acknowledgment tracking and follow-up activities.' ;
    rdfs:domain ind:LtbNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productIpCoreId rdf:type rdf:Property ;
    rdfs:label 'Product Ip Core Id' ;
    rdfs:comment 'Unique identifier for the IP core product record. Primary key for the IP core catalog.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaMm2 rdf:type rdf:Property ;
    rdfs:label 'Area Mm2' ;
    rdfs:comment 'Physical silicon area occupied by the IP core in square millimeters. Part of PPA (Power, Performance, Area) metrics.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'Comma-separated list of industry compliance certifications the IP core meets (e.g., ISO 26262 for automotive, DO-254 for aerospace, FIPS 140-2 for cryptography).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designForTestability rdf:type rdf:Property ;
    rdfs:label 'Design For Testability' ;
    rdfs:comment 'Indicates whether the IP core includes DFT features such as scan chains, BIST (Built-In Self-Test), or ATPG support.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationPackage rdf:type rdf:Property ;
    rdfs:label 'Documentation Package' ;
    rdfs:comment 'Reference to the documentation package location or identifier (e.g., datasheet, integration guide, verification plan, user manual).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errataNotes rdf:type rdf:Property ;
    rdfs:label 'Errata Notes' ;
    rdfs:comment 'Known issues, limitations, or workarounds for the IP core. Reference to errata document or summary of key issues.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundryCompatibility rdf:type rdf:Property ;
    rdfs:label 'Foundry Compatibility' ;
    rdfs:comment 'Comma-separated list of foundries whose PDKs this IP core is compatible with (e.g., TSMC, Samsung, GlobalFoundries, Intel).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationComplexity rdf:type rdf:Property ;
    rdfs:label 'Integration Complexity' ;
    rdfs:comment 'Estimated complexity level for integrating the IP core into an SoC or ASIC design: low (plug-and-play), medium (moderate customization), high (significant integration effort), very high (extensive customization required).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interfaceProtocol rdf:type rdf:Property ;
    rdfs:label 'Interface Protocol' ;
    rdfs:comment 'Standard interface protocol(s) supported by the IP core (e.g., AXI4, AHB, APB, PCIe Gen4, USB 3.2, DDR5). Comma-separated if multiple.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCategory rdf:type rdf:Property ;
    rdfs:label 'Ip Category' ;
    rdfs:comment 'Functional classification of the IP core: processor cores, memory controllers, interface controllers (USB, PCIe, Ethernet), analog blocks, PHYs, security engines, DSP blocks, or hardware accelerators. [ENUM-REF-CANDIDATE: processor|memory_controller|interface|analog|phy|security|dsp|accelerator — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCoreName rdf:type rdf:Property ;
    rdfs:label 'Ip Core Name' ;
    rdfs:comment 'Human-readable name of the IP core block (e.g., ARM Cortex-A78, USB 3.2 PHY, DDR5 Memory Controller).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingModel rdf:type rdf:Property ;
    rdfs:label 'Licensing Model' ;
    rdfs:comment 'Business model for IP core licensing: royalty-free (one-time fee), per-unit royalty (fee per chip manufactured), NRE upfront (non-recurring engineering fee), subscription (annual license), or hybrid (combination).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowPowerModes rdf:type rdf:Property ;
    rdfs:label 'Low Power Modes' ;
    rdfs:comment 'Comma-separated list of low-power operating modes supported by the IP core (e.g., sleep, retention, power gating, clock gating).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or name of the person who last modified the IP core record.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Operating Frequency Mhz' ;
    rdfs:comment 'Maximum operating frequency of the IP core in megahertz.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage V' ;
    rdfs:comment 'Nominal operating voltage for the IP core in volts (e.g., 0.8V, 1.2V).' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perUnitRoyaltyUsd rdf:type rdf:Property ;
    rdfs:label 'Per Unit Royalty Usd' ;
    rdfs:comment 'Royalty fee in USD charged per manufactured chip that incorporates this IP core. Null if licensing model is royalty-free.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetric rdf:type rdf:Property ;
    rdfs:label 'Performance Metric' ;
    rdfs:comment 'Key performance indicator for the IP core (e.g., clock frequency in MHz, throughput in Gbps, DMIPS for processors). Part of PPA metrics.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processNodeCompatibility rdf:type rdf:Property ;
    rdfs:label 'Process Node Compatibility' ;
    rdfs:comment 'Comma-separated list of process nodes (technology nodes) that this IP core supports (e.g., 7nm, 5nm, 3nm). Indicates which fabrication processes the IP can be manufactured on.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDesigns rdf:type rdf:Property ;
    rdfs:label 'Reference Designs' ;
    rdfs:comment 'Comma-separated list of reference design identifiers or links that demonstrate the IP core integration and usage.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContact rdf:type rdf:Property ;
    rdfs:label 'Support Contact' ;
    rdfs:comment 'Contact information for technical support and integration assistance for the IP core.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range C' ;
    rdfs:comment 'Operating temperature range for the IP core in Celsius (e.g., -40 to 125). Format: min to max.' ;
    rdfs:domain ind:ProductIpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current verification state of the IP core: not started, in progress (under verification), verified (passed all tests), or silicon proven (validated in actual silicon).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or name of the person who created the IP core record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCertificationId rdf:type rdf:Property ;
    rdfs:label 'Program Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.certification. Business justification: Qualification programs (AEC-Q100, JEDEC, ISO 26262) generate formal compliance certifications upon successful completion. Links qualification test results to issued certificates for automotive, aerosp' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:qualifiedSkuId rdf:type rdf:Property ;
    rdfs:label 'Qualified Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Qualification programs in semiconductors are often conducted for specific orderable variants (SKUs) — a qualification for a commercial-grade SKU does not automatically qualify the automotive-grade SKU' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:deviationGranted rdf:type rdf:Property ;
    rdfs:label 'Deviation Granted' ;
    rdfs:comment 'Indicates whether any deviations from the standard qualification test matrix were granted by engineering review board.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esdCdmEnabled rdf:type rdf:Property ;
    rdfs:label 'Esd Cdm Enabled' ;
    rdfs:comment 'Indicates whether ESD Charged Device Model stress test is included in the qualification plan. CDM simulates discharge from a charged device to ground.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esdCdmVoltageV rdf:type rdf:Property ;
    rdfs:label 'Esd Cdm Voltage V' ;
    rdfs:comment 'Target voltage level in volts for ESD Charged Device Model testing, typically 500V minimum for Class C2 devices.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esdHbmEnabled rdf:type rdf:Property ;
    rdfs:label 'Esd Hbm Enabled' ;
    rdfs:comment 'Indicates whether ESD Human Body Model stress test is included in the qualification plan. HBM simulates discharge from human contact.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esdHbmVoltageV rdf:type rdf:Property ;
    rdfs:label 'Esd Hbm Voltage V' ;
    rdfs:comment 'Target voltage level in volts for ESD Human Body Model testing, typically 2000V minimum for Class 2 devices.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureThresholdPpm rdf:type rdf:Property ;
    rdfs:label 'Failure Threshold Ppm' ;
    rdfs:comment 'Maximum allowable failure rate expressed in Defective Parts Per Million (DPPM) for the qualification program to pass.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hastDurationHours rdf:type rdf:Property ;
    rdfs:label 'Hast Duration Hours' ;
    rdfs:comment 'Duration in hours for Highly Accelerated Stress Test, typically 96 to 264 hours.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hastEnabled rdf:type rdf:Property ;
    rdfs:label 'Hast Enabled' ;
    rdfs:comment 'Indicates whether Highly Accelerated Stress Test is included in the qualification plan. HAST combines high temperature, high humidity, and voltage bias to accelerate corrosion and moisture-related failures.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hastRelativeHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Hast Relative Humidity Pct' ;
    rdfs:comment 'Relative humidity percentage for Highly Accelerated Stress Test, typically 85% RH.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hastTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Hast Temperature C' ;
    rdfs:comment 'Temperature in degrees Celsius for Highly Accelerated Stress Test, typically 110°C to 130°C.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:htolDurationHours rdf:type rdf:Property ;
    rdfs:label 'Htol Duration Hours' ;
    rdfs:comment 'Duration in hours for High Temperature Operating Life stress test, typically 1000 hours minimum per JEDEC standards.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:htolEnabled rdf:type rdf:Property ;
    rdfs:label 'Htol Enabled' ;
    rdfs:comment 'Indicates whether High Temperature Operating Life stress test is included in the qualification plan. HTOL accelerates time-dependent failure mechanisms under elevated temperature and voltage bias.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:htolTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Htol Temperature C' ;
    rdfs:comment 'Junction temperature in degrees Celsius for High Temperature Operating Life stress testing, typically 125°C to 150°C.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latchupCurrentMa rdf:type rdf:Property ;
    rdfs:label 'Latchup Current Ma' ;
    rdfs:comment 'Trigger current in milliamperes for latch-up testing, typically 100mA minimum per JEDEC standards.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latchupEnabled rdf:type rdf:Property ;
    rdfs:label 'Latchup Enabled' ;
    rdfs:comment 'Indicates whether latch-up susceptibility test is included in the qualification plan. Latch-up is a CMOS failure mode where parasitic thyristor structures create low-impedance paths.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotCount rdf:type rdf:Property ;
    rdfs:label 'Lot Count' ;
    rdfs:comment 'Number of independent fabrication lots from which qualification samples must be drawn to ensure manufacturing process representativeness.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Business identifier for the qualification program, typically combining product family code and qualification standard abbreviation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Descriptive name of the qualification program including product identifier and target application domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the qualification program. Gate-keeps product lifecycle transition from NPI to volume production.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Category of qualification program based on trigger event: new product introduction, process node change, package technology change, supply chain change, periodic requalification, or extended temperature range qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer' ;
    rdfs:comment 'Name of the reliability engineer responsible for planning, executing, and reporting the qualification program.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Total number of device units required for the complete qualification test plan across all test conditions and lots.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tcCycleCount rdf:type rdf:Property ;
    rdfs:label 'Tc Cycle Count' ;
    rdfs:comment 'Number of temperature cycles for Temperature Cycling test, typically 500 to 1000 cycles minimum.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tcEnabled rdf:type rdf:Property ;
    rdfs:label 'Tc Enabled' ;
    rdfs:comment 'Indicates whether Temperature Cycling stress test is included in the qualification plan. TC accelerates thermal fatigue failures due to coefficient of thermal expansion mismatch.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tcMaxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Tc Max Temperature C' ;
    rdfs:comment 'Maximum temperature in degrees Celsius for Temperature Cycling test, typically 125°C to 150°C.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tcMinTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Tc Min Temperature C' ;
    rdfs:comment 'Minimum temperature in degrees Celsius for Temperature Cycling test, typically -55°C or -65°C.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testMatrixVersion rdf:type rdf:Property ;
    rdfs:label 'Test Matrix Version' ;
    rdfs:comment 'Version identifier of the qualification test matrix document defining the complete set of reliability and environmental stress tests, sample sizes, and acceptance criteria.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverGranted rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted' ;
    rdfs:comment 'Indicates whether a waiver was granted to allow production release despite qualification test failures or incomplete testing.' ;
    rdfs:domain ind:ProductQualificationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifiedSkuId rdf:type rdf:Property ;
    rdfs:label 'Certified Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Compliance certifications in semiconductors are often package-specific and variant-specific — a RoHS certification for a TQFP-144 package may not apply to the same IC in a BGA-256 package. Linking com' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:primaryIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Ic Catalog Id' ;
    rdfs:comment 'FK to product.ic_catalog.ic_catalog_id — Compliance certifications are obtained for specific products or SKUs. Required for export control screening and customer documentation.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:siteCertificationId rdf:type rdf:Property ;
    rdfs:label 'Site Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.certification. Business justification: Product-specific compliance certificates (RoHS, REACH, conflict minerals) reference underlying site/process certifications (ISO 9001, ISO 14001, IATF 16949). Establishes certification hierarchy for se' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Comma-separated list of geographic markets, regions, or countries where this compliance certification is recognized and valid (e.g., USA, EU, CHN, JPN, KOR). Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Regions' ;
    rdfs:comment 'Comma-separated list of regulatory regions or jurisdictions where this certification applies (e.g., North America, European Union, Asia-Pacific, EMEA).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the lead auditor or assessor from the certification body who conducted the compliance assessment.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automotiveGradeCertified rdf:type rdf:Property ;
    rdfs:label 'Automotive Grade Certified' ;
    rdfs:comment 'Boolean flag indicating whether the product has achieved automotive-grade qualification certification (e.g., AEC-Q100 for ICs, AEC-Q101 for discrete semiconductors) for use in automotive applications.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the accredited third-party organization or regulatory authority that issued the compliance certification (e.g., TÜV, UL, Intertek, SGS, Bureau Veritas).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique certificate number or identifier issued by the certification body for this compliance certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Detailed description of the scope of the certification, including specific product variants, process nodes, package types, or application domains covered by this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the compliance certification indicating whether it is active and valid, expired, pending approval, suspended, revoked, or under review.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of regulatory or standards certification obtained. RoHS (Restriction of Hazardous Substances), REACH (Registration Evaluation Authorization and Restriction of Chemicals), TSCA (Toxic Substances Control Act), AEC-Q100/Q101 (Automotive Electronics Council qualification standards), ISO 26262 (Automotive Functional Safety), IEC 61508 (Functional Safety), UL (Underwriters Laboratories), CE (Conformité Européenne), FCC (Federal Communications Commission), ITAR (International Traffic in Arms Regulations), EAR (Export Administration Regulations). [ENUM-REF-CANDIDATE: RoHS|REACH|TSCA|AEC-Q100|AEC-Q101|ISO 26262|IEC 61508|UL|CE|FCC|ITAR|EAR — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for additional notes, exceptions, conditions, or special handling instructions related to this compliance certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsDeclaration rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Declaration' ;
    rdfs:comment 'Declaration of conflict minerals (tin, tantalum, tungsten, gold - 3TG) sourcing and compliance status with Dodd-Frank Act Section 1502 and OECD Due Diligence Guidance.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecificRequirement rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Requirement' ;
    rdfs:comment 'Description of any customer-specific compliance requirements or certifications that this record addresses beyond standard regulatory requirements.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earControlled rdf:type rdf:Property ;
    rdfs:label 'Ear Controlled' ;
    rdfs:comment 'Boolean flag indicating whether the product is subject to EAR (Export Administration Regulations) export controls administered by the Bureau of Industry and Security.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalStandard rdf:type rdf:Property ;
    rdfs:label 'Environmental Standard' ;
    rdfs:comment 'Environmental management system standard under which this certification was issued (e.g., ISO 14001, ISO 50001 for energy management).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalSafetyLevel rdf:type rdf:Property ;
    rdfs:label 'Functional Safety Level' ;
    rdfs:comment 'Functional safety integrity level achieved by the product under ISO 26262 (ASIL A/B/C/D for automotive) or IEC 61508 (SIL 1/2/3/4 for industrial) standards. ASIL (Automotive Safety Integrity Level), SIL (Safety Integrity Level). [ENUM-REF-CANDIDATE: ASIL_A|ASIL_B|ASIL_C|ASIL_D|SIL_1|SIL_2|SIL_3|SIL_4|not_applicable — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousSubstanceDeclaration rdf:type rdf:Property ;
    rdfs:label 'Hazardous Substance Declaration' ;
    rdfs:comment 'Detailed declaration of hazardous substances present in the product, including substance names, CAS (Chemical Abstracts Service) numbers, concentration levels, and compliance status with RoHS, REACH, and TSCA regulations.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOwner rdf:type rdf:Property ;
    rdfs:label 'Internal Owner' ;
    rdfs:comment 'Name or employee identifier of the internal compliance manager or product quality engineer responsible for maintaining this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the compliance certification was officially issued by the certification body.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityManagementStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Management Standard' ;
    rdfs:comment 'Quality management system standard under which this certification was issued (e.g., ISO 9001, IATF 16949, AS9100, ISO 13485).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Frequency Months' ;
    rdfs:comment 'Number of months between required recertification cycles. Null if recertification is not required or is event-driven rather than time-based.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Recertification Required' ;
    rdfs:comment 'Boolean flag indicating whether this certification requires periodic recertification or renewal (True) or is a one-time certification (False).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recertificationTriggerEvents rdf:type rdf:Property ;
    rdfs:label 'Recertification Trigger Events' ;
    rdfs:comment 'Comma-separated list of business events that trigger mandatory recertification (e.g., design change, process node migration, package change, supplier change, PCN issuance, material substitution).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedCountries rdf:type rdf:Property ;
    rdfs:label 'Restricted Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes to which export or sale of this product is restricted or prohibited under applicable export control regulations.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Url' ;
    rdfs:comment 'URL or file path to the repository location containing supporting documentation, test reports, certificates, and compliance declarations for this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testLaboratory rdf:type rdf:Property ;
    rdfs:label 'Test Laboratory' ;
    rdfs:comment 'Name of the accredited testing laboratory that performed the compliance testing and analysis supporting this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'Reference number of the official test report or assessment document that supports this compliance certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Reference to the automatic test equipment (ATE) test pattern, design verification plan test case, or simulation run that reproduces the errata. Used for regression testing and validation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:detectionTestProgramId rdf:type rdf:Property ;
    rdfs:label 'Detection Test Program Id' ;
    rdfs:comment 'Foreign key linking to test.test_program. Business justification: Errata are often discovered via specific test programs. Root cause analysis and test coverage improvement initiatives require linking errata to the test program that detected (or failed to detect) the' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:errataIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Errata Ic Catalog Id' ;
    rdfs:comment 'Reference to the affected integrated circuit (IC) product, system on chip (SoC), application-specific integrated circuit (ASIC), or field-programmable gate array (FPGA) product.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Silicon errata affecting functional safety (automotive ISO 26262, medical IEC 62304) or security features require regulatory disclosure filings. Links technical defects to mandatory safety notificatio' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:affectedRevisions rdf:type rdf:Property ;
    rdfs:label 'Affected Revisions' ;
    rdfs:comment 'Comma-separated list of all silicon revisions affected by this errata (e.g., A0,A1,B0). Used to determine scope of customer impact.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedUseCases rdf:type rdf:Property ;
    rdfs:label 'Affected Use Cases' ;
    rdfs:comment 'Description of customer application scenarios or operating modes impacted by the errata (e.g., high-speed PCIe Gen4 operation, concurrent multi-channel DMA, low-power sleep modes).' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessImpact rdf:type rdf:Property ;
    rdfs:label 'Business Impact' ;
    rdfs:comment 'Assessment of commercial and operational impact including potential revenue risk, customer satisfaction impact, warranty exposure, and time to market (TTM) implications.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Reason for closing the errata record. Fixed in Silicon: corrected in new revision; Fixed in Software: resolved via patch; Workaround Sufficient: mitigation acceptable; Product EOL: end-of-life product; Not Reproducible: cannot verify; Working as Designed: not a defect.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerDisclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Disclosure Status' ;
    rdfs:comment 'Status of customer communication regarding this errata. Not Disclosed: internal only; Pending Approval: awaiting management approval; Disclosed NDA: shared under non-disclosure agreement; Disclosed Public: published in public errata sheet.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'Date when the errata was first communicated to customers via product change notification (PCN), errata sheet update, or technical advisory. Null if not yet disclosed.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveredBy rdf:type rdf:Property ;
    rdfs:label 'Discovered By' ;
    rdfs:comment 'Source or method by which the errata was discovered. Internal Validation: found during wafer testing or quality assurance; Customer Report: reported by design-in customer; Field Failure: observed in production deployment; Design Verification: identified during design for testability (DFT) or automatic test pattern generation (ATPG).' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveredDate rdf:type rdf:Property ;
    rdfs:label 'Discovered Date' ;
    rdfs:comment 'Date when the silicon bug or functional deviation was first identified, either during internal validation, customer testing, or field deployment.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringOwner rdf:type rdf:Property ;
    rdfs:label 'Engineering Owner' ;
    rdfs:comment 'Name or identifier of the design engineer or engineering team responsible for investigating and resolving this errata. Used for accountability and workload tracking.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errataNumber rdf:type rdf:Property ;
    rdfs:label 'Errata Number' ;
    rdfs:comment 'Business identifier for the errata record, typically formatted as product-family prefix followed by sequential number (e.g., SOC-001234, FPGA-000567). Used in customer communications and product change notifications (PCN).' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errataStatus rdf:type rdf:Property ;
    rdfs:label 'Errata Status' ;
    rdfs:comment 'Current lifecycle status of the errata record. Draft: initial documentation; Under Review: engineering validation; Confirmed: verified silicon bug; Disclosed: communicated to customers; Resolved: fix available; Closed: no longer applicable.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixPlan rdf:type rdf:Property ;
    rdfs:label 'Fix Plan' ;
    rdfs:comment 'Planned resolution approach for the errata. Next Silicon Revision: will be corrected in next tapeout; Software Patch: addressable via firmware/driver update; No Fix Planned: low priority or end-of-life (EOL) product; Under Evaluation: fix strategy being assessed.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixTargetRevision rdf:type rdf:Property ;
    rdfs:label 'Fix Target Revision' ;
    rdfs:comment 'Silicon stepping or revision where the errata will be corrected (e.g., C0, D1). Null if fix is software-only or no fix planned.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalBlock rdf:type rdf:Property ;
    rdfs:label 'Functional Block' ;
    rdfs:comment 'Name of the intellectual property (IP) core, register transfer level (RTL) module, or functional block where the errata occurs (e.g., PCIe Controller, DDR PHY, CPU Core, DMA Engine).' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Customer Count' ;
    rdfs:comment 'Estimated or actual number of customers affected by this errata based on product shipments and silicon revision distribution. Used for risk assessment and communication prioritization.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryImpact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact' ;
    rdfs:comment 'Assessment of whether the errata affects compliance with industry standards or regulatory requirements such as automotive IATF 16949, functional safety ISO 26262, or export control ITAR/EAR classifications. Null if no regulatory impact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the errata was resolved either through silicon revision fix, software patch release, or closure decision. Null if still open or under evaluation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Engineering analysis of the underlying silicon defect or design flaw causing the errata. May reference RTL logic error, timing violation, or process variation sensitivity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Business impact severity of the errata. Critical: system failure or data corruption; Major: significant functional impact; Moderate: limited functional impact with workaround; Minor: cosmetic or edge-case issue.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siliconRevision rdf:type rdf:Property ;
    rdfs:label 'Silicon Revision' ;
    rdfs:comment 'Silicon stepping or revision identifier where the errata was discovered (e.g., A0, B1, C2). Corresponds to mask revision in the fabrication process.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:symptomDescription rdf:type rdf:Property ;
    rdfs:label 'Symptom Description' ;
    rdfs:comment 'Detailed technical description of the observable behavior or functional deviation caused by the silicon bug. Includes conditions under which the issue manifests.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Concise summary title of the silicon bug or functional deviation. Used in errata lists and customer-facing documentation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toRevision rdf:type rdf:Property ;
    rdfs:label 'To Revision' ;
    rdfs:comment 'FK to product.product_revision.product_revision_id — Errata are specific to a silicon revision/stepping. Must link to the affected revision.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when engineering verification of the errata was completed and status changed to verified or cannot reproduce. Null if verification still in progress or not started.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workaroundAvailable rdf:type rdf:Property ;
    rdfs:label 'Workaround Available' ;
    rdfs:comment 'Indicates whether a software, firmware, or operational workaround exists to mitigate the errata impact. True if workaround documented; False if no mitigation available.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workaroundDescription rdf:type rdf:Property ;
    rdfs:label 'Workaround Description' ;
    rdfs:comment 'Detailed instructions for software, firmware, or operational workaround to avoid or mitigate the errata. May include register configuration changes, driver patches, or usage restrictions. Null if no workaround available.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workaroundPerformanceImpact rdf:type rdf:Property ;
    rdfs:label 'Workaround Performance Impact' ;
    rdfs:comment 'Description of any power, performance, or area (PPA) degradation introduced by the workaround (e.g., 5% throughput reduction, 10mW additional power consumption, increased latency). Null if no measurable impact or no workaround.' ;
    rdfs:domain ind:Errata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultMaterialStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Default Material Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Process flows may specify default WIP staging or material storage locations for flow execution. Supports fab layout planning, material handling automation, and flow-level logistics optimization in sem' ;
    rdfs:domain ind:Flow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:flowProcessTechnologyNodeId rdf:type rdf:Property ;
    rdfs:label 'Flow Process Technology Node Id' ;
    rdfs:comment 'FK to process.technology_node.technology_node_id — Every process flow is designed for a specific technology node. This is the top-level classification relationship enabling node-based process management.' ;
    rdfs:domain ind:Flow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessTechnologyNode .

ind:primaryFlowProcessTechnologyNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Flow Process Technology Node Id' ;
    rdfs:comment 'Foreign key linking to process.process_technology_node. Business justification: A process flow is defined for a particular technology node; linking directly within the process domain eliminates cross-domain indirection.' ;
    rdfs:domain ind:Flow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessTechnologyNode .

ind:baselineCpk rdf:type rdf:Property ;
    rdfs:label 'Baseline Cpk' ;
    rdfs:comment 'Baseline process capability index (Cpk) representing the statistical process control capability of the flow at qualification.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalLayerCount rdf:type rdf:Property ;
    rdfs:label 'Critical Layer Count' ;
    rdfs:comment 'Number of critical layers requiring advanced lithography techniques (EUV, multi-patterning, or tight overlay control).' ;
    rdfs:domain ind:Flow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:euvLayerCount rdf:type rdf:Property ;
    rdfs:label 'Euv Layer Count' ;
    rdfs:comment 'Number of layers using Extreme Ultraviolet (EUV) lithography in the process flow.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flowCode rdf:type rdf:Property ;
    rdfs:label 'Flow Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the process flow in manufacturing execution systems and production planning. Used as the external business identifier.' ;
    rdfs:domain ind:Flow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowName rdf:type rdf:Property ;
    rdfs:label 'Flow Name' ;
    rdfs:comment 'Business name of the process flow, typically indicating the technology node and device family (e.g., \'5nm FinFET Logic Flow\', \'28nm CMOS Analog Flow\').' ;
    rdfs:domain ind:Flow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaselineFlow rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Flow' ;
    rdfs:comment 'Flag indicating whether this is the baseline (reference) process flow for the technology node. True if baseline, False otherwise.' ;
    rdfs:domain ind:Flow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lithographyLayerCount rdf:type rdf:Property ;
    rdfs:label 'Lithography Layer Count' ;
    rdfs:comment 'Total number of photolithography (patterning) layers in the complete process flow.' ;
    rdfs:domain ind:Flow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerOrganization rdf:type rdf:Property ;
    rdfs:label 'Owner Organization' ;
    rdfs:comment 'Process engineering organization or department responsible for this process flow (e.g., \'Advanced Logic Process\', \'Memory Process Engineering\').' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFlowDescription rdf:type rdf:Property ;
    rdfs:label 'Process Flow Description' ;
    rdfs:comment 'Detailed textual description of the process flow, including key process characteristics, intended applications, and any special considerations.' ;
    rdfs:domain ind:Flow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsMultiPatterning rdf:type rdf:Property ;
    rdfs:label 'Supports Multi Patterning' ;
    rdfs:comment 'Flag indicating whether the process flow includes multi-patterning lithography techniques (LELE, SADP, SAQP). True if multi-patterning is used, False otherwise.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalStepCount rdf:type rdf:Property ;
    rdfs:label 'Total Step Count' ;
    rdfs:comment 'Total number of unit process steps in the complete flow from wafer start through final inspection.' ;
    rdfs:domain ind:Flow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Material Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Process steps consume chemicals, gases, and materials from specific fab storage locations (WIP staging areas, chemical cabinets). Essential for material traceability and fab logistics planning in semi' ;
    rdfs:domain ind:Step ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryProcessFlowId rdf:type rdf:Property ;
    rdfs:label 'Primary Process Flow Id' ;
    rdfs:comment 'Foreign key linking to process.process_process_flow. Business justification: A process step belongs to a process flow; adding internal FK enables direct navigation within the process domain.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Flow .

ind:qualifiedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Qualified Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Process steps are often qualified for specific equipment/material suppliers (e.g., Applied Materials etch chamber with Lam Research-qualified recipe). Critical for vendor-specific process control, sup' ;
    rdfs:domain ind:Process ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:stepFlowId rdf:type rdf:Property ;
    rdfs:label 'Step Flow Id' ;
    rdfs:comment 'FK to process.process_flow.process_flow_id — Every process step must reference its parent process flow. This is the fundamental header-to-line relationship in the domain. Without this FK, you cannot reconstruct the ordered sequence of steps in a' ;
    rdfs:domain ind:Step ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Flow .

ind:cycleTimeTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Target Minutes' ;
    rdfs:comment 'Target processing time for this step in minutes, used for manufacturing planning, scheduling, and throughput optimization.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doseTarget rdf:type rdf:Property ;
    rdfs:label 'Dose Target' ;
    rdfs:comment 'Target ion implantation dose in ions per square centimeter, or exposure dose in millijoules per square centimeter for lithography steps.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyTargetKev rdf:type rdf:Property ;
    rdfs:label 'Energy Target Kev' ;
    rdfs:comment 'Target ion implantation energy in kilo-electron volts (keV), controlling the depth of dopant penetration into the silicon substrate.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gasFlowRateSccm rdf:type rdf:Property ;
    rdfs:label 'Gas Flow Rate Sccm' ;
    rdfs:comment 'Nominal gas flow rate in standard cubic centimeters per minute (SCCM) for process steps involving gas delivery such as CVD or etch.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCriticalStep rdf:type rdf:Property ;
    rdfs:label 'Is Critical Step' ;
    rdfs:comment 'Boolean flag indicating whether this step is classified as critical for yield, quality, or device performance, requiring enhanced monitoring and control.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReworkAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Rework Allowed' ;
    rdfs:comment 'Boolean flag indicating whether wafers can be reworked or reprocessed through this step if defects or out-of-spec conditions are detected.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerSetpointWatts rdf:type rdf:Property ;
    rdfs:label 'Power Setpoint Watts' ;
    rdfs:comment 'Nominal RF or DC power setpoint in watts for plasma-based process steps such as reactive ion etch or PECVD.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressureSetpointTorr rdf:type rdf:Property ;
    rdfs:label 'Pressure Setpoint Torr' ;
    rdfs:comment 'Nominal chamber pressure setpoint in Torr for vacuum process steps such as CVD, PVD, or plasma etch.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Numeric ordering of this step within the parent process flow, determining the execution sequence in the manufacturing line.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepName rdf:type rdf:Property ;
    rdfs:label 'Step Name' ;
    rdfs:comment 'Human-readable name of the process step, describing the operation performed (e.g., \'Gate Oxide CVD\', \'Contact Lithography\', \'Metal 1 Etch\').' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepNumber rdf:type rdf:Property ;
    rdfs:label 'Step Number' ;
    rdfs:comment 'Business identifier for the process step, typically a hierarchical or sequential code used in manufacturing documentation and traveler cards.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCdNm rdf:type rdf:Property ;
    rdfs:label 'Target Cd Nm' ;
    rdfs:comment 'Target critical dimension in nanometers for lithography and etch steps, defining the feature size specification.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLayer rdf:type rdf:Property ;
    rdfs:label 'Target Layer' ;
    rdfs:comment 'The specific material layer or structure being processed in this step (e.g., \'Poly Gate\', \'Metal 2\', \'Contact Via\', \'STI Oxide\').' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThicknessAngstrom rdf:type rdf:Property ;
    rdfs:label 'Target Thickness Angstrom' ;
    rdfs:comment 'Target film thickness in angstroms for deposition steps, used as the process control specification.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureSetpointCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Setpoint Celsius' ;
    rdfs:comment 'Nominal process temperature setpoint in degrees Celsius for thermal process steps such as deposition, diffusion, or annealing.' ;
    rdfs:domain ind:Step ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toolClass rdf:type rdf:Property ;
    rdfs:label 'Tool Class' ;
    rdfs:comment 'Equipment class or tool type required to execute this process step (e.g., \'EUV Scanner\', \'PECVD Reactor\', \'CMP Polisher\', \'Ion Implanter\').' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Baseline Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: Recipes often developed and baselined on specific chamber. Recipe management, transfer protocols, and chamber matching studies require baseline chamber attribution in semiconductor process engineering' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:defaultFabToolId rdf:type rdf:Property ;
    rdfs:label 'Default Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: A recipe is authored for a specific fab tool model; the FK supports recipe-tool compatibility checks and tool-specific parameter validation.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:cmpPadType rdf:type rdf:Property ;
    rdfs:label 'Cmp Pad Type' ;
    rdfs:comment 'CMP polishing pad material and type identifier. Null for non-CMP recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmpPlatenPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Cmp Platen Pressure Psi' ;
    rdfs:comment 'Downforce pressure in PSI applied to wafer during CMP. Null for non-CMP recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmpRemovalTargetNm rdf:type rdf:Property ;
    rdfs:label 'Cmp Removal Target Nm' ;
    rdfs:comment 'Target material removal thickness in nanometers for CMP process. Null for non-CMP recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmpTableSpeedRpm rdf:type rdf:Property ;
    rdfs:label 'Cmp Table Speed Rpm' ;
    rdfs:comment 'Platen rotation speed in RPM during CMP. Null for non-CMP recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionMethod rdf:type rdf:Property ;
    rdfs:label 'Deposition Method' ;
    rdfs:comment 'Thin film deposition technique: LPCVD (low pressure chemical vapor deposition), PECVD (plasma enhanced CVD), ALD (atomic layer deposition), PVD (physical vapor deposition), EPI (epitaxy), MOCVD (metal-organic CVD), or MBE (molecular beam epitaxy). Null for non-deposition recipes. [ENUM-REF-CANDIDATE: lpcvd|pecvd|ald|pvd|epi|mocvd|mbe — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositionPressureTorr rdf:type rdf:Property ;
    rdfs:label 'Deposition Pressure Torr' ;
    rdfs:comment 'Process chamber pressure in Torr during deposition. Null for non-deposition recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionRfPowerW rdf:type rdf:Property ;
    rdfs:label 'Deposition Rf Power W' ;
    rdfs:comment 'Radio frequency power in Watts for plasma-enhanced deposition processes (PECVD). Null for non-plasma deposition recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionTargetThicknessNm rdf:type rdf:Property ;
    rdfs:label 'Deposition Target Thickness Nm' ;
    rdfs:comment 'Target film thickness in nanometers for deposition processes. Null for non-deposition recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Deposition Temperature C' ;
    rdfs:comment 'Process chamber temperature in degrees Celsius during deposition. Null for non-deposition recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchChemistry rdf:type rdf:Property ;
    rdfs:label 'Etch Chemistry' ;
    rdfs:comment 'Primary etchant chemistry or gas mixture (e.g., CF4/O2, HBr/Cl2, SF6, HF/HNO3). Null for non-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etchPressureMtorr rdf:type rdf:Property ;
    rdfs:label 'Etch Pressure Mtorr' ;
    rdfs:comment 'Process chamber pressure in milliTorr during dry etch. Null for non-dry-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchRfBiasPowerW rdf:type rdf:Property ;
    rdfs:label 'Etch Rf Bias Power W' ;
    rdfs:comment 'RF bias power in Watts controlling ion bombardment energy in reactive ion etch. Null for non-plasma-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchRfSourcePowerW rdf:type rdf:Property ;
    rdfs:label 'Etch Rf Source Power W' ;
    rdfs:comment 'RF source power in Watts for plasma generation in reactive ion etch. Null for non-plasma-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchSelectivityRatio rdf:type rdf:Property ;
    rdfs:label 'Etch Selectivity Ratio' ;
    rdfs:comment 'Ratio of etch rate of target material to etch rate of mask or underlying material, indicating process selectivity. Null for non-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etchType rdf:type rdf:Property ;
    rdfs:label 'Etch Type' ;
    rdfs:comment 'Etch process category: dry (gas-phase), wet (liquid chemical), plasma, reactive ion etch (RIE), or deep reactive ion etch (DRIE). Null for non-etch recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implantDoseCm2 rdf:type rdf:Property ;
    rdfs:label 'Implant Dose Cm2' ;
    rdfs:comment 'Ion implantation dose in ions per square centimeter controlling dopant concentration. Null for non-implant recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantTiltAngleDeg rdf:type rdf:Property ;
    rdfs:label 'Implant Tilt Angle Deg' ;
    rdfs:comment 'Wafer tilt angle in degrees during ion implantation to control channeling effects. Null for non-implant recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implantTwistAngleDeg rdf:type rdf:Property ;
    rdfs:label 'Implant Twist Angle Deg' ;
    rdfs:comment 'Wafer twist (rotation) angle in degrees during ion implantation to control channeling effects. Null for non-implant recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithoExposureDoseMjCm2 rdf:type rdf:Property ;
    rdfs:label 'Litho Exposure Dose Mj Cm2' ;
    rdfs:comment 'Exposure energy dose in mJ/cm² for photoresist exposure. Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithoFocusOffsetNm rdf:type rdf:Property ;
    rdfs:label 'Litho Focus Offset Nm' ;
    rdfs:comment 'Focus offset in nanometers from best focus position for process window optimization. Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithoIlluminationMode rdf:type rdf:Property ;
    rdfs:label 'Litho Illumination Mode' ;
    rdfs:comment 'Illumination source configuration (e.g., conventional, annular, dipole, quadrupole, freeform). Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lithoNumericalAperture rdf:type rdf:Property ;
    rdfs:label 'Litho Numerical Aperture' ;
    rdfs:comment 'Numerical aperture of the lithography lens system controlling resolution. Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithoScannerModel rdf:type rdf:Property ;
    rdfs:label 'Litho Scanner Model' ;
    rdfs:comment 'Photolithography scanner tool model (e.g., ASML NXT:2000i, Nikon NSR-S630D). Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lithoWavelengthNm rdf:type rdf:Property ;
    rdfs:label 'Litho Wavelength Nm' ;
    rdfs:comment 'Exposure wavelength in nanometers (e.g., 193 for ArF DUV, 13.5 for EUV). Null for non-lithography recipes.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumableSupplierId rdf:type rdf:Property ;
    rdfs:label 'Consumable Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Tracks actual supplier of consumables/materials used in each lot run. Critical for yield correlation analysis (e.g., "all lots with Supplier X batch Y showed 5% yield drop"), defect root cause, and su' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:primaryLotRecipeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lot Recipe Id' ;
    rdfs:comment 'Reference to the actual recipe executed for this process step. May differ from the planned recipe if engineering overrides or recipe revisions occurred. Links to the recipe master in the fabrication domain.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recipe .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the lot processing completed on the equipment. Used to calculate actual process duration and equipment throughput.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the lot processing began on the equipment. Captured from MES equipment interface for cycle time analysis and equipment utilization tracking.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controlChartRuleViolated rdf:type rdf:Property ;
    rdfs:label 'Control Chart Rule Violated' ;
    rdfs:comment 'Specific SPC rule violated if control_chart_violation_flag is true (e.g., \'Western Electric Rule 1: Point beyond 3-sigma\', \'Nelson Rule 2: Nine points in a row on same side of centerline\'). Null if no violation.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChartViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Control Chart Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this process run violated SPC control chart rules (e.g., out-of-control limits, run rules, trend rules). True indicates a violation requiring engineering investigation.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectDensityPerCm2 rdf:type rdf:Property ;
    rdfs:label 'Defect Density Per Cm2' ;
    rdfs:comment 'Calculated defect density in defects per square centimeter for this lot at this process step. Key yield predictor and process health indicator.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementResultValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Result Value' ;
    rdfs:comment 'Primary in-line measurement result collected at this process step (e.g., film thickness, CD (Critical Dimension), overlay, resistivity). The specific measurement type is defined by the process step. Used for real-time SPC and process control.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementSiteCount rdf:type rdf:Property ;
    rdfs:label 'Measurement Site Count' ;
    rdfs:comment 'Number of measurement sites sampled on the wafer(s) for this in-line measurement. Used to assess measurement sampling adequacy and statistical confidence.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processGasFlowSccm rdf:type rdf:Property ;
    rdfs:label 'Process Gas Flow Sccm' ;
    rdfs:comment 'Total process gas flow rate in standard cubic centimeters per minute (SCCM) for this run. Aggregated flow for multi-gas processes; individual gas flows tracked in separate metrology records.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processNotes rdf:type rdf:Property ;
    rdfs:label 'Process Notes' ;
    rdfs:comment 'Free-text notes entered by the operator or process engineer documenting any anomalies, deviations, or special conditions during this process run. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processPowerWatts rdf:type rdf:Property ;
    rdfs:label 'Process Power Watts' ;
    rdfs:comment 'Actual RF or DC power in watts applied during this process run. Key parameter for plasma-based processes including etch, PVD, and PECVD (Plasma-Enhanced Chemical Vapor Deposition).' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Process Qualification Status' ;
    rdfs:comment 'Qualification status of the process step execution. Qualified indicates the process met all capability and stability requirements; not_qualified indicates process failed qualification criteria; pending_qualification indicates qualification in progress; requalification_required indicates process drift detected requiring re-qualification.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Process Temperature C' ;
    rdfs:comment 'Actual process temperature in degrees Celsius recorded during this run. Key process parameter for thermal processes such as CVD (Chemical Vapor Deposition), diffusion, annealing, and oxidation.' ;
    rdfs:domain ind:LotProcessRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineDataPoints rdf:type rdf:Property ;
    rdfs:label 'Baseline Data Points' ;
    rdfs:comment 'Number of data points collected during the baseline period to establish initial control limits. Typically 25-30 subgroups are required for reliable limit calculation.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chartActivationDate rdf:type rdf:Property ;
    rdfs:label 'Chart Activation Date' ;
    rdfs:comment 'Date when the SPC chart was first activated for production monitoring. Marks the beginning of the charts operational lifecycle.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chartName rdf:type rdf:Property ;
    rdfs:label 'Chart Name' ;
    rdfs:comment 'Business-friendly name of the SPC control chart for identification and reporting purposes.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOwner rdf:type rdf:Property ;
    rdfs:label 'Chart Owner' ;
    rdfs:comment 'Name or identifier of the process engineer or team responsible for monitoring and maintaining this SPC chart.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartRetirementDate rdf:type rdf:Property ;
    rdfs:label 'Chart Retirement Date' ;
    rdfs:comment 'Date when the SPC chart was retired from active monitoring. Nullable for active charts. Retired charts are preserved for historical analysis.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chartStatus rdf:type rdf:Property ;
    rdfs:label 'Chart Status' ;
    rdfs:comment 'Current lifecycle status of the SPC chart. Active charts are in production monitoring; suspended charts are temporarily paused; retired charts are no longer used; under review charts are being evaluated for limit adjustments; baseline collection charts are gathering initial data to establish control limits.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartType rdf:type rdf:Property ;
    rdfs:label 'Chart Type' ;
    rdfs:comment 'Type of SPC control chart used for monitoring. Xbar-R (average and range), Xbar-S (average and standard deviation), EWMA (exponentially weighted moving average), CUSUM (cumulative sum), IMR (individual and moving range), P-chart (proportion defective), NP-chart (number defective), C-chart (count of defects), U-chart (defects per unit). [ENUM-REF-CANDIDATE: xbar_r|xbar_s|ewma|cusum|imr|p_chart|np_chart|c_chart|u_chart — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlLimitCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Control Limit Calculation Method' ;
    rdfs:comment 'Method used to calculate the control limits for this SPC chart. Three sigma uses standard deviation-based limits; six sigma uses tighter limits; Cpk-based derives limits from process capability index; historical baseline uses past performance data; engineering specification uses design requirements.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the source system that provided the measurement data (e.g., KLA ICOS, Camstar MES, inline metrology tool). Enables data lineage tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLimitRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Last Limit Revision Date' ;
    rdfs:comment 'Date when the control limits were last revised or recalculated. Control limits should be periodically reviewed and updated as process capability improves.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'Lower control limit (LCL) for the SPC chart. Typically set at -3 sigma from the target value. Measurements below this limit indicate an out-of-control process.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerWarningLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Warning Limit' ;
    rdfs:comment 'Lower warning limit (LWL) for the SPC chart. Typically set at -2 sigma from the target value. Measurements below this limit trigger a warning but do not necessarily indicate an out-of-control process.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Actual measured value of the monitored parameter at the time of measurement. This is the primary data point plotted on the SPC chart.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Sequence Number' ;
    rdfs:comment 'Sequential number of this measurement within the SPC chart history. Used for time-series analysis and trend detection.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoredParameterName rdf:type rdf:Property ;
    rdfs:label 'Monitored Parameter Name' ;
    rdfs:comment 'Name of the process parameter being monitored by this SPC chart (e.g., critical dimension, film thickness, overlay, etch rate, resistivity).' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocapReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ocap Reference Number' ;
    rdfs:comment 'Reference number of the Out-of-Control Action Plan (OCAP) triggered by this measurement, if applicable. Links to the OCAP tracking system for root cause analysis and corrective action.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Parameter Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the monitored parameter (e.g., nm, angstrom, ohm-cm, percent, degrees Celsius).' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processActionTaken rdf:type rdf:Property ;
    rdfs:label 'Process Action Taken' ;
    rdfs:comment 'Action taken in response to the measurement and any rule violations. None indicates no action required; warning issued indicates notification sent; OCAP triggered indicates Out-of-Control Action Plan initiated; lot hold indicates lot placed on hold; equipment hold indicates equipment taken offline; process adjustment indicates recipe or parameter adjustment made; engineering review indicates escalation to process engineering. [ENUM-REF-CANDIDATE: none|warning_issued|ocap_triggered|lot_hold|equipment_hold|process_adjustment|engineering_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCapabilityIndexCp rdf:type rdf:Property ;
    rdfs:label 'Process Capability Index Cp' ;
    rdfs:comment 'Process capability index Cp, calculated as (USL - LSL) / (6 * sigma). Measures the potential capability of the process to meet specifications, assuming the process is centered. Values > 1.33 are typically considered acceptable.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processCapabilityIndexCpk rdf:type rdf:Property ;
    rdfs:label 'Process Capability Index Cpk' ;
    rdfs:comment 'Process capability index Cpk, calculated as min[(USL - mean) / (3 * sigma), (mean - LSL) / (3 * sigma)]. Measures the actual capability of the process to meet specifications, accounting for process centering. Values > 1.33 are typically considered acceptable.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleViolationsTriggered rdf:type rdf:Property ;
    rdfs:label 'Rule Violations Triggered' ;
    rdfs:comment 'Comma-separated list of SPC rule violations detected for this measurement (e.g., Western Electric rules 1-4, Nelson rules 1-8). Examples: Rule 1 (one point beyond 3 sigma), Rule 2 (nine points in a row on same side of center line), Rule 3 (six points in a row steadily increasing or decreasing).' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency' ;
    rdfs:comment 'Frequency at which measurements are taken for this SPC chart (e.g., every lot, every 5 lots, every 8 hours, per wafer).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteXCoordinate rdf:type rdf:Property ;
    rdfs:label 'Site X Coordinate' ;
    rdfs:comment 'X-axis coordinate of the measurement site on the wafer surface. Used for spatial analysis and mapping of process uniformity.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteYCoordinate rdf:type rdf:Property ;
    rdfs:label 'Site Y Coordinate' ;
    rdfs:comment 'Y-axis coordinate of the measurement site on the wafer surface. Used for spatial analysis and mapping of process uniformity.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Specification Lower Limit' ;
    rdfs:comment 'Lower specification limit (LSL) defined by the process design or customer requirements. Represents the minimum acceptable value for the parameter. Used in capability index calculations.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Specification Upper Limit' ;
    rdfs:comment 'Upper specification limit (USL) defined by the process design or customer requirements. Represents the maximum acceptable value for the parameter. Used in capability index calculations.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Target or nominal value for the monitored parameter. Represents the ideal process center line.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'Upper control limit (UCL) for the SPC chart. Typically set at +3 sigma from the target value. Measurements exceeding this limit indicate an out-of-control process.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperWarningLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Warning Limit' ;
    rdfs:comment 'Upper warning limit (UWL) for the SPC chart. Typically set at +2 sigma from the target value. Measurements exceeding this limit trigger a warning but do not necessarily indicate an out-of-control process.' ;
    rdfs:domain ind:SpcControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spcMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Spc Measurement Id' ;
    rdfs:comment 'Unique identifier for the SPC measurement data point. Primary key for the SPC measurement record.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metrologyRunId rdf:type rdf:Property ;
    rdfs:label 'Metrology Run Id' ;
    rdfs:comment 'The identifier of the measurement run or batch that this data point belongs to. Groups multiple measurements taken during a single metrology session or sampling event.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetrologyRun .

ind:deviationFromTarget rdf:type rdf:Property ;
    rdfs:label 'Deviation From Target' ;
    rdfs:comment 'The calculated difference between the measured value and the target value. Positive values indicate measurements above target; negative values indicate measurements below target.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementOnChart rdf:type rdf:Property ;
    rdfs:label 'Measurement On Chart' ;
    rdfs:comment 'FK to process.process_spc_control_chart.process_spc_control_chart_id — Every SPC measurement data point belongs to a specific control chart. This is the fundamental transaction-to-master relationship for SPC.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'The quality status of the measurement data point. Indicates whether the measurement is valid for SPC analysis or requires review, retest, or exclusion due to equipment errors or data quality issues.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'The category of measurement based on when and how it was taken. Distinguishes between inline production measurements, offline lab measurements, final inspection, process qualification runs, and dedicated monitor wafer measurements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfControlFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Control Flag' ;
    rdfs:comment 'Boolean indicator of whether this measurement triggered an out-of-control condition. True if the measurement violated control limits or SPC rules requiring corrective action.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfSpecFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Spec Flag' ;
    rdfs:comment 'Boolean indicator of whether this measurement exceeded specification limits. True if the measured value fell outside the upper or lower specification limits defined by engineering.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'The standardized code or abbreviation for the measured parameter. Used for system integration and cross-tool correlation (e.g., CD_GATE, THICK_OXIDE, OVL_X, RS_POLY).' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'The name of the process parameter being measured. Examples include critical dimension (CD), film thickness, overlay, sheet resistance, particle count, or other process-specific metrics.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleViolationFlags rdf:type rdf:Property ;
    rdfs:label 'Rule Violation Flags' ;
    rdfs:comment 'Comma-separated list of SPC rule violations triggered by this measurement. Includes Western Electric rules (e.g., WE1, WE2, WE3, WE4) and Nelson rules (e.g., N1, N2, N3) that detected out-of-control conditions or trends.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sigmaLevel rdf:type rdf:Property ;
    rdfs:label 'Sigma Level' ;
    rdfs:comment 'The number of standard deviations the measured value is from the process mean. Used to assess process capability and identify outliers.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteNumber rdf:type rdf:Property ;
    rdfs:label 'Site Number' ;
    rdfs:comment 'The sequential identifier of the measurement site within the wafer sampling plan. Corresponds to the predefined site map used for metrology sampling.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specificationLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Specification Limit Upper' ;
    rdfs:comment 'The upper specification limit defined by the process design. Represents the maximum acceptable value for the parameter as defined by engineering requirements.' ;
    rdfs:domain ind:SpcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capabilityId rdf:type rdf:Property ;
    rdfs:label 'Capability Id' ;
    rdfs:comment 'Unique identifier for the process capability record.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analysisTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Timestamp' ;
    rdfs:comment 'Date and time when the capability analysis was performed and this record was generated.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method used for capability assessment: short-term (initial process qualification), long-term (ongoing production monitoring), initial (pre-production), or ongoing (continuous monitoring).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Capability Status' ;
    rdfs:comment 'Overall assessment of process capability status based on Cpk threshold criteria. Typically capable (Cpk >= 1.33), marginal (1.0 <= Cpk < 1.33), incapable (Cpk < 1.0).' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChartType rdf:type rdf:Property ;
    rdfs:label 'Control Chart Type' ;
    rdfs:comment 'Type of Statistical Process Control (SPC) control chart used for monitoring this parameter (e.g., X-bar R, X-bar S, Individuals, P-chart, C-chart, U-chart).' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpIndex rdf:type rdf:Property ;
    rdfs:label 'Cp Index' ;
    rdfs:comment 'Process capability index Cp measuring the potential capability of the process assuming it is centered on target. Calculated as (USL - LSL) / (6 * standard deviation).' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpkIndex rdf:type rdf:Property ;
    rdfs:label 'Cpk Index' ;
    rdfs:comment 'Process capability index Cpk measuring the actual capability of the process accounting for centering. Calculated as minimum of [(USL - mean) / (3 * standard deviation), (mean - LSL) / (3 * standard deviation)].' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the time window over which process capability was calculated.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the time window over which process capability was calculated.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'Lower specification limit defining the minimum acceptable value for the parameter.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanValue rdf:type rdf:Property ;
    rdfs:label 'Mean Value' ;
    rdfs:comment 'Arithmetic mean of the parameter measurements over the evaluation period.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Metrology technique or measurement method used to collect parameter data (e.g., optical CD, SEM, ellipsometry, XRF, electrical test).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalityTestResult rdf:type rdf:Property ;
    rdfs:label 'Normality Test Result' ;
    rdfs:comment 'Result of statistical normality test (e.g., Anderson-Darling, Shapiro-Wilk) to validate that data follows normal distribution, a prerequisite for capability index calculation.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfControlPoints rdf:type rdf:Property ;
    rdfs:label 'Out Of Control Points' ;
    rdfs:comment 'Number of data points that violated SPC control rules during the evaluation period, indicating special cause variation.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppIndex rdf:type rdf:Property ;
    rdfs:label 'Pp Index' ;
    rdfs:comment 'Process performance index Pp measuring the overall performance of the process over time. Calculated as (USL - LSL) / (6 * overall standard deviation).' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppkIndex rdf:type rdf:Property ;
    rdfs:label 'Ppk Index' ;
    rdfs:comment 'Process performance index Ppk measuring the actual performance of the process accounting for centering over time. Calculated as minimum of [(USL - mean) / (3 * overall standard deviation), (mean - LSL) / (3 * overall standard deviation)].' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'Major process area classification: FEOL (Front End of Line), MOL (Middle of Line), or BEOL (Back End of Line).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCount rdf:type rdf:Property ;
    rdfs:label 'Sample Count' ;
    rdfs:comment 'Number of measurement samples included in the capability calculation.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardDeviation rdf:type rdf:Property ;
    rdfs:label 'Standard Deviation' ;
    rdfs:comment 'Standard deviation of the parameter measurements, representing process variation.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subgroupSize rdf:type rdf:Property ;
    rdfs:label 'Subgroup Size' ;
    rdfs:comment 'Number of measurements per subgroup used in the SPC control chart analysis.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'Directional trend of capability indices compared to previous evaluation periods, indicating process improvement or degradation.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'Upper specification limit defining the maximum acceptable value for the parameter.' ;
    rdfs:domain ind:Capability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assistFeatureRules rdf:type rdf:Property ;
    rdfs:label 'Assist Feature Rules' ;
    rdfs:comment 'Description or reference to the sub-resolution assist feature (SRAF) placement rules included in this OPC rule set.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edaToolName rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Name' ;
    rdfs:comment 'Name of the specific EDA tool product used for OPC processing (e.g., Proteus, Calibre nmOPC).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edaToolVendor rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Vendor' ;
    rdfs:comment 'Vendor of the EDA tool used to generate and apply this OPC rule set (e.g., Synopsys, Cadence, Mentor Graphics).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:illuminationMode rdf:type rdf:Property ;
    rdfs:label 'Illumination Mode' ;
    rdfs:comment 'Illumination configuration used in the scanner (e.g., conventional, annular, dipole, quadrupole, freeform).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lithographyWavelengthNm rdf:type rdf:Property ;
    rdfs:label 'Lithography Wavelength Nm' ;
    rdfs:comment 'Wavelength of the lithography exposure light in nanometers (e.g., 193 for DUV, 13.5 for EUV).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meefFeatureType rdf:type rdf:Property ;
    rdfs:label 'Meef Feature Type' ;
    rdfs:comment 'Type of feature for which the MEEF value was characterized (e.g., line, space, contact, via, dense, isolated).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meefMeasurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Meef Measurement Methodology' ;
    rdfs:comment 'Methodology used to measure and characterize MEEF (e.g., wafer metrology, simulation, focus-exposure matrix).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meefPitchNm rdf:type rdf:Property ;
    rdfs:label 'Meef Pitch Nm' ;
    rdfs:comment 'Feature pitch in nanometers at which the MEEF value was measured.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meefTargetCdNm rdf:type rdf:Property ;
    rdfs:label 'Meef Target Cd Nm' ;
    rdfs:comment 'Target critical dimension in nanometers for the MEEF characterization measurement.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opcModelType rdf:type rdf:Property ;
    rdfs:label 'Opc Model Type' ;
    rdfs:comment 'Type of OPC correction methodology employed in this rule set.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEngineerName rdf:type rdf:Property ;
    rdfs:label 'Owner Engineer Name' ;
    rdfs:comment 'Name of the process engineer or lithography engineer responsible for this OPC rule set.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processBiasTableReference rdf:type rdf:Property ;
    rdfs:label 'Process Bias Table Reference' ;
    rdfs:comment 'Reference identifier to the process bias lookup tables used for CD correction in this OPC rule set.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processWindowDofNm rdf:type rdf:Property ;
    rdfs:label 'Process Window Dof Nm' ;
    rdfs:comment 'Depth of focus in nanometers defining the usable focus range for this OPC rule set and layer.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processWindowElPercent rdf:type rdf:Property ;
    rdfs:label 'Process Window El Percent' ;
    rdfs:comment 'Exposure latitude as a percentage defining the usable dose range for this OPC rule set and layer.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleSetFileFormat rdf:type rdf:Property ;
    rdfs:label 'Rule Set File Format' ;
    rdfs:comment 'File format of the OPC rule set (e.g., proprietary Synopsys format, Cadence format, industry standard).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetFilePath rdf:type rdf:Property ;
    rdfs:label 'Rule Set File Path' ;
    rdfs:comment 'File system path or repository location of the OPC rule set file used by EDA tools (Synopsys, Cadence).' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Set Version' ;
    rdfs:comment 'Version identifier for this OPC rule set, tracking revisions and updates to the correction algorithms.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scannerNumericalAperture rdf:type rdf:Property ;
    rdfs:label 'Scanner Numerical Aperture' ;
    rdfs:comment 'Numerical aperture of the lithography scanner lens system, defining the light-gathering capability and resolution.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sigmaInner rdf:type rdf:Property ;
    rdfs:label 'Sigma Inner' ;
    rdfs:comment 'Inner sigma value defining the illumination pupil fill for off-axis illumination modes.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sigmaOuter rdf:type rdf:Property ;
    rdfs:label 'Sigma Outer' ;
    rdfs:comment 'Outer sigma value defining the illumination pupil fill for off-axis illumination modes.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLayerName rdf:type rdf:Property ;
    rdfs:label 'Target Layer Name' ;
    rdfs:comment 'Name of the lithography layer (e.g., Metal1, Poly, Contact) for which this OPC rule set applies.' ;
    rdfs:domain ind:OpcRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.certification. Business justification: Process qualification must be backed by a certification (e.g., ISO, ISO-9001) to satisfy customer and regulatory requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:obligationRegisterId rdf:type rdf:Property ;
    rdfs:label 'Obligation Register Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation_register. Business justification: Process qualifications may be required to meet regulatory obligations (automotive IATF, aerospace AS9100, medical ISO 13485). Compliance tracking requires linking qualification status to obligation fu' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ObligationRegister .

ind:qualificationFlowId rdf:type rdf:Property ;
    rdfs:label 'Qualification Flow Id' ;
    rdfs:comment 'FK to process.process_process_flow.process_process_flow_id — Process qualifications are conducted against specific process flows or steps. The flow reference establishes what is being qualified.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Flow .

ind:qualifiedToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Qualified Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: Process qualifications often chamber-specific (chamber matching studies). Production release, recipe transfer, and capacity planning require chamber-level qualification status in semiconductor fabs.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:acceptanceCriteriaSummary rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Summary' ;
    rdfs:comment 'High-level summary of the key acceptance criteria that must be met for qualification to pass (e.g., yield > 95%, Cpk > 1.33, defect density < 0.1/cm²).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCpk rdf:type rdf:Property ;
    rdfs:label 'Actual Cpk' ;
    rdfs:comment 'Actual process capability index (Cpk) achieved during qualification testing. Populated upon completion of qualification runs.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Percent' ;
    rdfs:comment 'Actual wafer yield percentage achieved during qualification testing. Populated upon completion of qualification runs.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Description of corrective actions planned or taken to address issues identified during qualification. Applicable for failed qualifications or qualifications requiring follow-up.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Status' ;
    rdfs:comment 'Status of customer approval for this qualification: not_required (no customer approval needed), pending (awaiting customer review), approved (customer approved), rejected (customer rejected).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeSummary rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Summary' ;
    rdfs:comment 'Summary of failure modes observed during qualification testing, if applicable. Used for failed or waived qualifications to document issues encountered.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planReference rdf:type rdf:Property ;
    rdfs:label 'Plan Reference' ;
    rdfs:comment 'Document reference or identifier for the formal qualification plan that defines acceptance criteria, test methodology, and success metrics. May reference PLM document number or file path.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmSystemSource rdf:type rdf:Property ;
    rdfs:label 'Plm System Source' ;
    rdfs:comment 'Source PLM system from which this qualification record was extracted: oracle_agile (Oracle Agile PLM), siemens_teamcenter (Siemens Teamcenter PLM), other.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmWorkflowReference rdf:type rdf:Property ;
    rdfs:label 'Plm Workflow Reference' ;
    rdfs:comment 'Workflow or change order identifier in the source PLM system that tracks the qualification approval process.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationName rdf:type rdf:Property ;
    rdfs:label 'Qualification Name' ;
    rdfs:comment 'Descriptive name of the qualification program, identifying the process or change being qualified.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the qualification program, typically assigned by PLM system. Format: PQ-XXXXXX.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCustomerApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Customer Approval' ;
    rdfs:comment 'Flag indicating whether this qualification requires formal customer approval before production deployment. True for customer-specific processes or foundry qualifications.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Risk level associated with deploying the qualified process to production: low (minimal risk), medium (moderate risk with mitigation), high (significant risk requiring close monitoring), critical (severe risk requiring executive approval).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'Date when the qualification results were formally signed off and approved.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOffEngineerName rdf:type rdf:Property ;
    rdfs:label 'Sign Off Engineer Name' ;
    rdfs:comment 'Name of the process engineer or technical authority who signed off on the qualification results.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the qualification program officially started or is planned to start.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetCpk rdf:type rdf:Property ;
    rdfs:label 'Target Cpk' ;
    rdfs:comment 'Target process capability index (Cpk) that must be achieved for qualification to pass. Typical semiconductor requirement is Cpk >= 1.33.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedFabToolId rdf:type rdf:Property ;
    rdfs:label 'Affected Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: PCNs track affected equipment for change impact analysis, customer notification, and requalification planning. Critical for semiconductor change control and regulatory compliance (automotive, aerospac' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:affectedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Affected Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: PCNs frequently originate from or impact suppliers (e.g., supplier changes chemical formulation requiring process requalification). Mandatory for supply chain change control, customer notification req' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:primaryChangeProcessFlowId rdf:type rdf:Property ;
    rdfs:label 'Primary Change Process Flow Id' ;
    rdfs:comment 'Foreign key linking to process.process_process_flow. Business justification: Change notifications affect a specific process flow; an internal FK provides direct reference within the process domain.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Flow .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Actual date when the process change was implemented in production manufacturing.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedCustomerList rdf:type rdf:Property ;
    rdfs:label 'Affected Customer List' ;
    rdfs:comment 'List of customer names or identifiers who have products affected by this change and require notification per contractual agreements.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedEquipmentList rdf:type rdf:Property ;
    rdfs:label 'Affected Equipment List' ;
    rdfs:comment 'List of manufacturing equipment tools or tool sets impacted by this process change, including tool IDs or model numbers.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedMaterialList rdf:type rdf:Property ;
    rdfs:label 'Affected Material List' ;
    rdfs:comment 'List of raw materials, chemicals, gases, or consumables that are being changed or affected by this process modification.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachments rdf:type rdf:Property ;
    rdfs:label 'Attachments' ;
    rdfs:comment 'References to supporting documentation such as technical specifications, test reports, FMEA analyses, customer communications, or qualification data associated with this PCN.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeClassification rdf:type rdf:Property ;
    rdfs:label 'Change Classification' ;
    rdfs:comment 'Impact classification of the change: major (requires customer approval and qualification), minor (notification required but no requalification), or notification_only (informational, no customer action required).' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business or technical justification for the change, such as yield improvement, cost reduction, obsolescence mitigation, reliability enhancement, or regulatory compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle status of the process change notification in the approval and implementation workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|customer_notified|implemented|cancelled|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Category of change being notified: process (recipe or flow modification), material (raw material or chemical change), equipment (tool or configuration change), design (mask or layout change), facility (fab site or cleanroom change), or supplier (vendor or subcontractor change).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Impact' ;
    rdfs:comment 'Assessment of the financial impact of the process change including implementation costs, ongoing cost savings or increases, and return on investment.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Required' ;
    rdfs:comment 'Indicates whether explicit customer approval is required before implementing the change, typically for major changes affecting form, fit, function, or reliability.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleTimeImpactHours rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Impact Hours' ;
    rdfs:comment 'Expected change in manufacturing cycle time resulting from the process change, measured in hours (positive for increase, negative for reduction).' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalImpact rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact' ;
    rdfs:comment 'Description of any environmental, health, or safety impacts resulting from the process change, including changes to hazardous material usage or waste generation.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTimeShipDate rdf:type rdf:Property ;
    rdfs:label 'Last Time Ship Date' ;
    rdfs:comment 'Final date for shipping products manufactured using the old process before transitioning to the new process.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Implementation Date' ;
    rdfs:comment 'Target date for implementing the process change in production manufacturing.' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yieldImpactPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Impact Percent' ;
    rdfs:comment 'Expected or measured change in manufacturing yield resulting from the process change, expressed as a percentage point change (positive for improvement, negative for degradation).' ;
    rdfs:domain ind:ChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingId rdf:type rdf:Property ;
    rdfs:label 'Booking Id' ;
    rdfs:comment 'Foreign key linking to sales.booking. Business justification: Yield loss events directly impact committed customer bookings — delivery risk assessment and customer notification require linking yield excursions to affected bookings. Semiconductor operations teams' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Booking .

ind:maintenanceEventId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Event Id' ;
    rdfs:comment 'Foreign key linking to equipment.maintenance_event. Business justification: Yield loss often triggers corrective maintenance investigation. 8D problem solving, CAPA closure, and maintenance effectiveness tracking require linking yield loss to corrective maintenance events.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceEvent .

ind:rootCauseSupplierId rdf:type rdf:Property ;
    rdfs:label 'Root Cause Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Yield loss root cause often traces to supplier material issues (e.g., contaminated chemical batch, out-of-spec wafer substrate). Essential for triggering supplier corrective action requests (SCAR), co' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:affectedDieCount rdf:type rdf:Property ;
    rdfs:label 'Affected Die Count' ;
    rdfs:comment 'Number of individual die on the wafer affected by this yield loss event. Used to calculate yield impact and prioritize corrective actions.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the engineer or team assigned to investigate and resolve the yield loss event. Used for workload management and escalation.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpkValue rdf:type rdf:Property ;
    rdfs:label 'Cpk Value' ;
    rdfs:comment 'Process capability index (Cpk) calculated at the time of the yield loss event. Indicates how well the process is centered and controlled relative to specification limits. Values below 1.33 typically indicate process capability issues.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectSizeNm rdf:type rdf:Property ;
    rdfs:label 'Defect Size Nm' ;
    rdfs:comment 'Measured or estimated size of the defect in nanometers. Critical for determining defect criticality and kill ratio at advanced technology nodes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Specific defect type or signature identified during inspection or test. Examples include scratch, particle, void, short, open, bridging, residue, etc. May reference defect classification taxonomy.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method or technique used to detect the yield loss event. Indicates whether detected via inline inspection, offline inspection, electrical test, parametric test, visual inspection, or metrology measurement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedYieldImpactPercent rdf:type rdf:Property ;
    rdfs:label 'Estimated Yield Impact Percent' ;
    rdfs:comment 'Estimated percentage point impact on wafer yield attributable to this event. Calculated from affected die count and total die per wafer. Used for yield loss Pareto analysis.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the yield loss event was detected or recorded. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Timestamp' ;
    rdfs:comment 'Date and time when root cause investigation of the yield loss event was initiated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotHoldApplied rdf:type rdf:Property ;
    rdfs:label 'Lot Hold Applied' ;
    rdfs:comment 'Indicates whether a lot hold was placed on the affected wafer lot as a result of this yield loss event. True if hold applied; false if no hold applied.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the engineer, operator, or automated system that reported or logged the yield loss event. Used for accountability and follow-up.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the yield loss event resolution workflow. Open indicates newly detected; under investigation indicates active RCA; root cause identified indicates RCA complete; corrective action implemented indicates fix deployed; closed indicates event resolved; deferred indicates event accepted or postponed.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the yield loss event was resolved and closed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Used to calculate mean time to resolution (MTTR) for yield events.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business severity classification of the yield loss event based on yield impact, affected volume, and customer impact. Critical indicates immediate action required; major indicates significant yield impact; minor indicates localized impact; negligible indicates minimal business impact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferPositionXMm rdf:type rdf:Property ;
    rdfs:label 'Wafer Position X Mm' ;
    rdfs:comment 'X-coordinate position on the wafer where the yield loss event was detected, in millimeters from wafer center. Used for spatial yield analysis and wafer mapping.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferPositionYMm rdf:type rdf:Property ;
    rdfs:label 'Wafer Position Y Mm' ;
    rdfs:comment 'Y-coordinate position on the wafer where the yield loss event was detected, in millimeters from wafer center. Used for spatial yield analysis and wafer mapping.' ;
    rdfs:domain ind:YieldLossEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossMode rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Mode' ;
    rdfs:comment 'Classification of the yield loss mechanism. Parametric indicates out-of-spec electrical parameters; systematic indicates repeatable defect patterns; random indicates sporadic defects; electrical indicates functional failures; particle indicates contamination; pattern indicates lithography or etch issues; edge indicates wafer edge exclusion. [ENUM-REF-CANDIDATE: parametric|systematic|random|electrical|particle|pattern|edge — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Process ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectInspectionResultId rdf:type rdf:Property ;
    rdfs:label 'Defect Inspection Result Id' ;
    rdfs:comment 'Unique identifier for the defect inspection result record. Primary key.' ;
    rdfs:domain ind:Process ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectInspectionResult .

ind:defectRecordId rdf:type rdf:Property ;
    rdfs:label 'Defect Record Id' ;
    rdfs:comment 'Foreign key linking to quality.defect_record. Business justification: Defect inspection results in the process domain feed into formal defect records in the quality domain. This is a core process→quality data flow in semiconductor fabs — inspection results become qualit' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectRecord .

ind:defectStepId rdf:type rdf:Property ;
    rdfs:label 'Defect Step Id' ;
    rdfs:comment 'FK to process.process_process_step.process_process_step_id — Defect inspections occur at specific process steps in the flow. Step reference provides manufacturing context for defect analysis.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Step .

ind:inspectionRecipeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Recipe Id' ;
    rdfs:comment 'Identifier of the inspection recipe or program used to configure the tool for this inspection run. Defines sensitivity, scan area, and detection parameters.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recipe .

ind:primaryDefectStepId rdf:type rdf:Property ;
    rdfs:label 'Primary Defect Step Id' ;
    rdfs:comment 'Foreign key linking to process.process_process_step. Business justification: Defect inspection results are tied to a specific process step; adding internal FK enables step-level analysis.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Step .

ind:crystalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Crystal Defect Count' ;
    rdfs:comment 'Number of defects classified as crystal originated particles (COPs) or intrinsic silicon defects.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectMapFileFormat rdf:type rdf:Property ;
    rdfs:label 'Defect Map File Format' ;
    rdfs:comment 'Format of the defect map file: KLARF (KLA Results File), CSV, XML, or proprietary vendor format.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectMapFilePath rdf:type rdf:Property ;
    rdfs:label 'Defect Map File Path' ;
    rdfs:comment 'File system path or URI to the defect map file (typically KLARF or proprietary format) containing spatial coordinates and attributes of all detected defects.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSizeBinLargeCount rdf:type rdf:Property ;
    rdfs:label 'Defect Size Bin Large Count' ;
    rdfs:comment 'Number of defects in the large size bin (typically > 0.5 µm or tool-specific threshold).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectSizeBinMediumCount rdf:type rdf:Property ;
    rdfs:label 'Defect Size Bin Medium Count' ;
    rdfs:comment 'Number of defects in the medium size bin (typically 0.1-0.5 µm or tool-specific threshold).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectSizeBinSmallCount rdf:type rdf:Property ;
    rdfs:label 'Defect Size Bin Small Count' ;
    rdfs:comment 'Number of defects in the small size bin (typically < 0.1 µm or tool-specific threshold).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionDetected rdf:type rdf:Property ;
    rdfs:label 'Excursion Detected' ;
    rdfs:comment 'Indicates whether a process excursion was detected based on defect density or count exceeding Statistical Process Control (SPC) limits.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectedAreaCm2 rdf:type rdf:Property ;
    rdfs:label 'Inspected Area Cm2' ;
    rdfs:comment 'Total wafer surface area inspected, measured in square centimeters. Used to calculate defect density.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionMode rdf:type rdf:Property ;
    rdfs:label 'Inspection Mode' ;
    rdfs:comment 'Inspection coverage mode: full wafer scan, die sampling, edge exclusion, or hot spot targeted inspection.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Type of inspection technology used: brightfield scanner, darkfield scanner, e-beam inspection, optical inspection, or macro inspection.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:killerDefectCount rdf:type rdf:Property ;
    rdfs:label 'Killer Defect Count' ;
    rdfs:comment 'Number of defects classified as killer defects (defects large enough or critical enough to cause die failure).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nuisanceDefectCount rdf:type rdf:Property ;
    rdfs:label 'Nuisance Defect Count' ;
    rdfs:comment 'Number of defects classified as nuisance (false positives or non-yield-impacting detections filtered by nuisance filter).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nuisanceFilterApplied rdf:type rdf:Property ;
    rdfs:label 'Nuisance Filter Applied' ;
    rdfs:comment 'Indicates whether a nuisance filter was applied to remove false positives or non-critical defects from the reported count.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nuisanceFilterVersion rdf:type rdf:Property ;
    rdfs:label 'Nuisance Filter Version' ;
    rdfs:comment 'Version identifier of the nuisance filter algorithm or rule set applied during this inspection.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:particleDefectCount rdf:type rdf:Property ;
    rdfs:label 'Particle Defect Count' ;
    rdfs:comment 'Number of defects classified as particles (foreign material on wafer surface).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patternDefectCount rdf:type rdf:Property ;
    rdfs:label 'Pattern Defect Count' ;
    rdfs:comment 'Number of defects classified as pattern defects (lithography or etch anomalies in the circuit pattern).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residueDefectCount rdf:type rdf:Property ;
    rdfs:label 'Residue Defect Count' ;
    rdfs:comment 'Number of defects classified as residue (chemical or material residue remaining after processing).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewRequired rdf:type rdf:Property ;
    rdfs:label 'Review Required' ;
    rdfs:comment 'Indicates whether engineering review is required based on defect count, type, or pattern analysis.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scratchDefectCount rdf:type rdf:Property ;
    rdfs:label 'Scratch Defect Count' ;
    rdfs:comment 'Number of defects classified as scratches (linear surface damage).' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spcControlLimitLower rdf:type rdf:Property ;
    rdfs:label 'Spc Control Limit Lower' ;
    rdfs:comment 'Lower control limit for defect density used in SPC monitoring.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spcControlLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Spc Control Limit Upper' ;
    rdfs:comment 'Upper control limit for defect density used in SPC monitoring. Excursions above this limit trigger alerts.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Total Defect Count' ;
    rdfs:comment 'Total number of defects detected on the wafer during this inspection, including all defect types and sizes.' ;
    rdfs:domain ind:DefectInspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metrologyMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Metrology Measurement Id' ;
    rdfs:comment 'Unique identifier for the metrology_measurement data product.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpValue rdf:type rdf:Property ;
    rdfs:label 'Cp Value' ;
    rdfs:comment 'Process capability index (Cp) calculated from this measurement, indicating the potential capability of the process without considering centering.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Flag indicating the quality and reliability of the measurement data. Good indicates reliable data, Suspect indicates questionable data, Bad indicates invalid data, Uncalibrated indicates tool calibration issue.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Spec Limit' ;
    rdfs:comment 'Lower specification limit for this measurement parameter. Values below this threshold fail specification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxValue rdf:type rdf:Property ;
    rdfs:label 'Max Value' ;
    rdfs:comment 'Maximum measured value across all sites on the wafer.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMode rdf:type rdf:Property ;
    rdfs:label 'Measurement Mode' ;
    rdfs:comment 'Mode in which the measurement was performed. Inline indicates production flow measurement, Offline indicates lab measurement, Engineering indicates development measurement, Qualification indicates process qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementParameter rdf:type rdf:Property ;
    rdfs:label 'Measurement Parameter' ;
    rdfs:comment 'Specific physical parameter being measured (e.g., critical dimension, overlay X/Y, film thickness, resistivity, reflectivity).' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medianValue rdf:type rdf:Property ;
    rdfs:label 'Median Value' ;
    rdfs:comment 'Median value of all site measurements for this parameter.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minValue rdf:type rdf:Property ;
    rdfs:label 'Min Value' ;
    rdfs:comment 'Minimum measured value across all sites on the wafer.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rangeValue rdf:type rdf:Property ;
    rdfs:label 'Range Value' ;
    rdfs:comment 'Difference between maximum and minimum site measurements (max - min).' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteCount rdf:type rdf:Property ;
    rdfs:label 'Site Count' ;
    rdfs:comment 'Total number of measurement sites sampled on the wafer.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stdDeviation rdf:type rdf:Property ;
    rdfs:label 'Std Deviation' ;
    rdfs:comment 'Standard deviation (1-sigma) of the site measurements, indicating within-wafer uniformity.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:threeSigma rdf:type rdf:Property ;
    rdfs:label 'Three Sigma' ;
    rdfs:comment 'Three times the standard deviation, representing the process variation range.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uniformityPercent rdf:type rdf:Property ;
    rdfs:label 'Uniformity Percent' ;
    rdfs:comment 'Within-wafer uniformity expressed as a percentage, calculated as (range / mean) * 100 or (3-sigma / mean) * 100 depending on convention.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Spec Limit' ;
    rdfs:comment 'Upper specification limit for this measurement parameter. Values above this threshold fail specification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferSlotNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Slot Number' ;
    rdfs:comment 'Position of the wafer within the lot carrier or cassette.' ;
    rdfs:domain ind:MetrologyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationScope rdf:type rdf:Property ;
    rdfs:label 'Application Scope' ;
    rdfs:comment 'Primary application domains or product families this technology node is designed to support (e.g., High Performance Computing, Mobile, Automotive, IoT, AI/ML Accelerators).' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineYieldTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Baseline Yield Target Percent' ;
    rdfs:comment 'Target baseline yield percentage (good dies per wafer) for production qualification of this technology node.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beolLayerCount rdf:type rdf:Property ;
    rdfs:label 'Beol Layer Count' ;
    rdfs:comment 'Number of process layers in the Back End of Line, covering metal interconnect formation.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceArchitecture rdf:type rdf:Property ;
    rdfs:label 'Device Architecture' ;
    rdfs:comment 'Transistor architecture type used in this technology node. Planar for traditional flat transistors, FinFET (Fin Field-Effect Transistor) for 3D fin structures, GAA (Gate All Around) for next-generation wrap-around gates, nanowire or nanosheet for advanced GAA variants.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dramHalfPitchNm rdf:type rdf:Property ;
    rdfs:label 'Dram Half Pitch Nm' ;
    rdfs:comment 'DRAM half-pitch in nanometers, a key metric for memory density and technology node classification per ITRS standards.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feolLayerCount rdf:type rdf:Property ;
    rdfs:label 'Feol Layer Count' ;
    rdfs:comment 'Number of process layers in the Front End of Line, covering transistor formation steps.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gatePitchNm rdf:type rdf:Property ;
    rdfs:label 'Gate Pitch Nm' ;
    rdfs:comment 'Gate pitch in nanometers, representing the distance between adjacent transistor gates in the Front End of Line (FEOL). Key dimension for transistor density.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:introductionYear rdf:type rdf:Property ;
    rdfs:label 'Introduction Year' ;
    rdfs:comment 'Calendar year when this technology node was first introduced or qualified for production.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBaselineNode rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Node' ;
    rdfs:comment 'Indicates whether this is the baseline or reference technology node for a given generation. Used for comparison and benchmarking purposes.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumMetalPitchNm rdf:type rdf:Property ;
    rdfs:label 'Minimum Metal Pitch Nm' ;
    rdfs:comment 'Minimum metal interconnect pitch in nanometers, representing the smallest distance between adjacent metal lines in the Back End of Line (BEOL).' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processTechnologyNodeDescription rdf:type rdf:Property ;
    rdfs:label 'Process Technology Node Description' ;
    rdfs:comment 'Detailed textual description of the technology node, including key features, capabilities, and differentiators.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Production Readiness Status' ;
    rdfs:comment 'Current production readiness state of the technology node. Research: early R&D phase. Development: active development. Qualification: undergoing process qualification. Pilot: pilot production runs. Production: full production ready. Mature: established high-volume production. EOL (End of Life): being phased out. [ENUM-REF-CANDIDATE: research|development|qualification|pilot|production|mature|eol — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPerformanceImprovementPercent rdf:type rdf:Property ;
    rdfs:label 'Target Performance Improvement Percent' ;
    rdfs:comment 'Target percentage improvement in performance (speed/frequency) compared to the previous technology node generation. Part of PPA (Power Performance Area) metrics.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPowerEfficiencyImprovementPercent rdf:type rdf:Property ;
    rdfs:label 'Target Power Efficiency Improvement Percent' ;
    rdfs:comment 'Target percentage improvement in power efficiency compared to the previous technology node generation. Part of PPA (Power Performance Area) metrics.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTransistorDensityPerMm2 rdf:type rdf:Property ;
    rdfs:label 'Target Transistor Density Per Mm2' ;
    rdfs:comment 'Target transistor density in millions of transistors per square millimeter for this technology node. Key metric for comparing node scaling and integration capability.' ;
    rdfs:domain ind:ProcessTechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wavelengthNm rdf:type rdf:Property ;
    rdfs:label 'Wavelength Nm' ;
    rdfs:comment 'Primary lithography wavelength in nanometers (e.g., 193nm for DUV, 13.5nm for EUV). Critical parameter for resolution and patterning capability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suspectedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Suspected Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Process excursions frequently caused by supplier material variation (e.g., resist viscosity drift, gas purity deviation). Critical for immediate containment actions, supplier notification per quality ' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:triggeringMaintenanceEventId rdf:type rdf:Property ;
    rdfs:label 'Triggering Maintenance Event Id' ;
    rdfs:comment 'Foreign key linking to equipment.maintenance_event. Business justification: Excursions often triggered by maintenance activities (PM, calibration, part replacement). CAPA, root cause analysis, and maintenance procedure improvement require linking excursions to triggering main' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceEvent .

ind:triggeringSpcMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Triggering Spc Measurement Id' ;
    rdfs:comment 'Foreign key linking to process.spc_measurement. Business justification: An excursion is triggered by a specific out-of-control SPC measurement point. Linking excursion to the specific spc_measurement that triggered it provides point-level traceability — engineers can navi' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpcMeasurement .

ind:affectedLotCount rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Count' ;
    rdfs:comment 'Total number of wafer lots affected by this excursion event. Used for impact assessment and containment scope determination.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containmentActionTaken rdf:type rdf:Property ;
    rdfs:label 'Containment Action Taken' ;
    rdfs:comment 'Immediate containment actions taken upon excursion detection. Describes steps such as lot hold, equipment quarantine, process parameter adjustment, or rework initiation.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Timestamp' ;
    rdfs:comment 'Date and time when containment actions were completed. Used to measure response time and containment effectiveness.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveActionReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Reference' ;
    rdfs:comment 'Reference number or identifier for the corrective action plan. Links to the formal corrective and preventive action (CAPA) system or Out-of-Control Action Plan (OCAP) record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Source system or method that detected the excursion event. Indicates whether the excursion was identified through Statistical Process Control (SPC), inspection, metrology measurement, electrical test, operator observation, or automated monitoring system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the excursion was first detected. Represents the business event time of excursion identification.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedFinancialImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Usd' ;
    rdfs:comment 'Estimated financial impact of the excursion in US dollars. Includes scrap cost, rework cost, yield loss, and potential customer claims.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excursionNumber rdf:type rdf:Property ;
    rdfs:label 'Excursion Number' ;
    rdfs:comment 'Business identifier for the excursion event. Human-readable reference number used for tracking and communication across engineering teams.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionType rdf:type rdf:Property ;
    rdfs:label 'Excursion Type' ;
    rdfs:comment 'Classification of the excursion event. Categorizes whether the excursion is due to out-of-specification parameters, out-of-control process conditions, yield loss, excessive defect density, parametric drift, or equipment fault.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the excursion investigation. Tracks progression from initial detection through root cause analysis to closure.' ;
    rdfs:domain ind:Excursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the supplier\'s primary address.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the supplier\'s primary address (optional).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City component of the supplier\'s primary address.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance standing of the supplier with internal and external regulations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount approved for the supplier.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Dun & Bradstreet unique identifier for the supplier organization.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialRating rdf:type rdf:Property ;
    rdfs:label 'Financial Rating' ;
    rdfs:comment 'Credit rating assigned to the supplier based on financial health.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalFootprint rdf:type rdf:Property ;
    rdfs:label 'Global Footprint' ;
    rdfs:comment 'Scope of the supplier\'s operational presence.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassification rdf:type rdf:Property ;
    rdfs:label 'Industry Classification' ;
    rdfs:comment 'Broad industry segment to which the supplier belongs.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCertifiedKga rdf:type rdf:Property ;
    rdfs:label 'Is Certified Kga' ;
    rdfs:comment 'Indicates whether the supplier holds a KGA (Known Good Assembly) certification.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent supplier quality or compliance audit.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal registered name of the supplier entity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCompanyName rdf:type rdf:Property ;
    rdfs:label 'Parent Company Name' ;
    rdfs:comment 'Name of the ultimate parent organization if the supplier is a subsidiary.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms negotiated with the supplier.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal/ZIP code of the supplier\'s primary address.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLogisticsPartner rdf:type rdf:Property ;
    rdfs:label 'Preferred Logistics Partner' ;
    rdfs:comment 'Logistics provider most frequently used for shipments from this supplier.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Name of the main contact person for the supplier.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Email address of the primary supplier contact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Telephone number of the primary supplier contact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Overall quality performance rating based on audits and defect data.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration number of the supplier\'s legal entity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Aggregated risk score derived from financial, geopolitical, and operational factors.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province of the supplier\'s primary address.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierGroup rdf:type rdf:Property ;
    rdfs:label 'Supplier Group' ;
    rdfs:comment 'Business grouping used for strategic sourcing and spend analysis.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Primary display name of the supplier used in business transactions.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Status' ;
    rdfs:comment 'Current lifecycle status of the supplier record.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier based on strategic importance and spend volume.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Score' ;
    rdfs:comment 'Score reflecting the supplier\'s environmental and social responsibility performance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Government-issued tax registration number for the supplier.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:website rdf:type rdf:Property ;
    rdfs:label 'Website' ;
    rdfs:comment 'Public website URL of the supplier.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Id' ;
    rdfs:comment 'Primary key for approved_vendor' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedVendor .

ind:primaryApprovedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Approved Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Each approved vendor record belongs to a single supplier; linking provides parent-child hierarchy and removes redundant supplier details that may exist in approved_vendor.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:approvedCommodityScope rdf:type rdf:Property ;
    rdfs:label 'Approved Commodity Scope' ;
    rdfs:comment 'List or description of material categories, chemical families, or process inputs the vendor is qualified to supply.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorDescription rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Description' ;
    rdfs:comment 'Free-form text providing additional context or notes about the vendor.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorStatus rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Status' ;
    rdfs:comment 'Overall operational status of the vendor within the enterprise.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numerical result of the latest audit (0-100).' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Currency code used for transactions with the vendor.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the vendor\'s primary contact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Telephone number of the vendor\'s primary contact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityTier rdf:type rdf:Property ;
    rdfs:label 'Quality Tier' ;
    rdfs:comment 'Internal quality classification assigned to the vendor based on performance and compliance.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the approved vendor record was first created in the system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the approved vendor record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Current status of the vendor with respect to applicable semiconductor regulations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province component of the vendor\'s address.' ;
    rdfs:domain ind:ApprovedVendor ;
