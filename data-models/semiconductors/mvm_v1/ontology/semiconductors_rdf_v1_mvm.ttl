    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'System-generated unique identifier for each cost allocation record.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySenderCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Sender Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Cost allocation records identify the sending cost center; the FK replaces the code and enforces referential integrity.' ;
    rdfs:domain ind:CostAllocation ;
