ind:planningMethod rdf:type rdf:Property ;
    rdfs:label 'Planning Method' ;
    rdfs:comment 'Methodology used to develop the budget (e.g., top-down, bottom-up, rolling forecast, zero-based).' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceToPriorYearAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Year Amount' ;
    rdfs:comment 'Difference between the planned amount and the actual amount of the prior fiscal year, expressed in currency.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToPriorYearPercent rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Year Percent' ;
    rdfs:comment 'Percentage difference between the planned amount and the prior year actual amount.' ;
