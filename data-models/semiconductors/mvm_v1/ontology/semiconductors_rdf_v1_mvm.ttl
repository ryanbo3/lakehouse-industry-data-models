    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteTestStepId rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Test Step Id' ;
    rdfs:comment 'Self-referencing FK on test_step (prerequisite_test_step_id)' ;
    rdfs:domain ind:TestStep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestStep .

ind:binMappingRequired rdf:type rdf:Property ;
    rdfs:label 'Bin Mapping Required' ;
    rdfs:comment 'True if the step\'s result must be mapped to a yield bin.' ;
    rdfs:domain ind:TestStep ;
    rdf:type owl:DatatypeProperty ;
