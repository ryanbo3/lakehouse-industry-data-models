    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferCostModelId rdf:type rdf:Property ;
    rdfs:label 'Wafer Cost Model Id' ;
    rdfs:comment 'Unique surrogate key for each wafer cost model record.' ;
