ind:complianceRegulationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Regulation Flag' ;
    rdfs:comment 'Indicates whether the budget plan complies with applicable regulatory requirements (e.g., SOX, CHIPS Act).' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
