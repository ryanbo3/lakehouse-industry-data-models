ind:configurationEccnClassificationId rdf:type rdf:Property ;
    rdfs:label 'Configuration Eccn Classification Id' ;
    rdfs:comment 'Foreign key linking to compliance.eccn_classification. Business justification: Configuration rules enabling/disabling features (encryption, performance tiers) can alter ECCN classification per EAR 740.17(b). Configurable semiconductors need ECCN determination per configuration f' ;
    rdfs:domain ind:ConfigurationRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EccnClassification .

ind:overriddenConfigurationRuleId rdf:type rdf:Property ;
    rdfs:label 'Overridden Configuration Rule Id' ;
