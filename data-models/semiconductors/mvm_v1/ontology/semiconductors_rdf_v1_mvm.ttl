    rdfs:range xsd:string .

ind:costModelDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Model Description' ;
    rdfs:comment 'Narrative description of the cost model methodology.' ;
    rdfs:domain ind:StandardCost ;
