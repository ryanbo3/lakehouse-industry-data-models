ind:applicableStandards rdf:type rdf:Property ;
    rdfs:label 'Applicable Standards' ;
    rdfs:comment 'Comma-separated list of standards governing the program (e.g., AEC-Q100, JEDEC JESD47, ISO 9001).' ;
