    rdfs:comment 'Quantity of the allocation basis (e.g., total machine hours).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'Primary driver used as the allocation base (e.g., machine hours, wafer passes).' ;
