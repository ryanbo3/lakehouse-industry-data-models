    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Pricing tier classification that determines discount levels.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteLineStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Line Status' ;
    rdfs:comment 'Current lifecycle status of the quote line.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Any customer-specific handling, packaging, or shipping notes.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Applicable tax rate expressed as a percentage.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPrice rdf:type rdf:Property ;
    rdfs:label 'Total Price' ;
    rdfs:comment 'Gross amount for the line (unit_price * quantity) before tax.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Measurement unit for quantity, typically \'pcs\' for pieces.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyYears rdf:type rdf:Property ;
    rdfs:label 'Warranty Years' ;
    rdfs:comment 'Number of years of warranty offered for the product.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySalesAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Account Id' ;
    rdfs:comment 'Identifier of the customer who selected the semiconductor device.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primarySalesSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Sku Id' ;
    rdfs:comment 'Identifier of the semiconductor device that won the design.' ;
    rdfs:domain ind:SalesDesignWin ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:salesNreAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sales Nre Agreement Id' ;
    rdfs:comment 'Identifier of the Non-Recurring Engineering agreement linked to the design win.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesNreAgreement .

ind:competitorDisplacementScore rdf:type rdf:Property ;
    rdfs:label 'Competitor Displacement Score' ;
    rdfs:comment 'Score (0-100) representing the impact of displacing the competitor.' ;
