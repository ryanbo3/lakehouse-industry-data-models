ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Monetary cost of freight/shipping.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Responsibility for freight costs.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEarControlled rdf:type rdf:Property ;
    rdfs:label 'Is Ear Controlled' ;
    rdfs:comment 'Indicates whether the PO is subject to U.S. Export Administration Regulations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plant rdf:type rdf:Property ;
    rdfs:label 'Plant' ;
    rdfs:comment 'SAP plant code where the goods are to be received.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseGroup rdf:type rdf:Property ;
    rdfs:label 'Purchase Group' ;
    rdfs:comment 'Organizational group responsible for the procurement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Status' ;
    rdfs:comment 'Current lifecycle state of the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderType rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Type' ;
    rdfs:comment 'Classification of the PO based on its procurement strategy.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseSupplierFk rdf:type rdf:Property ;
    rdfs:label 'Purchase Supplier Fk' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — Every PO is issued TO a supplier. This is a day-1 mandatory FK.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchasingOrg rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org' ;
    rdfs:comment 'SAP purchasing organization that owns the PO.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Warehouse or storage bin identifier for receipt.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Code representing the tax jurisdiction and rate applied.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Total Gross Amount' ;
    rdfs:comment 'Total amount before taxes, discounts, and freight.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Net Amount' ;
    rdfs:comment 'Final payable amount after taxes, discounts, and freight.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Aggregate tax amount applied to the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Unique surrogate identifier for the purchase order line record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:poMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Po Material Master Id' ;
    rdfs:comment 'FK to supply.material_master.material_master_id — Each PO line references a specific material being procured.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryPoMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Po Material Master Id' ;
    rdfs:comment 'FK to supply.material_master.material_master_id — Each PO line procures a specific material. Essential for material traceability and MRP consumption.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Order Id' ;
    rdfs:comment 'FK to supply.purchase_order.purchase_order_id — Header-line pattern: every PO line belongs to exactly one PO. Critical structural relationship.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:accountAssignmentCode rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Code' ;
    rdfs:comment 'Identifier of the specific cost center, WBS element, or order linked to this line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssignmentType rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Type' ;
    rdfs:comment 'Classification of the cost object (cost center, WBS element, or internal order).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Reference to a framework contract governing this line, if applicable.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Date by which the supplier should deliver the material.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'Current status of goods receipt for this line.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinalInvoice rdf:type rdf:Property ;
    rdfs:label 'Is Final Invoice' ;
    rdfs:comment 'Indicates whether this line has been invoiced in its final form.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isServiceLine rdf:type rdf:Property ;
    rdfs:label 'Is Service Line' ;
    rdfs:comment 'True if the line represents a service rather than a material.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Gross amount before tax and discount (ordered_quantity * net_price).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net monetary value of the line after tax and discount.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Net price per unit of the material before taxes and discounts.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'Number of units that the net price applies to (e.g., price per 1000 pieces).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date on which the goods were received.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Receipt Quantity' ;
    rdfs:comment 'Quantity of material that has been received against this line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyRiskScore rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Score' ;
    rdfs:comment 'Risk rating (0-100) assessing supplier and material availability risk.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Material Number' ;
    rdfs:comment 'Supplier\'s own part number for the material.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_shipment. Business justification: A goods receipt is the warehouse-side confirmation of an inbound shipment arriving at the fab or warehouse. Linking goods_receipt to inbound_shipment enables end-to-end traceability from logistics tra' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundShipment .

ind:primaryGoodsPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Purchase Order Id' ;
    rdfs:comment 'System identifier of the purchase order associated with the receipt.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the material complies with applicable regulations (e.g., RoHS).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReference rdf:type rdf:Property ;
    rdfs:label 'External Reference' ;
    rdfs:comment 'Any external system reference linked to this receipt (e.g., logistics tracking ID).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsPurchaseOrderFk rdf:type rdf:Property ;
    rdfs:label 'Goods Purchase Order Fk' ;
    rdfs:comment 'FK to supply.purchase_order.purchase_order_id — Goods receipts are posted against a purchase order. Core three-way match requirement.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total monetary value of the receipt before taxes and discounts.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Reference to the quality inspection lot created for this receipt.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Result of the incoming quality inspection for the received material.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Amount of material physically received, expressed in the unit of measure.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Business identifier assigned to the receipt document (e.g., GR number).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Exact date and time when the receipt was recorded in the system.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedBy rdf:type rdf:Property ;
    rdfs:label 'Received By' ;
    rdfs:comment 'Name or employee identifier of the person who logged the receipt.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Numeric score representing supply risk for the received material (higher = higher risk).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierBatchReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Batch Reference' ;
    rdfs:comment 'Reference supplied by the vendor for the batch (e.g., vendor lot number).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Id' ;
    rdfs:comment 'System-generated unique identifier for each supplier qualification record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierQualification .

ind:primarySupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Id' ;
    rdfs:comment 'Identifier of the supplier being qualified, linking to the supplier master record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
