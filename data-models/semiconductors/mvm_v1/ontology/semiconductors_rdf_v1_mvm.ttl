ind:problemStatement rdf:type rdf:Property ;
    rdfs:label 'Problem Statement' ;
    rdfs:comment 'Clear description of the problem or non-conformance that triggered the CAPA.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseMethod rdf:type rdf:Property ;
