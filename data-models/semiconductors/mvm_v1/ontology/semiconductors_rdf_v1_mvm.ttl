    rdfs:comment 'Current operational status of the hierarchy link.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'True if the child account is the primary entity under the parent; otherwise false.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classification of the hierarchical relationship between parent and child accounts.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketShareTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Market Share Target Percent' ;
    rdfs:comment 'Desired market share percentage for the segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Pricing model applied to the segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Usd' ;
    rdfs:comment 'Annual revenue target for the segment expressed in US dollars.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesMotion rdf:type rdf:Property ;
    rdfs:label 'Sales Motion' ;
    rdfs:comment 'Primary sales approach used for the segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short alphanumeric code that uniquely identifies the market segment within the organization.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Free-form description of the segment purpose and characteristics.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the market segment (e.g., Hyperscaler, Automotive Tier-1).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Tier' ;
    rdfs:comment 'Internal priority ranking used for resource allocation and go-to-market planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subVertical rdf:type rdf:Property ;
    rdfs:label 'Sub Vertical' ;
    rdfs:comment 'More granular market sub-category within the vertical (e.g., AI Chipmakers, Power Management). [ENUM-REF-CANDIDATE: ai_chipmakers|power_management|networking|mobile_devices|automotive_sensors|industrial_automation|defense_systems|smart_home|wearables|edge_computing] ' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamBand rdf:type rdf:Property ;
    rdfs:label 'Tam Band' ;
    rdfs:comment 'Size band of the total addressable market for the segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerType rdf:type rdf:Property ;
    rdfs:label 'Target Customer Type' ;
    rdfs:comment 'Primary type of customers targeted by the segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verticalMarket rdf:type rdf:Property ;
    rdfs:label 'Vertical Market' ;
    rdfs:comment 'High-level industry vertical to which the segment belongs (e.g., Semiconductor, Automotive, Consumer Electronics). [ENUM-REF-CANDIDATE: semiconductor|automotive|consumer_electronics|industrial_iot|government_defense|healthcare|telecom|energy|finance|retail|education|media] ' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressCode rdf:type rdf:Property ;
    rdfs:label 'Address Code' ;
    rdfs:comment 'Internal code used to reference the address within ERP and PLM systems.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Category of the address indicating its business purpose.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Timestamp' ;
    rdfs:comment 'Timestamp when the most recent address change was recorded.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Classification indicating whether the address belongs to internal organization, external customer, or partner.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the primary contact at the address.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact at the address.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlScreened rdf:type rdf:Property ;
    rdfs:label 'Export Control Screened' ;
    rdfs:comment 'True if the address has been screened against export control lists.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geolocation Accuracy' ;
    rdfs:comment 'Indicates the precision level of the latitude/longitude values.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label identifying the address (e.g., “HQ San Jose”).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerified rdf:type rdf:Property ;
    rdfs:label 'Last Verified' ;
    rdfs:comment 'Date when the address information was last validated.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Latitude coordinate in decimal degrees.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineageCode rdf:type rdf:Property ;
    rdfs:label 'Lineage Code' ;
    rdfs:comment 'Identifier linking this address to its predecessor in case of address merges or splits.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Longitude coordinate in decimal degrees.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Business purpose for which the address is used.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetLine1 rdf:type rdf:Property ;
    rdfs:label 'Street Line1' ;
    rdfs:comment 'First line of the street address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetLine2 rdf:type rdf:Property ;
    rdfs:label 'Street Line2' ;
    rdfs:comment 'Second line of the street address (optional).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code representing the tax jurisdiction applicable to the address.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'FK to customer.account.account_id — Every design-win is attributed to a specific customer account. This FK is critical for revenue forecasting and account-level reporting.' ;
    rdfs:domain ind:CustomerDesignWin ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Account Id' ;
    rdfs:comment 'Reference to the customer organization that owns the design win.' ;
    rdfs:domain ind:CustomerDesignWin ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:competitiveDisplacementFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Displacement Flag' ;
    rdfs:comment 'Indicates whether the win displaces a competitor\'s product (true) or not (false).' ;
    rdfs:domain ind:CustomerDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Timestamp when the design win was officially confirmed (won).' ;
    rdfs:domain ind:CustomerDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:designProjectName rdf:type rdf:Property ;
    rdfs:label 'Design Project Name' ;
    rdfs:comment 'Name of the internal design project associated with the win.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designWinSource rdf:type rdf:Property ;
    rdfs:label 'Design Win Source' ;
    rdfs:comment 'Origin of the design win (internal development, channel-sourced, or partner-sourced).' ;
    rdfs:domain ind:CustomerDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue Usd' ;
    rdfs:comment 'Projected annual revenue from the design win, expressed in US dollars.' ;
    rdfs:domain ind:CustomerDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Amount Usd' ;
    rdfs:comment 'Estimated NRE cost associated with the design win, expressed in US dollars.' ;
    rdfs:domain ind:CustomerDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Nre Required Flag' ;
    rdfs:comment 'True if the project includes a non-recurring engineering (NRE) component.' ;
    rdfs:domain ind:CustomerDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformGeneration rdf:type rdf:Property ;
    rdfs:label 'Platform Generation' ;
    rdfs:comment 'Generation of the platform family for which the design win is targeted.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionRampDate rdf:type rdf:Property ;
    rdfs:label 'Production Ramp Date' ;
    rdfs:comment 'Target date when volume production is expected to ramp.' ;
    rdfs:domain ind:CustomerDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Timestamp when the design win was first registered in the system.' ;
    rdfs:domain ind:CustomerDesignWin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validationTestProgramId rdf:type rdf:Property ;
    rdfs:label 'Validation Test Program Id' ;
    rdfs:comment 'Foreign key linking to test.test_program. Business justification: Design registrations specify validation test programs for engineering samples and characterization. Design-in process requires linking customer projects to test programs for silicon validation, yield ' ;
    rdfs:domain ind:CustomerDesignRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:designComplexity rdf:type rdf:Property ;
    rdfs:label 'Design Complexity' ;
    rdfs:comment 'Qualitative assessment of design difficulty.' ;
    rdfs:domain ind:CustomerDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designProjectDescription rdf:type rdf:Property ;
    rdfs:label 'Design Project Description' ;
    rdfs:comment 'Free-form description of the design objectives, features, and scope.' ;
    rdfs:domain ind:CustomerDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designStartDate rdf:type rdf:Property ;
    rdfs:label 'Design Start Date' ;
    rdfs:comment 'Date when the customer officially started the design effort.' ;
    rdfs:domain ind:CustomerDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percent' ;
    rdfs:comment 'Projected percentage of good dies per wafer for the design.' ;
    rdfs:domain ind:CustomerDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Nre Budget Amount' ;
    rdfs:comment 'Non-Recurring Engineering budget allocated for the design project.' ;
    rdfs:domain ind:CustomerDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreBudgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Nre Budget Currency' ;
    rdfs:comment 'Currency of the NRE budget amount.' ;
    rdfs:domain ind:CustomerDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionTargetDate rdf:type rdf:Property ;
    rdfs:label 'Production Target Date' ;
    rdfs:comment 'Target date for first silicon production run.' ;
    rdfs:domain ind:CustomerDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle state of the design registration.' ;
    rdfs:domain ind:CustomerDesignRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationReliabilityTestRunId rdf:type rdf:Property ;
    rdfs:label 'Qualification Reliability Test Run Id' ;
    rdfs:comment 'Foreign key linking to test.reliability_test_run. Business justification: Qualification status (especially AEC-Q, automotive PPAP) is directly driven by reliability test run results (HTOL, TC, HAST). Quality engineers link qualification records to specific reliability test ' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReliabilityTestRun .

ind:qualificationTestProgramId rdf:type rdf:Property ;
    rdfs:label 'Qualification Test Program Id' ;
    rdfs:comment 'Foreign key linking to test.test_program. Business justification: Customer qualification (AEC-Q100, PPAP, IATF) requires execution of specific test programs. Quality and reliability teams track which test program version was used to achieve qualification status for ' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:qualifiedFabToolId rdf:type rdf:Property ;
    rdfs:label 'Qualified Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Customer qualifications (AEC-Q, PPAP, IATF-16949) often tied to specific fab tool capabilities and certifications. Real business process: customer audit trails require traceability to qualified manufa' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:requiredToolQualificationId rdf:type rdf:Property ;
    rdfs:label 'Required Tool Qualification Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_qualification. Business justification: Customer qualification status links to tool qualification records for compliance traceability. Critical for automotive/aerospace customers requiring AEC-Q or PPAP certification - customer audits deman' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolQualification .

ind:aecQStatus rdf:type rdf:Property ;
    rdfs:label 'Aec Q Status' ;
    rdfs:comment 'Status of the AEC-Q100/Q101 compliance qualification.' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatf16949Status rdf:type rdf:Property ;
    rdfs:label 'Iatf 16949 Status' ;
    rdfs:comment 'Status of the IATF 16949 automotive quality certification.' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Qualification Status' ;
    rdfs:comment 'Aggregated qualification outcome for the customer.' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapStatus rdf:type rdf:Property ;
    rdfs:label 'Ppap Status' ;
    rdfs:comment 'Status of the Production Part Approval Process qualification.' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes regarding the qualification process.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Qualification Requirements' ;
    rdfs:comment 'Specific qualification requirements applicable to the customer.' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Review Date' ;
    rdfs:comment 'Date of the most recent qualification review.' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationScore rdf:type rdf:Property ;
    rdfs:label 'Qualification Score' ;
    rdfs:comment 'Numeric score (0-100) representing overall qualification assessment.' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationStartDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Start Date' ;
    rdfs:comment 'Date when qualification activities commenced.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifiedProductFamilies rdf:type rdf:Property ;
    rdfs:label 'Qualified Product Families' ;
    rdfs:comment 'Comma-separated list of product families the customer is qualified to receive.' ;
    rdfs:domain ind:QualificationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaAgreementId rdf:type rdf:Property ;
    rdfs:label 'Nda Agreement Id' ;
    rdfs:comment 'System-generated unique identifier for the NDA agreement record.' ;
    rdfs:domain ind:NdaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'List of regulatory or contractual compliance obligations referenced in the NDA (e.g., ITAR, EAR, GDPR).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Document Reference Code' ;
    rdfs:comment 'Identifier linking to the stored NDA document in the document management system.' ;
    rdfs:domain ind:NdaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date the NDA was signed by the authorized signatory.' ;
    rdfs:domain ind:NdaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'ISO-3166-1 alpha-3 country code representing the legal jurisdiction governing the NDA.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Nda Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the NDA agreement.' ;
    rdfs:domain ind:NdaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaType rdf:type rdf:Property ;
    rdfs:label 'Nda Type' ;
    rdfs:comment 'Indicates whether the NDA is mutual (both parties exchange confidential information) or one-way (only the semiconductor company shares information).' ;
    rdfs:domain ind:NdaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Date' ;
    rdfs:comment 'Date on which a renewal notice must be sent to the customer before expiry.' ;
    rdfs:domain ind:NdaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Free-text description of the technology, roadmap, pricing, or other information covered by the NDA.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryEmail rdf:type rdf:Property ;
    rdfs:label 'Signatory Email' ;
    rdfs:comment 'Email address of the signatory used for correspondence and notifications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Legal name of the individual who signed the NDA on behalf of the customer.' ;
    rdfs:domain ind:NdaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryPhone rdf:type rdf:Property ;
    rdfs:label 'Signatory Phone' ;
    rdfs:comment 'Primary telephone number of the signatory.' ;
    rdfs:domain ind:NdaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTeamId rdf:type rdf:Property ;
    rdfs:label 'Account Team Id' ;
    rdfs:comment 'Unique surrogate key for each account team assignment record.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the employee\'s assignment to the account ends or is scheduled to end (null if ongoing).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPrimaryTeam rdf:type rdf:Property ;
    rdfs:label 'Is Primary Team' ;
    rdfs:comment 'True if this assignment belongs to the account\'s primary coverage team (as opposed to secondary support).' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'True if this team member is the primary point of contact for the account.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'Functional role of the employee within the account coverage team.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workloadPercentage rdf:type rdf:Property ;
    rdfs:label 'Workload Percentage' ;
    rdfs:comment 'Portion of the employee\'s total workload allocated to this account (percentage).' ;
    rdfs:domain ind:AccountTeam ;
