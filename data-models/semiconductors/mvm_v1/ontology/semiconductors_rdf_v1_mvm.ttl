    rdfs:comment 'Accounting framework used for the budget plan (e.g., IFRS, US-GAAP).' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationUnitCode rdf:type rdf:Property ;
