ind:transferPriceId rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Id' ;
    rdfs:comment 'System-generated unique identifier for the transfer price master record.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Source Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Transfer pricing records govern intercompany pricing between legal entities in semiconductor enterprises (e.g., wafer pricing between fab subsidiary and design entity, IP royalty pricing between IP ho' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:approvalBy rdf:type rdf:Property ;
    rdfs:label 'Approval By' ;
