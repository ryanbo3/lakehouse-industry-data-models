ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'FK to quality.audit.audit_id — Audit findings (now merged into audit) trigger CAPAs. audit_finding description states \'linked CAPA record\'. This is a mandatory operational link for ISO 9001 clause 10.2.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

