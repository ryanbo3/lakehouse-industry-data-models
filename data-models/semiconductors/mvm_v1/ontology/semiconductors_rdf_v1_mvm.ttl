    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivePricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Effective Price Per Unit' ;
    rdfs:comment 'Calculated price per unit of product or service after applying the method and margin.' ;
