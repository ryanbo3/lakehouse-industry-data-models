# --- Attribute Properties ---
ind:analyticsRequestId rdf:type rdf:Property ;
    rdfs:label 'Analytics Request Id' ;
    rdfs:comment 'Unique identifier for the analytics request. Primary key for the analytics request entity.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticsRequest .

ind:advertiserId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Id' ;
    rdfs:comment 'Reference to the client who submitted the analytics request. Links to the client master entity.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Analytics requests are commissioned under master service agreements that define scope, pricing, and deliverables for analytics services. Essential for tracking analytics work against contractual terms' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:brandProfileId rdf:type rdf:Property ;
    rdfs:label 'Brand Profile Id' ;
    rdfs:comment 'Reference to the brand associated with this analytics request. Links to the brand master entity.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandProfile .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Reference to the campaign associated with this analytics request. Links to the campaign master entity. Nullable for non-campaign-specific requests.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:clientBriefId rdf:type rdf:Property ;
    rdfs:label 'Client Brief Id' ;
    rdfs:comment 'Foreign key linking to client.client_brief. Business justification: Client briefs trigger analytics requests for campaign measurement planning and performance analysis. Links request to originating brief, enabling traceability from client requirements to analytics del' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientBrief .

ind:clientContactId rdf:type rdf:Property ;
    rdfs:label 'Client Contact Id' ;
    rdfs:comment 'Foreign key linking to client.client_contact. Business justification: Analytics requests are submitted by specific client contacts. Structured FK enables tracking which stakeholders request analytics, supports workload analysis by contact, and replaces denormalized requ' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Analytics requests are work intake records tracked to cost centers for capacity planning, internal cost allocation, billable vs non-billable analysis, and resource utilization reporting in agency oper' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:initiativeId rdf:type rdf:Property ;
    rdfs:label 'Initiative Id' ;
    rdfs:comment 'Foreign key linking to project.initiative. Business justification: Analytics requests are often scoped to specific initiatives - project teams request analysis of their initiative\'s performance. Linking requests to initiatives enables tracking analytical support per ' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:sowId rdf:type rdf:Property ;
    rdfs:label 'Sow Id' ;
    rdfs:comment 'Foreign key linking to contract.sow. Business justification: Analytics requests are scoped within specific SOWs that define analytics deliverables, budgets, and timelines. Critical for tracking analytics work against SOW commitments and managing project scope.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sow .

ind:workerId rdf:type rdf:Property ;
    rdfs:label 'Worker Id' ;
    rdfs:comment 'Reference to the analyst assigned to fulfill this analytics request. Links to the talent or employee master entity.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date when the analytics request was delivered to the requestor. Nullable if not yet delivered.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'Actual effort in hours spent to complete the analytics request. Used for performance tracking and future estimation accuracy.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Period End Date' ;
    rdfs:comment 'End date of the time period covered by the analytics request analysis.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Period Start Date' ;
    rdfs:comment 'Start date of the time period covered by the analytics request analysis.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether the analytics request is billable to the client or is part of included services. True if billable, False if non-billable.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation or reason provided when an analytics request is cancelled. Nullable if not cancelled.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Client Satisfaction Rating' ;
    rdfs:comment 'Client satisfaction rating for the delivered analytics request, typically on a scale of 1 to 5. Nullable if feedback not yet collected.' ;
    rdfs:domain ind:AnalyticsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Date and time when this analytics request record was first created in the system. Audit trail for record creation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSourcesRequired rdf:type rdf:Property ;
    rdfs:label 'Data Sources Required' ;
    rdfs:comment 'List or description of data sources needed to fulfill the analytics request, such as campaign performance data, audience data, competitive intelligence feeds, or third-party data.' ;
    rdfs:domain ind:AnalyticsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Format or type of the final deliverable produced for the analytics request.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableUrl rdf:type rdf:Property ;
    rdfs:label 'Deliverable Url' ;
    rdfs:comment 'URL or file path to the final deliverable output such as a report, dashboard, or presentation. Nullable if not yet delivered or if physical delivery.' ;
    rdfs:domain ind:AnalyticsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effortEstimateHours rdf:type rdf:Property ;
    rdfs:label 'Effort Estimate Hours' ;
    rdfs:comment 'Estimated effort in hours required to complete the analytics request. Used for resource planning and capacity management.' ;
    rdfs:domain ind:AnalyticsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes or comments from the analytics team regarding the request, challenges encountered, or lessons learned.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'Executive summary of the key findings, insights, or recommendations from the analytics request. Populated upon completion.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiMeasured rdf:type rdf:Property ;
    rdfs:label 'Kpi Measured' ;
    rdfs:comment 'Primary KPI or metrics measured and analyzed in this analytics request, such as ROAS, CTR, CPA, brand lift, or audience reach.' ;
    rdfs:domain ind:AnalyticsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when this analytics request record was last modified. Audit trail for record updates.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Priority classification of the request. P1 indicates urgent, P2 indicates standard, P3 indicates low priority. Determines resource allocation and scheduling.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally-known unique business identifier for the analytics request. Used for tracking and communication with clients and internal teams.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the analytics request in the workflow. Tracks progression from intake through delivery.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the analytics request type. MMM refers to Media Mix Model. Determines the analytical approach and resource allocation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target delivery date requested by the client or internal team for completion of the analytics request.' ;
    rdfs:domain ind:AnalyticsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestorType rdf:type rdf:Property ;
    rdfs:label 'Requestor Type' ;
    rdfs:comment 'Classification indicating whether the requestor is a client contact or an internal agency team member.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Started Timestamp' ;
    rdfs:comment 'Date and time when the analytics deliverable entered the review phase. Nullable if not yet in review.' ;
    rdfs:domain ind:AnalyticsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the analytics request scope, objectives, deliverables, and any specific requirements or constraints provided by the requestor.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scoping Completed Timestamp' ;
    rdfs:comment 'Date and time when the scoping phase of the analytics request was completed. Nullable if not yet scoped.' ;
    rdfs:domain ind:AnalyticsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the analytics request was originally submitted by the requestor. Represents the business event timestamp for intake.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Short descriptive title of the analytics request provided by the requestor.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Work Started Timestamp' ;
    rdfs:comment 'Date and time when analytical work on the request was started. Nullable if not yet started.' ;
    rdfs:domain ind:AnalyticsRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attributionStudyId rdf:type rdf:Property ;
    rdfs:label 'Attribution Study Id' ;
    rdfs:comment 'Unique identifier for the attribution study record. Primary key.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttributionStudy .

ind:adChannelId rdf:type rdf:Property ;
    rdfs:label 'Ad Channel Id' ;
    rdfs:comment 'Foreign key linking to media.ad_channel. Business justification: Attribution studies measure channel-level contribution to conversions. Channel attribution drives budget allocation decisions. Links study findings to specific channels evaluated.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdChannel .

ind:brandProfileId rdf:type rdf:Property ;
    rdfs:label 'Brand Brand Profile Id' ;
    rdfs:comment 'Reference to the specific brand being analyzed in this attribution study.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandProfile .

ind:contractMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Contract Milestone Id' ;
    rdfs:comment 'Foreign key linking to contract.milestone. Business justification: Attribution studies are milestones in measurement plans, often triggering payments. Essential for tracking analytics project progress and managing payment schedules.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractMilestone .

ind:measurementPlanId rdf:type rdf:Property ;
    rdfs:label 'Measurement Plan Id' ;
    rdfs:comment 'Foreign key linking to analytics.measurement_plan. Business justification: Attribution studies are executed based on measurement plans. The measurement plan defines the attribution methodology, measurement window, conversion events, and data sources that the attribution stud' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementPlan .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to media.media_plan. Business justification: Attribution studies measure media plan channel contribution to conversions. Planners use attribution to optimize future plans. Links study findings to plan being evaluated.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to vendor.supplier. Business justification: Attribution studies track conversion paths through vendor touchpoints (publisher, DSP, data provider) to evaluate each vendor\'s contribution to campaign outcomes. Standard multi-touch attribution prac' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:vendorContractId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Id' ;
    rdfs:comment 'Foreign key linking to contract.vendor_contract. Business justification: External attribution vendors work under vendor contracts that define pricing and deliverables. Critical for managing vendor-delivered analytics and tracking vendor costs.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContract .

ind:attributionMethodology rdf:type rdf:Property ;
    rdfs:label 'Attribution Methodology' ;
    rdfs:comment 'Specific attribution model or algorithm applied in the study (e.g., last-click, data-driven, Shapley value, Markov chain, algorithmic MTA). [ENUM-REF-CANDIDATE: last_click|first_click|linear|time_decay|position_based|data_driven|algorithmic_mta|shapley_value|markov_chain|custom — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionEventsMeasured rdf:type rdf:Property ;
    rdfs:label 'Conversion Events Measured' ;
    rdfs:comment 'Comma-separated list or description of conversion events included in the attribution analysis (e.g., purchase, lead submission, app install, sign-up).' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary values in the attribution study (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourcesIntegrated rdf:type rdf:Property ;
    rdfs:label 'Data Sources Integrated' ;
    rdfs:comment 'List of data sources integrated for the attribution study (e.g., ad server, CRM, pixel data, clean room, DMP, CDP, offline sales).' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Date when the attribution study findings and deliverables were delivered to the client.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementWindowDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Days' ;
    rdfs:comment 'Number of days in the lookback window used to attribute conversions to touchpoints (e.g., 7, 14, 30, 90 days).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Model Confidence Score' ;
    rdfs:comment 'Statistical confidence score or accuracy metric for the attribution model, typically expressed as a percentage (0-100).' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelTrainingEndDate rdf:type rdf:Property ;
    rdfs:label 'Model Training End Date' ;
    rdfs:comment 'End date of the historical data period used to train the attribution model.' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelTrainingStartDate rdf:type rdf:Property ;
    rdfs:label 'Model Training Start Date' ;
    rdfs:comment 'Start date of the historical data period used to train the attribution model.' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Additional notes, comments, or context about the attribution study, including methodology adjustments, data quality issues, or special considerations.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformToolUsed rdf:type rdf:Property ;
    rdfs:label 'Platform Tool Used' ;
    rdfs:comment 'Name of the attribution platform, tool, or software used to conduct the study (e.g., Google Attribution, Neustar, Visual IQ, Rockerbox, custom in-house model).' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'URL or file path to the full attribution study report, dashboard, or presentation deliverable.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roasOverall rdf:type rdf:Property ;
    rdfs:label 'Roas Overall' ;
    rdfs:comment 'Overall Return on Ad Spend (ROAS) calculated across all channels and touchpoints in the attribution study.' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the attribution study for tracking and reference across systems.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Study Completion Date' ;
    rdfs:comment 'Date when the attribution study analysis was completed and finalized.' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'Business-friendly name or title of the attribution study for identification and reporting purposes.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'Date when the attribution study project was initiated or commissioned by the client.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle status of the attribution study (e.g., draft, in progress, under review, completed, delivered, archived, cancelled). [ENUM-REF-CANDIDATE: draft|in_progress|under_review|completed|delivered|archived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Classification of the attribution study methodology and scope (e.g., multi-touch attribution, unified measurement, media mix model).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topPerformingChannel rdf:type rdf:Property ;
    rdfs:label 'Top Performing Channel' ;
    rdfs:comment 'Marketing channel identified as the top performer based on attribution analysis (e.g., paid search, display, social, email, OOH).' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalConversionsAttributed rdf:type rdf:Property ;
    rdfs:label 'Total Conversions Attributed' ;
    rdfs:comment 'Total number of conversions attributed across all touchpoints and channels in the study period.' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueAttributed rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Attributed' ;
    rdfs:comment 'Total revenue amount attributed to marketing touchpoints based on the attribution model.' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationApproach rdf:type rdf:Property ;
    rdfs:label 'Validation Approach' ;
    rdfs:comment 'Method used to validate the accuracy and reliability of the attribution model (e.g., holdout validation, cross-validation, A/B test, control group).' ;
    rdfs:domain ind:AttributionStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceInsightId rdf:type rdf:Property ;
    rdfs:label 'Audience Insight Id' ;
    rdfs:comment 'Unique identifier for the audience insight deliverable. Primary key.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceInsight .

ind:audienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Id' ;
    rdfs:comment 'Reference to the primary audience segment analyzed in this insight.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:creativeBriefId rdf:type rdf:Property ;
    rdfs:label 'Creative Brief Id' ;
    rdfs:comment 'Foreign key linking to creative.creative_brief. Business justification: Audience research (persona insights, behavioral data, segmentation findings) directly informs brief development. Target audience definitions, key messages, and tone-of-voice in briefs are shaped by au' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeBrief .

ind:activationRecommendations rdf:type rdf:Property ;
    rdfs:label 'Activation Recommendations' ;
    rdfs:comment 'Strategic recommendations for how to activate the insight in media planning, creative development, channel selection, and targeting strategies.' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisEndDate rdf:type rdf:Property ;
    rdfs:label 'Analysis End Date' ;
    rdfs:comment 'The date when the analytical work for this insight was completed.' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisMethodology rdf:type rdf:Property ;
    rdfs:label 'Analysis Methodology' ;
    rdfs:comment 'Description of the analytical approach and techniques used to derive the insight (e.g., cohort analysis, regression modeling, clustering, propensity scoring, media mix modeling).' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisStartDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Start Date' ;
    rdfs:comment 'The date when the analytical work for this insight began.' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:audienceSize rdf:type rdf:Property ;
    rdfs:label 'Audience Size' ;
    rdfs:comment 'The estimated or measured size of the audience segment analyzed in this insight, expressed as the number of individuals or households.' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientFeedback rdf:type rdf:Property ;
    rdfs:label 'Client Feedback' ;
    rdfs:comment 'Summary of feedback received from the client regarding the insight deliverable, including requests for revisions, clarifications, or additional analysis.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Statistical confidence level of the insight findings, expressed as a percentage (e.g., 95.00 for 95% confidence). Indicates the reliability of the analytical conclusions.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Data Period End Date' ;
    rdfs:comment 'The end date of the time period covered by the data analyzed in this insight (e.g., the end of the observation window for audience behavior).' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Data Period Start Date' ;
    rdfs:comment 'The start date of the time period covered by the data analyzed in this insight (e.g., the beginning of the observation window for audience behavior).' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSources rdf:type rdf:Property ;
    rdfs:label 'Data Sources' ;
    rdfs:comment 'Comma-separated list or narrative description of the data sources used to generate this insight (e.g., first-party CRM, third-party DMP feeds, Nielsen panel data, Comscore digital measurement, social listening platforms).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the insight deliverable: draft (work in progress), in_review (under internal or client review), approved (finalized and approved), delivered (sent to client), or archived (historical record).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicFocus rdf:type rdf:Property ;
    rdfs:label 'Demographic Focus' ;
    rdfs:comment 'Description of the primary demographic characteristics of the audience analyzed (e.g., age range, gender, income level, education level).' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Description of the geographic coverage of the audience analyzed (e.g., USA, CAN, GBR, or multi-market). Use ISO 3166-1 alpha-3 country codes where applicable.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insightCode rdf:type rdf:Property ;
    rdfs:label 'Insight Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the insight deliverable for tracking and reference across systems and client reports.' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insightName rdf:type rdf:Property ;
    rdfs:label 'Insight Name' ;
    rdfs:comment 'Business-friendly name of the audience insight deliverable, used for identification and reference in client communications and internal tracking.' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insightType rdf:type rdf:Property ;
    rdfs:label 'Insight Type' ;
    rdfs:comment 'Classification of the insight based on the analytical focus: behavioral (actions and interactions), psychographic (attitudes and values), media consumption (channel and content preferences), purchase journey (path to conversion), cross-device (multi-device behavior), or seasonal (time-based patterns).' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insightVersion rdf:type rdf:Property ;
    rdfs:label 'Insight Version' ;
    rdfs:comment 'Version number of the insight deliverable, incremented when the insight is revised or updated based on new data or client feedback.' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyFindings rdf:type rdf:Property ;
    rdfs:label 'Key Findings' ;
    rdfs:comment 'Narrative summary of the primary audience behaviors, preferences, media consumption patterns, and purchase journey insights discovered through the analysis. Core deliverable content.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personaImplications rdf:type rdf:Property ;
    rdfs:label 'Persona Implications' ;
    rdfs:comment 'Description of how the insight findings inform or refine the understanding of target audience personas, including behavioral traits, motivations, and media habits.' ;
    rdfs:domain ind:AudienceInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'The number of data points, individuals, or observations included in the analysis sample used to generate this insight.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandLiftStudyId rdf:type rdf:Property ;
    rdfs:label 'Brand Lift Study Id' ;
    rdfs:comment 'Unique identifier for the brand lift study. Primary key for this entity.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandLiftStudy .

ind:conceptId rdf:type rdf:Property ;
    rdfs:label 'Concept Id' ;
    rdfs:comment 'Foreign key linking to creative.concept. Business justification: Pre-launch brand lift testing evaluates concepts before full production investment. Common for high-budget campaigns to test multiple concepts and select the strongest for production. Reduces creative' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Concept .

ind:creativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Id' ;
    rdfs:comment 'Foreign key linking to creative.creative_asset. Business justification: Brand lift studies measure awareness, favorability, and consideration lift from exposure to specific creative executions. The exposed group sees particular assets; the study must reference them. Stand' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:adRecallLiftPct rdf:type rdf:Property ;
    rdfs:label 'Ad Recall Lift Pct' ;
    rdfs:comment 'Percentage point lift in advertising recall (ability to remember seeing the ad) among the exposed group compared to the control group.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aidedAwarenessLiftPct rdf:type rdf:Property ;
    rdfs:label 'Aided Awareness Lift Pct' ;
    rdfs:comment 'Percentage point lift in aided brand awareness (recognition when prompted) among the exposed group compared to the control group.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandFavorabilityLiftPct rdf:type rdf:Property ;
    rdfs:label 'Brand Favorability Lift Pct' ;
    rdfs:comment 'Percentage point lift in brand favorability or positive sentiment among the exposed group compared to the control group.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandPreferenceLiftPct rdf:type rdf:Property ;
    rdfs:label 'Brand Preference Lift Pct' ;
    rdfs:comment 'Percentage point lift in brand preference (stated preference for this brand over competitors) among the exposed group compared to the control group.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Pct' ;
    rdfs:comment 'Statistical confidence level used for the brand lift study results, typically 90%, 95%, or 99%.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:considerationLiftPct rdf:type rdf:Property ;
    rdfs:label 'Consideration Lift Pct' ;
    rdfs:comment 'Percentage point lift in brand consideration (likelihood to consider the brand when making a purchase decision) among the exposed group compared to the control group.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlGroupDefinition rdf:type rdf:Property ;
    rdfs:label 'Control Group Definition' ;
    rdfs:comment 'Detailed description of the criteria and parameters used to define the control group (users who were not served the advertising campaign).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlSampleSize rdf:type rdf:Property ;
    rdfs:label 'Control Sample Size' ;
    rdfs:comment 'Number of respondents in the control group who completed the brand lift survey.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting the brand lift study, including vendor fees, incentives, and related expenses.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposedGroupDefinition rdf:type rdf:Property ;
    rdfs:label 'Exposed Group Definition' ;
    rdfs:comment 'Detailed description of the criteria and parameters used to define the exposed group (users who were served the advertising campaign).' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposedSampleSize rdf:type rdf:Property ;
    rdfs:label 'Exposed Sample Size' ;
    rdfs:comment 'Number of respondents in the exposed group who completed the brand lift survey.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marginOfErrorPct rdf:type rdf:Property ;
    rdfs:label 'Margin Of Error Pct' ;
    rdfs:comment 'Statistical margin of error for the brand lift study results, expressed as a percentage.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:messageAssociationLiftPct rdf:type rdf:Property ;
    rdfs:label 'Message Association Lift Pct' ;
    rdfs:comment 'Percentage point lift in message association (ability to correctly associate key campaign messages with the brand) among the exposed group compared to the control group.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodologyNotes rdf:type rdf:Property ;
    rdfs:label 'Methodology Notes' ;
    rdfs:comment 'Additional notes and details about the brand lift study methodology, sampling approach, survey design, and any deviations from standard practices.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseIntentLiftPct rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent Lift Pct' ;
    rdfs:comment 'Percentage point lift in purchase intent (stated likelihood to purchase the brand) among the exposed group compared to the control group.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Report Delivery Date' ;
    rdfs:comment 'Date when the final brand lift study report and results were delivered to the client.' ;
    rdfs:domain ind:BrandLiftStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statisticalSignificanceFlag rdf:type rdf:Property ;
