    rdfs:range xsd:integer .

ind:approvalWorkflowEnabled rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Enabled' ;
    rdfs:comment 'Indicates whether completed reviews using this template require approval from senior management or HR before being finalized and shared with the reviewee.' ;
