    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:dashboardWorkerId rdf:type rdf:Property ;
    rdfs:label 'Dashboard Worker Id' ;
    rdfs:comment 'Reference to the data analyst or analytics team member responsible for maintaining and updating this dashboard. Links to the Talent domain.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:mediaInsertionOrderId rdf:type rdf:Property ;
    rdfs:label 'Media Insertion Order Id' ;
    rdfs:comment 'Foreign key linking to media.media_insertion_order. Business justification: Dashboards track IO pacing, delivery, and spend vs authorization. IO-level dashboards monitor vendor delivery and budget utilization. Enables IO-level performance monitoring.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaInsertionOrder .

ind:mediaPlacementId rdf:type rdf:Property ;
    rdfs:label 'Media Placement Id' ;
    rdfs:comment 'Foreign key linking to media.placement. Business justification: Dashboards monitor placement delivery, viewability, and pacing. Placement-level dashboards track real-time performance and delivery issues. Enables placement-level metrics and alerts.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaPlacement .

ind:accessTier rdf:type rdf:Property ;
    rdfs:label 'Access Tier' ;
    rdfs:comment 'Defines the intended audience and access control level for the dashboard. Client-facing dashboards are shared externally. Internal-only dashboards are for agency use. Executive-only dashboards contain sensitive P&L (Profit and Loss) or strategic data. Restricted dashboards require special permissions.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'The current approval state of the dashboard before it can be published to clients or moved to live status. Pending indicates awaiting review. Approved indicates cleared for publication. Rejected indicates not approved. Revision requested indicates feedback provided and changes needed.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The timestamp when the dashboard was approved for publication. Null if not yet approved.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'The timestamp when the dashboard was archived and removed from active use. Null for non-archived dashboards.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dashboardCode rdf:type rdf:Property ;
    rdfs:label 'Dashboard Code' ;
    rdfs:comment 'Short alphanumeric code or identifier used for system references and API calls. Typically uppercase with underscores or hyphens.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardDescription rdf:type rdf:Property ;
    rdfs:label 'Dashboard Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and key insights provided by the dashboard. Includes business context and intended use cases.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardName rdf:type rdf:Property ;
    rdfs:label 'Dashboard Name' ;
    rdfs:comment 'The business name or title of the dashboard as displayed to users and referenced in documentation.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardType rdf:type rdf:Property ;
    rdfs:label 'Dashboard Type' ;
    rdfs:comment 'Classification of the dashboard by its primary analytical purpose. Campaign performance tracks KPIs (Key Performance Indicators) like CTR (Click-Through Rate), CPA (Cost Per Acquisition), ROAS (Return on Ad Spend). Brand health monitors NPS (Net Promoter Score) and brand equity. Audience insights analyze demographic and behavioral segments. Executive summary provides QBR (Quarterly Business Review) level metrics. Media mix evaluates channel performance and MMM (Media Mix Model) outputs. Competitive SOV (Share of Voice) benchmarks against competitors.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deprecated Timestamp' ;
    rdfs:comment 'The timestamp when the dashboard was marked as deprecated and scheduled for retirement. Null for active dashboards.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Indicates whether the dashboard refresh and data pipeline are fully automated (True) or require manual intervention (False).' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClientShared rdf:type rdf:Property ;
    rdfs:label 'Is Client Shared' ;
    rdfs:comment 'Indicates whether this dashboard has been shared with the client (True) or is internal-only (False). Used for access control and audit purposes.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The timestamp when this dashboard record was last updated. Tracks the most recent change to dashboard metadata, configuration, or status.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'The timestamp when the dashboard data was last refreshed from source systems. Used to communicate data freshness to users.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastValidatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Validated Date' ;
    rdfs:comment 'The date when the dashboard data accuracy and calculations were last verified by the owning analyst or QA (Quality Assurance) team. Critical for ensuring data integrity and client trust.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformTool rdf:type rdf:Property ;
    rdfs:label 'Platform Tool' ;
    rdfs:comment 'The business intelligence or analytics platform on which the dashboard is built and hosted. Datorama is now Salesforce Marketing Cloud Intelligence. [ENUM-REF-CANDIDATE: tableau|looker|power_bi|datorama|google_data_studio|salesforce_marketing_cloud_intelligence|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryKpi rdf:type rdf:Property ;
    rdfs:label 'Primary Kpi' ;
    rdfs:comment 'The main KPI (Key Performance Indicator) or metric that this dashboard is designed to track. Examples include ROAS (Return on Ad Spend), CTR (Click-Through Rate), CPA (Cost Per Acquisition), GRP (Gross Rating Point), SOV (Share of Voice), NPS (Net Promoter Score), or CLTV (Customer Lifetime Value).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle state of the dashboard. Development indicates active build. UAT (User Acceptance Testing) indicates client or stakeholder review phase. Live indicates production use. Deprecated indicates scheduled for retirement. Archived indicates historical record only.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'The timestamp when the dashboard was first published to live status and made available to its intended audience. Null for dashboards still in development or UAT (User Acceptance Testing).' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refreshCadence rdf:type rdf:Property ;
    rdfs:label 'Refresh Cadence' ;
    rdfs:comment 'The frequency at which the dashboard data is updated from source systems. Real-time indicates streaming or near-instantaneous updates. On-demand indicates manual refresh triggered by users.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'The end date of the time range covered by the dashboard data. Null for ongoing or open-ended dashboards.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'The start date of the time range covered by the dashboard data. Used to define the analytical window.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'The web URL or deep link to access the live dashboard in the hosting platform. Used for direct navigation and sharing.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the dashboard design and logic. Follows semantic versioning (e.g., v1.0, v2.1.3). Incremented when significant changes are made to layout, metrics, or data sources.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlGroupOutcomeValue rdf:type rdf:Property ;
    rdfs:label 'Control Group Outcome Value' ;
    rdfs:comment 'The observed outcome metric value in the control group during the test period, serving as the counterfactual baseline.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlGroupSize rdf:type rdf:Property ;
    rdfs:label 'Control Group Size' ;
    rdfs:comment 'The number of units (users, households, geographies, or time periods) in the control group that did not receive the media exposure.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incrementalCostPerOutcome rdf:type rdf:Property ;
    rdfs:label 'Incremental Cost Per Outcome' ;
    rdfs:comment 'The cost per incremental outcome unit, calculated as total media spend divided by the number of incremental outcomes attributable to the media. Represents the true Cost Per Acquisition (CPA) or Cost Per Action (CPA) accounting for baseline conversions.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalLiftEstimate rdf:type rdf:Property ;
    rdfs:label 'Incremental Lift Estimate' ;
    rdfs:comment 'The estimated causal lift (percentage increase) in the outcome metric attributable to the media exposure, calculated as (treatment - control) / control. Expressed as a decimal (e.g., 0.15 for 15% lift).' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalRoas rdf:type rdf:Property ;
    rdfs:label 'Incremental Roas' ;
    rdfs:comment 'The incremental revenue generated per dollar of media spend, calculated as incremental revenue divided by media spend. Represents the true Return on Ad Spend (ROAS) accounting for baseline revenue that would have occurred without the media.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isStatisticallySignificant rdf:type rdf:Property ;
    rdfs:label 'Is Statistically Significant' ;
    rdfs:comment 'Boolean flag indicating whether the incremental lift estimate is statistically significant at the pre-defined confidence level. True if p-value is below the significance threshold.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liftConfidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Lift Confidence Interval Lower' ;
    rdfs:comment 'The lower bound of the confidence interval for the incremental lift estimate, representing the minimum plausible lift given the data and confidence level.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liftConfidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Lift Confidence Interval Upper' ;
    rdfs:comment 'The upper bound of the confidence interval for the incremental lift estimate, representing the maximum plausible lift given the data and confidence level.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outcomeMetric rdf:type rdf:Property ;
    rdfs:label 'Outcome Metric' ;
    rdfs:comment 'The primary business outcome being measured for incremental lift (e.g., conversions, revenue, store visits, app installs, brand awareness, consideration). Defines the dependent variable in the causal analysis.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pValue rdf:type rdf:Property ;
    rdfs:label 'P Value' ;
    rdfs:comment 'The p-value from the hypothesis test of whether the incremental lift is statistically significantly different from zero. Values below the significance threshold (typically 0.05 or 0.10) indicate statistical significance.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerAnalysisConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Power Analysis Confidence Level' ;
    rdfs:comment 'The confidence level (1 - alpha) used in power analysis and hypothesis testing, typically 0.90 or 0.95. Defines the probability of correctly rejecting the null hypothesis when the alternative is true.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerAnalysisMinimumDetectableEffect rdf:type rdf:Property ;
    rdfs:label 'Power Analysis Minimum Detectable Effect' ;
    rdfs:comment 'The smallest true effect size (lift percentage) that the test is powered to detect with statistical significance, given the sample size and design. Expressed as a decimal (e.g., 0.05 for 5% lift).' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerAnalysisStatisticalPower rdf:type rdf:Property ;
    rdfs:label 'Power Analysis Statistical Power' ;
    rdfs:comment 'The statistical power (1 - beta) of the test design, representing the probability of detecting a true effect if it exists. Typically targeted at 0.80 or higher.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultsFinalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Results Finalized Timestamp' ;
    rdfs:comment 'The timestamp when the test results were finalized and approved for reporting to the client. Marks the transition from analysis to delivery.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statisticalMethodology rdf:type rdf:Property ;
    rdfs:label 'Statistical Methodology' ;
    rdfs:comment 'The statistical or econometric method used to estimate causal lift. Difference-in-differences compares pre/post changes between treatment and control; synthetic control constructs weighted control from untreated units; Bayesian causal impact uses time-series forecasting; propensity score matching balances covariates; regression discontinuity exploits threshold assignment; randomized control trial uses random assignment.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testChannel rdf:type rdf:Property ;
    rdfs:label 'Test Channel' ;
    rdfs:comment 'The media channel or tactic being tested for incremental contribution (e.g., display, video, social, search, OOH, CTV, audio). May be a specific channel or a combination.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCode rdf:type rdf:Property ;
    rdfs:label 'Test Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the incrementality test for external reference and tracking.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEndDate rdf:type rdf:Property ;
    rdfs:label 'Test End Date' ;
    rdfs:comment 'The date when the incrementality test period concluded. Marks the end of the treatment exposure window.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testName rdf:type rdf:Property ;
    rdfs:label 'Test Name' ;
    rdfs:comment 'Business-friendly name of the incrementality test, used for identification and reporting purposes.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testNotes rdf:type rdf:Property ;
    rdfs:label 'Test Notes' ;
    rdfs:comment 'Free-text field for additional context, observations, caveats, or learnings from the incrementality test. May include notes on data quality issues, external events during the test period, or recommendations for future tests.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testObjective rdf:type rdf:Property ;
    rdfs:label 'Test Objective' ;
    rdfs:comment 'The business question or hypothesis that this incrementality test is designed to answer (e.g., \'Does display advertising drive incremental store visits?\', \'What is the true lift from our CTV campaign?\').' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Start Date' ;
    rdfs:comment 'The date when the incrementality test period began. Marks the start of the treatment exposure window.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the incrementality test. Draft indicates planning phase; planned indicates approved and scheduled; in_flight indicates test is actively running; completed indicates test concluded and results available; cancelled indicates test was terminated before completion; failed indicates test did not meet validity criteria.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'The experimental design methodology used for the incrementality test. Geo holdout withholds treatment from specific geographies; audience holdout withholds from specific user segments; switchback alternates treatment over time; synthetic control constructs a counterfactual control group; matched market pairs similar markets; PSA (Public Service Announcement) test uses PSA impressions as control.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentGroupDefinition rdf:type rdf:Property ;
    rdfs:label 'Treatment Group Definition' ;
    rdfs:comment 'Detailed definition of the treatment group, including targeting criteria, geographic boundaries, audience segments, or time periods that received the media exposure being tested.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentGroupOutcomeValue rdf:type rdf:Property ;
    rdfs:label 'Treatment Group Outcome Value' ;
    rdfs:comment 'The observed outcome metric value in the treatment group during the test period (e.g., total conversions, total revenue, average brand lift score).' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentGroupSize rdf:type rdf:Property ;
    rdfs:label 'Treatment Group Size' ;
    rdfs:comment 'The number of units (users, households, geographies, or time periods) in the treatment group that received the media exposure.' ;
    rdfs:domain ind:IncrementalityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insightFindingId rdf:type rdf:Property ;
    rdfs:label 'Insight Finding Id' ;
    rdfs:comment 'Unique identifier for the insight finding record. Primary key for the insight finding entity.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InsightFinding .

ind:contractDeliverableId rdf:type rdf:Property ;
    rdfs:label 'Contract Deliverable Id' ;
    rdfs:comment 'Reference to the parent analytical deliverable (insight report, MMM study, attribution study, or data science experiment) from which this finding was extracted.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractDeliverable .

ind:insightReportId rdf:type rdf:Property ;
    rdfs:label 'Insight Report Id' ;
    rdfs:comment 'Foreign key linking to analytics.insight_report. Business justification: Findings are extracted from insight reports. This creates a proper parent-child hierarchy where insight_report is the authoritative source document and insight_finding captures individual insights ext' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InsightReport .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when this finding was approved for publication or client delivery. Marks the transition from draft to approved status.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:audienceSegment rdf:type rdf:Property ;
    rdfs:label 'Audience Segment' ;
    rdfs:comment 'Target audience segment or demographic group that this finding pertains to, if applicable. Enables audience-specific insight cataloging.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessImpactClassification rdf:type rdf:Property ;
    rdfs:label 'Business Impact Classification' ;
    rdfs:comment 'Primary business dimension that this finding impacts. Categorizes the strategic value and application area of the insight.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Media channel or platform that this finding relates to (e.g., display, social, search, OTT, OOH). Applicable for channel effectiveness findings.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Client Visibility Flag' ;
    rdfs:comment 'Indicates whether this finding is approved for client visibility and inclusion in client-facing deliverables. False indicates internal-only insight.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creativeElement rdf:type rdf:Property ;
    rdfs:label 'Creative Element' ;
    rdfs:comment 'Specific creative element, message, or asset that this finding analyzes (e.g., headline variant, color scheme, call-to-action). Applicable for creative performance findings.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Primary data source or system from which the analytical data for this finding was extracted (e.g., Google Analytics, Campaign Manager 360, Nielsen, Comscore).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNarrative rdf:type rdf:Property ;
    rdfs:label 'Finding Narrative' ;
    rdfs:comment 'Detailed narrative description of the insight finding, including context, analysis methodology, and interpretation of results. The full story behind the finding.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the insight finding within the analytical workflow and approval process.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Concise, descriptive title of the insight finding that summarizes the key discovery or recommendation.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the insight finding by analytical category. Determines the nature of the discovery and its application domain.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactValueUnit rdf:type rdf:Property ;
    rdfs:label 'Impact Value Unit' ;
    rdfs:comment 'Unit of measure for the quantified impact value (e.g., USD, percentage, basis points, impressions).' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiImpacted rdf:type rdf:Property ;
    rdfs:label 'Kpi Impacted' ;
    rdfs:comment 'Primary KPI or metric that this finding directly affects or provides insight into (e.g., CTR, ROAS, CPA, brand awareness).' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Analytical methodology or technique used to derive this finding (e.g., regression analysis, A/B test, cohort analysis, MMM, attribution modeling).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when this finding was published or delivered to the client. Marks the official release of the insight.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantifiedImpactValue rdf:type rdf:Property ;
    rdfs:label 'Quantified Impact Value' ;
    rdfs:comment 'Numerical quantification of the findings business impact, if measurable (e.g., projected revenue lift, cost savings, efficiency gain). Unit depends on impact classification.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Specific, actionable recommendation based on this finding. Describes what the client or internal team should do in response to this insight.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedFindingIds rdf:type rdf:Property ;
    rdfs:label 'Related Finding Ids' ;
    rdfs:comment 'Comma-separated list of related insight finding IDs that are connected to or build upon this finding. Enables insight graph navigation.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reusabilityScore rdf:type rdf:Property ;
    rdfs:label 'Reusability Score' ;
    rdfs:comment 'Score indicating the potential for this finding to be reused or referenced in future analyses or client deliverables. Scale 1-10, with 10 being highly reusable.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statisticalSignificance rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance' ;
    rdfs:comment 'P-value or statistical significance level of the finding, if applicable. Indicates the probability that the observed result occurred by chance.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingEvidenceSummary rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence Summary' ;
    rdfs:comment 'Summary of the data, metrics, statistical tests, and analytical evidence that support this finding. References to charts, tables, or data sources that validate the insight.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Time Period End' ;
    rdfs:comment 'End date of the analysis time period for this finding. Defines the temporal scope of the data analyzed.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Time Period Start' ;
    rdfs:comment 'Start date of the analysis time period for this finding. Defines the temporal scope of the data analyzed.' ;
    rdfs:domain ind:InsightFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedByWorkerId rdf:type rdf:Property ;
    rdfs:label 'Approved By Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Report approval is the quality control gate before client delivery. Tracking the approving worker is essential for accountability, compliance with client contracts, and managing approval SLAs. Current' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:archivedDate rdf:type rdf:Property ;
    rdfs:label 'Archived Date' ;
    rdfs:comment 'The date on which the insight report was moved to archived status, indicating it is no longer actively used but retained for historical reference.' ;
    rdfs:domain ind:InsightReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'Comma-separated list of email addresses or contact identifiers for recipients of this report. Contains client and internal stakeholder contacts.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiMetricsIncluded rdf:type rdf:Property ;
    rdfs:label 'Kpi Metrics Included' ;
    rdfs:comment 'Comma-separated list of KPI metrics analyzed and reported in this insight report (e.g., CPM, CPC, CTR, CPA, ROAS, ROI, GRP, TRP, VTR).' ;
    rdfs:domain ind:InsightReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'The primary language in which the report is written (e.g., English, Spanish, French).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAnalystName rdf:type rdf:Property ;
    rdfs:label 'Lead Analyst Name' ;
    rdfs:comment 'The full name of the principal analyst who authored or led the creation of this insight report.' ;
    rdfs:domain ind:InsightReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningAnalystTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Analyst Team' ;
    rdfs:comment 'The name or identifier of the analytics team responsible for producing this report.' ;
    rdfs:domain ind:InsightReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'The total number of pages or slides in the delivered report document.' ;
    rdfs:domain ind:InsightReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendations rdf:type rdf:Property ;
    rdfs:label 'Recommendations' ;
    rdfs:comment 'Actionable recommendations provided to the client based on the analysis, including optimization strategies, budget reallocation suggestions, and tactical adjustments.' ;
    rdfs:domain ind:InsightReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportFilePath rdf:type rdf:Property ;
    rdfs:label 'Report File Path' ;
    rdfs:comment 'The storage location or URI where the final report deliverable is stored (e.g., cloud storage path, DAM system reference).' ;
    rdfs:domain ind:InsightReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the insight report. Tracks progression from draft through review, approval, delivery, and archival.' ;
    rdfs:domain ind:InsightReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTitle rdf:type rdf:Property ;
    rdfs:label 'Report Title' ;
    rdfs:comment 'The formal title of the analytical insight report or deliverable as presented to the client.' ;
    rdfs:domain ind:InsightReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the insight report by analytical purpose. Includes campaign post-mortem, brand health, audience analysis, competitive landscape, MMM (Media Mix Model) readout, attribution study, performance summary, QBR (Quarterly Business Review), and custom analysis. [ENUM-REF-CANDIDATE: campaign_post_mortem|brand_health|audience_analysis|competitive_landscape|mmm_readout|attribution_study|performance_summary|quarterly_business_review|custom_analysis — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The end date of the time period covered by this analytical report. Defines the conclusion of the data observation window.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The start date of the time period covered by this analytical report. Defines the beginning of the data observation window.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'The version identifier of the report, tracking iterations and revisions (e.g., 1.0, 1.1, 2.0).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientOnboardingId rdf:type rdf:Property ;
    rdfs:label 'Client Onboarding Id' ;
    rdfs:comment 'Foreign key linking to client.client_onboarding. Business justification: New client onboarding includes establishing baseline measurement frameworks and KPI definitions. Links measurement plan to onboarding process enables tracking setup phase completion and ensures analyt' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientOnboarding .

ind:analystOwner rdf:type rdf:Property ;
    rdfs:label 'Analyst Owner' ;
    rdfs:comment 'Name or identifier of the data analyst or data scientist responsible for executing the measurement plan and delivering insights.' ;
    rdfs:domain ind:MeasurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the measurement plan received final approval from the client or internal stakeholder.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Days' ;
    rdfs:comment 'Number of days after ad exposure during which conversions or actions are attributed back to the campaign, commonly 7, 14, or 30 days.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineBenchmark rdf:type rdf:Property ;
    rdfs:label 'Baseline Benchmark' ;
    rdfs:comment 'Pre-campaign baseline metric or benchmark value used as the control point for measuring lift, improvement, or incremental impact.' ;
    rdfs:domain ind:MeasurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Description of regulatory and privacy compliance requirements applicable to this measurement plan, such as GDPR (General Data Protection Regulation), CCPA (California Consumer Privacy Act), or industry-specific standards.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated cost to execute the measurement plan, including vendor fees, data acquisition costs, and internal resource allocation.' ;
    rdfs:domain ind:MeasurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCollectionApproach rdf:type rdf:Property ;
    rdfs:label 'Data Collection Approach' ;
    rdfs:comment 'Description of how data will be collected for measurement, including sources (pixel tracking, survey panels, CRM integration, third-party data feeds), collection frequency, and data quality controls.' ;
    rdfs:domain ind:MeasurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableFormat rdf:type rdf:Property ;
    rdfs:label 'Deliverable Format' ;
    rdfs:comment 'Format in which measurement insights and reports will be delivered to the client, such as interactive dashboards, PDF reports, or API feeds.' ;
    rdfs:domain ind:MeasurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdoutTestDesign rdf:type rdf:Property ;
    rdfs:label 'Holdout Test Design' ;
    rdfs:comment 'Description of the holdout or control group design used for incrementality testing, including sample size, randomization approach, and geographic or audience segmentation.' ;
    rdfs:domain ind:MeasurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Primary analytical methodology applied in this measurement plan. Brand lift measures awareness and perception changes; sales lift measures direct revenue impact; MTA (Multi-Touch Attribution) assigns credit across touchpoints; MMM (Media Mix Modeling) evaluates channel contribution; incrementality testing uses holdout groups to isolate causal impact. [ENUM-REF-CANDIDATE: brand_lift|sales_lift|multi_touch_attribution|media_mix_modeling|incrementality_testing|attribution_modeling|cross_media_measurement|unified_measurement — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementObjective rdf:type rdf:Property ;
    rdfs:label 'Measurement Objective' ;
    rdfs:comment 'High-level strategic objective of the measurement plan, describing what business question or hypothesis the plan is designed to answer.' ;
    rdfs:domain ind:MeasurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementVendor rdf:type rdf:Property ;
    rdfs:label 'Measurement Vendor' ;
    rdfs:comment 'Name of the third-party measurement vendor or platform used to execute the measurement plan, such as Nielsen, Comscore, or a specialized attribution provider.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Window End Date' ;
    rdfs:comment 'The end date of the measurement period, marking the conclusion of data collection for this plan.' ;
    rdfs:domain ind:MeasurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Start Date' ;
    rdfs:comment 'The start date of the measurement period during which data will be collected and analyzed.' ;
    rdfs:domain ind:MeasurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current operational status of the measurement plan in its lifecycle.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number of the measurement plan, incremented with each revision or update to track plan evolution.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCadence rdf:type rdf:Property ;
    rdfs:label 'Reporting Cadence' ;
    rdfs:comment 'Frequency at which measurement results and insights will be delivered to the client, aligned with QBR (Quarterly Business Review) or campaign milestones. [ENUM-REF-CANDIDATE: daily|weekly|bi_weekly|monthly|quarterly|end_of_campaign|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Free-text notes documenting changes made in the current version of the measurement plan, including rationale for revisions.' ;
    rdfs:domain ind:MeasurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryKpi rdf:type rdf:Property ;
    rdfs:label 'Secondary Kpi' ;
    rdfs:comment 'Additional KPI (Key Performance Indicator) tracked to provide supplementary insight into campaign performance, such as engagement rate, VTR (View-Through Rate), or CPA (Cost Per Acquisition).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceDefinition rdf:type rdf:Property ;
    rdfs:label 'Target Audience Definition' ;
    rdfs:comment 'Detailed definition of the target audience for measurement, including demographic, psychographic, and behavioral criteria used to define the in-scope population.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date on which the MMM study analysis was completed and finalized.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Total budget allocated by the client for conducting this MMM study, including data acquisition, modeling, and delivery costs.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Status indicating whether the MMM model has been calibrated against known market conditions or holdout data to ensure accuracy.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'The date on which the MMM study was officially commissioned or initiated by the client.' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalVendorTool rdf:type rdf:Property ;
    rdfs:label 'External Vendor Tool' ;
    rdfs:comment 'Specific software tool or platform used by the external vendor for MMM analysis (e.g., Nielsen Marketing Cloud, Analytic Partners ROI Genome, Ekimetrics Copilot).' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:granularityLevel rdf:type rdf:Property ;
    rdfs:label 'Granularity Level' ;
    rdfs:comment 'The time granularity at which the MMM model operates and produces insights (e.g., daily, weekly, monthly, quarterly).' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdoutValidationApproach rdf:type rdf:Property ;
    rdfs:label 'Holdout Validation Approach' ;
    rdfs:comment 'The method used to validate the MMM model using holdout data (e.g., time-based split, geographic holdout, random sample, or no holdout).' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mape rdf:type rdf:Property ;
    rdfs:label 'Mape' ;
    rdfs:comment 'Mean Absolute Percentage Error metric representing the average absolute percentage difference between predicted and actual values, indicating model accuracy.' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaChannelsIncluded rdf:type rdf:Property ;
    rdfs:label 'Media Channels Included' ;
    rdfs:comment 'Comma-separated list or description of all media channels included in the MMM analysis (e.g., TV, Digital Display, Search, Social, OOH, Radio, Print).' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelingMethodology rdf:type rdf:Property ;
    rdfs:label 'Modeling Methodology' ;
    rdfs:comment 'Statistical or machine learning methodology employed for the Media Mix Model analysis (e.g., Bayesian, frequentist, Robyn, Meridian). [ENUM-REF-CANDIDATE: bayesian|frequentist|robyn|meridian|time_series|regression|machine_learning — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Modeling Period End Date' ;
    rdfs:comment 'The end date of the historical data period used for building and training the Media Mix Model.' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Modeling Period Start Date' ;
    rdfs:comment 'The start date of the historical data period used for building and training the Media Mix Model.' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeVariable rdf:type rdf:Property ;
    rdfs:label 'Outcome Variable' ;
    rdfs:comment 'The dependent variable or business outcome being modeled and optimized in the MMM study (e.g., revenue, sales volume, leads, conversions).' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rSquared rdf:type rdf:Property ;
    rdfs:label 'R Squared' ;
    rdfs:comment 'R-squared coefficient of determination indicating the proportion of variance in the outcome variable explained by the media mix model (range 0 to 1).' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmse rdf:type rdf:Property ;
    rdfs:label 'Rmse' ;
    rdfs:comment 'Root Mean Squared Error metric representing the standard deviation of prediction errors, providing a measure of model accuracy in the same units as the outcome variable.' ;
    rdfs:domain ind:MmmStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'The planned or target date for completing the MMM study analysis and delivering results to the client.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Report Delivery Id' ;
    rdfs:comment 'Unique identifier for each report or dashboard delivery instance. Primary key for the report delivery transaction.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportScheduleId rdf:type rdf:Property ;
    rdfs:label 'Report Schedule Id' ;
    rdfs:comment 'Foreign key linking to analytics.report_schedule. Business justification: Links report delivery instances back to the report schedule that triggered them. The delivery_trigger field on report_delivery indicates some deliveries are \'scheduled\' vs \'ad_hoc\' or \'manual\'. For sc' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportSchedule .

ind:slaId rdf:type rdf:Property ;
    rdfs:label 'Sla Id' ;
    rdfs:comment 'Foreign key linking to contract.sla. Business justification: Report deliveries are measured against SLA targets for timeliness and quality. Critical for tracking SLA compliance and identifying breaches requiring remediation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sla .

ind:clientAcknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Client Acknowledgment Status' ;
    rdfs:comment 'Indicates whether the client has acknowledged receipt and acceptance of the delivered report. Used for contractual compliance and client satisfaction tracking.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Client Acknowledgment Timestamp' ;
    rdfs:comment 'The date and time when the client formally acknowledged receipt of the report. Nullable if acknowledgment is pending or not required.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The technical channel or mechanism used to deliver the report. Indicates how the content was transmitted to the recipient.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes or comments about this delivery instance. Captures special instructions, exceptions, or contextual information.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Human-readable business identifier for the delivery instance. Format: DEL-YYYYMMDD-XXXXXX. Used for tracking and client communication.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPriority rdf:type rdf:Property ;
    rdfs:label 'Delivery Priority' ;
    rdfs:comment 'The priority level assigned to this delivery. Used for queue management and SLA enforcement.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySourceSystem rdf:type rdf:Property ;
    rdfs:label 'Delivery Source System' ;
    rdfs:comment 'The name or identifier of the system or platform that generated and delivered the report. Examples: Tableau, Power BI, custom analytics platform.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The exact date and time when the report or dashboard was delivered to the recipient. Primary business event timestamp for SLA tracking.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryTrigger rdf:type rdf:Property ;
    rdfs:label 'Delivery Trigger' ;
    rdfs:comment 'The mechanism that initiated this delivery. Distinguishes between automated scheduled deliveries and manual or event-driven requests.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryUrl rdf:type rdf:Property ;
    rdfs:label 'Delivery Url' ;
    rdfs:comment 'The URL or link where the recipient can access the delivered report or dashboard. Nullable for file-based deliveries.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionFlag rdf:type rdf:Property ;
    rdfs:label 'Encryption Flag' ;
    rdfs:comment 'Boolean indicator of whether the delivered file or content was encrypted for security. True if encrypted, false otherwise.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Technical error message or exception details if the delivery failed or bounced. Nullable for successful deliveries.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'The date and time when access to the delivered report expires. Nullable for permanent access deliveries.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'The file format in which the report or dashboard was delivered. Indicates the output format provided to the recipient.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'The size of the delivered file in bytes. Used for delivery performance monitoring and storage tracking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'The date and time when the recipient first opened or accessed the delivered report or dashboard. Nullable if not yet opened or tracking unavailable.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:passwordProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Password Protected Flag' ;
    rdfs:comment 'Boolean indicator of whether the delivered file requires a password to open. True if password-protected, false otherwise.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryRecipientEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Recipient Email' ;
    rdfs:comment 'The primary email address of the main recipient for this delivery. Used for client engagement tracking and communication.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientList rdf:type rdf:Property ;
    rdfs:label 'Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses or user identifiers who received this delivery. Captures the actual recipient list at time of delivery for audit purposes.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Report Period End Date' ;
    rdfs:comment 'The end date of the reporting period covered by this delivered report. Used for report content tracking and analytics.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Report Period Start Date' ;
    rdfs:comment 'The start date of the reporting period covered by this delivered report. Used for report content tracking and analytics.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'The number of retry attempts made for this delivery. Zero for successful first-attempt deliveries.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'The planned date and time for delivery when scheduled in advance. Nullable for ad-hoc deliveries. Used to measure delivery timeliness.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaActualMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Minutes' ;
    rdfs:comment 'The actual time in minutes from request to delivery. Used to measure SLA compliance and delivery performance.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Boolean indicator of whether the delivery met the SLA target. True if delivered within SLA, false otherwise.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'The contracted or expected delivery time in minutes from request to delivery. Used for SLA compliance tracking.' ;
    rdfs:domain ind:ReportDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Foreign key linking to client.client_preference. Business justification: Report schedules must align with client preferences for cadence, format, and delivery method. Links schedule to preference record ensures automated reporting respects client communication preferences—' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Preference .

ind:primaryReportWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Report Worker Id' ;
    rdfs:comment 'Reference to the internal user or team responsible for maintaining and managing this report schedule. Links to employee or team master data.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:recipientGroupId rdf:type rdf:Property ;
    rdfs:label 'Recipient Group Id' ;
    rdfs:comment 'Reference to a predefined recipient group or distribution list. Alternative to individual recipient list for managing large or dynamic audiences.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecipientGroup .

ind:tertiaryReportModifiedByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Report Modified By User Worker Id' ;
    rdfs:comment 'Reference to the user who last modified this report schedule. Links to employee or user master data for accountability.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:autoGenerationFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generation Flag' ;
    rdfs:comment 'Indicates whether the report is automatically generated and sent without manual intervention. True for fully automated schedules, false for manual approval workflows.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customParameters rdf:type rdf:Property ;
    rdfs:label 'Custom Parameters' ;
    rdfs:comment 'JSON or key-value string containing custom report parameters such as filters, date ranges, or specific metrics to include. Enables flexible report configuration.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRefreshLagHours rdf:type rdf:Property ;
    rdfs:label 'Data Refresh Lag Hours' ;
    rdfs:comment 'Number of hours of data latency expected before report generation. Ensures reports are generated after source data is fully refreshed and available.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryDayOfMonth rdf:type rdf:Property ;
    rdfs:label 'Delivery Day Of Month' ;
    rdfs:comment 'Specific day of the month for monthly or quarterly delivery schedules. Value between 1 and 31. Nullable for non-monthly frequencies.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Delivery Day Of Week' ;
    rdfs:comment 'Specific day of the week for weekly delivery schedules. Nullable for non-weekly frequencies. [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'File format or presentation format for the delivered report. Determines how the report content is packaged for recipients.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFrequency rdf:type rdf:Property ;
    rdfs:label 'Delivery Frequency' ;
    rdfs:comment 'Recurrence pattern for report delivery. Defines how often the report or dashboard is automatically generated and sent to recipients.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMessageBody rdf:type rdf:Property ;
    rdfs:label 'Delivery Message Body' ;
    rdfs:comment 'Email body text or message content accompanying the report delivery. Provides context and instructions to recipients.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySubjectLine rdf:type rdf:Property ;
    rdfs:label 'Delivery Subject Line' ;
    rdfs:comment 'Email subject line or message title used when delivering the report. Supports dynamic tokens for date, client name, or campaign name.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Time' ;
    rdfs:comment 'Time of day for scheduled delivery in HH:MM format (24-hour clock). Represents the target time for report generation and distribution.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryTimezone rdf:type rdf:Property ;
    rdfs:label 'Delivery Timezone' ;
    rdfs:comment 'Timezone for the delivery time. Uses IANA timezone database format (e.g., America/New_York, Europe/London).' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which this report schedule expires and stops executing deliveries. Nullable for indefinite schedules.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this report schedule becomes active and begins executing deliveries. Supports future-dated schedule activation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failureNotificationContacts rdf:type rdf:Property ;
    rdfs:label 'Failure Notification Contacts' ;
    rdfs:comment 'Comma-separated list of email addresses or user identifiers to notify when a scheduled delivery fails. Used for operational alerting and SLA management.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includeComparisonPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Include Comparison Period Flag' ;
    rdfs:comment 'Indicates whether the report should include prior period comparison data (e.g., week-over-week, month-over-month, year-over-year).' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDeliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Status' ;
    rdfs:comment 'Outcome status of the most recent delivery attempt. Indicates whether the last scheduled delivery completed successfully.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful delivery execution. Used for tracking delivery history and SLA compliance.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextScheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Delivery Date' ;
    rdfs:comment 'The next date on which this report schedule is set to execute. Updated after each successful delivery.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retryIntervalMinutes rdf:type rdf:Property ;
    rdfs:label 'Retry Interval Minutes' ;
    rdfs:comment 'Number of minutes to wait between retry attempts for failed deliveries. Defines the backoff strategy for delivery failures.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Schedule Description' ;
    rdfs:comment 'Detailed description of the schedule purpose, audience, and any special instructions for delivery or content.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Business-friendly name for the report schedule. Used for identification and management of recurring deliveries.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current operational status of the report schedule. Determines whether the schedule is actively executing deliveries.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeliveryWindowHours rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Window Hours' ;
    rdfs:comment 'Maximum number of hours allowed from scheduled time to successful delivery to meet SLA commitments. Used for performance monitoring and client satisfaction tracking.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDeliveriesCount rdf:type rdf:Property ;
    rdfs:label 'Total Deliveries Count' ;
    rdfs:comment 'Cumulative count of all delivery attempts (successful and failed) for this schedule since creation. Used for usage analytics and performance monitoring.' ;
    rdfs:domain ind:ReportSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationId rdf:type rdf:Property ;
    rdfs:label 'Activation Id' ;
    rdfs:comment 'Unique identifier for the audience activation record. Primary key.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activation .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Foreign key linking to finance.budget_line. Business justification: Each audience activation to a DSP/platform consumes a specific budget line (media spend allocation). Finance teams reconcile activation costs against budget lines. This link enables activation-level s' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:creativeDeliverableId rdf:type rdf:Property ;
    rdfs:label 'Creative Deliverable Id' ;
    rdfs:comment 'Foreign key linking to creative.creative_deliverable. Business justification: Activations reference deliverables for media plan execution; trafficking workflows map segments to specific creative deliverables to ensure correct creative versions serve to each audience across chan' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeDeliverable .

ind:dmpIntegrationId rdf:type rdf:Property ;
    rdfs:label 'Dmp Integration Id' ;
    rdfs:comment 'Foreign key linking to audience.dmp_integration. Business justification: audience_activation has target_platform (string) indicating which DSP/SSP/DMP the segment was activated to. dmp_integration is the configuration record for DMP/CDP platforms. Adding dmp_integration_id' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DmpIntegration .

ind:platformAudienceAudienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Platform Audience Audience Segment Id' ;
    rdfs:comment 'External identifier assigned by the target platform (DSP/SSP) for this activated audience segment.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:platformIntegrationId rdf:type rdf:Property ;
    rdfs:label 'Platform Integration Id' ;
    rdfs:comment 'Technical identifier for the API integration or connection used to push data to the target platform.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DmpIntegration .

ind:suppressionListId rdf:type rdf:Property ;
    rdfs:label 'Suppression List Id' ;
    rdfs:comment 'Foreign key linking to audience.suppression_list. Business justification: audience_activation pushes segments to DSPs/SSPs. suppression_list defines identifiers to exclude from targeting. An activation should reference which suppression list was applied to ensure excluded i' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SuppressionList .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the audience segment was activated and pushed to the target platform.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activationMethod rdf:type rdf:Property ;
    rdfs:label 'Activation Method' ;
    rdfs:comment 'Technical method used to push the audience segment to the target platform. API = Application Programming Interface, S2S = Server-to-Server integration.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationName rdf:type rdf:Property ;
    rdfs:label 'Activation Name' ;
    rdfs:comment 'Business-friendly name or label for this activation instance.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current operational status of the audience activation in its lifecycle.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'Precise timestamp when the activation was initiated and the segment push began.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activationType rdf:type rdf:Property ;
    rdfs:label 'Activation Type' ;
    rdfs:comment 'Classification of the activation purpose and targeting strategy.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidModifier rdf:type rdf:Property ;
    rdfs:label 'Bid Modifier' ;
    rdfs:comment 'Multiplier applied to base bid amounts for this audience segment (e.g., 1.25 = 25% bid increase, 0.80 = 20% bid decrease).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentFramework rdf:type rdf:Property ;
    rdfs:label 'Consent Framework' ;
    rdfs:comment 'Privacy consent framework applied to this activation. IAB TCF = Interactive Advertising Bureau Transparency and Consent Framework.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Privacy consent status for the audience segment members at the time of activation, ensuring GDPR and CCPA compliance.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCpm rdf:type rdf:Property ;
    rdfs:label 'Cost Cpm' ;
    rdfs:comment 'Cost per thousand impressions charged by the data provider or platform for activating this audience segment.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceType rdf:type rdf:Property ;
    rdfs:label 'Data Source Type' ;
    rdfs:comment 'Origin classification of the audience data being activated (first-party = owned, second-party = partner, third-party = purchased).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach' ;
    rdfs:comment 'Estimated number of unique users or devices in the activated audience segment available for targeting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCap rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap' ;
    rdfs:comment 'Maximum number of times an individual user in the activated segment should be exposed to campaign creative within the frequency window.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCapWindowHours rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Window Hours' ;
    rdfs:comment 'Time window in hours over which the frequency cap is applied.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful synchronization of audience data to the target platform.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Match Rate Percentage' ;
    rdfs:comment 'Percentage of audience segment records successfully matched and recognized by the target platform, expressed as a decimal (e.g., 75.50 for 75.5%).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchedUserCount rdf:type rdf:Property ;
    rdfs:label 'Matched User Count' ;
    rdfs:comment 'Actual number of users or devices successfully matched by the target platform during activation.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Sync Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next audience data synchronization to the target platform.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to this activation for resource allocation and optimization decisions.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncFrequency rdf:type rdf:Property ;
    rdfs:label 'Sync Frequency' ;
    rdfs:comment 'Cadence at which the audience segment membership is refreshed and re-synced to the target platform.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unmatchedUserCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched User Count' ;
    rdfs:comment 'Number of users or devices from the segment that could not be matched by the target platform.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Audience Consent Record Id' ;
    rdfs:comment 'Unique identifier for the audience consent record. Primary key for the consent record entity.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceConsentRecord .

ind:audienceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Audience Identifier' ;
    rdfs:comment 'Unique identifier for the audience member or device (e.g., hashed email, device ID, cookie ID, customer ID). This is the subject of the consent record.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdpProfileSyncEnabled rdf:type rdf:Property ;
    rdfs:label 'Cdp Profile Sync Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this audience identifier is enabled for synchronization with Customer Data Platforms for unified profile building.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'Channel or interface through which the consent was captured (e.g., web, mobile app, email, call center, in-person, API, partner portal). [ENUM-REF-CANDIDATE: web|mobile_app|email|call_center|in_person|api|partner_portal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'Date when the consent expires and must be re-confirmed. Null if consent does not expire or is perpetual until withdrawn.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the language in which the consent notice was presented to the audience member.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'Method by which consent was obtained (e.g., explicit opt-in, implicit opt-in, opt-out, pre-checked box, granular choice, bundled consent). Critical for GDPR compliance assessment.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentNoticeUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Notice Url' ;
    rdfs:comment 'URL or reference to the full privacy notice or consent text that was presented to the audience member. Provides traceability to the exact terms accepted.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentNoticeVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Notice Version' ;
    rdfs:comment 'Version identifier of the privacy notice or consent text that was presented to the audience member at the time of consent capture. Used for audit and compliance tracking.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentProofDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Document Url' ;
    rdfs:comment 'URL or storage path to the archived proof of consent (e.g., screenshot, signed form, audit log entry). Used for regulatory audit and dispute resolution.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScopeAnalytics rdf:type rdf:Property ;
    rdfs:label 'Consent Scope Analytics' ;
    rdfs:comment 'Boolean flag indicating whether consent has been granted for analytics and measurement purposes.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentScopeDataSharing rdf:type rdf:Property ;
    rdfs:label 'Consent Scope Data Sharing' ;
    rdfs:comment 'Boolean flag indicating whether consent has been granted for sharing audience data with third parties or partners.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentScopePersonalization rdf:type rdf:Property ;
    rdfs:label 'Consent Scope Personalization' ;
    rdfs:comment 'Boolean flag indicating whether consent has been granted for content personalization and recommendation purposes.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentScopeTargeting rdf:type rdf:Property ;
    rdfs:label 'Consent Scope Targeting' ;
    rdfs:comment 'Boolean flag indicating whether consent has been granted for audience targeting and personalized advertising purposes.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'Source system or channel through which the consent was captured (e.g., Consent Management Platform, preference center, opt-in form, registration flow, API integration, data import, or default setting). [ENUM-REF-CANDIDATE: cmp|preference_center|opt_in_form|registration|api|import|default — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Consent Source System' ;
    rdfs:comment 'Name or identifier of the specific system or platform that captured the consent (e.g., OneTrust, TrustArc, Salesforce Marketing Cloud, custom CMP).' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Date and time when the consent was originally granted or denied by the audience member. This is the primary business event timestamp for the consent action.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dmpSegmentSyncEnabled rdf:type rdf:Property ;
    rdfs:label 'Dmp Segment Sync Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this audience identifier is enabled for synchronization with Data Management Platforms for segment targeting.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotSellFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Sell Flag' ;
    rdfs:comment 'Boolean flag indicating whether the audience member has exercised their right to opt out of the sale of personal information under CCPA. True means do not sell.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalPrivacyControlSignal rdf:type rdf:Property ;
    rdfs:label 'Global Privacy Control Signal' ;
    rdfs:comment 'Boolean flag indicating whether a Global Privacy Control signal was detected from the user\'s browser or device at the time of consent capture. True means GPC signal was present.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'Type of audience identifier used in this consent record (e.g., email hash, device ID, cookie ID, customer ID, mobile advertising ID, CRM ID).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the device or user at the time consent was captured. Used for audit trail and fraud detection. May be considered PII in some jurisdictions.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether this consent record is currently active and should be enforced. False indicates the record is superseded or archived.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMinor rdf:type rdf:Property ;
    rdfs:label 'Is Minor' ;
    rdfs:comment 'Boolean flag indicating whether the audience member is a minor (under age of consent in their jurisdiction). Triggers additional COPPA or GDPR Article 8 protections.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Primary privacy regulation or jurisdiction governing this consent record (e.g., GDPR for European Union, CCPA for California, COPPA for children under 13, LGPD for Brazil, PIPEDA for Canada, APPI for Japan, POPIA for South Africa). [ENUM-REF-CANDIDATE: GDPR|CCPA|COPPA|LGPD|PIPEDA|APPI|POPIA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country or region where the consent was captured or where the audience member resides.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verification Timestamp' ;
    rdfs:comment 'Date and time when the consent status was last verified or re-confirmed with the audience member. Used for periodic consent refresh workflows.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentalConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Required' ;
    rdfs:comment 'Boolean flag indicating whether parental or guardian consent is required for this audience member due to age restrictions.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Timestamp' ;
    rdfs:comment 'Date and time when parental or guardian consent was obtained. Null if not applicable or not yet obtained.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tcfConsentString rdf:type rdf:Property ;
    rdfs:label 'Tcf Consent String' ;
    rdfs:comment 'IAB Transparency and Consent Framework encoded consent string capturing granular vendor and purpose consents. Used for programmatic advertising compliance.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingEnabled rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Enabled' ;
    rdfs:comment 'Boolean flag indicating whether audience data associated with this identifier can be shared with third-party partners or vendors.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'Browser or application user agent string at the time consent was captured. Provides technical context for the consent event.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Optional free-text or coded reason provided by the audience member for withdrawing consent. Used for compliance documentation and user experience improvement.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'Date and time when the consent was withdrawn by the audience member. Null if consent has not been withdrawn.' ;
    rdfs:domain ind:AudienceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxonomyId rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Id' ;
    rdfs:comment 'Unique identifier for the audience taxonomy node. Primary key for the audience taxonomy reference structure.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Taxonomy .

ind:ownerWorkerId rdf:type rdf:Property ;
    rdfs:label 'Owner Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Taxonomies are strategic classification frameworks requiring governance and change management. Tracking the responsible worker supports standards enforcement, version control, and cross-functional ali' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:parentTaxonomyId rdf:type rdf:Property ;
    rdfs:label 'Parent Taxonomy Id' ;
    rdfs:comment 'Reference to the parent node in the taxonomy hierarchy. Null for top-level (tier 1) categories. Enables hierarchical navigation and roll-up reporting.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Taxonomy .

ind:primaryReplacementTaxonomyId rdf:type rdf:Property ;
    rdfs:label 'Primary Replacement Taxonomy Id' ;
    rdfs:comment 'Reference to the taxonomy node that replaces this deprecated category. Null for active categories or deprecated categories without direct replacement. Enables automated migration of historical segments.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Taxonomy .

ind:applicablePlatforms rdf:type rdf:Property ;
    rdfs:label 'Applicable Platforms' ;
    rdfs:comment 'Comma-separated list of digital platforms and channels where this taxonomy category is applicable (e.g., display, video, social, search, CTV, DOOH). Guides media planners on appropriate channel selection.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageCpmUsd rdf:type rdf:Property ;
    rdfs:label 'Average Cpm Usd' ;
    rdfs:comment 'Average cost per thousand impressions in US dollars for media buys targeting this audience category. Based on historical campaign data and current market rates. Used for budget planning and cost estimation.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the audience category, including defining characteristics, typical behaviors, and use cases. Provides guidance for media planners and data analysts on appropriate segment application.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the audience taxonomy category. Used in campaign planning interfaces, reporting dashboards, and client presentations.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdpIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Cdp Integration Enabled' ;
    rdfs:comment 'Indicates whether this taxonomy category is integrated with Customer Data Platform for unified customer profile enrichment and personalization. True enables real-time audience orchestration across owned channels.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:comscoreCompatible rdf:type rdf:Property ;
    rdfs:label 'Comscore Compatible' ;
    rdfs:comment 'Indicates whether this taxonomy category can be mapped to Comscore digital audience measurement segments for cross-platform analytics and validation. True enables independent third-party audience verification.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Required' ;
    rdfs:comment 'Indicates whether explicit user consent is required under GDPR, CCPA, or other privacy regulations before using this audience category for targeting. True requires documented consent; false indicates legitimate interest or non-regulated data.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpmLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Cpm Last Updated Date' ;
    rdfs:comment 'Date when the average CPM value was last refreshed from campaign performance data and market intelligence. Indicates pricing data freshness.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'Primary data classification type for this audience category. Indicates the source and nature of the audience signal used for segmentation and targeting.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecationReason rdf:type rdf:Property ;
    rdfs:label 'Deprecation Reason' ;
    rdfs:comment 'Explanation for why this taxonomy category was deprecated or retired. Includes migration guidance to replacement categories. Null for active categories.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmpIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Dmp Integration Enabled' ;
    rdfs:comment 'Indicates whether this taxonomy category is integrated with the agency Data Management Platform for audience activation and cross-platform targeting. True enables automated segment sync to DSPs and SSPs.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dspActivationEnabled rdf:type rdf:Property ;
    rdfs:label 'Dsp Activation Enabled' ;
    rdfs:comment 'Indicates whether this taxonomy category is available for programmatic activation via Demand-Side Platforms such as The Trade Desk. True enables real-time bidding and automated audience targeting in programmatic campaigns.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionCategories rdf:type rdf:Property ;
    rdfs:label 'Exclusion Categories' ;
    rdfs:comment 'Comma-separated list of taxonomy codes that should be excluded when this category is used, to prevent audience overlap or conflicting targeting logic. Enforces mutually exclusive segment rules.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabStandardCode rdf:type rdf:Property ;
    rdfs:label 'Iab Standard Code' ;
    rdfs:comment 'Official IAB Audience Taxonomy standard code for this category. Null for custom agency extensions not covered by IAB standard. Enables industry-standard audience classification and cross-publisher comparison.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date when this taxonomy category was last reviewed for accuracy, relevance, and compliance. Supports taxonomy governance and quality assurance processes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumSegmentSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Segment Size' ;
    rdfs:comment 'Minimum number of unique users or devices required for this audience category to be activated in campaigns. Enforces privacy thresholds and prevents re-identification risk. Typically set to 1000+ for GDPR compliance and platform minimums.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nielsenCompatible rdf:type rdf:Property ;
    rdfs:label 'Nielsen Compatible' ;
    rdfs:comment 'Indicates whether this taxonomy category can be mapped to Nielsen audience measurement segments for GRP and TRP calculation. True enables cross-platform reach and frequency planning using Nielsen Ad Intel data.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Full hierarchical path from root to this node, using forward-slash delimiter (e.g., Demographics/Age/18-24). Enables breadcrumb navigation and full-path filtering in reporting tools.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyClassification rdf:type rdf:Property ;
    rdfs:label 'Privacy Classification' ;
    rdfs:comment 'Privacy sensitivity level of the audience data in this category. Non-PII contains no personal identifiers, pseudonymous uses hashed or tokenized IDs, PII-based includes direct identifiers, sensitive includes special category data under GDPR Article 9.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Reach Last Updated Date' ;
    rdfs:comment 'Date when the estimated reach value was last refreshed from source systems. Indicates data freshness for media planning decisions.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxonomyCode rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this taxonomy node. Used for system integration and cross-platform mapping. Follows agency naming convention.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyLevel rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Level' ;
    rdfs:comment 'Hierarchical tier level of this taxonomy node. Tier 1 represents top-level categories, tier 2 represents sub-categories, tier 3 represents granular segments. Supports drill-down analysis and hierarchical reporting.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageGuidelines rdf:type rdf:Property ;
    rdfs:label 'Usage Guidelines' ;
    rdfs:comment 'Best practice guidance and restrictions for using this audience category in campaigns. Includes recommended use cases, exclusion scenarios, and compliance considerations. Supports media planners and account teams in appropriate segment application.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:behavioralProfileId rdf:type rdf:Property ;
    rdfs:label 'Behavioral Profile Id' ;
    rdfs:comment 'Unique identifier for the behavioral audience profile record. Primary key.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BehavioralProfile .

ind:primaryBehavioralAudienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Behavioral Audience Segment Id' ;
    rdfs:comment 'Reference to the parent audience segment this behavioral profile belongs to.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:primaryTaxonomyId rdf:type rdf:Property ;
    rdfs:label 'Primary Taxonomy Id' ;
    rdfs:comment 'Foreign key linking to audience.audience_taxonomy. Business justification: behavioral_profile has browsing_category_primary and browsing_category_secondary (strings). audience_taxonomy provides standardized audience classification. Adding primary_taxonomy_id (FK to audience_' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Taxonomy .

ind:tertiaryBehavioralLookalikeSeedSegmentAudienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Behavioral Lookalike Seed Segment Audience Segment Id' ;
    rdfs:comment 'Reference to the seed audience segment used to generate this lookalike behavioral profile, if applicable.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:thirdPartyFeedId rdf:type rdf:Property ;
    rdfs:label 'Third Party Feed Id' ;
    rdfs:comment 'Foreign key linking to audience.third_party_feed. Business justification: behavioral_profile has dmp_source_platform (string). For third-party behavioral data, tracking which third_party_feed sourced the profile is critical for data lineage. Adding third_party_feed_id enabl' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyFeed .

ind:appUsagePattern rdf:type rdf:Property ;
    rdfs:label 'App Usage Pattern' ;
    rdfs:comment 'Description of observed mobile app usage patterns (e.g., \'Gaming Apps\', \'Shopping Apps\', \'News Apps\', \'Social Media Apps\').' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandAffinityCategory rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity Category' ;
    rdfs:comment 'Category of brands or products the user has shown affinity toward based on observed behavior (e.g., \'Luxury Brands\', \'Eco-Friendly Products\', \'Tech Gadgets\').' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browsingCategoryPrimary rdf:type rdf:Property ;
    rdfs:label 'Browsing Category Primary' ;
    rdfs:comment 'The primary content category observed in the user\'s browsing behavior (e.g., \'Automotive\', \'Travel\', \'Finance\', \'Health & Wellness\').' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browsingCategorySecondary rdf:type rdf:Property ;
    rdfs:label 'Browsing Category Secondary' ;
    rdfs:comment 'The secondary content category observed in the user\'s browsing behavior, indicating additional interests.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentConsumptionCategory rdf:type rdf:Property ;
    rdfs:label 'Content Consumption Category' ;
    rdfs:comment 'Category of content consumed by the user (e.g., \'Video\', \'Articles\', \'Podcasts\', \'Social Media\').' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDeviceActivityFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Device Activity Flag' ;
    rdfs:comment 'Indicates whether the behavioral profile includes cross-device activity tracking and identity resolution.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date when this behavioral profile data must be purged or anonymized per privacy regulations and data retention policies.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Data Source Description' ;
    rdfs:comment 'Detailed description of the data sources contributing to this behavioral profile (e.g., \'Website pixel data, mobile app SDK, CRM integration\').' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfWeekPreference rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Preference' ;
    rdfs:comment 'Observed preference for day of week when the user is most active online.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceTypePrimary rdf:type rdf:Property ;
    rdfs:label 'Device Type Primary' ;
    rdfs:comment 'The primary device type observed in the user\'s digital behavior.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementLevel rdf:type rdf:Property ;
    rdfs:label 'Engagement Level' ;
    rdfs:comment 'Overall engagement level classification based on interaction frequency, depth, and duration.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyScore rdf:type rdf:Property ;
    rdfs:label 'Frequency Score' ;
    rdfs:comment 'Frequency component of RFM scoring model, indicating how often the user exhibits the behavior (scale 1-5, 5 being most frequent).' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicBehaviorPattern rdf:type rdf:Property ;
    rdfs:label 'Geographic Behavior Pattern' ;
    rdfs:comment 'Description of observed geographic or location-based behavior patterns (e.g., \'Urban Commuter\', \'Frequent Traveler\', \'Suburban Resident\').' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastObservedBehaviorDate rdf:type rdf:Property ;
    rdfs:label 'Last Observed Behavior Date' ;
    rdfs:comment 'Date when the most recent behavioral signal was observed for this profile.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lookalikeSimilarityScore rdf:type rdf:Property ;
    rdfs:label 'Lookalike Similarity Score' ;
    rdfs:comment 'Similarity score (0.00 to 100.00) indicating how closely this profile matches the seed segment for lookalike modeling.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monetaryScore rdf:type rdf:Property ;
    rdfs:label 'Monetary Score' ;
    rdfs:comment 'Monetary component of RFM scoring model, indicating the value associated with the user\'s behavior (scale 1-5, 5 being highest value).' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privacyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Privacy Jurisdiction' ;
    rdfs:comment 'Primary privacy jurisdiction applicable to this behavioral profile (e.g., \'EU\', \'California\', \'Global\').' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCreationDate rdf:type rdf:Property ;
    rdfs:label 'Profile Creation Date' ;
    rdfs:comment 'Date when this behavioral profile was first created in the system.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this behavioral profile was last updated with new behavioral signals or attributes.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name or label for this behavioral profile (e.g., \'High-Intent Auto Shoppers\', \'Frequent Travelers\').' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileQualityScore rdf:type rdf:Property ;
    rdfs:label 'Profile Quality Score' ;
    rdfs:comment 'Quality score (0.00 to 100.00) indicating the accuracy, completeness, and reliability of the behavioral profile data.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileReachEstimate rdf:type rdf:Property ;
    rdfs:label 'Profile Reach Estimate' ;
    rdfs:comment 'Estimated number of unique users or devices matching this behavioral profile, used for campaign planning and media buying.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the behavioral profile indicating availability for targeting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the behavioral profile based on data source and construction method.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseIntentSignal rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent Signal' ;
    rdfs:comment 'Derived signal indicating the likelihood of purchase behavior based on observed actions (e.g., cart additions, product page views, price comparisons).' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyScore rdf:type rdf:Property ;
    rdfs:label 'Recency Score' ;
    rdfs:comment 'Recency component of RFM (Recency, Frequency, Monetary) scoring model, indicating how recently the user exhibited the behavior (scale 1-5, 5 being most recent).' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchIntentKeywords rdf:type rdf:Property ;
    rdfs:label 'Search Intent Keywords' ;
    rdfs:comment 'Comma-separated list of observed search keywords or phrases indicating user intent and interests.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalBehaviorPattern rdf:type rdf:Property ;
    rdfs:label 'Seasonal Behavior Pattern' ;
    rdfs:comment 'Description of observed seasonal or cyclical behavior patterns (e.g., \'Holiday Shopper\', \'Back-to-School\', \'Summer Traveler\').' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Targeting Eligibility Flag' ;
    rdfs:comment 'Indicates whether this behavioral profile is currently eligible for use in campaign targeting based on quality, consent, and compliance checks.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeOfDayPreference rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Preference' ;
    rdfs:comment 'Observed preference for time of day when the user is most active online.' ;
    rdfs:domain ind:BehavioralProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanRoomId rdf:type rdf:Property ;
    rdfs:label 'Clean Room Id' ;
    rdfs:comment 'Unique identifier for the clean room collaboration instance.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Worker Id' ;
    rdfs:comment 'Identifier of the user or system account that performed the most recent modification to this clean room collaboration record.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:measuredCreativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Measured Creative Asset Id' ;
    rdfs:comment 'Foreign key linking to creative.creative_asset. Business justification: Clean rooms match audiences with creative exposure data; privacy-safe measurement collaborations require asset-level attribution to analyze which creative drove outcomes for matched audiences, essenti' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:setupInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Setup Initiative Id' ;
    rdfs:comment 'Foreign key linking to project.initiative. Business justification: Clean room collaborations are complex multi-party projects requiring legal review, technical integration, and data governance setup. Agencies track which initiative governs clean room establishment fo' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:sourceMediaPlanId rdf:type rdf:Property ;
    rdfs:label 'Source Media Plan Id' ;
    rdfs:comment 'Foreign key linking to media.media_plan. Business justification: Clean room collaborations inform media planning with privacy-safe matched audience insights. Planners use clean room outputs to refine targeting strategies and validate audience reach assumptions for ' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:activationPermissions rdf:type rdf:Property ;
    rdfs:label 'Activation Permissions' ;
    rdfs:comment 'Defined permissions and restrictions governing how the matched audience output can be used, activated, or exported by participating parties.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'API endpoint URL used to programmatically access, query, or manage this clean room collaboration and its data outputs.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Security authentication mechanism used to verify identity and authorize access to the clean room platform and collaboration data.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant Flag' ;
    rdfs:comment 'Indicates whether this clean room collaboration meets CCPA requirements for consumer privacy rights, opt-out mechanisms, and data sale restrictions.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collaborationCode rdf:type rdf:Property ;
    rdfs:label 'Collaboration Code' ;
    rdfs:comment 'External reference code or identifier used to track this clean room collaboration across systems and with external partners.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Collaboration Cost Amount' ;
    rdfs:comment 'Total cost or fee associated with this clean room collaboration, expressed in the specified currency.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collaborationEndDate rdf:type rdf:Property ;
    rdfs:label 'Collaboration End Date' ;
    rdfs:comment 'Date when the clean room collaboration is scheduled to end or was terminated, after which data access and activation permissions expire.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collaborationName rdf:type rdf:Property ;
    rdfs:label 'Collaboration Name' ;
    rdfs:comment 'Business-friendly name assigned to this clean room collaboration for identification and reporting purposes.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationStartDate rdf:type rdf:Property ;
    rdfs:label 'Collaboration Start Date' ;
    rdfs:comment 'Date when the clean room collaboration became active and data matching or analysis began.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collaborationStatus rdf:type rdf:Property ;
    rdfs:label 'Collaboration Status' ;
    rdfs:comment 'Current lifecycle state of the clean room collaboration indicating operational readiness and availability.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationType rdf:type rdf:Property ;
    rdfs:label 'Collaboration Type' ;
    rdfs:comment 'Primary business purpose or use case for this clean room collaboration (e.g., audience enrichment, campaign measurement, attribution analysis). [ENUM-REF-CANDIDATE: audience enrichment|campaign measurement|attribution analysis|lookalike modeling|reach and frequency|overlap analysis|conversion lift|brand lift — promote to reference product]' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFrameworkCompliance rdf:type rdf:Property ;
    rdfs:label 'Consent Framework Compliance' ;
    rdfs:comment 'Privacy and consent framework(s) that this clean room collaboration adheres to, ensuring lawful data processing and user consent requirements are met.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costModel rdf:type rdf:Property ;
    rdfs:label 'Cost Model' ;
    rdfs:comment 'Pricing structure applied to this clean room collaboration, defining how costs are calculated and billed to participating parties. [ENUM-REF-CANDIDATE: CPM|flat fee|per query|per match|subscription|revenue share|tiered pricing — promote to reference product]' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataGovernanceRules rdf:type rdf:Property ;
    rdfs:label 'Data Governance Rules' ;
    rdfs:comment 'Structured description or reference to the data usage policies, access controls, and governance framework applied within this clean room to ensure privacy compliance and data protection.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'Number of days that matched audience data and collaboration outputs are retained within the clean room environment before automatic deletion or archival.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataVolumeMb rdf:type rdf:Property ;
    rdfs:label 'Data Volume Mb' ;
    rdfs:comment 'Total volume of data processed or stored within this clean room collaboration, measured in megabytes, for capacity planning and cost allocation.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:encryptionStandard rdf:type rdf:Property ;
    rdfs:label 'Encryption Standard' ;
    rdfs:comment 'Cryptographic encryption standard applied to protect data at rest and in transit within the clean room environment.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether this clean room collaboration meets GDPR requirements for lawful data processing, user consent, and data subject rights.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastQueryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Query Timestamp' ;
    rdfs:comment 'Timestamp of the most recent query or data analysis operation performed within this clean room collaboration.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchMethodology rdf:type rdf:Property ;
    rdfs:label 'Match Methodology' ;
    rdfs:comment 'Technical approach used to match and link audience identifiers across participating parties within the clean room environment. [ENUM-REF-CANDIDATE: hashed email|hashed phone|cookie sync|mobile ad ID|household ID|probabilistic|deterministic|CRM ID|universal ID — promote to reference product]' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedAudienceCount rdf:type rdf:Property ;
    rdfs:label 'Matched Audience Count' ;
    rdfs:comment 'Total number of unique audience members or identifiers successfully matched across all participating parties in the clean room.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Business team, department, or organizational unit responsible for managing and overseeing this clean room collaboration.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participatingParties rdf:type rdf:Property ;
    rdfs:label 'Participating Parties' ;
    rdfs:comment 'Comma-separated list or structured representation of all organizations, advertisers, publishers, or data partners participating in this clean room collaboration.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerPlatform rdf:type rdf:Property ;
    rdfs:label 'Provider Platform' ;
    rdfs:comment 'Technology platform or vendor providing the privacy-safe clean room environment for data collaboration. [ENUM-REF-CANDIDATE: InfoSum|Habu|LiveRamp|AWS Clean Rooms|Google Ads Data Hub|Snowflake Data Clean Room|Meta Advanced Analytics|The Trade Desk Data Alliance — promote to reference product]' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryCount rdf:type rdf:Property ;
    rdfs:label 'Query Count' ;
    rdfs:comment 'Total number of queries or analysis requests executed within this clean room collaboration, used for usage tracking and billing purposes.' ;
    rdfs:domain ind:CleanRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demographicProfileId rdf:type rdf:Property ;
    rdfs:label 'Demographic Profile Id' ;
    rdfs:comment 'Unique identifier for the demographic profile record. Primary key for the demographic profile entity.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemographicProfile .

ind:primaryDemographicAudienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Demographic Audience Segment Id' ;
    rdfs:comment 'External segment identifier from the Data Management Platform (DMP) system. Used for DMP integration and cross-platform targeting.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:ageBand rdf:type rdf:Property ;
    rdfs:label 'Age Band' ;
    rdfs:comment 'Age range classification for the demographic profile. Standard age cohorts used for audience segmentation and targeting.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childrenAgeRange rdf:type rdf:Property ;
    rdfs:label 'Children Age Range' ;
    rdfs:comment 'Age range of children in household (e.g., \'0-5\', \'6-12\', \'13-17\'). Used for family and parenting-focused targeting. Null if parental_status is non_parent.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date when consent was obtained for use of this demographic data. Required for GDPR and CCPA audit trails.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiration Date' ;
    rdfs:comment 'Date when consent expires and data can no longer be used for targeting. Null if consent does not expire.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code (e.g., \'USA\', \'CAN\', \'GBR\'). Used for international campaign targeting and compliance.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area code representing the geographic television market. Critical for broadcast and OOH media planning.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaName rdf:type rdf:Property ;
    rdfs:label 'Dma Name' ;
    rdfs:comment 'Human-readable name of the Nielsen DMA (e.g., \'New York\', \'Los Angeles\', \'Chicago\'). Used for media planning and reporting.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationLevel rdf:type rdf:Property ;
    rdfs:label 'Education Level' ;
    rdfs:comment 'Highest level of education attained. Used for audience segmentation and targeting strategies.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentCategory rdf:type rdf:Property ;
    rdfs:label 'Employment Category' ;
    rdfs:comment 'Employment status classification. Used for socioeconomic and lifestyle-based audience segmentation. [ENUM-REF-CANDIDATE: employed_full_time|employed_part_time|self_employed|unemployed|retired|student|undisclosed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Population Size' ;
    rdfs:comment 'Estimated number of individuals matching this demographic profile. Used for reach estimation and media planning.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ethnicity rdf:type rdf:Property ;
    rdfs:label 'Ethnicity' ;
    rdfs:comment 'Ethnic or cultural background classification where legally permissible and consented. Used for culturally relevant targeting. Subject to GDPR, CCPA, and local privacy regulations.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Gender classification for the demographic profile. Used for audience targeting and campaign personalization.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Broad geographic region classification within the country. Used for regional media planning and geo-targeting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Homeownership Status' ;
    rdfs:comment 'Indicates whether the individual owns or rents their residence. Used for real estate, home services, and financial product targeting.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdIncomeTier rdf:type rdf:Property ;
    rdfs:label 'Household Income Tier' ;
    rdfs:comment 'Household income bracket classification. Used for socioeconomic targeting and media planning. Sourced from Nielsen, Comscore, and first-party CRM data.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Number of individuals in the household. Used for household composition analysis and targeting.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the demographic profile data was last verified or updated. Used for data freshness assessment.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maritalStatus rdf:type rdf:Property ;
    rdfs:label 'Marital Status' ;
    rdfs:comment 'Marital status classification for the demographic profile. Used for household-based targeting and lifestyle segmentation.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupationCategory rdf:type rdf:Property ;
    rdfs:label 'Occupation Category' ;
    rdfs:comment 'Broad occupational category (e.g., \'Professional\', \'Management\', \'Service\', \'Sales\', \'Technical\'). Used for B2B and professional targeting.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalStatus rdf:type rdf:Property ;
    rdfs:label 'Parental Status' ;
    rdfs:comment 'Indicates whether the individual is a parent. Used for family-oriented campaign targeting.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal code (ZIP code in U.S.) for geographic targeting and localization. Used for hyper-local campaign targeting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'Primary language spoken by the demographic segment (e.g., \'English\', \'Spanish\', \'Mandarin\'). Used for creative localization and media channel selection.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Standardized code or identifier used across systems to reference this demographic profile (e.g., \'DEM-001\', \'PROF-URBAN-25-34\').' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Profile Confidence Score' ;
    rdfs:comment 'Confidence score (0-100) indicating the accuracy and completeness of the demographic profile data. Used for data quality assessment and targeting precision.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileDescription rdf:type rdf:Property ;
    rdfs:label 'Profile Description' ;
    rdfs:comment 'Detailed textual description of the demographic profile, including key characteristics and targeting use cases.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psychographicSegment rdf:type rdf:Property ;
    rdfs:label 'Psychographic Segment' ;
    rdfs:comment 'Psychographic or lifestyle segment classification (e.g., \'Early Adopters\', \'Value Seekers\', \'Luxury Enthusiasts\'). Used for behavioral and attitudinal targeting.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urbanicity rdf:type rdf:Property ;
    rdfs:label 'Urbanicity' ;
    rdfs:comment 'Classification of residential area type. Used for lifestyle-based targeting and media channel selection.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleOwnership rdf:type rdf:Property ;
    rdfs:label 'Vehicle Ownership' ;
    rdfs:comment 'Indicates whether the individual owns a vehicle. Used for automotive, insurance, and transportation-related targeting.' ;
    rdfs:domain ind:DemographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationOwnerWorkerId rdf:type rdf:Property ;
    rdfs:label 'Integration Owner Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: DMP platform integrations require dedicated technical ownership for API maintenance, authentication management, sync monitoring, and vendor escalation. Critical for operational continuity and incident' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:apiVersion rdf:type rdf:Property ;
    rdfs:label 'Api Version' ;
    rdfs:comment 'Version number of the API specification being used for integration (e.g., v2.0, v3.1).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStringFormat rdf:type rdf:Property ;
    rdfs:label 'Consent String Format' ;
    rdfs:comment 'Standard format used for encoding user consent signals: IAB Transparency & Consent Framework v2 (IAB-TCF-v2), IAB US Privacy String (IAB-USP), or Custom proprietary format.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerSyncUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Sync Usd' ;
    rdfs:comment 'Cost incurred per data synchronization operation, measured in US dollars, based on the platform\'s pricing model (per-call, per-record, or per-volume).' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:credentialExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Credential Expiry Date' ;
    rdfs:comment 'Date when the authentication credentials (API keys, tokens, certificates) expire and require renewal.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dmpIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Dmp Integration Status' ;
    rdfs:comment 'Current operational state of the integration: active (running), inactive (disabled), paused (temporarily suspended), error (failed), or pending (awaiting activation).' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorLogPath rdf:type rdf:Property ;
    rdfs:label 'Error Log Path' ;
    rdfs:comment 'File system path or cloud storage location where integration error logs and sync failure details are stored for troubleshooting and audit purposes.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationType rdf:type rdf:Property ;
    rdfs:label 'Integration Type' ;
    rdfs:comment 'Direction of data flow: inbound (data coming into the platform), outbound (data sent to external systems), or bidirectional (two-way sync).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProduction rdf:type rdf:Property ;
    rdfs:label 'Is Production' ;
    rdfs:comment 'Boolean flag indicating whether this integration is configured for the production environment (True) or a non-production environment such as development, staging, or testing (False).' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthlyCostCapUsd rdf:type rdf:Property ;
    rdfs:label 'Monthly Cost Cap Usd' ;
    rdfs:comment 'Maximum monthly expenditure limit for this integration in US dollars, used to prevent budget overruns and trigger alerts when approaching the cap.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Sync Timestamp' ;
    rdfs:comment 'Timestamp when the next scheduled data synchronization is planned to occur.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationEmail rdf:type rdf:Property ;
    rdfs:label 'Notification Email' ;
    rdfs:comment 'Email address of the technical contact or team to be notified of integration failures, sync errors, or credential expiry warnings.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Name of the DMP or CDP platform (e.g., Adobe Audience Manager, Salesforce DMP, Tealium AudienceStream, Segment.io, Oracle BlueKai, Lotame, LiveRamp).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'Classification of the platform: DMP (Data Management Platform), CDP (Customer Data Platform), DSP (Demand-Side Platform), SSP (Supply-Side Platform), or Hybrid.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLimitRequestsPerMinute rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Requests Per Minute' ;
    rdfs:comment 'Maximum number of API requests permitted per minute as defined by the platform\'s rate limiting policy to prevent service throttling.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsFailedCount rdf:type rdf:Property ;
    rdfs:label 'Records Failed Count' ;
    rdfs:comment 'Total number of audience records that failed to synchronize in the most recent sync operation due to errors or validation failures.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsSyncedCount rdf:type rdf:Property ;
    rdfs:label 'Records Synced Count' ;
    rdfs:comment 'Total number of audience records successfully synchronized in the most recent sync operation.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retryAttemptsMax rdf:type rdf:Property ;
    rdfs:label 'Retry Attempts Max' ;
    rdfs:comment 'Maximum number of automatic retry attempts for failed sync operations before escalating to manual intervention.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentMappingConfig rdf:type rdf:Property ;
    rdfs:label 'Segment Mapping Config' ;
    rdfs:comment 'JSON or XML configuration defining how audience segments are mapped between the internal taxonomy and the external platform\'s segment structure. Contains mapping rules, transformation logic, and segment ID translations.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncMethod rdf:type rdf:Property ;
    rdfs:label 'Sync Method' ;
    rdfs:comment 'Technical method used for data synchronization: pixel (tracking tag), API (Application Programming Interface), batch file transfer, webhook callback, SFTP (Secure File Transfer Protocol), or S3 bucket transfer.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'Outcome status of the most recent sync attempt: success (completed without errors), failed (encountered errors), partial (some records synced), or in-progress (currently running).' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeoutSeconds rdf:type rdf:Property ;
    rdfs:label 'Timeout Seconds' ;
    rdfs:comment 'Maximum number of seconds to wait for an API response before timing out and marking the sync attempt as failed.' ;
    rdfs:domain ind:DmpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdoutGroupId rdf:type rdf:Property ;
    rdfs:label 'Holdout Group Id' ;
    rdfs:comment 'Unique identifier for the holdout group. Primary key for the holdout group entity used in campaign measurement and incrementality testing.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HoldoutGroup .

ind:experimentIncrementalityTestId rdf:type rdf:Property ;
    rdfs:label 'Experiment Incrementality Test Id' ;
    rdfs:comment 'Reference to the parent experiment or test design that this holdout group belongs to. Links the group to the broader measurement framework.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IncrementalityTest .

ind:consentCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Compliant Flag' ;
    rdfs:comment 'Indicates whether all audience members in this holdout group have provided appropriate consent for inclusion in measurement activities under applicable privacy regulations.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dspPlatformName rdf:type rdf:Property ;
    rdfs:label 'Dsp Platform Name' ;
    rdfs:comment 'Name of the Demand-Side Platform where this holdout group is activated for campaign suppression or exposure control. Examples include The Trade Desk, Google DV360, Amazon DSP.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCode rdf:type rdf:Property ;
    rdfs:label 'Group Code' ;
    rdfs:comment 'Short alphanumeric code used for system integration and external reference. Enables consistent identification across platforms.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'Human-readable name for the holdout group. Provides clear identification for reporting and analysis purposes.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupSize rdf:type rdf:Property ;
    rdfs:label 'Group Size' ;
    rdfs:comment 'Total number of audience members or identifiers included in this holdout group. Represents the actual population count for statistical power calculations.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Classification of the group role in the experiment. Exposed groups receive campaign exposure, holdout/control groups do not, test groups receive variant treatments, baseline groups represent standard conditions.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdoutGroupDescription rdf:type rdf:Property ;
    rdfs:label 'Holdout Group Description' ;
    rdfs:comment 'Detailed narrative description of the holdout group purpose, composition criteria, and measurement objectives. Provides context for analysts and stakeholders.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumDetectableEffect rdf:type rdf:Property ;
    rdfs:label 'Minimum Detectable Effect' ;
    rdfs:comment 'Smallest effect size that the experiment is powered to detect with statistical significance. Expressed as a percentage lift, guiding sample size requirements.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Integration Status' ;
    rdfs:comment 'Status of holdout group synchronization with Demand-Side Platforms (DSP), Data Management Platforms (DMP), or measurement platforms. Synced indicates successful deployment, pending indicates in-progress, failed indicates integration errors.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationSeed rdf:type rdf:Property ;
    rdfs:label 'Randomization Seed' ;
    rdfs:comment 'Seed value used for random assignment algorithm. Ensures reproducibility of the split methodology and enables audit verification of group assignments.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitMethodology rdf:type rdf:Property ;
    rdfs:label 'Split Methodology' ;
    rdfs:comment 'Method used to divide the parent segment into test and control groups. Random ensures unbiased distribution, stratified maintains demographic balance, geographic uses location-based splits, behavioral uses engagement patterns, demographic uses audience attributes, matched pairs creates comparable groups.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitPercentage rdf:type rdf:Property ;
    rdfs:label 'Split Percentage' ;
    rdfs:comment 'Percentage of the parent segment allocated to this holdout group. Expressed as a decimal value between 0 and 100, enabling precise control group sizing for statistical validity.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stratificationVariables rdf:type rdf:Property ;
    rdfs:label 'Stratification Variables' ;
    rdfs:comment 'Comma-separated list of demographic or behavioral attributes used for stratified sampling. Ensures balanced representation across key audience dimensions.' ;
    rdfs:domain ind:HoldoutGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the holdout group was initially created and defined. Establishes the baseline for measurement period tracking.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identityGraphId rdf:type rdf:Property ;
    rdfs:label 'Identity Graph Id' ;
    rdfs:comment 'Unique identifier for the identity graph record linking multiple audience identifiers to a unified person-level entity.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:browser rdf:type rdf:Property ;
    rdfs:label 'Browser' ;
    rdfs:comment 'Web browser associated with the cookie ID (e.g., Chrome, Safari, Firefox, Edge). Used for browser-specific targeting and tracking compatibility.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookieIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cookie Identifier' ;
    rdfs:comment 'Browser cookie identifier used for web-based tracking and targeting. May be first-party or third-party cookie.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmIdentifier rdf:type rdf:Property ;
    rdfs:label 'Crm Identifier' ;
    rdfs:comment 'First-party CRM system identifier linking the identity graph to known customer records in Salesforce or other CRM platforms.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctvDeviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Ctv Device Identifier' ;
    rdfs:comment 'Device identifier for Connected TV and Over-the-Top (OTT) platforms used for CTV advertising targeting and measurement.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Type of device associated with this identity link. Used for cross-device frequency capping and device-specific targeting strategies. [ENUM-REF-CANDIDATE: desktop|mobile|tablet|ctv|smart_speaker|wearable|gaming_console|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Seen Timestamp' ;
    rdfs:comment 'Timestamp when this identifier was first observed in the advertising ecosystem. Used for recency/frequency analysis and new-user identification.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geographicCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Country Code' ;
    rdfs:comment 'Three-letter ISO country code derived from IP address or device location. Used for geographic targeting and compliance with regional privacy laws.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicDmaCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area code for US-based identities. Used for local media planning and TV/digital convergence strategies.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashedEmail rdf:type rdf:Property ;
    rdfs:label 'Hashed Email' ;
    rdfs:comment 'SHA-256 hashed email address used for privacy-safe identity matching and audience targeting across platforms.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdIdentifier rdf:type rdf:Property ;
    rdfs:label 'Household Identifier' ;
    rdfs:comment 'Identifier representing the household-level entity for household-based targeting and frequency management. Multiple unified person IDs may share the same household ID.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityGraphStatus rdf:type rdf:Property ;
    rdfs:label 'Identity Graph Status' ;
    rdfs:comment 'Current lifecycle status of the identity link. Active links are used for targeting; inactive/expired links are retained for historical analysis; suppressed links honor opt-out requests; revoked links have been invalidated.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityProviderVersion rdf:type rdf:Property ;
    rdfs:label 'Identity Provider Version' ;
    rdfs:comment 'Version or release identifier of the identity provider technology used for the match. Enables tracking of algorithm changes and match quality over time.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Seen Timestamp' ;
    rdfs:comment 'Timestamp when this identifier was most recently observed in ad serving or campaign activity. Used for recency targeting and inactive user suppression.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkCreationDate rdf:type rdf:Property ;
    rdfs:label 'Link Creation Date' ;
    rdfs:comment 'Date when the identity link was first established in the graph. Used for recency analysis and link decay modeling.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Link Expiration Date' ;
    rdfs:comment 'Date when the identity link is scheduled to expire if not reverified. Used for data retention policies and GDPR/CCPA compliance.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkLastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Link Last Verified Date' ;
    rdfs:comment 'Date when the identity link was most recently verified or refreshed through observed user activity or deterministic match.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Match Confidence Score' ;
    rdfs:comment 'Confidence score (0.0000 to 1.0000) indicating the reliability of the identity link. Higher scores indicate stronger match confidence. Used for quality filtering in targeting and attribution.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchMethod rdf:type rdf:Property ;
    rdfs:label 'Match Method' ;
    rdfs:comment 'Method used to link identifiers to the unified person entity. Deterministic uses exact matches (e.g., logged-in user data), probabilistic uses statistical modeling, hybrid combines both approaches.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileAdvertisingIdentifier rdf:type rdf:Property ;
    rdfs:label 'Mobile Advertising Identifier' ;
    rdfs:comment 'Device-level mobile advertising identifier (IDFA for iOS, GAID for Android) used for mobile app targeting and attribution.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the device (e.g., iOS, Android, Windows, macOS, tvOS, Roku OS). Used for OS-level targeting and compatibility analysis.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Boolean flag indicating whether the user has opted out of cross-device tracking or targeted advertising. True means user has opted out.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Timestamp' ;
    rdfs:comment 'Timestamp when the user opted out of tracking or targeting. Used for compliance reporting and suppression list management.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:privacyFramework rdf:type rdf:Property ;
    rdfs:label 'Privacy Framework' ;
    rdfs:comment 'Applicable privacy regulation or framework governing this identity link (e.g., GDPR, CCPA, IAB TCF v2.0, NAI Code). Used for compliance segmentation and reporting.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLinkedIdentifiers rdf:type rdf:Property ;
    rdfs:label 'Total Linked Identifiers' ;
    rdfs:comment 'Count of distinct identifiers (cookies, MAIDs, emails, etc.) linked to this unified person entity. Higher counts indicate richer cross-device profiles.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unifiedPersonCode rdf:type rdf:Property ;
    rdfs:label 'Unified Person Code' ;
    rdfs:comment 'Master identifier representing the unified person-level entity across all linked identifiers. This is the canonical ID used for people-based targeting and cross-device attribution.' ;
    rdfs:domain ind:IdentityGraph ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lookalikeModelId rdf:type rdf:Property ;
    rdfs:label 'Lookalike Model Id' ;
    rdfs:comment 'Unique identifier for the lookalike audience model record. Primary key for the lookalike model entity.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:developmentInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Development Initiative Id' ;
    rdfs:comment 'Foreign key linking to project.initiative. Business justification: Lookalike model development is a distinct project deliverable with dedicated timelines, resources, and budgets. Agencies track which initiative funded model creation for cost recovery and to manage da' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:algorithmType rdf:type rdf:Property ;
    rdfs:label 'Algorithm Type' ;
    rdfs:comment 'Machine learning algorithm used to build the lookalike model. Determines the mathematical approach for identifying similar audience members. [ENUM-REF-CANDIDATE: cosine_similarity|gradient_boosting|neural_network|random_forest|logistic_regression|collaborative_filtering|k_nearest_neighbors|decision_tree|support_vector_machine — promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselinePerformanceValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Performance Value' ;
    rdfs:comment 'Benchmark performance metric value from the seed segment, used to compare lookalike audience performance against the original high-value segment.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expansionRatio rdf:type rdf:Property ;
    rdfs:label 'Expansion Ratio' ;
    rdfs:comment 'Multiplier indicating how many times larger the lookalike audience is compared to the seed segment (e.g., 10.00 means the lookalike is 10x the seed size). Used to balance reach vs. similarity.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when the lookalike model is scheduled to expire and become unavailable for targeting unless refreshed or extended.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:featureSet rdf:type rdf:Property ;
    rdfs:label 'Feature Set' ;
    rdfs:comment 'Comma-separated list of data attributes used as input features for model training (e.g., demographics, behavioral signals, purchase history, engagement metrics).' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Date' ;
    rdfs:comment 'Date when the lookalike model was most recently retrained or refreshed with updated seed segment data.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelCost rdf:type rdf:Property ;
    rdfs:label 'Model Cost' ;
    rdfs:comment 'Total cost incurred to build and deploy the lookalike model, including data acquisition, platform fees, and computational resources.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelDescription rdf:type rdf:Property ;
    rdfs:label 'Model Description' ;
    rdfs:comment 'Detailed business description of the lookalike model purpose, target use cases, and strategic rationale for campaign planners and media buyers.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Business-friendly name assigned to the lookalike model for identification and campaign planning purposes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelStatus rdf:type rdf:Property ;
    rdfs:label 'Model Status' ;
    rdfs:comment 'Current lifecycle state of the lookalike model. Active models are available for campaign targeting; expired models require retraining.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Date' ;
    rdfs:comment 'Scheduled date for the next model retraining cycle based on the refresh frequency policy.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceMetricType rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Type' ;
    rdfs:comment 'Primary Key Performance Indicator (KPI) used to evaluate the lookalike model effectiveness in campaigns. CTR = Click-Through Rate, CVR = Conversion Rate, ROAS = Return on Ad Spend, CPA = Cost Per Acquisition, LTV = Lifetime Value.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency Days' ;
    rdfs:comment 'Number of days between scheduled model retraining cycles to maintain accuracy and relevance as audience behaviors evolve.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:similarityThreshold rdf:type rdf:Property ;
    rdfs:label 'Similarity Threshold' ;
    rdfs:comment 'Minimum similarity score (0.0000 to 1.0000) required for a user to be included in the lookalike audience. Higher thresholds produce smaller, more similar audiences.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingDate rdf:type rdf:Property ;
    rdfs:label 'Training Date' ;
    rdfs:comment 'Date when the lookalike model was trained on the seed segment data. Critical for understanding model freshness and performance decay over time.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationAccuracy rdf:type rdf:Property ;
    rdfs:label 'Validation Accuracy' ;
    rdfs:comment 'Model accuracy score (0.0000 to 1.0000) measured on a holdout validation dataset, indicating how well the model predicts high-value user characteristics.' ;
    rdfs:domain ind:LookalikeModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personaId rdf:type rdf:Property ;
    rdfs:label 'Persona Id' ;
    rdfs:comment 'Unique identifier for the audience persona profile. Primary key.' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByWorkerId rdf:type rdf:Property ;
    rdfs:label 'Created By Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Personas are high-value strategic frameworks authored by specific strategists or planners. Tracking authorship supports expertise mapping, quality assurance, and intellectual property management. Repl' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:psychographicProfileId rdf:type rdf:Property ;
    rdfs:label 'Psychographic Profile Id' ;
    rdfs:comment 'Foreign key linking to audience.psychographic_profile. Business justification: Personas currently have psychographic_traits (string) and related psychographic attributes. psychographic_profile is a structured, reusable psychographic profile with detailed VALS and lifestyle data.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PsychographicProfile .

ind:ccpaOptOutEligible rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Eligible' ;
    rdfs:comment 'Indicates whether individuals matching this persona have CCPA opt-out rights for data sale.' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdpAudienceKey rdf:type rdf:Property ;
    rdfs:label 'Cdp Audience Key' ;
    rdfs:comment 'Reference key for this persona in the Customer Data Platform for cross-channel activation.' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvEstimate rdf:type rdf:Property ;
    rdfs:label 'Cltv Estimate' ;
    rdfs:comment 'Projected lifetime value in USD for customers matching this persona profile.' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentPreferences rdf:type rdf:Property ;
    rdfs:label 'Content Preferences' ;
    rdfs:comment 'Types of content and messaging styles that resonate with this persona (e.g., \'Educational\', \'Humorous\', \'Inspirational\').' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionPropensity rdf:type rdf:Property ;
    rdfs:label 'Conversion Propensity' ;
    rdfs:comment 'Likelihood score (0-100) that this persona will convert based on historical campaign performance.' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmpSegmentIds rdf:type rdf:Property ;
    rdfs:label 'Dmp Segment Ids' ;
    rdfs:comment 'Comma-separated list of DMP segment IDs that map to this persona for programmatic activation.' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'Legal basis under GDPR for processing personal data associated with this persona.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Date and time when this persona profile was most recently modified or refreshed.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:narrativeDescription rdf:type rdf:Property ;
    rdfs:label 'Narrative Description' ;
    rdfs:comment 'Rich narrative description of the persona, including lifestyle, values, and behavioral characteristics used by creative teams.' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:painPoints rdf:type rdf:Property ;
    rdfs:label 'Pain Points' ;
    rdfs:comment 'Key challenges, frustrations, or unmet needs that this persona experiences, used to inform messaging strategy.' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personaCode rdf:type rdf:Property ;
    rdfs:label 'Persona Code' ;
    rdfs:comment 'Short alphanumeric code used for quick reference in campaign planning and media buying systems.' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personaName rdf:type rdf:Property ;
    rdfs:label 'Persona Name' ;
    rdfs:comment 'The archetypal name or label assigned to this persona (e.g., \'Tech-Savvy Millennial\', \'Budget-Conscious Parent\').' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personaStatus rdf:type rdf:Property ;
    rdfs:label 'Persona Status' ;
    rdfs:comment 'Current lifecycle status of the persona profile.' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredChannels rdf:type rdf:Property ;
    rdfs:label 'Preferred Channels' ;
    rdfs:comment 'Comma-separated list of most effective marketing channels for reaching this persona (e.g., \'Social Media, CTV, Digital Display\').' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaPlatforms rdf:type rdf:Property ;
    rdfs:label 'Social Media Platforms' ;
    rdfs:comment 'Comma-separated list of social media platforms where this persona is most active (e.g., \'Facebook, Instagram, TikTok\').' ;
    rdfs:domain ind:Persona ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of campaigns or media plans that have actively targeted this persona.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pixelId rdf:type rdf:Property ;
    rdfs:label 'Pixel Id' ;
    rdfs:comment 'Unique identifier for the tracking pixel or tag. Primary key.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pixel .

ind:deploymentInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Deployment Initiative Id' ;
    rdfs:comment 'Foreign key linking to project.initiative. Business justification: Pixel deployment is a standard project deliverable requiring technical implementation, QA testing, and client approval. Agencies track which initiative governs pixel deployment for timeline management' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:implementationOwnerWorkerId rdf:type rdf:Property ;
    rdfs:label 'Implementation Owner Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Pixel implementations require technical ownership for deployment QA, troubleshooting, compliance verification, and tag management. Essential for incident response and data quality accountability. Repl' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:trackingPixelId rdf:type rdf:Property ;
    rdfs:label 'Tracking Pixel Id' ;
    rdfs:comment 'Foreign key linking to performance.tracking_pixel. Business justification: Audience pixels (data collection for segmentation) often share deployment infrastructure with performance tracking pixels (conversion tracking). Links pixel configuration to tracking implementation, e' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrackingPixel .

ind:activatedDate rdf:type rdf:Property ;
    rdfs:label 'Activated Date' ;
    rdfs:comment 'Date when this pixel was first activated and began firing events.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentCategory rdf:type rdf:Property ;
    rdfs:label 'Consent Category' ;
    rdfs:comment 'The consent category under which this pixel operates, determining the level of user consent required: strictly necessary, functional, analytics, advertising, or personalization.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCode rdf:type rdf:Property ;
    rdfs:label 'Container Code' ;
    rdfs:comment 'The unique identifier of the tag container in which this pixel is deployed, used for container-level tracking and governance.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTagManager rdf:type rdf:Property ;
    rdfs:label 'Container Tag Manager' ;
    rdfs:comment 'The tag management system used to deploy and manage this pixel (e.g., Google Tag Manager, Adobe Launch, Tealium, Ensighten).' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Conversion Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for conversion values tracked by this pixel (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDomainTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Domain Tracking Enabled' ;
    rdfs:comment 'Indicates whether this pixel supports cross-domain tracking to follow users across multiple domains or subdomains.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCollected rdf:type rdf:Property ;
    rdfs:label 'Data Collected' ;
    rdfs:comment 'Description of the data elements captured by the pixel, such as page views, events, conversions, user identifiers, device attributes, or geographic location.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivatedDate rdf:type rdf:Property ;
    rdfs:label 'Deactivated Date' ;
    rdfs:comment 'Date when this pixel was deactivated or archived, if applicable.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentDomain rdf:type rdf:Property ;
    rdfs:label 'Deployment Domain' ;
    rdfs:comment 'The root domain where the pixel is deployed, used for domain-level tracking and reporting.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentUrl rdf:type rdf:Property ;
    rdfs:label 'Deployment Url' ;
    rdfs:comment 'The URL or domain where the pixel is deployed or embedded, typically a client or agency-managed digital property.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSchemaDefinition rdf:type rdf:Property ;
    rdfs:label 'Event Schema Definition' ;
    rdfs:comment 'Technical specification or schema definition for the events captured by this pixel, including field names, data types, and required vs. optional attributes.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTypesCaptured rdf:type rdf:Property ;
    rdfs:label 'Event Types Captured' ;
    rdfs:comment 'Comma-separated list or description of the specific event types this pixel is configured to capture (e.g., page_view, add_to_cart, purchase, lead_submit, video_view).' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firingRule rdf:type rdf:Property ;
    rdfs:label 'Firing Rule' ;
    rdfs:comment 'Business logic or conditions that determine when the pixel fires (e.g., on page load, on button click, on form submission, on purchase completion).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPartyCookie rdf:type rdf:Property ;
    rdfs:label 'First Party Cookie' ;
    rdfs:comment 'Indicates whether this pixel sets first-party cookies (owned by the advertiser domain) rather than third-party cookies, important for privacy and browser compatibility.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthStatus rdf:type rdf:Property ;
    rdfs:label 'Health Status' ;
    rdfs:comment 'Current health status of the pixel based on monitoring and validation checks: healthy (firing as expected), warning (potential issues detected), error (not firing or misconfigured), or inactive (not deployed).' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiersCaptured rdf:type rdf:Property ;
    rdfs:label 'Identifiers Captured' ;
    rdfs:comment 'Description of the user or device identifiers captured by the pixel, such as cookie IDs, mobile advertising IDs (IDFA, AAID), hashed emails, or platform-specific user IDs.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Event Timestamp' ;
    rdfs:comment 'Timestamp of the most recent event captured by this pixel, used for health monitoring and activity tracking.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lookbackWindowDays rdf:type rdf:Property ;
    rdfs:label 'Lookback Window Days' ;
    rdfs:comment 'Number of days in the attribution lookback window for this pixel, determining how far back in time conversions can be attributed to ad interactions.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pixelCode rdf:type rdf:Property ;
    rdfs:label 'Pixel Code' ;
    rdfs:comment 'Unique external code or identifier for the pixel, often used in platform integrations and trafficking systems.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pixelName rdf:type rdf:Property ;
    rdfs:label 'Pixel Name' ;
    rdfs:comment 'Human-readable name or label for the tracking pixel, used for identification and reporting purposes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pixelStatus rdf:type rdf:Property ;
    rdfs:label 'Pixel Status' ;
    rdfs:comment 'Current operational status of the pixel in its lifecycle: active (live and firing), paused (temporarily disabled), archived (retired), testing (under validation), or pending approval.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pixelType rdf:type rdf:Property ;
    rdfs:label 'Pixel Type' ;
    rdfs:comment 'Classification of the pixel based on its primary business purpose: retargeting, conversion tracking, audience building, measurement, view-through tracking, or click-through tracking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'The advertising platform or technology provider that hosts or serves this pixel (e.g., Google Campaign Manager 360, The Trade Desk, Meta, TikTok, LinkedIn, Amazon DSP).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Url' ;
    rdfs:comment 'URL to the privacy policy that governs the data collection and usage for this pixel, required for transparency and compliance.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serverSideEnabled rdf:type rdf:Property ;
    rdfs:label 'Server Side Enabled' ;
    rdfs:comment 'Indicates whether this pixel uses server-side tracking (as opposed to client-side browser-based tracking) for improved data accuracy and privacy compliance.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalEventsCaptured rdf:type rdf:Property ;
    rdfs:label 'Total Events Captured' ;
    rdfs:comment 'Cumulative count of all events captured by this pixel since activation, used for volume tracking and performance monitoring.' ;
    rdfs:domain ind:Pixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pixelEventId rdf:type rdf:Property ;
    rdfs:label 'Pixel Event Id' ;
    rdfs:comment 'Unique identifier for the pixel firing event. Primary key for the pixel event transactional record.' ;
    rdfs:domain ind:PixelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adId rdf:type rdf:Property ;
    rdfs:label 'Ad Id' ;
    rdfs:comment 'Reference to the specific ad creative that led to this pixel firing event. Used for creative-level performance attribution.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ad .

ind:conversionEventId rdf:type rdf:Property ;
    rdfs:label 'Conversion Event Id' ;
    rdfs:comment 'Foreign key linking to performance.conversion_event. Business justification: Pixel events trigger conversions - direct attribution path for pixel-based conversion tracking. Essential for validating conversion attribution, debugging tracking discrepancies, and reconciling audie' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConversionEvent .

ind:browserVersion rdf:type rdf:Property ;
    rdfs:label 'Browser Version' ;
    rdfs:comment 'Version number of the browser application. Used for technical compatibility analysis and fraud detection.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOut rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out' ;
    rdfs:comment 'Flag indicating whether the user has exercised CCPA opt-out rights for sale of personal information. True if user has opted out.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Flag' ;
    rdfs:comment 'Boolean indicator of whether this pixel event represents a conversion action as defined by campaign KPI targets. True for conversion events.' ;
    rdfs:domain ind:PixelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'Channel or platform from which the pixel event originated. Distinguishes web-based tracking from mobile app or Connected TV (CTV) tracking.' ;
    rdfs:domain ind:PixelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time when the pixel firing event occurred in the user\'s browser or device. Represents the real-world moment of user interaction.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Type of user interaction or behavior captured by the pixel firing event. Discriminates the business action that triggered the pixel.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventValue rdf:type rdf:Property ;
    rdfs:label 'Event Value' ;
    rdfs:comment 'Monetary value associated with the pixel event, if applicable. For purchase events, represents transaction amount. For other events, may represent estimated conversion value.' ;
    rdfs:domain ind:PixelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprApplies rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applies' ;
    rdfs:comment 'Flag indicating whether GDPR regulations apply to this pixel event based on user location and consent framework signals.' ;
    rdfs:domain ind:PixelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCity rdf:type rdf:Property ;
    rdfs:label 'Geographic City' ;
    rdfs:comment 'City where the pixel event originated, inferred from IP address geolocation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCountry rdf:type rdf:Property ;
    rdfs:label 'Geographic Country' ;
    rdfs:comment 'Country where the pixel event originated, inferred from IP address geolocation. Three-letter ISO country code.' ;
    rdfs:domain ind:PixelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the pixel event location, inferred from IP geolocation or device GPS when available.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the pixel event location, inferred from IP geolocation or device GPS when available.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Operating System Version' ;
    rdfs:comment 'Version number of the operating system. Used for device profiling and technical segmentation.' ;
    rdfs:domain ind:PixelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageUrl rdf:type rdf:Property ;
    rdfs:label 'Page Url' ;
    rdfs:comment 'Canonical URL of the page where the event was captured. May differ from referring_url in redirect scenarios.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringUrl rdf:type rdf:Property ;
    rdfs:label 'Referring Url' ;
    rdfs:comment 'Full URL of the web page where the pixel firing event occurred. Captures the context and content environment of the user interaction.' ;
    rdfs:domain ind:PixelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionIdentifier rdf:type rdf:Property ;
    rdfs:label 'Session Identifier' ;
    rdfs:comment 'Identifier for the user browsing session during which the pixel event occurred. Used to group events into session-based behavioral sequences.' ;
    rdfs:domain ind:PixelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userIdentifier rdf:type rdf:Property ;
    rdfs:label 'User Identifier' ;
    rdfs:comment 'Captured identifier for the user who triggered the event. May be a cookie ID, Mobile Advertising ID (MAID), hashed email, or other first-party identifier depending on tracking method and consent.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandAffinityTier rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity Tier' ;
    rdfs:comment 'Consumer preference tier for brand positioning and pricing sensitivity.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandLoyaltyScore rdf:type rdf:Property ;
    rdfs:label 'Brand Loyalty Score' ;
    rdfs:comment 'Score (0-100) indicating tendency toward brand loyalty versus brand switching behavior.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:culturalOrientation rdf:type rdf:Property ;
    rdfs:label 'Cultural Orientation' ;
    rdfs:comment 'Cultural identity and orientation influencing media preferences and brand affinity.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalEngagementLevel rdf:type rdf:Property ;
    rdfs:label 'Digital Engagement Level' ;
    rdfs:comment 'Level of engagement with digital media and online platforms.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConsciousnessScore rdf:type rdf:Property ;
    rdfs:label 'Environmental Consciousness Score' ;
    rdfs:comment 'Score (0-100) indicating level of environmental and sustainability concern in purchase decisions.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innovationAdoptionIndex rdf:type rdf:Property ;
    rdfs:label 'Innovation Adoption Index' ;
    rdfs:comment 'Index score (0-100) measuring propensity to adopt new products and technologies.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifestyleCategory rdf:type rdf:Property ;
    rdfs:label 'Lifestyle Category' ;
    rdfs:comment 'Broad lifestyle classification (e.g., \'Urban Professional\', \'Suburban Family\', \'Rural Traditional\', \'Digital Nomad\'). [ENUM-REF-CANDIDATE: urban_professional|suburban_family|rural_traditional|digital_nomad|active_retiree|student|young_single|empty_nester — promote to reference product]' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaConsumptionAttitude rdf:type rdf:Property ;
    rdfs:label 'Media Consumption Attitude' ;
    rdfs:comment 'Attitude toward new media channels and advertising formats.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opinionLeaderIndicator rdf:type rdf:Property ;
    rdfs:label 'Opinion Leader Indicator' ;
    rdfs:comment 'Flag indicating whether this profile represents opinion leaders or influencers within their social networks.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalityArchetype rdf:type rdf:Property ;
    rdfs:label 'Personality Archetype' ;
    rdfs:comment 'Primary personality archetype based on Jungian or brand personality frameworks (e.g., \'Explorer\', \'Caregiver\', \'Hero\', \'Rebel\'). [ENUM-REF-CANDIDATE: explorer|caregiver|hero|rebel|creator|sage|innocent|ruler|magician|lover|jester|everyman — promote to reference product]' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSensitivityIndex rdf:type rdf:Property ;
    rdfs:label 'Price Sensitivity Index' ;
    rdfs:comment 'Index score (0-100) measuring responsiveness to price changes and promotional offers.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryInterestCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Interest Category' ;
    rdfs:comment 'Top-level interest category based on IAB Content Taxonomy (e.g., \'Automotive\', \'Travel\', \'Technology\', \'Health & Fitness\'). [ENUM-REF-CANDIDATE: automotive|travel|technology|health_fitness|food_dining|home_garden|sports|entertainment — promote to reference product]' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseMotivationPrimary rdf:type rdf:Property ;
    rdfs:label 'Purchase Motivation Primary' ;
    rdfs:comment 'Primary driver behind purchase decisions for this psychographic segment. [ENUM-REF-CANDIDATE: quality|price|convenience|status|innovation|sustainability|tradition — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseMotivationSecondary rdf:type rdf:Property ;
    rdfs:label 'Purchase Motivation Secondary' ;
    rdfs:comment 'Secondary driver influencing purchase behavior. [ENUM-REF-CANDIDATE: quality|price|convenience|status|innovation|sustainability|tradition — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskToleranceLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Level' ;
    rdfs:comment 'Consumer risk tolerance in purchase decisions and product trials.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryInterestCategory rdf:type rdf:Property ;
    rdfs:label 'Secondary Interest Category' ;
    rdfs:comment 'Secondary interest category providing additional targeting depth.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaActivityScore rdf:type rdf:Property ;
    rdfs:label 'Social Media Activity Score' ;
    rdfs:comment 'Normalized score (0-100) representing social media engagement and influence level derived from social listening data.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Restriction Notes' ;
    rdfs:comment 'Free-text notes describing any contractual or regulatory restrictions on the use of this psychographic profile in campaigns.' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valsFrameworkSegment rdf:type rdf:Property ;
    rdfs:label 'Vals Framework Segment' ;
    rdfs:comment 'Primary VALS psychographic segment classification based on consumer motivations and resources. [ENUM-REF-CANDIDATE: innovators|thinkers|achievers|experiencers|believers|strivers|makers|survivors — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuesOrientation rdf:type rdf:Property ;
    rdfs:label 'Values Orientation' ;
    rdfs:comment 'Core values orientation (e.g., \'Achievement\', \'Security\', \'Benevolence\', \'Hedonism\', \'Tradition\', \'Self-Direction\'). [ENUM-REF-CANDIDATE: achievement|security|benevolence|hedonism|tradition|self_direction|universalism|power|stimulation|conformity — promote to reference product]' ;
    rdfs:domain ind:PsychographicProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterAgreementId rdf:type rdf:Property ;
    rdfs:label 'Master Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Audience segments often governed by master agreements defining data usage rights, licensing terms, geographic restrictions, and activation permissions. Critical for compliance tracking, data rights ma' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:ageBandMax rdf:type rdf:Property ;
    rdfs:label 'Age Band Max' ;
    rdfs:comment 'Upper bound of the age range for demographic qualification (e.g., 24 for 18-24 age band). Nullable if age is not a qualification criterion.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageBandMin rdf:type rdf:Property ;
    rdfs:label 'Age Band Min' ;
    rdfs:comment 'Lower bound of the age range for demographic qualification (e.g., 18 for 18-24 age band). Nullable if age is not a qualification criterion.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appUsageFlag rdf:type rdf:Property ;
    rdfs:label 'App Usage Flag' ;
    rdfs:comment 'Indicates whether segment qualification includes mobile app usage or in-app behavior signals.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audienceSegmentDescription rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Description' ;
    rdfs:comment 'Detailed business description of the segment purpose, target audience characteristics, and intended use cases for campaign targeting.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentName rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Name' ;
    rdfs:comment 'Human-readable name of the audience segment used for identification and campaign targeting.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentStatus rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment: active (available for targeting), inactive (paused), draft (under development), archived (historical reference), or expired (past validity period).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentType rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Type' ;
    rdfs:comment 'Classification of the segment based on the primary targeting methodology: behavioral (actions/browsing), demographic (age/gender/income), psychographic (attitudes/values), contextual (content affinity), lookalike (modeled similarity), or geographic (location-based).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandAffinityList rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity List' ;
    rdfs:comment 'Comma-separated list of brands that segment members have shown affinity toward through engagement, purchase, or social signals. Nullable if brand affinity is not a qualification criterion.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browsingCategories rdf:type rdf:Property ;
    rdfs:label 'Browsing Categories' ;
    rdfs:comment 'Comma-separated list of IAB content categories or site categories that segment members have browsed (e.g., IAB1 for Automotive, IAB3 for Business). Nullable if browsing behavior is not a qualification criterion.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentConsumptionTopics rdf:type rdf:Property ;
    rdfs:label 'Content Consumption Topics' ;
    rdfs:comment 'Comma-separated list of content topics or themes consumed by segment members (e.g., \'sports\', \'finance\', \'travel\'). Nullable if content affinity is not a qualification criterion.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationMethod rdf:type rdf:Property ;
    rdfs:label 'Creation Method' ;
    rdfs:comment 'Methodology used to build the segment: rules-based (Boolean logic), ML-modeled (algorithmic clustering/propensity), imported (from external platform), survey-derived (research panel), or manual (curated list).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDeviceFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Device Flag' ;
    rdfs:comment 'Indicates whether segment uses cross-device identity resolution to track users across desktop, mobile, tablet, and CTV.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceTier rdf:type rdf:Property ;
    rdfs:label 'Data Source Tier' ;
    rdfs:comment 'Origin tier of the segment data: first-party (owned CRM/web/app data), second-party (partner-shared data), or third-party (purchased from data providers).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaCodes rdf:type rdf:Property ;
    rdfs:label 'Dma Codes' ;
    rdfs:comment 'Comma-separated list of Nielsen DMA codes (e.g., 501 for New York) used for geographic targeting. Nullable if geography is not a qualification criterion.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date when the segment becomes available for targeting and activation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date when the segment is no longer valid for targeting, either due to data staleness, consent expiration, or campaign end. Nullable for evergreen segments.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalCode rdf:type rdf:Property ;
    rdfs:label 'External Code' ;
    rdfs:comment 'External identifier or code used by DSPs, DMPs, CDPs, and third-party platforms to reference this segment.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeTier rdf:type rdf:Property ;
    rdfs:label 'Income Tier' ;
    rdfs:comment 'Household income bracket or tier used for demographic qualification (e.g., <50K, 50K-100K, 100K+). Nullable if income is not a qualification criterion. [ENUM-REF-CANDIDATE: <25K|25K-50K|50K-75K|75K-100K|100K-150K|150K-250K|250K+ — promote to reference product]' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestTaxonomy rdf:type rdf:Property ;
    rdfs:label 'Interest Taxonomy' ;
    rdfs:comment 'Comma-separated list of interest categories or hobbies (e.g., \'fitness\', \'gaming\', \'cooking\') used for psychographic qualification. Nullable if interests are not a qualification criterion.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Primary language preference for segment members (ISO 639-1 codes: EN, ES, FR, etc.). Nullable if language is not a qualification criterion.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifestyleSegment rdf:type rdf:Property ;
    rdfs:label 'Lifestyle Segment' ;
    rdfs:comment 'Lifestyle or life-stage classification (e.g., \'young professionals\', \'empty nesters\', \'urban millennials\') used for psychographic qualification. Nullable if lifestyle is not a qualification criterion.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase History Flag' ;
    rdfs:comment 'Indicates whether segment qualification includes past purchase behavior from CRM or e-commerce data.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfmScore rdf:type rdf:Property ;
    rdfs:label 'Rfm Score' ;
    rdfs:comment 'RFM segmentation score (e.g., 555 for best customers, 111 for low-value) used for behavioral qualification. Nullable if RFM is not a qualification criterion.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Total count of unique users, devices, or households currently qualifying for this segment.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valsSegment rdf:type rdf:Property ;
    rdfs:label 'Vals Segment' ;
    rdfs:comment 'VALS psychographic segmentation classification (e.g., Innovators, Thinkers, Achievers, Experiencers) used for psychographic qualification. Nullable if VALS is not a qualification criterion. [ENUM-REF-CANDIDATE: innovators|thinkers|achievers|experiencers|believers|strivers|makers|survivors — promote to reference product]' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'Unique identifier for the segment membership record. Primary key for the segment membership association.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerMember rdf:type rdf:Property ;
    rdfs:label 'Cost Per Member' ;
    rdfs:comment 'The cost paid to acquire or license this specific segment membership from a third-party data provider, expressed in the campaign currency. Null for first-party segments. Used for data cost attribution and ROI analysis.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dspPlatform rdf:type rdf:Property ;
    rdfs:label 'Dsp Platform' ;
    rdfs:comment 'The name or identifier of the DSP platform where this segment membership is activated for programmatic buying (e.g., The Trade Desk, Google DV360, Amazon DSP). Used for cross-platform segment distribution tracking and activation reconciliation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Inclusion Flag' ;
    rdfs:comment 'Boolean flag indicating whether this is an inclusion (true) or exclusion (false) membership. Inclusion memberships are targeted in campaigns; exclusion memberships are suppressed. Supports negative targeting and suppression list management.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchRate rdf:type rdf:Property ;
    rdfs:label 'Match Rate' ;
    rdfs:comment 'The rate at which this audience identifier successfully matched to the segment criteria, expressed as a decimal between 0 and 1. Used for data quality assessment and segment match performance analysis across DMP and CDP integrations.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membershipExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Membership Expiry Date' ;
    rdfs:comment 'The date when the segment membership expires or is scheduled to expire. Nullable for evergreen segments. Used for time-bound segment management and automated exclusion workflows.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipSource rdf:type rdf:Property ;
    rdfs:label 'Membership Source' ;
    rdfs:comment 'The origin or derivation method of the segment membership. First-party indicates data collected directly by the advertiser. Second-party indicates data shared by a partner. Third-party indicates data purchased from a data provider. Modeled indicates membership derived from predictive modeling. Lookalike indicates membership based on similarity to a seed audience. Behavioral indicates membership based on observed actions. Contextual indicates membership based on content consumption. [ENUM-REF-CANDIDATE: first_party|second_party|third_party|modeled|lookalike|behavioral|contextual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Membership Start Date' ;
    rdfs:comment 'The date when the audience identifier first became a member of this segment. Used for recency analysis and segment freshness reporting.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the segment membership. Active indicates the identifier is currently in the segment and eligible for targeting. Expired indicates membership has lapsed. Excluded indicates the identifier has been explicitly removed. Pending indicates membership is being processed. Suppressed indicates the identifier is blocked from targeting due to consent or compliance rules.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyDays rdf:type rdf:Property ;
    rdfs:label 'Recency Days' ;
    rdfs:comment 'The number of days since the audience identifier last exhibited the behavior or attribute that qualifies them for this segment. Used for recency-based targeting strategies and segment decay analysis.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentPriority rdf:type rdf:Property ;
    rdfs:label 'Segment Priority' ;
    rdfs:comment 'A numeric priority ranking for this segment membership when the audience identifier belongs to multiple overlapping segments. Higher values indicate higher priority. Used for bid decisioning and creative selection when multiple segments apply.' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creationInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Creation Initiative Id' ;
    rdfs:comment 'Foreign key linking to project.initiative. Business justification: Suppression list creation and maintenance is often a project task within compliance or campaign setup initiatives. Agencies track which project funded list development for billing and to manage data o' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:governingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Governing Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Suppression obligations are frequently contractually mandated (competitor exclusions, brand safety requirements, regulatory compliance). Critical for compliance verification, audit trails, and ensurin' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:primarySuppressionWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Suppression Worker Id' ;
    rdfs:comment 'User ID or email of the business user responsible for maintaining and approving the suppression list.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Timestamp when the suppression list was approved for use in campaigns.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:archiveDate rdf:type rdf:Property ;
    rdfs:label 'Archive Date' ;
    rdfs:comment 'Date when the suppression list was archived and removed from active campaign targeting systems.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentWithdrawalFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawal Flag' ;
    rdfs:comment 'Indicates whether the suppression list contains identifiers for users who have withdrawn marketing consent (True/False).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCost rdf:type rdf:Property ;
    rdfs:label 'Data Cost' ;
    rdfs:comment 'Cost incurred to acquire or license the suppression list data from a third-party provider, in US Dollars (USD).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataProvider rdf:type rdf:Property ;
    rdfs:label 'Data Provider' ;
    rdfs:comment 'Name of the third-party data provider or vendor that supplied the suppression list, if applicable (e.g., \'Nielsen\', \'Comscore\', \'LiveRamp\').' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCapPeriod rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Period' ;
    rdfs:comment 'Time period over which the frequency cap threshold is measured (hour, day, week, month, campaign lifetime).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCapThreshold rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Threshold' ;
    rdfs:comment 'Maximum number of impressions or interactions allowed before an identifier is added to the suppression list. Applicable for frequency-capped suppression types.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hashingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Hashing Algorithm' ;
    rdfs:comment 'Cryptographic hashing algorithm applied to identifiers for privacy protection (SHA256, MD5, SHA1, none if identifiers are not hashed).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listCode rdf:type rdf:Property ;
    rdfs:label 'List Code' ;
    rdfs:comment 'Unique business code or external identifier for the suppression list used in campaign systems and Data Management Platforms (DMPs).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listName rdf:type rdf:Property ;
    rdfs:label 'List Name' ;
    rdfs:comment 'Business-friendly name of the suppression list (e.g., \'Q4 Converted Customers\', \'GDPR Opt-Out Master\', \'Competitor Employees\').' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listSize rdf:type rdf:Property ;
    rdfs:label 'List Size' ;
    rdfs:comment 'Total count of unique identifiers in the suppression list. Used for reach estimation and media planning.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listStatus rdf:type rdf:Property ;
    rdfs:label 'List Status' ;
    rdfs:comment 'Current lifecycle status of the suppression list (active, inactive, expired, pending approval, archived). Only active lists are applied to campaign targeting.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Platform Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful synchronization of the suppression list to downstream advertising platforms.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:privacyComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Compliance Flag' ;
    rdfs:comment 'Indicates whether the suppression list was created to satisfy privacy regulations such as General Data Protection Regulation (GDPR) or California Consumer Privacy Act (CCPA) opt-out requests (True/False).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which the suppression list is refreshed or re-synced from the source system (daily, weekly, monthly, quarterly, on-demand, real-time).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days the suppression list and its identifiers are retained before automatic archival or deletion, per data retention policies and privacy regulations.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeLevel rdf:type rdf:Property ;
    rdfs:label 'Scope Level' ;
    rdfs:comment 'Organizational level at which the suppression list is applied (global across all advertisers, advertiser-specific, campaign-specific, line-item-specific).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileName rdf:type rdf:Property ;
    rdfs:label 'Source File Name' ;
    rdfs:comment 'Name of the file or data feed from which the suppression list was ingested, if applicable. Supports audit and lineage tracking.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Originating system or platform that generated the suppression list (e.g., \'Salesforce CRM\', \'The Trade Desk\', \'Adobe Audience Manager\', \'Google Campaign Manager 360\', \'Internal CRM\').' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionListDescription rdf:type rdf:Property ;
    rdfs:label 'Suppression List Description' ;
    rdfs:comment 'Detailed business description of the suppression list purpose, use case, and any special handling instructions.' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionType rdf:type rdf:Property ;
    rdfs:label 'Suppression Type' ;
    rdfs:comment 'Category of suppression defining why identifiers are excluded from targeting (converted customer, opted-out user, frequency-capped audience, competitor employee, brand safety exclusion, fraud prevention).' ;
    rdfs:domain ind:SuppressionList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'Timestamp when the feed integration was activated and began syncing data.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract automatically renews upon expiration.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date when the data provider contract expires or is scheduled for renewal.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date when the data provider contract became effective.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpmRate rdf:type rdf:Property ;
    rdfs:label 'Cpm Rate' ;
    rdfs:comment 'Cost per thousand impressions or records for CPM-based pricing models.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataExpiryDays rdf:type rdf:Property ;
    rdfs:label 'Data Expiry Days' ;
    rdfs:comment 'Number of days after which the third-party data must be purged or refreshed per provider policy and privacy regulations.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataTaxonomyVersion rdf:type rdf:Property ;
    rdfs:label 'Data Taxonomy Version' ;
    rdfs:comment 'Version identifier of the data taxonomy or classification schema used by the provider for audience segment categorization.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Number of errors encountered during the last synchronization attempt.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedType rdf:type rdf:Property ;
    rdfs:label 'Feed Type' ;
    rdfs:comment 'Classification of the audience data feed by the type of data provided.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationDirection rdf:type rdf:Property ;
    rdfs:label 'Integration Direction' ;
    rdfs:comment 'Direction of data flow: inbound (receiving data from provider), outbound (sending data to provider), or bidirectional (two-way sync).' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationHealthScore rdf:type rdf:Property ;
    rdfs:label 'Integration Health Score' ;
    rdfs:comment 'Calculated health score (0-100) reflecting sync success rate, data quality, latency, and error frequency for this feed.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Overall lifecycle status of the third-party feed integration.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Last Error Message' ;
    rdfs:comment 'Detailed error message or code from the most recent failed synchronization event.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSyncRecordCount rdf:type rdf:Property ;
    rdfs:label 'Last Sync Record Count' ;
    rdfs:comment 'Number of records processed in the most recent synchronization event.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licensingTerms rdf:type rdf:Property ;
    rdfs:label 'Licensing Terms' ;
    rdfs:comment 'Summary of contractual licensing terms governing the use of the third-party data, including usage restrictions, redistribution rights, and compliance obligations.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyCostAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Cost Amount' ;
    rdfs:comment 'Fixed or estimated monthly cost for the data feed in the contract currency.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piiHandlingClassification rdf:type rdf:Property ;
    rdfs:label 'Pii Handling Classification' ;
    rdfs:comment 'Classification of how the feed handles PII: no PII present, pseudonymized identifiers, hashed identifiers, fully anonymized, or contains direct PII.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentMappingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Segment Mapping Configuration' ;
    rdfs:comment 'JSON or structured configuration defining how provider segments map to internal audience taxonomy and targeting rules.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRecordsSynced rdf:type rdf:Property ;
    rdfs:label 'Total Records Synced' ;
    rdfs:comment 'Cumulative count of audience records or segments synchronized from this feed since activation.' ;
    rdfs:domain ind:ThirdPartyFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:architectureId rdf:type rdf:Property ;
    rdfs:label 'Architecture Id' ;
    rdfs:comment 'Unique identifier for the brand architecture record.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guidelineId rdf:type rdf:Property ;
    rdfs:label 'Guideline Id' ;
    rdfs:comment 'Foreign key linking to brand.brand_guideline. Business justification: Brand architecture decisions reference specific brand guidelines that govern the portfolio structure. Currently architecture_code and architecture_name exist, but the guideline reference should be a f' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guideline .

ind:supersededByArchitectureId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Architecture Id' ;
    rdfs:comment 'Reference to the brand architecture record that replaced this configuration. Null if current.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Architecture .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the individual who approved this brand architecture configuration.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:architectureCode rdf:type rdf:Property ;
    rdfs:label 'Architecture Code' ;
    rdfs:comment 'Unique business identifier for this brand architecture configuration.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:architectureName rdf:type rdf:Property ;
    rdfs:label 'Architecture Name' ;
    rdfs:comment 'Descriptive name for this brand architecture structure.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:architectureStatus rdf:type rdf:Property ;
    rdfs:label 'Architecture Status' ;
    rdfs:comment 'Current lifecycle status of this brand architecture configuration.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:architectureType rdf:type rdf:Property ;
    rdfs:label 'Architecture Type' ;
    rdfs:comment 'Classification of the brand architecture strategy model used by the client.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandEquityContributionScore rdf:type rdf:Property ;
    rdfs:label 'Brand Equity Contribution Score' ;
    rdfs:comment 'Quantitative assessment of this brands contribution to overall portfolio brand equity.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandRole rdf:type rdf:Property ;
    rdfs:label 'Brand Role' ;
    rdfs:comment 'Functional role this brand plays within the portfolio architecture.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Media channels and touchpoints where this brand architecture structure is applied.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBrandingAllowed rdf:type rdf:Property ;
    rdfs:label 'Co Branding Allowed' ;
    rdfs:comment 'Indicates whether this brand is permitted to participate in co-branding partnerships.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endorsementStrength rdf:type rdf:Property ;
    rdfs:label 'Endorsement Strength' ;
    rdfs:comment 'Degree to which the parent brand visibly endorses or supports this brand in market communications.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth level in the brand hierarchy tree. Level 1 is master brand, increasing numbers represent deeper nesting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isGlobalMaster rdf:type rdf:Property ;
    rdfs:label 'Is Global Master' ;
    rdfs:comment 'Indicates whether this architecture serves as the global master template for regional adaptations.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent formal review of this brand architecture.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketPositioningDifferentiation rdf:type rdf:Property ;
    rdfs:label 'Market Positioning Differentiation' ;
    rdfs:comment 'Description of how this brand is differentiated from other brands in the portfolio within the market.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this brand architecture configuration.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioStrategyRationale rdf:type rdf:Property ;
    rdfs:label 'Portfolio Strategy Rationale' ;
    rdfs:comment 'Business justification and strategic reasoning for this brand architecture configuration.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Product Category Scope' ;
    rdfs:comment 'Product categories or segments this brand covers within the portfolio.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Nature of the relationship between this brand and related brands in the portfolio.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Frequency in months at which this brand architecture is formally reviewed and validated.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAudienceOverlapPct rdf:type rdf:Property ;
    rdfs:label 'Target Audience Overlap Pct' ;
    rdfs:comment 'Estimated percentage of target audience overlap with parent or sibling brands in the portfolio.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visualConnectionLevel rdf:type rdf:Property ;
    rdfs:label 'Visual Connection Level' ;
    rdfs:comment 'Degree of visual identity alignment between this brand and its parent or sibling brands.' ;
    rdfs:domain ind:Architecture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandAssetId rdf:type rdf:Property ;
    rdfs:label 'Brand Asset Id' ;
    rdfs:comment 'Unique system-generated identifier for each brand asset record in the DAM. Primary key for the brand_asset product.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandAsset .

ind:damAssetId rdf:type rdf:Property ;
    rdfs:label 'Dam Asset Id' ;
    rdfs:comment 'External reference identifier for this asset in the Digital Asset Management (DAM) system — Adobe Creative Cloud or Workfront DAM. Used to cross-reference and retrieve the physical file from the DAM platform.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:parentAssetBrandAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Brand Asset Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the master or parent asset from which this variant or localized version was derived. Enables asset hierarchy and lineage tracking.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandAsset .

ind:productionSupplierId rdf:type rdf:Property ;
    rdfs:label 'Production Supplier Id' ;
    rdfs:comment 'Foreign key linking to vendor.supplier. Business justification: Brand assets track production vendor (design agencies, production houses, photographers) for asset provenance, rights management, and vendor performance evaluation. Critical for usage rights tracking ' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:approvedChannels rdf:type rdf:Property ;
    rdfs:label 'Approved Channels' ;
    rdfs:comment 'Comma-separated list of channels for which this asset has been approved for deployment (e.g., \'digital,print,OOH,broadcast,social\'). Enforces brand compliance by restricting asset use to authorized channels only.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed narrative description of the brand asset including its intended use, visual characteristics, and any special handling instructions for creative teams.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or title of the brand asset as catalogued in the DAM (e.g., \'Primary Logo RGB\', \'Brand Typeface Regular\', \'Hero Photography Q1 2024\').' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the brand asset by its creative or identity function. Drives usage rights enforcement and channel eligibility rules. [ENUM-REF-CANDIDATE: logo|icon|typeface|brand_video|photography|illustration|template|motion_graphic|brand_guideline|color_palette — promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobrandingPartner rdf:type rdf:Property ;
    rdfs:label 'Cobranding Partner' ;
    rdfs:comment 'Name of the co-branding partner organization whose brand identity is incorporated in this asset (e.g., for co-branded campaigns or partnership activations). Null if no co-branding applies.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorMode rdf:type rdf:Property ;
    rdfs:label 'Color Mode' ;
    rdfs:comment 'Color space or mode of the asset (RGB for digital, CMYK for print, Pantone for brand-matched spot colors). Critical for ensuring correct reproduction across digital and print channels.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentCount rdf:type rdf:Property ;
    rdfs:label 'Deployment Count' ;
    rdfs:comment 'Total number of times this asset has been deployed across campaigns, channels, or markets. Supports asset utilization reporting and ROI analysis for brand asset investment.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'File size of the asset in kilobytes. Used to validate compliance with channel-specific file weight limits (e.g., IAB ad unit max file sizes for digital placements).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightPx rdf:type rdf:Property ;
    rdfs:label 'Height Px' ;
    rdfs:comment 'Height dimension of the asset in pixels. Used alongside width for aspect ratio validation and channel placement eligibility.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMasterAsset rdf:type rdf:Property ;
    rdfs:label 'Is Master Asset' ;
    rdfs:comment 'Indicates whether this asset is the master/canonical version of the asset type for the brand (True) or a derivative/localized variant (False). Supports brand governance by identifying the authoritative source asset.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 region subtag) indicating the language of any text or copy embedded in the asset (e.g., \'en\', \'en-US\', \'fr-FR\'). Supports multi-market localization management.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDeployedDate rdf:type rdf:Property ;
    rdfs:label 'Last Deployed Date' ;
    rdfs:comment 'Date on which this asset was most recently deployed in a campaign, channel, or market activation. Used for asset utilization reporting and identifying dormant assets.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage in the brand asset\'s lifecycle from creation through retirement. Governs whether the asset may be deployed in campaigns or channels. Aligns with Workfront proofing workflow stages.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketApplicability rdf:type rdf:Property ;
    rdfs:label 'Market Applicability' ;
    rdfs:comment 'Comma-separated list of markets or regions where this asset is approved for use (e.g., \'USA,CAN,GBR\'). Supports multi-market brand governance and localization compliance.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDpi rdf:type rdf:Property ;
    rdfs:label 'Resolution Dpi' ;
    rdfs:comment 'Resolution of the asset expressed in dots per inch (DPI). Determines print and digital quality suitability (e.g., 72 DPI for web, 300 DPI for print).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Restriction Notes' ;
    rdfs:comment 'Free-text field capturing any specific restrictions, caveats, or conditions on the use of this asset (e.g., \'Not for use in alcohol advertising\', \'Minimum size 100px\', \'Do not alter color values\'). Supports brand compliance enforcement.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rights Expiry Date' ;
    rdfs:comment 'Date on which the usage rights for this asset expire. After this date, the asset must not be deployed without rights renewal. Critical for rights management compliance and avoiding unauthorized use.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsTerritory rdf:type rdf:Property ;
    rdfs:label 'Rights Territory' ;
    rdfs:comment 'Geographic territory or market scope in which the usage rights for this asset are valid (e.g., \'USA\', \'GBR\', \'Global\', \'EMEA\'). Restricts deployment to authorized markets only.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsType rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Type' ;
    rdfs:comment 'Classification of the intellectual property rights governing this asset\'s use (e.g., owned outright, licensed, royalty-free, rights-managed). Determines permissible deployment scope and commercial use restrictions.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPx rdf:type rdf:Property ;
    rdfs:label 'Width Px' ;
    rdfs:comment 'Width dimension of the asset in pixels. Used for channel eligibility validation and ad serving compatibility checks.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandComplianceCheckId rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Check Id' ;
    rdfs:comment 'Unique identifier for the brand compliance check record. Primary key for this transactional compliance review entity.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverWorkerId rdf:type rdf:Property ;
    rdfs:label 'Approver Worker Id' ;
    rdfs:comment 'Identifier of the authorized individual who provided final sign-off on the compliance check. May differ from reviewer for escalated or senior-level approvals.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:partnershipId rdf:type rdf:Property ;
    rdfs:label 'Partnership Id' ;
    rdfs:comment 'Foreign key linking to brand.brand_partnership. Business justification: Compliance checks validate co-branded materials from brand partnerships. Nullable FK populated when reviewing partnership-related assets. Currently partnership_type and partner_brand_name are descript' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partnership .

ind:prCampaignId rdf:type rdf:Property ;
    rdfs:label 'Pr Campaign Id' ;
    rdfs:comment 'Foreign key linking to brand.pr_campaign. Business justification: Compliance checks validate PR campaign materials for brand guideline adherence. Nullable FK populated when item_type=\'pr_campaign\'. Enables tracking compliance across PR activities and linking to camp' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrCampaign .

ind:previousCheckBrandComplianceCheckId rdf:type rdf:Property ;
    rdfs:label 'Previous Check Brand Compliance Check Id' ;
    rdfs:comment 'Identifier of the prior compliance check record for this item, if this is a resubmission. Supports version history and remediation tracking.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandComplianceCheck .

ind:primaryBrandWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Brand Worker Id' ;
    rdfs:comment 'Identifier of the talent resource who performed the compliance review. Links to the talent domain for reviewer identity and credentials.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the individual who granted final compliance approval, supporting audit trail and accountability requirements.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Business identifier for the compliance check, formatted as BCC-YYYYMMDD sequence for external reference and audit trail purposes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOutcome rdf:type rdf:Property ;
    rdfs:label 'Compliance Outcome' ;
    rdfs:comment 'Final determination of whether the reviewed item meets brand guideline requirements. Drives remediation workflow and approval routing.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemIdentifier rdf:type rdf:Property ;
    rdfs:label 'Item Identifier' ;
    rdfs:comment 'Business reference code or identifier of the specific asset, campaign, press release, or partnership material under review. May reference DAM asset ID, campaign code, or PR document number.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemTitle rdf:type rdf:Property ;
    rdfs:label 'Item Title' ;
    rdfs:comment 'Human-readable title or name of the item under compliance review, supporting quick identification and reporting.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Classification of the deliverable or material being reviewed for brand compliance. Determines applicable guideline sets and review criteria. [ENUM-REF-CANDIDATE: creative_asset|campaign_execution|press_release|partnership_material|social_media_post|ooh_creative|digital_banner|video_ad|landing_page — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerBrandName rdf:type rdf:Property ;
    rdfs:label 'Partner Brand Name' ;
    rdfs:comment 'Name of the partner brand involved in co-branded materials or partnership deliverables. Supports co-branding approval workflows and conflict checking.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipType rdf:type rdf:Property ;
    rdfs:label 'Partnership Type' ;
    rdfs:comment 'Classification of co-branding or partnership arrangement requiring compliance review. Determines additional approval requirements and guideline sets.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory or industry standard framework applied during this compliance check. Supports multi-jurisdiction compliance tracking and regulatory reporting. [ENUM-REF-CANDIDATE: ASA|FTC|EASA|IAB|GDPR|CCPA|TAG|MRC|internal — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDeadline rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline' ;
    rdfs:comment 'Target date by which identified violations must be corrected and the item resubmitted for compliance review. Supports SLA tracking and escalation workflows.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationNotes rdf:type rdf:Property ;
    rdfs:label 'Remediation Notes' ;
    rdfs:comment 'Detailed instructions and recommendations for correcting identified violations. Provides actionable guidance to creative teams and account managers.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Boolean indicator of whether corrective action is required before the item can be approved for use. Drives workflow routing and deadline tracking.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'Number of times the item has been resubmitted for compliance review after remediation. Tracks rework cycles and quality metrics.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The date when the compliance review was performed. Principal business event timestamp for this compliance check transaction.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Review Duration Minutes' ;
    rdfs:comment 'Total time in minutes spent conducting the compliance review. Supports resource planning, capacity management, and process efficiency analysis.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewPriority rdf:type rdf:Property ;
    rdfs:label 'Review Priority' ;
    rdfs:comment 'Priority level assigned to this compliance check, driving SLA targets and resource allocation. Urgent reviews support time-sensitive campaign launches.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle status of the compliance check workflow. Tracks progression from initial submission through final approval or rejection.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Precise date and time when the compliance review was initiated, supporting detailed audit trail and SLA tracking.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Free-text comments and observations from the compliance reviewer. Provides context, rationale, and additional guidance beyond structured violation fields.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the individual who conducted the compliance review, supporting audit trail and accountability requirements.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'Date when final approval was granted and the compliance check was closed. Null for checks still in progress or requiring remediation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'Precise date and time of final compliance approval, supporting detailed audit trail and regulatory reporting requirements.' ;
    rdfs:domain ind:BrandComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:violationSeverity rdf:type rdf:Property ;
    rdfs:label 'Violation Severity' ;
    rdfs:comment 'Classification of the severity level of identified violations. Critical violations block approval; major violations require remediation; minor violations may be conditionally approved.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationsIdentified rdf:type rdf:Property ;
    rdfs:label 'Violations Identified' ;
    rdfs:comment 'Detailed list of specific guideline clauses or requirements that were breached, including clause numbers and brief descriptions. Supports remediation planning and regulatory reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisEventId rdf:type rdf:Property ;
    rdfs:label 'Crisis Event Id' ;
    rdfs:comment 'Unique identifier for the brand crisis event record. Primary key.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCrisisWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Crisis Worker Id' ;
    rdfs:comment 'Identifier of the talent or worker assigned as the primary crisis response lead responsible for coordinating the response strategy and communications.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:affectedMarkets rdf:type rdf:Property ;
    rdfs:label 'Affected Markets' ;
    rdfs:comment 'Geographic markets or regions impacted by the crisis event, stored as comma-separated three-letter ISO country codes (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandAwarenessImpactPct rdf:type rdf:Property ;
    rdfs:label 'Brand Awareness Impact Pct' ;
    rdfs:comment 'Percentage change in brand awareness metrics (aided or unaided recall) measured post-crisis compared to pre-crisis baseline.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationChannelsUsed rdf:type rdf:Property ;
    rdfs:label 'Communication Channels Used' ;
    rdfs:comment 'Comma-separated list of communication channels employed in the crisis response (e.g., press release, social media, email, website statement, media interview).' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Description of corrective actions and preventive measures implemented to address the root cause and prevent recurrence.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisName rdf:type rdf:Property ;
    rdfs:label 'Crisis Name' ;
    rdfs:comment 'Business-friendly name or title assigned to the crisis event for internal reference and tracking.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisStatus rdf:type rdf:Property ;
    rdfs:label 'Crisis Status' ;
    rdfs:comment 'Current lifecycle state of the crisis event: monitoring (watching for escalation), active (response underway), contained (impact limited), or resolved (closed).' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisType rdf:type rdf:Property ;
    rdfs:label 'Crisis Type' ;
    rdfs:comment 'Classification of the crisis event by nature: product recall, executive misconduct, social media backlash, regulatory action, data breach, or competitive attack.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Channel or system through which the crisis was first identified (e.g., social media monitoring, news alert, customer complaint, internal audit, regulatory notice).' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the crisis event was first detected or identified by monitoring systems or personnel.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the crisis was escalated to senior leadership or executive crisis management team. Null if no escalation occurred.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate' ;
    rdfs:comment 'Estimated financial impact of the crisis event in USD, including direct costs (legal fees, settlements, remediation) and indirect costs (lost revenue, brand damage).' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingStatementReference rdf:type rdf:Property ;
    rdfs:label 'Holding Statement Reference' ;
    rdfs:comment 'Reference identifier or document link to the initial holding statement or public communication issued in response to the crisis.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalActionFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Action Flag' ;
    rdfs:comment 'Indicates whether legal action (lawsuit, regulatory fine, cease-and-desist) was initiated as a result of the crisis event.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaMentionsCount rdf:type rdf:Property ;
    rdfs:label 'Media Mentions Count' ;
    rdfs:comment 'Total count of media mentions (news articles, broadcast segments, online publications) referencing the crisis event.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsImpactScore rdf:type rdf:Property ;
    rdfs:label 'Nps Impact Score' ;
    rdfs:comment 'Measured change in Net Promoter Score (NPS) for the affected brand following the crisis event, indicating impact on customer loyalty and advocacy.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postCrisisImpactAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Post Crisis Impact Assessment Flag' ;
    rdfs:comment 'Indicates whether a formal post-crisis brand impact assessment has been completed to measure reputational damage and recovery metrics.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBodyInvolved rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Involved' ;
    rdfs:comment 'Name of the regulatory or governing body involved in the crisis (e.g., FTC, ASA, GDPR authority). Null if no regulatory involvement.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the crisis was officially declared resolved and closed. Null if crisis is still active or contained.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseStrategyType rdf:type rdf:Property ;
    rdfs:label 'Response Strategy Type' ;
    rdfs:comment 'Classification of the crisis response approach being employed (e.g., proactive disclosure, defensive positioning, apology and remediation, legal defense, silence strategy).' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTeamSize rdf:type rdf:Property ;
    rdfs:label 'Response Team Size' ;
    rdfs:comment 'Number of internal and external personnel mobilized as part of the crisis response team.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rootCauseSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Summary' ;
    rdfs:comment 'Brief summary of the identified root cause or contributing factors that led to the crisis event, documented after investigation.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Aggregated sentiment score reflecting public perception during the crisis, typically ranging from -100 (highly negative) to +100 (highly positive).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Priority classification of the crisis event indicating urgency and impact: P1 (critical), P2 (high), P3 (medium), P4 (low).' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaVolume rdf:type rdf:Property ;
    rdfs:label 'Social Media Volume' ;
    rdfs:comment 'Total volume of social media posts, comments, and shares related to the crisis event across monitored platforms.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stakeholderNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Notification Timestamp' ;
    rdfs:comment 'Date and time when key stakeholders (clients, partners, investors) were formally notified of the crisis event.' ;
    rdfs:domain ind:CrisisEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedProductionSupplierId rdf:type rdf:Property ;
    rdfs:label 'Approved Production Supplier Id' ;
    rdfs:comment 'Foreign key linking to vendor.supplier. Business justification: Brand guidelines specify approved production vendors (design agencies, production houses) for asset creation. Essential for vendor compliance in creative production and ensuring brand consistency acro' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:previousVersionGuidelineId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Guideline Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding version of this guideline. Enables version chain traversal and supports messaging framework evolution auditing.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guideline .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes identifying the geographic markets to which this guideline applies (e.g., \'USA|GBR|DEU\'). Supports multi-market brand governance and regional variant management.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTypefaces rdf:type rdf:Property ;
    rdfs:label 'Approved Typefaces' ;
    rdfs:comment 'Pipe-delimited list of approved font family names for use in brand communications (e.g., \'Helvetica Neue|Georgia|Arial\'). Populated for visual_identity guideline types. Sourced from Adobe Creative Cloud font libraries.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceMessageMap rdf:type rdf:Property ;
    rdfs:label 'Audience Message Map' ;
    rdfs:comment 'Structured JSON-serialised string capturing audience segment-to-message mappings (e.g., segment name, primary message, secondary message, call-to-action). Populated for messaging_framework guideline types to support audience-targeted communications.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandPillars rdf:type rdf:Property ;
    rdfs:label 'Brand Pillars' ;
    rdfs:comment 'Pipe-delimited list of the brand\'s strategic pillars (e.g., \'Innovation|Trust|Sustainability\'). Populated for messaging_framework guideline types. Confidential as it represents proprietary brand positioning strategy.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandPromise rdf:type rdf:Property ;
    rdfs:label 'Brand Promise' ;
    rdfs:comment 'The core brand promise statement articulating the fundamental value the brand commits to delivering to its audience. Populated for messaging_framework guideline types. Confidential as it represents proprietary brand strategy.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'Free-text summary of the key changes introduced in this version relative to the previous version. Supports change communication to creative, media, and PR teams.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'Pipe-delimited list of media channels to which this guideline applies (e.g., \'digital|ooh|ctv|print|social\'). Aligns with IAB channel taxonomy and supports channel-specific creative governance. [ENUM-REF-CANDIDATE: digital|ooh|ctv|print|social|radio|dooh|ott|email|search — promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBrandPartnerName rdf:type rdf:Property ;
    rdfs:label 'Co Brand Partner Name' ;
    rdfs:comment 'Name of the partner brand involved in a co-branding arrangement governed by this guideline. Populated only for co_branding guideline types. Supports competitive conflict checks and partner brand governance.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damUri rdf:type rdf:Property ;
    rdfs:label 'Dam Uri' ;
    rdfs:comment 'Fully-qualified URI pointing to the master guideline document stored in the Adobe Creative Cloud Digital Asset Management (DAM) system. Serves as the authoritative source-of-record reference for creative teams.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevatorPitch rdf:type rdf:Property ;
    rdfs:label 'Elevator Pitch' ;
    rdfs:comment 'Concise 30–60 second verbal description of the brand\'s value proposition for use in sales, PR, and client-facing communications. Populated for messaging_framework guideline types.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forbiddenLanguage rdf:type rdf:Property ;
    rdfs:label 'Forbidden Language' ;
    rdfs:comment 'Pipe-delimited list of words, phrases, or claims that are explicitly prohibited in all brand communications under this guideline. Supports compliance with ASA, FTC, and client brand safety requirements.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineCode rdf:type rdf:Property ;
    rdfs:label 'Guideline Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the guideline document, used in Workfront project references and Adobe Creative Cloud DAM asset tagging. Format: BG- followed by 4–12 uppercase alphanumeric characters.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineType rdf:type rdf:Property ;
    rdfs:label 'Guideline Type' ;
    rdfs:comment 'Categorical classification of the guideline document by its primary subject matter. Visual Identity covers logos, colour palettes, typography; Tone of Voice covers language style; Messaging Framework covers brand promise and pillars; Digital covers web/social/app standards; Out-of-Home (OOH) covers outdoor/transit formats; Co-Branding covers partner brand usage rules.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobal rdf:type rdf:Property ;
    rdfs:label 'Is Global' ;
    rdfs:comment 'Indicates whether this guideline applies globally across all markets (True) or is restricted to the markets specified in applicable_markets (False). Supports multi-market brand governance hierarchies.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether compliance with this guideline is mandatory (True) for all creative and communications outputs, or advisory/recommended (False). Supports brand compliance enforcement workflows.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyProofPoints rdf:type rdf:Property ;
    rdfs:label 'Key Proof Points' ;
    rdfs:comment 'Pipe-delimited list of substantiated claims or evidence statements that support the brand promise and pillars. Used by copywriters and PR teams to ensure message consistency. Populated for messaging_framework guideline types.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageVariants rdf:type rdf:Property ;
    rdfs:label 'Language Variants' ;
    rdfs:comment 'Pipe-delimited list of BCP-47 language tags identifying the language versions covered by this guideline (e.g., \'en-US|fr-FR|de-DE\'). Supports localisation of tone-of-voice and messaging framework guidelines.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoUsageRules rdf:type rdf:Property ;
    rdfs:label 'Logo Usage Rules' ;
    rdfs:comment 'Free-text description of approved and prohibited logo usage rules including minimum size, clear space, colour variants, and placement restrictions. Populated for visual_identity and co_branding guideline types.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColourPalette rdf:type rdf:Property ;
    rdfs:label 'Primary Colour Palette' ;
    rdfs:comment 'Pipe-delimited list of approved primary brand colours expressed as HEX codes (e.g., \'#FF0000|#FFFFFF|#000000\'). Populated for visual_identity guideline types. Sourced from Adobe Creative Cloud brand libraries.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleDays rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Days' ;
    rdfs:comment 'Scheduled review frequency for this guideline expressed in calendar days (e.g., 365 for annual review). Drives automated review reminders and governance calendar planning.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryColourPalette rdf:type rdf:Property ;
    rdfs:label 'Secondary Colour Palette' ;
    rdfs:comment 'Pipe-delimited list of approved secondary/accent brand colours expressed as HEX codes. Populated for visual_identity guideline types. Supports extended creative palette governance.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagline rdf:type rdf:Property ;
    rdfs:label 'Tagline' ;
    rdfs:comment 'The primary approved tagline for the brand as defined in this guideline version. Confidential as it may represent unreleased creative strategy prior to campaign launch.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toneDescriptors rdf:type rdf:Property ;
    rdfs:label 'Tone Descriptors' ;
    rdfs:comment 'Pipe-delimited list of adjectives describing the brand\'s approved tone of voice (e.g., \'Authoritative|Warm|Witty|Direct\'). Populated for tone_of_voice and messaging_framework guideline types.' ;
    rdfs:domain ind:Guideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthMetricId rdf:type rdf:Property ;
    rdfs:label 'Health Metric Id' ;
    rdfs:comment 'Unique identifier for the brand health metric record. Primary key for this entity.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positioningId rdf:type rdf:Property ;
    rdfs:label 'Positioning Id' ;
    rdfs:comment 'Foreign key linking to brand.brand_positioning. Business justification: Brand health metrics measure the effectiveness of brand positioning strategies. Nullable FK links metrics (NPS, awareness, sentiment) to the positioning statement being validated. Enables analysis of ' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Positioning .

ind:benchmarkValue rdf:type rdf:Property ;
    rdfs:label 'Benchmark Value' ;
    rdfs:comment 'Industry or competitive benchmark value for comparison. Enables performance assessment relative to category norms or key competitors. Sourced from Nielsen Ad Intel or commissioned research.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Collection Frequency' ;
    rdfs:comment 'Frequency at which this metric is collected or updated. Real-time for social listening, daily for news monitoring, quarterly for surveys, annual for brand audits, ad-hoc for special research projects. [ENUM-REF-CANDIDATE: real_time|daily|weekly|monthly|quarterly|annual|ad_hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Quality score for the measurement data on a scale of 0-100. Assesses completeness, accuracy, timeliness, and reliability of the data source. Used for data governance and quality monitoring.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographyCode rdf:type rdf:Property ;
    rdfs:label 'Geography Code' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic market where the measurement was conducted. Examples: USA, GBR, CAN, AUS.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginOfError rdf:type rdf:Property ;
    rdfs:label 'Margin Of Error' ;
    rdfs:comment 'Margin of error for survey-based metrics, expressed as a percentage (e.g., 3.50 for ±3.5%). Indicates the precision of the measurement.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Geographic or demographic market segment for which this metric was measured. Examples: USA_18-34_Female, UK_All_Adults, APAC_Premium_Segment. Enables segmented brand health analysis.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'Date when the brand health metric was measured or collected. For surveys: fieldwork completion date. For sentiment: observation date. For reviews: review event date.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'End date of the measurement period for aggregated metrics. For sentiment signals collected over a time window, this marks the end of the observation period.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'Start date of the measurement period for aggregated metrics. For sentiment signals collected over a time window, this marks the beginning of the observation period.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Type of brand health measurement. Survey-based metrics (NPS, awareness, consideration), sentiment signals (social listening, news monitoring), or brand review events (QBR, annual audit).' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mentionVolume rdf:type rdf:Property ;
    rdfs:label 'Mention Volume' ;
    rdfs:comment 'Total number of brand mentions captured during the measurement period for sentiment-based metrics. Sourced from social listening tools, news monitoring, or review platforms.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Specific brand health metric being captured. For surveys: NPS (Net Promoter Score), awareness, consideration, preference, purchase intent, loyalty index, equity score. For sentiment: sentiment score, review rating. [ENUM-REF-CANDIDATE: nps|awareness|consideration|preference|purchase_intent|loyalty_index|equity_score|sentiment_score|review_rating — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricValue rdf:type rdf:Property ;
    rdfs:label 'Metric Value' ;
    rdfs:comment 'Quantitative value of the brand health metric. For NPS: -100 to +100. For awareness/consideration: percentage 0-100. For sentiment: -1 to +1 or 0-100 scale depending on methodology.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Prior Period Value' ;
    rdfs:comment 'Metric value from the previous measurement period. Enables period-over-period trend analysis and tracking of brand health trajectory.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchVendor rdf:type rdf:Property ;
    rdfs:label 'Research Vendor' ;
    rdfs:comment 'Name of the research vendor or data provider who conducted the measurement or supplied the data. Examples: Nielsen, Comscore, Brandwatch, Sprinklr, internal research team.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewEventType rdf:type rdf:Property ;
    rdfs:label 'Review Event Type' ;
    rdfs:comment 'Type of brand review event for review-based measurements. QBR (Quarterly Business Review), annual brand audit, mid-year review, or campaign debrief.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFindings rdf:type rdf:Property ;
    rdfs:label 'Review Findings' ;
    rdfs:comment 'Summary of key findings from brand review events. Captures qualitative insights, strengths, weaknesses, opportunities, and threats identified during QBRs or brand audits.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewRecommendations rdf:type rdf:Property ;
    rdfs:label 'Review Recommendations' ;
    rdfs:comment 'Strategic recommendations resulting from brand review events. Action items and strategic guidance for brand positioning, messaging, or campaign adjustments.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentClassification rdf:type rdf:Property ;
    rdfs:label 'Sentiment Classification' ;
    rdfs:comment 'Categorical sentiment classification for sentiment-based metrics. Positive, negative, neutral, or mixed sentiment derived from social listening, news monitoring, or review platforms.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentMagnitude rdf:type rdf:Property ;
    rdfs:label 'Sentiment Magnitude' ;
    rdfs:comment 'Numerical magnitude or intensity of sentiment, typically on a scale of 0-1 or 0-100. Indicates the strength of positive or negative sentiment beyond the classification.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shareOfVoicePercentage rdf:type rdf:Property ;
    rdfs:label 'Share Of Voice Percentage' ;
    rdfs:comment 'Brand\'s share of voice as a percentage of total category mentions. Calculated as (brand mentions / total category mentions) × 100. Sourced from Nielsen Ad Intel or Comscore competitive monitoring.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Target or goal value for this brand health metric as defined in the brand strategy or annual planning. Enables performance tracking against objectives.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topicTags rdf:type rdf:Property ;
    rdfs:label 'Topic Tags' ;
    rdfs:comment 'Comma-separated list of topic tags or themes associated with the sentiment data. Examples: product_quality, customer_service, pricing, sustainability. Enables thematic analysis of brand perception.' ;
    rdfs:domain ind:HealthMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Percentage change from prior period value. Calculated as ((current_value - prior_period_value) / prior_period_value) × 100. Positive indicates improvement, negative indicates decline.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualBrandAwarenessLiftPct rdf:type rdf:Property ;
    rdfs:label 'Actual Brand Awareness Lift Pct' ;
    rdfs:comment 'The measured percentage increase in brand awareness achieved through the partnership.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRoiPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Roi Percentage' ;
    rdfs:comment 'The realized Return on Investment (ROI) percentage achieved by the partnership, calculated post-campaign or at measurement intervals.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedCobrandedAssetReferences rdf:type rdf:Property ;
    rdfs:label 'Approved Cobranded Asset References' ;
    rdfs:comment 'Comma-separated list of Digital Asset Management (DAM) URIs or asset identifiers for approved co-branded creative materials.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandFitScore rdf:type rdf:Property ;
    rdfs:label 'Brand Fit Score' ;
    rdfs:comment 'Quantitative assessment of strategic alignment and compatibility between the two brands, typically on a 0-100 scale. Higher scores indicate stronger brand synergy.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Required Flag' ;
    rdfs:comment 'Indicates whether co-branded assets and partnership activities require formal compliance review per brand guidelines and regulatory standards.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference identifier or document locator for the legal partnership agreement or Statement of Work (SOW).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Category' ;
    rdfs:comment 'The product category or market segment to which exclusivity restrictions apply, if applicable.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the partnership includes exclusivity provisions preventing either brand from entering similar partnerships with competitors during the contract period.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Check Date' ;
    rdfs:comment 'The date of the most recent compliance review conducted for this partnership.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketScope rdf:type rdf:Property ;
    rdfs:label 'Market Scope' ;
    rdfs:comment 'Geographic markets or regions where the partnership is active, expressed as comma-separated ISO 3-letter country codes or region descriptors.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Name or identifier of the user who last modified this partnership record.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'The primary business goal or strategic objective of the partnership (e.g., market expansion, audience reach, brand equity enhancement, revenue growth).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCompanyName rdf:type rdf:Property ;
    rdfs:label 'Partner Company Name' ;
    rdfs:comment 'The legal name of the company owning the partner brand.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipCode rdf:type rdf:Property ;
    rdfs:label 'Partnership Code' ;
    rdfs:comment 'Unique business identifier code for the partnership, used for external reference and tracking.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipName rdf:type rdf:Property ;
    rdfs:label 'Partnership Name' ;
    rdfs:comment 'The official name or title of the brand partnership initiative.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Status' ;
    rdfs:comment 'Current lifecycle status of the partnership: proposed (initial concept), negotiation (terms being finalized), active (live and operational), paused (temporarily suspended), terminated (ended before expiry), or expired (reached natural end date).' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueShareModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Model' ;
    rdfs:comment 'The financial arrangement for revenue distribution between partners: fixed fee (flat payment), percentage split (proportional revenue sharing), tiered (performance-based brackets), hybrid (combination model), or none (no direct revenue sharing).' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'The percentage of revenue allocated to the partner brand, if applicable. Expressed as a decimal (e.g., 25.00 for 25%).' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetBrandAwarenessLiftPct rdf:type rdf:Property ;
    rdfs:label 'Target Brand Awareness Lift Pct' ;
    rdfs:comment 'The target percentage increase in brand awareness expected from the partnership.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRoiPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Roi Percentage' ;
    rdfs:comment 'The target Return on Investment (ROI) percentage goal for the partnership, used to measure financial performance.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Explanation or rationale for partnership termination, if applicable. Captures business context for ended partnerships.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPositioningId rdf:type rdf:Property ;
    rdfs:label 'Parent Positioning Id' ;
    rdfs:comment 'Reference to the global master brand_positioning_id from which this regional or market-specific positioning is derived. Null if this record is itself the global master or a standalone positioning.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Positioning .

ind:primarySupersededByPositioningId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Positioning Id' ;
    rdfs:comment 'Reference to the brand_positioning_id of the newer record that replaced this one. Null if this is the current active version. Enables navigation of the positioning version chain.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Positioning .

ind:awarenessType rdf:type rdf:Property ;
    rdfs:label 'Awareness Type' ;
    rdfs:comment 'Specifies the methodology used to measure the brand awareness baseline: \'unaided\' = spontaneous recall without prompting; \'aided\' = recognition when brand name is provided; \'top_of_mind\' = first brand recalled in category.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandAwarenessBaselinePct rdf:type rdf:Property ;
    rdfs:label 'Brand Awareness Baseline Pct' ;
    rdfs:comment 'The unaided or aided brand awareness percentage recorded at the time this positioning was established or last reviewed. Used as a benchmark to measure the effectiveness of the positioning strategy over time.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandEssence rdf:type rdf:Property ;
    rdfs:label 'Brand Essence' ;
    rdfs:comment 'A concise distillation of the brand\'s fundamental nature and core value — typically a short phrase or single sentence that captures the brand\'s soul and guides all brand expression (e.g., \'Empowering human potential\').' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandPersonality rdf:type rdf:Property ;
    rdfs:label 'Brand Personality' ;
    rdfs:comment 'Description of the human characteristics and traits attributed to the brand (e.g., \'bold, innovative, approachable\'). Guides tone of voice, creative direction, and communications style across all channels.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSentimentBaseline rdf:type rdf:Property ;
    rdfs:label 'Brand Sentiment Baseline' ;
    rdfs:comment 'The baseline brand sentiment score (e.g., on a -100 to +100 scale) recorded at the time this positioning was established or last reviewed. Tracks consumer perception and emotional affinity toward the brand.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveSetIds rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Ids' ;
    rdfs:comment 'Comma-separated list of competitor brand or advertiser identifiers that constitute the defined competitive set for this positioning. Used to scope Share of Voice (SOV) tracking and competitive monitoring via Nielsen Ad Intel.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which this positioning record is considered active and authoritative. Supports temporal tracking of positioning history and enables point-in-time analysis of brand strategy.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frameOfReference rdf:type rdf:Property ;
    rdfs:label 'Frame Of Reference' ;
    rdfs:comment 'The competitive category or context within which the brand competes and against which consumers evaluate it (e.g., \'premium athletic footwear\', \'cloud-based HR software\'). Defines the competitive set boundary for the positioning.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messagingFramework rdf:type rdf:Property ;
    rdfs:label 'Messaging Framework' ;
    rdfs:comment 'Structured narrative framework defining the hierarchy of brand messages — from core proposition through supporting messages to proof points — used to ensure consistency across campaigns and communications.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenBrandCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Brand Code' ;
    rdfs:comment 'The brand identifier assigned by Nielsen Ad Intel for competitive monitoring and SOV tracking. Used to link this positioning record to Nielsen competitive intelligence data and GRP/TRP measurement reports.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsBaseline rdf:type rdf:Property ;
    rdfs:label 'Nps Baseline' ;
    rdfs:comment 'The Net Promoter Score (NPS) baseline value recorded at the time this positioning was established or last reviewed. Provides a benchmark for measuring brand health improvement attributable to the positioning strategy.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointOfDifference rdf:type rdf:Property ;
    rdfs:label 'Point Of Difference' ;
    rdfs:comment 'The key attribute, benefit, or association that differentiates the brand from competitors within the frame of reference. Represents the core competitive advantage articulated in the positioning strategy.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positioningCode rdf:type rdf:Property ;
    rdfs:label 'Positioning Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the positioning record, used in cross-system references, client deliverables, and brand strategy documents (e.g., BP-ACME2024). Satisfies MASTER_RESOURCE BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positioningName rdf:type rdf:Property ;
    rdfs:label 'Positioning Name' ;
    rdfs:comment 'Human-readable title or label for this positioning record (e.g., \'FY2024 Premium Repositioning — ACME Corp\'). Used in reports, presentations, and brand strategy documents. Satisfies MASTER_RESOURCE IDENTITY_LABEL category.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positioningStatus rdf:type rdf:Property ;
    rdfs:label 'Positioning Status' ;
    rdfs:comment 'Current lifecycle state of the positioning record. \'draft\' = in development; \'active\' = approved and in use; \'under_review\' = scheduled review cycle in progress; \'superseded\' = replaced by a newer version; \'archived\' = retired. Satisfies MASTER_RESOURCE LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonToBelieve rdf:type rdf:Property ;
    rdfs:label 'Reason To Believe' ;
    rdfs:comment 'The substantiation or proof points that support the brand\'s point of difference and make the positioning credible to the target audience. May include product features, certifications, heritage, or third-party endorsements.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'The scheduled frequency at which this positioning record is formally reviewed and validated by the brand strategy team and client. Drives workflow scheduling in Workfront and QBR agenda planning.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sov Target Pct' ;
    rdfs:comment 'The target Share of Voice (SOV) percentage the brand aims to achieve within its competitive set and frame of reference. Used as a KPI benchmark for media planning and campaign performance evaluation. Satisfies MASTER_RESOURCE MEASUREMENT_OR_VALUE category.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statement rdf:type rdf:Property ;
    rdfs:label 'Statement' ;
    rdfs:comment 'The formal, approved positioning statement articulating the brand\'s unique place in the market. Typically follows the structure: \'For [target audience], [brand] is the [frame of reference] that [point of difference] because [reason to believe].\' Classified confidential as it represents proprietary brand strategy.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'The date on which this positioning record was superseded by a newer version. Null if the record is currently active. Enables full positioning history tracking and audit trail.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'The primary strategic territory in which the brand is positioned. \'functional\' = product/service performance benefits; \'emotional\' = feelings and personal identity; \'societal\' = broader social, environmental, or cultural purpose. Satisfies MASTER_RESOURCE CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workfrontProjectCode rdf:type rdf:Property ;
    rdfs:label 'Workfront Project Code' ;
    rdfs:comment 'The identifier of the corresponding brand strategy project in Workfront (Project Management system). Enables traceability between the positioning record and the project deliverable, resource plan, and approval workflow.' ;
    rdfs:domain ind:Positioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedMediaSupplierId rdf:type rdf:Property ;
    rdfs:label 'Approved Media Supplier Id' ;
    rdfs:comment 'Foreign key linking to vendor.supplier. Business justification: Brand profiles maintain approved media supplier lists for brand safety compliance and media buying operations. Critical for vendor approval workflows and ensuring brand-safe media placements across ca' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:activeMarkets rdf:type rdf:Property ;
    rdfs:label 'Active Markets' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the markets where the brand is currently active and running campaigns. Supports geo-targeting in The Trade Desk, media planning in Mediaocean Prisma, and multi-market reporting.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyOnboardDate rdf:type rdf:Property ;
    rdfs:label 'Agency Onboard Date' ;
    rdfs:comment 'Date on which the brand was formally onboarded to the agency and the brand profile record was activated in the system of record. Marks the start of the agency-client brand management relationship.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asaCompliant rdf:type rdf:Property ;
    rdfs:label 'Asa Compliant' ;
    rdfs:comment 'Indicates whether the brand\'s advertising materials and practices are compliant with Advertising Standards Authority (ASA) regulations. Required for UK and international market campaign approvals.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandArchetype rdf:type rdf:Property ;
    rdfs:label 'Brand Archetype' ;
    rdfs:comment 'Jungian brand archetype classification (e.g., Hero, Caregiver, Explorer, Sage, Outlaw, Creator, Ruler, Magician, Innocent, Everyman, Lover, Jester) that defines the brand\'s personality framework. Anchors tone of voice, creative direction, and brand strategy positioning. [ENUM-REF-CANDIDATE: Hero|Caregiver|Explorer|Sage|Outlaw|Creator|Ruler|Magician|Innocent|Everyman|Lover|Jester — promote to reference product]' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the brand across agency systems, including Mediaocean Prisma and Google Campaign Manager 360. Used as the business key for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandGuidelinesUrl rdf:type rdf:Property ;
    rdfs:label 'Brand Guidelines Url' ;
    rdfs:comment 'URL reference to the master brand guidelines document stored in Workfront DAM. Serves as the authoritative source for all brand identity standards including logo usage, color palette, typography, and tone of voice rules.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The primary commercial name of the brand as it appears in market-facing communications, campaign briefs, and agency deliverables. Serves as the human-readable identity label for the brand profile.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyCategory rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Category' ;
    rdfs:comment 'Classification of the brand\'s content adjacency sensitivity level for programmatic media buying. Determines the brand safety targeting parameters applied in The Trade Desk and Google Campaign Manager 360 to prevent ad placement near inappropriate content.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current operational lifecycle status of the brand profile record within the agency\'s system of record. Controls whether the brand is eligible for new campaign assignments, media planning, and creative production activities.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandTier rdf:type rdf:Property ;
    rdfs:label 'Brand Tier' ;
    rdfs:comment 'Market positioning tier of the brand reflecting its price-point and competitive positioning strategy. Informs media planning, creative tone, and channel selection within campaign strategy and planning processes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easaCompliant rdf:type rdf:Property ;
    rdfs:label 'Easa Compliant' ;
    rdfs:comment 'Indicates whether the brand\'s advertising practices comply with European Advertising Standards Alliance (EASA) cross-border complaint handling and self-regulatory standards. Required for European market campaign activation.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftcCompliant rdf:type rdf:Property ;
    rdfs:label 'Ftc Compliant' ;
    rdfs:comment 'Indicates whether the brand\'s advertising disclosures, endorsements, and claims comply with Federal Trade Commission (FTC) Advertising Practices Division guidelines. Required for US market campaign activation.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprDataUseConsent rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Use Consent' ;
    rdfs:comment 'Indicates whether the brand has provided consent for audience data usage in programmatic targeting and analytics under GDPR Article 6 lawful basis requirements. Governs data activation in The Trade Desk and DMP/CDP integrations.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The primary industry sector classification of the brand per IAB Content Taxonomy (e.g., Automotive, Consumer Packaged Goods, Financial Services, Retail, Technology). Used for competitive conflict detection, audience segmentation, and Nielsen Ad Intel competitive monitoring alignment. [ENUM-REF-CANDIDATE: Automotive|Consumer Packaged Goods|Financial Services|Retail|Technology|Healthcare|Entertainment|Travel|Telecommunications|Food & Beverage — promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date on which the brand was officially launched in its primary market. Used for brand age calculations, lifecycle stage validation, and historical competitive Share of Voice (SOV) analysis via Nielsen Ad Intel.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localBrandName rdf:type rdf:Property ;
    rdfs:label 'Local Brand Name' ;
    rdfs:comment 'Market-specific or locale-specific variant of the brand name used in regional campaigns, translations, or co-branded executions. Supports multi-market brand management and localization workflows.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Asset Url' ;
    rdfs:comment 'URL reference to the master brand logo file stored in the Workfront Digital Asset Management (DAM) system. Provides a canonical pointer to the approved logo for use in campaign trafficking, ad serving via Google Campaign Manager 360, and creative production.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketTier rdf:type rdf:Property ;
    rdfs:label 'Market Tier' ;
    rdfs:comment 'Classification of the brand\'s market investment tier indicating the scale and priority of media investment. Tier 1 represents highest-investment markets; Tier 3 represents emerging or test markets. Drives media budget allocation in Mediaocean Prisma.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messagingFrameworkUrl rdf:type rdf:Property ;
    rdfs:label 'Messaging Framework Url' ;
    rdfs:comment 'URL reference to the brand\'s approved messaging framework document in Workfront DAM. Defines key messages, proof points, and value propositions used across campaign strategy, PR communications, and creative development.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsBaselineScore rdf:type rdf:Property ;
    rdfs:label 'Nps Baseline Score' ;
    rdfs:comment 'Baseline Net Promoter Score (NPS) for the brand at the time of agency engagement or last formal brand health assessment. Serves as the reference benchmark for measuring brand health improvement over the engagement period. Range: -100.00 to 100.00.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCompanyName rdf:type rdf:Property ;
    rdfs:label 'Parent Company Name' ;
    rdfs:comment 'Legal name of the parent organization that owns or controls the brand. Used for competitive conflict checks, client hierarchy management, and consolidated reporting across brand portfolios.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Primary Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the brand\'s primary color as defined in the brand guidelines. Used by Adobe Creative Cloud (Photoshop, Illustrator, InDesign) for asset production and Workfront DAM for brand compliance checks.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMarket rdf:type rdf:Property ;
    rdfs:label 'Primary Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the brand\'s primary or home market. Used as the default market context for brand health benchmarking, SOV tracking via Nielsen Ad Intel, and regulatory compliance flag evaluation.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTypeface rdf:type rdf:Property ;
    rdfs:label 'Primary Typeface' ;
    rdfs:comment 'Name of the primary typeface (font family) specified in the brand\'s typography standards. Governs headline and body copy font usage across all creative executions produced in Adobe Creative Cloud.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Secondary Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the brand\'s secondary color as defined in the brand guidelines. Supports multi-color palette management in Adobe Creative Cloud and Workfront DAM for creative production workflows.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryTypeface rdf:type rdf:Property ;
    rdfs:label 'Secondary Typeface' ;
    rdfs:comment 'Name of the secondary or supporting typeface specified in the brand\'s typography standards. Used for subheadings, captions, and supporting copy in creative executions.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentBaseline rdf:type rdf:Property ;
    rdfs:label 'Sentiment Baseline' ;
    rdfs:comment 'Baseline brand sentiment classification derived from social listening, PR monitoring, and consumer research at the time of agency engagement. Anchors sentiment tracking and PR communications strategy.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Sov Tracking Enabled' ;
    rdfs:comment 'Indicates whether competitive Share of Voice (SOV) tracking is active for this brand via Nielsen Ad Intel. When enabled, competitive monitoring data is ingested and linked to brand health metrics.' ;
    rdfs:domain ind:BrandProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tagCertified rdf:type rdf:Property ;
    rdfs:label 'Tag Certified' ;
    rdfs:comment 'Indicates whether the brand holds Trustworthy Accountability Group (TAG) certification for brand safety, anti-fraud, and malware protection in digital advertising. Influences publisher allowlist/blocklist configuration in The Trade Desk and Google Campaign Manager 360.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toneOfVoice rdf:type rdf:Property ;
    rdfs:label 'Tone Of Voice' ;
    rdfs:comment 'Standardized classification of the brand\'s communication style and personality expression across all channels. Governs copywriting, creative briefs, and PR communications to ensure brand consistency. [ENUM-REF-CANDIDATE: authoritative|playful|inspirational|empathetic|bold|sophisticated|conversational — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBrandId rdf:type rdf:Property ;
    rdfs:label 'Competitive Brand Id' ;
    rdfs:comment 'Unique identifier for the competitor brand record in the agency\'s competitive intelligence program.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetitiveBrand .

ind:brandPositioningStatement rdf:type rdf:Property ;
    rdfs:label 'Brand Positioning Statement' ;
    rdfs:comment 'The observed or inferred brand positioning statement that articulates the competitor brand\'s unique value proposition and target audience.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSentimentScore rdf:type rdf:Property ;
    rdfs:label 'Brand Sentiment Score' ;
    rdfs:comment 'Aggregated brand sentiment score ranging from -100 (very negative) to +100 (very positive) based on social listening and media monitoring data.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Brand Website Url' ;
    rdfs:comment 'The primary website URL for the competitor brand, used for digital presence monitoring and competitive analysis.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveDifferentiationFactors rdf:type rdf:Property ;
    rdfs:label 'Competitive Differentiation Factors' ;
    rdfs:comment 'Comma-separated list of key factors that differentiate this competitor brand from others in the category (e.g., price leadership, innovation, customer service, sustainability).' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveThreatLevel rdf:type rdf:Property ;
    rdfs:label 'Competitive Threat Level' ;
    rdfs:comment 'Assessment of the competitive threat level this brand poses to the agency\'s clients based on market overlap, Share of Voice (SOV), and strategic positioning.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comscoreEntityCode rdf:type rdf:Property ;
    rdfs:label 'Comscore Entity Code' ;
    rdfs:comment 'The unique entity identifier assigned by Comscore for tracking digital audience measurement and cross-platform analytics for the competitor brand.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystems rdf:type rdf:Property ;
    rdfs:label 'Data Source Systems' ;
    rdfs:comment 'Comma-separated list of source systems providing competitive intelligence data for this brand (e.g., Nielsen Ad Intel, Comscore, social listening platforms, manual research).' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualAdSpendTier rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Ad Spend Tier' ;
    rdfs:comment 'Estimated tier classification of the competitor brand\'s annual advertising spend based on competitive intelligence and media monitoring data.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBrandAwarenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Estimated Brand Awareness Percentage' ;
    rdfs:comment 'Estimated percentage of target audience with aided or unaided brand awareness, derived from competitive benchmarking studies and market research.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyMessagingThemes rdf:type rdf:Property ;
    rdfs:label 'Key Messaging Themes' ;
    rdfs:comment 'Comma-separated list of key messaging themes and value propositions consistently used by the competitor brand in their advertising and communications.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownAgencyRelationships rdf:type rdf:Property ;
    rdfs:label 'Known Agency Relationships' ;
    rdfs:comment 'Comma-separated list of known advertising agencies, media buying agencies, or creative agencies that the competitor brand works with, based on public announcements and competitive intelligence.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastIntelligenceUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Intelligence Update Date' ;
    rdfs:comment 'The date when competitive intelligence data for this brand was last updated from Nielsen Ad Intel, Comscore, or other monitoring sources.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaMixStrategy rdf:type rdf:Property ;
    rdfs:label 'Media Mix Strategy' ;
    rdfs:comment 'Observed media mix strategy employed by the competitor brand, describing the allocation approach across traditional, digital, and emerging media channels.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStartDate rdf:type rdf:Property ;
    rdfs:label 'Monitoring Start Date' ;
    rdfs:comment 'The date when competitive monitoring for this brand was initiated in the agency\'s intelligence program.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Status' ;
    rdfs:comment 'Current status of competitive monitoring for this brand in the agency\'s intelligence program.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenAdIntelCompetitorCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Ad Intel Competitor Code' ;
    rdfs:comment 'The unique competitor identifier assigned by Nielsen Ad Intel for tracking competitive advertising activity, Gross Rating Points (GRP), and Share of Voice (SOV).' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsBenchmarkScore rdf:type rdf:Property ;
    rdfs:label 'Nps Benchmark Score' ;
    rdfs:comment 'Net Promoter Score (NPS) benchmark for the competitor brand, ranging from -100 to +100, used for brand health comparison and competitive positioning analysis.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMarkets rdf:type rdf:Property ;
    rdfs:label 'Primary Markets' ;
    rdfs:comment 'Comma-separated list of primary geographic markets where the competitor brand has significant presence and advertising activity.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMediaChannels rdf:type rdf:Property ;
    rdfs:label 'Primary Media Channels' ;
    rdfs:comment 'Comma-separated list of primary media channels used by the competitor brand (e.g., television, digital display, social media, search, Out-of-Home (OOH), Connected TV (CTV), radio).' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'The primary product or service category that the competitor brand represents within their industry vertical.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recentCampaignThemes rdf:type rdf:Property ;
    rdfs:label 'Recent Campaign Themes' ;
    rdfs:comment 'Comma-separated list of recent major campaign themes or creative concepts launched by the competitor brand in the past 12 months.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandles rdf:type rdf:Property ;
    rdfs:label 'Social Media Handles' ;
    rdfs:comment 'Comma-separated list of primary social media handles for the competitor brand across major platforms (e.g., @brand on Twitter, @brand on Instagram).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSegments rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segments' ;
    rdfs:comment 'Comma-separated list of primary target audience segments the competitor brand focuses on based on demographic, psychographic, and behavioral analysis.' ;
    rdfs:domain ind:CompetitiveBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaCoverageId rdf:type rdf:Property ;
    rdfs:label 'Media Coverage Id' ;
    rdfs:comment 'Unique identifier for the earned media coverage record. Primary key.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSpokespersonId rdf:type rdf:Property ;
    rdfs:label 'Brand Spokesperson Id' ;
    rdfs:comment 'Foreign key linking to brand.spokesperson. Business justification: Media coverage features specific authorized spokespersons. Currently spokesperson_featured is STRING - converting to FK enables validation that featured spokespersons are approved, and allows joining ' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandSpokesperson .

ind:publisherId rdf:type rdf:Property ;
    rdfs:label 'Publisher Id' ;
    rdfs:comment 'Foreign key linking to vendor.publisher. Business justification: Media coverage records track which publisher/outlet published the story. Core PR measurement process for earned media value calculation, share of voice analysis, and outlet tier performance reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Publisher .

ind:articleWordCount rdf:type rdf:Property ;
    rdfs:label 'Article Word Count' ;
    rdfs:comment 'Total word count of the article or transcript. For broadcast, this represents the transcript word count.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aveAmount rdf:type rdf:Property ;
    rdfs:label 'Ave Amount' ;
    rdfs:comment 'Estimated monetary value of the earned media coverage if it had been purchased as advertising space or airtime. Calculated based on outlet advertising rates and coverage size/duration.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aveCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Ave Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the AVE amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandMentionCount rdf:type rdf:Property ;
    rdfs:label 'Brand Mention Count' ;
    rdfs:comment 'Number of times the client brand name or product is mentioned in the coverage content.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circulationCount rdf:type rdf:Property ;
    rdfs:label 'Circulation Count' ;
    rdfs:comment 'For print media, the verified circulation count of the publication. For broadcast, the average viewership or listenership. For digital, the monthly unique visitors.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitiveMentionFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Mention Flag' ;
    rdfs:comment 'Boolean flag indicating whether competitor brands were mentioned in the same coverage. True if competitors are mentioned, False if only client brand is featured.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Date' ;
    rdfs:comment 'The date the media coverage was published or aired. This is the principal business event timestamp for earned media tracking.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageProminence rdf:type rdf:Property ;
    rdfs:label 'Coverage Prominence' ;
    rdfs:comment 'Placement prominence of the coverage within the outlet. Front page/homepage indicates top-tier placement, section front indicates category lead placement, inside page/standard indicates regular placement, featured indicates highlighted or promoted content.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Coverage Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for this media coverage record, used for tracking and reporting.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current lifecycle status of the media coverage record. Published indicates live coverage, scheduled indicates confirmed future coverage, cancelled indicates coverage that did not run, retracted indicates coverage that was removed post-publication, updated indicates coverage that was modified after initial publication.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Coverage Timestamp' ;
    rdfs:comment 'Precise date and time the media coverage was published or aired, including timezone information for broadcast segments.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coverageType rdf:type rdf:Property ;
    rdfs:label 'Coverage Type' ;
    rdfs:comment 'The medium through which the coverage was delivered. Print includes newspapers and magazines, online includes digital publications and blogs, broadcast includes TV and radio, podcast includes audio streaming platforms, social media includes influencer and brand social posts, wire service includes AP, Reuters, and other syndication services.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageUrl rdf:type rdf:Property ;
    rdfs:label 'Coverage Url' ;
    rdfs:comment 'Direct URL link to the online article, broadcast clip, or podcast episode. Null for print-only coverage.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the user who created this media coverage record.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domainAuthorityScore rdf:type rdf:Property ;
    rdfs:label 'Domain Authority Score' ;
    rdfs:comment 'For digital outlets, the domain authority score (0-100) indicating the SEO strength and credibility of the publishing website. Higher scores indicate more authoritative domains.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Primary geographic market or region where the coverage was distributed (e.g., National, New York DMA, United Kingdom, EMEA).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headline rdf:type rdf:Property ;
    rdfs:label 'Headline' ;
    rdfs:comment 'The headline, title, or subject line of the media coverage. For broadcast segments, this is the segment title or topic description.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalistName rdf:type rdf:Property ;
    rdfs:label 'Journalist Name' ;
    rdfs:comment 'Name of the journalist, reporter, editor, or content creator who authored or produced the coverage.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyMessageAlignmentScore rdf:type rdf:Property ;
    rdfs:label 'Key Message Alignment Score' ;
    rdfs:comment 'Percentage score (0-100) indicating how well the coverage aligns with the client\'s key messaging framework and campaign objectives. Higher scores indicate stronger message alignment.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this media coverage record.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringSource rdf:type rdf:Property ;
    rdfs:label 'Monitoring Source' ;
    rdfs:comment 'Name of the media monitoring service or tool that captured this coverage record (e.g., Nielsen Ad Intel, Meltwater, Cision, Manual Entry).' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outletTier rdf:type rdf:Property ;
    rdfs:label 'Outlet Tier' ;
    rdfs:comment 'Classification of the media outlet based on reach and influence. Tier 1 represents top-tier national/international outlets, Tier 2 represents major regional outlets, Tier 3 represents smaller regional outlets, niche represents specialized industry publications, local represents local community outlets, regional represents multi-market regional outlets.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageAuthorityScore rdf:type rdf:Property ;
    rdfs:label 'Page Authority Score' ;
    rdfs:comment 'For digital coverage, the page authority score (0-100) of the specific article or page where the coverage appears, indicating its ranking potential.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Segment Duration Seconds' ;
    rdfs:comment 'For broadcast and podcast coverage, the duration of the segment in seconds. Null for print and online text coverage.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shareOfVoiceContribution rdf:type rdf:Property ;
    rdfs:label 'Share Of Voice Contribution' ;
    rdfs:comment 'Percentage contribution of this coverage to the overall brand Share of Voice in the competitive media landscape during the measurement period.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyValidationFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Validation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this coverage record has been validated by a third-party media monitoring service (e.g., Nielsen Ad Intel, Comscore). True if validated, False if internally tracked only.' ;
    rdfs:domain ind:MediaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaDistributionSupplierId rdf:type rdf:Property ;
    rdfs:label 'Media Distribution Supplier Id' ;
    rdfs:comment 'Foreign key linking to vendor.supplier. Business justification: PR campaigns contract with media distribution and monitoring suppliers (wire services, monitoring platforms). Core PR vendor management process for tracking distribution partners and earned media meas' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:actualEarnedMediaValue rdf:type rdf:Property ;
    rdfs:label 'Actual Earned Media Value' ;
    rdfs:comment 'The actual earned media value (EMV) achieved by the PR campaign, representing the estimated advertising equivalency value of PR coverage generated. Expressed in the organization\'s reporting currency.' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMediaImpressions rdf:type rdf:Property ;
    rdfs:label 'Actual Media Impressions' ;
    rdfs:comment 'The actual number of media impressions or reach achieved by the PR campaign across all earned media placements. Populated upon campaign completion or during active tracking.' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocation rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation' ;
    rdfs:comment 'The total budget amount allocated to this PR campaign for all activities, resources, and expenses. Expressed in the organization\'s reporting currency.' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the PR campaign for external reference and tracking across systems.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'The official name or title of the PR campaign used for identification and reporting purposes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisFlag rdf:type rdf:Property ;
    rdfs:label 'Crisis Flag' ;
    rdfs:comment 'Boolean indicator whether this PR campaign is related to crisis management or reputation protection activities. True indicates crisis-related campaign.' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earnedMediaValueTarget rdf:type rdf:Property ;
    rdfs:label 'Earned Media Value Target' ;
    rdfs:comment 'The target earned media value (EMV) representing the estimated advertising equivalency value of PR coverage this campaign aims to generate. Expressed in the organization\'s reporting currency.' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The planned or actual end date when the PR campaign activities conclude. Format: yyyy-MM-dd. Nullable for ongoing campaigns.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keyMessagesReference rdf:type rdf:Property ;
    rdfs:label 'Key Messages Reference' ;
    rdfs:comment 'Reference identifier or location pointer to the approved key messaging framework and talking points document for this PR campaign.' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaKitReference rdf:type rdf:Property ;
    rdfs:label 'Media Kit Reference' ;
    rdfs:comment 'Reference identifier or location pointer to the media kit or press materials package associated with this PR campaign, typically stored in the Digital Asset Management (DAM) system.' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaPlacementsCount rdf:type rdf:Property ;
    rdfs:label 'Media Placements Count' ;
    rdfs:comment 'The total number of earned media placements (articles, mentions, features) secured by this PR campaign.' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objectiveType rdf:type rdf:Property ;
    rdfs:label 'Objective Type' ;
    rdfs:comment 'The primary strategic objective or purpose of the PR campaign. Valid values: product-launch (new product introduction), crisis-management (reputation protection), brand-awareness (visibility building), thought-leadership (industry positioning), event-pr (event promotion), csr (corporate social responsibility).' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prCampaignStatus rdf:type rdf:Property ;
    rdfs:label 'Pr Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the PR campaign. Valid values: planning (in development), active (currently running), completed (finished), on-hold (temporarily paused), cancelled (terminated before completion).' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressReleaseCount rdf:type rdf:Property ;
    rdfs:label 'Press Release Count' ;
    rdfs:comment 'The total number of press releases issued as part of this PR campaign.' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Channel' ;
    rdfs:comment 'The primary channel or medium through which this PR campaign is executed. Valid values: traditional-media (print/broadcast), digital-media (online news), social-media (social platforms), influencer (influencer partnerships), events (press events/conferences), mixed (multi-channel approach).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The official start date when the PR campaign activities begin. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Detailed description of the intended audience or public segment this PR campaign aims to reach, including demographic and psychographic characteristics.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMediaImpressions rdf:type rdf:Property ;
    rdfs:label 'Target Media Impressions' ;
    rdfs:comment 'The target number of media impressions or reach the PR campaign aims to achieve across all earned media placements.' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetMediaTier rdf:type rdf:Property ;
    rdfs:label 'Target Media Tier' ;
    rdfs:comment 'The tier or category of media outlets targeted by this PR campaign. Valid values: tier-1 (top national/international outlets), tier-2 (regional/secondary outlets), trade (industry-specific publications), digital (online-only media), broadcast (TV/radio), print (newspapers/magazines).' ;
    rdfs:domain ind:PrCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Username or identifier of the system user who created this PR campaign record.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressReleaseId rdf:type rdf:Property ;
    rdfs:label 'Press Release Id' ;
    rdfs:comment 'Unique identifier for the press release record. Primary key.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boilerplateText rdf:type rdf:Property ;
    rdfs:label 'Boilerplate Text' ;
    rdfs:comment 'Standard company or brand description paragraph included at the end of the press release.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Date' ;
    rdfs:comment 'Date and time when the press release was distributed to wire services and media contacts.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionGeography rdf:type rdf:Property ;
    rdfs:label 'Distribution Geography' ;
    rdfs:comment 'Geographic regions or markets targeted for press release distribution (e.g., USA, CAN, GBR, global).' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the final published press release document stored in the Digital Asset Management (DAM) system.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftVersion rdf:type rdf:Property ;
    rdfs:label 'Draft Version' ;
    rdfs:comment 'Version number of the press release draft, incremented with each revision.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:embargoDate rdf:type rdf:Property ;
    rdfs:label 'Embargo Date' ;
    rdfs:comment 'Date and time before which the press release must not be published by media outlets. Null if no embargo applies.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:keyMessages rdf:type rdf:Property ;
    rdfs:label 'Key Messages' ;
    rdfs:comment 'Summary of the primary messaging themes and talking points covered in the press release.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaContactEmail rdf:type rdf:Property ;
    rdfs:label 'Media Contact Email' ;
    rdfs:comment 'Email address of the public relations contact person for media inquiries.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaContactName rdf:type rdf:Property ;
    rdfs:label 'Media Contact Name' ;
    rdfs:comment 'Name of the public relations contact person listed on the press release for media inquiries.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaContactPhone rdf:type rdf:Property ;
    rdfs:label 'Media Contact Phone' ;
    rdfs:comment 'Phone number of the public relations contact person for media inquiries.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupCount rdf:type rdf:Property ;
    rdfs:label 'Pickup Count' ;
    rdfs:comment 'Number of media outlets, publications, or websites that picked up and published the press release after distribution.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseType rdf:type rdf:Property ;
    rdfs:label 'Release Type' ;
    rdfs:comment 'Category of press release indicating the nature of the announcement (product launch, financial results, partnership, crisis response, award, CSR, executive appointment). [ENUM-REF-CANDIDATE: product_launch|financial_results|partnership|crisis_response|award|csr|executive_appointment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovImpact rdf:type rdf:Property ;
    rdfs:label 'Sov Impact' ;
    rdfs:comment 'Measured impact of the press release on the brand\'s Share of Voice (SOV) in competitive media landscape, expressed as percentage point change.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWireService rdf:type rdf:Property ;
    rdfs:label 'Target Wire Service' ;
    rdfs:comment 'Primary wire service used for press release distribution (PR Newswire, Business Wire, GlobeNewswire, other).' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wordCount rdf:type rdf:Property ;
    rdfs:label 'Word Count' ;
    rdfs:comment 'Total number of words in the press release body text.' ;
    rdfs:domain ind:PressRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shareOfVoiceId rdf:type rdf:Property ;
    rdfs:label 'Share Of Voice Id' ;
    rdfs:comment 'Primary key for share_of_voice' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandImpressionCount rdf:type rdf:Property ;
    rdfs:label 'Brand Impression Count' ;
    rdfs:comment 'Total number of advertising impressions delivered by the client brand during the measurement period. Used as an alternative numerator for share of voice calculations when impression data is available.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSovPercentage rdf:type rdf:Property ;
    rdfs:label 'Brand Sov Percentage' ;
    rdfs:comment 'Percentage of total category voice captured by the client brand during the measurement period. Calculated as brand impressions or spend divided by total category impressions or spend, expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandSpendEstimate rdf:type rdf:Property ;
    rdfs:label 'Brand Spend Estimate' ;
    rdfs:comment 'Estimated advertising spend by the client brand during the measurement period. Sourced from Nielsen Ad Intel competitive monitoring. Used as the numerator for share of voice calculations.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveRank rdf:type rdf:Property ;
    rdfs:label 'Competitive Rank' ;
    rdfs:comment 'Rank of the client brand within the product category based on share of voice during the measurement period. Rank 1 indicates the highest share of voice in the category. Supports competitive positioning analysis.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorImpressionCount rdf:type rdf:Property ;
    rdfs:label 'Competitor Impression Count' ;
    rdfs:comment 'Total number of advertising impressions delivered by the competitor brand during the measurement period. Used for competitive impression share analysis.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorSovPercentage rdf:type rdf:Property ;
    rdfs:label 'Competitor Sov Percentage' ;
    rdfs:comment 'Percentage of total category voice captured by the competitor brand during the measurement period. Calculated as competitor impressions or spend divided by total category impressions or spend, expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceReference rdf:type rdf:Property ;
    rdfs:label 'Data Source Reference' ;
    rdfs:comment 'Reference identifier or citation for the source of the share of voice data. Typically references Nielsen Ad Intel competitive monitoring module, report ID, or data extract identifier. Supports data lineage and audit requirements.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the competitive intelligence system or platform that provided the share of voice data. Primary source is Nielsen Ad Intel; may include other competitive monitoring platforms.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketGeography rdf:type rdf:Property ;
    rdfs:label 'Market Geography' ;
    rdfs:comment 'Geographic market or region where the share of voice is being measured. Can be country, state, DMA (Designated Market Area), metro area, or custom geographic segment.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketGeographyCode rdf:type rdf:Property ;
    rdfs:label 'Market Geography Code' ;
    rdfs:comment 'Standardized code for the geographic market (e.g., ISO country code, DMA code, Nielsen market code). Enables consistent geographic aggregation and comparison.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'End date of the measurement period for this share of voice tracking record. Supports weekly, monthly, or custom period analysis.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'Start date of the measurement period for this share of voice tracking record. Supports weekly, monthly, or custom period analysis.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'Type of measurement period for the share of voice tracking. Indicates whether the period is weekly, monthly, quarterly, or a custom date range.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaChannel rdf:type rdf:Property ;
    rdfs:label 'Media Channel' ;
    rdfs:comment 'Media channel or platform where the share of voice is being measured. Includes traditional and digital channels such as TV, radio, print, digital display, social media, out-of-home, connected TV, over-the-top, search, and native advertising. [ENUM-REF-CANDIDATE: tv|radio|print|digital|social|ooh|dooh|ctv|ott|search|display|video|audio|native — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSubcategory rdf:type rdf:Property ;
    rdfs:label 'Product Subcategory' ;
    rdfs:comment 'Subcategory within the product category for more granular competitive analysis (e.g., within automotive: sedans, SUVs, electric vehicles). Enables detailed competitive positioning analysis.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovIndexVsCategoryAverage rdf:type rdf:Property ;
    rdfs:label 'Sov Index Vs Category Average' ;
    rdfs:comment 'Index comparing the brand\'s share of voice to the category average, where 100.00 represents parity with the average. Values above 100 indicate above-average share of voice; values below 100 indicate below-average share of voice. Calculated as (brand SOV / category average SOV) * 100.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCategoryImpressionCount rdf:type rdf:Property ;
    rdfs:label 'Total Category Impression Count' ;
    rdfs:comment 'Total number of advertising impressions delivered across all brands in the product category during the measurement period. Used as the denominator for impression-based share of voice calculations.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCategorySpendEstimate rdf:type rdf:Property ;
    rdfs:label 'Total Category Spend Estimate' ;
    rdfs:comment 'Estimated total advertising spend across all brands in the product category during the measurement period. Sourced from Nielsen Ad Intel competitive monitoring. Used as the denominator for share of voice calculations.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCompetitorsTracked rdf:type rdf:Property ;
    rdfs:label 'Total Competitors Tracked' ;
    rdfs:comment 'Total number of competitor brands tracked in the product category during the measurement period. Provides context for the competitive rank and share of voice analysis.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackingStatus rdf:type rdf:Property ;
    rdfs:label 'Tracking Status' ;
    rdfs:comment 'Current status of the share of voice tracking record. Active indicates ongoing monitoring; completed indicates the measurement period has ended and data is finalized; pending indicates data collection in progress; cancelled indicates tracking was discontinued; under_review indicates data quality validation in progress.' ;
    rdfs:domain ind:ShareOfVoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentAgencySupplierId rdf:type rdf:Property ;
    rdfs:label 'Talent Agency Supplier Id' ;
    rdfs:comment 'Foreign key linking to vendor.supplier. Business justification: Spokespersons contracted through talent agencies (supplier type: talent/casting agency). Real business process: spokesperson vendor management, contract negotiation, and talent agency relationship tra' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'Date when the spokesperson authorization expires and requires renewal. Null for indefinite authorizations.' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedTopics rdf:type rdf:Property ;
    rdfs:label 'Approved Topics' ;
    rdfs:comment 'Comma-separated list of topics and subject areas the spokesperson is authorized to discuss in media and public communications (e.g., product innovation, sustainability, financial performance, industry trends).' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of background verification and reputational screening: completed (passed all checks), pending (in progress), not_required (waived for this spokesperson type), or failed (did not pass screening).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biography rdf:type rdf:Property ;
    rdfs:label 'Biography' ;
    rdfs:comment 'Official biography or background summary of the spokesperson for use in press releases, media kits, and public communications.' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Type of compensation arrangement for the spokesperson: salaried (regular employee), per_appearance (paid per engagement), retainer (ongoing fee), equity (stock/ownership), pro_bono (reduced fee), or volunteer (unpaid).' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictOfInterestCheckDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Check Date' ;
    rdfs:comment 'Date when the most recent conflict of interest screening was performed to ensure the spokesperson has no competing brand affiliations or reputational risks.' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crisisContactName rdf:type rdf:Property ;
    rdfs:label 'Crisis Contact Name' ;
    rdfs:comment 'Name of the primary contact person (e.g., publicist, agent, manager) to reach in case of crisis or urgent media situation involving the spokesperson.' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisisContactPhone rdf:type rdf:Property ;
    rdfs:label 'Crisis Contact Phone' ;
    rdfs:comment 'Emergency phone number for the crisis contact person to reach in urgent situations.' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for contacting the spokesperson.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headshotUrl rdf:type rdf:Property ;
    rdfs:label 'Headshot Url' ;
    rdfs:comment 'URL or Digital Asset Management (DAM) reference to the spokesperson\'s official headshot photograph for media use.' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Media Training Date' ;
    rdfs:comment 'Date when the spokesperson completed their most recent media training session.' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaTrainingStatus rdf:type rdf:Property ;
    rdfs:label 'Media Training Status' ;
    rdfs:comment 'Current status of the spokesperson\'s media training certification: completed (training finished and current), in_progress (currently undergoing training), not_started (no training yet), or expired (training certification has lapsed).' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organization rdf:type rdf:Property ;
    rdfs:label 'Organization' ;
    rdfs:comment 'Organization or company the spokesperson is affiliated with.' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the spokesperson.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedTopics rdf:type rdf:Property ;
    rdfs:label 'Restricted Topics' ;
    rdfs:comment 'Comma-separated list of topics and subject areas the spokesperson is NOT authorized to discuss or must avoid in media and public communications (e.g., pending litigation, confidential product launches, competitor strategies).' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spokespersonName rdf:type rdf:Property ;
    rdfs:label 'Spokesperson Name' ;
    rdfs:comment 'Full legal name of the individual authorized to represent the brand.' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spokespersonType rdf:type rdf:Property ;
    rdfs:label 'Spokesperson Type' ;
    rdfs:comment 'Classification of the spokesperson role: executive (company leadership), celebrity (public figure), influencer (social media personality), subject matter expert (industry specialist), brand ambassador (contracted representative), or employee (staff member).' ;
    rdfs:domain ind:BrandSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemId rdf:type rdf:Property ;
    rdfs:label 'Line Item Id' ;
    rdfs:comment 'Reference to the parent campaign line item under which this ad is trafficked.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LineItem .

ind:traffickingOrderId rdf:type rdf:Property ;
    rdfs:label 'Trafficking Order Id' ;
    rdfs:comment 'Foreign key linking to campaign.trafficking_order. Business justification: Ads are trafficked to ad servers via trafficking orders. Currently no FK exists to track which trafficking order activated a specific ad. This is essential for operational tracking (when was this ad t' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TraffickingOrder .

ind:adName rdf:type rdf:Property ;
    rdfs:label 'Ad Name' ;
    rdfs:comment 'Human-readable name assigned to this ad unit for identification and reporting purposes.' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adStatus rdf:type rdf:Property ;
    rdfs:label 'Ad Status' ;
    rdfs:comment 'Current lifecycle status of the ad unit. Governs whether the ad is eligible for serving. [ENUM-REF-CANDIDATE: draft|pending_review|approved|rejected|live|paused|archived|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adType rdf:type rdf:Property ;
    rdfs:label 'Ad Type' ;
    rdfs:comment 'Classification of the ad unit by format type. Determines rendering and trafficking requirements. [ENUM-REF-CANDIDATE: banner|video|native|rich_media|audio|dooh|ctv|display|interstitial — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyVerified rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Verified' ;
    rdfs:comment 'Indicates whether the ad creative has passed brand safety verification checks.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpaOptOutHonored rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Honored' ;
    rdfs:comment 'Indicates whether this ad honors CCPA Do Not Sell requests.' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clickThroughUrl rdf:type rdf:Property ;
    rdfs:label 'Click Through Url' ;
    rdfs:comment 'Destination URL where users are directed when they click on the ad. May include tracking macros.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Dimensions of the ad creative in width x height format (e.g., 300x250, 728x90, 1920x1080). Null for non-display formats.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Required' ;
    rdfs:comment 'Indicates whether user consent is required under GDPR before serving this ad.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Date when the ad becomes eligible to start serving.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impressionTrackerUrl rdf:type rdf:Property ;
    rdfs:label 'Impression Tracker Url' ;
    rdfs:comment 'Third-party tracking pixel or beacon URL fired when the ad impression is served.' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'Final destination landing page URL after click-through, excluding tracking parameters.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Serving priority of this ad relative to other ads in the same line item. Higher values indicate higher priority.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation for why the ad was rejected during review. Null if not rejected.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serverAdCode rdf:type rdf:Property ;
    rdfs:label 'Server Ad Code' ;
    rdfs:comment 'External identifier assigned by the ad server platform (e.g., Google Campaign Manager 360) for this ad unit.' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sslCompliant rdf:type rdf:Property ;
    rdfs:label 'Ssl Compliant' ;
    rdfs:comment 'Indicates whether the ad creative and all tracking tags are served over HTTPS for secure delivery.' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Third Party Tracking Enabled' ;
    rdfs:comment 'Indicates whether third-party tracking pixels and beacons are enabled for this ad.' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:traffickingStatus rdf:type rdf:Property ;
    rdfs:label 'Trafficking Status' ;
    rdfs:comment 'Operational status indicating whether the ad has been trafficked to the ad server and its current serving state.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vastTagUrl rdf:type rdf:Property ;
    rdfs:label 'Vast Tag Url' ;
    rdfs:comment 'VAST or VPAID tag URL for video ad serving. Null for non-video ad types.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewTrackerUrl rdf:type rdf:Property ;
    rdfs:label 'View Tracker Url' ;
    rdfs:comment 'Third-party tracking URL fired when the ad is viewable according to MRC viewability standards.' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vpaidEnabled rdf:type rdf:Property ;
    rdfs:label 'Vpaid Enabled' ;
    rdfs:comment 'Indicates whether the ad uses VPAID for interactive video ad execution.' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Relative weight for rotation when multiple ads are eligible to serve. Used for A/B testing and creative rotation.' ;
    rdfs:domain ind:Ad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Id' ;
    rdfs:comment 'Unique identifier for the budget allocation record. Primary key for this entity.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetAllocation .

ind:flightId rdf:type rdf:Property ;
    rdfs:label 'Flight Id' ;
    rdfs:comment 'Reference to the parent flight within the campaign for which budget is allocated.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Flight .

ind:pacingRuleId rdf:type rdf:Property ;
    rdfs:label 'Pacing Rule Id' ;
    rdfs:comment 'Foreign key linking to campaign.pacing_rule. Business justification: budget_allocation currently has pacing_rule_name (STRING) which is a denormalized reference. Should normalize to FK relationship with pacing_rule.pacing_rule_id. This enables joining to get full pacin' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PacingRule .

ind:actualSpend rdf:type rdf:Property ;
    rdfs:label 'Actual Spend' ;
    rdfs:comment 'The actual amount spent to date against this budget allocation, based on delivered impressions and clicks.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The method used to distribute budget across periods or channels (e.g., percentage-based, fixed amount, dynamic optimization).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationReference rdf:type rdf:Property ;
    rdfs:label 'Allocation Reference' ;
    rdfs:comment 'Business-facing reference number or code for this budget allocation, used for tracking and reconciliation.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'The current lifecycle status of this budget allocation (e.g., draft, active, paused, completed, cancelled).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoOptimizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Optimization Enabled' ;
    rdfs:comment 'Indicates whether automated optimization algorithms are enabled to adjust bids and budgets dynamically based on performance.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetPeriodType rdf:type rdf:Property ;
    rdfs:label 'Budget Period Type' ;
    rdfs:comment 'The time period granularity for which this budget allocation applies (e.g., monthly, weekly, flight-level).' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetSource rdf:type rdf:Property ;
    rdfs:label 'Budget Source' ;
    rdfs:comment 'The origin or authority for this budget allocation (e.g., client-approved, agency-estimated, internal forecast).' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'The advertising channel or media type for which this budget is allocated. CTV (Connected TV), OTT (Over-the-Top), DOOH (Digital Out-of-Home), OOH (Out-of-Home). [ENUM-REF-CANDIDATE: display|video|social|search|audio|native|ctv|ott|dooh|ooh|print|radio|tv — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedSpend rdf:type rdf:Property ;
    rdfs:label 'Committed Spend' ;
    rdfs:comment 'The amount of budget that has been committed through insertion orders or programmatic deals but not yet spent.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyImpressionGoal rdf:type rdf:Property ;
    rdfs:label 'Daily Impression Goal' ;
    rdfs:comment 'The target number of impressions to be delivered per day under the pacing rule.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailySpendCap rdf:type rdf:Property ;
    rdfs:label 'Daily Spend Cap' ;
    rdfs:comment 'The maximum amount that can be spent per day for this allocation, enforced by the pacing rule.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date when this budget allocation was last reconciled against actual spend and delivery data from ad servers and billing systems.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optimizationAlgorithmReference rdf:type rdf:Property ;
    rdfs:label 'Optimization Algorithm Reference' ;
    rdfs:comment 'Reference to the specific optimization algorithm or strategy applied to this allocation (e.g., CPA optimization, ROAS maximization).' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overDeliveryAction rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Action' ;
    rdfs:comment 'The action to take when delivery exceeds the pacing goal or budget cap (e.g., pause campaign, throttle bids, send alert).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overDeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Pct' ;
    rdfs:comment 'The acceptable percentage over-delivery before corrective action is taken (e.g., 5.00 means 5% over-delivery is tolerated).' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pacingAlertThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Pacing Alert Threshold Pct' ;
    rdfs:comment 'The percentage deviation from the pacing goal that triggers an alert to campaign managers (e.g., 10.00 means alert at 10% deviation).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pacingCheckFrequency rdf:type rdf:Property ;
    rdfs:label 'Pacing Check Frequency' ;
    rdfs:comment 'How frequently the pacing engine evaluates delivery performance and adjusts bid strategies (e.g., real-time, hourly, daily).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacingType rdf:type rdf:Property ;
    rdfs:label 'Pacing Type' ;
    rdfs:comment 'The pacing strategy governing how budget and impressions are delivered over time (e.g., even, accelerated, front-loaded, back-loaded, custom curve).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Budget Amount' ;
    rdfs:comment 'The original planned budget amount allocated for this period and channel, as approved in the initial media plan.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'The current status of the budget reconciliation process for this allocation (e.g., pending, reconciled, discrepancy found, approved).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBudget rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget' ;
    rdfs:comment 'The remaining unspent budget available for this allocation, calculated as revised (or planned) budget minus actual spend and committed spend.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Budget Amount' ;
    rdfs:comment 'The revised budget amount after any adjustments, reallocations, or change orders. Null if no revision has occurred.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underDeliveryAction rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Action' ;
    rdfs:comment 'The action to take when delivery falls short of the pacing goal (e.g., boost bids, increase budget allocation, send alert).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Pct' ;
    rdfs:comment 'The acceptable percentage under-delivery before corrective action is taken (e.g., 5.00 means 5% under-delivery is tolerated).' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weeklyImpressionGoal rdf:type rdf:Property ;
    rdfs:label 'Weekly Impression Goal' ;
    rdfs:comment 'The target number of impressions to be delivered per week under the pacing rule.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weeklySpendCap rdf:type rdf:Property ;
    rdfs:label 'Weekly Spend Cap' ;
    rdfs:comment 'The maximum amount that can be spent per week for this allocation, enforced by the pacing rule.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'Attribution model used to credit conversions for the campaign: last click, first click, linear, time decay, position-based, or data-driven.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyLevel rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Level' ;
    rdfs:comment 'Brand safety filtering level applied to the campaign: standard, moderate, strict, or custom. Determines content exclusions.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefReference rdf:type rdf:Property ;
    rdfs:label 'Brief Reference' ;
    rdfs:comment 'Reference identifier or document link to the original campaign brief or statement of work (SOW).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total budget allocated for the campaign. Overall spending ceiling across all channels and placements.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign: draft (planning), approved (ready), active (running), paused (temporarily stopped), completed (finished), or cancelled (terminated).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignTier rdf:type rdf:Property ;
    rdfs:label 'Campaign Tier' ;
    rdfs:comment 'Strategic importance or priority tier of the campaign within the advertisers portfolio.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign based on its strategic objective: brand awareness, direct response, performance, retention, seasonal, or always-on.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Conversion Window Days' ;
    rdfs:comment 'Number of days after an ad interaction during which a conversion can be attributed to the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceTargeting rdf:type rdf:Property ;
    rdfs:label 'Device Targeting' ;
    rdfs:comment 'Device types targeted by the campaign. Comma-separated list such as desktop, mobile, tablet, CTV, OTT.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCapWindow rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Window' ;
    rdfs:comment 'Time window for the frequency cap: per hour, day, week, month, or entire campaign duration.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoTargeting rdf:type rdf:Property ;
    rdfs:label 'Geo Targeting' ;
    rdfs:comment 'Geographic targeting parameters for the campaign. Comma-separated list of countries, regions, cities, or postal codes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabCategory rdf:type rdf:Property ;
    rdfs:label 'Iab Category' ;
    rdfs:comment 'IAB content taxonomy category for the campaign, used for brand safety and contextual targeting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pacing Strategy' ;
    rdfs:comment 'Budget pacing strategy for the campaign: even (spread evenly), ASAP (spend as fast as possible), custom (user-defined), or dayparting (time-of-day based).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryKpis rdf:type rdf:Property ;
    rdfs:label 'Secondary Kpis' ;
    rdfs:comment 'Additional metrics tracked for campaign performance evaluation. Comma-separated list of KPIs.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCpa rdf:type rdf:Property ;
    rdfs:label 'Target Cpa' ;
    rdfs:comment 'Target cost per acquisition or conversion for the campaign. Maximum acceptable cost to acquire one customer or conversion.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCpm rdf:type rdf:Property ;
    rdfs:label 'Target Cpm' ;
    rdfs:comment 'Target cost per thousand impressions for the campaign. Used for brand awareness and reach campaigns.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCtr rdf:type rdf:Property ;
    rdfs:label 'Target Ctr' ;
    rdfs:comment 'Target click-through rate percentage for the campaign. Represents the expected ratio of clicks to impressions.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRoas rdf:type rdf:Property ;
    rdfs:label 'Target Roas' ;
    rdfs:comment 'Target return on ad spend ratio for the campaign. Represents revenue generated per dollar spent on advertising.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewabilityStandard rdf:type rdf:Property ;
    rdfs:label 'Viewability Standard' ;
    rdfs:comment 'Viewability measurement standard applied to the campaign: MRC (Media Rating Council), GroupM, or custom threshold.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalId rdf:type rdf:Property ;
    rdfs:label 'Approval Id' ;
    rdfs:comment 'Unique identifier for the campaign approval record. Primary key.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Approval .

ind:approvalAssignedReviewerUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Approval Assigned Reviewer User Worker Id' ;
    rdfs:comment 'Identifier of the user assigned to review and decide on the approval request.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:approvalCreatedByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Approval Created By User Worker Id' ;
    rdfs:comment 'Identifier of the system user who created this approval record.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:approvalEscalatedToUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Approval Escalated To User Worker Id' ;
    rdfs:comment 'Identifier of the higher-authority user to whom the approval was escalated. Populated only when escalation_flag is True.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:approvalModifiedByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Approval Modified By User Worker Id' ;
    rdfs:comment 'Identifier of the system user who last modified this approval record.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:approvalWorkerId rdf:type rdf:Property ;
    rdfs:label 'Approval Worker Id' ;
    rdfs:comment 'Identifier of the user who initiated the approval request.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:campaignBriefId rdf:type rdf:Property ;
    rdfs:label 'Campaign Brief Id' ;
    rdfs:comment 'Foreign key linking to campaign.campaign_brief. Business justification: Campaign briefs require client approval before campaign execution (campaign_brief has approved_by_client_flag, client_approval_date, client_approver_name). approval.parent_entity_type can include camp' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignBrief .

ind:amountThreshold rdf:type rdf:Property ;
    rdfs:label 'Amount Threshold' ;
    rdfs:comment 'The monetary threshold (in campaign currency) that triggered this approval requirement. Used for budget change and IO execution approvals.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'The category of approval being requested: campaign launch, budget change, creative approval, IO (Insertion Order) execution, media plan sign-off, or compliance review.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedReviewerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Reviewer Name' ;
    rdfs:comment 'Full name of the user assigned to review the approval request.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityLevel rdf:type rdf:Property ;
    rdfs:label 'Authority Level' ;
    rdfs:comment 'The organizational authority tier required for this approval (e.g., Manager, Director, VP, C-Level, Board).' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'The regulatory or industry compliance framework governing this approval (e.g., GDPR, CCPA, IAB Standards, FTC Guidelines, Brand Safety Standards). Populated primarily for compliance_review approval types.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'The date and time when the reviewer made their approval or rejection decision.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionNotes rdf:type rdf:Property ;
    rdfs:label 'Decision Notes' ;
    rdfs:comment 'Free-text comments or rationale provided by the reviewer explaining their approval or rejection decision.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or URI to supporting documentation attached to the approval request (e.g., revised media plan, updated creative brief, budget justification memo).' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToName rdf:type rdf:Property ;
    rdfs:label 'Escalated To Name' ;
    rdfs:comment 'Full name of the higher-authority user to whom the approval was escalated.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date and time when the approval request was escalated to a higher authority.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this approval request has been escalated to a higher authority for resolution.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Free-text explanation of why the approval was escalated (e.g., exceeds reviewer authority threshold, conflicting stakeholder input, regulatory concern).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date and time when the approval decision notification was sent.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether notification of the approval decision has been sent to relevant stakeholders.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentEntityType rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Type' ;
    rdfs:comment 'The type of entity that this approval is associated with (e.g., campaign, media plan, insertion order, creative asset, budget revision, compliance check).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for rejection (e.g., budget_exceeded, creative_noncompliant, missing_documentation, brand_safety_concern). Populated only when approval_status is rejected.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedByName rdf:type rdf:Property ;
    rdfs:label 'Requested By Name' ;
    rdfs:comment 'Full name of the user who initiated the approval request.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'The date and time when the approval request was submitted.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerRole rdf:type rdf:Property ;
    rdfs:label 'Reviewer Role' ;
    rdfs:comment 'The organizational role or title of the assigned reviewer (e.g., Account Director, Finance Manager, Compliance Officer, Creative Director).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'The sequential order of this approval step within a multi-stage approval workflow (e.g., 1 for first approval, 2 for second approval).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'The target date and time by which the approval decision must be completed per organizational SLA (Service Level Agreement) policies.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalApprovalStages rdf:type rdf:Property ;
    rdfs:label 'Total Approval Stages' ;
    rdfs:comment 'The total number of approval stages required for this parent entity to be fully authorized.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The date and time when the approval request was withdrawn.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorWorkerId rdf:type rdf:Property ;
    rdfs:label 'Author Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Campaign briefs are authored documents requiring clear ownership for version control, approval routing, and accountability in agency workflows. Agency_lead_name exists but is denormalized text; proper' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:agencyLeadEmail rdf:type rdf:Property ;
    rdfs:label 'Agency Lead Email' ;
    rdfs:comment 'Email address of the agency lead responsible for this campaign brief.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyLeadName rdf:type rdf:Property ;
    rdfs:label 'Agency Lead Name' ;
    rdfs:comment 'Full name of the agency account lead or strategist responsible for this campaign brief.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByClientFlag rdf:type rdf:Property ;
    rdfs:label 'Approved By Client Flag' ;
    rdfs:comment 'Indicates whether the client has formally approved this brief version (True) or not (False).' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:briefNumber rdf:type rdf:Property ;
    rdfs:label 'Brief Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the campaign brief, used in client communications and internal tracking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefStatus rdf:type rdf:Property ;
    rdfs:label 'Brief Status' ;
    rdfs:comment 'Current lifecycle status of the campaign brief indicating its approval and usage state.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetEnvelopeAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Envelope Amount' ;
    rdfs:comment 'Total budget allocation or spending cap approved for the campaign as specified in the brief.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelPreferences rdf:type rdf:Property ;
    rdfs:label 'Channel Preferences' ;
    rdfs:comment 'Preferred or mandated media channels and platforms for campaign execution (e.g., digital, TV, OOH, social, CTV).' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientApproverName rdf:type rdf:Property ;
    rdfs:label 'Client Approver Name' ;
    rdfs:comment 'Full name of the client representative who provided formal approval for this brief.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveContext rdf:type rdf:Property ;
    rdfs:label 'Competitive Context' ;
    rdfs:comment 'Analysis of the competitive landscape, including key competitors, their messaging, and market positioning relevant to this campaign.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeFormatRequirements rdf:type rdf:Property ;
    rdfs:label 'Creative Format Requirements' ;
    rdfs:comment 'Specification of required creative formats and deliverables (e.g., video lengths, display ad sizes, social media formats).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedDate rdf:type rdf:Property ;
    rdfs:label 'Issued Date' ;
    rdfs:comment 'Date on which the campaign brief was formally issued to the agency team for execution.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keyMessage rdf:type rdf:Property ;
    rdfs:label 'Key Message' ;
    rdfs:comment 'Primary message or value proposition that the campaign must communicate to the target audience.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRequirements rdf:type rdf:Property ;
    rdfs:label 'Language Requirements' ;
    rdfs:comment 'Languages in which campaign creative and messaging must be produced and delivered.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryExclusions rdf:type rdf:Property ;
    rdfs:label 'Mandatory Exclusions' ;
    rdfs:comment 'List of prohibited elements, themes, imagery, or messaging that must not appear in campaign creative due to brand, legal, or ethical constraints.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryInclusions rdf:type rdf:Property ;
    rdfs:label 'Mandatory Inclusions' ;
    rdfs:comment 'List of required elements, messages, disclaimers, logos, or legal copy that must appear in all campaign creative.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Special regulatory, legal, or compliance considerations that must be observed in campaign execution (e.g., GDPR, CCPA, industry-specific advertising restrictions).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionHistoryReference rdf:type rdf:Property ;
    rdfs:label 'Revision History Reference' ;
    rdfs:comment 'Reference identifier or pointer to the detailed revision history log for this brief, tracking all changes across versions.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCriteria rdf:type rdf:Property ;
    rdfs:label 'Success Criteria' ;
    rdfs:comment 'Narrative description of the qualitative and quantitative metrics that will define campaign success (e.g., brand lift, engagement rate, conversion targets).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineEndDate rdf:type rdf:Property ;
    rdfs:label 'Timeline End Date' ;
    rdfs:comment 'Target date by which the campaign must be fully executed and delivered as specified in the brief.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timelineStartDate rdf:type rdf:Property ;
    rdfs:label 'Timeline Start Date' ;
    rdfs:comment 'Earliest date by which campaign planning and creative development must commence as specified in the brief.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignKpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Campaign Kpi Target Id' ;
    rdfs:comment 'Unique identifier for the campaign KPI target record. Primary key for this entity.' ;
    rdfs:domain ind:CampaignKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAudienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment Id' ;
    rdfs:comment 'Foreign key linking to audience.segment. Business justification: KPI targets are frequently set for specific audience segments (e.g., \'achieve 8% conversion rate among in-market auto intenders segment\'). Performance reporting and optimization decisions require meas' ;
    rdfs:domain ind:CampaignKpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:alertThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Percentage' ;
    rdfs:comment 'The percentage deviation from target that triggers a performance alert. Used for automated monitoring and optimization workflows.' ;
    rdfs:domain ind:CampaignKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The baseline or minimum acceptable value for this KPI. Used to establish performance thresholds below which the campaign is considered underperforming.' ;
    rdfs:domain ind:CampaignKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source' ;
    rdfs:comment 'The source of industry benchmark data used to establish this target (e.g., Nielsen norms, IAB benchmarks, historical campaign data).' ;
    rdfs:domain ind:CampaignKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryKpi rdf:type rdf:Property ;
    rdfs:label 'Is Primary Kpi' ;
    rdfs:comment 'Indicates whether this is the primary KPI for the parent entity. True if this is the main success metric; false for secondary or supporting KPIs.' ;
    rdfs:domain ind:CampaignKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiType rdf:type rdf:Property ;
    rdfs:label 'Kpi Type' ;
    rdfs:comment 'The specific KPI metric being targeted. [ENUM-REF-CANDIDATE: impressions|clicks|ctr|conversions|cpa|cpm|cpc|roas|vtr|grp|trp|sov|reach|frequency|nps|viewability|completion_rate|engagement_rate — promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'The system or platform that will provide the actual measurement data for this KPI. Determines the source of truth for performance reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationPriority rdf:type rdf:Property ;
    rdfs:label 'Optimization Priority' ;
    rdfs:comment 'The priority level for optimization efforts when this KPI is underperforming. Guides resource allocation for campaign management.' ;
    rdfs:domain ind:CampaignKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Business justification for the most recent revision to this KPI target. Captures why the target was changed mid-campaign.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchTargetValue rdf:type rdf:Property ;
    rdfs:label 'Stretch Target Value' ;
    rdfs:comment 'The aspirational or stretch goal value for this KPI. Represents exceptional performance beyond the standard target.' ;
    rdfs:domain ind:CampaignKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'The specific audience segment for which this KPI target applies. Allows for segment-specific performance targets within a single campaign.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPeriod rdf:type rdf:Property ;
    rdfs:label 'Target Period' ;
    rdfs:comment 'The time period over which the target should be achieved. \'Total\' indicates the target is for the entire campaign/flight/line_item duration.' ;
    rdfs:domain ind:CampaignKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRevisionNumber rdf:type rdf:Property ;
    rdfs:label 'Target Revision Number' ;
    rdfs:comment 'Version number tracking revisions to this KPI target. Increments each time the target is modified during campaign execution.' ;
    rdfs:domain ind:CampaignKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle status of the KPI target. Tracks whether the target is in planning, actively being measured, or has been completed or cancelled.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUnit rdf:type rdf:Property ;
    rdfs:label 'Target Unit' ;
    rdfs:comment 'The unit of measure for the target_value. Defines how the target should be interpreted (absolute count, percentage, currency amount, or rating point).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique identifier for each campaign status transition record. Primary key for the campaign status history event log.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowStepId rdf:type rdf:Property ;
    rdfs:label 'Workflow Step Id' ;
    rdfs:comment 'Identifier of the workflow step or stage that triggered this transition. Used for process mining and workflow optimization.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkflowStep .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this status transition required formal approval according to campaign governance rules.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changedBySystem rdf:type rdf:Property ;
    rdfs:label 'Changed By System' ;
    rdfs:comment 'Name or identifier of the system that triggered the status change. Populated for automated and system-initiated transitions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedByUserName rdf:type rdf:Property ;
    rdfs:label 'Changed By User Name' ;
    rdfs:comment 'Full name of the user who initiated the status change. Denormalized for reporting convenience and historical preservation.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientVisibleFlag rdf:type rdf:Property ;
    rdfs:label 'Client Visible Flag' ;
    rdfs:comment 'Indicates whether this status transition should be visible to the client in external reporting and dashboards.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Completed Flag' ;
    rdfs:comment 'Indicates whether required compliance review has been completed for this status transition.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Required Flag' ;
    rdfs:comment 'Indicates whether this status transition requires compliance or legal review according to regulatory requirements.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationInPreviousStatusHours rdf:type rdf:Property ;
    rdfs:label 'Duration In Previous Status Hours' ;
    rdfs:comment 'The number of hours the campaign spent in the previous status before this transition. Calculated field for lifecycle analytics.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The status of the campaign after this transition. Captures the to-state in the status lifecycle. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|scheduled|active|paused|completed|cancelled|archived — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time when stakeholder notifications were sent for this status transition. Null if no notifications were sent.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The status of the campaign immediately before this transition occurred. Captures the from-state in the status lifecycle. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|scheduled|active|paused|completed|cancelled|archived — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The date and time when this history record was created in the data warehouse. Used for data lineage and audit purposes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rollbackFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Flag' ;
    rdfs:comment 'Indicates whether this status transition was later rolled back or reversed. Used for tracking corrections and error recovery.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackReason rdf:type rdf:Property ;
    rdfs:label 'Rollback Reason' ;
    rdfs:comment 'Explanation of why this status transition was rolled back. Provides context for error analysis and process improvement.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rollback Timestamp' ;
    rdfs:comment 'The date and time when this status transition was rolled back. Null if the transition was not rolled back.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionCode rdf:type rdf:Property ;
    rdfs:label 'Session Code' ;
    rdfs:comment 'The user session identifier during which the status change occurred. Links to session logs for detailed audit trails.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The unique identifier of this status transition record in the source operational system. Enables traceability back to source.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the status change. Used for categorization and reporting of transition patterns.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of why the status transition occurred. Provides context for audit and client reporting purposes.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The precise date and time when the campaign status transition occurred. Primary event timestamp for this history record.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transitionType rdf:type rdf:Property ;
    rdfs:label 'Transition Type' ;
    rdfs:comment 'The mechanism that triggered the status change. Distinguishes between user-initiated, system-triggered, and automated workflow transitions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegments rdf:type rdf:Property ;
    rdfs:label 'Audience Segments' ;
    rdfs:comment 'Comma-separated list or structured description of audience segments targeted in this flight (e.g., demographic, behavioral, contextual, or custom segments from DMP/CDP).' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list or structured description of the media channels included in this flight (e.g., \'Display, Video, Social, OOH\'). Defines the multi-channel execution strategy for this burst.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeRotation rdf:type rdf:Property ;
    rdfs:label 'Creative Rotation' ;
    rdfs:comment 'The strategy for rotating multiple creatives within this flight (even = equal distribution, weighted = custom weights, optimized = algorithm-driven, sequential = fixed order).' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartRestrictions rdf:type rdf:Property ;
    rdfs:label 'Daypart Restrictions' ;
    rdfs:comment 'Time-of-day or day-of-week restrictions for ad delivery within this flight (e.g., \'Weekdays 6AM-10PM\', \'Prime Time Only\'). Enables dayparting strategies to optimize audience reach.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightCode rdf:type rdf:Property ;
    rdfs:label 'Flight Code' ;
    rdfs:comment 'Externally-known unique code or identifier for this flight, used in trafficking systems, insertion orders, and billing reconciliation.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightName rdf:type rdf:Property ;
    rdfs:label 'Flight Name' ;
    rdfs:comment 'Human-readable name or label for this flight, often indicating the burst period, theme, or seasonal focus (e.g., \'Holiday Wave 1\', \'Back-to-School Burst\').' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Status' ;
    rdfs:comment 'Current lifecycle status of the flight. Indicates whether the flight is in planning, actively running, paused, or concluded.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacingGoal rdf:type rdf:Property ;
    rdfs:label 'Pacing Goal' ;
    rdfs:comment 'The metric by which pacing is measured and controlled (e.g., impressions delivered, clicks generated, conversions achieved, unique reach, or spend amount).' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFrequency rdf:type rdf:Property ;
    rdfs:label 'Target Frequency' ;
    rdfs:comment 'The planned average number of times each unique user should be exposed to the ad during this flight. Used to balance reach and repetition.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGrp rdf:type rdf:Property ;
    rdfs:label 'Target Grp' ;
    rdfs:comment 'The planned Gross Rating Points for this flight, representing the sum of all rating points delivered. Standard metric for traditional media planning.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetImpressions rdf:type rdf:Property ;
    rdfs:label 'Target Impressions' ;
    rdfs:comment 'The planned number of ad impressions to be delivered during this flight. Used for pacing and performance tracking.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetReach rdf:type rdf:Property ;
    rdfs:label 'Target Reach' ;
    rdfs:comment 'The planned number of unique individuals or households to be reached during this flight. Key metric for awareness campaigns.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetTrp rdf:type rdf:Property ;
    rdfs:label 'Target Trp' ;
    rdfs:comment 'The planned Target Rating Points for this flight, representing GRP adjusted for the specific target audience. Used for audience-specific media planning.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractInsertionOrderId rdf:type rdf:Property ;
    rdfs:label 'Contract Insertion Order Id' ;
    rdfs:comment 'Reference to the insertion order that authorizes this line item buy. Links media execution to contractual commitment.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractInsertionOrder .

ind:programmaticDealId rdf:type rdf:Property ;
    rdfs:label 'Programmatic Deal Id' ;
    rdfs:comment 'The unique identifier for a programmatic deal (PMP, preferred deal, or programmatic guaranteed) associated with this line item. Nullable for open exchange buys.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgrammaticDeal .

ind:vendorPublisherId rdf:type rdf:Property ;
    rdfs:label 'Vendor Publisher Id' ;
    rdfs:comment 'Reference to the media vendor or publisher delivering this line item inventory. Links to vendor master for billing and performance tracking.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Publisher .

ind:adFormat rdf:type rdf:Property ;
    rdfs:label 'Ad Format' ;
    rdfs:comment 'The creative format specification for this line item (e.g., 300x250 banner, 15-second pre-roll, sponsored post). Defines the deliverable unit.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Rate' ;
    rdfs:comment 'The commission percentage applied to this line item. Expressed as a percentage (e.g., 15.00 for 15%). Used to calculate net from gross cost.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookedClicks rdf:type rdf:Property ;
    rdfs:label 'Booked Clicks' ;
    rdfs:comment 'The contracted number of clicks to be delivered for this line item. Primary delivery goal for click-based buys.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookedConversions rdf:type rdf:Property ;
    rdfs:label 'Booked Conversions' ;
    rdfs:comment 'The contracted number of conversions or acquisitions to be delivered for this line item. Primary delivery goal for performance-based buys.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookedImpressions rdf:type rdf:Property ;
    rdfs:label 'Booked Impressions' ;
    rdfs:comment 'The contracted number of impressions to be delivered for this line item. Primary delivery goal for impression-based buys.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookedViews rdf:type rdf:Property ;
    rdfs:label 'Booked Views' ;
    rdfs:comment 'The contracted number of video views or viewable impressions to be delivered for this line item. Primary delivery goal for video and viewability-based buys.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSafetyTier rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Tier' ;
    rdfs:comment 'The level of brand safety filtering applied to this line item. Determines which content categories and contexts are excluded.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Creative Assignment Status' ;
    rdfs:comment 'The status of creative asset assignment and approval for this line item. Indicates whether creatives are ready for serving.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCapImpressions rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Impressions' ;
    rdfs:comment 'The maximum number of impressions a unique user can receive for this line item within the frequency cap period. Used to control ad exposure.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossCost rdf:type rdf:Property ;
    rdfs:label 'Gross Cost' ;
    rdfs:comment 'The gross media cost for this line item before agency commission. Represents the total amount billed to the client.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isProgrammatic rdf:type rdf:Property ;
    rdfs:label 'Is Programmatic' ;
    rdfs:comment 'Indicates whether this line item is executed through programmatic buying platforms (DSP) or through direct/manual insertion orders.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemCode rdf:type rdf:Property ;
    rdfs:label 'Line Item Code' ;
    rdfs:comment 'External business identifier or SKU for the line item. Used for trafficking, billing reconciliation, and cross-system reference.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemName rdf:type rdf:Property ;
    rdfs:label 'Line Item Name' ;
    rdfs:comment 'Human-readable name for the line item. Typically includes targeting, format, and channel descriptors for operational clarity.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Ordinal position of this line item within the parent flight. Used for display ordering and operational sequencing.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netCost rdf:type rdf:Property ;
    rdfs:label 'Net Cost' ;
    rdfs:comment 'The net media cost for this line item after agency commission and discounts. Used for internal P&L and margin analysis.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pacingStatus rdf:type rdf:Property ;
    rdfs:label 'Pacing Status' ;
    rdfs:comment 'The current pacing health of the line item relative to its delivery goal and timeline. Used for proactive delivery management.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'The buying model or inventory type for this line item. Indicates whether inventory is reserved, auction-based, or programmatic. [ENUM-REF-CANDIDATE: guaranteed|non-guaranteed|programmatic_guaranteed|preferred_deal|private_auction|open_exchange|direct — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'The unit rate for this line item based on the rate type. For CPM, this is cost per thousand impressions; for CPC, cost per click; for flat, total cost.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'The pricing model for this line item. Determines how cost is calculated based on delivery metrics (Cost Per Mille, Cost Per Click, Cost Per Acquisition, Cost Per View, flat fee). [ENUM-REF-CANDIDATE: cpm|cpc|cpa|cpv|cpe|flat|cpcv|vcpm — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingSummary rdf:type rdf:Property ;
    rdfs:label 'Targeting Summary' ;
    rdfs:comment 'High-level summary of audience targeting parameters applied to this line item (demographics, geography, behavior, context). Detailed targeting stored in related tables.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Viewability Target Percentage' ;
    rdfs:comment 'The target percentage of impressions that must meet viewability standards (MRC definition: 50% of pixels in view for 1 second for display, 2 seconds for video).' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationEventId rdf:type rdf:Property ;
    rdfs:label 'Optimization Event Id' ;
    rdfs:comment 'Unique identifier for the optimization event. Primary key for the optimization event entity.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimizationRuleId rdf:type rdf:Property ;
    rdfs:label 'Optimization Rule Id' ;
    rdfs:comment 'Reference to the predefined optimization rule that triggered this event, if applicable. Null for manual or ad-hoc automated optimizations. Links to the optimization rule entity.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OptimizationRule .

ind:primaryOptimizationWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Optimization Worker Id' ;
    rdfs:comment 'Reference to the user who performed the optimization action. Null if the optimization was performed by an automated system. Links to the user or employee entity.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:targetingRuleId rdf:type rdf:Property ;
    rdfs:label 'Targeting Rule Id' ;
    rdfs:comment 'Foreign key linking to campaign.targeting_rule. Business justification: Optimizations frequently adjust targeting rules (add/remove audience segments, change geo targeting, adjust device targeting). Adding targeting_rule_id enables tracking when optimizations specifically' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TargetingRule .

ind:actualImpact rdf:type rdf:Property ;
    rdfs:label 'Actual Impact' ;
    rdfs:comment 'The measured impact of the optimization on campaign performance after sufficient time has passed for evaluation. Captures actual changes in KPIs (Key Performance Indicators) to enable optimization effectiveness analysis.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedEntityCount rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Count' ;
    rdfs:comment 'The number of entities (placements, creatives, audience segments, etc.) affected by this optimization. Provides scale context for the optimization impact.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedImpact rdf:type rdf:Property ;
    rdfs:label 'Expected Impact' ;
    rdfs:comment 'The anticipated impact of the optimization on campaign performance at the time the change was made. Describes expected improvements in KPIs (Key Performance Indicators) such as CTR (Click-Through Rate), CPA (Cost Per Acquisition), or ROAS (Return on Ad Spend).' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'The value of the parameter after the optimization was applied. Stored as string to accommodate various data types (numeric, categorical, JSON).' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationScope rdf:type rdf:Property ;
    rdfs:label 'Optimization Scope' ;
    rdfs:comment 'The granularity level at which the optimization was applied. Indicates whether the change affected the entire campaign, a specific flight, a line item, a placement, or a creative asset.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationStatus rdf:type rdf:Property ;
    rdfs:label 'Optimization Status' ;
    rdfs:comment 'Current lifecycle status of the optimization event. Tracks whether the optimization is pending execution, successfully applied, failed to apply, rolled back, or expired due to time constraints.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Optimization Timestamp' ;
    rdfs:comment 'The exact date and time when the optimization action was executed. Represents the business event time when the change took effect in the campaign execution system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optimizationType rdf:type rdf:Property ;
    rdfs:label 'Optimization Type' ;
    rdfs:comment 'The type of optimization action performed. Categorizes the nature of the change made to the campaign execution. [ENUM-REF-CANDIDATE: bid_adjustment|budget_reallocation|audience_expansion|audience_exclusion|creative_rotation_change|pacing_adjustment|frequency_cap_change|placement_exclusion|channel_shift|daypart_shift — promote to reference product]' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performedBySystem rdf:type rdf:Property ;
    rdfs:label 'Performed By System' ;
    rdfs:comment 'Name or identifier of the automated system that performed the optimization. Examples include DSP (Demand-Side Platform) names like The Trade Desk, Google Campaign Manager 360, or internal optimization engine identifiers. Null if performed manually by a user.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousValue rdf:type rdf:Property ;
    rdfs:label 'Previous Value' ;
    rdfs:comment 'The value of the parameter before the optimization was applied. Stored as string to accommodate various data types (numeric, categorical, JSON).' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testControlFlag rdf:type rdf:Property ;
    rdfs:label 'Test Control Flag' ;
    rdfs:comment 'Indicates whether this optimization is part of a controlled experiment or A/B test. True if the optimization is being tested against a control group, False for standard optimizations.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'Detailed explanation of why the optimization was triggered. Captures the business rationale, performance threshold breach, or strategic decision that prompted the change.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'Indicates whether the optimization was triggered manually by a user, automatically by a system algorithm, or by a predefined rule-based condition.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueUnit rdf:type rdf:Property ;
    rdfs:label 'Value Unit' ;
    rdfs:comment 'The unit of measurement for the previous and new values. Examples include currency code (USD, EUR), percentage (%), CPM (Cost Per Mille), CPC (Cost Per Click), impressions, or dimensionless for categorical changes.' ;
    rdfs:domain ind:OptimizationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationAlgorithmId rdf:type rdf:Property ;
    rdfs:label 'Optimization Algorithm Id' ;
    rdfs:comment 'Reference to the optimization algorithm or model used for auto-pacing adjustments, if applicable.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OptimizationAlgorithm .

ind:primaryPacingWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Pacing Worker Id' ;
    rdfs:comment 'Reference to the user who created this pacing rule record.' ;
    rdfs:domain ind:PacingRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:customCurveDefinition rdf:type rdf:Property ;
    rdfs:label 'Custom Curve Definition' ;
    rdfs:comment 'JSON or structured definition of a custom pacing curve when pacing_type is set to custom_curve. Defines delivery distribution over time.' ;
    rdfs:domain ind:PacingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartingEnabled rdf:type rdf:Property ;
    rdfs:label 'Dayparting Enabled' ;
    rdfs:comment 'Indicates whether dayparting (time-of-day targeting) is applied as part of the pacing strategy.' ;
    rdfs:domain ind:PacingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daypartingSchedule rdf:type rdf:Property ;
    rdfs:label 'Dayparting Schedule' ;
    rdfs:comment 'Structured definition of the dayparting schedule (e.g., JSON or cron-like format) specifying hours and days when delivery is allowed or prioritized.' ;
    rdfs:domain ind:PacingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name or label for the pacing rule, used for identification and reporting purposes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier (e.g., America/New_York, Europe/London) used for interpreting pacing schedules and dayparting rules.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserType rdf:type rdf:Property ;
    rdfs:label 'Browser Type' ;
    rdfs:comment 'The web browser targeted (e.g., Chrome, Safari, Firefox, Edge).' ;
    rdfs:domain ind:TargetingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether this targeting rule respects CCPA opt-out requests (Do Not Sell My Personal Information).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:connectionType rdf:type rdf:Property ;
    rdfs:label 'Connection Type' ;
    rdfs:comment 'The type of network connection targeted: WiFi, cellular, ethernet, or unknown.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartSchedule rdf:type rdf:Property ;
    rdfs:label 'Daypart Schedule' ;
    rdfs:comment 'The time-of-day or day-of-week schedule for ad delivery, specified in a structured format (e.g., JSON or cron-like expression).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudPreventionThreshold rdf:type rdf:Property ;
    rdfs:label 'Fraud Prevention Threshold' ;
    rdfs:comment 'The minimum fraud detection score (0-100) required for ad delivery, used to filter out suspected invalid traffic.' ;
    rdfs:domain ind:TargetingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyCapLimit rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Limit' ;
    rdfs:comment 'The maximum number of times an ad can be shown to a user within the specified frequency cap window.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCapUnit rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Unit' ;
    rdfs:comment 'The time unit for the frequency cap window: hour, day, week, month, or lifetime.' ;
    rdfs:domain ind:TargetingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoLevel rdf:type rdf:Property ;
    rdfs:label 'Geo Level' ;
    rdfs:comment 'The granularity of geographic targeting: country, region/state, Designated Market Area (DMA), city, or postal code.' ;
    rdfs:domain ind:TargetingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osType rdf:type rdf:Property ;
    rdfs:label 'Os Type' ;
    rdfs:comment 'The operating system targeted (e.g., iOS, Android, Windows, macOS, tvOS).' ;
    rdfs:domain ind:TargetingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyWindow rdf:type rdf:Property ;
    rdfs:label 'Recency Window' ;
    rdfs:comment 'The time window (in days) for behavioral or retargeting data recency, specifying how recent user activity must be to qualify for targeting.' ;
    rdfs:domain ind:TargetingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetingDimension rdf:type rdf:Property ;
    rdfs:label 'Targeting Dimension' ;
    rdfs:comment 'The dimension or category of targeting applied by this rule. [ENUM-REF-CANDIDATE: geography|demographic|behavioral|contextual|keyword|device|daypart|audience_segment|retargeting|lookalike|brand_safety_content_exclusion|brand_safety_keyword_block|brand_safety_domain_block|brand_safety_category_exclusion|frequency_cap|viewability|fraud_prevention — promote to reference product]' ;
    rdfs:domain ind:TargetingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingOperator rdf:type rdf:Property ;
    rdfs:label 'Targeting Operator' ;
    rdfs:comment 'Specifies whether the targeting rule includes or excludes the specified targeting value.' ;
    rdfs:domain ind:TargetingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingValue rdf:type rdf:Property ;
    rdfs:label 'Targeting Value' ;
    rdfs:comment 'The specific value or identifier for the targeting dimension (e.g., country code, age range, device type, audience segment ID).' ;
    rdfs:domain ind:TargetingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetingValueType rdf:type rdf:Property ;
    rdfs:label 'Targeting Value Type' ;
    rdfs:comment 'Indicates the format of the targeting value: single value, range, comma-separated list, or pattern/regex.' ;
    rdfs:domain ind:TargetingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTraffickingOrderId rdf:type rdf:Property ;
    rdfs:label 'Parent Trafficking Order Id' ;
    rdfs:comment 'Reference to the original trafficking order if this is a revision or amendment, enabling tracking of the full order history and change lineage.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TraffickingOrder .

ind:primaryTraffickingWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Trafficking Worker Id' ;
    rdfs:comment 'Reference to the user or ad operations specialist who submitted the trafficking order to the ad server platform.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:actualLiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Live Timestamp' ;
    rdfs:comment 'Actual date and time when the trafficking order went live and ads began serving, as confirmed by the ad server platform.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adServerOrderCode rdf:type rdf:Property ;
    rdfs:label 'Ad Server Order Code' ;
    rdfs:comment 'External order or campaign identifier assigned by the ad server platform (e.g., CM360 order ID, Trade Desk campaign ID) for cross-system reconciliation.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adServerPlatform rdf:type rdf:Property ;
    rdfs:label 'Ad Server Platform' ;
    rdfs:comment 'The ad serving or demand-side platform (DSP) to which this trafficking order is submitted for campaign activation and delivery. [ENUM-REF-CANDIDATE: Google Campaign Manager 360|The Trade Desk|DV360|Amazon DSP|Xandr|MediaMath|Adobe Advertising Cloud|Sizmek|Other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adsTraffickedCount rdf:type rdf:Property ;
    rdfs:label 'Ads Trafficked Count' ;
    rdfs:comment 'Total number of individual ad creatives that were trafficked and uploaded to the ad server as part of this trafficking order.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the trafficking order was marked as completed, indicating that all line items and ads are live and the operational handoff is finalized.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineItemsTraffickedCount rdf:type rdf:Property ;
    rdfs:label 'Line Items Trafficked Count' ;
    rdfs:comment 'Total number of campaign line items that were trafficked and configured in the ad server as part of this trafficking order.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pixelFiringValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Pixel Firing Validation Status' ;
    rdfs:comment 'Validation status of tracking pixels and conversion tags, confirming that impression, click, and conversion pixels are firing correctly in test environments.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qa Completed Timestamp' ;
    rdfs:comment 'Date and time when the quality assurance review was completed and the trafficking order was approved or rejected for go-live.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qaStatus rdf:type rdf:Property ;
    rdfs:label 'Qa Status' ;
    rdfs:comment 'Current status of the quality assurance review process for this trafficking order, indicating whether pre-launch validation checks have been completed and passed.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential version number tracking revisions and resubmissions of the trafficking order due to changes, corrections, or rejections.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target number of hours within which the trafficking order should be completed from submission to go-live, as defined by internal SLA policies.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the trafficking order was submitted to the ad server or DSP for processing and activation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:traffickingNotes rdf:type rdf:Property ;
    rdfs:label 'Trafficking Notes' ;
    rdfs:comment 'Free-text operational notes and instructions provided by the trafficking team regarding special setup requirements, targeting parameters, creative specifications, or platform-specific configurations.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traffickingOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Trafficking Order Number' ;
    rdfs:comment 'Business-facing unique trafficking order number used for operational reference and communication with ad ops teams and external platforms.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traffickingType rdf:type rdf:Property ;
    rdfs:label 'Trafficking Type' ;
    rdfs:comment 'Classification of the trafficking order based on the campaign buying model and activation method (standard direct IO, programmatic guaranteed, sponsorship, etc.).' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vastTagValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Vast Tag Validation Status' ;
    rdfs:comment 'Validation status of VAST tags for video ad creatives, indicating whether the tags conform to IAB VAST specifications and are ready for serving.' ;
    rdfs:domain ind:TraffickingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTeamId rdf:type rdf:Property ;
    rdfs:label 'Account Team Id' ;
    rdfs:comment 'Unique surrogate identifier for each account team assignment record in the advertising agency. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountTeam .

ind:managedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Managed Supplier Id' ;
    rdfs:comment 'Foreign key linking to vendor.supplier. Business justification: Account team members often have vendor relationship management responsibilities—e.g., media buyer assigned to manage Google/Meta relationships for specific clients. Tracks vendor stewardship assignmen' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:primaryAccountWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Worker Id' ;
    rdfs:comment 'Reference to the agency-side personnel record (account director, strategist, planner, media buyer, creative) assigned to this account. Links to the talent domain employee master.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:tertiaryAccountApprovedByEmployeeWorkerId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Account Approved By Employee Worker Id' ;
    rdfs:comment 'Reference to the agency employee (typically a Managing Director or Group Account Director) who approved this team assignment. Supports governance, audit trails, and staffing approval workflows.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:accountAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Account Access Level' ;
    rdfs:comment 'The level of access this team member has to the client account record in Salesforce CRM (read, edit, or all). Mirrors the Salesforce AccountTeamMember AccountAccessLevel field and governs data visibility for compliance and conflict-of-interest checks.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this account team assignment, used in Workfront project management and Salesforce CRM for cross-system reference and QBR (Quarterly Business Review) reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text field capturing additional context about the team member\'s assignment, such as special responsibilities, client preferences, transition notes, or coverage arrangements. Supports account management continuity.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the team member\'s assignment to the account. \'active\' indicates currently serving; \'on_leave\' indicates temporary absence with backup coverage; \'transitioning\' indicates handover in progress; \'inactive\' indicates assignment ended; \'pending\' indicates assignment approved but not yet started.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classifies the nature of the team member\'s assignment to the account: \'dedicated\' = exclusively assigned; \'shared\' = split across multiple accounts; \'project_based\' = assigned for a specific campaign or project; \'interim\' = temporary coverage assignment.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateType rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Type' ;
    rdfs:comment 'Specifies the time unit basis for the billing rate applied to this team member\'s account assignment (hourly, daily, monthly, or fixed fee). Determines how FTE allocation and time tracking translate to client invoicing.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateUsd rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Usd' ;
    rdfs:comment 'The hourly or daily billing rate in USD applied to this team member\'s time on the client account, as defined in the Statement of Work (SOW) or Master Service Agreement. Used for financial reconciliation and P&L reporting in SAP S/4HANA.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Client Facing Flag' ;
    rdfs:comment 'Indicates whether this team member has direct client-facing responsibilities and appears on the client-facing org chart. True = client-facing; False = internal/support role only. Governs inclusion in client communications and org chart generation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictOfInterestFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Flag' ;
    rdfs:comment 'Indicates whether a potential conflict of interest has been identified for this team member\'s assignment to the account (e.g., simultaneous assignment to a competing advertiser). True = conflict identified; False = no conflict. Triggers compliance review workflow.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictReviewDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Review Date' ;
    rdfs:comment 'The date on which the most recent conflict-of-interest review was conducted for this team member\'s account assignment. Supports compliance audit trails and periodic review scheduling.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Conflict Review Outcome' ;
    rdfs:comment 'The outcome of the most recent conflict-of-interest review for this assignment. \'cleared\' = no conflict found; \'waived\' = conflict acknowledged and waived by client; \'escalated\' = referred to senior management; \'pending\' = review in progress.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation Pct' ;
    rdfs:comment 'The percentage of the team member\'s full-time equivalent (FTE) capacity allocated to this specific client account, expressed as a decimal percentage (e.g., 50.00 = 50%). Supports resource utilization tracking, capacity planning, and P&L cost allocation.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBackupContact rdf:type rdf:Property ;
    rdfs:label 'Is Backup Contact' ;
    rdfs:comment 'Indicates whether this team member serves as the backup coverage contact for the client account when the primary contact is unavailable. True = designated backup; False = not a backup. Supports continuity planning and leave coverage.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this team member is the designated primary point of contact for the client account. True = primary contact; False = supporting team member. Used for client-facing org chart generation and escalation routing.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orgChartDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Org Chart Display Order' ;
    rdfs:comment 'Numeric sequence controlling the display order of this team member within the client-facing org chart for the account. Lower values appear first. Enables structured presentation of the account team hierarchy to clients.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedHoursPerMonth rdf:type rdf:Property ;
    rdfs:label 'Planned Hours Per Month' ;
    rdfs:comment 'The planned number of hours per month this team member is expected to dedicate to this client account, as agreed in the Statement of Work (SOW) or resource plan. Used for utilization tracking and capacity planning in Workfront.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qbrPresenterFlag rdf:type rdf:Property ;
    rdfs:label 'Qbr Presenter Flag' ;
    rdfs:comment 'Indicates whether this team member is designated to present at the client\'s Quarterly Business Review (QBR). True = QBR presenter; False = not a QBR presenter. Used for QBR preparation and client-facing agenda planning.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'The functional role this agency personnel member holds on the client account (e.g., Account Director, Strategic Planner, Media Lead, Creative Director, Account Manager, Media Buyer). Drives org chart generation and responsibility mapping. [ENUM-REF-CANDIDATE: Account Director|Strategic Planner|Media Lead|Creative Director|Account Manager|Media Buyer|Digital Strategist|Data Analyst|PR Lead|Brand Strategist — promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceTeamMemberCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Team Member Code' ;
    rdfs:comment 'The unique identifier of the corresponding AccountTeamMember record in Salesforce CRM Sales Cloud. Supports CRM synchronization, client relationship management, and QBR preparation workflows.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Seniority Level' ;
    rdfs:comment 'The seniority classification of the team member within their assigned role on this account (e.g., junior, mid, senior, lead, executive). Used for billing rate determination, resource planning, and QBR staffing reviews.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamFunction rdf:type rdf:Property ;
    rdfs:label 'Team Function' ;
    rdfs:comment 'The agency functional discipline this team member represents on the account (account management, media, creative, strategy, analytics, or PR). Enables cross-functional team composition reporting and resource planning by discipline.' ;
    rdfs:domain ind:AccountTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSegmentId rdf:type rdf:Property ;
    rdfs:label 'Client Segment Id' ;
    rdfs:comment 'Foreign key linking to client.client_segment. Business justification: Advertisers are classified into strategic business segments. The advertiser table currently has \'business_segment\' as a STRING field, which should be normalized to a FK reference to the client_segment' ;
    rdfs:domain ind:Client ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientSegment .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the advertiser account. Drives workflow routing, reporting segmentation, and CRM pipeline management. \'prospect\' = pre-contract; \'active\' = live campaigns; \'dormant\' = no recent activity; \'churned\' = relationship ended; \'suspended\' = temporarily on hold.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Commercial tier classification of the advertiser based on revenue contribution, strategic importance, and engagement level. Determines service level, dedicated account team assignment, and reporting cadence. Aligns with agency tiering models used in account management.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Indicates the validation status of the advertiser\'s billing address against a postal address verification service. \'validated\' = confirmed deliverable; \'unvalidated\' = not yet checked; \'failed\' = address could not be verified; \'pending\' = verification in progress. Used in SAP S/4HANA and Mediaocean Prisma billing workflows.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalWorkflowType rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Type' ;
    rdfs:comment 'Defines the creative and campaign approval workflow configuration for this advertiser. \'single_approver\' = one designated approver; \'multi_approver\' = sequential or parallel approval chain; \'auto_approve\' = pre-authorized for specific asset types. Configured in Workfront proofing module.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Consent Flag' ;
    rdfs:comment 'Indicates whether the advertiser has opted in to data sharing under CCPA regulations. True = data sharing permitted; False = opt-out or not applicable. Applicable for California-based advertisers and campaigns targeting California consumers. Drives NAI and TAG compliance controls.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnDate rdf:type rdf:Property ;
    rdfs:label 'Churn Date' ;
    rdfs:comment 'The date on which the advertiser\'s account was marked as churned (relationship ended). Populated only when account_status = \'churned\'. Used for churn analysis, win-back campaign targeting, and P&L impact reporting.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditTerms rdf:type rdf:Property ;
    rdfs:label 'Credit Terms' ;
    rdfs:comment 'The agreed payment credit terms for this advertiser, defining the number of days after invoice date by which payment is due. Configured in SAP S/4HANA AR and Mediaocean Prisma for billing workflows. Drives cash flow forecasting and P&L management.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'The unique account identifier assigned to this advertiser in Salesforce CRM (Sales Cloud). Serves as the cross-system join key between the lakehouse Silver Layer and the CRM system of record for account management and client services.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ein rdf:type rdf:Property ;
    rdfs:label 'Ein' ;
    rdfs:comment 'The US federal Employer Identification Number (EIN) assigned by the IRS to the advertiser. Used for US tax reporting, W-9 compliance, and financial reconciliation in SAP S/4HANA. Applicable for US-incorporated entities.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Customer Number' ;
    rdfs:comment 'The customer master number assigned to this advertiser in SAP S/4HANA (FI/AR module). Used for billing, accounts receivable, and financial reconciliation processes. Links advertiser identity to financial transactions.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the advertiser has provided explicit consent for data sharing and processing under GDPR. True = consent granted; False = consent not granted or withdrawn. Mandatory for EU-based advertisers and any data processing involving EU data subjects. Drives data governance controls.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdingCompanyName rdf:type rdf:Property ;
    rdfs:label 'Holding Company Name' ;
    rdfs:comment 'The name of the parent holding company or corporate group to which this advertiser belongs (e.g., WPP, Publicis, Omnicom client-side equivalent). Used for consolidated billing, conflict-of-interest checks, and group-level revenue reporting.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabIndustryVertical rdf:type rdf:Property ;
    rdfs:label 'Iab Industry Vertical' ;
    rdfs:comment 'The advertiser\'s primary industry vertical classified using the IAB Content Taxonomy. Used for audience targeting, competitive analysis, Share of Voice (SOV) reporting, and media planning segmentation. Examples: \'Automotive\', \'Financial Services\', \'Consumer Packaged Goods\'. [ENUM-REF-CANDIDATE: promote to reference product aligned to IAB Content Taxonomy v3.0]' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Incorporation Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code of the jurisdiction in which the advertiser\'s legal entity is incorporated. Used for regulatory compliance, tax treatment, and contract law determination. Examples: \'US\', \'GB\', \'DEU\'.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'The preferred method by which invoices are delivered to the advertiser. Drives automated invoice dispatch workflows in SAP S/4HANA and Mediaocean Prisma. \'edi\' = Electronic Data Interchange for enterprise clients with automated AP systems.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAgencyManaged rdf:type rdf:Property ;
    rdfs:label 'Is Agency Managed' ;
    rdfs:comment 'Indicates whether this advertiser is managed through an intermediary agency relationship (True) or is a direct client of the agency (False). Determines billing structure, IO (Insertion Order) routing, and account team assignment in Mediaocean Prisma and Salesforce CRM.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The full registered legal name of the advertiser as recorded with the relevant incorporation authority. Used for contracts, invoices, and regulatory filings. Maps to Salesforce CRM Account Name (legal) and SAP S/4HANA customer master legal name.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Managing Agency Name' ;
    rdfs:comment 'Name of the intermediary agency managing this advertiser\'s account, if is_agency_managed is True. Used for IO routing, commission calculations, and agency-of-record (AOR) tracking in Mediaocean Prisma and Salesforce CRM.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'The date on which the advertiser was formally onboarded as a client of the agency. Marks the start of the commercial relationship. Used for tenure calculations, anniversary-based QBR scheduling, and cohort analysis in analytics workflows.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'The agreed payment method/instrument for this advertiser\'s invoices. Distinct from credit_terms (which defines timing); this defines the payment channel/instrument. Configured in SAP S/4HANA and Mediaocean Prisma for financial reconciliation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Comm Channel' ;
    rdfs:comment 'The advertiser\'s preferred channel for day-to-day account communications and notifications. Used to route alerts, campaign updates, and approval requests in Salesforce CRM and Workfront project management workflows.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code representing the advertiser\'s preferred billing and reporting currency (e.g., \'USD\', \'EUR\', \'GBP\'). Used in Mediaocean Prisma for media billing and SAP S/4HANA for invoicing and financial reconciliation.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The primary email address of the advertiser\'s main point of contact at the client organization. Used for campaign communications, reporting delivery, and account management correspondence. Sourced from Salesforce CRM Contact object.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the advertiser\'s primary point of contact at the client organization. Used in account management, QBR preparation, and client services workflows. Sourced from Salesforce CRM Contact object.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for the advertiser\'s main point of contact. Used for urgent campaign communications and account management. Stored in E.164 international format. Sourced from Salesforce CRM Contact object.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOfficeCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Office Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the advertiser\'s registered office is located. May differ from billing address country. Used for regulatory compliance, GDPR/CCPA applicability determination, and legal jurisdiction.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'The advertiser\'s primary operational time zone expressed as an IANA Time Zone Database identifier (e.g., \'America/New_York\', \'Europe/London\'). Used for scheduling campaign flights, reporting cadence, and meeting coordination in Workfront and Salesforce CRM.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'The brand or \'doing business as\' (DBA) name under which the advertiser operates commercially. May differ from the legal entity name. Used in campaign documentation, media plans, and client-facing materials.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Number' ;
    rdfs:comment 'The advertiser\'s Value Added Tax (VAT) registration number issued by the relevant tax authority. Required for EU/UK invoicing compliance and cross-border tax treatment. Stored for financial reconciliation in SAP S/4HANA FI module.' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertiserHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each advertiser hierarchy relationship record in the silver layer. Serves as the primary key for this entity.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAdvertiserId rdf:type rdf:Property ;
    rdfs:label 'Child Advertiser Id' ;
    rdfs:comment 'Identifier of the child advertiser entity in the hierarchy (e.g., subsidiary, brand, or sub-brand). References the advertiser entity that sits one level below the parent in the corporate tree.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:parentAdvertiserId rdf:type rdf:Property ;
    rdfs:label 'Parent Advertiser Id' ;
    rdfs:comment 'Identifier of the parent advertiser entity in the hierarchy (e.g., holding company or parent subsidiary). References the advertiser entity that sits one level above the child in the corporate tree.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:primaryRootAdvertiserId rdf:type rdf:Property ;
    rdfs:label 'Primary Root Advertiser Id' ;
    rdfs:comment 'Identifier of the ultimate holding company or top-level entity in the advertiser corporate tree. Enables direct roll-up to the conglomerate level for consolidated billing, SOV analysis, and enterprise reporting without traversing the full hierarchy path.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:billingConsolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Consolidation Flag' ;
    rdfs:comment 'Indicates whether invoices and media spend for the child entity are consolidated and billed through the parent entity. Distinct from the general consolidation flag — specifically governs Mediaocean Prisma billing workflows and Insertion Order (IO) aggregation.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Categorized reason code explaining why this hierarchy relationship record was created or last modified. Supports audit trail requirements and change management reporting for account management teams during corporate restructuring events. [ENUM-REF-CANDIDATE: acquisition|divestiture|rebranding|restructuring|correction|initial_setup|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether the child entity\'s spend, impressions, and campaign performance metrics should be financially consolidated into the parent entity\'s reporting and P&L. Critical for holding company clients where subsidiary budgets roll up to a master account in SAP S/4HANA CO.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Crm Hierarchy Code' ;
    rdfs:comment 'The native account hierarchy relationship identifier from Salesforce CRM Sales Cloud. Enables bi-directional synchronization between the lakehouse silver layer and the CRM system of record for account management and client services workflows.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether the child advertiser entity has provided consent for audience data and campaign performance data to be shared with the parent entity in this hierarchy. Critical for GDPR and CCPA compliance when consolidating audience insights across corporate structures.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known alphanumeric business code uniquely identifying this parent-child hierarchy relationship. Used in Mediaocean Prisma and Salesforce CRM for cross-system reconciliation and billing roll-up references.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDescription rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Description' ;
    rdfs:comment 'Free-text narrative describing the business context, rationale, or special conditions of this parent-child hierarchy relationship. Captures nuances such as regional carve-outs, brand licensing arrangements, or joint venture structures not fully expressed by the type and role fields.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Human-readable label describing this specific parent-child hierarchy relationship (e.g., \'Unilever > Dove Brand Portfolio\'). Used in account management dashboards, QBR presentations, and client services reporting for clear identification of the relationship.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized slash-delimited path string representing the full ancestry chain from the root holding company to the current child node (e.g., \'/HoldCo/SubsidiaryA/BrandX\'). Supports efficient subtree queries and lineage tracing in Databricks without recursive CTEs.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of the parent-child hierarchy relationship. Drives whether the relationship is used for active campaign attribution, billing consolidation, and reporting roll-ups in Mediaocean Prisma and Google Campaign Manager 360.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classifies the nature of the parent-child relationship within the advertiser corporate structure. Determines how billing, reporting, and campaign attribution roll up through the account tree. [ENUM-REF-CANDIDATE: holding_company|subsidiary|brand_portfolio|brand|sub_brand|division — promote to reference product]' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'The IAB Content Taxonomy industry sector classification of the child advertiser entity within this hierarchy (e.g., \'Consumer Packaged Goods\', \'Automotive\', \'Financial Services\'). Supports audience segmentation, competitive SOV analysis, and Nielsen Ad Intel competitive monitoring.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryHierarchy rdf:type rdf:Property ;
    rdfs:label 'Is Primary Hierarchy' ;
    rdfs:comment 'Indicates whether this relationship represents the primary (canonical) hierarchy path for the child advertiser entity. When an entity belongs to multiple hierarchy trees (e.g., matrix structures), this flag identifies the authoritative roll-up path for billing and consolidated reporting.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketRegion rdf:type rdf:Property ;
    rdfs:label 'Market Region' ;
    rdfs:comment 'The geographic market region in which this hierarchy relationship is operationally active (e.g., \'North America\', \'EMEA\', \'APAC\'). Determines applicable regulatory frameworks (GDPR, CCPA), media buying practices, and regional account team assignments. [ENUM-REF-CANDIDATE: North America|EMEA|APAC|LATAM|MEA|Global — promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'The percentage of ownership the parent entity holds in the child entity (0.00–100.00). Used to determine proportional financial consolidation thresholds and to classify the relationship as majority-owned, minority-owned, or affiliated for P&L reporting in SAP S/4HANA.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prismaHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Prisma Hierarchy Code' ;
    rdfs:comment 'The native account hierarchy identifier from Mediaocean Prisma used for media planning, buying, and billing roll-up. Supports reconciliation between the lakehouse and Prisma for consolidated media spend reporting across the advertiser corporate tree.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRole rdf:type rdf:Property ;
    rdfs:label 'Relationship Role' ;
    rdfs:comment 'Describes the commercial or legal role of the child entity relative to the parent within the hierarchy (e.g., wholly-owned subsidiary vs. franchise vs. joint venture). Informs contract and billing treatment in SAP S/4HANA and Mediaocean Prisma.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingConsolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Consolidation Flag' ;
    rdfs:comment 'Indicates whether campaign performance data (impressions, clicks, CTR, ROAS) for the child entity rolls up into the parent entity\'s consolidated reporting dashboards in Google Campaign Manager 360 and The Trade Desk. May differ from billing consolidation in matrix account structures.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sovRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Sov Rollup Flag' ;
    rdfs:comment 'Indicates whether the child entity\'s media spend and impressions should be included in the parent entity\'s Share of Voice (SOV) calculations for competitive analysis in Nielsen Ad Intel and Comscore. Enables accurate conglomerate-level SOV reporting.' ;
    rdfs:domain ind:AdvertiserHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agencyRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Agency Relationship Id' ;
    rdfs:comment 'Unique surrogate identifier for the agency-advertiser relationship record. Primary key for this entity. Role classification: MASTER_AGREEMENT — represents a long-running formal binding relationship between the agency and an advertiser.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgencyRelationship .

ind:primarySupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Id' ;
    rdfs:comment 'Foreign key linking to vendor.supplier. Business justification: Agency relationships often designate primary media suppliers or tech platforms used for that client account. Tracks which DSPs, SSPs, or publishers are approved/preferred under specific agency-client ' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'The contracted annual agency fee or retainer amount in the agreed currency for this relationship. Used for P&L reporting, budget management, and financial reconciliation. Applicable for retainer and project-fee structures.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aorDesignation rdf:type rdf:Property ;
    rdfs:label 'Aor Designation' ;
    rdfs:comment 'Specifies the specific Agency of Record (AOR) designation held by the agency for this client, if applicable. Distinguishes between full-service AOR and discipline-specific AOR designations (media, creative, digital, PR, social). Used for AOR tracking and executive relationship reporting. [ENUM-REF-CANDIDATE: full_service_aor|media_aor|creative_aor|digital_aor|pr_aor|social_aor|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandScope rdf:type rdf:Property ;
    rdfs:label 'Brand Scope' ;
    rdfs:comment 'Comma-delimited list of the client\'s brand names or brand portfolio segments covered under this agency relationship. Distinguishes relationships that cover the full client portfolio from those scoped to specific brands or sub-brands.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactEmail rdf:type rdf:Property ;
    rdfs:label 'Client Contact Email' ;
    rdfs:comment 'The business email address of the primary client contact for this relationship. Used for direct communication, meeting scheduling, and CRM record maintenance. Subject to GDPR and CCPA data protection requirements.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePct rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Pct' ;
    rdfs:comment 'The agreed agency commission rate expressed as a percentage of gross media spend, applicable when the fee structure type is commission_based or hybrid. Used for financial reconciliation in Mediaocean Prisma and SAP S/4HANA.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveConflictFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Conflict Flag' ;
    rdfs:comment 'Indicates whether this agency-client relationship involves a known competitive conflict with another client in the agency\'s portfolio (i.e., the agency serves two competing advertisers in the same category). Critical for conflict management and new business governance.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictCategory rdf:type rdf:Property ;
    rdfs:label 'Conflict Category' ;
    rdfs:comment 'The product or industry category in which a competitive conflict exists, if the competitive conflict flag is true (e.g., \'Automotive\', \'Financial Services\', \'FMCG — Beverages\'). Used for conflict management reporting and new business screening.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Code' ;
    rdfs:comment 'The external identifier of the corresponding Salesforce CRM Opportunity record that originated or tracks this agency-client relationship. Enables bi-directional traceability between the data lakehouse and the CRM system of record.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEventType rdf:type rdf:Property ;
    rdfs:label 'Current Event Type' ;
    rdfs:comment 'The type of the most recent state-change event recorded against this relationship. Supports AOR win/loss tracking, scope change management, and executive relationship lifecycle reporting. Full event history is stored as effective-dated event records within this product. [ENUM-REF-CANDIDATE: aor_win|aor_loss|scope_expansion|scope_reduction|renewal|escalation|status_transition|termination|suspension|reinstatement|pitch_initiated — promote to reference product]' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualBillings rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Billings' ;
    rdfs:comment 'The estimated total annual media billings or revenue associated with this agency-client relationship, in the fee currency. Used for revenue forecasting, P&L reporting, and strategic account prioritisation. Distinct from the contracted annual fee amount.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Event Effective Date' ;
    rdfs:comment 'The business-effective date of the most recent state-change event (e.g., the date an AOR win took effect, the date a scope expansion was agreed). Distinct from the record audit timestamp; used for effective-dated relationship lifecycle reporting.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text narrative notes providing additional context for the most recent relationship state-change event. Captures qualitative detail such as client rationale, negotiation outcomes, or escalation context. Supports audit trail and executive relationship lifecycle reporting.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTrigger rdf:type rdf:Property ;
    rdfs:label 'Event Trigger' ;
    rdfs:comment 'A brief description of the business event or circumstance that triggered the most recent relationship state change (e.g., \'Client initiated competitive review\', \'Scope expanded to include social media\', \'Contract renewed for FY2025\'). Supports narrative audit trail and executive reporting.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annual fee amount and any financial values associated with this relationship (e.g., USD, GBP, EUR). Supports multi-currency financial reconciliation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeStructureType rdf:type rdf:Property ;
    rdfs:label 'Fee Structure Type' ;
    rdfs:comment 'The commercial fee model governing agency compensation under this relationship. Retainer_fee is a fixed recurring payment; commission_based is a percentage of media spend; project_fee is a one-time scoped payment; performance_based ties compensation to KPI outcomes; hybrid combines multiple models.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incumbentAgencyName rdf:type rdf:Property ;
    rdfs:label 'Incumbent Agency Name' ;
    rdfs:comment 'The name of the previous incumbent agency that held the account prior to this relationship being established, if applicable. Used for competitive intelligence, pitch history analysis, and AOR win/loss reporting.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether the agency holds an exclusive mandate for the defined scope of services with this advertiser, preventing the client from engaging competing agencies for the same services. Critical for competitive conflict management and AOR governance.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAccountDirector rdf:type rdf:Property ;
    rdfs:label 'Lead Account Director' ;
    rdfs:comment 'The name of the senior agency account director who holds primary responsibility for managing this client relationship. Used for account team assignment, escalation routing, and executive relationship reporting.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaoceanClientCode rdf:type rdf:Property ;
    rdfs:label 'Mediaocean Client Code' ;
    rdfs:comment 'The client code assigned to this advertiser in Mediaocean Prisma, the media planning and buying system of record. Used for reconciliation of media plans, insertion orders (IOs), and billing records against this relationship.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'The number of calendar days of advance written notice required by either party to terminate or materially modify this agency-client relationship, as specified in the governing contract or Statement of Work (SOW).' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pitchType rdf:type rdf:Property ;
    rdfs:label 'Pitch Type' ;
    rdfs:comment 'The type of pitch or selection process through which this agency-client relationship was established. Competitive_review is a formal multi-agency pitch; direct_award is a non-competitive appointment; incumbent_retention is a renewal without a formal pitch; rfi_rfp is a formal Request for Information (RFI) or Request for Proposal (RFP) process.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchWinDate rdf:type rdf:Property ;
    rdfs:label 'Pitch Win Date' ;
    rdfs:comment 'The date on which the agency formally won the pitch or competitive review that established this relationship. Used for pitch history tracking, new business reporting, and AOR win/loss analytics.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousRelationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Relationship Status' ;
    rdfs:comment 'The relationship status immediately prior to the most recent state-change event. Stored alongside the current status to support audit trail requirements and state-transition reporting without requiring a separate history table.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryClientContact rdf:type rdf:Property ;
    rdfs:label 'Primary Client Contact' ;
    rdfs:comment 'The name of the primary contact person on the client/advertiser side for this relationship (e.g., CMO, Marketing Director, Brand Manager). Used for account management, communication routing, and CRM record maintenance.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipCode rdf:type rdf:Property ;
    rdfs:label 'Relationship Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this agency-client relationship, used in Salesforce CRM, Mediaocean Prisma, and client-facing correspondence (e.g., REL-2024-00123). Serves as the BUSINESS_IDENTIFIER for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle state of the agency-client relationship. Active indicates a live, operational engagement; pending indicates a relationship that has been agreed but not yet commenced; suspended indicates a temporary hold; terminated indicates the relationship has ended; under_review indicates a formal review or pitch process is underway. Serves as LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipTier rdf:type rdf:Property ;
    rdfs:label 'Relationship Tier' ;
    rdfs:comment 'The strategic importance tier assigned to this agency-client relationship based on revenue, strategic value, and growth potential. Strategic denotes top-tier accounts receiving dedicated senior resources; key_account denotes significant accounts; standard denotes routine engagements; emerging denotes new or high-growth potential accounts.' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date on which the agency-client relationship contract is due for renewal or renegotiation. Distinct from the effective end date; used for proactive renewal pipeline management and AOR retention tracking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Comma-delimited list of service disciplines covered under this relationship (e.g., media, creative, pr, digital, social, ooh, programmatic, sem, seo). Defines the breadth of the agency mandate and is used for competitive conflict management and scope expansion tracking. [ENUM-REF-CANDIDATE: media|creative|pr|digital|social|ooh|programmatic|sem|seo|analytics|content|influencer — promote to reference product]' ;
    rdfs:domain ind:AgencyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique surrogate identifier for each client address record in the advertising agency\'s client management system. Primary key for the client_address data product.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are used for current correspondence and billing; unverified addresses have not yet passed validation; invalid addresses failed validation checks; archived addresses are retained for historical reference only.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address by its business purpose. Billing addresses are used for invoice delivery and financial correspondence; registered_office is the legal domicile; regional_office supports geo-based audience targeting alignment; mailing is for general correspondence. [ENUM-REF-CANDIDATE: billing|shipping|registered_office|regional_office|mailing|legal — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionLine rdf:type rdf:Property ;
    rdfs:label 'Attention Line' ;
    rdfs:comment 'Specific person, department, or role name to whom correspondence at this address should be directed (e.g., \'Attn: Accounts Payable\', \'Attn: Marketing Director\'). Used for invoice delivery and legal correspondence routing within large advertiser organizations.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality name of the address. Used for geo-based audience targeting alignment, regional media planning, and Out-of-Home (OOH) and Digital Out-of-Home (DOOH) campaign geo-targeting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAddressCode rdf:type rdf:Property ;
    rdfs:label 'Crm Address Code' ;
    rdfs:comment 'External identifier for this address record in the Salesforce CRM system (Sales Cloud or Service Cloud). Enables cross-system reconciliation between the lakehouse Silver layer and the operational CRM system of record for client address data.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverabilityScore rdf:type rdf:Property ;
    rdfs:label 'Deliverability Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the confidence level that mail or deliveries sent to this address will be successfully received. Derived from postal validation services. Supports data quality governance and prioritization of address re-validation efforts.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this address record is considered valid and active for business use. Supports bi-temporal data management, enabling accurate historical reporting of client address data for audit, legal correspondence, and campaign geo-targeting alignment.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date after which this address record is no longer valid for active business use. Nullable for currently active addresses. Supports address history management, enabling accurate point-in-time queries for invoice delivery, legal correspondence, and regulatory compliance.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:erpAddressCode rdf:type rdf:Property ;
    rdfs:label 'Erp Address Code' ;
    rdfs:comment 'External identifier for this address record in SAP S/4HANA (FI module - Business Partner). Used for financial reconciliation, invoice routing, and cross-system data lineage between the lakehouse and the ERP system of record.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Indicates the structural format of the address for correct postal formatting and routing. Domestic addresses follow national postal standards; international addresses follow UPU standards; military addresses use APO/FPO/DPO formats; po_box addresses use PO Box routing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoordinates assigned to this address. Rooftop indicates exact building-level precision; range_interpolated is street-level; geometric_center is centroid of a region; approximate is low-precision. Informs the reliability of geo-based audience targeting and OOH/DOOH proximity analysis.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingDefault rdf:type rdf:Property ;
    rdfs:label 'Is Billing Default' ;
    rdfs:comment 'Indicates whether this address is the default destination for invoice and billing document delivery. Used by Mediaocean Prisma and SAP S/4HANA FI to route financial documents including Insertion Orders (IOs) and billing statements.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDoNotMail rdf:type rdf:Property ;
    rdfs:label 'Is Do Not Mail' ;
    rdfs:comment 'Indicates whether this address has been flagged to suppress physical mail correspondence, in compliance with client preferences or regulatory opt-out requirements. Supports compliance with direct mail suppression lists and client communication preferences.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the primary address for the client or contact. Only one address per client per address_type should be flagged as primary. Used to determine the default address for invoice delivery and legal correspondence.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including building number, street name, and suite or unit number. Used for invoice delivery, legal correspondence, and geo-based audience targeting alignment in campaign planning.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as floor number, building name, department, or attention line. Supplements address_line_1 for complete physical location identification.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line used for international addresses requiring additional locality or district information, or for extended address details not captured in lines 1 and 2.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBox rdf:type rdf:Property ;
    rdfs:label 'Po Box' ;
    rdfs:comment 'Post Office Box number for clients who receive mail via PO Box rather than a physical street address. Used for mailing and billing correspondence when a physical address is not applicable or preferred by the client.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the address using ISO 3166-2 subdivision codes (e.g., US-CA, GB-ENG). Supports regional media buying, regulatory compliance (CCPA for California), and geo-targeted campaign delivery.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the address was last validated against postal authority databases. Used to determine whether re-validation is required based on data freshness policies and to support audit trails for compliance with GDPR and CCPA data accuracy requirements.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the address validation service or system used to verify the address (e.g., USPS CASS, SmartyStreets, Loqate, Google Maps API). Supports audit trails and data quality governance for address accuracy.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Result of the most recent address validation check against postal authority databases. Validated addresses have been confirmed as deliverable; failed addresses contain errors; pending addresses are queued for validation. Supports data quality management for invoice delivery and legal correspondence.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientBrandAdvertiserId rdf:type rdf:Property ;
    rdfs:label 'Client Brand Advertiser Id' ;
    rdfs:comment 'Reference to the parent advertiser (client) who owns this brand. A single advertiser may own multiple brands (e.g., Unilever owns Dove, Axe, Lipton).' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:clientBrandCampaignManagerAdvertiserId rdf:type rdf:Property ;
    rdfs:label 'Client Brand Campaign Manager Advertiser Id' ;
    rdfs:comment 'The advertiser/brand identifier assigned within Google Campaign Manager 360 for ad serving, trafficking, and reporting. Required for reconciling impression delivery data and click-through reporting back to the brand.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:annualMediaBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Media Budget' ;
    rdfs:comment 'The total approved annual media spend budget allocated to this brand in the base currency. Used for budget pacing, media plan authorization, and Profit & Loss (P&L) reporting in SAP S/4HANA.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCategory rdf:type rdf:Property ;
    rdfs:label 'Brand Category' ;
    rdfs:comment 'Primary product or service category the brand competes in (e.g., Personal Care, Food & Beverage, Automotive, Financial Services). Aligns with IAB Content Taxonomy for audience targeting and competitive analysis. [ENUM-REF-CANDIDATE: Personal Care|Food & Beverage|Automotive|Financial Services|Technology|Retail|Healthcare|Entertainment|Travel|Other — promote to reference product]' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Free-text narrative describing the brand\'s identity, value proposition, target audience, and key differentiators. Used by account teams, creative teams, and media planners to ensure brand-consistent execution.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the brand\'s annual media budget (e.g., USD, EUR, GBP). Required for multi-currency financial reconciliation in SAP S/4HANA and Mediaocean Prisma.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmBrandCode rdf:type rdf:Property ;
    rdfs:label 'Crm Brand Code' ;
    rdfs:comment 'The brand\'s unique identifier in Salesforce CRM (Sales Cloud / Marketing Cloud). Enables cross-system reconciliation between the lakehouse Silver Layer and the operational CRM system of record.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damFolderCode rdf:type rdf:Property ;
    rdfs:label 'Dam Folder Code' ;
    rdfs:comment 'The folder or collection identifier in Workfront DAM (Digital Asset Management) where all creative assets for this brand are stored. Enables direct navigation from brand record to associated creative library.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyClassification rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Classification' ;
    rdfs:comment 'Privacy classification governing data collection and audience targeting practices for this brand. \'children\' applies COPPA/GDPR-K restrictions. \'sensitive\' applies enhanced consent requirements under GDPR Article 9 and CCPA. Drives audience data usage policies in the DMP/CDP.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalAdvertisingEnabled rdf:type rdf:Property ;
    rdfs:label 'Digital Advertising Enabled' ;
    rdfs:comment 'Indicates whether the brand is approved and configured for digital advertising including programmatic, paid search (PPC/SEM), and social media. Controls eligibility for The Trade Desk DSP activation and Google Campaign Manager 360 trafficking.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'The date on which the brand was officially discontinued or retired from the market. Null for active brands. Used to enforce data governance rules preventing new campaign assignments to discontinued brands.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guidelinesUrl rdf:type rdf:Property ;
    rdfs:label 'Guidelines Url' ;
    rdfs:comment 'URL pointing to the brand\'s official style guide and creative guidelines document stored in Workfront DAM or Adobe Creative Cloud. Used by creative teams to ensure brand-consistent asset production.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Iab Category Code' ;
    rdfs:comment 'The IAB Content Taxonomy category code assigned to the brand (e.g., IAB1, IAB7-25). Used for programmatic audience targeting on The Trade Desk, brand safety controls, and contextual advertising alignment.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHouseBrand rdf:type rdf:Property ;
    rdfs:label 'Is House Brand' ;
    rdfs:comment 'Indicates whether this brand is an agency house brand or proprietary brand (True) versus a client-owned advertiser brand (False). Affects revenue recognition, conflict-of-interest checks, and P&L attribution in SAP S/4HANA.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingMarkets rdf:type rdf:Property ;
    rdfs:label 'Operating Markets' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing all markets where the brand is actively sold and advertised. Used for multi-market campaign planning, regulatory compliance scoping, and global media buying via The Trade Desk.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioRank rdf:type rdf:Property ;
    rdfs:label 'Portfolio Rank' ;
    rdfs:comment 'Numeric rank of the brand within the advertiser\'s portfolio based on strategic importance and revenue contribution (1 = highest priority). Used for resource allocation, account team staffing, and Quarterly Business Review (QBR) prioritization.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMarketCountry rdf:type rdf:Property ;
    rdfs:label 'Primary Market Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the brand\'s primary operating market (e.g., USA, GBR, DEU). Drives regulatory compliance requirements (GDPR, CCPA), media planning geography, and reporting currency selection.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prismaBrandCode rdf:type rdf:Property ;
    rdfs:label 'Prisma Brand Code' ;
    rdfs:comment 'The brand identifier used in Mediaocean Prisma for media planning, buying, billing, and financial reconciliation. Ensures accurate budget allocation and invoice matching at the brand level.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticEligible rdf:type rdf:Property ;
    rdfs:label 'Programmatic Eligible' ;
    rdfs:comment 'Indicates whether the brand is approved for Real-Time Bidding (RTB) and programmatic media buying via Demand-Side Platforms (DSPs) such as The Trade Desk. Brands may be excluded due to regulatory restrictions, brand safety policies, or client preference.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restrictions' ;
    rdfs:comment 'Free-text description of any regulatory or legal advertising restrictions applicable to the brand (e.g., alcohol advertising watershed rules, pharmaceutical fair balance requirements, gambling advertising restrictions). Informs creative compliance review and media placement approvals.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Level' ;
    rdfs:comment 'The brand safety classification tier governing content adjacency restrictions for programmatic and digital media buying. Determines keyword blocklists, content category exclusions, and inventory quality thresholds applied in The Trade Desk and Google Campaign Manager 360.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subCategory rdf:type rdf:Property ;
    rdfs:label 'Sub Category' ;
    rdfs:comment 'Secondary classification within the brand category providing finer segmentation (e.g., within Personal Care: Skin Care, Hair Care, Deodorants). Supports audience insights, competitive benchmarking via Nielsen Ad Intel, and media planning.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDemographic rdf:type rdf:Property ;
    rdfs:label 'Target Demographic' ;
    rdfs:comment 'Textual description of the brand\'s primary target audience demographic (e.g., \'Adults 25-54, HHI $75K+, Urban\'). Informs audience targeting strategies in The Trade Desk, Nielsen audience measurement, and Comscore cross-platform analytics.' ;
    rdfs:domain ind:ClientBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The official public-facing website URL for the brand. Used for digital campaign trafficking, click-through destination validation in Google Campaign Manager 360, and SEO/SEM performance tracking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPersonaId rdf:type rdf:Property ;
    rdfs:label 'Target Persona Id' ;
    rdfs:comment 'Foreign key linking to audience.persona. Business justification: Briefs reference personas to guide creative strategy, messaging, and channel selection. Standard practice in advertising where personas inform campaign development beyond just segment targeting. Suppo' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Persona .

ind:brandGuidelinesVersion rdf:type rdf:Property ;
    rdfs:label 'Brand Guidelines Version' ;
    rdfs:comment 'Version identifier of the client brand guidelines document that must be adhered to for all creative executions under this brief (e.g., \'v3.2\', \'2024-Q1\'). Ensures creative compliance with current brand standards.' ;
    rdfs:domain ind:ClientBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefType rdf:type rdf:Property ;
    rdfs:label 'Brief Type' ;
    rdfs:comment 'Classification of the brief by the type of work being requested. Determines the downstream workflow and team assignment. [ENUM-REF-CANDIDATE: campaign|creative|media|pr|digital|brand_strategy — promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetIndicationAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Indication Amount' ;
    rdfs:comment 'Client-indicated total budget for the campaign or project described in this brief, expressed in the operating currency. This is a directional figure provided at brief stage, not a committed spend. Used for resource planning and scoping.' ;
    rdfs:domain ind:ClientBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignEndDate rdf:type rdf:Property ;
    rdfs:label 'Campaign End Date' ;
    rdfs:comment 'Client-requested end date for the campaign or deliverable described in the brief. Defines the desired flight window.' ;
    rdfs:domain ind:ClientBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignObjective rdf:type rdf:Property ;
    rdfs:label 'Campaign Objective' ;
    rdfs:comment 'Primary marketing objective the client wants to achieve with this campaign or project. Drives KPI selection and channel strategy. [ENUM-REF-CANDIDATE: brand_awareness|lead_generation|sales_conversion|retention|consideration|reach|engagement|app_install — promote to reference product]' ;
    rdfs:domain ind:ClientBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStartDate rdf:type rdf:Property ;
    rdfs:label 'Campaign Start Date' ;
    rdfs:comment 'Client-requested start date for the campaign or deliverable described in the brief. Represents the desired go-live date as specified by the client.' ;
    rdfs:domain ind:ClientBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelRequirements rdf:type rdf:Property ;
    rdfs:label 'Channel Requirements' ;
    rdfs:comment 'Client-specified media channels or platforms required or preferred for this campaign (e.g., CTV, DOOH, OTT, social, search, OOH, programmatic). Free-text to capture complex multi-channel requirements.' ;
    rdfs:domain ind:ClientBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date on which the brief was formally closed, either upon successful completion of all deliverables or cancellation. Null if the brief is still active. Supports lifecycle reporting and pipeline analytics.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Reason code explaining why the brief was closed. Populated when brief_status transitions to \'closed\'. Supports win/loss analysis and client relationship management.' ;
    rdfs:domain ind:ClientBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableDueDate rdf:type rdf:Property ;
    rdfs:label 'Deliverable Due Date' ;
    rdfs:comment 'Client-specified deadline by which the primary deliverable (creative, media plan, strategy deck, etc.) must be completed and delivered. May differ from campaign start date.' ;
    rdfs:domain ind:ClientBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Indicates whether the client has designated this brief as confidential, restricting access to named account team members only. Drives data access controls and document handling procedures.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryKpiTargetValue rdf:type rdf:Property ;
    rdfs:label 'Primary Kpi Target Value' ;
    rdfs:comment 'Numeric target value the client expects to achieve for the primary KPI (e.g., a CTR of 0.0250 means 2.5%, a CPM of 5.00 means $5.00 per thousand impressions). Precision to 4 decimal places supports rate-based KPIs.' ;
    rdfs:domain ind:ClientBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesforceOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Code' ;
    rdfs:comment 'Reference identifier of the associated Salesforce CRM Opportunity record, linking the brief to the revenue pipeline and account management context.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Calendar date on which the client formally submitted the brief to the agency. The principal business event date for this record.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Client Consent Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each client consent record in the advertising platform. Primary key for the client_consent_record data product.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ccpaApplicable rdf:type rdf:Property ;
    rdfs:label 'Ccpa Applicable' ;
    rdfs:comment 'Indicates whether CCPA/CPRA applies to this consent record based on the data subject\'s California residency or the processing context. True if CCPA obligations apply; False otherwise. Drives CCPA-specific opt-out and data deletion workflows.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentBasis rdf:type rdf:Property ;
    rdfs:label 'Consent Basis' ;
    rdfs:comment 'The legal basis under which consent or data processing is justified. Maps to GDPR Article 6 lawful bases (consent, legitimate interest, contract performance) or CCPA opt-out/opt-in mechanisms, or CAN-SPAM compliance. Drives regulatory reporting and audit obligations.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentProofReference rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the stored evidence of consent (e.g., screenshot of consent form, signed document ID in DAM, email confirmation message ID, API request log ID). Required for GDPR Article 7(1) demonstrability. May reference a Workfront DAM asset or document management system record.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Reference Number' ;
    rdfs:comment 'Externally-visible alphanumeric reference number assigned to this consent record, used in regulatory correspondence, audit trails, and data subject access requests. Format: CNS- followed by 8–16 alphanumeric characters.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Classification of the specific consent category captured. Distinguishes between marketing communications consent, data processing consent, third-party data sharing consent, profiling, retargeting, and analytics use. [ENUM-REF-CANDIDATE: marketing_communications|data_processing|third_party_sharing|profiling|retargeting|analytics — promote to reference product if additional types are required]' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the privacy notice, consent form, or cookie banner under which this consent was obtained (e.g., v1.0, v2.3). Enables tracking of consent obtained under different notice versions for regulatory audit and re-consent workflows when notices are updated.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmConsentRecordCode rdf:type rdf:Property ;
    rdfs:label 'Crm Consent Record Code' ;
    rdfs:comment 'The native record identifier for this consent record in Salesforce CRM (Marketing Cloud or Service Cloud). Enables bi-directional synchronisation between the lakehouse silver layer and the operational CRM system of record for consent management.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategoriesCovered rdf:type rdf:Property ;
    rdfs:label 'Data Categories Covered' ;
    rdfs:comment 'Comma-separated list or structured description of the personal data categories covered by this consent record (e.g., \'email address, browsing behaviour, device identifiers, location data\'). Required for GDPR Article 13/14 transparency and maps to IAB TCF data category definitions.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Data Subject Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code representing the jurisdiction of the data subject at the time consent was captured. Determines which regulatory framework (GDPR, CCPA, LGPD, PIPEDA, etc.) governs this consent record and associated data processing obligations.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Indicates whether the consent was confirmed via a double opt-in mechanism (e.g., email confirmation link clicked). True if double opt-in confirmation was received. Provides stronger demonstrability of consent under GDPR Article 7 and is required for certain marketing communication channels.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInDate rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Date' ;
    rdfs:comment 'The precise date and time at which the double opt-in confirmation was received (e.g., confirmation link clicked). Null if double opt-in was not used or not yet confirmed. Supports audit trail for GDPR Article 7 demonstrability.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether GDPR applies to this consent record based on the data subject\'s jurisdiction or the processing context. True if GDPR obligations apply; False otherwise. Drives GDPR-specific processing rules and data subject rights workflows.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iabTcfConsentString rdf:type rdf:Property ;
    rdfs:label 'Iab Tcf Consent String' ;
    rdfs:comment 'The encoded IAB TCF v2.2 consent string representing the data subject\'s vendor and purpose consent selections. Used by DSPs, SSPs, and DMPs to enforce consent downstream in programmatic advertising supply chains. Null for non-digital or non-programmatic consent records.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabTcfVersion rdf:type rdf:Property ;
    rdfs:label 'Iab Tcf Version' ;
    rdfs:comment 'Version of the IAB Transparency and Consent Framework under which the TCF consent string was generated. Required for correct decoding and downstream enforcement of the consent string in programmatic advertising systems.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Flag' ;
    rdfs:comment 'Indicates whether the consent record represents an affirmative opt-in (True) or an opt-out election (False). Distinguishes between opt-in consent models (GDPR default) and opt-out models (CCPA default). Critical for determining permissible data processing activities.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyNoticeUrl rdf:type rdf:Property ;
    rdfs:label 'Privacy Notice Url' ;
    rdfs:comment 'URL of the privacy notice or consent form presented to the data subject at the time consent was captured. Provides an auditable link to the exact notice version shown, supporting GDPR Article 13/14 transparency and demonstrability requirements.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'Specific, granular description of the data processing activity for which consent was obtained, as required by GDPR Article 13/14 transparency obligations. Examples include: \'Delivery of targeted programmatic advertising via DSP\', \'Audience segmentation for lookalike modelling\', \'Cross-channel attribution reporting\'. Free-text field aligned to the IAB TCF purpose taxonomy.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalReminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Sent Date' ;
    rdfs:comment 'Date on which the most recent consent renewal reminder communication was sent to the data subject. Supports consent lifecycle management workflows and prevents inadvertent processing of expired consent.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this consent record requires active renewal before the expiry_date. True triggers automated re-consent workflow in Salesforce Marketing Cloud. Supports proactive consent lifecycle management to prevent lapses in permissible data processing.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionListFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression List Flag' ;
    rdfs:comment 'Indicates whether this contact/advertiser is currently on a marketing suppression list as a result of this consent record (e.g., following opt-out or withdrawal). True means the contact must be excluded from all marketing communications. Enforced in Salesforce Marketing Cloud and campaign execution systems.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyVendorName rdf:type rdf:Property ;
    rdfs:label 'Third Party Vendor Name' ;
    rdfs:comment 'Name of the third-party vendor or partner organisation with whom data may be shared under this consent record (applicable when consent_type is \'third_party_sharing\'). Supports IAB TCF vendor list alignment and GDPR Article 28 data processor obligations.' ;
    rdfs:domain ind:ClientConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountRole rdf:type rdf:Property ;
    rdfs:label 'Account Role' ;
    rdfs:comment 'The contact\'s strategic role in the client account relationship as classified by the account management team. Used for stakeholder mapping, Account-Based Marketing (ABM) targeting, and relationship health scoring.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactSource rdf:type rdf:Property ;
    rdfs:label 'Contact Source' ;
    rdfs:comment 'The originating channel or method through which this contact was first acquired or entered into the CRM system. Used for relationship provenance tracking and business development analytics.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Indicates whether the contact is actively engaged, temporarily unavailable, or has left the client organisation. Drives CRM hygiene and suppression logic.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Functional classification of the contact\'s role in the client relationship (e.g., primary day-to-day contact, billing approver, legal signatory, technical integration contact). Drives workflow routing for insertion orders, statements of work, and campaign approvals.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'Source system identifier for this contact record in Salesforce CRM (Sales Cloud / Service Cloud). Used for lineage tracing and cross-system reconciliation with the operational system of record.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Flag' ;
    rdfs:comment 'Indicates whether an active data subject request (e.g., right of access, right to erasure, right to rectification) has been submitted by or on behalf of this contact. True = active DSR in progress. Triggers data handling restrictions.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departedDate rdf:type rdf:Property ;
    rdfs:label 'Departed Date' ;
    rdfs:comment 'Date on which the contact left their role at the client organisation or was otherwise deactivated. Null for active contacts. Used to manage record lifecycle, suppress communications, and trigger successor identification workflows.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Business department or functional unit the contact belongs to within their organisation (e.g., Marketing, Procurement, Legal, Finance). Used to segment contacts for targeted communications and account planning.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact. Used for campaign briefings, insertion order delivery, reporting distribution, and all formal client communications. SSOT sourced from Salesforce CRM.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given (first) name of the client-side contact individual as recorded in Salesforce CRM. Used for personalised communications, salutations, and account team relationship management.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full display name of the contact (typically first_name + last_name) as stored in Salesforce CRM. Used as the canonical human-readable label for the contact across reporting, dashboards, and client-facing documents.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date on which the contact granted or last updated their GDPR consent. Required for audit and compliance demonstration under GDPR Article 7(1). Null if consent has not been collected or is not applicable.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR consent status for processing this contact\'s personal data for marketing and communications purposes. Mandatory for contacts in EU/EEA jurisdictions. Drives suppression and opt-in logic.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingContact rdf:type rdf:Property ;
    rdfs:label 'Is Billing Contact' ;
    rdfs:comment 'Indicates whether this contact is authorised to receive and approve invoices, purchase orders, and financial reconciliation documents. True = billing contact. Used by finance teams for invoice routing and payment approval workflows.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLegalSignatory rdf:type rdf:Property ;
    rdfs:label 'Is Legal Signatory' ;
    rdfs:comment 'Indicates whether this contact has authority to sign contracts, statements of work (SOW), insertion orders (IO), and other legally binding documents on behalf of the client organisation.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title of the contact at their organisation (e.g., Marketing Director, Brand Manager, Procurement Lead, Finance Approver). Drives routing logic for proposals, insertion orders, and campaign approvals.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent recorded interaction (call, email, meeting, or campaign review) between the agency and this contact. Used to identify at-risk relationships and trigger re-engagement workflows.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family (last) name of the client-side contact individual as recorded in Salesforce CRM. Combined with first_name to form the full display name for reporting and correspondence.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL of the contact\'s LinkedIn professional profile. Used by account management and business development teams for relationship intelligence, stakeholder mapping, and pre-meeting research.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt Out Flag' ;
    rdfs:comment 'Indicates whether the contact has opted out of receiving marketing and promotional communications from the agency. True = opted out. Applies globally across all channels and overrides channel-specific preferences.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile phone number for the contact in E.164 international format. Supports SMS-based communications, two-factor authentication for portal access, and urgent out-of-hours escalations.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recently recorded Net Promoter Score (NPS) provided by this contact in a client satisfaction survey. Integer value from 0 to 10. Used to measure relationship health and identify promoters, passives, and detractors.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date on which the most recent NPS survey response was collected from this contact. Used to determine the currency of the NPS score and schedule the next survey cycle.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business phone number for the contact in E.164 international format. Used for urgent campaign escalations, account management calls, and QBR scheduling.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s stated preferred channel for receiving communications from the agency. Drives outreach strategy for account managers and ensures client satisfaction by respecting communication preferences.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date on which the agency\'s relationship with this contact was formally established or the contact was first recorded in the CRM. Used for relationship tenure analysis and loyalty recognition in QBRs.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondaryEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Email' ;
    rdfs:comment 'Alternate or personal business email address for the contact. Used as a fallback communication channel when the primary email is undeliverable or the contact is out of office.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each client interaction record in the Silver layer. Primary key for the client_interaction data product.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionFollowUpOwnerWorkerId rdf:type rdf:Property ;
    rdfs:label 'Interaction Follow Up Owner Worker Id' ;
    rdfs:comment 'Reference to the agency staff member responsible for completing the follow-up actions arising from this interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:interactionWorkerId rdf:type rdf:Property ;
    rdfs:label 'Interaction Worker Id' ;
    rdfs:comment 'Reference to the primary agency-side account manager or relationship owner who led or logged this interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:agencyAttendees rdf:type rdf:Property ;
    rdfs:label 'Agency Attendees' ;
    rdfs:comment 'Comma-separated list of agency staff names or employee IDs who participated in the interaction. Captures the full agency-side attendance roster beyond the primary account manager.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agenda rdf:type rdf:Property ;
    rdfs:label 'Agenda' ;
    rdfs:comment 'Pre-interaction agenda or discussion topics as prepared by the account team. Supports meeting preparation, QBR structuring, and relationship planning.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessTopic rdf:type rdf:Property ;
    rdfs:label 'Business Topic' ;
    rdfs:comment 'Primary business topic or purpose of the interaction. Categorises the interaction by its strategic business function to support analytics and relationship health reporting. [ENUM-REF-CANDIDATE: campaign_review|media_planning|creative_review|budget_discussion|contract_renewal|new_business|reporting|escalation|onboarding|strategy|compliance — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAttendees rdf:type rdf:Property ;
    rdfs:label 'Client Attendees' ;
    rdfs:comment 'Comma-separated list of client-side participant names or contact IDs who attended the interaction. Captures the full client attendance roster beyond the primary contact.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSentiment rdf:type rdf:Property ;
    rdfs:label 'Client Sentiment' ;
    rdfs:comment 'Account manager\'s qualitative assessment of client sentiment observed during the interaction. Supports relationship health monitoring, NPS tracking, and early warning of at-risk accounts.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmActivityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Activity Code' ;
    rdfs:comment 'Source system identifier from Salesforce CRM Activity or Task object. Used for lineage tracing and reconciliation with the operational system of record.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRegion rdf:type rdf:Property ;
    rdfs:label 'Data Region' ;
    rdfs:comment 'Geographic data residency region for this interaction record, used for GDPR, CCPA, and cross-border data transfer compliance. Determines applicable regulatory framework.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the interaction was initiated by the client (inbound) or by the agency (outbound). Used for relationship health analysis and proactive engagement tracking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Actual or estimated duration of the interaction in minutes, as logged by the account manager. Supports relationship effort analysis and resource planning.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Precise date and time when the interaction concluded. Used in conjunction with interaction_start_timestamp to compute interaction duration.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpActions rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions' ;
    rdfs:comment 'Documented next steps, action items, or commitments arising from the interaction. Supports task management, accountability tracking, and client relationship continuity.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which the follow-up actions from this interaction must be completed. Used for SLA monitoring and account team accountability.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Obtained' ;
    rdfs:comment 'Indicates whether explicit consent was obtained from client contacts for recording, data processing, or follow-up communications arising from this interaction, as required under GDPR.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'The calendar date on which the interaction occurred or is scheduled to occur. Used for day-level reporting, relationship cadence analysis, and NPS tracking timelines.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the interaction record. Indicates whether the interaction has been completed, is upcoming, was cancelled, or the client did not attend.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the business interaction format. Covers the primary interaction modalities used in agency-client relationship management. Quarterly Business Review (QBR) is a formal structured review. [ENUM-REF-CANDIDATE: meeting|call|email|presentation|qbr|site_visit|workshop|webinar — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEscalation rdf:type rdf:Property ;
    rdfs:label 'Is Escalation' ;
    rdfs:comment 'Indicates whether this interaction was triggered by or resulted in a client escalation. Used for relationship risk monitoring and account health dashboards.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQbr rdf:type rdf:Property ;
    rdfs:label 'Is Qbr' ;
    rdfs:comment 'Indicates whether this interaction is a formal Quarterly Business Review (QBR) session. QBRs are structured strategic reviews between agency leadership and senior client stakeholders.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location of the interaction. For in-person meetings, this is the venue or office address. For virtual meetings, this may be the video conference URL or platform name (e.g., Zoom, Teams).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityCode rdf:type rdf:Property ;
    rdfs:label 'Opportunity Code' ;
    rdfs:comment 'Reference to the Salesforce CRM Opportunity linked to this interaction, if the interaction is associated with an active pitch, proposal, or new business pursuit.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcomeSummary rdf:type rdf:Property ;
    rdfs:label 'Outcome Summary' ;
    rdfs:comment 'Narrative summary of the interaction outcome, key discussion points, decisions made, and client sentiment as recorded by the account manager post-interaction. Sourced from Salesforce CRM Activity Description/Comments field.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationUrl rdf:type rdf:Property ;
    rdfs:label 'Presentation Url' ;
    rdfs:comment 'URL or DAM (Digital Asset Management) link to the presentation deck or materials shared during the interaction. Supports knowledge management and account continuity.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingUrl rdf:type rdf:Property ;
    rdfs:label 'Recording Url' ;
    rdfs:comment 'URL link to the recorded video or audio of the interaction (e.g., Zoom, Teams recording). Applicable for virtual meetings where recording consent was obtained. Confidential as it may contain sensitive business discussions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Precise date and time when the interaction began. Provides sub-day precision for scheduling, duration calculation, and time-zone-aware reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Short descriptive title or subject line of the interaction, as recorded in Salesforce CRM. Equivalent to the Subject field on the Salesforce Activity/Task object.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryClientWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Client Worker Id' ;
    rdfs:comment 'Reference to the employee responsible for coordinating and managing the onboarding process end-to-end.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:workfrontProjectInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Workfront Project Initiative Id' ;
    rdfs:comment 'Unique identifier for the onboarding project in Workfront, used to track tasks, milestones, and resource allocation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:analyticsDashboardCreatedFlag rdf:type rdf:Property ;
    rdfs:label 'Analytics Dashboard Created Flag' ;
    rdfs:comment 'Indicates whether the client-specific analytics dashboard has been created in Google Analytics or other reporting platforms for campaign performance tracking.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analyticsDashboardCreationDate rdf:type rdf:Property ;
    rdfs:label 'Analytics Dashboard Creation Date' ;
    rdfs:comment 'Date when the analytics dashboard was configured and made accessible to the client and account team.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingCodeCreatedFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Code Created Flag' ;
    rdfs:comment 'Indicates whether the client billing code has been successfully created in SAP S/4HANA FI module for invoicing and revenue recognition.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCodeCreationDate rdf:type rdf:Property ;
    rdfs:label 'Billing Code Creation Date' ;
    rdfs:comment 'Date when the billing code was created in the ERP system, enabling financial transactions for this client.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockerResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Blocker Resolution Date' ;
    rdfs:comment 'Date when identified blockers were resolved, allowing the onboarding process to resume normal progression.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockersDescription rdf:type rdf:Property ;
    rdfs:label 'Blockers Description' ;
    rdfs:comment 'Detailed description of any impediments, delays, or issues preventing progression of the onboarding process.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandGuidelinesReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Guidelines Received Flag' ;
    rdfs:comment 'Indicates whether the client has provided comprehensive brand guidelines including logos, color palettes, typography, and usage rules.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditApplicationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Application Received Flag' ;
    rdfs:comment 'Indicates whether the credit application has been submitted and approved, establishing payment terms and credit limits.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:damAccessProvisionedDate rdf:type rdf:Property ;
    rdfs:label 'Dam Access Provisioned Date' ;
    rdfs:comment 'Date when DAM access credentials and folder structure were established for the client.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:damAccessProvisionedFlag rdf:type rdf:Property ;
    rdfs:label 'Dam Access Provisioned Flag' ;
    rdfs:comment 'Indicates whether client access to the Digital Asset Management system has been configured for brand asset storage and retrieval.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoffFromSalesDate rdf:type rdf:Property ;
    rdfs:label 'Handoff From Sales Date' ;
    rdfs:comment 'Date when the account was formally transitioned from the sales team to the account management and onboarding team.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kickoffDate rdf:type rdf:Property ;
    rdfs:label 'Kickoff Date' ;
    rdfs:comment 'Date when the formal onboarding process was initiated, typically following contract signature and sales handoff.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaAuthorizationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Media Authorization Received Flag' ;
    rdfs:comment 'Indicates whether media buying authorization forms have been received, granting permission to place media on behalf of the client.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msaSignedFlag rdf:type rdf:Property ;
    rdfs:label 'Msa Signed Flag' ;
    rdfs:comment 'Indicates whether the Master Service Agreement has been fully executed by both parties, establishing the legal framework for services.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current lifecycle status of the onboarding process. Tracks progression from initiation through operational readiness.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingType rdf:type rdf:Property ;
    rdfs:label 'Onboarding Type' ;
    rdfs:comment 'Classification of the onboarding engagement based on the nature of the client relationship being established.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postOnboardingSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Post Onboarding Satisfaction Score' ;
    rdfs:comment 'Client satisfaction rating collected after onboarding completion, typically on a scale of 1-10, measuring the onboarding experience quality.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postOnboardingSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Post Onboarding Survey Date' ;
    rdfs:comment 'Date when the post-onboarding satisfaction survey was completed by the client or primary contact.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectManagementSetupDate rdf:type rdf:Property ;
    rdfs:label 'Project Management Setup Date' ;
    rdfs:comment 'Date when the project management workspace was configured and made available to the account team.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectManagementSetupFlag rdf:type rdf:Property ;
    rdfs:label 'Project Management Setup Flag' ;
    rdfs:comment 'Indicates whether the client workspace has been provisioned in Workfront or Monday.com for campaign project management and collaboration.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Business-facing unique reference code for this onboarding engagement, used in communications and tracking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Service level tier assigned to this client, determining resource allocation, response times, and support levels during and post-onboarding.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Days' ;
    rdfs:comment 'Number of business days allocated for completing the onboarding process per service level agreement commitments.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:w9W8benReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'W9 W8ben Received Flag' ;
    rdfs:comment 'Indicates whether the required IRS tax form (W-9 for US entities or W-8BEN for foreign entities) has been received and validated.' ;
    rdfs:domain ind:ClientOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Approval Turnaround Days' ;
    rdfs:comment 'Number of business days the client requires to review and approve submitted materials (creative, media plans, insertion orders). Used to set SLA expectations and project timelines in Workfront.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceDataUsageAllowed rdf:type rdf:Property ;
    rdfs:label 'Audience Data Usage Allowed' ;
    rdfs:comment 'Indicates whether the client permits the agency to use their first-party audience data for targeting, lookalike modelling, or cross-campaign analytics. Governs use of client data in DMP/CDP platforms.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetAlertThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Budget Alert Threshold Pct' ;
    rdfs:comment 'Percentage of campaign budget consumption at which the agency should proactively alert the client. For example, a value of 80.00 means the client is notified when 80% of the approved budget has been spent.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveReportingAllowed rdf:type rdf:Property ;
    rdfs:label 'Competitive Reporting Allowed' ;
    rdfs:comment 'Indicates whether the client permits the agency to include their campaign data in aggregated competitive intelligence reports (e.g., Share of Voice analysis using Nielsen Ad Intel). Some clients restrict inclusion in benchmarking studies.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCaptureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Capture Timestamp' ;
    rdfs:comment 'The date and time at which the client\'s data sharing consent (GDPR/CCPA) was formally captured or last updated. Required for regulatory audit trails demonstrating lawful basis for data processing.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creativeApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Creative Approval Required' ;
    rdfs:comment 'Indicates whether the client requires formal approval of all creative assets before trafficking and delivery. When true, creative assets must pass through the client approval workflow in Workfront before being trafficked in Google Campaign Manager 360.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmRecordCode rdf:type rdf:Property ;
    rdfs:label 'Crm Record Code' ;
    rdfs:comment 'The unique identifier of the corresponding client preference or contact record in Salesforce CRM (Sales Cloud or Service Cloud). Enables bidirectional synchronisation between the lakehouse Silver Layer and the operational CRM system.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsentCcpa rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Ccpa' ;
    rdfs:comment 'Indicates whether the client has opted in or out of data sharing under CCPA regulations. A value of false indicates the client has exercised their right to opt out of the sale or sharing of personal information.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingConsentGdpr rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Gdpr' ;
    rdfs:comment 'Indicates whether the client has provided consent for the agency to share their data with third-party partners and platforms under GDPR requirements. Must be captured and honoured for all clients operating in EU/EEA jurisdictions.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Fraud Verification Required' ;
    rdfs:comment 'Indicates whether the client mandates third-party ad fraud verification (e.g., IAS, DoubleVerify, MOAT) on all programmatic and digital campaigns. When true, fraud verification tags must be applied in Google Campaign Manager 360 trafficking.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceFormat rdf:type rdf:Property ;
    rdfs:label 'Invoice Format' ;
    rdfs:comment 'Preferred electronic or physical format for invoice documents. Supports structured e-invoicing standards (EDI X12, UBL) as well as traditional PDF and CSV formats per client procurement requirements.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Io Approval Required' ;
    rdfs:comment 'Indicates whether the client requires explicit approval of each Insertion Order (IO) before media commitments are finalized. Governs the IO sign-off workflow in Mediaocean Prisma.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaPlanApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Media Plan Approval Required' ;
    rdfs:comment 'Indicates whether the client requires formal sign-off on media plans before buying activity commences. When true, media plans must be approved before Insertion Orders (IOs) are executed in Mediaocean Prisma.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pacingAlertEnabled rdf:type rdf:Property ;
    rdfs:label 'Pacing Alert Enabled' ;
    rdfs:comment 'Indicates whether the client has opted in to receive automated campaign pacing alerts when delivery is tracking significantly above or below the planned schedule. Drives alert configuration in The Trade Desk and Google Campaign Manager 360.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceScope rdf:type rdf:Property ;
    rdfs:label 'Preference Scope' ;
    rdfs:comment 'Indicates whether this preference record applies at the advertiser account level or at an individual contact level. Drives how the preference is applied during client engagement workflows.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of this preference record. \'active\' means the preference is in force; \'superseded\' means a newer record has replaced it; \'pending_review\' means awaiting client confirmation.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the client\'s preferred billing and reporting currency (e.g., \'USD\', \'EUR\', \'GBP\'). Used in SAP S/4HANA FI and Mediaocean Prisma for invoice generation and budget reporting.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDsp rdf:type rdf:Property ;
    rdfs:label 'Preferred Dsp' ;
    rdfs:comment 'The client\'s preferred or mandated Demand-Side Platform (DSP) for programmatic media buying (e.g., \'The Trade Desk\', \'DV360\', \'Amazon DSP\'). Governs platform selection during media planning in Mediaocean Prisma.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredKpiSet rdf:type rdf:Property ;
    rdfs:label 'Preferred Kpi Set' ;
    rdfs:comment 'Comma-separated list or named KPI template identifying the client\'s primary campaign performance metrics for reporting (e.g., \'CTR,CPA,ROAS,VTR\'). Drives default dashboard configuration and report templates. [ENUM-REF-CANDIDATE: CTR|CPA|ROAS|VTR|CPM|CPC|GRP|TRP|SOV|ROI — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'IETF BCP 47 language tag representing the client\'s preferred language for all agency communications, reports, and documents (e.g., \'en-US\', \'fr-FR\', \'de-DE\'). Enables localized service delivery.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredMeetingFormat rdf:type rdf:Property ;
    rdfs:label 'Preferred Meeting Format' ;
    rdfs:comment 'Client\'s preferred format for scheduled meetings such as Quarterly Business Reviews (QBRs), campaign briefings, and creative reviews. Informs account team logistics planning.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTimezone rdf:type rdf:Property ;
    rdfs:label 'Preferred Timezone' ;
    rdfs:comment 'IANA time zone identifier representing the client\'s local time zone (e.g., \'America/New_York\', \'Europe/London\'). Used to schedule meetings, report delivery, and campaign flight times in the client\'s local context.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDeliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Report Delivery Channel' ;
    rdfs:comment 'The channel through which campaign performance reports and analytics outputs are delivered to the client. Supports automated distribution via email, client portal, API push, or SFTP file transfer.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyDataSharingAllowed rdf:type rdf:Property ;
    rdfs:label 'Third Party Data Sharing Allowed' ;
    rdfs:comment 'Indicates whether the client permits the agency to share campaign data, audience segments, or performance data with third-party vendors such as DSPs, DMPs, or CDPs. Governs data flows to platforms like The Trade Desk.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approverEmployeeWorkerId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Worker Id' ;
    rdfs:comment 'Reference to the employee (typically a Managing Director or Finance Business Partner) who approved this revenue target. Supports audit trail and governance requirements for P&L sign-off.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:primaryRevenueWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Revenue Worker Id' ;
    rdfs:comment 'Reference to the account director or senior account manager who owns and is accountable for achieving this revenue target. Used for performance management, QBR accountability, and Workday HCM talent performance review alignment.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:accountGrowthRatePct rdf:type rdf:Property ;
    rdfs:label 'Account Growth Rate Pct' ;
    rdfs:comment 'The year-over-year or period-over-period percentage growth rate embedded in this target relative to the prior comparable period\'s target. Expressed as a decimal (e.g., 0.1500 = 15%). Used in account growth planning and QBR target-setting rationale.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedSowCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Contracted Sow Coverage Pct' ;
    rdfs:comment 'The proportion of the revenue target already covered by signed Statements of Work (SOW) or Insertion Orders (IO) at the time of target setting or last update. Expressed as a decimal (e.g., 0.6500 = 65%). Supports pipeline risk assessment and P&L confidence scoring.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCentreCode rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Code' ;
    rdfs:comment 'SAP S/4HANA CO cost centre code to which this revenue target is allocated for internal P&L management and financial reporting. Enables drill-down from agency-level P&L to individual account team cost centres.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter to which this target applies (Q1–Q4). Populated when target_period_type is \'quarterly\'; null for annual targets. Used in QBR preparation and quarterly pacing analysis.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The four-digit fiscal year to which this revenue target applies (e.g., 2025). Aligns with the SAP S/4HANA FI fiscal year calendar for P&L management and budget reconciliation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRateApplied rdf:type rdf:Property ;
    rdfs:label 'Fx Rate Applied' ;
    rdfs:comment 'The exchange rate used to convert target_amount to target_amount_usd at the time of target creation or last revision. Stored for auditability and variance analysis when FX rates fluctuate during the target period.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isStretchTarget rdf:type rdf:Property ;
    rdfs:label 'Is Stretch Target' ;
    rdfs:comment 'Indicates whether this target is designated as a stretch (aspirational) target above the base committed target. True = stretch target used for incentive compensation modelling; False = base committed target used for P&L planning. Supports Workday HCM talent performance review and bonus calculation.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Original Target Amount' ;
    rdfs:comment 'The initial revenue target amount set at the start of the period before any revisions. Preserved for variance analysis comparing original plan vs. revised plan vs. actual billed revenue. Populated only when revision_number > 0.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The calendar date on which the revenue target period ends. Defines the boundary for target attainment measurement and QBR reporting cycles.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The calendar date on which the revenue target period begins. Used to align target pacing with actual billed revenue from the finance domain and to support time-series analytics.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipelineAmount rdf:type rdf:Property ;
    rdfs:label 'Pipeline Amount' ;
    rdfs:comment 'The total value of identified but not yet contracted revenue opportunities in the Salesforce CRM pipeline that are expected to contribute to this target. Distinct from target_amount (the committed plan) and actual billed revenue. Supports gap-to-target analysis.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCentreCode rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Code' ;
    rdfs:comment 'SAP S/4HANA CO profit centre code associated with this revenue target, enabling segment-level P&L reporting by business unit, geography, or service line. Supports EBITDA reporting and management accounting.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roasTarget rdf:type rdf:Property ;
    rdfs:label 'Roas Target' ;
    rdfs:comment 'The target Return on Ad Spend (ROAS) ratio associated with this revenue target, where applicable (primarily for performance-based media service lines). Expressed as a multiplier (e.g., 4.0000 = $4 revenue per $1 ad spend). Used in digital performance optimization and KPI alignment with The Trade Desk programmatic buying.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLine rdf:type rdf:Property ;
    rdfs:label 'Service Line' ;
    rdfs:comment 'The agency service line to which this revenue target is attributed: media (Media Planning and Buying), creative (Creative Development and Production), digital (Digital Marketing and Performance Optimization), pr (Public Relations and Communications), analytics (Data Analytics and Audience Insights), strategy (Brand Strategy and Positioning). Enables service-line-level P&L reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAmount rdf:type rdf:Property ;
    rdfs:label 'Target Amount' ;
    rdfs:comment 'The gross or net revenue target value set for the advertiser account for the specified period and service line, expressed in the currency defined by currency_code. This is the planned figure; actual billed revenue is owned by the finance domain. Core input for P&L management and account growth planning.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Target Amount Usd' ;
    rdfs:comment 'The revenue target amount converted to US Dollars (USD) using the exchange rate applied at the time of target setting. Enables cross-currency portfolio aggregation and global P&L reporting without requiring runtime FX conversion.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this revenue target record, used in Quarterly Business Review (QBR) reporting, P&L management, and cross-system reconciliation with SAP S/4HANA CO module.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable label for this revenue target, typically combining the advertiser name, service line, and target period (e.g., \'Acme Corp — Media — FY2025 Q1\'). Used in QBR decks and account growth planning documents.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOwnerName rdf:type rdf:Property ;
    rdfs:label 'Target Owner Name' ;
    rdfs:comment 'Display name of the account director or account manager who owns this revenue target. Stored denormalized for reporting convenience in QBR decks and P&L dashboards without requiring a join to the talent domain.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPeriodType rdf:type rdf:Property ;
    rdfs:label 'Target Period Type' ;
    rdfs:comment 'Granularity of the target period: annual (full fiscal year), quarterly (fiscal quarter), or monthly (calendar month). Determines how the target_amount is interpreted and how actuals are paced against it in QBR reporting.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSettingMethod rdf:type rdf:Property ;
    rdfs:label 'Target Setting Method' ;
    rdfs:comment 'The methodology used to derive this revenue target: top_down (allocated from agency-level P&L plan), bottom_up (built from individual campaign and SOW estimates), negotiated (agreed bilaterally with client), market_indexed (benchmarked against market growth indices such as Nielsen Ad Intel competitive data).' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Classification of the revenue target by income recognition method: gross_revenue (total billings before agency commission deduction), net_revenue (billings net of media costs), fee_income (project or retainer fees), commission_income (media commission earned), retainer_fee (recurring fixed-fee arrangement). Drives P&L line allocation in SAP S/4HANA FI.' ;
    rdfs:domain ind:RevenueTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abmEligible rdf:type rdf:Property ;
    rdfs:label 'Abm Eligible' ;
    rdfs:comment 'Indicates whether advertisers in this segment are eligible for Account-Based Marketing (ABM) programs. ABM-eligible segments receive dedicated content personalization, targeted outreach, and bespoke pitch strategies. Drives campaign targeting logic in Salesforce Marketing Cloud.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'External identifier for this segment as recorded in Salesforce CRM Sales Cloud. Enables bidirectional synchronization between the Databricks Silver Layer and the CRM system of record for account assignment and pipeline reporting.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyTier rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Tier' ;
    rdfs:comment 'Privacy compliance tier applied to data handling for advertisers in this segment. Standard applies baseline CCPA/GDPR controls; Enhanced applies additional consent management; Strict applies maximum data minimization and opt-in requirements for regulated industries (e.g., healthcare, finance).' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedAccountTeamRequired rdf:type rdf:Property ;
    rdfs:label 'Dedicated Account Team Required' ;
    rdfs:comment 'Indicates whether advertisers in this segment require a dedicated account management team (as opposed to a pooled or shared service model). Drives FTE (Full-Time Equivalent) resource planning in Workday HCM and Workfront capacity management.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iabIndustryVerticalCode rdf:type rdf:Property ;
    rdfs:label 'Iab Industry Vertical Code' ;
    rdfs:comment 'IAB Content Taxonomy category code representing the industry vertical classification of advertisers within this segment (e.g., IAB3 for Business, IAB19 for Technology). Used for competitive analysis, audience targeting alignment, and industry benchmarking via Nielsen Ad Intel and Comscore.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabIndustryVerticalName rdf:type rdf:Property ;
    rdfs:label 'Iab Industry Vertical Name' ;
    rdfs:comment 'Human-readable label corresponding to the IAB industry vertical code assigned to this segment (e.g., Automotive, Financial Services, Retail). Supports executive reporting, pitch targeting, and ABM (Account-Based Marketing) strategy alignment.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimarySegment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Segment' ;
    rdfs:comment 'Indicates whether this segment record represents the primary (active) segment assignment for an advertiser at a given point in time. Enforces the business rule that each advertiser is assigned to exactly one primary segment at any point in time. Used in deduplication logic and point-in-time reporting.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minAnnualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Min Annual Spend Usd' ;
    rdfs:comment 'Minimum annual media and campaign spend (in USD) expected from advertisers assigned to this segment. Used in revenue forecasting, P&L (Profit and Loss) planning, and EBITDA (Earnings Before Interest, Taxes, Depreciation, and Amortization) modeling in SAP S/4HANA.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Corporate email address of the segment owner used for automated review notifications, QBR scheduling, and escalation workflows. Classified as confidential as it identifies an internal employee.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the internal business owner (typically a Group Account Director or VP of Client Services) responsible for the segment definition, criteria governance, and periodic review. Referenced in Salesforce CRM and Workfront for accountability tracking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryChannelMix rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Mix' ;
    rdfs:comment 'Comma-separated list of primary advertising channels typically utilized by advertisers in this segment (e.g., CTV, DOOH, PPC, OTT, SEM). Informs media planning defaults in Mediaocean Prisma and programmatic buying strategies in The Trade Desk.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticBuyingEligible rdf:type rdf:Property ;
    rdfs:label 'Programmatic Buying Eligible' ;
    rdfs:comment 'Indicates whether advertisers in this segment are eligible for programmatic media buying via DSP (Demand-Side Platform) channels such as The Trade Desk. Drives RTB (Real-Time Bidding) activation and audience targeting configuration.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueThresholdMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold Max Usd' ;
    rdfs:comment 'Maximum annual advertiser revenue (in USD) for assignment to this segment. Defines the upper bound of the revenue tier. Null for the highest tier (Enterprise) where no upper cap applies. Used in conjunction with revenue_threshold_min_usd for tier boundary enforcement.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueThresholdMinUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold Min Usd' ;
    rdfs:comment 'Minimum annual advertiser revenue (in USD) required for assignment to this segment. Defines the lower bound of the revenue tier used in segmentation scoring methodology. Used in SAP S/4HANA financial reconciliation and revenue forecasting models.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCadence rdf:type rdf:Property ;
    rdfs:label 'Review Cadence' ;
    rdfs:comment 'Frequency at which the segment definition, criteria, and advertiser assignments are formally reviewed and validated. Quarterly cadence aligns with QBR (Quarterly Business Review) cycles. Drives automated review scheduling in Workfront.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoringMethodology rdf:type rdf:Property ;
    rdfs:label 'Scoring Methodology' ;
    rdfs:comment 'Description of the scoring model or criteria used to classify advertisers into this segment (e.g., RFM scoring, revenue-only threshold, composite score including spend velocity, strategic fit, and growth potential). Documents the business rules applied during segment assignment for auditability and QBR review.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoringWeightGrowthPotential rdf:type rdf:Property ;
    rdfs:label 'Scoring Weight Growth Potential' ;
    rdfs:comment 'Percentage weight (0.00–100.00) assigned to the growth potential dimension in the composite segmentation scoring model. Reflects the advertiser\'s projected spend trajectory, market expansion signals, and new product adoption likelihood.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoringWeightRevenue rdf:type rdf:Property ;
    rdfs:label 'Scoring Weight Revenue' ;
    rdfs:comment 'Percentage weight (0.00–100.00) assigned to the revenue dimension in the composite segmentation scoring model. Reflects the relative importance of advertiser revenue versus other scoring dimensions (strategic fit, growth potential). Used to calibrate segment assignment consistency.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoringWeightStrategicFit rdf:type rdf:Property ;
    rdfs:label 'Scoring Weight Strategic Fit' ;
    rdfs:comment 'Percentage weight (0.00–100.00) assigned to the strategic fit dimension in the composite segmentation scoring model. Captures alignment with agency growth priorities, brand portfolio synergies, and ABM (Account-Based Marketing) target profiles.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the segment, used in Salesforce CRM, Mediaocean Prisma, and cross-system reporting (e.g., ENT-001, MID-002, SMB-003). Serves as the human-readable unique code referenced in Account-Based Marketing (ABM) campaigns and Quarterly Business Reviews (QBRs).' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment\'s purpose, target advertiser profile, strategic rationale, and key differentiators from adjacent segments. Used in new business pitch materials, RFP (Request for Proposal) responses, and internal onboarding documentation.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the advertiser segment used for account prioritization and tiered service delivery (e.g., Enterprise, Mid-Market, SMB, Strategic Growth). Displayed in executive portfolio reports, QBRs, and new business pitch targeting materials.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the segment definition. Active segments are in use for account assignment; under_review segments are being evaluated for criteria changes; deprecated segments have been superseded by updated definitions.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentTier rdf:type rdf:Property ;
    rdfs:label 'Segment Tier' ;
    rdfs:comment 'Revenue-based tier classification of the advertiser segment used for resource allocation, service level assignment, and account prioritization. Enterprise represents the highest-value accounts; SMB (Small and Medium Business) represents the lowest revenue tier. Strategic Growth identifies high-potential accounts regardless of current revenue.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation approach used to define this segment. Indicates whether the segment is defined by revenue tier, industry vertical, geographic market, strategic priority, or behavioral attributes. Drives which scoring methodology and criteria apply.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTierLevel rdf:type rdf:Property ;
    rdfs:label 'Service Tier Level' ;
    rdfs:comment 'Tiered service delivery level assigned to this segment, determining the scope of dedicated account management resources, response SLAs, and value-added services. Platinum represents the highest service commitment; Bronze represents standard self-serve support.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRoasBenchmark rdf:type rdf:Property ;
    rdfs:label 'Target Roas Benchmark' ;
    rdfs:comment 'Benchmark ROAS (Return on Ad Spend) target established for advertisers in this segment, expressed as a ratio (e.g., 4.0000 = $4 revenue per $1 spent). Used to set performance expectations in campaign strategy, KPI (Key Performance Indicator) frameworks, and QBR reporting.' ;
    rdfs:domain ind:ClientSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveConflictId rdf:type rdf:Property ;
    rdfs:label 'Competitive Conflict Id' ;
    rdfs:comment 'Unique system-generated identifier for each competitive conflict declaration record. Primary key for the competitive_conflict data product.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCompetitiveAdvertiserId rdf:type rdf:Property ;
    rdfs:label 'Primary Competitive Advertiser Id' ;
    rdfs:comment 'Reference to the first advertiser (incumbent client) in the competitive conflict pair. Typically the existing Agency of Record (AOR) client whose category exclusivity may be at risk.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:workfrontTaskId rdf:type rdf:Property ;
    rdfs:label 'Workfront Task Id' ;
    rdfs:comment 'Reference to the Workfront project management task or work item tracking the resolution activities for this competitive conflict. Links conflict management to the agency\'s project management and resource planning workflows.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:aorContractClause rdf:type rdf:Property ;
    rdfs:label 'Aor Contract Clause' ;
    rdfs:comment 'Reference to the specific clause(s) in the Agency of Record (AOR) contract(s) that govern competitive conflict obligations for this declaration. Used by legal and account management teams to assess contractual exposure and resolution requirements.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Board Approval Reference' ;
    rdfs:comment 'Reference number or identifier for the board-level or senior leadership approval document authorizing the selected resolution approach. Required for \'critical\' severity conflicts and account resignations. Links to governance documentation in the agency\'s document management system.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientANotificationDate rdf:type rdf:Property ;
    rdfs:label 'Client A Notification Date' ;
    rdfs:comment 'The date on which Advertiser A (the incumbent client) was formally notified of the competitive conflict declaration. Required for AOR compliance and contractual notification obligations.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientAWaiverDate rdf:type rdf:Property ;
    rdfs:label 'Client A Waiver Date' ;
    rdfs:comment 'The date on which Advertiser A formally granted a written waiver accepting the agency\'s representation of the competing Advertiser B. Null if no waiver was granted or if resolution_approach is not \'client_waiver\'.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientBNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Client B Notification Date' ;
    rdfs:comment 'The date on which Advertiser B (the challenger or prospective client) was formally notified of the competitive conflict declaration. Required for new business pitch eligibility screening and AOR compliance.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientBWaiverDate rdf:type rdf:Property ;
    rdfs:label 'Client B Waiver Date' ;
    rdfs:comment 'The date on which Advertiser B formally granted a written waiver accepting the agency\'s representation of the competing Advertiser A. Null if no waiver was granted or if resolution_approach is not \'client_waiver\'.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictDescription rdf:type rdf:Property ;
    rdfs:label 'Conflict Description' ;
    rdfs:comment 'Detailed narrative description of the competitive conflict, including the specific products, services, or campaigns that create the conflict, the business rationale for the conflict classification, and any relevant context for resolution decision-making. Classified as confidential due to sensitive client business information.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Conflict Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this conflict declaration, used in correspondence with clients, legal counsel, and board-level approval documentation. Format: CC-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictSeverity rdf:type rdf:Property ;
    rdfs:label 'Conflict Severity' ;
    rdfs:comment 'Business-assessed severity level of the competitive conflict, used to prioritize resolution actions and escalation paths. \'critical\' typically requires board-level approval or account resignation; \'high\' requires senior leadership review; \'medium\' may be resolved via information barriers; \'low\' may be managed with standard team separation.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Status' ;
    rdfs:comment 'Current lifecycle status of the competitive conflict declaration. \'declared\' indicates newly identified conflict; \'under_review\' indicates active assessment in progress; \'resolved\' indicates a resolution approach has been implemented; \'waived\' indicates client has granted a formal waiver; \'escalated\' indicates board-level or legal escalation; \'expired\' indicates the conflict review period has lapsed without resolution.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictType rdf:type rdf:Property ;
    rdfs:label 'Conflict Type' ;
    rdfs:comment 'Classification of the nature of the competitive conflict between the two advertiser accounts. \'direct_competitor\' indicates brands competing for the same customers in the same category; \'indirect_adjacent\' indicates brands in adjacent categories with overlapping audiences; \'category_overlap\' indicates partial product category overlap; \'channel_overlap\' indicates conflict limited to specific media channels; \'geographic_overlap\' indicates conflict limited to specific geographic markets. [ENUM-REF-CANDIDATE: direct_competitor|indirect_adjacent|category_overlap|channel_overlap|geographic_overlap — promote to reference product]' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'The date on which the competitive conflict was formally declared and entered into the agency\'s conflict management system. Serves as the start of the conflict review clock for AOR compliance and E&O insurance purposes.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declaringParty rdf:type rdf:Property ;
    rdfs:label 'Declaring Party' ;
    rdfs:comment 'The party who formally identified and declared the competitive conflict. \'agency\' indicates internal agency conflict screening; \'client_a\' or \'client_b\' indicates the conflict was raised by one of the affected advertisers; \'legal_counsel\' indicates identification by agency legal team; \'new_business_team\' indicates identification during pitch eligibility screening.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eoInsuranceNotified rdf:type rdf:Property ;
    rdfs:label 'Eo Insurance Notified' ;
    rdfs:comment 'Indicates whether the agency\'s Errors and Omissions (E&O) insurance carrier has been formally notified of this competitive conflict declaration. Required for high and critical severity conflicts to preserve insurance coverage.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicMarkets rdf:type rdf:Property ;
    rdfs:label 'Geographic Markets' ;
    rdfs:comment 'Comma-separated list of specific country codes (ISO 3166-1 alpha-3) or market identifiers where the competitive conflict applies when geographic_scope is \'regional\', \'national\', or \'local\'. Example: \'USA,CAN,GBR\'. Null when geographic_scope is \'global\'.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabCategoryName rdf:type rdf:Property ;
    rdfs:label 'Iab Category Name' ;
    rdfs:comment 'Human-readable name of the IAB content taxonomy category corresponding to iab_category_code (e.g., \'Automotive\', \'Consumer Electronics\'). Provides business-friendly label for reporting and conflict screening dashboards.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informationBarrierImplemented rdf:type rdf:Property ;
    rdfs:label 'Information Barrier Implemented' ;
    rdfs:comment 'Indicates whether a formal information barrier (Chinese wall) has been implemented between the account teams serving the two conflicting advertisers. True when system access controls, physical separation, and data governance protocols are in place per the resolution approach.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'The date on which the agency\'s legal counsel completed their formal review of the competitive conflict and provided a written opinion or clearance. Null if legal_review_required is False or review is still in progress.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required' ;
    rdfs:comment 'Indicates whether this competitive conflict requires formal review by the agency\'s legal counsel before a resolution approach can be approved. Typically set to True for critical severity conflicts, account resignations, or conflicts involving active litigation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pitchEligibilityBlocked rdf:type rdf:Property ;
    rdfs:label 'Pitch Eligibility Blocked' ;
    rdfs:comment 'Indicates whether this active competitive conflict blocks the agency from participating in new business pitches involving either of the conflicting advertiser categories. True when the conflict is unresolved and pitch participation would violate AOR obligations or client contracts.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionApproach rdf:type rdf:Property ;
    rdfs:label 'Resolution Approach' ;
    rdfs:comment 'The approved method selected to manage or resolve the competitive conflict. \'chinese_wall\' (information barrier) restricts data and personnel access between account teams; \'client_waiver\' indicates the affected client has formally waived the conflict; \'account_resignation\' indicates the agency will resign one of the conflicting accounts; \'category_carve_out\' limits the agency\'s scope for one client to exclude the conflicting category; \'team_separation\' establishes dedicated, non-overlapping account teams.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the resolution process, key decisions, client communications, and any conditions or limitations attached to the approved resolution approach. Classified as confidential due to sensitive client and legal information.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Review Expiry Date' ;
    rdfs:comment 'The date by which the conflict declaration must be reviewed, renewed, or formally closed. Used to trigger automated review reminders and ensure ongoing AOR compliance. Typically set 12 months from declaration_date or per client contract terms.' ;
    rdfs:domain ind:CompetitiveConflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npsResponseId rdf:type rdf:Property ;
    rdfs:label 'Nps Response Id' ;
    rdfs:comment 'Unique system-generated identifier for each NPS survey response record. Primary key for the nps_response data product within the client domain.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryNpsWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Nps Worker Id' ;
    rdfs:comment 'Reference to the internal account manager or client services lead responsible for the client relationship at the time of survey collection. Used for relationship health attribution.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:surveyWaveId rdf:type rdf:Property ;
    rdfs:label 'Survey Wave Id' ;
    rdfs:comment 'Reference to the survey wave or batch under which this NPS response was collected (e.g., Q1 2024 Post-Campaign Wave, Annual Relationship Survey). Links to the survey wave definition record.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveyWave .

ind:anonymizedFlag rdf:type rdf:Property ;
    rdfs:label 'Anonymized Flag' ;
    rdfs:comment 'Indicates whether the respondent\'s personal identifiers have been anonymized or pseudonymized in this record (True) in response to a data subject erasure or anonymization request under GDPR/CCPA. When True, contact_id and respondent-identifying fields are nullified.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atRiskFlag rdf:type rdf:Property ;
    rdfs:label 'At Risk Flag' ;
    rdfs:comment 'Indicates whether this NPS response has triggered an at-risk account designation for the associated client (True) or not (False). Set based on score thresholds, trend deterioration, or critical verbatim feedback. Feeds into account health dashboards and retention workflows.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessSegment rdf:type rdf:Property ;
    rdfs:label 'Business Segment' ;
    rdfs:comment 'The client business segment classification at the time of survey collection (e.g., enterprise, mid_market, smb, agency, direct). Captured as a snapshot to support segment-level NPS benchmarking and trend analysis.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientTenureMonths rdf:type rdf:Property ;
    rdfs:label 'Client Tenure Months' ;
    rdfs:comment 'The number of months the client has been an active account at the time of survey collection. Captured at survey time to enable cohort analysis of NPS trends by client maturity and relationship longevity.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentGiven rdf:type rdf:Property ;
    rdfs:label 'Consent Given' ;
    rdfs:comment 'Indicates whether the respondent provided explicit consent for their survey response data (including verbatim feedback) to be stored, processed, and used for relationship management and analytics purposes (True = consent given, False = not given or withdrawn). Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmSurveyRecordCode rdf:type rdf:Property ;
    rdfs:label 'Crm Survey Record Code' ;
    rdfs:comment 'The native record identifier from Salesforce CRM (Marketing Cloud or Service Cloud Survey module) for this NPS response. Enables bidirectional traceability between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingBasis rdf:type rdf:Property ;
    rdfs:label 'Data Processing Basis' ;
    rdfs:comment 'The legal basis under GDPR Article 6 for processing the personal data contained in this NPS response (e.g., consent, legitimate_interest, contract, legal_obligation). Required for regulatory compliance documentation and data subject rights management.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'The date on which the follow-up action with the client contact was completed or is scheduled. Used to measure response time to detractor/passive feedback and track SLA compliance for client recovery actions.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpNotes rdf:type rdf:Property ;
    rdfs:label 'Follow Up Notes' ;
    rdfs:comment 'Free-text notes recorded by the account team following the client follow-up conversation. Documents the outcome of the recovery or reinforcement discussion, commitments made, and next steps agreed with the client.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpStatus rdf:type rdf:Property ;
    rdfs:label 'Follow Up Status' ;
    rdfs:comment 'Current status of the follow-up action triggered by this NPS response: pending (action required but not started), in_progress (account team engaged), completed (follow-up conversation concluded), not_required (no action needed), escalated (escalated to senior leadership or executive sponsor).' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementSuggestion rdf:type rdf:Property ;
    rdfs:label 'Improvement Suggestion' ;
    rdfs:comment 'Open-text field capturing the respondent\'s specific suggestions for service or relationship improvement, collected as a secondary open-ended question in the NPS survey. Distinct from verbatim_feedback which explains the score.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbrLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Qbr Linked Flag' ;
    rdfs:comment 'Indicates whether this NPS response has been formally linked to and presented in a Quarterly Business Review (QBR) session with the client (True) or not (False). Supports QBR preparation workflows and tracks which responses have been actioned in formal client review meetings.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipAspect rdf:type rdf:Property ;
    rdfs:label 'Relationship Aspect' ;
    rdfs:comment 'The specific dimension of the client-agency relationship being rated in the secondary question (e.g., strategic_counsel, creative_quality, responsiveness, reporting, media_execution, overall_value). Enables multi-dimensional satisfaction analysis.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipAspectRating rdf:type rdf:Property ;
    rdfs:label 'Relationship Aspect Rating' ;
    rdfs:comment 'Secondary rating (1-5 scale) capturing the respondent\'s satisfaction with a specific relationship dimension (e.g., strategic counsel, creative quality, responsiveness, reporting transparency) as defined by the survey wave. Complements the primary NPS score with dimensional insight.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reminderCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Count' ;
    rdfs:comment 'The number of reminder communications sent to the respondent before they submitted (or declined) the survey. Used to assess survey fatigue, optimize reminder cadence, and contextualize response quality.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:respondentCategory rdf:type rdf:Property ;
    rdfs:label 'Respondent Category' ;
    rdfs:comment 'Classification of the respondent based on their NPS score: promoter (score 9-10), passive (score 7-8), detractor (score 0-6). Derived classification stored for operational use in segmentation, at-risk identification, and follow-up routing without requiring score recalculation.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentRole rdf:type rdf:Property ;
    rdfs:label 'Respondent Role' ;
    rdfs:comment 'The functional role of the survey respondent within the client organization (e.g., decision_maker, day_to_day, executive_sponsor, procurement, finance). Enables role-stratified NPS analysis to identify satisfaction gaps across stakeholder levels.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle state of the NPS survey response: submitted (complete response received), partial (respondent started but did not complete), declined (respondent explicitly opted out), expired (survey link expired before completion), invalidated (response flagged as invalid for data quality reasons).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) at which the respondent submitted the NPS survey response. Used for response latency analysis and audit trail.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyChannel rdf:type rdf:Property ;
    rdfs:label 'Survey Channel' ;
    rdfs:comment 'The delivery channel through which the NPS survey was administered to the respondent (e.g., email link, web portal, phone interview, in-person QBR, SMS). Supports channel effectiveness analysis.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyDate rdf:type rdf:Property ;
    rdfs:label 'Survey Date' ;
    rdfs:comment 'The calendar date on which the NPS survey was sent or administered to the respondent. Used as the principal business event date for trend analysis and wave alignment.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Survey Expiry Date' ;
    rdfs:comment 'The date after which the survey link or invitation is no longer valid for response submission. Used to manage response windows, flag expired non-responses, and calculate response rate denominators.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyInvitationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Invitation Sent Timestamp' ;
    rdfs:comment 'The precise date and time the NPS survey invitation was dispatched to the respondent. Used to calculate response latency (time from invitation to submission) and to manage survey expiry windows.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyLanguage rdf:type rdf:Property ;
    rdfs:label 'Survey Language' ;
    rdfs:comment 'The ISO 639-1 language code (optionally with ISO 3166-1 alpha-2 region code) in which the survey was presented and the response was collected (e.g., en, en-US, fr-FR, de-DE). Supports multilingual client portfolio management.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyResponseCode rdf:type rdf:Property ;
    rdfs:label 'Survey Response Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this NPS response, used in client communications, follow-up tracking, and CRM cross-referencing (e.g., NPS-2024Q1-001234). Distinct from the internal surrogate key.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the NPS survey by its trigger or cadence: post_campaign (collected after campaign completion), quarterly (scheduled quarterly relationship check), annual (annual relationship review), ad_hoc (unscheduled), onboarding (new client), offboarding (departing client). [ENUM-REF-CANDIDATE: post_campaign|quarterly|annual|ad_hoc|onboarding|offboarding — promote to reference product]' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimFeedback rdf:type rdf:Property ;
    rdfs:label 'Verbatim Feedback' ;
    rdfs:comment 'The open-text qualitative feedback provided by the respondent explaining their NPS score. Captures the \'why\' behind the rating and is used for sentiment analysis, theme identification, and account team coaching. May contain client-sensitive commentary.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHistoryId rdf:type rdf:Property ;
    rdfs:label 'Relationship History Id' ;
    rdfs:comment 'Unique surrogate identifier for each immutable relationship history event record. Primary key of this append-only audit log.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRelationshipWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Relationship Worker Id' ;
    rdfs:comment 'The system user identifier (Salesforce CRM user ID or Workfront user ID) of the individual who initiated or recorded this relationship event. Provides accountability and audit trail for relationship lifecycle changes.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:accountTeamLeadName rdf:type rdf:Property ;
    rdfs:label 'Account Team Lead Name' ;
    rdfs:comment 'Full name of the lead account director or client partner at the time of this event. Stored for human-readable reporting and QBR documentation without requiring a join to talent systems.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aorScope rdf:type rdf:Property ;
    rdfs:label 'Aor Scope' ;
    rdfs:comment 'Describes the specific channels, disciplines, or service lines covered by the Agency of Record (AOR) mandate at the time of this event (e.g., \'Digital, Social, OOH\'). Relevant for AOR win, loss, expansion, and reduction event types.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactName rdf:type rdf:Property ;
    rdfs:label 'Client Contact Name' ;
    rdfs:comment 'Full name of the primary client-side contact involved in or notified of this relationship event (e.g., the CMO who signed off on an AOR award). Supports relationship continuity tracking when client-side personnel change.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactTitle rdf:type rdf:Property ;
    rdfs:label 'Client Contact Title' ;
    rdfs:comment 'Job title of the primary client-side contact involved in this relationship event (e.g., Chief Marketing Officer, VP of Marketing). Provides seniority context for relationship event significance assessment.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Competing Agency Name' ;
    rdfs:comment 'Name of the competing agency involved in a pitch or competitive review associated with this relationship event. Populated when competitive_review_flag is True. Supports competitive intelligence and win/loss analysis.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Review Flag' ;
    rdfs:comment 'Indicates whether this relationship event is associated with a formal competitive agency review or pitch process (True). Enables tracking of accounts under competitive threat and supports win/loss analysis.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationSeverity rdf:type rdf:Property ;
    rdfs:label 'Escalation Severity' ;
    rdfs:comment 'Severity classification of the escalation when escalation_flag is True. Drives prioritisation of executive response and account recovery actions. Null when escalation_flag is False.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRevenueImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact' ;
    rdfs:comment 'The estimated annual revenue impact (positive or negative) on the agency resulting from this relationship event, expressed in the client\'s preferred currency. Used for P&L forecasting and executive pipeline reporting. Positive values indicate revenue gain; negative values indicate revenue loss.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The business date on which the relationship event occurred or was formally recognised (e.g., the date an AOR contract was signed, the date a scope change was approved). Distinct from the record creation timestamp.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventNarrative rdf:type rdf:Property ;
    rdfs:label 'Event Narrative' ;
    rdfs:comment 'Detailed free-text notes authored by the account team or executive sponsor describing the circumstances, rationale, and business context of the relationship event. Supports Quarterly Business Review (QBR) documentation and institutional knowledge retention.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioReference rdf:type rdf:Property ;
    rdfs:label 'Io Reference' ;
    rdfs:comment 'The Insertion Order (IO) number associated with this relationship event where the event is linked to a specific media buy or campaign commitment. Relevant for scope change and contract renewal events.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStateDescription rdf:type rdf:Property ;
    rdfs:label 'New State Description' ;
    rdfs:comment 'Free-text narrative describing the new state of the relationship, scope, team composition, or contract terms after this event. Provides the post-event context for executive reporting and QBR preparation.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStateDescription rdf:type rdf:Property ;
    rdfs:label 'Previous State Description' ;
    rdfs:comment 'Free-text narrative describing the prior state of the relationship, scope, team composition, or contract terms before this event. Captures contextual detail beyond the structured status field (e.g., \'AOR for digital and social channels only\').' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHealthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Health Score' ;
    rdfs:comment 'A numeric score (typically 1–10) representing the assessed health of the client relationship at the time of this event, as recorded by the account team. Supports at-risk client identification and proactive retention strategies. Not a calculated metric — this is the human-assessed score captured at event time.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated_revenue_impact amount (e.g., USD, GBP, EUR). Ensures correct financial interpretation in multi-currency agency environments.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The native record identifier from the originating source system (e.g., Salesforce CRM Account History ID, Workfront task ID). Enables traceability and deduplication during ETL processing.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredByName rdf:type rdf:Property ;
    rdfs:label 'Triggered By Name' ;
    rdfs:comment 'Full name of the agency staff member or executive who initiated or recorded this relationship event. Stored for human-readable audit trail and executive reporting without requiring a join to HR systems.' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredByRole rdf:type rdf:Property ;
    rdfs:label 'Triggered By Role' ;
    rdfs:comment 'The business role or title of the individual who triggered this relationship event. Enables analysis of which organisational levels are driving relationship changes and escalations. [ENUM-REF-CANDIDATE: account_director|account_manager|ceo|cso|client_partner|business_development|finance_director — promote to reference product]' ;
    rdfs:domain ind:RelationshipHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Id' ;
    rdfs:comment 'Reference to the parent or master agreement if this is a child agreement (e.g., SOW under an MSA, Amendment to an IO). Nullable for top-level agreements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known business identifier for the agreement, used in client communications and invoicing.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the agreement. [ENUM-REF-CANDIDATE: Draft|Pending Approval|Active|Suspended|Terminated|Expired|Renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the commercial agreement. MSA = Master Service Agreement, SOW = Statement of Work, IO = Insertion Order, RFP = Request for Proposal, RFI = Request for Information. [ENUM-REF-CANDIDATE: MSA|SOW|IO|RFP Response|RFI Response|Vendor Media Supply|Technology License|Production Services|Amendment — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date of the most recent compliance or legal review of this agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a confidentiality or non-disclosure provision.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'Name or identifier of the individual responsible for ongoing management and compliance of this agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Indicates whether the agreement is with a client (revenue-generating), vendor (cost-generating), or strategic partner.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesSummary rdf:type rdf:Property ;
    rdfs:label 'Deliverables Summary' ;
    rdfs:comment 'High-level summary of key deliverables, milestones, or outputs expected under this agreement.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed mechanism for resolving disputes arising from this agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageUrl rdf:type rdf:Property ;
    rdfs:label 'Document Storage Url' ;
    rdfs:comment 'URL or file path to the signed agreement document in the Digital Asset Management (DAM) or document management system.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the interpretation and enforcement of this agreement (e.g., State of New York, England and Wales).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Indemnity Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes an indemnity provision protecting one or both parties from third-party claims.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum liability amount either party can be held responsible for under this agreement. Nullable if no cap applies.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date within which payment is due (e.g., Net 30, Net 60).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceBonusClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes performance-based bonus or incentive provisions.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Commercial pricing structure for this agreement. CPM = Cost Per Mille, CPC = Cost Per Click, CPA = Cost Per Acquisition. [ENUM-REF-CANDIDATE: Fixed Fee|Time and Materials|Retainer|Commission|CPM|CPC|CPA|Hybrid — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required to prevent auto-renewal or to initiate renewal negotiation.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeOfWorkDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Description' ;
    rdfs:comment 'Detailed description of the services, deliverables, and work products covered by this agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when all parties executed the agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Included Flag' ;
    rdfs:comment 'Indicates whether the agreement includes defined Service Level Agreements with performance targets and penalties.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date when the agreement was terminated, if applicable. Nullable for active agreements.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required for either party to terminate the agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCommittedValue rdf:type rdf:Property ;
    rdfs:label 'Total Committed Value' ;
    rdfs:comment 'Total monetary value committed under this agreement over its full term. For client agreements, represents expected revenue; for vendor agreements, represents committed spend.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Unique identifier for the contract amendment record. Primary key.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:supersededByAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment Id' ;
    rdfs:comment 'Reference to a subsequent amendment that supersedes or replaces this amendment, if applicable.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:agencySignatoryName rdf:type rdf:Property ;
    rdfs:label 'Agency Signatory Name' ;
    rdfs:comment 'Full name of the agency representative who signed the amendment on behalf of the agency.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencySignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Agency Signatory Title' ;
    rdfs:comment 'Job title or role of the agency representative who signed the amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential or hierarchical amendment identifier (e.g., A-001, Amendment 1, 2024-A-03) used for external reference and tracking.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle state of the amendment in the approval and execution workflow.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment based on the nature of the contractual change being made.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetDeltaAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Delta Amount' ;
    rdfs:comment 'The net change in budget amount resulting from the amendment (revised minus original).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed narrative describing the specific contractual changes, modifications, or adjustments being made through this amendment.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Name' ;
    rdfs:comment 'Full name of the client representative who signed the amendment on behalf of the client organization.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Title' ;
    rdfs:comment 'Job title or role of the client representative who signed the amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date on which all required parties signed and executed the amendment.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed' ;
    rdfs:comment 'Indicates whether the required legal review has been completed for this amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Original Budget Amount' ;
    rdfs:comment 'The original contracted budget amount before the amendment, if the amendment involves budget changes.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalEndDate rdf:type rdf:Property ;
    rdfs:label 'Original End Date' ;
    rdfs:comment 'The original contract end date before the amendment, if the amendment involves timeline changes.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalValue rdf:type rdf:Property ;
    rdfs:label 'Original Value' ;
    rdfs:comment 'The original contractual value, term, or specification before the amendment (stored as text to accommodate various data types).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedBy rdf:type rdf:Property ;
    rdfs:label 'Requested By' ;
    rdfs:comment 'Name or identifier of the individual or party who initiated the amendment request.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedEndDate rdf:type rdf:Property ;
    rdfs:label 'Revised End Date' ;
    rdfs:comment 'The new contract end date after the amendment is applied, if the amendment involves timeline changes.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedValue rdf:type rdf:Property ;
    rdfs:label 'Revised Value' ;
    rdfs:comment 'The new contractual value, term, or specification after the amendment is applied (stored as text to accommodate various data types).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Unique identifier for the compliance obligation record. Primary key.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Frequency at which this compliance obligation is reviewed or audited to ensure ongoing adherence.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Target date by which the compliance obligation must be fully satisfied or achieved.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the obligation indicating whether the requirement is being met, in progress, under review, waived, or not applicable.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Indicates whether this compliance obligation requires escalation to senior management, legal counsel, or the board due to its risk or complexity.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Evidence Location' ;
    rdfs:comment 'File path, document management system reference, or URL where compliance evidence is stored and accessible for audit purposes.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceRequired rdf:type rdf:Property ;
    rdfs:label 'Evidence Required' ;
    rdfs:comment 'Description of the evidence, documentation, or proof required to demonstrate compliance with this obligation (e.g., audit reports, certifications, signed agreements, consent records).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent audit or compliance review for this obligation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Date of the next scheduled audit or compliance review for this obligation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonCompliancePenalty rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Penalty' ;
    rdfs:comment 'Description of the penalties, fines, sanctions, or consequences that may result from failure to meet this compliance obligation.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the compliance obligation, including specific requirements, scope, and context.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'Business-facing unique reference number for the compliance obligation, used in communications and reporting.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationTitle rdf:type rdf:Property ;
    rdfs:label 'Obligation Title' ;
    rdfs:comment 'Short descriptive title of the compliance obligation for quick identification and reporting.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the compliance obligation by its origin and nature (regulatory mandate, contractual commitment, industry standard, certification requirement, data privacy rule, brand safety requirement, disclosure mandate, or consent management). [ENUM-REF-CANDIDATE: regulatory|contractual|industry_standard|certification|data_privacy|brand_safety|disclosure|consent_management — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary value of the potential fine or penalty for non-compliance, if quantifiable.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Specific citation or reference to the regulation, law, standard, or contractual clause that creates this obligation (e.g., GDPR Article 28, CCPA Section 1798.100, IAB TCF v2.0, FTC Act Section 5).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the regulatory authority, governing body, or standards organization that mandates this obligation (e.g., FTC, GDPR Authority, IAB, ASA, TAG, MRC).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationOwner rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for executing the remediation plan.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Description of the action plan or steps required to achieve or restore compliance if the obligation is currently not met.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name or identifier of the individual, team, or department responsible for ensuring compliance with this obligation.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Email' ;
    rdfs:comment 'Primary email contact for the responsible party overseeing this compliance obligation.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of the risk exposure if this compliance obligation is not met, considering financial, reputational, and legal consequences.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRateCardId rdf:type rdf:Property ;
    rdfs:label 'Contract Rate Card Id' ;
    rdfs:comment 'Unique identifier for the contract rate card. Primary key for this entity.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractRateCard .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'The standard or base rate amount for this rate card entry, before any adjustments, discounts, or surcharges. Precision supports fractional currency units and CPM calculations.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'How often charges under this rate card are invoiced: weekly, biweekly, monthly, quarterly, milestone (upon reaching project milestones), on_completion (at project end), or custom (bespoke schedule). [ENUM-REF-CANDIDATE: weekly|biweekly|monthly|quarterly|milestone|on_completion|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRateCardStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Rate Card Status' ;
    rdfs:comment 'Current lifecycle status of the rate card: draft (being prepared), pending_approval (submitted for review), approved (authorized but not yet effective), active (currently in force), suspended (temporarily inactive), expired (past effective period), superseded (replaced by newer version). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|expired|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Negotiated discount percentage applied to the base rate, expressed as a percentage (e.g., 15.00 for 15% discount). Supports volume discounts or client-specific pricing.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographyScope rdf:type rdf:Property ;
    rdfs:label 'Geography Scope' ;
    rdfs:comment 'Geographic scope or market to which this rate card applies, such as \'USA\', \'EMEA\', \'APAC\', \'New York DMA\', \'Global\'. Supports geo-specific pricing.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Flag indicating whether this is the default rate card for the associated contract or service line. True if default, False otherwise.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNegotiable rdf:type rdf:Property ;
    rdfs:label 'Is Negotiable' ;
    rdfs:comment 'Flag indicating whether rates in this card are open to negotiation or are fixed. True if negotiable, False if fixed.' ;
    rdfs:domain ind:ContractRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markupPercentage rdf:type rdf:Property ;
    rdfs:label 'Markup Percentage' ;
    rdfs:comment 'Agency markup or commission percentage applied to vendor costs or media spend, expressed as a percentage (e.g., 20.00 for 20% markup).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumRate rdf:type rdf:Property ;
    rdfs:label 'Maximum Rate' ;
    rdfs:comment 'Ceiling rate or maximum charge applicable under this rate card. Used for rate caps or maximum allowable charges.' ;
    rdfs:domain ind:ContractRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'For media inventory rate cards, the type of media covered: display, video, audio, social, search, native, OOH (Out-of-Home), DOOH (Digital Out-of-Home), CTV (Connected TV), OTT (Over-the-Top), print, radio, TV, mobile, or email. [ENUM-REF-CANDIDATE: display|video|audio|social|search|native|ooh|dooh|ctv|ott|print|radio|tv|mobile|email — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Rate' ;
    rdfs:comment 'Floor rate or minimum charge applicable under this rate card. Used for CPM floors, minimum hourly charges, or minimum project fees.' ;
    rdfs:domain ind:ContractRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardName rdf:type rdf:Property ;
    rdfs:label 'Rate Card Name' ;
    rdfs:comment 'Descriptive name of the rate card for business reference, such as \'Q1 2024 Agency Services Rate Card\' or \'Premium Media Inventory Pricing\'.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Card Number' ;
    rdfs:comment 'Business identifier for the rate card, typically used in invoicing and billing reconciliation. Format: RC- followed by alphanumeric code.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardType rdf:type rdf:Property ;
    rdfs:label 'Rate Card Type' ;
    rdfs:comment 'Classification of the rate card by its purpose: agency_services (hourly FTE rates by role), media_inventory (CPM/CPC rates for ad placements), production (creative production cost rates), vendor_services (third-party vendor pricing), commission (media commission percentages), or hybrid (combination of multiple types).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCategory rdf:type rdf:Property ;
    rdfs:label 'Rate Category' ;
    rdfs:comment 'Business classification or grouping for the rates in this card, such as \'Senior Creative Staff\', \'Digital Media Placements\', \'Video Production Services\', or \'Programmatic Inventory\'. Supports rate organization and reporting.' ;
    rdfs:domain ind:ContractRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleLevel rdf:type rdf:Property ;
    rdfs:label 'Role Level' ;
    rdfs:comment 'For agency services rate cards, the seniority or role level to which this rate applies, such as \'Junior Designer\', \'Senior Account Director\', \'Executive Creative Director\'. Supports role-based billing.' ;
    rdfs:domain ind:ContractRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit by which the rate is measured and billed: hour (hourly rate), day (daily rate), month (monthly retainer), impression (per 1000 impressions for CPM), click (per click for CPC), acquisition (per conversion for CPA), unit (per deliverable), project (per project), percentage (commission), or flat (one-time fee). [ENUM-REF-CANDIDATE: hour|day|month|impression|click|acquisition|unit|project|percentage|flat — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTier rdf:type rdf:Property ;
    rdfs:label 'Volume Tier' ;
    rdfs:comment 'Volume-based pricing tier identifier for tiered rate cards, such as \'Tier 1: 0-100K impressions\', \'Tier 2: 100K-500K impressions\'. Supports tiered pricing models.' ;
    rdfs:domain ind:ContractRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowchartId rdf:type rdf:Property ;
    rdfs:label 'Flowchart Id' ;
    rdfs:comment 'Foreign key linking to media.media_flowchart. Business justification: Flowcharts are contractual deliverables with acceptance criteria. Linking deliverables to flowcharts enables acceptance tracking, milestone payment triggers, and provides audit trail for deliverable s' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Flowchart .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'The specific criteria, standards, or requirements that must be met for the client to accept the deliverable.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'The date on which the client formally accepted the deliverable as meeting contractual requirements.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'The actual total cost incurred to produce this deliverable, used for budget reconciliation and profitability analysis.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'The actual number of labor hours spent on completing this deliverable, tracked for billing and performance analysis.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billableAmount rdf:type rdf:Property ;
    rdfs:label 'Billable Amount' ;
    rdfs:comment 'The amount that will be billed to the client for this deliverable, as specified in the contract or SOW.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDeliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Contract Deliverable Description' ;
    rdfs:comment 'Detailed description of the deliverable scope, content, and specifications as outlined in the contract or SOW.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDeliverableStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Deliverable Status' ;
    rdfs:comment 'Current lifecycle status of the deliverable (e.g., pending, in-progress, submitted, under review, accepted, rejected, on hold, cancelled). [ENUM-REF-CANDIDATE: pending|in_progress|submitted|under_review|accepted|rejected|on_hold|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableCode rdf:type rdf:Property ;
    rdfs:label 'Deliverable Code' ;
    rdfs:comment 'Unique business identifier or code for the deliverable, often used for tracking and billing purposes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableName rdf:type rdf:Property ;
    rdfs:label 'Deliverable Name' ;
    rdfs:comment 'The business name or title of the deliverable as specified in the contract (e.g., \'Q1 Brand Strategy Deck\', \'Creative Asset Package - Summer Campaign\').' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The contractually committed date by which the deliverable must be completed and submitted to the client.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'The estimated total cost to produce this deliverable, including labor, materials, and third-party expenses.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Hours' ;
    rdfs:comment 'The estimated number of labor hours required to complete this deliverable, used for resource planning and budgeting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Milestone' ;
    rdfs:comment 'Boolean flag indicating whether this deliverable represents a major milestone in the contract or project timeline.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresClientApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Client Approval' ;
    rdfs:comment 'Boolean flag indicating whether this deliverable requires formal client approval before being considered complete.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'The internal team or department responsible for producing and delivering this deliverable (e.g., Creative, Media Planning, Analytics, Strategy).' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Master Service Agreement Id' ;
    rdfs:comment 'Reference to the parent master service agreement or contract under which this insertion order is executed.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the billing contact for invoice delivery and payment-related communications.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Name of the primary billing contact responsible for invoice processing and payment authorization for this insertion order.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyingMethod rdf:type rdf:Property ;
    rdfs:label 'Buying Method' ;
    rdfs:comment 'The method by which media inventory is purchased under this insertion order. RTB (Real-Time Bidding) indicates auction-based programmatic buying.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationPolicy rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy' ;
    rdfs:comment 'Terms and conditions governing cancellation or early termination of the insertion order, including notice periods and financial penalties.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedClicks rdf:type rdf:Property ;
    rdfs:label 'Committed Clicks' ;
    rdfs:comment 'The total number of clicks committed or guaranteed under this insertion order for CPC-based campaigns. Null for non-click-based rate types.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedConversions rdf:type rdf:Property ;
    rdfs:label 'Committed Conversions' ;
    rdfs:comment 'The total number of conversions or acquisitions committed under this insertion order for CPA-based campaigns. Null for non-conversion-based rate types.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedImpressions rdf:type rdf:Property ;
    rdfs:label 'Committed Impressions' ;
    rdfs:comment 'The total number of ad impressions committed or guaranteed by the media vendor under this insertion order. Null for non-guaranteed or performance-based deals.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'The date when the media campaign flight ends and ad serving authorization under this insertion order expires.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'The date when the media campaign flight begins and ad serving is authorized to commence under this insertion order.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ioApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Io Approved Date' ;
    rdfs:comment 'The date when the insertion order was approved by the media vendor, authorizing campaign setup and trafficking.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ioName rdf:type rdf:Property ;
    rdfs:label 'Io Name' ;
    rdfs:comment 'Human-readable descriptive name for the insertion order, typically including campaign reference and media vendor for easy identification.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioNumber rdf:type rdf:Property ;
    rdfs:label 'Io Number' ;
    rdfs:comment 'The externally-known unique business identifier for this insertion order, used in communications with media vendors and internal tracking systems.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioSignedDate rdf:type rdf:Property ;
    rdfs:label 'Io Signed Date' ;
    rdfs:comment 'The date when the insertion order was executed and signed by all required parties, establishing the binding commitment.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ioStatus rdf:type rdf:Property ;
    rdfs:label 'Io Status' ;
    rdfs:comment 'Current lifecycle status of the insertion order in the approval and execution workflow. [ENUM-REF-CANDIDATE: draft|pending_signature|executed|active|paused|cancelled|completed|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Io Submitted Date' ;
    rdfs:comment 'The date when the insertion order was submitted to the media vendor for review and approval.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ioType rdf:type rdf:Property ;
    rdfs:label 'Io Type' ;
    rdfs:comment 'Classification of the insertion order based on the media buying model and inventory commitment type.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makeGoodPolicy rdf:type rdf:Property ;
    rdfs:label 'Make Good Policy' ;
    rdfs:comment 'Terms governing make-good provisions when the media vendor fails to deliver committed impressions or performance metrics, including remediation options.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementSpecifications rdf:type rdf:Property ;
    rdfs:label 'Placement Specifications' ;
    rdfs:comment 'Detailed specifications for ad placements including ad formats, sizes, positions, targeting criteria, and creative requirements as agreed with the media vendor.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyAdServingFee rdf:type rdf:Property ;
    rdfs:label 'Third Party Ad Serving Fee' ;
    rdfs:comment 'Additional fee charged for third-party ad serving technology, tracking, and verification services associated with this insertion order.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAuthorizedSpend rdf:type rdf:Property ;
    rdfs:label 'Total Authorized Spend' ;
    rdfs:comment 'The total budget amount authorized for media spend under this insertion order, representing the maximum financial commitment.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:traffickingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Trafficking Contact Email' ;
    rdfs:comment 'Email address of the trafficking contact for campaign setup and creative asset coordination.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traffickingContactName rdf:type rdf:Property ;
    rdfs:label 'Trafficking Contact Name' ;
    rdfs:comment 'Name of the primary trafficking contact responsible for campaign setup, creative delivery, and ad serving coordination.' ;
    rdfs:domain ind:ContractInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Approved baseline date for milestone completion, used for variance analysis and performance tracking. May differ from planned_date if the project has been re-baselined.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this milestone is on the project critical path (True), meaning any delay will impact the overall project completion date, or not (False).' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Detailed description of the deliverable(s) or work product(s) associated with this milestone, including acceptance criteria and quality standards.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyMilestoneIds rdf:type rdf:Property ;
    rdfs:label 'Dependency Milestone Ids' ;
    rdfs:comment 'Comma-separated list of milestone_id values representing predecessor milestones that must be completed before this milestone can begin or be completed.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Reference to the invoice generated as a result of this milestone completion, if applicable. Null if milestone has not triggered invoicing or is not a payment trigger.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Descriptive name of the milestone (e.g., Creative Concept Approval, Campaign Launch, Final Deliverable Acceptance).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneNumber rdf:type rdf:Property ;
    rdfs:label 'Milestone Number' ;
    rdfs:comment 'Business-readable identifier for the milestone, often used in client communications and invoicing (e.g., M-001, MS-2023-Q1-01).' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle status of the milestone: planned (not yet started), in_progress (work underway), completed (milestone achieved), delayed (past due date), cancelled (no longer applicable), or on_hold (temporarily suspended).' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone indicating its purpose in the engagement lifecycle: payment trigger (invoice generation), phase gate (project stage transition), deliverable acceptance (client sign-off), go-live (campaign launch), creative review (creative approval checkpoint), or final acceptance (project closure).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Fixed monetary amount associated with this milestone if it is a payment trigger. Null if milestone does not trigger payment or uses percentage-based calculation.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPercentage rdf:type rdf:Property ;
    rdfs:label 'Payment Percentage' ;
    rdfs:comment 'Percentage of total contract value to be paid upon milestone completion (e.g., 25.00 for 25%). Null if milestone uses fixed payment_amount or does not trigger payment.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Trigger Flag' ;
    rdfs:comment 'Indicates whether completion of this milestone triggers a payment or invoice generation event (True) or not (False).' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Originally scheduled date for milestone completion as defined in the SOW or project plan.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date when revenue associated with this milestone is recognized in financial statements, per ASC 606 / IFRS 15 revenue recognition standards.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Number of days between planned_date and actual_completion_date. Positive values indicate delay; negative values indicate early completion. Null if milestone is not yet completed.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateCardLineId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Line Id' ;
    rdfs:comment 'Primary key for rate_card_line' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Internal cost center or department code for financial allocation and profit and loss (P&L) tracking. Links rate card revenue to organizational units.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code for revenue recognition. Maps rate card line items to chart of accounts for financial reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRetainerEligible rdf:type rdf:Property ;
    rdfs:label 'Is Retainer Eligible' ;
    rdfs:comment 'Indicates whether this line item can be included in retainer-based billing arrangements. Supports hybrid fee structures combining retainer and project-based work.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether this line item is subject to sales tax or value-added tax (VAT). Drives tax calculation in billing systems.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential ordering of this line item within the parent rate card. Determines display order in proposals and invoices.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of this rate card line item. Controls whether the line is available for use in proposals and billing.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCommitmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Commitment Quantity' ;
    rdfs:comment 'Maximum volume or hours available for this line item under the contract terms. Null if no cap applies. Manages scope and resource allocation.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCommitmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Quantity' ;
    rdfs:comment 'Minimum volume or hours the client must purchase for this line item under the contract terms. Null if no minimum applies. Enforces contractual commitments.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRate rdf:type rdf:Property ;
    rdfs:label 'Overage Rate' ;
    rdfs:comment 'Rate charged for usage exceeding the maximum commitment quantity. Typically higher than the standard unit rate. Null if no overage pricing applies.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'Job title or role designation for labor-based rate card lines (e.g., Senior Art Director, Media Planner, Account Executive). Null for non-labor items.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed description of the service, role, or media placement type covered by this line item. Provides clarity on scope and deliverables.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Category of service or deliverable covered by this rate card line. Classifies the type of work being priced.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code for this line item. Used by financial systems to apply correct tax rates and comply with jurisdictional tax rules.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'The base price charged per unit of measure. Core pricing element used for billing calculations and budget forecasting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold Max' ;
    rdfs:comment 'Maximum quantity threshold for volume-based pricing tier. Null for open-ended top tier. Defines upper bound of pricing tier range.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold Min' ;
    rdfs:comment 'Minimum quantity threshold for volume-based pricing tier. Null if no volume discounting applies. Used with volume_tier_threshold_max to define tier ranges.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalId rdf:type rdf:Property ;
    rdfs:label 'Renewal Id' ;
    rdfs:comment 'Unique identifier for the contract renewal event record. Primary key.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalApprovedByContactClientContactId rdf:type rdf:Property ;
    rdfs:label 'Renewal Approved By Contact Client Contact Id' ;
    rdfs:comment 'Reference to the internal executive or approver who authorized this renewal. Null if no approval was required.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:renewalClientContactId rdf:type rdf:Property ;
    rdfs:label 'Renewal Client Contact Id' ;
    rdfs:comment 'Reference to the client contact who has authority to approve or decline the renewal. Key stakeholder for renewal negotiations.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:alertSentFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Sent Flag' ;
    rdfs:comment 'Indicates whether automated renewal alerts (90/60/30-day notifications) were successfully sent to the account team. True if alerts sent, False otherwise.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Clause Flag' ;
    rdfs:comment 'Indicates whether the renewed contract includes an automatic renewal clause for the next term. True if auto-renewal is enabled, False if manual renewal required.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Flag' ;
    rdfs:comment 'Indicates whether this renewal was flagged as high churn risk based on client health indicators, payment issues, or competitive threats. True if at-risk, False otherwise.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveThreatFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Threat Flag' ;
    rdfs:comment 'Indicates whether the renewal process involved known competitive pressure or client evaluation of alternative agencies. True if competitive threat identified, False otherwise.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationEndDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation End Date' ;
    rdfs:comment 'Date when renewal negotiations concluded, either with agreement or termination of discussions.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date when formal renewal negotiations began with the client. Marks the transition from renewal notice to active discussion phase.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newTermEndDate rdf:type rdf:Property ;
    rdfs:label 'New Term End Date' ;
    rdfs:comment 'End date of the renewed contract term. Defines the duration of the new agreement period.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newTermStartDate rdf:type rdf:Property ;
    rdfs:label 'New Term Start Date' ;
    rdfs:comment 'Start date of the renewed contract term. Typically matches renewal_effective_date but may differ if there is a gap or overlap period.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newTermValue rdf:type rdf:Property ;
    rdfs:label 'New Term Value' ;
    rdfs:comment 'Total contract value of the renewed term, expressed in the contract currency. Captures pricing adjustments, scope changes, or inflationary increases.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'Date when the renewal notice was sent to the client or vendor, triggering the renewal evaluation period. Critical for tracking compliance with contractual notice requirements (e.g., 90-day notice clauses).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Final result of the renewal process: renewed (client accepted renewal on existing or similar terms), renegotiated (client renewed with material changes), lapsed (client did not respond or declined passively), terminated (client actively ended relationship).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModelChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Change Flag' ;
    rdfs:comment 'Indicates whether the renewal involved a change to the pricing model (e.g., shift from CPM to CPA, or from fixed fee to performance-based). True if pricing model changed, False otherwise.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Prior Term End Date' ;
    rdfs:comment 'End date of the contract term that is being renewed. Marks the expiration of the prior agreement and the trigger point for renewal evaluation.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorTermStartDate rdf:type rdf:Property ;
    rdfs:label 'Prior Term Start Date' ;
    rdfs:comment 'Start date of the contract term that is being renewed. Used to calculate term length and renewal cycle metrics.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorTermValue rdf:type rdf:Property ;
    rdfs:label 'Prior Term Value' ;
    rdfs:comment 'Total contract value of the term being renewed, expressed in the contract currency. Used to calculate renewal rate and revenue retention metrics.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:probabilityScore rdf:type rdf:Property ;
    rdfs:label 'Probability Score' ;
    rdfs:comment 'Predictive score (0-100) representing the likelihood of successful renewal at the time of renewal notice. Derived from client health metrics, engagement scores, and historical renewal patterns.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Free-text explanation of the drivers behind the renewal outcome. Captures client feedback, competitive factors, performance issues, or strategic rationale.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Number' ;
    rdfs:comment 'Business-facing identifier for this renewal event, typically formatted as contract number plus renewal sequence (e.g., MSA-2024-001-R2).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current lifecycle state of the renewal event: pending (renewal window opened, no action yet), in_negotiation (active discussions), approved (client committed), renewed (executed and effective), lapsed (client did not renew), terminated (client ended relationship), cancelled (renewal process aborted). [ENUM-REF-CANDIDATE: pending|in_negotiation|approved|renewed|lapsed|terminated|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Classification of the renewal mechanism: auto (automatic renewal per contract terms), manual (proactive renewal negotiation), renegotiation (renewal with material term changes), amendment (renewal with scope or pricing adjustments).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Scope Change Flag' ;
    rdfs:comment 'Indicates whether the renewal involved a change to the scope of services or deliverables (e.g., added channels, reduced markets, new service lines). True if scope changed, False otherwise.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sowUpdatedFlag rdf:type rdf:Property ;
    rdfs:label 'Sow Updated Flag' ;
    rdfs:comment 'Indicates whether the renewal required an updated Statement of Work (SOW) document due to scope, deliverable, or Service Level Agreement (SLA) changes. True if SOW updated, False otherwise.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valueChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Value Change Amount' ;
    rdfs:comment 'Net change in contract value from prior term to new term (new_term_value minus prior_term_value). Positive values indicate upsell, negative values indicate downsell or discount.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Value Change Percentage' ;
    rdfs:comment 'Percentage change in contract value from prior term to new term, calculated as (value_change_amount / prior_term_value) * 100. Key metric for renewal pricing analysis.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfpResponseId rdf:type rdf:Property ;
    rdfs:label 'Rfp Response Id' ;
    rdfs:comment 'Primary key for rfp_response' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRfpAdvertiserId rdf:type rdf:Property ;
    rdfs:label 'Primary Rfp Advertiser Id' ;
    rdfs:comment 'Identifier of the client or prospect organization that issued the RFP or RFI. Links to the advertiser or client entity.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:primaryRfpWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Rfp Worker Id' ;
    rdfs:comment 'Identifier of the primary team member leading the pitch and response effort. Typically links to an employee or talent record.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:resultingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Resulting Agreement Id' ;
    rdfs:comment 'Identifier of the contract or master service agreement (MSA) that resulted from winning this RFP. Null if the response was lost or no contract was signed.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:clientIndustry rdf:type rdf:Property ;
    rdfs:label 'Client Industry' ;
    rdfs:comment 'Industry or vertical market of the issuing client or prospect (e.g., automotive, financial services, retail, healthcare). Used for segmentation and expertise matching.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIntelligenceNotes rdf:type rdf:Property ;
    rdfs:label 'Competitive Intelligence Notes' ;
    rdfs:comment 'Internal notes capturing competitive intelligence gathered during the RFP process, including known competitors, their strengths/weaknesses, and strategic positioning insights.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedContractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Estimated Contract Duration Months' ;
    rdfs:comment 'Estimated duration of the resulting contract in months, as proposed or anticipated in the RFP response.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedContractValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Contract Value' ;
    rdfs:comment 'Internal estimate of the total contract value or annual revenue potential if the RFP is won. Used for pipeline forecasting and resource planning.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Internal Approval Date' ;
    rdfs:comment 'Date when the RFP response received final internal approval from agency leadership before submission to the client.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noBidReason rdf:type rdf:Property ;
    rdfs:label 'No Bid Reason' ;
    rdfs:comment 'Explanation of why the agency decided not to respond to the RFP (no-bid decision). Captures strategic, resource, or conflict-of-interest considerations.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Pitch Team Members' ;
    rdfs:comment 'List of team members involved in preparing and presenting the response. May include names, roles, or identifiers in a delimited format.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationDate rdf:type rdf:Property ;
    rdfs:label 'Presentation Date' ;
    rdfs:comment 'Date when the agency presented or pitched the response to the client in person or virtually. Null if no presentation was required or conducted.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:presentationLocation rdf:type rdf:Property ;
    rdfs:label 'Presentation Location' ;
    rdfs:comment 'Physical location or virtual platform where the pitch presentation took place (e.g., client office address, Zoom, Microsoft Teams).' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfWinPercent rdf:type rdf:Property ;
    rdfs:label 'Probability Of Win Percent' ;
    rdfs:comment 'Internal assessment of the likelihood of winning the RFP, expressed as a percentage (0-100). Used for pipeline forecasting and resource allocation decisions.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedBudgetMax rdf:type rdf:Property ;
    rdfs:label 'Proposed Budget Max' ;
    rdfs:comment 'Maximum value of the proposed budget range included in the response. Represents the upper bound of the financial commitment proposed to the client.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedBudgetMin rdf:type rdf:Property ;
    rdfs:label 'Proposed Budget Min' ;
    rdfs:comment 'Minimum value of the proposed budget range included in the response. Represents the lower bound of the financial commitment proposed to the client.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedScopeSummary rdf:type rdf:Property ;
    rdfs:label 'Proposed Scope Summary' ;
    rdfs:comment 'High-level summary of the scope of work, services, and deliverables proposed in the response. Captures the strategic approach and key offerings.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedServices rdf:type rdf:Property ;
    rdfs:label 'Proposed Services' ;
    rdfs:comment 'Detailed list or description of specific services proposed (e.g., media planning, creative development, digital marketing, analytics). May be comma-separated or narrative format.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Response Document Url' ;
    rdfs:comment 'URL or file path to the submitted RFP response document or presentation deck stored in the agency\'s DAM (Digital Asset Management) system or document repository.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Rfp Received Date' ;
    rdfs:comment 'Date when the agency received the RFP or RFI from the client or prospect.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfpReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Reference Number' ;
    rdfs:comment 'The externally-known reference number or identifier assigned to the RFP or RFI by the issuing client or prospect. This is the business identifier used in communications and documentation.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpType rdf:type rdf:Property ;
    rdfs:label 'Rfp Type' ;
    rdfs:comment 'Classification of the request type: RFP (Request for Proposal), RFI (Request for Information), RFQ (Request for Quote), pitch invitation, tender, or general proposal request.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'Date and time by which the RFP response must be submitted to the client. This is the principal business event timestamp for the response lifecycle.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:winLossCategory rdf:type rdf:Property ;
    rdfs:label 'Win Loss Category' ;
    rdfs:comment 'Categorical classification of the primary factor contributing to the win or loss outcome: pricing, creative approach, team expertise, strategic fit, incumbent advantage, or timing.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossReason rdf:type rdf:Property ;
    rdfs:label 'Win Loss Reason' ;
    rdfs:comment 'Explanation or categorization of why the response was won or lost. Captures feedback from the client, internal assessment, or competitive factors. Used for pipeline analysis and continuous improvement.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeItemId rdf:type rdf:Property ;
    rdfs:label 'Scope Item Id' ;
    rdfs:comment 'Unique identifier for the scope item within the contract management system.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScopeItem .

ind:changeOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Change Order Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this scope item was added via a change order or amendment (True) or was part of the original contract (False).' ;
    rdfs:domain ind:ScopeItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Change Order Number' ;
    rdfs:comment 'Reference number of the change order or amendment that added or modified this scope item, if applicable.' ;
    rdfs:domain ind:ScopeItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableCategory rdf:type rdf:Property ;
    rdfs:label 'Deliverable Category' ;
    rdfs:comment 'Specific classification of the deliverable type when item_type is deliverable (e.g., \'Campaign Brief\', \'Media Plan\', \'Creative Assets\', \'Performance Report\').' ;
    rdfs:domain ind:ScopeItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedUnits rdf:type rdf:Property ;
    rdfs:label 'Estimated Units' ;
    rdfs:comment 'Estimated quantity of units for this scope item when priced on a unit basis (e.g., number of ads, number of reports, number of campaigns).' ;
    rdfs:domain ind:ScopeItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed description of the work, service, activity, or deliverable covered by this scope item.' ;
    rdfs:domain ind:ScopeItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemName rdf:type rdf:Property ;
    rdfs:label 'Item Name' ;
    rdfs:comment 'Short descriptive name or title of the scope item (e.g., \'Digital Campaign Creative Development\', \'Media Buying Services\').' ;
    rdfs:domain ind:ScopeItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemNumber rdf:type rdf:Property ;
    rdfs:label 'Item Number' ;
    rdfs:comment 'Business identifier or line number for the scope item within the contract or SOW (e.g., 1.1, 2.3, A-5).' ;
    rdfs:domain ind:ScopeItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemSequence rdf:type rdf:Property ;
    rdfs:label 'Item Sequence' ;
    rdfs:comment 'Numeric ordering of the scope item within the parent contract or SOW for display and processing purposes.' ;
    rdfs:domain ind:ScopeItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeItemStatus rdf:type rdf:Property ;
    rdfs:label 'Scope Item Status' ;
    rdfs:comment 'Current lifecycle status of the scope item indicating its state in the contract execution process.' ;
    rdfs:domain ind:ScopeItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'High-level categorization of the service or work type covered by this scope item aligned with agency service offerings. [ENUM-REF-CANDIDATE: creative|media_planning|media_buying|strategy|analytics|production|account_management|digital_marketing|public_relations|brand_strategy — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total contracted value for this scope item calculated as estimated_units multiplied by unit_rate, or as a fixed fee.' ;
    rdfs:domain ind:ScopeItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Role or individual who has authority to approve SLA modifications, waivers, or breach remediation plans.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineMeasurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Baseline Measurement Period' ;
    rdfs:comment 'The time period over which the baseline performance was measured (e.g., \'Q4 2023\', \'Last 6 months\', \'Prior contract term\').' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselinePerformance rdf:type rdf:Property ;
    rdfs:label 'Baseline Performance' ;
    rdfs:comment 'Historical or benchmark performance level used as a reference point for setting the SLA target, captured at contract negotiation.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachThreshold rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold' ;
    rdfs:comment 'The performance level at which an SLA breach is triggered, may differ from target to allow tolerance (e.g., target 24 hours, breach at 30 hours).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Unit' ;
    rdfs:comment 'Unit of measure for the breach threshold value.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Client Acceptance Date' ;
    rdfs:comment 'The date when the client formally accepted and signed off on this SLA commitment.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Compliance Tracking Enabled' ;
    rdfs:comment 'Indicates whether automated compliance monitoring and breach alerting is enabled for this SLA (true) or manual tracking only (false).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationContact rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact' ;
    rdfs:comment 'Name or role of the individual or team to be notified when an SLA breach occurs or is imminent.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Circumstances or conditions explicitly excluded from SLA measurement (e.g., force majeure, client-caused delays, third-party platform outages, holiday periods).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often the SLA performance is measured and reported (per transaction, daily, weekly, monthly, quarterly, annual).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the target value (hours, business days, calendar days, percentage, minutes, count).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyMechanism rdf:type rdf:Property ;
    rdfs:label 'Penalty Mechanism' ;
    rdfs:comment 'The contractual remedy applied when an SLA is breached (service credit, fee reduction, termination right, penalty payment, none).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationTerms rdf:type rdf:Property ;
    rdfs:label 'Remediation Terms' ;
    rdfs:comment 'Detailed description of the corrective actions, escalation procedures, and resolution commitments when an SLA breach occurs.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSchedule rdf:type rdf:Property ;
    rdfs:label 'Reporting Schedule' ;
    rdfs:comment 'Frequency at which SLA performance reports are delivered to the client or stakeholders (real-time, daily, weekly, monthly, quarterly, on-demand).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Business identifier or code for the SLA, often referenced in contract documents and quarterly business reviews (QBRs).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable name of the SLA commitment (e.g., \'Creative Turnaround Time\', \'Campaign Go-Live SLA\', \'Reporting Delivery Deadline\').' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current lifecycle status of the SLA (active, suspended, expired, terminated, draft, under review).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of SLA defining the nature of the performance commitment (creative turnaround, campaign go-live, reporting delivery, platform uptime, trafficking response, client approval).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByClientContactId rdf:type rdf:Property ;
    rdfs:label 'Approved By Client Contact Id' ;
    rdfs:comment 'Reference to the client contact who provided formal approval for this SOW. Typically a senior marketing or procurement executive.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:sowAdvertiserId rdf:type rdf:Property ;
    rdfs:label 'Sow Advertiser Id' ;
    rdfs:comment 'Reference to the specific advertiser entity under the client organization. May differ from client_id in holding company structures.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:sowApprovedByAgencyContactWorkerId rdf:type rdf:Property ;
    rdfs:label 'Sow Approved By Agency Contact Worker Id' ;
    rdfs:comment 'Reference to the agency contact who provided internal approval for this SOW. Typically an account director or managing director.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:sowClientAdvertiserId rdf:type rdf:Property ;
    rdfs:label 'Sow Client Advertiser Id' ;
    rdfs:comment 'Reference to the client or advertiser for whom this SOW is executed. Links to the client master record.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:sowWorkerId rdf:type rdf:Property ;
    rdfs:label 'Sow Worker Id' ;
    rdfs:comment 'Reference to the agency account manager responsible for this SOW. Primary point of contact for client relationship and SOW execution.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:agencyFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Agency Fee Amount' ;
    rdfs:comment 'Total agency service fees for the SOW, excluding media costs and third-party pass-throughs. Represents the agency\'s revenue from this engagement.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingModel rdf:type rdf:Property ;
    rdfs:label 'Billing Model' ;
    rdfs:comment 'Pricing structure for the SOW. Determines how the client is invoiced (fixed price, hourly rates, monthly retainer, media commission, performance incentives, or combination).' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClause rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause' ;
    rdfs:comment 'Text of the confidentiality and non-disclosure provisions governing how both parties handle sensitive information shared during the engagement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intellectualPropertyOwnership rdf:type rdf:Property ;
    rdfs:label 'Intellectual Property Ownership' ;
    rdfs:comment 'Specifies who owns the intellectual property rights to work created under this SOW (client owns all, agency retains rights, shared ownership, or work-for-hire arrangement).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicingFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoicing Frequency' ;
    rdfs:comment 'Cadence at which the client will be invoiced under this SOW. Aligns with billing model and cash flow requirements.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Media Budget Amount' ;
    rdfs:comment 'Total media spend budget allocated under this SOW for media buying and placement. Excludes agency fees and production costs.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBonusAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Amount' ;
    rdfs:comment 'Maximum potential performance bonus amount payable to the agency if all performance criteria are met. Null if no performance incentives exist.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBonusCriteria rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Criteria' ;
    rdfs:comment 'Description of performance metrics and thresholds that trigger bonus payments to the agency (e.g., \'ROAS exceeds 5:1\', \'Campaign CTR above 2%\').' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Production Budget Amount' ;
    rdfs:comment 'Total budget allocated for creative production, including video, photography, design, and other content creation costs.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required to terminate or opt out of renewal. Null if no renewal option exists.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the SOW includes an option for renewal or extension beyond the initial term. True if renewal clause exists.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfWork rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Comprehensive description of all services, deliverables, and activities included in the SOW. Defines what is in-scope and out-of-scope.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeliverableTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Sla Deliverable Turnaround Days' ;
    rdfs:comment 'Standard number of business days committed for deliverable turnaround under normal circumstances. Part of service level commitments.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Maximum number of hours the agency commits to respond to client requests or issues under this SOW. Part of service level commitments.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sowDescription rdf:type rdf:Property ;
    rdfs:label 'Sow Description' ;
    rdfs:comment 'Detailed narrative description of the SOW scope, objectives, and high-level deliverables. Provides context for the engagement.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowNumber rdf:type rdf:Property ;
    rdfs:label 'Sow Number' ;
    rdfs:comment 'Business-facing unique identifier for the SOW, typically formatted as SOW-XXXXXX. Used in client communications, invoicing, and contract references.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowStatus rdf:type rdf:Property ;
    rdfs:label 'Sow Status' ;
    rdfs:comment 'Current lifecycle status of the SOW. Tracks progression from draft through approval, execution, and closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowType rdf:type rdf:Property ;
    rdfs:label 'Sow Type' ;
    rdfs:comment 'Classification of the SOW by engagement type. Determines billing model, resource allocation, and deliverable expectations. [ENUM-REF-CANDIDATE: project|retainer|campaign|media_buy|creative_services|consulting|production|research|strategy — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Text of the termination provisions, specifying conditions under which either party may terminate the SOW and associated notice periods or penalties.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total monetary value of the SOW across its entire duration, including all fees, media spend, and pass-through costs. Expressed in the contract currency.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableClientTier rdf:type rdf:Property ;
    rdfs:label 'Applicable Client Tier' ;
    rdfs:comment 'Client segmentation tier for which this template is designed. Ensures appropriate terms and pricing structures are applied based on client size and strategic importance.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseLibraryReference rdf:type rdf:Property ;
    rdfs:label 'Clause Library Reference' ;
    rdfs:comment 'Reference identifier or URL to the pre-approved clause library or playbook that this template draws from. Supports traceability to approved legal language.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTemplateDescription rdf:type rdf:Property ;
    rdfs:label 'Contract Template Description' ;
    rdfs:comment 'Detailed description of the template\'s purpose, scope, and intended use cases. Guides account teams and legal staff in selecting the appropriate template.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVerticalApplicability rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical Applicability' ;
    rdfs:comment 'Comma-separated list of industry verticals (e.g., retail, healthcare, financial services) for which this template is optimized. Supports industry-specific compliance and terminology requirements.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapFlag rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Flag' ;
    rdfs:comment 'Indicates whether the template includes a limitation of liability clause. True if liability cap language is present, false otherwise.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningLegalTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Legal Team' ;
    rdfs:comment 'Name or identifier of the legal team or department responsible for maintaining and updating this template.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Standard interval in months between scheduled reviews of the template. Supports proactive template maintenance and compliance.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selfServiceEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Self Service Enabled Flag' ;
    rdfs:comment 'Indicates whether account teams are authorized to use this template without legal review for standard deals. True if self-service is permitted, false if legal review is required.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardPaymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Standard Payment Terms Days' ;
    rdfs:comment 'Default payment terms in days (e.g., Net 30, Net 60) specified in the template. May be negotiated in individual agreements.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardPricingModel rdf:type rdf:Property ;
    rdfs:label 'Standard Pricing Model' ;
    rdfs:comment 'Default pricing structure embedded in the template. Guides account teams in structuring commercial terms.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the contract template, describing its purpose and scope.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateNumber rdf:type rdf:Property ;
    rdfs:label 'Template Number' ;
    rdfs:comment 'Business-facing unique identifier or code for the template, used for reference in legal operations and contract management systems.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateStatus rdf:type rdf:Property ;
    rdfs:label 'Template Status' ;
    rdfs:comment 'Current lifecycle status of the template. Only approved or active templates may be used for new agreement creation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the template by agreement type. Determines which contract lifecycle stage and legal framework the template supports.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termId rdf:type rdf:Property ;
    rdfs:label 'Term Id' ;
    rdfs:comment 'Primary key for term' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of times this term clause has been amended or modified since the original contract execution.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether this term grants audit rights to either party (True) or does not include audit provisions (False).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clauseCategory rdf:type rdf:Property ;
    rdfs:label 'Clause Category' ;
    rdfs:comment 'High-level categorization of the clause into legal, commercial, operational, compliance, financial, or technical domains for organizational and reporting purposes.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseSummary rdf:type rdf:Property ;
    rdfs:label 'Clause Summary' ;
    rdfs:comment 'Plain-language summary of the clause for business users, highlighting key obligations, rights, and implications.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseText rdf:type rdf:Property ;
    rdfs:label 'Clause Text' ;
    rdfs:comment 'Full legal text of the term clause as negotiated and executed. Contains the complete wording of the contractual provision.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseTitle rdf:type rdf:Property ;
    rdfs:label 'Clause Title' ;
    rdfs:comment 'Short descriptive title or heading of the term clause as it appears in the contract document.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseType rdf:type rdf:Property ;
    rdfs:label 'Clause Type' ;
    rdfs:comment 'Classification of the term clause by its legal or commercial function (e.g., payment terms, IP ownership, confidentiality, indemnification, termination rights, audit rights, liability limitation, warranty, SLA, scope, deliverable, pricing, renewal). [ENUM-REF-CANDIDATE: payment|intellectual_property|confidentiality|indemnification|termination|audit_rights|liability_limitation|warranty|service_level|scope_of_work|deliverable|pricing|renewal — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Flag' ;
    rdfs:comment 'Indicates whether this term clause is subject to regulatory compliance monitoring and reporting requirements (True) or is a standard commercial term (False).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityDurationYears rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Duration Years' ;
    rdfs:comment 'Number of years that confidentiality obligations remain in effect after contract termination when the clause type is confidentiality-related.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indemnificationScope rdf:type rdf:Property ;
    rdfs:label 'Indemnification Scope' ;
    rdfs:comment 'Description of the scope and limitations of indemnification obligations when the clause type is indemnification-related.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendedDate rdf:type rdf:Property ;
    rdfs:label 'Last Amended Date' ;
    rdfs:comment 'Date of the most recent amendment to this term clause.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the liability cap amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Negotiated Flag' ;
    rdfs:comment 'Indicates whether this term was negotiated and modified from the standard template (True) or accepted as-is from the standard contract language (False).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Specified payment instrument or mechanism for financial settlement (e.g., wire transfer, ACH, check, credit card, EFT) when applicable to the term.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermDays rdf:type rdf:Property ;
    rdfs:label 'Payment Term Days' ;
    rdfs:comment 'Number of days for payment terms (e.g., net-30, net-60, net-90) when the clause type is payment-related.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyProvision rdf:type rdf:Property ;
    rdfs:label 'Penalty Provision' ;
    rdfs:comment 'Description of financial or contractual penalties for non-compliance with the term, including service level breaches, late payments, or other violations.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Ordering or numbering of the term within the parent contract or Statement of Work (SOW), used to maintain clause hierarchy and presentation order.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLevelMetric rdf:type rdf:Property ;
    rdfs:label 'Service Level Metric' ;
    rdfs:comment 'Name of the performance metric or Key Performance Indicator (KPI) specified in the service level term (e.g., response time, uptime percentage, delivery timeframe).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelTarget rdf:type rdf:Property ;
    rdfs:label 'Service Level Target' ;
    rdfs:comment 'Target value or threshold for the service level metric (e.g., 99.9% uptime, 24-hour response time, 5-day delivery).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Standard Clause Flag' ;
    rdfs:comment 'Indicates whether this term is part of the organization\'s standard contract template (True) or is a custom clause specific to this agreement (False).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termNumber rdf:type rdf:Property ;
    rdfs:label 'Term Number' ;
    rdfs:comment 'Business identifier for the term clause, often used for legal reference and cross-referencing within contract documents.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required for contract termination when the clause type is termination-related (e.g., 30-day notice, 60-day notice).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationId rdf:type rdf:Property ;
    rdfs:label 'Accreditation Id' ;
    rdfs:comment 'Foreign key linking to vendor.accreditation. Business justification: Vendor contracts reference required certifications (TAG, MRC, brand safety) as contract conditions. Procurement teams enforce accreditation requirements in vendor_contract terms, trigger compliance re' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Accreditation .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Vendor contracts specify default GL accounts for expense posting and accrual management; finance uses this for automated posting and audit trail.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the digitally stored contract document in the Digital Asset Management (DAM) system or document repository.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the vendor contract, typically used in communications and invoicing.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the vendor contract. Tracks progression from draft through approval, active execution, and eventual termination or renewal. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|terminated|expired|renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the vendor contract based on the nature of services or products provided. Distinguishes media supply agreements, technology licenses (DSP, SSP, DMP, CDP), production services, and other vendor relationships.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingAddendumFlag rdf:type rdf:Property ;
    rdfs:label 'Data Processing Addendum Flag' ;
    rdfs:comment 'Indicates whether a Data Processing Addendum (DPA) is attached to this contract to comply with GDPR, CCPA, or other privacy regulations. True if DPA is in place, False otherwise.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law that applies to the contract (e.g., State of New York, England and Wales). Defines where disputes will be resolved.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnificationClause rdf:type rdf:Property ;
    rdfs:label 'Indemnification Clause' ;
    rdfs:comment 'Text describing indemnification obligations, specifying which party is responsible for legal claims, intellectual property disputes, or third-party liabilities.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or modification to the contract terms. Nullable if no amendments have been made.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyClauseDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Description' ;
    rdfs:comment 'Description of financial penalties, service credits, or other remedies applicable if the vendor fails to meet performance guarantees or SLA commitments.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceGuaranteeDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Description' ;
    rdfs:comment 'Description of any Service Level Agreements (SLAs), Key Performance Indicators (KPIs), or performance guarantees the vendor has committed to meet, including uptime, delivery timelines, or quality metrics.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Uptime Percent' ;
    rdfs:comment 'Target uptime percentage guaranteed by the vendor for technology platforms or services (e.g., 99.9% for DSP or DMP platforms). Nullable if not applicable.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationForCauseClause rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Clause' ;
    rdfs:comment 'Text describing the conditions under which either party may terminate the contract immediately for cause, such as breach of terms, non-performance, or regulatory violations.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommittedSpend rdf:type rdf:Property ;
    rdfs:label 'Total Committed Spend' ;
    rdfs:comment 'Total monetary value committed to the vendor over the contract term. Represents the agencys financial obligation under this agreement.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountThreshold rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Threshold' ;
    rdfs:comment 'Minimum spend or volume level required to trigger volume-based pricing discounts or rebates. Nullable if no volume discounts apply.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adaptationId rdf:type rdf:Property ;
    rdfs:label 'Adaptation Id' ;
    rdfs:comment 'Unique identifier for the creative adaptation record. Primary key.' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adaptation .

ind:adaptationCreatedByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Adaptation Created By User Worker Id' ;
    rdfs:comment 'Reference to the user who initiated or created this adaptation record.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:adaptationModifiedByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Adaptation Modified By User Worker Id' ;
    rdfs:comment 'Reference to the user who last modified this adaptation record.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:adaptationWorkerId rdf:type rdf:Property ;
    rdfs:label 'Adaptation Worker Id' ;
    rdfs:comment 'Reference to the user or stakeholder who granted final approval for this adaptation.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:specId rdf:type rdf:Property ;
    rdfs:label 'Spec Id' ;
    rdfs:comment 'Foreign key linking to creative.creative_spec. Business justification: Adaptations are created to meet target format specifications for specific platforms or channels. The adaptation table has target_format as a STRING, which should be normalized to creative_spec_id FK. ' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Spec .

ind:accessibilityComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliance Flag' ;
    rdfs:comment 'Indicates whether this adaptation includes accessibility features such as closed captions, audio descriptions, or screen reader compatibility. True if accessibility features are present.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adaptationName rdf:type rdf:Property ;
    rdfs:label 'Adaptation Name' ;
    rdfs:comment 'Human-readable name or title assigned to this creative adaptation for identification and tracking purposes.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaptationType rdf:type rdf:Property ;
    rdfs:label 'Adaptation Type' ;
    rdfs:comment 'Classification of the adaptation method applied to the master asset. Defines the nature of the derivative work.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'Display aspect ratio of the adapted visual asset (e.g., 16:9, 4:3, 1:1, 9:16). Defines the proportional relationship between width and height.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Score' ;
    rdfs:comment 'Quantitative score (0-100) representing adherence to brand guidelines in this adaptation. Higher scores indicate stronger brand alignment.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorSpace rdf:type rdf:Property ;
    rdfs:label 'Color Space' ;
    rdfs:comment 'Color space standard used in the adapted asset. Critical for print vs digital delivery and color accuracy across platforms.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when adaptation work was completed and the asset was delivered. Follows ISO 8601 date format (yyyy-MM-dd).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:culturalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Cultural Review Status' ;
    rdfs:comment 'Current status of cultural sensitivity and appropriateness review for the target market. Ensures brand safety and cultural compliance.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Dam Asset Url' ;
    rdfs:comment 'Direct URL or path to the adapted asset file stored in the Digital Asset Management system (e.g., Workfront DAM, Adobe Creative Cloud).' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Duration of the adapted video or audio asset in seconds. Applicable to time-based media formats.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rationale rdf:type rdf:Property ;
    rdfs:label 'Rationale' ;
    rdfs:comment 'Business justification or reason for creating this adaptation. Captures strategic context such as regulatory compliance, cultural sensitivity, platform requirements, or audience targeting needs.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Status' ;
    rdfs:comment 'Current status of regulatory and legal compliance review for the target market. Ensures adherence to local advertising standards and regulations.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Pixel resolution of the adapted visual asset (e.g., 1920x1080, 1080x1920, 300x250). Defines the dimensions in pixels.' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLanguage rdf:type rdf:Property ;
    rdfs:label 'Source Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code of the original master asset before adaptation.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetChannel rdf:type rdf:Property ;
    rdfs:label 'Target Channel' ;
    rdfs:comment 'Media channel or platform for which this adaptation is intended (e.g., Facebook, Instagram, YouTube, CTV, DOOH, Print).' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLanguage rdf:type rdf:Property ;
    rdfs:label 'Target Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code of the adapted asset. Used for language dub and localization tracking.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLocale rdf:type rdf:Property ;
    rdfs:label 'Target Locale' ;
    rdfs:comment 'ISO locale code representing the target language and region for this adaptation (e.g., en_US, fr_FR, es_MX). Used for localization tracking.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic market for which this adaptation is intended.' ;
    rdfs:domain ind:Adaptation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetVersionId rdf:type rdf:Property ;
    rdfs:label 'Asset Version Id' ;
    rdfs:comment 'Unique identifier for the asset version record. Primary key.' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:adobeCcDocumentVersionRef rdf:type rdf:Property ;
    rdfs:label 'Adobe Cc Document Version Ref' ;
    rdfs:comment 'External version identifier from Adobe Creative Cloud system. Enables traceability to source Adobe application (Photoshop, Illustrator, InDesign, Premiere Pro).' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the individual who approved this version for promotion or final delivery. Null if not yet approved.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archive Timestamp' ;
    rdfs:comment 'Date and time when this version was archived. Null if not yet archived.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:brandComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Status' ;
    rdfs:comment 'Indicates whether this version adheres to brand guidelines and standards. Used for brand governance and quality control.' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., MD5, SHA-256) of the file for integrity verification and duplicate detection.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'Color space or profile used in this version (e.g., sRGB, Adobe RGB, CMYK). Critical for print and digital color accuracy.' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Timestamp' ;
    rdfs:comment 'Date and time when brand compliance review was last performed on this version. Null if not yet reviewed.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original file name of this version as stored in the system.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Storage location or URI reference to the physical file for this version in the Digital Asset Management (DAM) system or cloud storage.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightPixels rdf:type rdf:Property ;
    rdfs:label 'Height Pixels' ;
    rdfs:comment 'Height dimension of the creative asset in pixels. Applicable to image and video formats.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isArchived rdf:type rdf:Property ;
    rdfs:label 'Is Archived' ;
    rdfs:comment 'Indicates whether this version has been archived and moved to long-term storage. True if archived, False if active.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromoted rdf:type rdf:Property ;
    rdfs:label 'Is Promoted' ;
    rdfs:comment 'Indicates whether this version has been promoted to production or final delivery status. True if promoted, False otherwise.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Promotion Timestamp' ;
    rdfs:comment 'Date and time when this version was promoted to production or approved for final delivery. Null if not yet promoted.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'Human-readable version label or tag (e.g., v1, v2_client_feedback, v3_final, draft_A). Used for identification and communication.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of this version. Tracks progression through creative approval workflow.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPixels rdf:type rdf:Property ;
    rdfs:label 'Width Pixels' ;
    rdfs:comment 'Width dimension of the creative asset in pixels. Applicable to image and video formats.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workfrontProofVersionRef rdf:type rdf:Property ;
    rdfs:label 'Workfront Proof Version Ref' ;
    rdfs:comment 'External proof version identifier from Workfront proofing system. Links to approval and feedback workflow.' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptCopywriterWorkerId rdf:type rdf:Property ;
    rdfs:label 'Concept Copywriter Worker Id' ;
    rdfs:comment 'Reference to the copywriter who developed the messaging and copy for this concept. Links to talent or employee record.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:conceptCreatedByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Concept Created By User Worker Id' ;
    rdfs:comment 'Reference to the user who created this concept record. Links to employee or user management system.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:conceptModifiedByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Concept Modified By User Worker Id' ;
    rdfs:comment 'Reference to the user who last modified this concept record. Links to employee or user management system.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:conceptWorkerId rdf:type rdf:Property ;
    rdfs:label 'Concept Worker Id' ;
    rdfs:comment 'Reference to the creative lead or art director responsible for developing this concept. Links to talent or employee record.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:parentConceptId rdf:type rdf:Property ;
    rdfs:label 'Parent Concept Id' ;
    rdfs:comment 'Reference to the parent concept if this is a revision or variation. Enables tracking of concept evolution and iteration history.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Concept .

ind:brandComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Flag' ;
    rdfs:comment 'Indicates whether the concept has been reviewed and confirmed to comply with brand guidelines and standards. True if compliant, false if non-compliant or not yet reviewed.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveDifferentiation rdf:type rdf:Property ;
    rdfs:label 'Competitive Differentiation' ;
    rdfs:comment 'Description of how this concept differentiates the brand from competitors. Explains the unique positioning and competitive advantage.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptCode rdf:type rdf:Property ;
    rdfs:label 'Concept Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the concept for tracking and reference across systems. Often used in project management and DAM systems.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptDescription rdf:type rdf:Property ;
    rdfs:label 'Concept Description' ;
    rdfs:comment 'Detailed narrative description of the creative concept. Explains the big idea, execution approach, and how the concept will come to life across touchpoints.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptStatus rdf:type rdf:Property ;
    rdfs:label 'Concept Status' ;
    rdfs:comment 'Current lifecycle status of the concept. Tracks progression through internal review, client presentation, and approval stages. [ENUM-REF-CANDIDATE: draft|in_review|pending_approval|approved|rejected|on_hold|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeTerritory rdf:type rdf:Property ;
    rdfs:label 'Creative Territory' ;
    rdfs:comment 'The overarching creative theme, space, or territory that this concept occupies. Defines the broad strategic positioning and thematic direction.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedProductionCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Production Cost' ;
    rdfs:comment 'Estimated cost to produce and execute this concept if approved. Used for budget planning and concept selection decisions.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Review Status' ;
    rdfs:comment 'Status of legal review process for this concept. Tracks whether legal has cleared the concept for use in advertising.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodBoardReference rdf:type rdf:Property ;
    rdfs:label 'Mood Board Reference' ;
    rdfs:comment 'Reference to mood board assets or inspiration materials that illustrate the visual and emotional tone of the concept. May include links to DAM assets or external references.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionComplexity rdf:type rdf:Property ;
    rdfs:label 'Production Complexity' ;
    rdfs:comment 'Assessment of the production complexity and resource requirements for this concept. Influences feasibility and timeline planning.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicRationale rdf:type rdf:Property ;
    rdfs:label 'Strategic Rationale' ;
    rdfs:comment 'The strategic reasoning and business justification for this concept. Explains how the concept addresses the brief objectives and target audience insights.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingRecommendation rdf:type rdf:Property ;
    rdfs:label 'Testing Recommendation' ;
    rdfs:comment 'Recommendation for whether and how this concept should be tested with target audiences before full production (e.g., focus groups, A/B testing, concept testing).' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visualDirection rdf:type rdf:Property ;
    rdfs:label 'Visual Direction' ;
    rdfs:comment 'Description of the visual style, aesthetic, and design direction for the concept. Includes guidance on imagery, color palette, typography, and overall look and feel.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAssetCreativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Creative Asset Id' ;
    rdfs:comment 'Reference to the parent or original asset from which this version was derived. Establishes version lineage and asset family relationships.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:primaryCreativeWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Creative Worker Id' ;
    rdfs:comment 'Reference to the user or talent who created or uploaded the asset. Supports attribution, workflow tracking, and resource management.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:taskId rdf:type rdf:Property ;
    rdfs:label 'Task Id' ;
    rdfs:comment 'Foreign key linking to project.task. Business justification: Assets are outputs of specific tasks. Linking enables granular effort tracking, resource utilization analysis, task completion validation, and productivity measurement. Essential for time tracking and' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:campaignTheme rdf:type rdf:Property ;
    rdfs:label 'Campaign Theme' ;
    rdfs:comment 'Overarching creative theme or concept associated with the asset (e.g., Summer Sale, Back to School, Holiday 2024). Links asset to strategic messaging.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSuitability rdf:type rdf:Property ;
    rdfs:label 'Channel Suitability' ;
    rdfs:comment 'Comma-separated list of media channels for which this asset is optimized or approved (e.g., TV, Digital, OOH, Social, CTV). Guides media planning and trafficking.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codec rdf:type rdf:Property ;
    rdfs:label 'Codec' ;
    rdfs:comment 'Video or audio codec used for encoding (e.g., H.264, H.265, AAC, MP3). Critical for playback compatibility and quality.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightHolder rdf:type rdf:Property ;
    rdfs:label 'Copyright Holder' ;
    rdfs:comment 'Name of the individual or organization that holds copyright to the asset. Critical for legal compliance and rights management.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Description' ;
    rdfs:comment 'Free-text description of the asset content, purpose, and usage notes. Provides context for search, reuse, and creative briefing.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damAssetRef rdf:type rdf:Property ;
    rdfs:label 'Dam Asset Ref' ;
    rdfs:comment 'External unique identifier from the source DAM system (Workfront DAM or Adobe AEM). Used for cross-system reconciliation and asset retrieval.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileStoragePath rdf:type rdf:Property ;
    rdfs:label 'File Storage Path' ;
    rdfs:comment 'Full path or URI to the asset file in the storage system (cloud storage, DAM repository, CDN). Used for retrieval and delivery.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Type of license under which the asset is used (e.g., royalty-free, rights-managed, exclusive, non-exclusive). Governs usage terms and restrictions.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodTags rdf:type rdf:Property ;
    rdfs:label 'Mood Tags' ;
    rdfs:comment 'Comma-separated keywords describing the emotional tone or mood of the asset (e.g., energetic, calm, humorous, inspirational). Aids in creative selection and reuse.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Clearance Status' ;
    rdfs:comment 'Status of legal rights and usage permissions for the asset (talent, music, stock imagery, etc.). Determines where and how the asset can be used.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectTags rdf:type rdf:Property ;
    rdfs:label 'Subject Tags' ;
    rdfs:comment 'Comma-separated descriptive keywords describing the subject matter or content of the asset (e.g., product, lifestyle, testimonial). Supports search and discovery.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL to a thumbnail or preview image of the asset. Enables quick visual identification in DAM interfaces and reporting tools.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetUsageId rdf:type rdf:Property ;
    rdfs:label 'Asset Usage Id' ;
    rdfs:comment 'Unique identifier for each instance of creative asset deployment or trafficking. Primary key.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyId rdf:type rdf:Property ;
    rdfs:label 'Buy Id' ;
    rdfs:comment 'Foreign key linking to media.media_buy. Business justification: Usage records link assets to specific buys for delivery verification, makegood tracking, and reconciliation. Ensures creative ran as contracted and supports billing disputes and performance analysis b' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Buy .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Asset usage events can trigger accrual or revenue journal entries (e.g., usage-based royalties, performance fees). Links usage to financial postings for automated accrual generation and audit trail.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:adServerRef rdf:type rdf:Property ;
    rdfs:label 'Ad Server Ref' ;
    rdfs:comment 'The unique identifier assigned by the ad server (e.g., Google Campaign Manager 360) for this creative deployment. Enables reconciliation with ad server reporting.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetVersion rdf:type rdf:Property ;
    rdfs:label 'Asset Version' ;
    rdfs:comment 'The version identifier of the creative asset used in this deployment. Tracks which iteration or variant of the asset was trafficked.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickCount rdf:type rdf:Property ;
    rdfs:label 'Click Count' ;
    rdfs:comment 'The total number of clicks recorded for this asset usage instance. Captured from ad server reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creativeRotationWeight rdf:type rdf:Property ;
    rdfs:label 'Creative Rotation Weight' ;
    rdfs:comment 'The rotation weight or priority assigned to this asset within a multi-creative rotation. Higher values indicate higher priority or frequency.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ctr rdf:type rdf:Property ;
    rdfs:label 'Ctr' ;
    rdfs:comment 'The click-through rate for this asset usage instance, expressed as a decimal (e.g., 0.025 for 2.5%). Enables creative performance benchmarking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionCount rdf:type rdf:Property ;
    rdfs:label 'Impression Count' ;
    rdfs:comment 'The total number of impressions delivered for this asset usage instance. Captured from ad server reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRightsCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Rights Compliant' ;
    rdfs:comment 'Boolean flag indicating whether this asset usage is within the approved rights period and territory. True if compliant, False if expired or out of territory.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:market rdf:type rdf:Property ;
    rdfs:label 'Market' ;
    rdfs:comment 'The market or geographic region where the asset is being deployed. Enables market-specific creative performance analysis.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsEndDate rdf:type rdf:Property ;
    rdfs:label 'Rights End Date' ;
    rdfs:comment 'The end date of the usage rights period for this asset. Critical for rights expiry monitoring and compliance. Nullable for perpetual rights.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsStartDate rdf:type rdf:Property ;
    rdfs:label 'Rights Start Date' ;
    rdfs:comment 'The start date of the usage rights period for this asset. Defines when the legal right to use the asset begins.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:traffickedBy rdf:type rdf:Property ;
    rdfs:label 'Trafficked By' ;
    rdfs:comment 'The name or identifier of the user or system that trafficked this asset into the ad server or media channel. Supports audit trail and accountability.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traffickingDate rdf:type rdf:Property ;
    rdfs:label 'Trafficking Date' ;
    rdfs:comment 'The date when the creative asset was trafficked or deployed into the ad server or media channel. Principal business event timestamp for this usage record.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageEndDate rdf:type rdf:Property ;
    rdfs:label 'Usage End Date' ;
    rdfs:comment 'The date when the creative asset usage period ends. Marks the conclusion of the active deployment window.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Free-text notes or comments about this specific asset usage instance. May include trafficking instructions, special handling notes, or performance observations.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageStartDate rdf:type rdf:Property ;
    rdfs:label 'Usage Start Date' ;
    rdfs:comment 'The date when the creative asset usage period begins. Marks the start of the active deployment window.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageStatus rdf:type rdf:Property ;
    rdfs:label 'Usage Status' ;
    rdfs:comment 'The current lifecycle status of this asset usage instance. Tracks whether the deployment is active, paused, completed, cancelled, or expired.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'The type of deployment or usage context for this asset instance. Distinguishes between campaign trafficking, ad server deployment, social media posting, email marketing, website placement, mobile app integration, or out-of-home display. [ENUM-REF-CANDIDATE: campaign|ad_server|social_media|email|website|mobile_app|ooh — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate' ;
    rdfs:comment 'The video completion rate for video asset usage, expressed as a decimal. Percentage of video views that reached 100% completion. Null for non-video assets.' ;
    rdfs:domain ind:AssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandGuidelineId rdf:type rdf:Property ;
    rdfs:label 'Brand Guideline Id' ;
    rdfs:comment 'Unique identifier for the creative brand guideline record. Primary key.' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandGuideline .

ind:maintainedByWorkerId rdf:type rdf:Property ;
    rdfs:label 'Maintained By Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Tracks which employee maintains brand guidelines. Essential for guideline ownership, update accountability, and brand governance. Replaces denormalized text field with structured FK for stewardship re' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:complianceThresholdScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold Score' ;
    rdfs:comment 'Minimum compliance score (0-100) required for creative assets to pass brand compliance validation during review and production QA.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceValidationEnabled rdf:type rdf:Property ;
    rdfs:label 'Compliance Validation Enabled' ;
    rdfs:comment 'Flag indicating whether automated brand compliance validation is enabled for creative assets produced under this guideline.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalAssetManagementUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Asset Management Url' ;
    rdfs:comment 'URL or reference to the location of the full brand guideline document in the Digital Asset Management system (e.g., Workfront DAM, Adobe Experience Manager).' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doExamples rdf:type rdf:Property ;
    rdfs:label 'Do Examples' ;
    rdfs:comment 'Positive examples demonstrating correct application of brand guidelines. Used for training and reference during creative production.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dontExamples rdf:type rdf:Property ;
    rdfs:label 'Dont Examples' ;
    rdfs:comment 'Negative examples showing incorrect or prohibited uses of brand elements. Critical for compliance validation and creative QA.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatSpecifications rdf:type rdf:Property ;
    rdfs:label 'Format Specifications' ;
    rdfs:comment 'Technical specifications for creative asset formats including file types, dimensions, resolution, color space, and compression standards for different channels (digital, print, OOH, OTT, CTV).' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineDescription rdf:type rdf:Property ;
    rdfs:label 'Guideline Description' ;
    rdfs:comment 'Detailed description of the scope, purpose, and coverage of this brand guideline document.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineStatus rdf:type rdf:Property ;
    rdfs:label 'Guideline Status' ;
    rdfs:comment 'Current lifecycle status of the brand guideline. Indicates whether the guideline is in draft, actively used, archived, superseded by a newer version, or under review.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineVersion rdf:type rdf:Property ;
    rdfs:label 'Guideline Version' ;
    rdfs:comment 'Version identifier for this brand guideline (e.g., \'v3.2\', \'2024.1\'). Supports version control and change tracking.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageryStyleGuidelines rdf:type rdf:Property ;
    rdfs:label 'Imagery Style Guidelines' ;
    rdfs:comment 'Guidelines governing photography and imagery style including subject matter, composition, lighting, color treatment, and mood. Ensures visual consistency.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoClearSpaceMinimum rdf:type rdf:Property ;
    rdfs:label 'Logo Clear Space Minimum' ;
    rdfs:comment 'Minimum clear space required around the logo, typically expressed as a multiple of a logo element (e.g., \'2x height of logo mark\').' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoMinimumSize rdf:type rdf:Property ;
    rdfs:label 'Logo Minimum Size' ;
    rdfs:comment 'Minimum allowable size for logo reproduction across different media (print, digital, OOH), ensuring legibility and brand integrity.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messagingGuidelines rdf:type rdf:Property ;
    rdfs:label 'Messaging Guidelines' ;
    rdfs:comment 'Key messaging pillars, brand promises, value propositions, and approved language for brand communications.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColorPalette rdf:type rdf:Property ;
    rdfs:label 'Primary Color Palette' ;
    rdfs:comment 'Approved primary brand colors in multiple formats (hex, Pantone, CMYK, RGB). Stored as structured text or JSON for parsing by creative tools.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryColorPalette rdf:type rdf:Property ;
    rdfs:label 'Secondary Color Palette' ;
    rdfs:comment 'Approved secondary or accent brand colors in multiple formats (hex, Pantone, CMYK, RGB). Used for supporting visual elements.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typographyRules rdf:type rdf:Property ;
    rdfs:label 'Typography Rules' ;
    rdfs:comment 'Detailed rules governing typography usage including font weights, sizes, line spacing, letter spacing, and hierarchy. Stored as structured text or JSON.' ;
    rdfs:domain ind:BrandGuideline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectBriefId rdf:type rdf:Property ;
    rdfs:label 'Project Brief Id' ;
    rdfs:comment 'Foreign key linking to project.project_brief. Business justification: Creative briefs are execution-level briefs derived from project briefs. Linking enables strategic alignment validation, requirements traceability, scope verification, and brief-to-execution tracking. ' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectBrief .

ind:requestedByWorkerId rdf:type rdf:Property ;
    rdfs:label 'Requested By Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Tracks which internal employee requested the creative brief. Essential for workload analysis, requestor accountability, and brief intake workflow management. Replaces denormalized name/email fields wi' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:artDirectorAssigned rdf:type rdf:Property ;
    rdfs:label 'Art Director Assigned' ;
    rdfs:comment 'Name of the art director assigned to develop visual concepts and design for this creative brief.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandGuidelinesReference rdf:type rdf:Property ;
    rdfs:label 'Brand Guidelines Reference' ;
    rdfs:comment 'Reference to applicable brand guidelines, style guides, or Digital Asset Management (DAM) locations that creative teams must follow.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefName rdf:type rdf:Property ;
    rdfs:label 'Brief Name' ;
    rdfs:comment 'Descriptive name or title of the creative brief, typically reflecting the campaign or project name.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessObjective rdf:type rdf:Property ;
    rdfs:label 'Business Objective' ;
    rdfs:comment 'High-level business goal that this creative work is intended to achieve, such as brand awareness, lead generation, or product launch support.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToAction rdf:type rdf:Property ;
    rdfs:label 'Call To Action' ;
    rdfs:comment 'Desired audience action or response that the creative should drive, such as visit website, call now, or download app.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDistribution rdf:type rdf:Property ;
    rdfs:label 'Channel Distribution' ;
    rdfs:comment 'Media channels and platforms where the creative assets will be deployed, such as television, digital display, social media, OOH (Out-of-Home), or print.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copywriterAssigned rdf:type rdf:Property ;
    rdfs:label 'Copywriter Assigned' ;
    rdfs:comment 'Name of the copywriter assigned to develop written content for this creative brief.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeBriefStatus rdf:type rdf:Property ;
    rdfs:label 'Creative Brief Status' ;
    rdfs:comment 'Current lifecycle status of the creative brief in the approval and production workflow.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeDirectorAssigned rdf:type rdf:Property ;
    rdfs:label 'Creative Director Assigned' ;
    rdfs:comment 'Name of the creative director assigned to oversee and approve the creative development for this brief.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableFormats rdf:type rdf:Property ;
    rdfs:label 'Deliverable Formats' ;
    rdfs:comment 'List of required creative asset formats and specifications, such as video lengths, display ad dimensions, print sizes, or social media formats.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRegulatoryRequirements rdf:type rdf:Property ;
    rdfs:label 'Legal Regulatory Requirements' ;
    rdfs:comment 'Specific legal disclaimers, regulatory compliance requirements, or industry standards that must be adhered to in the creative execution.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatories rdf:type rdf:Property ;
    rdfs:label 'Mandatories' ;
    rdfs:comment 'Required elements that must be included in the creative execution, such as logos, legal disclaimers, regulatory statements, or specific product features.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Date when the creative brief was formally submitted for review and approval.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:successMetrics rdf:type rdf:Property ;
    rdfs:label 'Success Metrics' ;
    rdfs:comment 'Key Performance Indicators (KPI) and measurement criteria that will be used to evaluate the effectiveness of the creative execution.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingMessages rdf:type rdf:Property ;
    rdfs:label 'Supporting Messages' ;
    rdfs:comment 'Secondary messages or proof points that reinforce the key message and provide additional context.' ;
    rdfs:domain ind:CreativeBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeComplianceCheckId rdf:type rdf:Property ;
    rdfs:label 'Creative Compliance Check Id' ;
    rdfs:comment 'Unique identifier for the creative compliance check record. Primary key.' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Id' ;
    rdfs:comment 'Foreign key linking to project.approval_workflow. Business justification: Compliance checks require approval workflows. Linking enables multi-stage review, sign-off tracking, audit trail maintenance, and regulatory compliance verification. Critical for brand safety and lega' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovalWorkflow .

ind:changeRequestId rdf:type rdf:Property ;
    rdfs:label 'Change Request Id' ;
    rdfs:comment 'Foreign key linking to project.change_request. Business justification: Compliance failures trigger change requests. Linking enables remediation tracking, client communication, timeline impact analysis, and cost recovery. Critical for risk management and client relationsh' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeRequest .

ind:previousCheckCreativeComplianceCheckId rdf:type rdf:Property ;
    rdfs:label 'Previous Check Creative Compliance Check Id' ;
    rdfs:comment 'Reference to a prior compliance check record for this asset, enabling version tracking and remediation history.' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeComplianceCheck .

ind:proofId rdf:type rdf:Property ;
    rdfs:label 'Proof Id' ;
    rdfs:comment 'Foreign key linking to creative.proof. Business justification: Compliance checks can be performed on proofs during the review cycle, not just on final assets. This allows early-stage compliance validation before final production. Cardinality: N:1 (one proof can h' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Proof .

ind:brandCompliancePass rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Pass' ;
    rdfs:comment 'Boolean flag indicating whether the asset passed brand compliance checks (logo usage, color palette, typography, tone of voice, brand guidelines adherence).' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'Date when the compliance check was performed or initiated. Principal business event timestamp for this review.' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Check Duration Minutes' ;
    rdfs:comment 'Total time spent performing the compliance check, measured in minutes. Used for resource planning and efficiency analysis.' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkStatus rdf:type rdf:Property ;
    rdfs:label 'Check Status' ;
    rdfs:comment 'Current lifecycle status of the compliance check: pending (queued), in_progress (under review), completed (review finished), approved (passed all checks), rejected (failed), remediation_required (conditional pass with required fixes).' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Timestamp' ;
    rdfs:comment 'Precise timestamp when the compliance check was initiated, providing audit-level granularity for regulatory reporting.' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkType rdf:type rdf:Property ;
    rdfs:label 'Check Type' ;
    rdfs:comment 'Category of compliance review performed: brand compliance (brand guidelines adherence), legal/regulatory (FTC, ASA, GDPR, CCPA disclosures), platform policy (IAB, TAG, MRC standards), or full review (all categories).' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCompliancePass rdf:type rdf:Property ;
    rdfs:label 'Legal Compliance Pass' ;
    rdfs:comment 'Boolean flag indicating whether the asset passed legal and regulatory compliance checks (FTC disclosures, ASA code, GDPR consent language, CCPA privacy notices, truth in advertising).' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformPolicyPass rdf:type rdf:Property ;
    rdfs:label 'Platform Policy Pass' ;
    rdfs:comment 'Boolean flag indicating whether the asset passed platform-specific policy compliance checks (IAB standards, TAG certification, MRC measurement guidelines, VAST/VPAID specifications, social media ad policies).' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformTarget rdf:type rdf:Property ;
    rdfs:label 'Platform Target' ;
    rdfs:comment 'Target advertising platform or channel for which compliance is being checked (e.g., Google Ads, Facebook, Instagram, YouTube, LinkedIn, TikTok, OOH, CTV). Platform-specific policies may apply. [ENUM-REF-CANDIDATE: Google_Ads|Facebook|Instagram|YouTube|LinkedIn|TikTok|Twitter|Snapchat|Pinterest|OOH|DOOH|CTV|OTT|Display|Native|Email — promote to reference product]' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recheckRequired rdf:type rdf:Property ;
    rdfs:label 'Recheck Required' ;
    rdfs:comment 'Boolean flag indicating whether a follow-up compliance check is required after remediation actions are completed.' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationActions rdf:type rdf:Property ;
    rdfs:label 'Remediation Actions' ;
    rdfs:comment 'Detailed description of specific remediation actions required to bring the asset into compliance. Free-text field providing actionable guidance to creative teams.' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Required' ;
    rdfs:comment 'Boolean flag indicating whether remediation actions are required before the asset can be approved for use.' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signOffBy rdf:type rdf:Property ;
    rdfs:label 'Sign Off By' ;
    rdfs:comment 'Name of the person who provided formal sign-off or approval, establishing accountability for compliance decisions.' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffStatus rdf:type rdf:Property ;
    rdfs:label 'Sign Off Status' ;
    rdfs:comment 'Status of formal sign-off or approval following the compliance check: not_required (auto-approved), pending (awaiting sign-off), approved (formally signed off), rejected (sign-off denied).' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Total number of distinct compliance violations identified in this check, used for severity assessment and prioritization.' ;
    rdfs:domain ind:CreativeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedArtDirectorWorkerId rdf:type rdf:Property ;
    rdfs:label 'Assigned Art Director Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Tracks art director assigned to deliverable. Essential for resource allocation, workload management, and creative team accountability. Replaces denormalized text field with structured FK for capacity ' ;
    rdfs:domain ind:CreativeDeliverable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:productionJobId rdf:type rdf:Property ;
    rdfs:label 'Production Job Id' ;
    rdfs:comment 'Foreign key linking to creative.production_job. Business justification: A creative deliverable is the output produced by a production job. This is a direct operational relationship: the production job is the unit of work that creates the deliverable. Cardinality: N:1 (one' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionJob .

ind:projectBudgetId rdf:type rdf:Property ;
    rdfs:label 'Project Budget Id' ;
    rdfs:comment 'Foreign key linking to project.project_budget. Business justification: Deliverables have budget allocations. Linking enables cost-to-deliver tracking, profitability analysis, budget forecasting, and financial reporting. Critical for project financial management and prici' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectBudget .

ind:projectMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Project Milestone Id' ;
    rdfs:comment 'Foreign key linking to project.project_milestone. Business justification: Deliverables are tied to contractual milestones. Linking enables billing trigger validation, client acceptance tracking, payment release management, and SOW compliance verification. Essential for reve' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectMilestone .

ind:workPackageId rdf:type rdf:Property ;
    rdfs:label 'Work Package Id' ;
    rdfs:comment 'Foreign key linking to project.work_package. Business justification: Deliverables map to specific work packages in WBS. Linking enables granular schedule tracking, resource allocation, earned value management, and deliverable-level progress reporting. Essential for pro' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkPackage .

ind:acceptedDate rdf:type rdf:Property ;
    rdfs:label 'Accepted Date' ;
    rdfs:comment 'Date when the client formally accepted the deliverable and signed off on completion.' ;
    rdfs:domain ind:CreativeDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedCopywriter rdf:type rdf:Property ;
    rdfs:label 'Assigned Copywriter' ;
    rdfs:comment 'Name of the copywriter assigned to develop copy and messaging for this deliverable.' ;
    rdfs:domain ind:CreativeDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedCreativeTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Creative Team' ;
    rdfs:comment 'Name or identifier of the creative team or studio responsible for producing this deliverable.' ;
    rdfs:domain ind:CreativeDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableStatus rdf:type rdf:Property ;
    rdfs:label 'Deliverable Status' ;
    rdfs:comment 'Current lifecycle status of the creative deliverable in the production and approval workflow. [ENUM-REF-CANDIDATE: not_started|in_production|in_review|revisions_requested|approved|delivered|accepted|rejected|on_hold|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredDate rdf:type rdf:Property ;
    rdfs:label 'Delivered Date' ;
    rdfs:comment 'Date when the deliverable was delivered to the client or uploaded to the delivery platform.' ;
    rdfs:domain ind:CreativeDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dimensions rdf:type rdf:Property ;
    rdfs:label 'Dimensions' ;
    rdfs:comment 'Physical or pixel dimensions of the deliverable (e.g., \'300x250\', \'1920x1080\', \'8.5x11 inches\').' ;
    rdfs:domain ind:CreativeDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Size of the final deliverable file in megabytes, used for storage planning and delivery validation.' ;
    rdfs:domain ind:CreativeDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Approval Required' ;
    rdfs:comment 'Flag indicating whether this deliverable requires legal review and approval before delivery (e.g., for claims, disclaimers, regulatory compliance).' ;
    rdfs:domain ind:CreativeDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Approval Status' ;
    rdfs:comment 'Current status of legal review and approval for this deliverable.' ;
    rdfs:domain ind:CreativeDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStartDate rdf:type rdf:Property ;
    rdfs:label 'Production Start Date' ;
    rdfs:comment 'Date when production work on this deliverable began.' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityRequired rdf:type rdf:Property ;
    rdfs:label 'Quantity Required' ;
    rdfs:comment 'Number of units or versions of this deliverable required (e.g., 3 language versions, 5 size variations).' ;
    rdfs:domain ind:CreativeDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionCount rdf:type rdf:Property ;
    rdfs:label 'Revision Count' ;
    rdfs:comment 'Number of revision cycles this deliverable has undergone since initial submission.' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creativeRequestId rdf:type rdf:Property ;
    rdfs:label 'Creative Request Id' ;
    rdfs:comment 'Unique identifier for the creative request. Primary key.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCreativeClientContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Creative Client Contact Id' ;
    rdfs:comment 'Reference to the client contact or internal stakeholder who initiated the creative request.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Date and time when the creative request was actually completed and delivered.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedStudio rdf:type rdf:Property ;
    rdfs:label 'Assigned Studio' ;
    rdfs:comment 'Name or identifier of the creative studio, production unit, or external vendor assigned to fulfill the request.' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTeamMemberName rdf:type rdf:Property ;
    rdfs:label 'Assigned Team Member Name' ;
    rdfs:comment 'Name of the creative professional or studio assigned to the request for quick reference.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Rationale or business reason for the creative request, explaining why the change is necessary.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Estimated number of hours required to complete the creative request, used for resource planning and capacity management.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactedAssetCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Asset Count' ;
    rdfs:comment 'Number of creative assets that will be affected or modified by this request.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactedAssetList rdf:type rdf:Property ;
    rdfs:label 'Impacted Asset List' ;
    rdfs:comment 'Comma-separated list or description of specific creative asset IDs or names that are impacted by this request.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Indicates whether the creative request requires legal or compliance review before completion.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Three-letter ISO country code representing the target market or geography for which the creative request is intended.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address of the requestor for communication and notification purposes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the individual who submitted the creative request.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Deadline Timestamp' ;
    rdfs:comment 'Service Level Agreement deadline timestamp by which the request must be completed to meet contractual obligations.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workfrontRequestRef rdf:type rdf:Property ;
    rdfs:label 'Workfront Request Ref' ;
    rdfs:comment 'External system identifier from Workfront request queue, used for integration and cross-system tracking.' ;
    rdfs:domain ind:CreativeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adUnitType rdf:type rdf:Property ;
    rdfs:label 'Ad Unit Type' ;
    rdfs:comment 'The type of ad unit (e.g., Banner, Interstitial, Video, Native, Story, Carousel, Sponsored Post, Billboard, Transit Shelter).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animationLoopAllowed rdf:type rdf:Property ;
    rdfs:label 'Animation Loop Allowed' ;
    rdfs:comment 'Indicates whether animated creatives (GIF, HTML5) are allowed to loop continuously (True) or must play once (False).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioChannels rdf:type rdf:Property ;
    rdfs:label 'Audio Channels' ;
    rdfs:comment 'The required audio channel configuration (mono, stereo, surround). Null for non-audio formats.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioCodec rdf:type rdf:Property ;
    rdfs:label 'Audio Codec' ;
    rdfs:comment 'The required audio codec for video or audio creatives (e.g., AAC, MP3, Vorbis). Null for non-audio formats.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioSampleRateHz rdf:type rdf:Property ;
    rdfs:label 'Audio Sample Rate Hz' ;
    rdfs:comment 'The required audio sample rate in Hertz (e.g., 44100, 48000). Null for non-audio formats.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bitRateKbps rdf:type rdf:Property ;
    rdfs:label 'Bit Rate Kbps' ;
    rdfs:comment 'The required or recommended bit rate for video or audio creatives in kilobits per second (Kbps). Null for non-media formats.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bleedPixels rdf:type rdf:Property ;
    rdfs:label 'Bleed Pixels' ;
    rdfs:comment 'The bleed area in pixels extending beyond the trim edge for print creatives to ensure no white edges after cutting.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickableRequired rdf:type rdf:Property ;
    rdfs:label 'Clickable Required' ;
    rdfs:comment 'Indicates whether the creative must include a clickable call-to-action or link (True) or can be non-interactive (False).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceTags rdf:type rdf:Property ;
    rdfs:label 'Compliance Tags' ;
    rdfs:comment 'Comma-separated list of compliance or regulatory tags applicable to this specification (e.g., \'GDPR\', \'COPPA\', \'Alcohol Restricted\', \'Pharma Compliant\').' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatCategory rdf:type rdf:Property ;
    rdfs:label 'Format Category' ;
    rdfs:comment 'High-level category of the creative format (static image, animated image, video, audio, HTML5, rich media, native, interactive, print, physical). [ENUM-REF-CANDIDATE: static_image|animated_image|video|audio|html5|rich_media|native|interactive|print|physical — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameRateFps rdf:type rdf:Property ;
    rdfs:label 'Frame Rate Fps' ;
    rdfs:comment 'The required or recommended frame rate for video creatives in frames per second (e.g., 24, 30, 60). Null for non-video formats.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iabStandardUnit rdf:type rdf:Property ;
    rdfs:label 'Iab Standard Unit' ;
    rdfs:comment 'The IAB standard ad unit designation if this specification conforms to an IAB standard (e.g., \'Medium Rectangle\', \'Leaderboard\', \'Skyscraper\').' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAnimationLoops rdf:type rdf:Property ;
    rdfs:label 'Max Animation Loops' ;
    rdfs:comment 'The maximum number of times an animated creative is allowed to loop. Null if unlimited or not applicable.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Max Duration Seconds' ;
    rdfs:comment 'The maximum duration for video or audio creatives in seconds. Null for non-time-based formats.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxFileSizeKb rdf:type rdf:Property ;
    rdfs:label 'Max File Size Kb' ;
    rdfs:comment 'The maximum allowed file size for the creative asset in kilobytes (KB).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Min Duration Seconds' ;
    rdfs:comment 'The minimum duration for video or audio creatives in seconds. Null for non-time-based formats.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformSpecVersion rdf:type rdf:Property ;
    rdfs:label 'Platform Spec Version' ;
    rdfs:comment 'The version of the platform-specific specification this record is based on (e.g., \'Meta Q1 2024\', \'Google CM360 v3.2\'). Used to track spec changes as platforms update requirements.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeZonePixels rdf:type rdf:Property ;
    rdfs:label 'Safe Zone Pixels' ;
    rdfs:comment 'The safe zone margin in pixels where critical content (text, logos) must remain to avoid being cut off during display or printing.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specCode rdf:type rdf:Property ;
    rdfs:label 'Spec Code' ;
    rdfs:comment 'Unique business identifier code for the specification, used for system integration and asset validation workflows.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specName rdf:type rdf:Property ;
    rdfs:label 'Spec Name' ;
    rdfs:comment 'Human-readable name for the creative specification (e.g., \'Facebook Feed Image Standard\', \'Google Display 300x250\', \'Instagram Story Video\').' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specStatus rdf:type rdf:Property ;
    rdfs:label 'Spec Status' ;
    rdfs:comment 'Current lifecycle status of the creative specification (active, deprecated, draft, archived, pending approval, retired).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transparencyAllowed rdf:type rdf:Property ;
    rdfs:label 'Transparency Allowed' ;
    rdfs:comment 'Indicates whether the creative format supports transparency (alpha channel) in images (True) or requires opaque backgrounds (False).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:videoCodec rdf:type rdf:Property ;
    rdfs:label 'Video Codec' ;
    rdfs:comment 'The required video codec for video creatives (e.g., H.264, H.265, VP9). Null for non-video formats.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductionWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Worker Id' ;
    rdfs:comment 'Reference to the producer or project manager responsible for overseeing this production job.' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:brandComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Required' ;
    rdfs:comment 'Indicates whether this production job requires formal brand guideline compliance review and approval.' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliverableCount rdf:type rdf:Property ;
    rdfs:label 'Deliverable Count' ;
    rdfs:comment 'Total number of distinct creative assets or deliverables produced as part of this production job.' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryDeadline rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline' ;
    rdfs:comment 'Target date by which final creative assets must be delivered to the client or campaign team.' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Final Delivery Date' ;
    rdfs:comment 'Date when final approved creative assets were delivered to the client or campaign team.' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether this production job is billable to the client or is internal/non-billable work.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Detailed description of the production job scope, objectives, and deliverables as defined in the creative brief or project plan.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobName rdf:type rdf:Property ;
    rdfs:label 'Job Name' ;
    rdfs:comment 'Human-readable name or title of the production job, typically describing the deliverable or campaign element.' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobNumber rdf:type rdf:Property ;
    rdfs:label 'Job Number' ;
    rdfs:comment 'Externally-known unique job number assigned by the production management system (e.g., Workfront). Format typically includes prefix and sequential number.' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobStatus rdf:type rdf:Property ;
    rdfs:label 'Job Status' ;
    rdfs:comment 'Current lifecycle status of the production job. Values: briefed (job briefed, not started), in-production (active production work), internal-review (internal creative review), qa (quality assurance check), client-review (submitted to client), revisions (rework requested), approved (client approved), delivered (final assets delivered), cancelled (job cancelled). [ENUM-REF-CANDIDATE: briefed|in-production|internal-review|qa|client-review|revisions|approved|delivered|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobType rdf:type rdf:Property ;
    rdfs:label 'Job Type' ;
    rdfs:comment 'Category of creative production work. Values: print (print advertising), digital (digital display/banner), video (video production), audio (radio/podcast), ooh (Out-of-Home static), dooh (Digital Out-of-Home), ctv (Connected TV), social (social media creative), experiential (event/activation), motion-graphics (animation/motion design). [ENUM-REF-CANDIDATE: print|digital|video|audio|ooh|dooh|ctv|social|experiential|motion-graphics — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Production Completion Date' ;
    rdfs:comment 'Date when production work was completed and job moved to review or delivery status.' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP Project Systems WBS element code used for cost tracking and financial reconciliation of this production job.' ;
    rdfs:domain ind:ProductionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalCount rdf:type rdf:Property ;
    rdfs:label 'Approval Count' ;
    rdfs:comment 'Number of reviewers who approved the proof (either approved or approved with changes). Used for consensus tracking.' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automatedCheckFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Check Flag' ;
    rdfs:comment 'Indicates whether automated compliance checks (legal, accessibility, brand guidelines) were run on this proof. True = automated checks performed, False = manual review only.' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automatedCheckResult rdf:type rdf:Property ;
    rdfs:label 'Automated Check Result' ;
    rdfs:comment 'Result of automated compliance checks if performed. Pass = all checks passed, Fail = critical issues found, Warning = minor issues flagged, Not Applicable = no automated checks run.' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentCount rdf:type rdf:Property ;
    rdfs:label 'Comment Count' ;
    rdfs:comment 'Total number of comments and annotations submitted by all reviewers on this proof. Indicator of feedback volume and creative iteration intensity.' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Date and time when the overall proof decision was finalized. Used as the end point for SLA turnaround time calculations.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instructions rdf:type rdf:Property ;
    rdfs:label 'Instructions' ;
    rdfs:comment 'Free-text instructions or context provided to reviewers about what to focus on in this proof (e.g., \'Please review headline copy for brand voice compliance\').' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallDecision rdf:type rdf:Property ;
    rdfs:label 'Overall Decision' ;
    rdfs:comment 'Consolidated decision outcome across all assigned reviewers. Approved = all reviewers approved, Approved with Changes = approved but revisions requested, Rejected = requires major rework, Pending = awaiting reviewer decisions.' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofName rdf:type rdf:Property ;
    rdfs:label 'Proof Name' ;
    rdfs:comment 'Descriptive name of the proof, typically derived from the asset name and proof round (e.g., \'Q1 Campaign Hero Banner - Client Round 2\').' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofNumber rdf:type rdf:Property ;
    rdfs:label 'Proof Number' ;
    rdfs:comment 'Human-readable business identifier for the proof, typically auto-generated in format PRF-YYYYMMDD or similar.' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofStatus rdf:type rdf:Property ;
    rdfs:label 'Proof Status' ;
    rdfs:comment 'Current lifecycle status of the proof. Draft = being prepared, Submitted = sent to reviewers, In Review = active review in progress, Approved = accepted as-is, Approved with Changes = accepted with minor revisions, Rejected = requires major rework, Cancelled = proof withdrawn. [ENUM-REF-CANDIDATE: draft|submitted|in_review|approved|approved_with_changes|rejected|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofType rdf:type rdf:Property ;
    rdfs:label 'Proof Type' ;
    rdfs:comment 'Type of proof being submitted for review. Concept = early ideation, Copy = text/messaging review, Layout = design structure, Final Art = production-ready creative, Legal = regulatory compliance review, Accessibility = WCAG/ADA compliance, Brand Compliance = brand guideline adherence. [ENUM-REF-CANDIDATE: concept|copy|layout|final_art|legal|accessibility|brand_compliance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionCount rdf:type rdf:Property ;
    rdfs:label 'Rejection Count' ;
    rdfs:comment 'Number of reviewers who rejected the proof. Used for quality control and creative iteration analysis.' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewerCount rdf:type rdf:Property ;
    rdfs:label 'Reviewer Count' ;
    rdfs:comment 'Total number of reviewers assigned to this proof. Used for workload and stakeholder engagement analysis.' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundNumber rdf:type rdf:Property ;
    rdfs:label 'Round Number' ;
    rdfs:comment 'Sequential round number for this proof within the asset version lifecycle (1 = first proof, 2 = second proof after revisions, etc.).' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Stage of the proofing workflow. Internal = agency-only review, Client Round 1/2/3 = sequential client review cycles, Final = final approval before production.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Hours' ;
    rdfs:comment 'Calculated elapsed time in hours between submission_timestamp and decision_timestamp. Key metric for agency SLA compliance reporting on review cycle speed.' ;
    rdfs:domain ind:Proof ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofCommentId rdf:type rdf:Property ;
    rdfs:label 'Proof Comment Id' ;
    rdfs:comment 'Unique identifier for the proof comment record. Primary key.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCommentProofCommentId rdf:type rdf:Property ;
    rdfs:label 'Parent Comment Proof Comment Id' ;
    rdfs:comment 'Reference to the parent comment if this is a reply or threaded response. Null for top-level comments. Supports nested conversation threads within proof reviews.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProofComment .

ind:primaryProofWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Proof Worker Id' ;
    rdfs:comment 'Reference to the user or stakeholder who authored this comment. May be internal team member, client contact, or external reviewer.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:reviewCycleId rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Id' ;
    rdfs:comment 'Reference to the review cycle or approval stage during which this comment was made. Supports multi-stage approval workflows.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewCycle .

ind:tertiaryProofDeletedByWorkerId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Proof Deleted By Worker Id' ;
    rdfs:comment 'Reference to the user who deleted the comment. Null if the comment has not been deleted. Supports audit trail and accountability.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:annotationPageNumber rdf:type rdf:Property ;
    rdfs:label 'Annotation Page Number' ;
    rdfs:comment 'Page or frame number within a multi-page proof document (e.g., PDF, presentation deck, video timeline) where the annotation is placed. Null for single-page assets or general comments.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annotationTimestampSeconds rdf:type rdf:Property ;
    rdfs:label 'Annotation Timestamp Seconds' ;
    rdfs:comment 'Timestamp in seconds for video or audio proof assets, indicating the exact moment in the timeline where the comment applies. Null for static image or document proofs.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annotationXCoordinate rdf:type rdf:Property ;
    rdfs:label 'Annotation X Coordinate' ;
    rdfs:comment 'Horizontal position coordinate of the visual markup or annotation on the proof asset. Null for general comments not tied to a specific location. Expressed as normalized coordinate (0.0 to 1.0) or pixel position depending on system configuration.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annotationYCoordinate rdf:type rdf:Property ;
    rdfs:label 'Annotation Y Coordinate' ;
    rdfs:comment 'Vertical position coordinate of the visual markup or annotation on the proof asset. Null for general comments not tied to a specific location. Expressed as normalized coordinate (0.0 to 1.0) or pixel position depending on system configuration.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attachmentFileName rdf:type rdf:Property ;
    rdfs:label 'Attachment File Name' ;
    rdfs:comment 'Original file name of the attachment, if provided. Used for display and audit purposes.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Attachment Url' ;
    rdfs:comment 'URL or file path to any supporting document, reference image, or file attached to the comment. Null if no attachment is provided.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentPriority rdf:type rdf:Property ;
    rdfs:label 'Comment Priority' ;
    rdfs:comment 'Priority or severity level assigned to the comment, indicating urgency of resolution. Critical issues may block approval; low priority may be optional enhancements.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentSource rdf:type rdf:Property ;
    rdfs:label 'Comment Source' ;
    rdfs:comment 'The channel or interface through which the comment was submitted. Tracks whether feedback came from the proofing web app, mobile app, email integration, or external API.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentText rdf:type rdf:Property ;
    rdfs:label 'Comment Text' ;
    rdfs:comment 'The full text content of the feedback or annotation provided by the reviewer. Captures the detailed feedback, suggestion, or approval note.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentType rdf:type rdf:Property ;
    rdfs:label 'Comment Type' ;
    rdfs:comment 'Categorical classification of the comment based on the nature of feedback. Enables filtering and routing of comments to appropriate resolution teams. [ENUM-REF-CANDIDATE: general|legal|brand|copy|design|technical|compliance|approval|rejection — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commenterName rdf:type rdf:Property ;
    rdfs:label 'Commenter Name' ;
    rdfs:comment 'Full name of the person who made the comment, captured at the time of comment creation for audit trail purposes.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commenterRole rdf:type rdf:Property ;
    rdfs:label 'Commenter Role' ;
    rdfs:comment 'The functional role or responsibility of the commenter in the review process. Used to categorize feedback by stakeholder type and prioritize resolution. [ENUM-REF-CANDIDATE: creative_director|copywriter|art_director|account_manager|client_stakeholder|legal_reviewer|brand_manager|producer|external_reviewer|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deleted Timestamp' ;
    rdfs:comment 'Date and time when the comment was marked as deleted. Null if the comment has not been deleted.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isClientVisible rdf:type rdf:Property ;
    rdfs:label 'Is Client Visible' ;
    rdfs:comment 'Indicates whether this comment is visible to external client stakeholders or is internal-only feedback. Supports internal team collaboration without exposing all feedback to clients.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Indicates whether the comment has been soft-deleted. Supports audit trail retention while removing comments from active review workflows.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current resolution state of the comment in the approval workflow. Tracks whether feedback has been addressed, rejected, or is still pending action.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the comment was marked as resolved or closed. Null if comment is still open. Used to calculate resolution turnaround time.' ;
    rdfs:domain ind:ProofComment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rightsClearanceId rdf:type rdf:Property ;
    rdfs:label 'Rights Clearance Id' ;
    rdfs:comment 'Unique identifier for the rights clearance record. Primary key for tracking intellectual property and usage rights clearance throughout the creative asset lifecycle.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Stock Media Asset Id' ;
    rdfs:comment 'Unique identifier assigned by the stock media provider to the licensed asset. Required for license verification and audit trail.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:clearanceDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Clearance Documentation Url' ;
    rdfs:comment 'URL to the signed clearance documentation, talent release, or license agreement stored in the Digital Asset Management (DAM) system or document repository.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Clearance Number' ;
    rdfs:comment 'Business identifier for the rights clearance record, formatted as RC- followed by 8 digits. Used for external communication and tracking with legal teams and licensors.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Current lifecycle status of the rights clearance process. Critical for trafficking approval workflow and preventing rights violations in campaign execution.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveCategoryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Competitive Category Restrictions' ;
    rdfs:comment 'Description of competitive categories or brands that are restricted from using the same licensed content. Common in talent releases and music licensing.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Legal Review Notes' ;
    rdfs:comment 'Internal notes from legal review process documenting any concerns, special conditions, or clarifications regarding the rights clearance.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEndDate rdf:type rdf:Property ;
    rdfs:label 'License End Date' ;
    rdfs:comment 'Date when the usage rights expire. Critical for campaign trafficking systems to prevent rights violations. Null indicates perpetual rights.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'License Fee Amount' ;
    rdfs:comment 'Total fee paid for the usage rights. Used for budget reconciliation and cost allocation to campaigns. Does not include taxes or additional fees.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'License Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the license fee (e.g., USD, EUR, GBP). Required for multi-currency financial reporting and reconciliation.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'Date when the usage rights become effective. Assets cannot be used in campaigns before this date without violating license terms.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Licensor Contact Email' ;
    rdfs:comment 'Primary email address for the licensor or their representative. Used for rights negotiation, renewal notifications, and clearance documentation.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Licensor Contact Phone' ;
    rdfs:comment 'Primary phone number for the licensor or their representative for urgent clearance matters and contract negotiations.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorName rdf:type rdf:Property ;
    rdfs:label 'Licensor Name' ;
    rdfs:comment 'Name of the entity or individual granting the usage rights. May be a talent agency, stock media provider, music publisher, or rights holder.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicArtist rdf:type rdf:Property ;
    rdfs:label 'Music Artist' ;
    rdfs:comment 'Name of the recording artist or composer of the licensed music. Used for rights attribution and royalty reporting to performance rights organizations.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicIsrcCode rdf:type rdf:Property ;
    rdfs:label 'Music Isrc Code' ;
    rdfs:comment 'International Standard Recording Code uniquely identifying the music recording. Standard identifier for music rights tracking and royalty distribution.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicTitle rdf:type rdf:Property ;
    rdfs:label 'Music Title' ;
    rdfs:comment 'Title of the licensed music track used in the creative asset. Required for music rights tracking and performance rights organization (PRO) reporting.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedChannels rdf:type rdf:Property ;
    rdfs:label 'Permitted Channels' ;
    rdfs:comment 'Comma-separated list of media channels where the asset may be used (e.g., TV, digital, OOH, social, radio, print, CTV, OTT, DOOH). Channel restrictions are critical for trafficking compliance. [ENUM-REF-CANDIDATE: tv|digital|social|ooh|dooh|radio|print|ctv|ott|cinema|podcast|email|sms — promote to reference product]' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedTerritories rdf:type rdf:Property ;
    rdfs:label 'Permitted Territories' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the asset may be used (e.g., USA, CAN, GBR, DEU). Geographic restrictions are enforced in campaign geo-targeting to prevent rights violations.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Days' ;
    rdfs:comment 'Number of days before license expiration that renewal notification must be sent to the licensor. Used for automated renewal workflow triggers.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Available' ;
    rdfs:comment 'Indicates whether the license includes an option to renew upon expiration. Used for proactive rights management and campaign continuity planning.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsType rdf:type rdf:Property ;
    rdfs:label 'Rights Type' ;
    rdfs:comment 'Category of intellectual property rights being cleared. Determines the specific clearance requirements and documentation needed for legal compliance. [ENUM-REF-CANDIDATE: talent_release|music_license|stock_image|stock_video|third_party_ip|trademark|copyright|publicity_rights — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Legal teams assessment of the risk level associated with using this asset. High or critical risk assets require additional approval layers before trafficking.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyStructure rdf:type rdf:Property ;
    rdfs:label 'Royalty Structure' ;
    rdfs:comment 'Description of any performance-based royalty or usage-based fee structure beyond the base license fee. May include per-impression fees, revenue share, or tiered pricing.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockMediaProvider rdf:type rdf:Property ;
    rdfs:label 'Stock Media Provider' ;
    rdfs:comment 'Name of the stock media library or provider from which the image or video was licensed. Used for license compliance audits and vendor management.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentName rdf:type rdf:Property ;
    rdfs:label 'Talent Name' ;
    rdfs:comment 'Full name of the talent (actor, model, voice artist, influencer) appearing in the creative asset. Required for talent release tracking and union compliance reporting.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentUnionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Talent Union Affiliation' ;
    rdfs:comment 'Union membership status of the talent. Determines residual payment requirements, usage reporting obligations, and contract terms.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitations rdf:type rdf:Property ;
    rdfs:label 'Usage Limitations' ;
    rdfs:comment 'Free-text description of any additional usage restrictions not captured in structured fields. May include impression caps, exclusivity clauses, competitive restrictions, or content adjacency requirements.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageReportFrequency rdf:type rdf:Property ;
    rdfs:label 'Usage Report Frequency' ;
    rdfs:comment 'Frequency at which usage reports must be submitted to the licensor. Determines reporting workflow and compliance monitoring schedule.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Usage Tracking Required' ;
    rdfs:comment 'Indicates whether detailed usage tracking and reporting is required by the license terms. When true, impression counts and placement details must be reported to the licensor.' ;
    rdfs:domain ind:RightsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accrualId rdf:type rdf:Property ;
    rdfs:label 'Accrual Id' ;
    rdfs:comment 'Unique identifier for the accrual record. Primary key for the accrual entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Accrual .

ind:accrualAccountGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Accrual Account Gl Account Id' ;
    rdfs:comment 'Reference to the client account associated with this accrual, enabling client-level revenue and cost tracking for Profit and Loss (P&L) reporting.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accrualGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Accrual Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Accruals must post to specific GL accounts. Currently references via natural key (gl_account_code). Adding gl_account_id FK enables proper chart of accounts integration.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:clickEventId rdf:type rdf:Property ;
    rdfs:label 'Click Event Id' ;
    rdfs:comment 'Foreign key linking to performance.click_event. Business justification: CPC cost accruals based on delivered clicks not yet invoiced; requires click volume for accurate accrual estimation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClickEvent .

ind:financialCloseId rdf:type rdf:Property ;
    rdfs:label 'Financial Close Id' ;
    rdfs:comment 'Foreign key linking to finance.financial_close. Business justification: Accruals are posted during financial close periods as part of period-end adjustments. This FK links the accrual to the financial close period it belongs to, enabling close workflow tracking and ensuri' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialClose .

ind:impressionEventId rdf:type rdf:Property ;
    rdfs:label 'Impression Event Id' ;
    rdfs:comment 'Foreign key linking to performance.impression_event. Business justification: Media cost accruals estimate costs for delivered-but-not-yet-billed impressions; requires impression volume data for accurate accrual calculation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImpressionEvent .

ind:accrualDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Date' ;
    rdfs:comment 'The date on which the accrual entry is recorded in the financial system, typically the last day of the accounting period.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualDescription rdf:type rdf:Property ;
    rdfs:label 'Accrual Description' ;
    rdfs:comment 'Detailed narrative description of the accrual, explaining the nature of the cost or revenue, the business rationale, and any supporting context for period-end close and audit purposes.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualType rdf:type rdf:Property ;
    rdfs:label 'Accrual Type' ;
    rdfs:comment 'Classification of the accrual by nature of the transaction: expense accrual for general operating costs, revenue accrual for earned but unbilled revenue, media cost accrual for media buys incurred but not invoiced, production cost accrual for creative production work completed but not billed, talent cost accrual for freelance or contractor work performed but not invoiced, or overhead accrual for allocated indirect costs.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Invoice Amount' ;
    rdfs:comment 'The actual invoiced amount received after the accrual was posted, used to calculate accrual variance and improve future estimation accuracy. Populated when the actual invoice is received and matched to the accrual.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'The methodology used to calculate the accrual amount. Contract indicates the accrual is based on contractual terms; estimate indicates management estimate based on available information; historical indicates the accrual is based on historical spending patterns; percentage_of_completion indicates the accrual is calculated based on project completion percentage.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Amount' ;
    rdfs:comment 'The estimated monetary value of the accrued cost or revenue in the specified currency. This is the best estimate at period-end based on available information, contracts, and historical patterns.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period within the fiscal year to which this accrual applies. Format: Q1-Q4 for quarters, M01-M12 for months, or P01-P13 for SAP posting periods.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP CO internal order number for project-based or campaign-based cost tracking, used when accruals need to be allocated to specific internal orders for detailed cost control.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Material' ;
    rdfs:comment 'Boolean flag indicating whether this accrual is considered material for financial reporting purposes based on corporate materiality thresholds. Material accruals require additional review and documentation.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaoceanPrismaReference rdf:type rdf:Property ;
    rdfs:label 'Mediaocean Prisma Reference' ;
    rdfs:comment 'Reference identifier from Mediaocean Prisma system for media cost accruals, enabling reconciliation between media planning/buying platform and financial system.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the accrual entry was posted to the general ledger in the financial system, which may differ from the accrual date if the entry was prepared in advance and posted later.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'Name or user ID of the finance analyst or accountant who prepared this accrual entry, supporting accountability and audit trail requirements.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The profit center code to which this accrual is allocated, enabling profitability analysis by business unit, service line, or geographic region.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which this accrual is scheduled to be reversed, typically the first day of the subsequent accounting period. Accruals are reversed when the actual invoice or payment is received and recorded.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalStatus rdf:type rdf:Property ;
    rdfs:label 'Reversal Status' ;
    rdfs:comment 'Current status of the accrual reversal process. Pending indicates the accrual is active and awaiting reversal; reversed indicates the accrual has been reversed upon receipt of actual invoice; cancelled indicates the accrual was cancelled without reversal; adjusted indicates the accrual amount was modified before reversal.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiAccrualDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Accrual Document Number' ;
    rdfs:comment 'The SAP FI document number assigned to this accrual entry in the SAP S/4HANA system, used for traceability and reconciliation between the lakehouse and the source ERP system.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The difference between the estimated accrual amount and the actual invoice amount (actual_invoice_amount minus estimated_amount). Positive variance indicates over-accrual; negative variance indicates under-accrual. Used for accrual accuracy analysis and process improvement.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'Amount of the budget that has been allocated or committed to specific activities or sub-budgets, but not yet spent.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'The total approved budget amount in the specified currency. This is the baseline for spend authorization and variance analysis.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level financial category of the budget: operating (day-to-day operational expenses), capital (long-term asset investments), project (specific project-based allocation), discretionary (flexible spend allocation).' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetDescription rdf:type rdf:Property ;
    rdfs:label 'Budget Description' ;
    rdfs:comment 'Detailed description of the budget purpose, scope, and any special conditions or notes.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Descriptive name of the budget for easy identification and reporting purposes.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known unique business identifier for the budget record, used for reference in financial documents and approvals.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget by its purpose: campaign (client campaign spend), overhead (agency operational costs), media (media buying allocation), production (creative production costs), talent (talent and usage rights fees), creative (creative development costs).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockStatus rdf:type rdf:Property ;
    rdfs:label 'Lock Status' ;
    rdfs:comment 'Indicates whether the budget is locked (true) and cannot be modified, or unlocked (false) and can still be edited. Locked budgets are typically final versions used for variance reporting.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaoceanPrismaBudgetReference rdf:type rdf:Property ;
    rdfs:label 'Mediaocean Prisma Budget Reference' ;
    rdfs:comment 'Reference identifier to the corresponding budget record in Mediaocean Prisma for media planning and billing reconciliation.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or identifier of the individual or role responsible for managing and authorizing spend against this budget.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Amount' ;
    rdfs:comment 'Remaining unspent budget amount, calculated as approved amount minus spent amount and allocated amount.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapCoInternalOrder rdf:type rdf:Property ;
    rdfs:label 'Sap Co Internal Order' ;
    rdfs:comment 'Reference to the SAP S/4HANA CO internal order number used for cost collection and budget control in the ERP system.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spentAmount rdf:type rdf:Property ;
    rdfs:label 'Spent Amount' ;
    rdfs:comment 'Actual amount spent against this budget to date, used for budget-vs-actual variance analysis.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percent' ;
    rdfs:comment 'Acceptable variance threshold as a percentage of the approved budget. Exceeding this threshold triggers alerts or requires additional approval.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planLineId rdf:type rdf:Property ;
    rdfs:label 'Plan Line Id' ;
    rdfs:comment 'Foreign key linking to media.media_plan_line. Business justification: Budget lines allocated to plan lines for detailed budget management and plan-to-actual variance tracking in media planning.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanLine .

ind:billingCategory rdf:type rdf:Property ;
    rdfs:label 'Billing Category' ;
    rdfs:comment 'Classification of how this budget line will appear on client invoices. Aligns with industry-standard billing practices and client contract terms.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount of budget that has been committed through Insertion Orders (IO), contracts, or purchase orders but not yet invoiced or paid. Represents encumbered funds.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'Classification of the budget line by cost type. Determines how the expense is categorized in financial reporting and Profit and Loss (P&L) statements. [ENUM-REF-CANDIDATE: media|creative_production|talent|technology|research|overhead|contingency — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Detailed textual description of what this budget line covers, including scope, deliverables, and any special conditions or assumptions.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the parent budget. Used for ordering and referencing specific line items in budget documentation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Amount' ;
    rdfs:comment 'The current approved budget amount after any revisions, amendments, or reforecasts. Reflects the most up-to-date budget allocation for this line.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Client Invoice Id' ;
    rdfs:comment 'Unique identifier for the client invoice record. Primary key for the client invoice entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientInvoice .

ind:performanceKpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Performance Kpi Target Id' ;
    rdfs:comment 'Foreign key linking to performance.performance_kpi_target. Business justification: Performance-based invoicing validates delivery against contractual KPI targets; billing adjustments require linking to target definitions.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceKpiTarget .

ind:videoCompletionEventId rdf:type rdf:Property ;
    rdfs:label 'Video Completion Event Id' ;
    rdfs:comment 'Foreign key linking to performance.video_completion_event. Business justification: CPCV invoicing bills for video completions; invoice validation requires linking billed amounts to completion event data.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VideoCompletionEvent .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Additional adjustments applied to the invoice (credits, surcharges, reconciliation adjustments). Can be positive or negative.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountOutstanding rdf:type rdf:Property ;
    rdfs:label 'Amount Outstanding' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Calculated as total_amount minus amount_paid. Zero when invoice is fully paid.' ;
    rdfs:domain ind:ClientInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Total amount received from the client against this invoice. Used to track partial payments and calculate outstanding balance.' ;
    rdfs:domain ind:ClientInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the period covered by this invoice. Defines the scope of services or media placements included in the billing cycle.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this invoice. Relevant for retainer billing, subscription services, and time-based billing.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount applied to the invoice. May include volume discounts, early payment discounts, or negotiated rate reductions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date when the client raised a dispute on this invoice. Used for dispute aging and resolution tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Reason provided by client for disputing the invoice. Populated when invoice_status is disputed. Used for dispute resolution tracking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the invoice was issued to the client. Used for revenue recognition timing and aging analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNotes rdf:type rdf:Property ;
    rdfs:label 'Invoice Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to the invoice. May include payment instructions, billing clarifications, or client-specific requirements.' ;
    rdfs:domain ind:ClientInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice: draft (not yet finalized), issued (approved for sending), sent (delivered to client), partially_paid (payment in progress), paid (fully settled), overdue (past due date), disputed (under client review), cancelled (voided). [ENUM-REF-CANDIDATE: draft|issued|sent|partially_paid|paid|overdue|disputed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice based on billing model: retainer (recurring fee), project (fixed scope), media (placement costs), production (creative development), pass_through (third-party costs), or adjustment (credit/debit memo).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaoceanBillingReference rdf:type rdf:Property ;
    rdfs:label 'Mediaocean Billing Reference' ;
    rdfs:comment 'Reference identifier from Mediaocean Prisma billing system for media cost reconciliation and invoice generation. Links to media buy billing records.' ;
    rdfs:domain ind:ClientInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when full or final payment was received from the client. Null if invoice is unpaid or partially paid.' ;
    rdfs:domain ind:ClientInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Client purchase order number required for invoice processing. Many clients require PO reference for accounts payable approval.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Document Number' ;
    rdfs:comment 'SAP S/4HANA FI document number for the accounting entry created from this invoice. Links invoice to general ledger posting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Date and time when the invoice was sent to the client. Used for tracking invoice delivery and aging calculations.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Total invoice amount before taxes, discounts, or adjustments. Sum of all line item charges.' ;
    rdfs:domain ind:ClientInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount applied to the invoice (sales tax, VAT, GST). Calculated based on jurisdiction and tax rules.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final total amount due from the client. Calculated as subtotal + tax - discount + adjustment. This is the amount the client must pay.' ;
    rdfs:domain ind:ClientInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Reference to the parent cost center in a hierarchical cost center structure. Enables roll-up reporting and multi-level budget consolidation. Null for top-level cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'The total approved budget amount allocated to this cost center for the fiscal year. Used for budget-versus-actual variance analysis and financial planning.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which expenditures charged to this cost center require additional approval. Amounts below this threshold may be auto-approved based on delegation rules.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Budget Owner Email' ;
    rdfs:comment 'The email address of the budget owner for communication regarding budget approvals, variance reporting, and financial planning.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetOwnerName rdf:type rdf:Property ;
    rdfs:label 'Budget Owner Name' ;
    rdfs:comment 'The name of the individual responsible for managing and approving the budget for this cost center. Typically a department head, practice leader, or senior manager.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The company code or legal entity identifier to which this cost center belongs. Used for multi-entity financial consolidation and reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'The controlling area in SAP S/4HANA CO that groups cost centers for management accounting and internal reporting purposes. A controlling area may span multiple company codes.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'High-level functional category of the cost center. Production centers create deliverables, service centers provide internal services, support centers enable operations, sales centers drive revenue, marketing centers manage campaigns, and administration centers handle corporate governance.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The human-readable name or title of the cost center, used for display and reporting purposes.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active centers are operational and accepting charges, inactive centers are temporarily disabled, suspended centers are under review, closed centers are permanently retired, and pending approval centers are awaiting activation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center based on its function and cost allocation model. Overhead centers support general operations, billable centers track client-facing work, shared services centers provide cross-functional support, direct centers relate to revenue-generating activities, indirect centers support operations, and administrative centers manage corporate functions.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPoolFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Pool Flag' ;
    rdfs:comment 'Boolean indicator of whether this cost center functions as a cost pool that aggregates costs for subsequent allocation to other cost centers or client accounts. True indicates a cost pool; false indicates a standard cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'The username or identifier of the user who last modified this cost center record. Supports audit requirements and change management.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Three-letter code identifying the primary geographic location or office where this cost center operates. Examples include NYC, LON, SFO, TOR. Used for location-based cost analysis and reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Overhead Allocation Percentage' ;
    rdfs:comment 'The percentage of overhead costs allocated to this cost center from shared services or administrative cost pools. Used in fully-loaded cost calculations and margin analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'The department or organizational unit that owns and manages this cost center. Examples include Creative Services, Media Planning, Account Management, Finance, Human Resources, IT, Operations.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceGroup rdf:type rdf:Property ;
    rdfs:label 'Practice Group' ;
    rdfs:comment 'The specialized practice area or service line associated with this cost center, such as Digital Marketing, Brand Strategy, Public Relations, Data Analytics, Creative Production, Media Buying.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitAndLossResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Profit And Loss Responsibility Flag' ;
    rdfs:comment 'Boolean indicator of whether this cost center has direct profit and loss accountability. True indicates the center is a profit center with revenue and expense responsibility; false indicates a pure cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarterlyBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Quarterly Budget Amount' ;
    rdfs:comment 'The budget amount allocated to this cost center for the current quarter. Supports quarterly business review (QBR) processes and short-term financial management.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapCoCostCenterReference rdf:type rdf:Property ;
    rdfs:label 'Sap Co Cost Center Reference' ;
    rdfs:comment 'The corresponding cost center identifier in the SAP S/4HANA Controlling (CO) module. Used for integration and reconciliation between the lakehouse and the source ERP system.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Unique identifier for the credit memo record. Primary key.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Reference to the original invoice being adjusted by this credit memo.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:vendorPayableId rdf:type rdf:Property ;
    rdfs:label 'Vendor Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.vendor_payable. Business justification: Credit memos received from vendors reduce vendor payables (AP liabilities). This FK links the credit memo to the vendor payable record it is adjusting, enabling AP reconciliation and tracking of payab' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorPayable .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Indicates whether the credit memo has been applied to outstanding balances: open (not yet applied), partially applied, fully applied, or void.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the credit memo that has been applied to invoices or outstanding balances.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The gross monetary value of the credit being issued or received, before tax adjustments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Externally visible business identifier for the credit memo, used in client and vendor communications.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoType rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Type' ;
    rdfs:comment 'Classification of the credit memo indicating the nature of the adjustment: client-issued (agency credits client), vendor-received (vendor credits agency), internal adjustment, make-good, under-delivery, or billing error correction.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date the credit memo was officially issued or received.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Net Credit Amount' ;
    rdfs:comment 'The total credit amount including tax adjustments, representing the final credit value.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for issuing the credit memo: billing error, under-delivery, make-good, rate adjustment, volume discount, or quality issue.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the credit memo was issued, providing context beyond the reason code.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'The unapplied portion of the credit memo still available for future application.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this credit memo reverses a previous credit memo or invoice (True if reversal, False otherwise).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original credit memo or invoice being reversed, if this is a reversal transaction.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualsPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Accruals Posted Flag' ;
    rdfs:comment 'Indicates whether all required accruals have been posted for the period.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'The actual date when the financial close was completed and the period was locked.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:apSubledgerReconciledFlag rdf:type rdf:Property ;
    rdfs:label 'Ap Subledger Reconciled Flag' ;
    rdfs:comment 'Indicates whether the accounts payable subledger has been reconciled to the general ledger control account.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arSubledgerReconciledFlag rdf:type rdf:Property ;
    rdfs:label 'Ar Subledger Reconciled Flag' ;
    rdfs:comment 'Indicates whether the accounts receivable subledger has been reconciled to the general ledger control account.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Ready Flag' ;
    rdfs:comment 'Indicates whether all documentation and supporting evidence is prepared and ready for external audit review by Big 4 auditors.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference number or identifier linking this close to audit documentation and supporting evidence for Big 4 audit readiness.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankReconciliationsCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Bank Reconciliations Complete Flag' ;
    rdfs:comment 'Indicates whether all bank account reconciliations have been completed and cleared for the period.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cfoSignOffBy rdf:type rdf:Property ;
    rdfs:label 'Cfo Sign Off By' ;
    rdfs:comment 'Name of the CFO who signed off on the close.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cfoSignOffFlag rdf:type rdf:Property ;
    rdfs:label 'Cfo Sign Off Flag' ;
    rdfs:comment 'Indicates whether the CFO has reviewed and approved the close for the period.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cfoSignOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cfo Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the CFO signed off on the close.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeCommentary rdf:type rdf:Property ;
    rdfs:label 'Close Commentary' ;
    rdfs:comment 'Free-text commentary and notes about the close process, including issues encountered, resolutions, and key decisions made during the period.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeOwner rdf:type rdf:Property ;
    rdfs:label 'Close Owner' ;
    rdfs:comment 'Name of the individual responsible for coordinating and overseeing the financial close process for this period.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Close Owner Email' ;
    rdfs:comment 'Email address of the close owner for communication and escalation purposes.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closePeriodReference rdf:type rdf:Property ;
    rdfs:label 'Close Period Reference' ;
    rdfs:comment 'Business reference number for the close period, used for external communication and audit trail.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Current status of the financial close workflow: open (not started), in-progress (tasks being executed), pending-review (awaiting approval), closed (completed and locked), or reopened (unlocked for adjustments).' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeType rdf:type rdf:Property ;
    rdfs:label 'Close Type' ;
    rdfs:comment 'Type of financial close being performed: monthly, quarterly, annual, or special (ad-hoc).' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerSignOffBy rdf:type rdf:Property ;
    rdfs:label 'Controller Sign Off By' ;
    rdfs:comment 'Name of the controller who signed off on the close.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerSignOffFlag rdf:type rdf:Property ;
    rdfs:label 'Controller Sign Off Flag' ;
    rdfs:comment 'Indicates whether the controller has reviewed and approved the close for the period.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllerSignOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Controller Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the controller signed off on the close.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysToClose rdf:type rdf:Property ;
    rdfs:label 'Days To Close' ;
    rdfs:comment 'Number of calendar days taken to complete the close from period end to actual close date. Key performance indicator for close efficiency.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdingCompanyDeadline rdf:type rdf:Property ;
    rdfs:label 'Holding Company Deadline' ;
    rdfs:comment 'Deadline imposed by the holding company for completion of the financial close and submission of consolidated reporting packages.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyEliminationsDoneFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Eliminations Done Flag' ;
    rdfs:comment 'Indicates whether all intercompany transactions have been identified and elimination entries posted for consolidated reporting.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaCostReconciliationsClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Media Cost Reconciliations Cleared Flag' ;
    rdfs:comment 'Indicates whether all media cost reconciliations between planned and billed amounts have been cleared and approved.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognizedFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognized Flag' ;
    rdfs:comment 'Indicates whether all revenue recognition entries have been posted according to performance obligations and contract terms.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapFiPeriodLockDate rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Period Lock Date' ;
    rdfs:comment 'Date when the period was locked in SAP S/4HANA FI.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapFiPeriodLockStatus rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Period Lock Status' ;
    rdfs:comment 'Status of the period lock in SAP S/4HANA FI: open (postings allowed), locked (no postings allowed), or partially-locked (restricted postings only).' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliance Flag' ;
    rdfs:comment 'Indicates whether all SOX 404 internal control requirements have been met for this close period.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCloseDate rdf:type rdf:Property ;
    rdfs:label 'Target Close Date' ;
    rdfs:comment 'The planned date by which the financial close should be completed, typically set by holding company or regulatory deadlines.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceExplanation rdf:type rdf:Property ;
    rdfs:label 'Variance Explanation' ;
    rdfs:comment 'Explanation of significant variances identified during the close process, including budget-to-actual and period-over-period variances.' ;
    rdfs:domain ind:FinancialClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'The externally-known unique account number used in financial transactions and reporting. Typically a 4-10 digit numeric code aligned to the chart of accounts structure.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDescriptionLong rdf:type rdf:Property ;
    rdfs:label 'Account Description Long' ;
    rdfs:comment 'Extended description or explanatory text for the general ledger account, providing additional context, usage guidelines, or business rules for posting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'The hierarchical grouping or category within the chart of accounts (e.g., \'Current Assets\', \'Operating Expenses\', \'Client Revenue\'). Used for rollup and reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The human-readable name or title of the general ledger account (e.g., \'Media Costs - Digital\', \'Client Revenue - Retainer\', \'Salaries and Wages\').' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'The fundamental accounting classification of the account: asset, liability, equity, revenue, or expense. Determines the account\'s role in the balance sheet or profit and loss statement.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'The detailed balance sheet classification for asset, liability, and equity accounts: current asset, non-current asset, current liability, non-current liability, equity, or not applicable (for P&L accounts).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'The chart of accounts identifier to which this account belongs. Defines the account structure and numbering scheme for the organization or group.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'The consolidation grouping code used for corporate group financial consolidation and elimination entries. Aligns accounts across legal entities for consolidated reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterApplicable rdf:type rdf:Property ;
    rdfs:label 'Cost Center Applicable' ;
    rdfs:comment 'Indicates whether this account requires cost center assignment for expense tracking and allocation. True if cost center is mandatory for postings to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElement rdf:type rdf:Property ;
    rdfs:label 'Cost Element' ;
    rdfs:comment 'The cost element code linking this GL account to the controlling (CO) module for cost center and internal order tracking. Used for management accounting and margin analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'The field status group code that controls which fields are required, optional, or hidden when posting to this account. Enforces data entry rules at the account level.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'The primary financial statement to which this account belongs: balance sheet, income statement (P&L), cash flow statement, or statement of equity.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapMapping rdf:type rdf:Property ;
    rdfs:label 'Gaap Mapping' ;
    rdfs:comment 'The US GAAP account classification or line item code to which this account maps for GAAP-compliant financial reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Account Status' ;
    rdfs:comment 'The current lifecycle status of the general ledger account: active (in use), inactive (not in use but retained), pending (awaiting approval), or archived (historical only).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsMapping rdf:type rdf:Property ;
    rdfs:label 'Ifrs Mapping' ;
    rdfs:comment 'The IFRS account classification or line item code to which this account maps for IFRS-compliant financial reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items (journal entry details) are stored and displayed for this account. True if line-item reporting is enabled; false if only totals are maintained.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether this account uses open item management for tracking and clearing individual postings (e.g., invoices, payments). True if open item clearing is required.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plClassification rdf:type rdf:Property ;
    rdfs:label 'Pl Classification' ;
    rdfs:comment 'The detailed profit and loss classification for revenue and expense accounts: operating revenue, non-operating revenue, cost of sales, operating expense, non-operating expense, or not applicable (for balance sheet accounts).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlocked rdf:type rdf:Property ;
    rdfs:label 'Posting Blocked' ;
    rdfs:comment 'Indicates whether direct postings to this account are currently blocked. True if the account is locked for new transactions (e.g., during period close or account deactivation).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterApplicable rdf:type rdf:Property ;
    rdfs:label 'Profit Center Applicable' ;
    rdfs:comment 'Indicates whether this account requires profit center assignment for P&L segmentation and profitability analysis. True if profit center is mandatory for postings to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account' ;
    rdfs:comment 'Indicates whether this is a reconciliation account (control account) that summarizes subledger balances (e.g., accounts receivable, accounts payable, vendor accounts). True if this account is managed by a subledger.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'The sort key or allocation field used for automatic assignment of posting keys, document numbers, or payment terms during transaction entry.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The tax category or tax code applicable to this account for automatic tax calculation and reporting (e.g., \'VAT Standard\', \'Sales Tax Exempt\', \'Input Tax\').' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this general ledger account is valid and available for use in financial transactions. Supports time-dependent account structures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this general ledger account is valid. Null if the account is open-ended. Used for account retirement and historical tracking.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key for this entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:originalTransactionIntercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Intercompany Transaction Id' ;
    rdfs:comment 'Reference to the original intercompany transaction ID if this record is a reversal or adjustment, enabling audit trail and correction tracking.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:receivingEntityCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Receiving Entity Cost Center Id' ;
    rdfs:comment 'Identifier of the legal entity within the holding group that is the recipient of this intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:sendingEntityCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Sending Entity Cost Center Id' ;
    rdfs:comment 'Identifier of the legal entity within the holding group that is the originator or sender of this intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this intercompany transaction should be eliminated during consolidated financial statement preparation (True) or retained (False).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to convert the transaction amount to the functional currency, if applicable.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the functional currency of the sending entity for consolidated reporting purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'The fiscal period (YYYY-MM format) in which this intercompany transaction was posted to the general ledger.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date on which this intercompany transaction was successfully reconciled and matched between the sending and receiving entities.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this intercompany transaction is a reversal or correction of a previously posted transaction (True) or an original transaction (False).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the intercompany transaction was fully settled or paid between the sending and receiving entities.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current status indicating whether the intercompany transaction has been financially settled between the entities.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code representing the tax jurisdiction or country under whose regulations this intercompany transaction is governed for tax reporting purposes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The monetary value of the intercompany transaction in the transaction currency.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The business date on which the intercompany transaction occurred or was recognized for accounting purposes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'Externally visible unique reference number assigned to this intercompany transaction for tracking and reconciliation purposes across entities.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the nature of the intercompany transaction, such as cost allocation, shared service charge, intercompany loan, management fee, royalty, transfer pricing adjustment, or recharge. [ENUM-REF-CANDIDATE: cost_allocation|shared_service_charge|intercompany_loan|management_fee|royalty|transfer_pricing|recharge — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The transfer pricing methodology applied to determine the transaction amount for tax compliance and arm\'s length pricing requirements.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the invoice line item. Primary key for the invoice_line product.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewabilityMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Viewability Measurement Id' ;
    rdfs:comment 'Foreign key linking to performance.viewability_measurement. Business justification: Invoice lines for viewability-guaranteed placements bill based on viewable impressions; requires linking to viewability measurement data.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ViewabilityMeasurement .

ind:billingCode rdf:type rdf:Property ;
    rdfs:label 'Billing Code' ;
    rdfs:comment 'Internal billing classification code used to categorize the type of service or cost being invoiced. Maps to agency billing taxonomy.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current lifecycle status of this invoice line item. Tracks progression through billing workflow from draft to final billing. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|billed|disputed|adjusted|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Total agency commission earned on this line item. Represents agency revenue on media pass-through costs.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Percentage' ;
    rdfs:comment 'Agency commission rate applied to media costs. Standard agency markup percentage per client contract terms.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Date' ;
    rdfs:comment 'Date on which service delivery was confirmed by client or operations. Triggers revenue recognition eligibility.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmed Flag' ;
    rdfs:comment 'Indicates whether service delivery has been confirmed and validated. True when performance obligation is fulfilled and documented.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether this line item is under client dispute. True when client has challenged the charge and resolution is pending.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Total monetary value for this invoice line before tax. Calculated as quantity multiplied by unit rate, adjusted for discounts or markups.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotal rdf:type rdf:Property ;
    rdfs:label 'Line Total' ;
    rdfs:comment 'Total amount for this invoice line including tax. Sum of line amount and tax amount, representing the final billable value.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Numeric quantity of units being billed. Represents impressions, hours, days, or other unit of measure depending on service type.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Classification of revenue recognition status for this line item. Determines timing of revenue realization per accounting standards.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'End date of the service period being billed. Defines the completion of the performance obligation delivery window.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Start date of the service period being billed. Defines the beginning of the performance obligation delivery window.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax classification code determining the applicable tax treatment for this line item. Maps to tax jurisdiction and rate tables.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Foreign key linking to finance.payment. Business justification: Journal entries are created to record payment transactions (both AP disbursements and AR receipts) in the general ledger. This FK links the JE to the payment record it is posting, enabling cash reconc' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:revenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Id' ;
    rdfs:comment 'Foreign key linking to finance.revenue_recognition. Business justification: Journal entries are created to recognize revenue per revenue recognition schedules and performance obligations. This FK links the JE to the revenue recognition record it is posting, enabling complianc' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:accrualReversalDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Date' ;
    rdfs:comment 'For accrual-type entries, the date on which the accrual will be automatically reversed. Typically the first day of the following fiscal period. Null for non-accrual entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualReversalStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Status' ;
    rdfs:comment 'Status of the automatic reversal for accrual entries: not_applicable (non-accrual entry), pending (scheduled for reversal), reversed (reversal completed), or failed (reversal encountered an error).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User ID or name of the individual who approved this journal entry for posting. Null if no approval workflow is required or if entry is still pending approval.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReference rdf:type rdf:Property ;
    rdfs:label 'Batch Reference' ;
    rdfs:comment 'The batch identifier for grouped journal entries posted together in a single batch run. Used for batch-level reconciliation and error tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the source document or transaction that triggered this journal entry. May differ from posting date for backdated or forward-dated entries.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of the journal entry indicating the nature of the posting: standard (regular operational postings), accrual (period-end accruals with auto-reversal), reversal (reverses a prior entry), intercompany (cross-entity transactions), reclassification (reallocation between accounts), or adjustment (corrective postings).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAmountFlag rdf:type rdf:Property ;
    rdfs:label 'Estimated Amount Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the amounts in this journal entry are estimates (True) or actuals (False). Common for accruals where final invoice amounts are not yet known.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyPartnerEntity rdf:type rdf:Property ;
    rdfs:label 'Intercompany Partner Entity' ;
    rdfs:comment 'For intercompany entries, the legal entity code or name of the counterparty entity within the corporate group. Null for non-intercompany entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Description' ;
    rdfs:comment 'Free-text description providing business context for the journal entry, such as the nature of the transaction, campaign reference, or accounting rationale.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Number' ;
    rdfs:comment 'Business-facing unique journal entry document number assigned by the accounting system. Used for external reference and audit trails.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalJournalEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Original Journal Entry Number' ;
    rdfs:comment 'For reversal-type entries, the journal entry number of the original entry being reversed. Null for non-reversal entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Date and time when this journal entry was posted to the general ledger. Null if entry is still in draft or pending approval status.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry: draft (not yet posted), posted (committed to the general ledger), reversed (entry has been reversed), cancelled (entry voided before posting), or pending_approval (awaiting authorization).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclassificationReason rdf:type rdf:Property ;
    rdfs:label 'Reclassification Reason' ;
    rdfs:comment 'For reclassification entries, a textual explanation of why the reallocation between accounts was necessary. Null for non-reclassification entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number linking this journal entry to a source document such as an invoice, purchase order, media insertion order (IO), or contract. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalJournalEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Journal Entry Number' ;
    rdfs:comment 'The journal entry number of the reversing entry that offsets this original entry. Null if this entry has not been reversed.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedByUser rdf:type rdf:Property ;
    rdfs:label 'Reversed By User' ;
    rdfs:comment 'User ID or name of the individual who reversed this journal entry. Null if entry has not been reversed.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversed Timestamp' ;
    rdfs:comment 'Date and time when this journal entry was reversed. Null if entry has not been reversed.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'The sum of all credit amounts across all line items in this journal entry. Must equal total_debit_amount per double-entry accounting principles.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'The sum of all debit amounts across all line items in this journal entry. Must equal total_credit_amount per double-entry accounting principles.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for the journal entry line product.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedLineJournalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Reversed Line Journal Entry Line Id' ;
    rdfs:comment 'Reference to the original journal entry line that this entry reverses. Null if this is not a reversal entry.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntryLine .

ind:assignmentReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Reference' ;
    rdfs:comment 'Free-text assignment field used for grouping related line items, linking to external references, or supporting reconciliation processes.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'Business area for cross-company code reporting and segment analysis. Enables consolidated P&L by business line or service offering.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date on which this line item was cleared (matched with offsetting entry). Null for open items. Supports accounts payable and receivable reconciliation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'Document number of the clearing entry that closed this line item. Null for open items. Links payments to invoices and supports reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'Debit amount for this line item in the transaction currency. Null or zero if the line is a credit entry.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Two-character document type code that classifies the journal entry (e.g., SA for G/L account document, DR for customer invoice, KR for vendor invoice). Controls number ranges and posting rules.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Descriptive text providing additional context for the line item. Used for audit trails, reconciliation notes, and financial statement drill-down.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the company code local currency used in financial statements.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Credit Amount' ;
    rdfs:comment 'Credit amount converted to the company code local currency for consolidated financial reporting and P&L analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Debit Amount' ;
    rdfs:comment 'Debit amount converted to the company code local currency for consolidated financial reporting and P&L analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit posting key that determines whether the line is a debit or credit and controls field status and account type. Standard SAP posting keys include 40 (debit GL), 50 (credit GL), 01 (debit customer), 11 (credit customer), 31 (debit vendor), 21 (credit vendor).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey rdf:type rdf:Property ;
    rdfs:label 'Reference Key' ;
    rdfs:comment 'Reference key for external system integration and cross-system reconciliation. May contain invoice numbers, purchase order numbers, or other source document identifiers.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Trading partner company code for intercompany transactions. Supports elimination entries and consolidated financial statements.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'Value date for cash management and liquidity planning. Represents the effective date for interest calculation and cash flow forecasting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaCostReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Media Cost Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the media cost reconciliation record. Primary key for this entity.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryPacingId rdf:type rdf:Property ;
    rdfs:label 'Delivery Pacing Id' ;
    rdfs:comment 'Foreign key linking to performance.delivery_pacing. Business justification: Pacing data informs reconciliation of planned vs actual delivery and spend; variance analysis requires pacing metrics.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryPacing .

ind:actualCpm rdf:type rdf:Property ;
    rdfs:label 'Actual Cpm' ;
    rdfs:comment 'The actual cost per thousand impressions calculated from billed cost and delivered impressions. Calculated as (billed_cost_amount / delivered_impressions) * 1000.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Cost Amount' ;
    rdfs:comment 'The actual cost amount invoiced by the vendor for the media delivery. Represents the vendor\'s claim for payment based on delivered impressions or placements.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmVariance rdf:type rdf:Property ;
    rdfs:label 'Cpm Variance' ;
    rdfs:comment 'The difference between planned CPM and actual CPM. Used to identify rate discrepancies and pricing issues.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredImpressions rdf:type rdf:Property ;
    rdfs:label 'Delivered Impressions' ;
    rdfs:comment 'The actual number of impressions delivered by the vendor as confirmed by third-party ad serving platforms (Google Campaign Manager 360, DSP platforms). Used for delivery variance calculation.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Opened Date' ;
    rdfs:comment 'Date when a dispute was formally opened for this reconciliation record. Null if no dispute has been raised.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the dispute resolution process, including vendor communications, adjustments made, and final agreement terms.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolvedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolved Date' ;
    rdfs:comment 'Date when the dispute was formally resolved and the reconciliation was cleared. Null if dispute is still open or no dispute was raised.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when the reconciled amount was posted to the general ledger in SAP S/4HANA FI. Used for financial period closing and P&L reporting.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impressionVariance rdf:type rdf:Property ;
    rdfs:label 'Impression Variance' ;
    rdfs:comment 'The difference between planned impressions and delivered impressions. Positive values indicate over-delivery; negative values indicate under-delivery.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impressionVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Impression Variance Percentage' ;
    rdfs:comment 'The impression variance expressed as a percentage of planned impressions. Calculated as (impression_variance / planned_impressions) * 100. Used for delivery performance tracking.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makeGoodFlag rdf:type rdf:Property ;
    rdfs:label 'Make Good Flag' ;
    rdfs:comment 'Boolean indicator of whether this reconciliation includes make-good impressions provided by the vendor to compensate for under-delivery or quality issues.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makeGoodImpressions rdf:type rdf:Property ;
    rdfs:label 'Make Good Impressions' ;
    rdfs:comment 'Number of additional impressions provided by the vendor as make-good compensation. Null or zero if no make-good was provided.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment to the vendor is due based on contract payment terms. Used for accounts payable scheduling and cash flow management.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Amount' ;
    rdfs:comment 'The originally planned media cost as specified in the insertion order and media plan. Represents the budgeted amount for this media buy.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCpm rdf:type rdf:Property ;
    rdfs:label 'Planned Cpm' ;
    rdfs:comment 'The planned cost per thousand impressions as negotiated in the media buy. Used as the baseline rate for cost reconciliation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedImpressions rdf:type rdf:Property ;
    rdfs:label 'Planned Impressions' ;
    rdfs:comment 'The number of impressions originally planned and contracted in the insertion order. Used as the baseline for delivery reconciliation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciledAmount rdf:type rdf:Property ;
    rdfs:label 'Reconciled Amount' ;
    rdfs:comment 'The final agreed-upon cost amount after reconciliation adjustments, dispute resolution, and variance analysis. This is the amount approved for payment and client billing.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Document Number' ;
    rdfs:comment 'Unique document number generated by Mediaocean Prisma for this reconciliation transaction. Used for audit trail and cross-system reference.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Third Party Verification Date' ;
    rdfs:comment 'Date when the third-party verification data was received or confirmed. Used for audit trail and data freshness tracking.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thirdPartyVerificationSource rdf:type rdf:Property ;
    rdfs:label 'Third Party Verification Source' ;
    rdfs:comment 'Name of the third-party ad serving or verification platform that provided the delivered impressions data (e.g., Google Campaign Manager 360, The Trade Desk, Nielsen, Comscore).' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for the cost variance. Used for root cause analysis and vendor performance tracking.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the variance reason, including context, supporting evidence, and resolution notes. Provides audit trail for financial reconciliation.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorReference rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference' ;
    rdfs:comment 'External reference identifier provided by the media vendor or publisher for this billing cycle. May include invoice number or billing statement reference.' ;
    rdfs:domain ind:MediaCostReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Reference to the bank account from which the payment was debited (outbound) or to which it was credited (inbound). Links to the agency\'s cash management system.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:originalPaymentId rdf:type rdf:Property ;
    rdfs:label 'Original Payment Id' ;
    rdfs:comment 'Reference to the original payment record that this payment reverses. Populated only when is_reversal is True.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The gross monetary value of the payment transaction in the specified currency. Represents the total cash movement before any adjustments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Bank Transaction Reference' ;
    rdfs:comment 'The unique transaction identifier assigned by the bank or payment processor. Used for bank reconciliation and dispute resolution.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Boolean flag indicating whether this payment is a reversal of a previous payment transaction. True if this is a reversal entry, False otherwise.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memo rdf:type rdf:Property ;
    rdfs:label 'Memo' ;
    rdfs:comment 'Free-text memo or notes field providing additional context about the payment. May include invoice references, campaign details, or special instructions.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeName rdf:type rdf:Property ;
    rdfs:label 'Payee Name' ;
    rdfs:comment 'The name of the party receiving the payment. For inbound payments, this is the agency entity. For outbound payments, this is the vendor, publisher, or supplier.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerName rdf:type rdf:Property ;
    rdfs:label 'Payer Name' ;
    rdfs:comment 'The name of the party making the payment. For inbound payments, this is the client or advertiser. For outbound payments, this is the agency entity.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which the payment transaction was executed or received. This is the business event date for cash flow recognition.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment: pending (initiated but not cleared), cleared (funds transferred), failed (transaction rejected), cancelled (voided before clearing), reversed (funds returned after clearing), or reconciled (matched to invoice/payable).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment purpose: invoice payment (standard settlement), advance payment (prepayment), refund (return of funds), rebate (volume discount payment), commission (agency fee), or retainer (upfront fee).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Reference' ;
    rdfs:comment 'Reference number or identifier from the remittance advice document accompanying the payment. Used to match payment to specific invoices or line items.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPaymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Payment Document Number' ;
    rdfs:comment 'The payment document number generated in SAP S/4HANA FI module. Primary reference for integration with the ERP (Enterprise Resource Planning) system.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terms rdf:type rdf:Property ;
    rdfs:label 'Terms' ;
    rdfs:comment 'The contractual payment terms applicable to this payment (e.g., Net 30, Net 60, 2/10 Net 30). Indicates the agreed-upon payment schedule and any early payment discounts.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of tax withheld from the payment as required by tax regulations. Common for cross-border payments and vendor payments subject to withholding.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Explanation for any adjustment, reversal, or correction made to the revenue recognition record. Required when recognition status is adjusted or reversed.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'External business identifier for the contract or Statement of Work (SOW) document.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Amount' ;
    rdfs:comment 'Amount of revenue that has been billed or received but not yet recognized, representing the contract liability. Calculated as total contract value minus recognized amount to date.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Date' ;
    rdfs:comment 'Date when the milestone was achieved or is expected to be achieved, triggering revenue recognition for milestone-based contracts.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:percentageComplete rdf:type rdf:Property ;
    rdfs:label 'Percentage Complete' ;
    rdfs:comment 'Percentage of completion for this performance obligation, used when recognition method is percentage-of-completion. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Detailed description of the specific performance obligation being fulfilled (e.g., media planning services, creative production, campaign execution, retainer services).' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition End Date' ;
    rdfs:comment 'Date when revenue recognition is expected to complete for this performance obligation, typically aligned with contract end date or service completion.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'Method used to recognize revenue for this performance obligation per accounting standards. Straight-line for retainers, milestone for project-based, percentage-of-completion for long-term campaigns, point-in-time for discrete deliverables.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Start Date' ;
    rdfs:comment 'Date when revenue recognition begins for this performance obligation, typically aligned with contract effective date or service commencement.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition record. Pending indicates not yet started, in-progress for ongoing recognition, completed when fully recognized, deferred for postponed recognition, reversed for corrections, adjusted for amendments.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedAmountToDate rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount To Date' ;
    rdfs:comment 'Cumulative revenue amount recognized to date for this performance obligation. Updated as revenue is recognized over time or at point in time.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueType rdf:type rdf:Property ;
    rdfs:label 'Revenue Type' ;
    rdfs:comment 'Classification of revenue stream type. Retainer for ongoing monthly fees, project for fixed-price engagements, commission for percentage-based fees, media markup for agency margin on media buys, production for creative services, consulting for advisory services, performance fee for outcome-based compensation. [ENUM-REF-CANDIDATE: retainer|project|commission|media_markup|production|consulting|performance_fee — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiPostingDate rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Posting Date' ;
    rdfs:comment 'Date when the revenue recognition entry was posted in SAP S/4HANA FI general ledger.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unbilledRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Unbilled Revenue Amount' ;
    rdfs:comment 'Amount of revenue recognized but not yet billed to the client, representing a contract asset or accrued revenue.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Foreign key linking to vendor.invoice. Business justification: Vendor payables track liabilities for specific vendor invoices. Finance teams reconcile payables against vendor.invoice records for payment matching, dispute resolution, and three-way match (PO-invoic' ;
    rdfs:domain ind:VendorPayable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:discountDeadline rdf:type rdf:Property ;
    rdfs:label 'Discount Deadline' ;
    rdfs:comment 'The last date by which payment must be made to qualify for the early payment discount. Used for cash flow optimization decisions.' ;
    rdfs:domain ind:VendorPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total amount owed to the vendor before any discounts or adjustments are applied. Represents the full invoice value.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaoceanPayableReference rdf:type rdf:Property ;
    rdfs:label 'Mediaocean Payable Reference' ;
    rdfs:comment 'The unique payable reference identifier from Mediaocean Prisma billing system. Enables reconciliation between media buying platform and financial system for media cost tracking.' ;
    rdfs:domain ind:VendorPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The final amount payable to the vendor after applying early payment discounts and any other adjustments. This is the actual payment amount.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payableDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payable Document Number' ;
    rdfs:comment 'The unique business document number assigned to this accounts payable record, used for tracking and reconciliation purposes.' ;
    rdfs:domain ind:VendorPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The unique reference number assigned to the payment transaction (e.g., check number, wire confirmation number, ACH trace number). Used for payment tracking and bank reconciliation.' ;
    rdfs:domain ind:VendorPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequentialLiabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Sequential Liability Flag' ;
    rdfs:comment 'Indicates whether this payable is subject to sequential liability rules, where the agency is liable for vendor payment only after receiving payment from the client. Critical for cash flow management and risk mitigation in media buying.' ;
    rdfs:domain ind:VendorPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to media.category. Business justification: ad_channel currently has channel_category as a STRING attribute. The category product exists to provide hierarchical classification taxonomy for advertising channels. This FK normalizes the channel-to' ;
    rdfs:domain ind:Media ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:agencyCommissionPct rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Pct' ;
    rdfs:comment 'Standard agency commission percentage applied to gross media spend on this channel. Typically 15% for traditional media, 10-15% for digital. Null if commission varies by client or IO.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidStrategyDefault rdf:type rdf:Property ;
    rdfs:label 'Bid Strategy Default' ;
    rdfs:comment 'Default bidding strategy applied to campaigns on this channel unless overridden at campaign level. Determines how the platform optimizes bids to achieve campaign objectives. [ENUM-REF-CANDIDATE: manual_cpc|enhanced_cpc|maximize_clicks|maximize_conversions|target_cpa|target_roas|target_impression_share|viewable_cpm — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyKeywords rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or content categories to exclude for brand safety (e.g., violence, adult content, controversial topics). Applied as negative targeting across all campaigns on this channel.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutSupported rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Supported' ;
    rdfs:comment 'Indicates whether this channel supports CCPA Do Not Sell signals for California users. Required for compliance with California privacy regulations.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the channel across all systems (e.g., SEM_GOOGLE, SOCIAL_FB, DISPLAY_PROG). Used as the business identifier in campaign planning, trafficking, and reporting.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Human-readable name of the advertising channel (e.g., Google Search, Facebook Social, Programmatic Display).' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the channel. Active channels are available for campaign planning and buying; deprecated channels are phased out but may have historical data.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickAttributionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Click Attribution Window Days' ;
    rdfs:comment 'Number of days after a click during which conversions are attributed to this channel. Typically longer than view attribution window due to higher intent signal.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentSignalFormat rdf:type rdf:Property ;
    rdfs:label 'Consent Signal Format' ;
    rdfs:comment 'Format of privacy consent signals passed to this channel. TCF v2 (Transparency and Consent Framework) for GDPR, US Privacy String for CCPA, GPP (Global Privacy Platform) for multi-jurisdiction compliance.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryModality rdf:type rdf:Property ;
    rdfs:label 'Delivery Modality' ;
    rdfs:comment 'Method by which media is bought and delivered through this channel. Determines operational workflow, trafficking requirements, and reconciliation processes.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dspSeatCode rdf:type rdf:Property ;
    rdfs:label 'Dsp Seat Code' ;
    rdfs:comment 'Unique seat identifier within the DSP platform (e.g., The Trade Desk seat ID). Used for programmatic bid requests, deal configuration, and reconciliation. Confidential operational credential.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCapDefault rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Default' ;
    rdfs:comment 'Default maximum number of times an ad can be shown to the same user within the frequency cap period. Prevents ad fatigue and optimizes reach. Null indicates no default cap.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCapPeriodDefault rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Period Default' ;
    rdfs:comment 'Time window over which the default frequency cap is applied (e.g., 3 impressions per day). Works in conjunction with frequency_cap_default.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsAudienceTargeting rdf:type rdf:Property ;
    rdfs:label 'Supports Audience Targeting' ;
    rdfs:comment 'Indicates whether this channel supports audience segment targeting using first-party, third-party, or platform-native audience data. Critical for personalized campaign strategies.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsDayparting rdf:type rdf:Property ;
    rdfs:label 'Supports Dayparting' ;
    rdfs:comment 'Indicates whether this channel supports daypart scheduling (time-of-day and day-of-week targeting). Common in broadcast, CTV, and digital channels for optimizing reach and frequency.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsGeoTargeting rdf:type rdf:Property ;
    rdfs:label 'Supports Geo Targeting' ;
    rdfs:comment 'Indicates whether this channel supports geographic targeting by country, region, DMA (Designated Market Area), postal code, or radius. Essential for local and regional campaigns.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsProgrammatic rdf:type rdf:Property ;
    rdfs:label 'Supports Programmatic' ;
    rdfs:comment 'Indicates whether this channel supports programmatic buying via DSP platforms and RTB (Real-Time Bidding) protocols. True for most digital channels; false for traditional media.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utmMediumDefault rdf:type rdf:Property ;
    rdfs:label 'Utm Medium Default' ;
    rdfs:comment 'Default value for utm_medium parameter in campaign tracking URLs for this channel (e.g., cpc, social, display). Enables consistent channel attribution in web analytics.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSourceDefault rdf:type rdf:Property ;
    rdfs:label 'Utm Source Default' ;
    rdfs:comment 'Default value for utm_source parameter in campaign tracking URLs for this channel. Standardizes attribution and analytics reporting across Google Analytics and other web analytics platforms.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewAttributionWindowDays rdf:type rdf:Property ;
    rdfs:label 'View Attribution Window Days' ;
    rdfs:comment 'Number of days after an ad view (impression without click) during which conversions are attributed to this channel. Typically 1-7 days for display and video channels.' ;
    rdfs:domain ind:AdChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewabilityThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Viewability Threshold Pct' ;
    rdfs:comment 'Minimum viewability percentage required for impressions on this channel to be considered valid for billing and reporting purposes. Typically 50-70% based on MRC standards.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adFormatId rdf:type rdf:Property ;
    rdfs:label 'Ad Format Id' ;
    rdfs:comment 'Unique identifier for the advertising format. Primary key for the ad_format product.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdFormat .

ind:acceptedFileFormats rdf:type rdf:Property ;
    rdfs:label 'Accepted File Formats' ;
    rdfs:comment 'Comma-separated list of accepted file extensions for creative assets (e.g., JPG, PNG, GIF, MP4, MOV, HTML5, ZIP). Used for creative validation and trafficking.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptedMimeTypes rdf:type rdf:Property ;
    rdfs:label 'Accepted Mime Types' ;
    rdfs:comment 'Comma-separated list of accepted MIME types for creative files (e.g., image/jpeg, image/png, video/mp4, application/javascript). Defines technical compatibility.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adServerPlatformCompatibility rdf:type rdf:Property ;
    rdfs:label 'Ad Server Platform Compatibility' ;
    rdfs:comment 'Comma-separated list of ad server platforms that support this format (e.g., Google Campaign Manager 360, The Trade Desk, Sizmek, Flashtalking). Used for trafficking validation.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickThroughUrlRequired rdf:type rdf:Property ;
    rdfs:label 'Click Through Url Required' ;
    rdfs:comment 'Indicates whether a click-through URL is mandatory for this ad format. True for most digital formats; false for awareness-only formats (e.g., some OOH).' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deprecationDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Date' ;
    rdfs:comment 'Date when the ad format was deprecated and scheduled for retirement. Null for active formats. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deviceTypeCompatibility rdf:type rdf:Property ;
    rdfs:label 'Device Type Compatibility' ;
    rdfs:comment 'Comma-separated list of device types compatible with this format (e.g., desktop, mobile, tablet, CTV, smart_speaker, digital_billboard). Used for targeting and trafficking.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentType rdf:type rdf:Property ;
    rdfs:label 'Environment Type' ;
    rdfs:comment 'Primary environment where the ad format is delivered (e.g., web, app, CTV, DOOH, print, broadcast, social). Aligns with media planning and buying strategies. [ENUM-REF-CANDIDATE: web|app|ctv|dooh|print|broadcast|social — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatCode rdf:type rdf:Property ;
    rdfs:label 'Format Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the ad format across systems (e.g., DISPLAY_300X250, VIDEO_PREROLL_15S). Used for trafficking and system integration.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatName rdf:type rdf:Property ;
    rdfs:label 'Format Name' ;
    rdfs:comment 'Human-readable name of the advertising format (e.g., Medium Rectangle, Pre-Roll Video, Native In-Feed).' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatStatus rdf:type rdf:Property ;
    rdfs:label 'Format Status' ;
    rdfs:comment 'Current lifecycle status of the ad format. Active formats are available for trafficking; deprecated formats are phased out; retired formats are no longer supported.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatSubcategory rdf:type rdf:Property ;
    rdfs:label 'Format Subcategory' ;
    rdfs:comment 'Detailed classification within the format category (e.g., banner, interstitial, pre-roll, mid-roll, post-roll, in-stream, out-stream, expandable, takeover).' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCapRecommended rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Recommended' ;
    rdfs:comment 'Recommended frequency cap (number of impressions per user per period) for this format to optimize user experience and campaign performance. Null if no recommendation.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iabFormatCode rdf:type rdf:Property ;
    rdfs:label 'Iab Format Code' ;
    rdfs:comment 'Official IAB classification code for the ad format, enabling standardized reporting and cross-platform compatibility.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionTrackingPixelRequired rdf:type rdf:Property ;
    rdfs:label 'Impression Tracking Pixel Required' ;
    rdfs:comment 'Indicates whether an impression tracking pixel is required for delivery measurement. True for most digital formats to enable campaign reporting.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNativeFormat rdf:type rdf:Property ;
    rdfs:label 'Is Native Format' ;
    rdfs:comment 'Indicates whether the ad format is a native advertising format designed to match the form and function of the surrounding content. True for native in-feed, content recommendation, and sponsored content formats.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProgrammaticEligible rdf:type rdf:Property ;
    rdfs:label 'Is Programmatic Eligible' ;
    rdfs:comment 'Indicates whether the ad format is eligible for programmatic buying via Demand-Side Platforms (DSP) and Real-Time Bidding (RTB). True for formats supported by programmatic infrastructure.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementPositionOptions rdf:type rdf:Property ;
    rdfs:label 'Placement Position Options' ;
    rdfs:comment 'Comma-separated list of allowed placement positions for this format (e.g., above_the_fold, below_the_fold, in_feed, interstitial, pre_roll, mid_roll, post_roll, sidebar, footer). Used for trafficking and optimization.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the ad format was fully retired and removed from active use. Null for active and deprecated formats. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportsAnimation rdf:type rdf:Property ;
    rdfs:label 'Supports Animation' ;
    rdfs:comment 'Indicates whether the ad format supports animated creative content (e.g., GIF, HTML5 animation, video). False for static-only formats.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsAudio rdf:type rdf:Property ;
    rdfs:label 'Supports Audio' ;
    rdfs:comment 'Indicates whether the ad format supports audio playback. True for video, audio, and CTV/OTT formats; false for display and print.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsInteractivity rdf:type rdf:Property ;
    rdfs:label 'Supports Interactivity' ;
    rdfs:comment 'Indicates whether the ad format supports interactive elements (e.g., expandable units, rich media, VPAID). True for formats allowing user engagement beyond click-through.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vastVersionSupported rdf:type rdf:Property ;
    rdfs:label 'Vast Version Supported' ;
    rdfs:comment 'Supported VAST specification version for video ad serving (e.g., 2.0, 3.0, 4.0, 4.1, 4.2). Null for non-video formats.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityMeasurementSupported rdf:type rdf:Property ;
    rdfs:label 'Viewability Measurement Supported' ;
    rdfs:comment 'Indicates whether the ad format supports viewability measurement per Media Rating Council (MRC) standards. True for formats compatible with viewability vendors.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewabilityVendorCompatibility rdf:type rdf:Property ;
    rdfs:label 'Viewability Vendor Compatibility' ;
    rdfs:comment 'Comma-separated list of viewability measurement vendors compatible with this format (e.g., IAS, MOAT, DoubleVerify, Comscore). Used for third-party verification setup.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vpaidVersionSupported rdf:type rdf:Property ;
    rdfs:label 'Vpaid Version Supported' ;
    rdfs:comment 'Supported VPAID specification version for interactive video ads (e.g., 1.0, 2.0). Null for non-interactive or non-video formats.' ;
    rdfs:domain ind:AdFormat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceRatingId rdf:type rdf:Property ;
    rdfs:label 'Audience Rating Id' ;
    rdfs:comment 'Unique surrogate identifier for each audience rating record in the media vehicle measurement dataset. Primary key for the audience_rating data product.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publisherPropertyId rdf:type rdf:Property ;
    rdfs:label 'Publisher Property Id' ;
    rdfs:comment 'Reference to the media vehicle (network, station, site, or publication) for which this audience rating applies. Links to the media vehicle master record.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PublisherProperty .

ind:ageRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Age Range High' ;
    rdfs:comment 'Upper bound of the age range for the demographic cell (e.g., 49 for the A18-49 cell). A null value indicates an open-ended upper bound (e.g., \'65+\').' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeLow rdf:type rdf:Property ;
    rdfs:label 'Age Range Low' ;
    rdfs:comment 'Lower bound of the age range for the demographic cell (e.g., 18 for the A18-49 cell). Enables precise demographic filtering and TRP validation in media planning.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageAudience rdf:type rdf:Property ;
    rdfs:label 'Average Audience' ;
    rdfs:comment 'Average number of persons (in thousands) tuned to or engaged with the media vehicle during the average minute of the measured time slot. The primary audience delivery metric used in GRP/TRP calculations and media plan validation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidenceInterval rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval' ;
    rdfs:comment 'Statistical confidence interval (expressed as a decimal, e.g., 0.95 for 95%) associated with the rating estimate, reflecting measurement precision. Used by media planners to assess reliability of ratings for planning and reconciliation decisions.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeAudience rdf:type rdf:Property ;
    rdfs:label 'Cumulative Audience' ;
    rdfs:comment 'Total unduplicated number of persons (in thousands) who were exposed to the media vehicle at least once during the measurement period. Also known as \'reach\' or \'cume\'. Used in reach and frequency planning.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'The audience measurement currency in which this rating is expressed (e.g., \'grp\' for Gross Rating Points, \'trp\' for Target Rating Points, \'impressions\' for digital impression-based measurement). Aligns with IAB and MRC currency standards for cross-media planning.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVintageDate rdf:type rdf:Property ;
    rdfs:label 'Data Vintage Date' ;
    rdfs:comment 'The date on which this specific version of the rating data was published or released by the measurement source. Enables tracking of data revisions and ensures media planners are using the most current ratings vintage for planning and reconciliation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daypartCode rdf:type rdf:Property ;
    rdfs:label 'Daypart Code' ;
    rdfs:comment 'Standardized code identifying the daypart or time slot for which the rating is measured (e.g., \'PRIME\', \'EARLY_NEWS\', \'LATE_FRINGE\', \'MORNING_DRIVE\'). Aligns with Nielsen and MRC daypart definitions used in media planning and GRP/TRP calculations.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartName rdf:type rdf:Property ;
    rdfs:label 'Daypart Name' ;
    rdfs:comment 'Human-readable label for the daypart or time slot (e.g., \'Prime Time\', \'Early Morning\', \'Late Night\'). Used in media planning reports and client-facing deliverables.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderSegment rdf:type rdf:Property ;
    rdfs:label 'Gender Segment' ;
    rdfs:comment 'Gender component of the demographic cell for which the rating is reported. \'persons\' and \'all\' indicate total audience regardless of gender, consistent with Nielsen P2+ and Comscore total audience reporting.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyName rdf:type rdf:Property ;
    rdfs:label 'Geography Name' ;
    rdfs:comment 'Human-readable name of the geographic market for this rating (e.g., \'New York\', \'Los Angeles\', \'National\'). Used in media planning reports and client-facing deliverables.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyType rdf:type rdf:Property ;
    rdfs:label 'Geography Type' ;
    rdfs:comment 'The geographic scope of the audience measurement (e.g., \'national\' for national ratings, \'dma\' for Nielsen Designated Market Area, \'msa\' for Metropolitan Statistical Area). Determines the applicable universe estimate and planning geography.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpContribution rdf:type rdf:Property ;
    rdfs:label 'Grp Contribution' ;
    rdfs:comment 'The Gross Rating Point (GRP) value contributed by a single exposure on this vehicle in this daypart for the total audience demographic. GRP = Rating × Number of Spots. Stored at the unit level to support media plan GRP accumulation and delivery validation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingested Timestamp' ;
    rdfs:comment 'Timestamp when this audience rating record was first ingested into the Databricks Silver Layer from the source measurement system (Nielsen Ad Intel or Comscore). Supports data lineage and audit trail for the lakehouse pipeline.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isLowReliability rdf:type rdf:Property ;
    rdfs:label 'Is Low Reliability' ;
    rdfs:comment 'Flag indicating that this rating record has been identified as statistically unreliable due to insufficient sample size, high margin of error, or measurement source quality flags. Low-reliability ratings should not be used for billing reconciliation without additional validation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrcAccredited rdf:type rdf:Property ;
    rdfs:label 'Mrc Accredited' ;
    rdfs:comment 'Indicates whether the measurement source and methodology for this rating record hold current Media Rating Council (MRC) accreditation. MRC-accredited data is the industry standard for media buying and billing reconciliation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Lifecycle status of the rating record indicating whether the data is preliminary (initial estimate), final (confirmed), revised (updated after initial release), or superseded (replaced by a newer vintage). Critical for media reconciliation — only \'final\' ratings are used for billing reconciliation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingValue rdf:type rdf:Property ;
    rdfs:label 'Rating Value' ;
    rdfs:comment 'The audience rating expressed as a percentage of the total universe that viewed/listened to/visited the media vehicle during the measured time slot and demographic cell. A rating of 5.25 means 5.25% of the universe was exposed. Core metric for GRP and TRP delivery validation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shareValue rdf:type rdf:Property ;
    rdfs:label 'Share Value' ;
    rdfs:comment 'Percentage of the Households Using Television (HUT) or Persons Using Television (PUT) that were tuned to this vehicle during the time slot. Share = (Average Audience / HUT or PUT) × 100. Used alongside rating to assess competitive performance.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeSlotEnd rdf:type rdf:Property ;
    rdfs:label 'Time Slot End' ;
    rdfs:comment 'End time of the measured time slot in HH:MM (24-hour) format (e.g., \'23:00\' for 11 PM). Defines the close of the measurement window.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeSlotStart rdf:type rdf:Property ;
    rdfs:label 'Time Slot Start' ;
    rdfs:comment 'Start time of the measured time slot in HH:MM (24-hour) format (e.g., \'20:00\' for 8 PM). Used to precisely define the measurement window within a daypart.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trpContribution rdf:type rdf:Property ;
    rdfs:label 'Trp Contribution' ;
    rdfs:comment 'The Target Rating Point (TRP) value contributed by a single exposure on this vehicle for the specific demographic cell. TRP = Target Demographic Rating × Number of Spots. Used to validate targeted audience delivery against media plan objectives.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:universeEstimate rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate' ;
    rdfs:comment 'Total estimated population size (in persons) for the demographic cell and geography against which the rating is calculated. Used as the denominator in rating calculations and for projecting absolute audience size from rating percentages.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Classification of the media vehicle by channel type. Determines which measurement methodology and rating currency applies. [ENUM-REF-CANDIDATE: broadcast_tv|cable_tv|radio|digital|print|ooh|ctv_ott|podcast — promote to reference product]' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityId rdf:type rdf:Property ;
    rdfs:label 'Availability Id' ;
    rdfs:comment 'Unique identifier for the inventory availability record.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityCode rdf:type rdf:Property ;
    rdfs:label 'Availability Code' ;
    rdfs:comment 'Business identifier or code for this availability record, often sourced from SSP or publisher systems.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current lifecycle status of the inventory: available for purchase, sold out, reserved for a campaign, blacked out, or pending confirmation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityType rdf:type rdf:Property ;
    rdfs:label 'Availability Type' ;
    rdfs:comment 'Classification of the availability record: real-time snapshot, forecasted projection, reserved inventory, guaranteed deal, or non-guaranteed open market.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableImpressions rdf:type rdf:Property ;
    rdfs:label 'Available Impressions' ;
    rdfs:comment 'Number of impressions currently available for purchase or reservation.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutEndDate rdf:type rdf:Property ;
    rdfs:label 'Blackout End Date' ;
    rdfs:comment 'The end date of a blackout period during which inventory is unavailable for sale.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blackoutReason rdf:type rdf:Property ;
    rdfs:label 'Blackout Reason' ;
    rdfs:comment 'Explanation for why inventory is blacked out (e.g., publisher maintenance, seasonal unavailability, exclusive deal).' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutStartDate rdf:type rdf:Property ;
    rdfs:label 'Blackout Start Date' ;
    rdfs:comment 'The start date of a blackout period during which inventory is unavailable for sale.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daypart rdf:type rdf:Property ;
    rdfs:label 'Daypart' ;
    rdfs:comment 'The time-of-day segment (e.g., prime time, daytime, late night) for which availability is reported, relevant for broadcast and streaming inventory.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorCpm rdf:type rdf:Property ;
    rdfs:label 'Floor Cpm' ;
    rdfs:comment 'The minimum Cost Per Mille (CPM) rate at which the publisher will sell this inventory.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'The date on which the availability forecast was generated or last updated.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastMethodology rdf:type rdf:Property ;
    rdfs:label 'Forecast Methodology' ;
    rdfs:comment 'Description of the forecasting method or algorithm used to generate availability projections (e.g., time-series model, machine learning, historical average).' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketName rdf:type rdf:Property ;
    rdfs:label 'Market Name' ;
    rdfs:comment 'The geographic market or Designated Market Area (DMA) for which this availability applies.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingCapacityPct rdf:type rdf:Property ;
    rdfs:label 'Remaining Capacity Pct' ;
    rdfs:comment 'Percentage of total inventory capacity that remains available for sale, calculated as (available_impressions / total_impressions) * 100.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedImpressions rdf:type rdf:Property ;
    rdfs:label 'Reserved Impressions' ;
    rdfs:comment 'Number of impressions reserved but not yet confirmed or trafficked.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalDemandSignal rdf:type rdf:Property ;
    rdfs:label 'Seasonal Demand Signal' ;
    rdfs:comment 'Indicator of expected demand intensity for the period: low, medium, high, or peak, used to inform pricing and planning decisions.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soldImpressions rdf:type rdf:Property ;
    rdfs:label 'Sold Impressions' ;
    rdfs:comment 'Number of impressions already sold or committed to campaigns.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'External reference identifier or key from the source system (SSP, DSP, or publisher platform) for traceability.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sspExchange rdf:type rdf:Property ;
    rdfs:label 'Ssp Exchange' ;
    rdfs:comment 'The Supply-Side Platform or ad exchange offering this inventory for sale.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalImpressions rdf:type rdf:Property ;
    rdfs:label 'Total Impressions' ;
    rdfs:comment 'Total impression volume available for the specified channel, placement, and period.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benchmarkId rdf:type rdf:Property ;
    rdfs:label 'Benchmark Id' ;
    rdfs:comment 'Unique identifier for the benchmark record.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benchmarkCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Code' ;
    rdfs:comment 'Business-assigned unique code identifying this benchmark entry for reference and reporting purposes.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkDate rdf:type rdf:Property ;
    rdfs:label 'Benchmark Date' ;
    rdfs:comment 'The date on which this benchmark was published, released, or made available for use in planning and evaluation, in yyyy-MM-dd format.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benchmarkName rdf:type rdf:Property ;
    rdfs:label 'Benchmark Name' ;
    rdfs:comment 'Descriptive name of the benchmark, typically indicating the metric, channel, and segment being measured.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkStatus rdf:type rdf:Property ;
    rdfs:label 'Benchmark Status' ;
    rdfs:comment 'Current lifecycle status of the benchmark record indicating whether it is actively used for planning, archived for historical reference, in draft state, under review for validation, or deprecated and no longer applicable.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkType rdf:type rdf:Property ;
    rdfs:label 'Benchmark Type' ;
    rdfs:comment 'Classification of the benchmark source and methodology: industry standard benchmarks from third-party sources, agency-observed benchmarks from internal campaign data, client-specific benchmarks, competitive benchmarks, historical performance benchmarks, or predictive benchmarks.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMrcAccredited rdf:type rdf:Property ;
    rdfs:label 'Is Mrc Accredited' ;
    rdfs:comment 'Boolean flag indicating whether the data source or measurement methodology for this benchmark is accredited by the Media Rating Council (MRC), ensuring adherence to industry measurement standards.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Boolean flag indicating whether this benchmark has been reviewed and verified by an internal subject matter expert or data steward for accuracy and applicability.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'The specific performance metric being benchmarked: Click-Through Rate (CTR), Cost Per Mille (CPM), Cost Per Click (CPC), Cost Per Acquisition (CPA), View-Through Rate (VTR), viewability rate, Return on Ad Spend (ROAS), completion rate, or engagement rate. [ENUM-REF-CANDIDATE: ctr|cpm|cpc|cpa|vtr|viewability_rate|roas|completion_rate|engagement_rate — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentileRank rdf:type rdf:Property ;
    rdfs:label 'Percentile Rank' ;
    rdfs:comment 'The statistical percentile or central tendency measure that this benchmark represents: 10th percentile, 25th percentile (lower quartile), 50th percentile (median), 75th percentile (upper quartile), 90th percentile, mean (average), or median. [ENUM-REF-CANDIDATE: p10|p25|p50|p75|p90|mean|median — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'The planning period or fiscal cycle for which this benchmark is intended to be used (e.g., 2024 Annual Plan, Q1 2024, H2 2024).' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unit rdf:type rdf:Property ;
    rdfs:label 'Unit' ;
    rdfs:comment 'The unit of measure for the benchmark value, indicating whether it represents a percentage, currency amount, ratio, impression count, click count, or conversion count.' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the individual or team who verified this benchmark record for accuracy and business applicability.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedDate rdf:type rdf:Property ;
    rdfs:label 'Verified Date' ;
    rdfs:comment 'The date on which this benchmark was verified by an internal subject matter expert, in yyyy-MM-dd format.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vertical rdf:type rdf:Property ;
    rdfs:label 'Vertical' ;
    rdfs:comment 'The industry vertical or product category to which this benchmark applies (e.g., automotive, financial services, retail, healthcare, technology, consumer packaged goods).' ;
    rdfs:domain ind:Benchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent category in the hierarchical taxonomy. Null for top-level channel families.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:adFormatTypes rdf:type rdf:Property ;
    rdfs:label 'Ad Format Types' ;
    rdfs:comment 'Comma-separated list of ad formats supported by this category (e.g., banner, video, native, audio, interstitial, rich media). Used for creative trafficking and asset management.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceTargetingCapability rdf:type rdf:Property ;
    rdfs:label 'Audience Targeting Capability' ;
    rdfs:comment 'Level of audience segmentation and targeting available for this category. Advanced = behavioral, contextual, lookalike; basic = demographic + interest; demographic_only = age/gender only; none = broad reach only.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique business identifier code for the category used in media planning and reporting systems. Follows IAB-aligned naming conventions.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the category. Active categories are available for media planning and buying; deprecated categories are retained for historical reporting only.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'Classification level within the taxonomy hierarchy: channel_family (top-level such as Digital, Broadcast, Print, OOH), channel_subcategory (mid-level such as Programmatic Display, Paid Social), or channel_type (leaf-level granular channel).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartApplicable rdf:type rdf:Property ;
    rdfs:label 'Daypart Applicable' ;
    rdfs:comment 'Indicates whether daypart scheduling (time-of-day targeting such as prime time, daytime, late night) is relevant for this category. Primarily applicable to broadcast, radio, and linear TV.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultAttributionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Default Attribution Window Days' ;
    rdfs:comment 'Standard attribution lookback window (in days) for conversion tracking in this category. Used for ROAS (Return on Ad Spend) and CPA (Cost Per Acquisition) measurement.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultPricingModel rdf:type rdf:Property ;
    rdfs:label 'Default Pricing Model' ;
    rdfs:comment 'Standard pricing model typically used for this category: CPM (Cost Per Mille), CPC (Cost Per Click), CPA (Cost Per Acquisition), CPV (Cost Per View), flat fee, daypart rate, or GRP-based pricing. [ENUM-REF-CANDIDATE: cpm|cpc|cpa|cpv|flat_fee|daypart|grp — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCapSupport rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Support' ;
    rdfs:comment 'Indicates whether this category supports frequency capping (limiting the number of times a user sees an ad within a time period). Common in digital and CTV/OTT channels.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAddressable rdf:type rdf:Property ;
    rdfs:label 'Is Addressable' ;
    rdfs:comment 'Indicates whether this category supports addressable (audience-targeted, household-level) advertising capabilities, common in CTV (Connected TV), OTT (Over-the-Top), and digital channels.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this category is a terminal leaf node (true) or a parent node with children (false). Leaf nodes are used for actual media placement assignment.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementStandard rdf:type rdf:Property ;
    rdfs:label 'Measurement Standard' ;
    rdfs:comment 'Industry measurement standard or methodology applicable to this category (e.g., Nielsen GRP, Comscore vCE, MOAT Viewability, IAS Brand Safety). Used for performance tracking and reconciliation.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationMethod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Method' ;
    rdfs:comment 'Standard billing reconciliation approach for this category. Automated = system-to-system delivery log matching; manual = invoice-based reconciliation; hybrid = combination; not_applicable = non-billable category.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresTrafficking rdf:type rdf:Property ;
    rdfs:label 'Requires Trafficking' ;
    rdfs:comment 'Indicates whether placements in this category require formal ad trafficking instructions (creative asset delivery, tag generation, third-party verification setup) via ad servers such as Google Campaign Manager 360.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Display sequence number for this category within its parent level. Used for consistent ordering in media planning UI, reports, and dashboards.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportsGrp rdf:type rdf:Property ;
    rdfs:label 'Supports Grp' ;
    rdfs:comment 'Indicates whether this category supports GRP-based planning and measurement, typically applicable to broadcast and linear TV channels.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsTrp rdf:type rdf:Property ;
    rdfs:label 'Supports Trp' ;
    rdfs:comment 'Indicates whether this category supports TRP-based audience targeting and measurement, used for demographic-specific reach planning.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsViewability rdf:type rdf:Property ;
    rdfs:label 'Supports Viewability' ;
    rdfs:comment 'Indicates whether this category supports MRC-compliant viewability measurement (e.g., 50% of pixels in-view for 1+ seconds for display, 2+ seconds for video).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vastVpaidSupport rdf:type rdf:Property ;
    rdfs:label 'Vast Vpaid Support' ;
    rdfs:comment 'Indicates video ad serving standard support for this category. VAST for linear video ads, VPAID for interactive video ads, both for hybrid support, none for non-video categories.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelRateId rdf:type rdf:Property ;
    rdfs:label 'Channel Rate Id' ;
    rdfs:comment 'Unique identifier for the channel rate record.' ;
    rdfs:domain ind:ChannelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountPct rdf:type rdf:Property ;
    rdfs:label 'Discount Pct' ;
    rdfs:comment 'Percentage discount applied to the base rate for this tier or negotiated deal.' ;
    rdfs:domain ind:ChannelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRate rdf:type rdf:Property ;
    rdfs:label 'Gross Rate' ;
    rdfs:comment 'The published or negotiated gross rate before any commissions or discounts are applied.' ;
    rdfs:domain ind:ChannelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedImpressions rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Impressions' ;
    rdfs:comment 'Minimum number of impressions guaranteed by the vendor at this rate, applicable to guaranteed buys.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodPolicy rdf:type rdf:Property ;
    rdfs:label 'Makegood Policy' ;
    rdfs:comment 'Description of the makegood or audience deficiency unit (ADU) policy associated with this rate.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRate rdf:type rdf:Property ;
    rdfs:label 'Net Rate' ;
    rdfs:comment 'The net rate after agency commission is deducted from the gross rate.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prismaRateCode rdf:type rdf:Property ;
    rdfs:label 'Prisma Rate Code' ;
    rdfs:comment 'External reference identifier for this rate in the Mediaocean Prisma media planning and buying system.' ;
    rdfs:domain ind:ChannelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardCode rdf:type rdf:Property ;
    rdfs:label 'Rate Card Code' ;
    rdfs:comment 'Unique business identifier for the rate card, typically assigned by the vendor or publisher.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Origin or source of this rate information.' ;
    rdfs:domain ind:ChannelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the rate card entry.' ;
    rdfs:domain ind:ChannelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTierMax rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Max' ;
    rdfs:comment 'Maximum volume threshold (impressions, spend, or units) for this rate tier. Null indicates no upper limit.' ;
    rdfs:domain ind:ChannelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTierMin rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Min' ;
    rdfs:comment 'Minimum volume threshold (impressions, spend, or units) required to qualify for this rate tier.' ;
    rdfs:domain ind:ChannelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTierName rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Name' ;
    rdfs:comment 'Name or label of the volume discount tier (e.g., Bronze, Silver, Gold, Platinum) if this rate is part of a tiered pricing structure.' ;
    rdfs:domain ind:ChannelRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRuleId rdf:type rdf:Property ;
    rdfs:label 'Compliance Rule Id' ;
    rdfs:comment 'Unique identifier for the compliance rule record. Primary key.' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sspPlatformId rdf:type rdf:Property ;
    rdfs:label 'Ssp Platform Id' ;
    rdfs:comment 'Foreign key linking to media.ssp_platform. Business justification: Compliance rules are often SSP-specific (e.g., platform-specific ad policies). Currently platform_name is a STRING; adding ssp_platform_id FK to ssp_platform provides authoritative platform reference ' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SspPlatform .

ind:adFormatRestrictions rdf:type rdf:Property ;
    rdfs:label 'Ad Format Restrictions' ;
    rdfs:comment 'Description of ad format or creative specifications that are restricted or required under this compliance rule (e.g., IAB LEAN ad standards limiting file size and animation, VAST/VPAID requirements for video ads).' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToDirectBuy rdf:type rdf:Property ;
    rdfs:label 'Applies To Direct Buy' ;
    rdfs:comment 'Indicates whether this compliance rule applies to direct media buys negotiated with publishers through insertion orders and managed campaigns.' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToProgrammatic rdf:type rdf:Property ;
    rdfs:label 'Applies To Programmatic' ;
    rdfs:comment 'Indicates whether this compliance rule applies to programmatic advertising buys executed through DSPs (Demand-Side Platforms), SSPs (Supply-Side Platforms), and RTB (Real-Time Bidding) exchanges.' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether this compliance rule mandates the creation and retention of an audit trail documenting compliance verification, user consent, or enforcement actions.' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentMechanism rdf:type rdf:Property ;
    rdfs:label 'Consent Mechanism' ;
    rdfs:comment 'Description of the technical or procedural mechanism used to capture and validate user consent for this compliance rule (e.g., CMP integration, opt-in checkbox, consent string, IAB TCF framework).' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureRequirement rdf:type rdf:Property ;
    rdfs:label 'Disclosure Requirement' ;
    rdfs:comment 'Description of the mandatory disclosure or labeling that must accompany advertising under this compliance rule (e.g., \'Paid Partnership\', \'Sponsored\', \'Ad\', FTC endorsement disclosure).' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Level' ;
    rdfs:comment 'The severity of enforcement for this compliance rule. Mandatory rules block campaign trafficking if violated, recommended rules generate warnings but allow override, and advisory rules provide guidance without enforcement.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'The regulatory authority, platform, or industry organization that mandates or publishes this compliance rule (e.g., FTC, ASA, EASA, Google, Meta, IAB, TAG).' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of the legal, financial, or operational penalties that may result from violating this compliance rule (e.g., fines, account suspension, legal action, reputational damage).' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Reference Document Code' ;
    rdfs:comment 'The official document identifier, regulation number, or policy code that formally defines this compliance rule (e.g., GDPR Article 6, FTC Act Section 5, IAB LEAN Ad Standard).' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceUrl rdf:type rdf:Property ;
    rdfs:label 'Reference Url' ;
    rdfs:comment 'The web URL linking to the official documentation, regulation text, or policy page that defines this compliance rule.' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresConsent rdf:type rdf:Property ;
    rdfs:label 'Requires Consent' ;
    rdfs:comment 'Indicates whether this compliance rule mandates explicit user consent before the advertising activity can proceed (e.g., GDPR consent for targeted advertising, CCPA opt-out mechanisms).' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedAudienceSegments rdf:type rdf:Property ;
    rdfs:label 'Restricted Audience Segments' ;
    rdfs:comment 'Comma-separated list of audience segments or demographic groups that cannot be targeted under this compliance rule (e.g., minors under 13, sensitive health conditions, protected classes).' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedContentTypes rdf:type rdf:Property ;
    rdfs:label 'Restricted Content Types' ;
    rdfs:comment 'Comma-separated list of content types or product categories that are restricted or prohibited under this compliance rule (e.g., alcohol, tobacco, gambling, pharmaceuticals, political advertising).' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'The functional category of the compliance requirement. Disclosure rules mandate advertiser identification, consent rules govern user permission for data usage, targeting rules restrict audience segmentation, creative content rules limit ad messaging, data usage rules govern PII handling, and measurement rules define verification standards.' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Unique business identifier code for the compliance rule, used for external reference and system integration.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed narrative description of the compliance rule, including the specific requirement, the business rationale, and the enforcement mechanism.' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the compliance rule. Active rules are enforced in trafficking workflows, inactive rules are not enforced, pending rules are awaiting approval, deprecated rules are phased out, and suspended rules are temporarily disabled.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the compliance rule by its governing authority or purpose. Regulatory rules are mandated by law, platform policies are vendor-specific, industry standards are self-regulatory, brand safety rules protect advertiser reputation, privacy rules govern data usage, and content restrictions limit creative content.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Third Party Verification Required' ;
    rdfs:comment 'Indicates whether this compliance rule requires third-party verification or certification (e.g., TAG certification, MRC accreditation, IAS or DoubleVerify brand safety verification).' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationVendor rdf:type rdf:Property ;
    rdfs:label 'Verification Vendor' ;
    rdfs:comment 'The name of the third-party verification vendor or service provider used to validate compliance with this rule (e.g., Integral Ad Science, DoubleVerify, MOAT, Comscore).' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationAction rdf:type rdf:Property ;
    rdfs:label 'Violation Action' ;
    rdfs:comment 'The system action taken when this compliance rule is violated during campaign trafficking or creative approval. Block prevents the action, warn notifies the user but allows override, log records the violation silently, and escalate routes to compliance review.' ;
    rdfs:domain ind:ComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerWorkerId rdf:type rdf:Property ;
    rdfs:label 'Buyer Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Media buys must track the specific buyer who negotiated rates, executed the purchase, and owns vendor relationships. Essential for performance reviews, commission tracking, and vendor relationship man' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:traffickingInstructionId rdf:type rdf:Property ;
    rdfs:label 'Trafficking Instruction Id' ;
    rdfs:comment 'Google Campaign Manager 360 (CM360) placement or ad trafficking identifier assigned during ad trafficking. Links the media buy to the ad server delivery record for impression tracking and reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TraffickingInstruction .

ind:addedValueFlag rdf:type rdf:Property ;
    rdfs:label 'Added Value Flag' ;
    rdfs:comment 'Indicates whether this buy includes added-value inventory (bonus impressions, sponsored content, or value-add placements) negotiated as part of the overall media deal at no incremental cost to the client.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agencyCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Amount' ;
    rdfs:comment 'Agency commission deducted from the gross buy amount, typically 15% of gross per industry standard. Represents the agency\'s compensation component embedded in the media buy.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedSpendCeiling rdf:type rdf:Property ;
    rdfs:label 'Authorized Spend Ceiling' ;
    rdfs:comment 'Maximum spend amount authorized for this media buy as approved on the Insertion Order or client budget authorization. Acts as a financial control limit; actual spend must not exceed this value.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookedUnits rdf:type rdf:Property ;
    rdfs:label 'Booked Units' ;
    rdfs:comment 'Quantity of media delivery units contracted in this buy (e.g., number of impressions, GRPs, TRPs, clicks, or spots). The unit type is defined by the rate_basis field. Used for pacing and delivery reconciliation.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyDate rdf:type rdf:Property ;
    rdfs:label 'Buy Date' ;
    rdfs:comment 'The principal real-world business event date on which the media buy was executed — i.e., the date the agency committed spend to the media vehicle. Distinct from system audit timestamps.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buyNumber rdf:type rdf:Property ;
    rdfs:label 'Buy Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the media buy, used in communications with vendors, on Insertion Orders, and in billing reconciliation. Corresponds to the buy reference number in Mediaocean Prisma.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyStatus rdf:type rdf:Property ;
    rdfs:label 'Buy Status' ;
    rdfs:comment 'Current workflow lifecycle state of the media buy. Drives operational actions: pending = awaiting vendor confirmation; confirmed = vendor-accepted and active; cancelled = buy voided; paused = temporarily halted; completed = delivery fulfilled.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyType rdf:type rdf:Property ;
    rdfs:label 'Buy Type' ;
    rdfs:comment 'Classification of the buying modality used to acquire this media inventory. Upfront = advance commitment; scatter = opportunistic spot market; programmatic RTB = real-time bidding via DSP; direct = direct IO with publisher; retail media = retail media network purchase; CTV addressable = addressable CTV/OTT buy.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date on which this media buy was cancelled, if applicable. Populated only when buy_status = \'cancelled\'. Used for cancellation liability calculations and vendor notification tracking.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossBuyAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Buy Amount' ;
    rdfs:comment 'Total gross value of the media buy before agency commission, discounts, or adjustments. Represents the full billing value to the vendor as stated on the Insertion Order.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Flag' ;
    rdfs:comment 'Indicates whether this media buy is a makegood — compensatory inventory provided by the vendor to remedy underdelivery or audience guarantee shortfalls on a prior buy. True = this is a makegood buy.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketType rdf:type rdf:Property ;
    rdfs:label 'Market Type' ;
    rdfs:comment 'Broadcast market commitment classification. Upfront = advance season commitment at negotiated rates; scatter = opportunistic in-season purchase at prevailing market rates; makeweight = inventory added to fulfill audience delivery guarantees (GRP/TRP shortfall).' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatedRate rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate' ;
    rdfs:comment 'The unit rate negotiated with the vendor for this media buy, expressed in the applicable rate basis (e.g., CPM, CPC, CPA, GRP cost). This is the commercially sensitive contracted rate, distinct from rate card pricing.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netBuyAmount rdf:type rdf:Property ;
    rdfs:label 'Net Buy Amount' ;
    rdfs:comment 'Net cost of the media buy after deducting agency commission from the gross amount. Represents the actual vendor payment obligation. Net = Gross minus Agency Commission.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prismaBuyCode rdf:type rdf:Property ;
    rdfs:label 'Prisma Buy Code' ;
    rdfs:comment 'Source system identifier for this buy record in Mediaocean Prisma, the system of record for media planning, buying, and billing. Used for system-of-record traceability and reconciliation.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'The pricing metric on which the negotiated rate is denominated. CPM = Cost Per Mille (thousand impressions); CPC = Cost Per Click; CPA = Cost Per Acquisition; GRP = Gross Rating Point cost; flat = fixed fee; CPCV = Cost Per Completed View; vCPM = viewable CPM. [ENUM-REF-CANDIDATE: cpm|cpc|cpa|grp|flat|cpcv|vcpm — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontDealYear rdf:type rdf:Property ;
    rdfs:label 'Upfront Deal Year' ;
    rdfs:comment 'Broadcast season year reference for upfront market commitments (e.g., \'2024-2025\'). Identifies the upfront buying cycle to which this buy belongs, enabling season-level budget tracking and audience guarantee management.' ;
    rdfs:domain ind:Buy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountExecutiveName rdf:type rdf:Property ;
    rdfs:label 'Account Executive Name' ;
    rdfs:comment 'Name of the account executive who presented the flowchart to the client.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByTitle rdf:type rdf:Property ;
    rdfs:label 'Approved By Title' ;
    rdfs:comment 'Job title of the client representative who authorized the flowchart.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSummaryJson rdf:type rdf:Property ;
    rdfs:label 'Channel Summary Json' ;
    rdfs:comment 'JSON structure containing summary-level spend allocations by channel with percentage splits and key metrics for flowchart visualization.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportFilePath rdf:type rdf:Property ;
    rdfs:label 'Export File Path' ;
    rdfs:comment 'Storage location or URI of the exported flowchart file for client delivery and archival.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportFormat rdf:type rdf:Property ;
    rdfs:label 'Export Format' ;
    rdfs:comment 'File format in which the flowchart was exported for client delivery.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightingPatternJson rdf:type rdf:Property ;
    rdfs:label 'Flighting Pattern Json' ;
    rdfs:comment 'JSON structure containing time-based spend distribution data for visual flighting pattern representation in the flowchart.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowchartName rdf:type rdf:Property ;
    rdfs:label 'Flowchart Name' ;
    rdfs:comment 'Descriptive name of the media flowchart, typically reflecting campaign name and planning period.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowchartNumber rdf:type rdf:Property ;
    rdfs:label 'Flowchart Number' ;
    rdfs:comment 'Business identifier for the flowchart, used in client communications and internal tracking.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyTarget rdf:type rdf:Property ;
    rdfs:label 'Frequency Target' ;
    rdfs:comment 'Target average number of exposures per reached individual, as specified in the flowchart.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grpTarget rdf:type rdf:Property ;
    rdfs:label 'Grp Target' ;
    rdfs:comment 'Total GRP delivery target shown on the flowchart for broadcast media components.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionTarget rdf:type rdf:Property ;
    rdfs:label 'Impression Target' ;
    rdfs:comment 'Total planned impression delivery across all digital and programmatic channels shown in the flowchart.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketBreakout rdf:type rdf:Property ;
    rdfs:label 'Market Breakout' ;
    rdfs:comment 'Geographic segmentation approach used in the flowchart (national, spot markets, DMA-level, etc.).' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerName rdf:type rdf:Property ;
    rdfs:label 'Planner Name' ;
    rdfs:comment 'Name of the media planner who created the flowchart, for client reference and internal accountability.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prismaFlowchartCode rdf:type rdf:Property ;
    rdfs:label 'Prisma Flowchart Code' ;
    rdfs:comment 'External identifier from Mediaocean Prisma system linking this flowchart to the media planning platform.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachTargetPct rdf:type rdf:Property ;
    rdfs:label 'Reach Target Pct' ;
    rdfs:comment 'Target percentage of the audience to be reached at least once, as specified in the flowchart.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeGranularity rdf:type rdf:Property ;
    rdfs:label 'Time Granularity' ;
    rdfs:comment 'Time period breakdown used in the flowchart for spend allocation visualization (weekly, monthly, quarterly).' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFlowchartBudget rdf:type rdf:Property ;
    rdfs:label 'Total Flowchart Budget' ;
    rdfs:comment 'Total media spend amount shown on the flowchart across all channels, markets, and flight periods.' ;
    rdfs:domain ind:Flowchart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trpTarget rdf:type rdf:Property ;
    rdfs:label 'Trp Target' ;
    rdfs:comment 'Total TRP delivery target shown on the flowchart for target audience-specific media components.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:traffickerWorkerId rdf:type rdf:Property ;
    rdfs:label 'Trafficker Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Insertion orders require a designated trafficker responsible for ad server setup, creative trafficking, and delivery monitoring. Critical for accountability in campaign execution and operational hando' ;
    rdfs:domain ind:Media ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:vendorRateCardId rdf:type rdf:Property ;
    rdfs:label 'Vendor Rate Card Id' ;
    rdfs:comment 'Reference to the vendor rate card governing the pricing of placements under this IO. Links to the media rate card product for CPM, CPC, CPA, and flat-fee rate validation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorRateCard .

ind:authorizedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Authorized Spend Amount' ;
    rdfs:comment 'Total gross media spend authorized under this IO, expressed in the IO currency. Represents the maximum contractual commitment to the vendor before agency commission and fees. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET (gross base amount) category.' ;
    rdfs:domain ind:MediaInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency at which the vendor invoices against this IO. Drives accounts payable scheduling and cash flow forecasting in SAP S/4HANA FI.' ;
    rdfs:domain ind:MediaInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyRequirements rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Requirements' ;
    rdfs:comment 'Free-text or structured description of brand safety and suitability requirements contractually mandated for this IO (e.g., IAB content category exclusions, GARM brand safety floor). Enforced during trafficking and programmatic bid configuration.' ;
    rdfs:domain ind:MediaInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notice Days' ;
    rdfs:comment 'Number of business days advance notice required to cancel this IO without incurring the full cancellation penalty. Operationalizes the cancellation policy for workflow and legal compliance.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Net Spend Amount' ;
    rdfs:comment 'Net media cost payable to the vendor after deducting agency commission from the gross authorized spend. Used for vendor payment and reconciliation. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET (net total) category.' ;
    rdfs:domain ind:MediaInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Client-issued Purchase Order number associated with this IO. Required by many advertisers for invoice matching and financial controls in SAP S/4HANA MM. Links the IO to the client\'s internal procurement system.' ;
    rdfs:domain ind:MediaInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prismaIoCode rdf:type rdf:Property ;
    rdfs:label 'Prisma Io Code' ;
    rdfs:comment 'Native system identifier for this IO in Mediaocean Prisma. Enables direct cross-reference and reconciliation between the lakehouse Silver layer and the source system of record.' ;
    rdfs:domain ind:MediaInsertionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adServerPlacementId rdf:type rdf:Property ;
    rdfs:label 'Ad Server Placement Id' ;
    rdfs:comment 'The placement identifier assigned by Google Campaign Manager 360 (CM360) ad server used for trafficking, creative assignment, and delivery reporting. This is the operational key used by ad operations teams to manage the placement in the ad server.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Placement .

ind:originalPlacementMediaPlacementId rdf:type rdf:Property ;
    rdfs:label 'Original Placement Media Placement Id' ;
    rdfs:comment 'For make-good placements (is_makegood = true), the reference to the original media_placement_id that this placement is compensating for. Enables traceability between under-delivered placements and their corresponding make-good replacements.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaPlacement .

ind:primaryMediaAudienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Media Audience Segment Id' ;
    rdfs:comment 'Foreign key linking to audience.segment. Business justification: Placements are bought and trafficked against specific audience segments. Ad ops teams require explicit segment linkage for ad server targeting setup, delivery pacing, and performance reporting by audi' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:traffickingContactWorkerId rdf:type rdf:Property ;
    rdfs:label 'Trafficking Contact Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Placements need a designated trafficking contact for coordinating creative delivery, troubleshooting ad serving issues, and managing publisher communications. Critical for operational efficiency and e' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:aboveFoldClassification rdf:type rdf:Property ;
    rdfs:label 'Above Fold Classification' ;
    rdfs:comment 'Classification indicating whether the placement typically appears above or below the fold on initial page load, critical for viewability.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adUnitSize rdf:type rdf:Property ;
    rdfs:label 'Ad Unit Size' ;
    rdfs:comment 'Dimensions of the ad unit in pixels (e.g., 728x90, 300x250, 1920x1080) or duration for video/audio placements.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'IAB Content Taxonomy category for the content surrounding this placement (e.g., News, Sports, Entertainment, Finance).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedImpressions rdf:type rdf:Property ;
    rdfs:label 'Contracted Impressions' ;
    rdfs:comment 'The total number of ad impressions guaranteed or estimated for this placement under the IO. For CPM-based buys this is the primary delivery metric; for GRP/TRP buys this is the estimated impression equivalent. Used for reach/frequency planning and MRC-compliant delivery verification.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'The negotiated unit rate for this placement as agreed in the Insertion Order (IO), expressed in the applicable rate type currency (e.g., CPM rate in USD, CPC rate in USD, flat fee in USD). This is commercially sensitive pricing data. Serves as the LINE_VALUE_OR_RESULT for this transaction line.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedUnits rdf:type rdf:Property ;
    rdfs:label 'Contracted Units' ;
    rdfs:comment 'The total number of units (impressions, clicks, acquisitions, GRPs, or flat occurrences) contracted for this placement as specified in the Insertion Order. Serves as the LINE_QUANTITY for this transaction line. Used for pacing, delivery tracking, and reconciliation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedValue rdf:type rdf:Property ;
    rdfs:label 'Contracted Value' ;
    rdfs:comment 'The total gross monetary value of this placement as contracted in the Insertion Order (IO), calculated as contracted rate × contracted units. Represents the full financial commitment for this placement before any adjustments, make-goods, or agency commission. Part of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmFloorPrice rdf:type rdf:Property ;
    rdfs:label 'Cpm Floor Price' ;
    rdfs:comment 'Minimum CPM rate for this placement position, used in programmatic bidding and rate card negotiations.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmListPrice rdf:type rdf:Property ;
    rdfs:label 'Cpm List Price' ;
    rdfs:comment 'Published list CPM rate for this placement on the rate card, before negotiation or discounts.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartAvailability rdf:type rdf:Property ;
    rdfs:label 'Daypart Availability' ;
    rdfs:comment 'Time-of-day availability for this placement (e.g., Prime Time, Daytime, Late Night, Run-of-Schedule), relevant for broadcast and digital video.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedMonthlyImpressions rdf:type rdf:Property ;
    rdfs:label 'Estimated Monthly Impressions' ;
    rdfs:comment 'Projected monthly impression volume available for this placement position, used in media planning and forecasting.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedReachPct rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach Pct' ;
    rdfs:comment 'Estimated percentage of target audience reached by this placement within a standard campaign flight.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoTargetingScope rdf:type rdf:Property ;
    rdfs:label 'Geo Targeting Scope' ;
    rdfs:comment 'Geographic targeting granularity available for this placement (global, national, Designated Market Area (DMA), postal code, etc.).' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpContracted rdf:type rdf:Property ;
    rdfs:label 'Grp Contracted' ;
    rdfs:comment 'The total Gross Rating Points (GRP) contracted for this placement, applicable to broadcast TV, radio, and OOH buys. GRP = Reach% × Frequency. Used for broadcast media planning, Nielsen audience measurement reconciliation, and post-buy analysis. Null for digital-only placements.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGuaranteedInventory rdf:type rdf:Property ;
    rdfs:label 'Is Guaranteed Inventory' ;
    rdfs:comment 'Flag indicating whether this placement is sold as guaranteed inventory (direct buy) versus non-guaranteed (programmatic auction).' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMakegood rdf:type rdf:Property ;
    rdfs:label 'Is Makegood' ;
    rdfs:comment 'Indicates whether this placement was created as a make-good (compensatory placement) to replace under-delivered or cancelled inventory from a prior placement. Make-goods are tracked separately for financial reconciliation and vendor performance management.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netContractedValue rdf:type rdf:Property ;
    rdfs:label 'Net Contracted Value' ;
    rdfs:comment 'The net monetary value of this placement after deducting agency commission from the gross contracted value. Represents the actual cost remitted to the media vendor. Part of the MONETARY_TRIPLET net total.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementCode rdf:type rdf:Property ;
    rdfs:label 'Placement Code' ;
    rdfs:comment 'External business identifier or SKU for the placement position, used in media planning and buying systems.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementName rdf:type rdf:Property ;
    rdfs:label 'Placement Name' ;
    rdfs:comment 'Human-readable name describing the placement position (e.g., Homepage Leaderboard, In-Stream Pre-Roll, Sidebar Rectangle, Sponsored Post Slot).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementStatus rdf:type rdf:Property ;
    rdfs:label 'Placement Status' ;
    rdfs:comment 'Current lifecycle status of the placement position in inventory management.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:position rdf:type rdf:Property ;
    rdfs:label 'Position' ;
    rdfs:comment 'The specific position or placement location within the site, broadcast, or publication (e.g., above-the-fold, pre-roll, homepage takeover, run-of-site). Directly impacts CPM rate, viewability, and audience engagement. [ENUM-REF-CANDIDATE: above_the_fold|below_the_fold|pre_roll|mid_roll|post_roll|homepage|run_of_site|run_of_network — promote to reference product]' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Specific position classification within the property page or content stream, critical for viewability and engagement benchmarks. [ENUM-REF-CANDIDATE: above_fold|below_fold|in_stream|pre_roll|mid_roll|post_roll|sidebar|footer|header|interstitial|native_feed|sponsored_tile — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'The name of the specific website, TV station, radio station, publication, or network where the ad will run (e.g., \'CNN.com\', \'NBC Nightly News\', \'The New York Times\'). Represents the RESOURCE_REFERENCE for the media property being purchased.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingParameters rdf:type rdf:Property ;
    rdfs:label 'Targeting Parameters' ;
    rdfs:comment 'Descriptive summary of the audience and contextual targeting criteria applied to this placement (e.g., \'Adults 25-54, HHI $75K+, Interest: Auto, Geo: US-NY\'). Captures demographic, geographic, behavioral, and contextual targeting as configured in The Trade Desk or Google CM360. Free-text summary for operational reference.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vastTagRequired rdf:type rdf:Property ;
    rdfs:label 'Vast Tag Required' ;
    rdfs:comment 'Flag indicating whether this placement requires VAST tag implementation for video ad serving.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewabilityRateBenchmarkPct rdf:type rdf:Property ;
    rdfs:label 'Viewability Rate Benchmark Pct' ;
    rdfs:comment 'Historical or guaranteed viewability rate benchmark for this placement, measured per Media Rating Council (MRC) standards.' ;
    rdfs:domain ind:MediaPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewabilityTargetPct rdf:type rdf:Property ;
    rdfs:label 'Viewability Target Pct' ;
    rdfs:comment 'The minimum viewability percentage contracted or targeted for this digital placement, per MRC viewability standards (e.g., 70% viewable impressions). Used to set vendor accountability thresholds and trigger make-good provisions in the IO.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vpaidSupported rdf:type rdf:Property ;
    rdfs:label 'Vpaid Supported' ;
    rdfs:comment 'Flag indicating whether this placement supports VPAID interactive video ad units.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyingApproach rdf:type rdf:Property ;
    rdfs:label 'Buying Approach' ;
    rdfs:comment 'The media buying methodology planned for this plan — direct IO-based buying, programmatic Real-Time Bidding (RTB) via DSP, or a hybrid approach. Determines execution path in Mediaocean Prisma and The Trade Desk.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartStrategy rdf:type rdf:Property ;
    rdfs:label 'Daypart Strategy' ;
    rdfs:comment 'The planned daypart scheduling strategy for broadcast and digital media placements. Defines when within the day media will be concentrated to maximize target audience reach.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBudget rdf:type rdf:Property ;
    rdfs:label 'Net Budget' ;
    rdfs:comment 'The net media budget after deducting agency commission and applicable fees from the gross planned budget. Represents the actual spend allocated to media vendors and publishers.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable descriptive name of the media plan, typically including client name, campaign flight, and planning period (e.g., \'Acme Q3 2025 Brand Awareness Plan\'). Used in Mediaocean Prisma and client presentations.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known unique business identifier for the media plan as assigned by Mediaocean Prisma. Used in client-facing documents, insertion orders, and cross-system references.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the media plan by strategic objective and buying approach. Determines the KPI framework and channel mix strategy applied. [ENUM-REF-CANDIDATE: brand_awareness|direct_response|performance|sponsorship|integrated|programmatic — promote to reference product]' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prismaPlanCode rdf:type rdf:Property ;
    rdfs:label 'Prisma Plan Code' ;
    rdfs:comment 'The native plan identifier assigned by Mediaocean Prisma, the system of record for media planning and buying. Used for cross-system reconciliation between the lakehouse and Prisma.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sfdcOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Sfdc Opportunity Code' ;
    rdfs:comment 'The Salesforce CRM Opportunity ID associated with this media plan. Links the media plan to the sales pipeline record for revenue tracking and account management reporting.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgeRange rdf:type rdf:Property ;
    rdfs:label 'Target Age Range' ;
    rdfs:comment 'The primary demographic age range targeted by this media plan (e.g., \'25-54\', \'18-34\'). Used for GRP/TRP calculation and audience buying parameters in Nielsen Ad Intel and The Trade Desk.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGender rdf:type rdf:Property ;
    rdfs:label 'Target Gender' ;
    rdfs:comment 'Gender targeting parameter for the media plan audience. Informs GRP/TRP delivery targets and audience buying configurations in Nielsen Ad Intel and The Trade Desk.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarkets rdf:type rdf:Property ;
    rdfs:label 'Target Markets' ;
    rdfs:comment 'Comma-separated list of target geographic markets or Designated Market Areas (DMAs) where media will run (e.g., \'New York DMA, Los Angeles DMA, Chicago DMA\'). Used for geo-targeting and local market buying.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPlannedBudget rdf:type rdf:Property ;
    rdfs:label 'Total Planned Budget' ;
    rdfs:comment 'The gross total budget allocated to this media plan across all channels and placements for the full flight period. Expressed in the plan currency. Sourced from Mediaocean Prisma budget module.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyingStatus rdf:type rdf:Property ;
    rdfs:label 'Buying Status' ;
    rdfs:comment 'Operational buying and trafficking status of this line item, tracking progression from plan through insertion order issuance, confirmation, trafficking, and delivery. Distinct from approval_status which governs internal authorization. [ENUM-REF-CANDIDATE: not_ordered|io_sent|io_confirmed|trafficking|live|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyingType rdf:type rdf:Property ;
    rdfs:label 'Buying Type' ;
    rdfs:comment 'The pricing and buying model for this line item, determining how media is purchased and measured. CPM (Cost Per Mille), CPC (Cost Per Click), CPA (Cost Per Acquisition), CPV (Cost Per View), flat_rate, GRP (Gross Rating Point), or TRP (Target Rating Point). Drives rate card application and performance benchmarking. [ENUM-REF-CANDIDATE: cpm|cpc|cpa|cpv|flat_rate|grp|trp — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBonus rdf:type rdf:Property ;
    rdfs:label 'Is Bonus' ;
    rdfs:comment 'Indicates whether this line item represents bonus or added-value inventory provided by the publisher at no additional cost as part of a negotiated package. Bonus lines are excluded from spend calculations but included in delivery and GRP reporting.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Descriptive name for this media plan line item, typically combining the vehicle, placement, and flight period (e.g., \'CNN Homepage Takeover - Q1 2025\'). Used for human-readable identification in reports and insertion orders.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaSubtype rdf:type rdf:Property ;
    rdfs:label 'Media Subtype' ;
    rdfs:comment 'Granular classification within the media type (e.g., display, video, paid_search, social, connected_tv, digital_out_of_home, programmatic, direct). Enables detailed channel-level performance analysis and buying strategy differentiation. [ENUM-REF-CANDIDATE: display|video|paid_search|social|connected_tv|digital_out_of_home|programmatic|direct|audio|native — promote to reference product]' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCpa rdf:type rdf:Property ;
    rdfs:label 'Planned Cpa' ;
    rdfs:comment 'Planned Cost Per Acquisition (CPA) — the negotiated or estimated cost for each conversion or acquisition event generated by this line item. Used for performance-based buying where payment is tied to measurable outcomes.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCpc rdf:type rdf:Property ;
    rdfs:label 'Planned Cpc' ;
    rdfs:comment 'Planned Cost Per Click (CPC) — the negotiated or estimated cost for each click generated by this line item. Primary pricing metric for paid search and performance-based digital campaigns. Applicable when buying_type is CPC.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFrequency rdf:type rdf:Property ;
    rdfs:label 'Planned Frequency' ;
    rdfs:comment 'Planned average number of times a member of the target audience will be exposed to the ad during the flight period. Used with reach to calculate GRPs and to optimize against frequency caps and diminishing returns thresholds.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGrps rdf:type rdf:Property ;
    rdfs:label 'Planned Grps' ;
    rdfs:comment 'Planned Gross Rating Points (GRPs) for this line item, representing total audience delivery as a percentage of the total target population. Primary planning metric for broadcast TV, radio, and OOH. Calculated as reach × frequency.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedNetSpend rdf:type rdf:Property ;
    rdfs:label 'Planned Net Spend' ;
    rdfs:comment 'Planned net media spend after agency commission, discounts, and negotiated rebates have been deducted from the gross planned spend. Used for vendor payment reconciliation and agency P&L reporting.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReachPct rdf:type rdf:Property ;
    rdfs:label 'Planned Reach Pct' ;
    rdfs:comment 'Planned percentage of the target audience expected to be exposed to the ad at least once during the flight period. Key media planning metric used alongside frequency to evaluate campaign effectiveness and GRP decomposition.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSpend rdf:type rdf:Property ;
    rdfs:label 'Planned Spend' ;
    rdfs:comment 'Total planned gross media spend allocated to this line item for the full flight period, in the plan currency. Primary budget field used for financial planning, client billing, and P&L management. LINE_VALUE_OR_RESULT per TRANSACTION_LINE canonical role.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTrps rdf:type rdf:Property ;
    rdfs:label 'Planned Trps' ;
    rdfs:comment 'Planned Target Rating Points (TRPs) for this line item, representing audience delivery specifically among the defined target demographic as a percentage of that target population. More precise than GRPs for audience-specific campaign planning.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Units' ;
    rdfs:comment 'The planned quantity of media units to be purchased for this line item. Unit interpretation depends on buying_type: impressions for CPM, clicks for CPC, conversions for CPA, spots for broadcast, panels for OOH. LINE_QUANTITY per TRANSACTION_LINE canonical role.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publisherName rdf:type rdf:Property ;
    rdfs:label 'Publisher Name' ;
    rdfs:comment 'Name of the media owner or publisher selling the inventory for this line item (e.g., \'WarnerMedia\', \'Google\', \'Clear Channel\'). Used for vendor management, spend reporting, and competitive analysis.' ;
    rdfs:domain ind:PlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleName rdf:type rdf:Property ;
    rdfs:label 'Vehicle Name' ;
    rdfs:comment 'Name of the specific media property or publisher vehicle where the ad will run (e.g., \'CNN.com\', \'NBC Nightly News\', \'Times Square Billboard\', \'Spotify\'). Core planning field used in insertion orders and vendor negotiations.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedLoopMeasurement rdf:type rdf:Property ;
    rdfs:label 'Closed Loop Measurement' ;
    rdfs:comment 'Indicates whether closed-loop measurement (linking ad exposure to purchase/conversion outcomes) is available for this deal. Particularly relevant for Retail Media Network (RMN) deals (Amazon DSP, Walmart Connect, Instacart Ads) where purchase data enables attribution. True = closed-loop measurement available.' ;
    rdfs:domain ind:ProgrammaticDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealCode rdf:type rdf:Property ;
    rdfs:label 'Deal Code' ;
    rdfs:comment 'Externally-known deal identifier assigned by the DSP or SSP/exchange (e.g., The Trade Desk deal ID, Amazon DSP deal ID). Used for trafficking, bid requests, and reconciliation across platforms. Maps to the deal_id field in The Trade Desk and OpenRTB bid-request objects.' ;
    rdfs:domain ind:ProgrammaticDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealName rdf:type rdf:Property ;
    rdfs:label 'Deal Name' ;
    rdfs:comment 'Human-readable name of the programmatic deal as entered in the DSP or Mediaocean Prisma. Used for identification in media plans, trafficking sheets, and reporting dashboards.' ;
    rdfs:domain ind:ProgrammaticDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Deal Source System' ;
    rdfs:comment 'The operational system of record from which this programmatic deal record was sourced. Used for data lineage, reconciliation, and ETL pipeline routing. Drives system-specific field mapping in the Silver layer ingestion process. [ENUM-REF-CANDIDATE: the_trade_desk|amazon_dsp|google_cm360|mediaocean_prisma|walmart_dsp|instacart_ads|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProgrammaticDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Current lifecycle state of the programmatic deal. Draft = in negotiation; Pending Approval = submitted for internal/publisher approval; Active = live and eligible for bidding; Paused = temporarily suspended; Expired = past end date; Cancelled = terminated before end date.' ;
    rdfs:domain ind:ProgrammaticDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealType rdf:type rdf:Property ;
    rdfs:label 'Deal Type' ;
    rdfs:comment 'Classification of the programmatic deal structure. PMP (Private Marketplace) = curated invite-only auction; Preferred Deal = fixed CPM, non-guaranteed; Programmatic Guaranteed (PG) = fixed CPM with impression commitment; Open Auction = RTB open exchange; Retailer PMP = retailer-specific private marketplace (e.g., Amazon DSP, Walmart Connect). [ENUM-REF-CANDIDATE: pmp|preferred_deal|programmatic_guaranteed|open_auction|retailer_pmp — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalDealRef rdf:type rdf:Property ;
    rdfs:label 'External Deal Ref' ;
    rdfs:comment 'Secondary external reference identifier for this deal as recorded in a partner system (e.g., publisher deal ID, SSP deal reference, Mediaocean Prisma order number). Enables cross-system reconciliation and deduplication.' ;
    rdfs:domain ind:ProgrammaticDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionCommitment rdf:type rdf:Property ;
    rdfs:label 'Impression Commitment' ;
    rdfs:comment 'The total number of impressions committed under this deal. Mandatory for Programmatic Guaranteed (PG) deals where delivery is contractually obligated. For PMP and Preferred Deals, represents the estimated or target impression volume. Used for pacing, delivery forecasting, and make-good calculations.' ;
    rdfs:domain ind:ProgrammaticDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Negotiated Timestamp' ;
    rdfs:comment 'The real-world business event timestamp when the programmatic deal was formally agreed/struck between the buyer and seller. Distinct from the record audit created timestamp. Used for deal velocity reporting and SLA tracking.' ;
    rdfs:domain ind:ProgrammaticDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rtbBidStrategy rdf:type rdf:Property ;
    rdfs:label 'Rtb Bid Strategy' ;
    rdfs:comment 'The Real-Time Bidding (RTB) bid strategy configured in the DSP for this deal. Fixed CPM is standard for PG deals; Dynamic CPM and performance-based strategies (Target CPA, Target ROAS) apply to PMP and open auction deals. Configured in The Trade Desk Bid Management module.' ;
    rdfs:domain ind:ProgrammaticDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopperDataEnabled rdf:type rdf:Property ;
    rdfs:label 'Shopper Data Enabled' ;
    rdfs:comment 'Indicates whether retailer shopper/purchase data is used for audience targeting in this deal. Applicable to Retail Media Network (RMN) deals on Amazon DSP, Walmart Connect, and Instacart Ads. True = first-party shopper data targeting is active.' ;
    rdfs:domain ind:ProgrammaticDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for the media schedule record. Primary key for the media_schedule data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Duration Seconds' ;
    rdfs:comment 'Length of the ad creative in seconds, applicable to broadcast TV, radio, CTV/OTT, and digital video formats (e.g., 15, 30, 60). Used for broadcast trafficking, pod position management, and VAST/VPAID configuration.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airEndTime rdf:type rdf:Property ;
    rdfs:label 'Air End Time' ;
    rdfs:comment 'Precise date-time at which the ad unit is scheduled to stop airing or delivering on a given occurrence. Used alongside air_start_time to define the exact delivery window.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airStartTime rdf:type rdf:Property ;
    rdfs:label 'Air Start Time' ;
    rdfs:comment 'Precise date-time at which the ad unit is scheduled to begin airing or delivering on a given occurrence. Critical for broadcast trafficking and programmatic deal scheduling. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creativeRotationType rdf:type rdf:Property ;
    rdfs:label 'Creative Rotation Type' ;
    rdfs:comment 'Instruction governing how multiple creative assets are rotated across scheduled impressions — even (equal distribution), weighted (percentage-based), sequential (ordered), or optimised (performance-driven). Trafficked into Google Campaign Manager 360.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podPosition rdf:type rdf:Property ;
    rdfs:label 'Pod Position' ;
    rdfs:comment 'Requested or guaranteed position of the ad within a commercial break pod for broadcast TV, radio, and CTV/OTT channels. First and last pod positions command premium pricing. Null for non-broadcast channels.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptible rdf:type rdf:Property ;
    rdfs:label 'Preemptible' ;
    rdfs:comment 'Flag indicating whether this scheduled placement can be preempted by a higher-paying advertiser. Preemptible spots are typically priced lower than guaranteed placements. Relevant for broadcast and premium digital inventory.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number for this schedule, as assigned by the media planning system (Mediaocean Prisma) or trafficking system (Google Campaign Manager 360). Used for cross-system reconciliation.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledGrp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Grp' ;
    rdfs:comment 'Total Gross Rating Points (GRP) planned for this media schedule, representing the sum of ratings across all scheduled airings. GRP = Reach % × Frequency. Used for broadcast media planning and audience delivery measurement.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledImpressions rdf:type rdf:Property ;
    rdfs:label 'Scheduled Impressions' ;
    rdfs:comment 'Total number of ad impressions contracted and scheduled for delivery under this media schedule record for the defined flight period. Used for pacing, delivery tracking, and reconciliation against actuals.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledTrp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Trp' ;
    rdfs:comment 'Total Target Rating Points (TRP) planned for this media schedule, measuring GRP delivery against a specific target audience demographic. TRP is the audience-qualified subset of GRP used for precision media planning.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledUnits rdf:type rdf:Property ;
    rdfs:label 'Scheduled Units' ;
    rdfs:comment 'Number of discrete ad units (spots, insertions, or placements) scheduled for the flight period — applicable to broadcast (spots), print (insertions), and OOH (faces/panels). Distinct from impressions which measure audience exposure.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adFraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Ad Fraud Risk Score' ;
    rdfs:comment 'The fraud risk score for this property (0-100 scale, where higher scores indicate higher fraud risk) based on invalid traffic (IVT) detection and TAG certification.' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appBundleCode rdf:type rdf:Property ;
    rdfs:label 'App Bundle Code' ;
    rdfs:comment 'The platform-specific bundle identifier for mobile or CTV apps (e.g., com.example.app).' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appStoreCode rdf:type rdf:Property ;
    rdfs:label 'App Store Code' ;
    rdfs:comment 'The unique identifier for the mobile or CTV app in the app store (e.g., Apple App Store ID, Google Play Store ID, Roku Channel Store ID).' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceComposition rdf:type rdf:Property ;
    rdfs:label 'Audience Composition' ;
    rdfs:comment 'Description of the primary audience demographics and psychographics for this property (e.g., \'Adults 25-54, HHI $75K+, Tech Early Adopters\').' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageCpm rdf:type rdf:Property ;
    rdfs:label 'Average Cpm' ;
    rdfs:comment 'The average Cost Per Mille (CPM) rate achieved for ad placements on this property over the past 90 days.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandSafetyClassification rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Classification' ;
    rdfs:comment 'The brand safety tier or classification for this property based on content quality, adjacency risk, and third-party verification (e.g., TAG Certified, IAS/DV brand safety scores).' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignManagerSiteCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Manager Site Code' ;
    rdfs:comment 'The unique site identifier for this property in Google Campaign Manager 360 ad serving platform.' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentVertical rdf:type rdf:Property ;
    rdfs:label 'Content Vertical' ;
    rdfs:comment 'The primary content category or vertical of the property (e.g., News, Sports, Entertainment, Finance, Lifestyle) per IAB Content Taxonomy.' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'The primary geographic markets or regions served by this property (e.g., \'USA National\', \'New York DMA\', \'EMEA\', \'Global\').' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabContentCategory rdf:type rdf:Property ;
    rdfs:label 'Iab Content Category' ;
    rdfs:comment 'The standardized IAB content category code for the property (e.g., IAB1 for Arts & Entertainment, IAB3 for Business).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyImpressions rdf:type rdf:Property ;
    rdfs:label 'Monthly Impressions' ;
    rdfs:comment 'The average number of ad impressions available per month for this property.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyUniqueVisitors rdf:type rdf:Property ;
    rdfs:label 'Monthly Unique Visitors' ;
    rdfs:comment 'The average number of unique visitors or users per month for this property.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrcAuditDate rdf:type rdf:Property ;
    rdfs:label 'Mrc Audit Date' ;
    rdfs:comment 'The date of the most recent MRC audit or certification for this property.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pmpDealsAvailable rdf:type rdf:Property ;
    rdfs:label 'Pmp Deals Available' ;
    rdfs:comment 'Indicates whether this property offers Private Marketplace (PMP) programmatic deals with negotiated terms and pricing.' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prismaPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Prisma Property Code' ;
    rdfs:comment 'The unique identifier for this property in the Mediaocean Prisma media planning and buying system.' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticEnabled rdf:type rdf:Property ;
    rdfs:label 'Programmatic Enabled' ;
    rdfs:comment 'Indicates whether this property is available for programmatic buying through Demand-Side Platforms (DSPs) and Supply-Side Platforms (SSPs).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:propertyCode rdf:type rdf:Property ;
    rdfs:label 'Property Code' ;
    rdfs:comment 'The externally-known unique identifier or code for this property used in media planning and buying systems (e.g., site ID, app ID, network code).' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyName rdf:type rdf:Property ;
    rdfs:label 'Property Name' ;
    rdfs:comment 'The human-readable name of the media property, site, app, network, or placement (e.g., \'ESPN Mobile App\', \'The New York Times Homepage\', \'Clear Channel Billboard Network\').' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyStatus rdf:type rdf:Property ;
    rdfs:label 'Property Status' ;
    rdfs:comment 'Current lifecycle status of the property in the media inventory system.' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyType rdf:type rdf:Property ;
    rdfs:label 'Property Type' ;
    rdfs:comment 'The category of media property: website, mobile app, Connected TV (CTV) app, streaming channel, TV network, radio station, Out-of-Home (OOH) network, or print publication. [ENUM-REF-CANDIDATE: website|mobile_app|ctv_app|streaming_channel|tv_network|radio_station|ooh_network|print_publication — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyUrl rdf:type rdf:Property ;
    rdfs:label 'Property Url' ;
    rdfs:comment 'The primary URL or web address for the property (for websites and web-based properties).' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtbEnabled rdf:type rdf:Property ;
    rdfs:label 'Rtb Enabled' ;
    rdfs:comment 'Indicates whether this property supports Real-Time Bidding (RTB) for ad inventory.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportedAdFormats rdf:type rdf:Property ;
    rdfs:label 'Supported Ad Formats' ;
    rdfs:comment 'Comma-separated list of ad formats supported by this property (e.g., display, video, native, audio, DOOH).' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vastVersion rdf:type rdf:Property ;
    rdfs:label 'Vast Version' ;
    rdfs:comment 'The version of the Video Ad Serving Template (VAST) standard supported by this property (e.g., VAST 2.0, VAST 3.0, VAST 4.0).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoPlayerType rdf:type rdf:Property ;
    rdfs:label 'Video Player Type' ;
    rdfs:comment 'The type of video player used on this property for video ad serving (e.g., JW Player, Brightcove, Video.js, native CTV player).' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityBenchmarkPct rdf:type rdf:Property ;
    rdfs:label 'Viewability Benchmark Pct' ;
    rdfs:comment 'The average viewability rate for ad placements on this property, measured as percentage of impressions that meet MRC viewability standards (50% of pixels in view for 1+ seconds for display, 2+ seconds for video).' ;
    rdfs:domain ind:PublisherProperty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Sov Benchmark Id' ;
    rdfs:comment 'Unique surrogate identifier for each Share of Voice (SOV) benchmark record in the media planning reference master.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorNames rdf:type rdf:Property ;
    rdfs:label 'Competitor Names' ;
    rdfs:comment 'Comma-delimited list of individual competitor brand names included in the defined competitor set for this SOV benchmark. Confidential competitive intelligence sourced from Nielsen Ad Intel or Pathmatics.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorSetName rdf:type rdf:Property ;
    rdfs:label 'Competitor Set Name' ;
    rdfs:comment 'Label identifying the defined group of competing brands or advertisers included in the SOV calculation (e.g., \'Tier-1 Auto Competitors — Luxury Segment\'). Confidential competitive intelligence.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBrandSpend rdf:type rdf:Property ;
    rdfs:label 'Estimated Brand Spend' ;
    rdfs:comment 'Estimated total media spend (in USD) for the advertiser\'s brand within the defined channel, market, and measurement period. Sourced from Nielsen Ad Intel, Comscore, or Pathmatics/Sensor Tower competitive intelligence.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCompetitorSpend rdf:type rdf:Property ;
    rdfs:label 'Estimated Competitor Spend' ;
    rdfs:comment 'Estimated total media spend (in USD) for all competitors in the defined competitor set within the channel, market, and measurement period. Sourced from competitive intelligence platforms.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grpBenchmark rdf:type rdf:Property ;
    rdfs:label 'Grp Benchmark' ;
    rdfs:comment 'The Gross Rating Point (GRP) benchmark value for the advertiser\'s brand within the defined channel, market, and measurement period. Used for broadcast and video channel SOV benchmarking alongside spend-based SOV.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionSharePct rdf:type rdf:Property ;
    rdfs:label 'Impression Share Pct' ;
    rdfs:comment 'The advertiser\'s share of total available impressions within the defined channel, market, and measurement period. Particularly relevant for digital channels (paid search, display) as a complement to spend-based SOV.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedBudget rdf:type rdf:Property ;
    rdfs:label 'Recommended Budget' ;
    rdfs:comment 'The media budget (in spend_currency_code) recommended by media strategists to achieve the sov_target_pct for the advertiser\'s brand in the defined channel and market. Derived from competitive intelligence and used in client budget justification.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovPct rdf:type rdf:Property ;
    rdfs:label 'Sov Pct' ;
    rdfs:comment 'The measured or estimated Share of Voice (SOV) percentage for the advertiser\'s brand within the defined competitor set, channel, and market for the measurement period. Expressed as a percentage (0.0000–100.0000). Core metric driving media budget allocation recommendations.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Spend Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all spend figures in this benchmark record (estimated_brand_spend, estimated_competitor_spend, total_category_spend). Defaults to USD for US markets.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCategorySpend rdf:type rdf:Property ;
    rdfs:label 'Total Category Spend' ;
    rdfs:comment 'Estimated total media spend (in USD) across all advertisers in the product/service category within the channel, market, and measurement period. Denominator used to calculate SOV percentage.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trpBenchmark rdf:type rdf:Property ;
    rdfs:label 'Trp Benchmark' ;
    rdfs:comment 'The Target Rating Point (TRP) benchmark value for the advertiser\'s brand, scoped to the defined target audience segment. Complements GRP by focusing on the specific audience rather than the total population.' ;
    rdfs:domain ind:SovBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adsTxtCertified rdf:type rdf:Property ;
    rdfs:label 'Ads Txt Certified' ;
    rdfs:comment 'Indicates whether the SSP is certified and compliant with the IAB Tech Lab ads.txt standard for authorized digital sellers.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidFloorCpm rdf:type rdf:Property ;
    rdfs:label 'Bid Floor Cpm' ;
    rdfs:comment 'The minimum CPM bid floor required by this SSP for participating in auctions.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandSafetyProvider rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Provider' ;
    rdfs:comment 'The third-party brand safety verification provider integrated with this SSP (e.g., IAS, DoubleVerify, MOAT).' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaCompliant rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant' ;
    rdfs:comment 'Indicates whether the SSP is compliant with CCPA requirements for consumer privacy rights.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dspIntegrationList rdf:type rdf:Property ;
    rdfs:label 'Dsp Integration List' ;
    rdfs:comment 'Comma-separated list of DSP platforms integrated with this SSP (e.g., The Trade Desk, DV360, Amazon DSP).' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudDetectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Fraud Detection Enabled' ;
    rdfs:comment 'Indicates whether fraud detection and invalid traffic (IVT) filtering is enabled for this SSP.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant' ;
    rdfs:comment 'Indicates whether the SSP is compliant with GDPR requirements for data privacy and user consent.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Health Check Status' ;
    rdfs:comment 'The result of the most recent health check indicating the operational status of the SSP integration.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationDate rdf:type rdf:Property ;
    rdfs:label 'Integration Date' ;
    rdfs:comment 'The date when the technical integration with this SSP was completed and went live.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastHealthCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Health Check Timestamp' ;
    rdfs:comment 'The timestamp of the most recent health check or connectivity test performed on this SSP integration.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:openrtbVersion rdf:type rdf:Property ;
    rdfs:label 'Openrtb Version' ;
    rdfs:comment 'The version of the OpenRTB protocol supported by this SSP (e.g., 2.5, 2.6, 3.0).' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Internal short code or abbreviation used to reference the SSP in operational systems and reporting (e.g., GAM, MAG, PUB).' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Status' ;
    rdfs:comment 'Current operational status of the SSP integration within the agency\'s programmatic infrastructure.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmpEnabled rdf:type rdf:Property ;
    rdfs:label 'Pmp Enabled' ;
    rdfs:comment 'Indicates whether Private Marketplace deals are supported and enabled for this SSP.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programmaticGuaranteedEnabled rdf:type rdf:Property ;
    rdfs:label 'Programmatic Guaranteed Enabled' ;
    rdfs:comment 'Indicates whether Programmatic Guaranteed deals are supported and enabled for this SSP.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qpsLimit rdf:type rdf:Property ;
    rdfs:label 'Qps Limit' ;
    rdfs:comment 'The maximum number of bid requests per second that can be sent to this SSP as per the integration agreement.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueSharePct rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Pct' ;
    rdfs:comment 'The percentage of revenue shared with the SSP as per the contractual agreement.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellersJsonCompliant rdf:type rdf:Property ;
    rdfs:label 'Sellers Json Compliant' ;
    rdfs:comment 'Indicates whether the SSP publishes a sellers.json file in compliance with IAB Tech Lab transparency standards.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportedDealTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Deal Types' ;
    rdfs:comment 'Comma-separated list of programmatic deal types supported (e.g., PMP - Private Marketplace, PG - Programmatic Guaranteed, Open Auction, Preferred Deal).' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'Email address of the technical support contact at the SSP for integration and troubleshooting.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeoutMs rdf:type rdf:Property ;
    rdfs:label 'Timeout Ms' ;
    rdfs:comment 'The maximum time in milliseconds to wait for a bid response from this SSP before timing out.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewabilityMeasurementEnabled rdf:type rdf:Property ;
    rdfs:label 'Viewability Measurement Enabled' ;
    rdfs:comment 'Indicates whether viewability measurement is enabled for impressions served through this SSP.' ;
    rdfs:domain ind:SspPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentInstructionTraffickingInstructionId rdf:type rdf:Property ;
    rdfs:label 'Parent Instruction Trafficking Instruction Id' ;
    rdfs:comment 'Reference to the original trafficking instruction that this record revises or cancels. Enables lineage tracking across instruction versions and supports audit of changes to creative delivery parameters.' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TraffickingInstruction .

ind:adServer rdf:type rdf:Property ;
    rdfs:label 'Ad Server' ;
    rdfs:comment 'Name of the ad serving platform to which this trafficking instruction is dispatched. Identifies the technology stack responsible for delivering the creative asset to the designated placement. Primary system is Google Campaign Manager 360.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adServerPlacementCode rdf:type rdf:Property ;
    rdfs:label 'Ad Server Placement Code' ;
    rdfs:comment 'The unique placement tag or code assigned by the ad server (e.g., Google Campaign Manager 360 placement ID) that maps this instruction to the correct ad unit within the ad serving platform. Used for trafficking reconciliation.' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetySegment rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Segment' ;
    rdfs:comment 'Specific brand safety content category or segment classification applied to this instruction (e.g., \'exclude adult content\', \'exclude fake news\', \'GARM Floor\'). Defines the content adjacency restrictions enforced during ad delivery.' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Precise date and time when the ad server or media vendor confirmed receipt and acceptance of the trafficking instruction. Used for SLA compliance measurement and operational reporting.' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creativeSize rdf:type rdf:Property ;
    rdfs:label 'Creative Size' ;
    rdfs:comment 'Pixel dimensions of the creative asset being trafficked, expressed as width x height (e.g., 300x250, 728x90, 160x600). Must conform to IAB standard ad unit sizes. Used for placement compatibility validation.' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery End Date' ;
    rdfs:comment 'The scheduled date on which ad creative delivery is to cease per this trafficking instruction. Aligns with the media plan flight end dates and insertion order terms.' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Start Date' ;
    rdfs:comment 'The scheduled date on which ad creative delivery is to commence per this trafficking instruction. Aligns with the media plan flight dates and insertion order terms.' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impressionTrackingPixelUrl rdf:type rdf:Property ;
    rdfs:label 'Impression Tracking Pixel Url' ;
    rdfs:comment 'URL of the impression tracking pixel fired upon each ad impression to record delivery counts. Used for third-party verification, billing reconciliation, and campaign measurement. May include multiple pixels concatenated or the primary pixel URL.' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionNumber rdf:type rdf:Property ;
    rdfs:label 'Instruction Number' ;
    rdfs:comment 'Externally-known, human-readable reference number for this trafficking instruction, used in communications with ad servers, media vendors, and internal trafficking teams. Typically follows a structured naming convention (e.g., TI-2024-00123).' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionStatus rdf:type rdf:Property ;
    rdfs:label 'Instruction Status' ;
    rdfs:comment 'Current lifecycle state of the trafficking instruction: pending (created but not yet dispatched), sent (transmitted to ad server or vendor), confirmed (acknowledged by recipient), rejected (refused by recipient), or cancelled (voided before confirmation).' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionType rdf:type rdf:Property ;
    rdfs:label 'Instruction Type' ;
    rdfs:comment 'Classifies the nature of the trafficking instruction: new (initial dispatch of a creative), revision (update to an existing instruction), cancellation (termination of delivery), pause (temporary halt), or resume (restart after pause).' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityTagUrl rdf:type rdf:Property ;
    rdfs:label 'Viewability Tag Url' ;
    rdfs:comment 'URL of the viewability measurement tag embedded in the ad creative to track whether the ad was viewable per MRC and IAB viewability standards (e.g., 50% of pixels in view for 1 continuous second for display). Used for viewability reporting and vendor compliance.' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vpaidTagUrl rdf:type rdf:Property ;
    rdfs:label 'Vpaid Tag Url' ;
    rdfs:comment 'The Video Player-Ad Interface Definition (VPAID) tag URL enabling interactive video ad execution within the video player environment. Used for rich interactive video creatives requiring player-level communication. Applicable for VPAID-enabled placements.' ;
    rdfs:domain ind:TraffickingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModelId rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Id' ;
    rdfs:comment 'Unique identifier for the attribution model configuration. Primary key.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttributionModel .

ind:attributionModelDescription rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Description' ;
    rdfs:comment 'Detailed business description of the attribution model configuration, including rationale, use cases, and any special rules or exclusions.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModelStatus rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Status' ;
    rdfs:comment 'Current lifecycle status of the attribution model configuration. Active models are applied to conversion events; inactive models are retained for historical reference; draft models are under development; archived models are deprecated; testing models are in A/B comparison.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickThroughWindowDays rdf:type rdf:Property ;
    rdfs:label 'Click Through Window Days' ;
    rdfs:comment 'Number of days after a click during which a conversion can be attributed to that click event. Standard values range from 1 to 90 days.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comparisonGroupCode rdf:type rdf:Property ;
    rdfs:label 'Comparison Group Code' ;
    rdfs:comment 'Identifier linking this attribution model to an A/B testing or incrementality testing group for model comparison workflows. Null if not part of a comparison test.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionEventScope rdf:type rdf:Property ;
    rdfs:label 'Conversion Event Scope' ;
    rdfs:comment 'Defines which conversion events this attribution model applies to. May be a comma-separated list of conversion event types (e.g., \'purchase,lead_form,signup\') or \'all\' for universal application.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossChannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Channel Enabled' ;
    rdfs:comment 'Indicates whether the attribution model tracks and attributes conversions across multiple marketing channels (display, search, social, video, email, OOH, CTV, etc.).' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossDeviceEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Device Enabled' ;
    rdfs:comment 'Indicates whether the attribution model uses cross-device identity graph to track and attribute conversions across multiple devices (desktop, mobile, tablet, CTV) for the same user.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataDrivenAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Data Driven Algorithm Version' ;
    rdfs:comment 'For data-driven (algorithmic) attribution models, the version identifier of the machine learning algorithm or model used to calculate fractional credit distribution. Null for rule-based models.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDrivenMinimumConversions rdf:type rdf:Property ;
    rdfs:label 'Data Driven Minimum Conversions' ;
    rdfs:comment 'For data-driven attribution models, the minimum number of conversions required in the training dataset for the model to be statistically valid. Null for rule-based models.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataDrivenMinimumPaths rdf:type rdf:Property ;
    rdfs:label 'Data Driven Minimum Paths' ;
    rdfs:comment 'For data-driven attribution models, the minimum number of unique customer journey paths required in the training dataset for the model to be statistically valid. Null for rule-based models.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataDrivenTrainingEndDate rdf:type rdf:Property ;
    rdfs:label 'Data Driven Training End Date' ;
    rdfs:comment 'For data-driven attribution models, the end date of the historical data period used to train the machine learning model. Null for rule-based models.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataDrivenTrainingStartDate rdf:type rdf:Property ;
    rdfs:label 'Data Driven Training Start Date' ;
    rdfs:comment 'For data-driven attribution models, the start date of the historical data period used to train the machine learning model. Null for rule-based models.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Short alphanumeric code or identifier for the attribution model used in reporting and system integration.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'The type of attribution methodology applied: last-click (100% credit to final touchpoint), first-click (100% credit to initial touchpoint), linear (equal credit across all touchpoints), time-decay (exponentially increasing credit toward conversion), position-based (U-shaped: 40% first, 40% last, 20% distributed), or data-driven (algorithmic/machine-learning-based credit distribution).' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionBasedFirstTouchWeight rdf:type rdf:Property ;
    rdfs:label 'Position Based First Touch Weight' ;
    rdfs:comment 'For position-based (U-shaped) attribution models, the fractional credit weight assigned to the first touchpoint (e.g., 0.4000 for 40%). Null for non-position-based models.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionBasedLastTouchWeight rdf:type rdf:Property ;
    rdfs:label 'Position Based Last Touch Weight' ;
    rdfs:comment 'For position-based (U-shaped) attribution models, the fractional credit weight assigned to the last touchpoint (e.g., 0.4000 for 40%). Null for non-position-based models.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionBasedMiddleTouchWeight rdf:type rdf:Property ;
    rdfs:label 'Position Based Middle Touch Weight' ;
    rdfs:comment 'For position-based (U-shaped) attribution models, the fractional credit weight distributed equally among all middle touchpoints (e.g., 0.2000 for 20% total). Null for non-position-based models.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reprocessingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reprocessing Required Flag' ;
    rdfs:comment 'Indicates whether historical conversion events within the attribution window need to be reprocessed due to changes in this model configuration.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reprocessingStartDate rdf:type rdf:Property ;
    rdfs:label 'Reprocessing Start Date' ;
    rdfs:comment 'The earliest date from which historical conversion events should be reprocessed when model configuration changes. Null if no reprocessing is required.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeDecayHalfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Time Decay Half Life Days' ;
    rdfs:comment 'For time-decay attribution models, the number of days at which a touchpoint receives half the credit of the most recent touchpoint. Defines the exponential decay rate. Null for non-time-decay models.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewThroughWindowDays rdf:type rdf:Property ;
    rdfs:label 'View Through Window Days' ;
    rdfs:comment 'Number of days after an impression (view) during which a conversion can be attributed to that impression event, even without a click. Standard values range from 1 to 30 days.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSafetySignalId rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Signal Id' ;
    rdfs:comment 'Unique identifier for the brand safety signal record. Primary key.' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advertiserPolicyId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Policy Id' ;
    rdfs:comment 'Reference to the specific advertiser brand safety policy or ruleset that was applied to evaluate this signal.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdvertiserPolicy .

ind:adjacencyRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Adjacency Risk Level' ;
    rdfs:comment 'Overall adjacency risk level summarizing the brand safety assessment (None = no risk, Low/Medium/High = increasing risk levels, Critical = severe brand risk).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adultContentFlag rdf:type rdf:Property ;
    rdfs:label 'Adult Content Flag' ;
    rdfs:comment 'Boolean flag indicating whether adult or sexually explicit content was detected on the page (True = adult content detected, False = no adult content).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingAction rdf:type rdf:Property ;
    rdfs:label 'Blocking Action' ;
    rdfs:comment 'Action taken based on the brand safety evaluation (Allowed = impression served, Blocked = impression prevented, Flagged = marked for review, Reviewed = manual review completed).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Detailed explanation of why the impression was blocked or flagged, including specific policy violations or risk factors identified.' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyScore rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Score' ;
    rdfs:comment 'Numerical brand safety score assigned by the vendor, typically ranging from 0-100 where higher scores indicate safer content for brand adjacency.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentUrl rdf:type rdf:Property ;
    rdfs:label 'Content Url' ;
    rdfs:comment 'The URL of the web page or content where the ad was served and evaluated for brand safety.' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:garmBrandSafetyFloor rdf:type rdf:Property ;
    rdfs:label 'Garm Brand Safety Floor' ;
    rdfs:comment 'GARM Brand Safety Floor classification indicating the minimum acceptable brand safety standard (Floor = universally acceptable, Low/Medium/High Risk = increasing levels of brand risk).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:garmSuitabilityTier rdf:type rdf:Property ;
    rdfs:label 'Garm Suitability Tier' ;
    rdfs:comment 'GARM Brand Suitability tier classification (Tier 1 = most restrictive/brand-safe, Tier 4 = least restrictive/broader content acceptance).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code where the impression was served (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hateSpeechFlag rdf:type rdf:Property ;
    rdfs:label 'Hate Speech Flag' ;
    rdfs:comment 'Boolean flag indicating whether hate speech, discriminatory language, or extremist content was detected (True = hate speech detected, False = no hate speech).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iabSubcategory rdf:type rdf:Property ;
    rdfs:label 'Iab Subcategory' ;
    rdfs:comment 'Detailed subcategory classification within the IAB Content Taxonomy (e.g., IAB1-1 Books & Literature, IAB3-1 Advertising).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:illegalContentFlag rdf:type rdf:Property ;
    rdfs:label 'Illegal Content Flag' ;
    rdfs:comment 'Boolean flag indicating whether illegal activities, drugs, or other unlawful content was detected (True = illegal content detected, False = no illegal content).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:misinformationFlag rdf:type rdf:Property ;
    rdfs:label 'Misinformation Flag' ;
    rdfs:comment 'Boolean flag indicating whether misinformation, disinformation, or fake news content was detected (True = misinformation detected, False = no misinformation).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piracyFlag rdf:type rdf:Property ;
    rdfs:label 'Piracy Flag' ;
    rdfs:comment 'Boolean flag indicating whether copyright infringement or pirated content was detected (True = piracy detected, False = no piracy).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preBidSignalFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Bid Signal Flag' ;
    rdfs:comment 'Boolean flag indicating whether this signal was captured during pre-bid filtering (True) or post-impression verification (False).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signal Timestamp' ;
    rdfs:comment 'The exact date and time when the brand safety signal was captured and evaluated, representing the real-world event time of the brand safety check.' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spamFlag rdf:type rdf:Property ;
    rdfs:label 'Spam Flag' ;
    rdfs:comment 'Boolean flag indicating whether spam, malware, or fraudulent content was detected (True = spam detected, False = no spam).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terrorismFlag rdf:type rdf:Property ;
    rdfs:label 'Terrorism Flag' ;
    rdfs:comment 'Boolean flag indicating whether terrorism-related content or extremist propaganda was detected (True = terrorism content detected, False = no terrorism content).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorSignalCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Signal Code' ;
    rdfs:comment 'Unique identifier assigned by the brand safety vendor to this specific signal record, used for reconciliation and troubleshooting.' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityRate rdf:type rdf:Property ;
    rdfs:label 'Viewability Rate' ;
    rdfs:comment 'Percentage of the ad that was viewable according to MRC standards, expressed as a value between 0 and 100.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Viewability Status' ;
    rdfs:comment 'Indicates whether the impression met MRC viewability standards (Viewable = met standard, Non-Viewable = did not meet standard, Unmeasurable = could not be measured).' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violenceFlag rdf:type rdf:Property ;
    rdfs:label 'Violence Flag' ;
    rdfs:comment 'Boolean flag indicating whether violent, graphic, or disturbing content was detected (True = violence detected, False = no violence).' ;
    rdfs:domain ind:BrandSafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Identifier for the user session during which the click occurred. Enables session-level analysis and multi-touch attribution within a single browsing session.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Session .

ind:adServerName rdf:type rdf:Property ;
    rdfs:label 'Ad Server Name' ;
    rdfs:comment 'The name or identifier of the ad server that recorded and tracked this click event (e.g., Google Campaign Manager 360, Sizmek, Flashtalking). Used for data reconciliation and discrepancy analysis.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWindowHours rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Hours' ;
    rdfs:comment 'The number of hours after the click during which a conversion can be attributed to this click event. Typically set at campaign or advertiser level (e.g., 24, 72, 168 hours).' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickFraudScore rdf:type rdf:Property ;
    rdfs:label 'Click Fraud Score' ;
    rdfs:comment 'Numeric fraud risk score assigned by the invalid traffic detection system, typically ranging from 0 (legitimate) to 100 (high fraud risk). Used for sophisticated IVT filtering and billing dispute resolution.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clickInteractionType rdf:type rdf:Property ;
    rdfs:label 'Click Interaction Type' ;
    rdfs:comment 'The type of user interaction that triggered the click event. Distinguishes between standard clicks, video overlay clicks, expandable ad interactions, and mobile gestures. [ENUM-REF-CANDIDATE: standard_click|call_to_action|video_overlay|expandable_panel|swipe|tap|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Click Latency Ms' ;
    rdfs:comment 'Time elapsed in milliseconds between the impression render and the click event. Used to detect rapid-fire bot clicks and analyze user engagement timing patterns.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickPositionX rdf:type rdf:Property ;
    rdfs:label 'Click Position X' ;
    rdfs:comment 'Horizontal pixel coordinate of the click within the ad unit. Used for heatmap analysis and creative engagement optimization.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickPositionY rdf:type rdf:Property ;
    rdfs:label 'Click Position Y' ;
    rdfs:comment 'Vertical pixel coordinate of the click within the ad unit. Used for heatmap analysis and creative engagement optimization.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickRedirectUrl rdf:type rdf:Property ;
    rdfs:label 'Click Redirect Url' ;
    rdfs:comment 'The destination URL to which the user was redirected after clicking the ad. May include tracking parameters, campaign identifiers, and attribution tokens.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickSourcePlatform rdf:type rdf:Property ;
    rdfs:label 'Click Source Platform' ;
    rdfs:comment 'The platform or channel through which the click was delivered. Distinguishes between web, mobile app, connected TV (CTV), digital out-of-home (DOOH), and other channels. [ENUM-REF-CANDIDATE: web|mobile_web|mobile_app|ctv|dooh|email|social|search|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Click Timestamp' ;
    rdfs:comment 'Precise date and time when the user clicked the ad unit, captured in UTC. Primary business event timestamp for click-through rate (CTR) calculation and time-series analysis.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clickValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Click Validation Status' ;
    rdfs:comment 'Validation status indicating whether the click is considered legitimate traffic or flagged as invalid per TAG (Trustworthy Accountability Group) and MRC (Media Rating Council) invalid traffic (IVT) detection standards. Determines billability for cost-per-click (CPC) campaigns. [ENUM-REF-CANDIDATE: valid|invalid_bot|invalid_duplicate|invalid_fraud|invalid_datacenter|suspicious|pending_validation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionAttributedFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Attributed Flag' ;
    rdfs:comment 'Boolean flag indicating whether this click event was later attributed to a conversion event within the attribution window. Used for click-to-conversion analysis and return on ad spend (ROAS) calculation.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpcRate rdf:type rdf:Property ;
    rdfs:label 'Cpc Rate' ;
    rdfs:comment 'The contracted cost per click rate for this event in the campaign currency. Used to calculate click-level revenue and cost-per-acquisition (CPA) metrics.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Hashed or anonymized device identifier derived from browser characteristics, IP address, user agent, and other signals. Used for fraud detection, frequency capping, and cross-session attribution without relying on cookies.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ivtDetectionMethod rdf:type rdf:Property ;
    rdfs:label 'Ivt Detection Method' ;
    rdfs:comment 'The method or layer at which invalid traffic detection was applied: general IVT (GIVT) for automated bot detection, sophisticated IVT (SIVT) for advanced fraud analysis, or manual review.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this click event record was last modified or enriched (e.g., validation status updated, conversion attribution applied). Used for change tracking and data quality monitoring.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'The URL of the page or application context where the ad was displayed and clicked. Used for contextual analysis and publisher verification.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingPixelFiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tracking Pixel Fired Flag' ;
    rdfs:comment 'Boolean flag indicating whether the click tracking pixel successfully fired and recorded the event. Used for data quality validation and discrepancy troubleshooting.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attributionType rdf:type rdf:Property ;
    rdfs:label 'Attribution Type' ;
    rdfs:comment 'Indicates whether this conversion was attributed to a click-through or view-through interaction.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionCurrency rdf:type rdf:Property ;
    rdfs:label 'Conversion Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the conversion value (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionName rdf:type rdf:Property ;
    rdfs:label 'Conversion Name' ;
    rdfs:comment 'Human-readable name or label for the specific conversion action as defined by the advertiser (e.g., \'Product Purchase\', \'Newsletter Signup\', \'Demo Request\').' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionPageUrl rdf:type rdf:Property ;
    rdfs:label 'Conversion Page Url' ;
    rdfs:comment 'The URL of the advertiser page where the conversion action was completed.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionQuantity rdf:type rdf:Property ;
    rdfs:label 'Conversion Quantity' ;
    rdfs:comment 'The number of units or items involved in the conversion (e.g., number of products purchased, number of form submissions).' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'The validation status of the conversion event (e.g., confirmed, pending verification, rejected, flagged as fraud).' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'The exact date and time when the conversion action occurred on the advertiser property. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'The category of conversion action that occurred (e.g., purchase, sign-up, form fill, app install, lead generation, download).' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionValue rdf:type rdf:Property ;
    rdfs:label 'Conversion Value' ;
    rdfs:comment 'The monetary value associated with this conversion event (e.g., purchase amount, estimated lead value). Used to calculate ROAS (Return on Ad Spend).' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deduplicationKey rdf:type rdf:Property ;
    rdfs:label 'Deduplication Key' ;
    rdfs:comment 'Unique key used to prevent duplicate counting of the same conversion event across multiple tracking sources or attribution models.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'A numeric score (0-100) indicating the likelihood that this conversion is fraudulent, as determined by fraud detection systems.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoCity rdf:type rdf:Property ;
    rdfs:label 'Geo City' ;
    rdfs:comment 'City where the conversion occurred, derived from IP geolocation.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountry rdf:type rdf:Property ;
    rdfs:label 'Geo Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the conversion occurred (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRegion rdf:type rdf:Property ;
    rdfs:label 'Geo Region' ;
    rdfs:comment 'State, province, or region where the conversion occurred (e.g., California, Ontario, Bavaria).' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDuplicate rdf:type rdf:Property ;
    rdfs:label 'Is Duplicate' ;
    rdfs:comment 'Flag indicating whether this conversion event was identified as a duplicate and excluded from reporting (True/False).' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderReference rdf:type rdf:Property ;
    rdfs:label 'Order Reference' ;
    rdfs:comment 'The advertiser\'s internal order or transaction identifier associated with this conversion (e.g., e-commerce order number).' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioLineId rdf:type rdf:Property ;
    rdfs:label 'Io Line Id' ;
    rdfs:comment 'Foreign key linking to vendor.vendor_io_line. Business justification: Pacing monitors delivery against contracted IO line commitments. Required for under-delivery alerts, budget reallocation decisions, vendor delivery performance tracking, and triggering makegood clause' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IoLine .

ind:actualImpressions rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions' ;
    rdfs:comment 'The actual number of impressions delivered during this pacing period as reported by the ad server or demand-side platform (DSP).' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'The actual spend amount incurred during this pacing period as reported by the billing system or DSP.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertSeverity rdf:type rdf:Property ;
    rdfs:label 'Alert Severity' ;
    rdfs:comment 'The severity level of the pacing alert if triggered. None means no alert, low/medium/high/critical indicate escalating levels of deviation requiring intervention.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidWinRate rdf:type rdf:Property ;
    rdfs:label 'Bid Win Rate' ;
    rdfs:comment 'For programmatic campaigns, the percentage of bid requests that resulted in won auctions during this pacing period. Low win rates may indicate bid prices are too low.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clickThroughRate rdf:type rdf:Property ;
    rdfs:label 'Click Through Rate' ;
    rdfs:comment 'The percentage of impressions that resulted in clicks during this pacing period, calculated as (clicks / impressions) * 100. Key performance indicator for engagement.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionCount rdf:type rdf:Property ;
    rdfs:label 'Conversion Count' ;
    rdfs:comment 'The total number of conversions attributed to this line item or placement during the pacing period, based on conversion tracking pixels and attribution models.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveCpa rdf:type rdf:Property ;
    rdfs:label 'Effective Cpa' ;
    rdfs:comment 'The effective cost per conversion for this pacing period, calculated as actual_spend_amount / conversion_count. Key metric for performance-based campaigns.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveCpm rdf:type rdf:Property ;
    rdfs:label 'Effective Cpm' ;
    rdfs:comment 'The effective cost per thousand impressions for this pacing period, calculated as (actual_spend_amount / actual_impressions) * 1000. Used to evaluate media efficiency.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyCapReached rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Reached' ;
    rdfs:comment 'Boolean flag indicating whether the frequency cap has been reached for this line item during the pacing period, which may impact delivery velocity.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impressionPacingPercentage rdf:type rdf:Property ;
    rdfs:label 'Impression Pacing Percentage' ;
    rdfs:comment 'The percentage of planned impressions that have been delivered, calculated as (actual_impressions / planned_impressions) * 100. Values above 100 indicate over-delivery.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryAvailabilityScore rdf:type rdf:Property ;
    rdfs:label 'Inventory Availability Score' ;
    rdfs:comment 'A score (0-100) representing the availability of ad inventory matching the targeting criteria during this pacing period. Low scores may explain under-delivery.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The exact timestamp when this pacing measurement was captured from the source system. Critical for understanding data freshness and real-time vs near-real-time reporting.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pacingAlertTriggered rdf:type rdf:Property ;
    rdfs:label 'Pacing Alert Triggered' ;
    rdfs:comment 'Boolean flag indicating whether an automated pacing alert was triggered for this period due to significant variance from plan, requiring campaign manager attention.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pacingGranularity rdf:type rdf:Property ;
    rdfs:label 'Pacing Granularity' ;
    rdfs:comment 'The time granularity at which pacing is measured and reported. Hourly for real-time optimization, daily for standard monitoring, weekly for longer flights, or flight for entire campaign duration.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pacingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Pacing Period End' ;
    rdfs:comment 'The end timestamp of the pacing measurement period. Defines the conclusion of the window for which delivery progress is being measured.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pacingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Pacing Period Start' ;
    rdfs:comment 'The start timestamp of the pacing measurement period. Defines the beginning of the window for which delivery progress is being measured.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pacingVarianceThreshold rdf:type rdf:Property ;
    rdfs:label 'Pacing Variance Threshold' ;
    rdfs:comment 'The acceptable variance threshold percentage used to determine pacing status. If actual pacing percentage deviates from 100% by more than this threshold, status changes from on-pace to under/over-delivering.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Spend Amount' ;
    rdfs:comment 'The target spend amount planned for this pacing period based on the media budget allocation and flight schedule.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Platform-assigned quality score (typically 0-10 scale) reflecting ad relevance, landing page experience, and expected CTR. Higher scores improve auction competitiveness.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedBidAdjustment rdf:type rdf:Property ;
    rdfs:label 'Recommended Bid Adjustment' ;
    rdfs:comment 'System-generated recommendation for bid adjustment to correct pacing issues. Positive values suggest increasing bids to accelerate delivery, negative values suggest decreasing bids to slow delivery.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedBudgetAdjustment rdf:type rdf:Property ;
    rdfs:label 'Recommended Budget Adjustment' ;
    rdfs:comment 'System-generated recommendation for budget adjustment to correct pacing issues. Positive values suggest increasing budget allocation, negative values suggest reducing budget allocation.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendPacingPercentage rdf:type rdf:Property ;
    rdfs:label 'Spend Pacing Percentage' ;
    rdfs:comment 'The percentage of planned spend that has been consumed, calculated as (actual_spend_amount / planned_spend_amount) * 100. Values above 100 indicate over-spend.' ;
    rdfs:domain ind:DeliveryPacing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adPosition rdf:type rdf:Property ;
    rdfs:label 'Ad Position' ;
    rdfs:comment 'The position of the ad unit on the page or within the app. Indicates placement prominence and impacts viewability and engagement rates. [ENUM-REF-CANDIDATE: above_the_fold|below_the_fold|header|footer|sidebar|in_content|interstitial|overlay — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adServerSource rdf:type rdf:Property ;
    rdfs:label 'Ad Server Source' ;
    rdfs:comment 'The ad serving platform or demand-side platform (DSP) that recorded and delivered this impression. Identifies the operational system of record for this event.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adSize rdf:type rdf:Property ;
    rdfs:label 'Ad Size' ;
    rdfs:comment 'The pixel dimensions of the ad creative served (e.g., 300x250, 728x90, 1920x1080). Used for format performance analysis and creative optimization.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auctionId rdf:type rdf:Property ;
    rdfs:label 'Auction Id' ;
    rdfs:comment 'The unique identifier for the programmatic auction in which this impression was won. Used for RTB (Real-Time Bidding) analysis, bid landscape reconstruction, and supply-path optimization.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceSegmentIds rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Ids' ;
    rdfs:comment 'Comma-separated list of audience segment IDs that the user matched at impression time. Links to audience taxonomy from DMP (Data Management Platform) or CDP (Customer Data Platform). Used for audience targeting validation and performance analysis.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidPriceCpm rdf:type rdf:Property ;
    rdfs:label 'Bid Price Cpm' ;
    rdfs:comment 'The winning bid price for this impression expressed in CPM (Cost Per Mille / cost per thousand impressions). Represents the clearing price in the programmatic auction. Used for media cost analysis and ROAS calculation.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'The name and version of the source system that generated this impression event record. Used for data lineage tracking and cross-system reconciliation.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCapCount rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Count' ;
    rdfs:comment 'The number of times this user has been exposed to this campaign or creative prior to this impression. Used for frequency capping enforcement and ad fatigue analysis.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geoPostalCode rdf:type rdf:Property ;
    rdfs:label 'Geo Postal Code' ;
    rdfs:comment 'The postal or ZIP code where the impression was delivered. Supports neighborhood-level targeting and local market analysis.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Impression Timestamp' ;
    rdfs:comment 'Exact date and time when the ad impression was served to the end user. Represents the real-world event time of ad delivery. Critical for time-series analysis, dayparting optimization, and billing reconciliation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impressionType rdf:type rdf:Property ;
    rdfs:label 'Impression Type' ;
    rdfs:comment 'The format or modality of the ad impression served. Distinguishes between display banners, video ads, native content, audio spots, and rich media executions.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'The timestamp when this impression event record was ingested into the lakehouse silver layer. Used for data freshness monitoring and ETL (Extract Transform Load) pipeline auditing. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAutoplay rdf:type rdf:Property ;
    rdfs:label 'Is Autoplay' ;
    rdfs:comment 'Boolean flag indicating whether the video ad started playing automatically without user initiation. Applicable to video impressions. Impacts user experience and engagement metrics.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBotTraffic rdf:type rdf:Property ;
    rdfs:label 'Is Bot Traffic' ;
    rdfs:comment 'Boolean flag indicating whether the impression was identified as non-human bot traffic. Used for invalid traffic (IVT) filtering and billing adjustment.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMuted rdf:type rdf:Property ;
    rdfs:label 'Is Muted' ;
    rdfs:comment 'Boolean flag indicating whether the video or audio ad was muted at the time of impression. Applicable to video and audio impression types. Impacts engagement and completion rates.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaCost rdf:type rdf:Property ;
    rdfs:label 'Media Cost' ;
    rdfs:comment 'The actual media cost incurred for this single impression. Calculated from the bid price or rate card. Used for billing reconciliation, budget tracking, and ROI (Return on Investment) analysis.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteDomain rdf:type rdf:Property ;
    rdfs:label 'Site Domain' ;
    rdfs:comment 'The domain name of the website or app where the impression was served. Used for brand safety analysis, contextual targeting validation, and publisher performance tracking.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainObject rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Object' ;
    rdfs:comment 'The sellers.json or SupplyChain object captured at impression time, identifying all intermediaries in the programmatic supply chain. Used for supply-path transparency and optimization per IAB ads.txt and sellers.json standards.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeInViewSeconds rdf:type rdf:Property ;
    rdfs:label 'Time In View Seconds' ;
    rdfs:comment 'The total duration in seconds that the impression was visible in the users viewport. Critical metric for engagement analysis and viewability quality assessment.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Video Duration Seconds' ;
    rdfs:comment 'The total duration of the video ad creative in seconds. Applicable only to video impression types. Used for video completion rate analysis and engagement measurement.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoPlayerSize rdf:type rdf:Property ;
    rdfs:label 'Video Player Size' ;
    rdfs:comment 'The size category of the video player at impression time. Applicable to video impressions. Impacts viewability and user engagement.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Viewability Percentage' ;
    rdfs:comment 'The percentage of the ad creative that was visible in the viewport at the time of measurement. Ranges from 0.00 to 100.00. Used for granular viewability analysis and quality scoring.' ;
    rdfs:domain ind:ImpressionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ivtClassificationId rdf:type rdf:Property ;
    rdfs:label 'Ivt Classification Id' ;
    rdfs:comment 'Unique identifier for the IVT classification record. Primary key for the IVT classification entity.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealNotes rdf:type rdf:Property ;
    rdfs:label 'Appeal Notes' ;
    rdfs:comment 'Free-text notes documenting the rationale for appeal or dispute resolution outcome. Used for audit trails and process improvement.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Status of any appeal filed by the media vendor disputing the IVT classification. Tracks dispute resolution process.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:behavioralAnomalyScore rdf:type rdf:Property ;
    rdfs:label 'Behavioral Anomaly Score' ;
    rdfs:comment 'Score indicating deviation from normal user behavior patterns (e.g., click speed, navigation patterns, session duration). Higher scores indicate higher SIVT likelihood.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:botSignatureMatch rdf:type rdf:Property ;
    rdfs:label 'Bot Signature Match' ;
    rdfs:comment 'Indicates whether the user agent or behavior matched a known bot signature from IAB/ABC International Spiders and Bots List.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Eligible Flag' ;
    rdfs:comment 'Indicates whether this IVT event qualifies for vendor chargeback per contract terms. Depends on IVT category, detection timing, and service level agreement.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackStatus rdf:type rdf:Property ;
    rdfs:label 'Chargeback Status' ;
    rdfs:comment 'Current status of the chargeback request for this IVT event. Tracks the chargeback lifecycle from identification through payment. [ENUM-REF-CANDIDATE: pending|submitted|approved|rejected|paid|disputed|not_eligible — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Classification Timestamp' ;
    rdfs:comment 'Timestamp when the IVT classification was performed. May differ from event timestamp for post-campaign analysis or re-classification.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataCenterFlag rdf:type rdf:Property ;
    rdfs:label 'Data Center Flag' ;
    rdfs:comment 'Indicates whether the event originated from a known data center IP range. Data center traffic is classified as GIVT per MRC standards.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Technical method used to detect invalid traffic. Informs confidence level and appeals process for disputed IVT classifications. [ENUM-REF-CANDIDATE: rule_based|machine_learning|behavioral_analysis|device_fingerprinting|ip_reputation|user_agent_analysis|hybrid — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventReference rdf:type rdf:Property ;
    rdfs:label 'Event Reference' ;
    rdfs:comment 'Unique identifier of the impression or click event being classified for invalid traffic. Links to the raw delivery event log.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicAnomalyFlag rdf:type rdf:Property ;
    rdfs:label 'Geographic Anomaly Flag' ;
    rdfs:comment 'Indicates whether the event originated from a geographic location inconsistent with campaign targeting or user profile. Common SIVT signal.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invalidClickCount rdf:type rdf:Property ;
    rdfs:label 'Invalid Click Count' ;
    rdfs:comment 'Number of clicks classified as invalid for this event record. Used for click fraud analysis and CPC chargeback calculations.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invalidImpressionCount rdf:type rdf:Property ;
    rdfs:label 'Invalid Impression Count' ;
    rdfs:comment 'Number of impressions classified as invalid for this event record. Typically 1 for event-level records; may be aggregated for batch classifications.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invalidSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Invalid Spend Amount' ;
    rdfs:comment 'Monetary value of media spend attributed to this invalid traffic event. Used for financial reconciliation and vendor chargebacks.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ivtCategory rdf:type rdf:Property ;
    rdfs:label 'Ivt Category' ;
    rdfs:comment 'High-level category of invalid traffic classification per MRC standards. GIVT = General Invalid Traffic (routine filtration); SIVT = Sophisticated Invalid Traffic (advanced analysis required); Valid = legitimate traffic.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ivtDetectionSource rdf:type rdf:Property ;
    rdfs:label 'Ivt Detection Source' ;
    rdfs:comment 'Source system or vendor that performed the IVT classification. TAG certified vendors carry higher audit credibility for MRC compliance.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ivtFlag rdf:type rdf:Property ;
    rdfs:label 'Ivt Flag' ;
    rdfs:comment 'Boolean indicator of whether the event was classified as invalid traffic. True indicates IVT detected; False indicates valid traffic.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ivtType rdf:type rdf:Property ;
    rdfs:label 'Ivt Type' ;
    rdfs:comment 'Specific type of invalid traffic detected. Provides granular classification for fraud analysis, vendor disputes, and MRC compliance reporting. [ENUM-REF-CANDIDATE: bot_traffic|data_center_traffic|hijacked_device|adware|click_farm|cookie_stuffing|domain_spoofing|hidden_ads|incentivized_traffic|malware|proxy_traffic|automated_browsing|none — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrcCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Mrc Compliant Flag' ;
    rdfs:comment 'Indicates whether the IVT detection and classification process followed MRC accredited standards. Required for audited campaign reporting.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tagCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Tag Certified Flag' ;
    rdfs:comment 'Indicates whether the IVT detection was performed by a TAG Certified Against Fraud vendor. TAG certification provides industry-recognized fraud prevention assurance.' ;
    rdfs:domain ind:IvtClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementDiscrepancyId rdf:type rdf:Property ;
    rdfs:label 'Measurement Discrepancy Id' ;
    rdfs:comment 'Unique identifier for the measurement discrepancy record. Primary key for the measurement discrepancy entity.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorContactId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Id' ;
    rdfs:comment 'Foreign key linking to vendor.vendor_contact. Business justification: Discrepancy resolution requires tracking which vendor contact is handling investigation. Essential for SLA adherence tracking, escalation management, response time measurement, and maintaining audit t' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContact .

ind:affectedDateEnd rdf:type rdf:Property ;
    rdfs:label 'Affected Date End' ;
    rdfs:comment 'End date of the delivery data range affected by this discrepancy. Defines the conclusion of the time window where measurement variance or data quality issues occurred.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedDateStart rdf:type rdf:Property ;
    rdfs:label 'Affected Date Start' ;
    rdfs:comment 'Start date of the delivery data range affected by this discrepancy. Defines the beginning of the time window where measurement variance or data quality issues occurred.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataQualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Data Quality Check Status' ;
    rdfs:comment 'Result status of the automated data quality validation. Passed indicates data met quality criteria. Failed indicates data did not meet criteria and requires remediation. Warning indicates potential issue requiring review. Skipped indicates check was not executed.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityCheckType rdf:type rdf:Property ;
    rdfs:label 'Data Quality Check Type' ;
    rdfs:comment 'For data quality check discrepancies, specifies the type of automated validation that failed. Completeness checks for missing required fields. Consistency checks for logical contradictions. Deduplication checks for duplicate events. Latency checks for delayed data arrival. Schema validation checks for structural conformance. Referential integrity checks for orphaned records.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualitySeverity rdf:type rdf:Property ;
    rdfs:label 'Data Quality Severity' ;
    rdfs:comment 'Severity classification of the data quality issue. Critical indicates data unusable for billing or reporting. High indicates significant impact on accuracy. Medium indicates moderate impact requiring attention. Low indicates minor issue with minimal business impact.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Count' ;
    rdfs:comment 'Absolute difference between primary and secondary counts. Calculated as primary_count minus secondary_count. Positive values indicate over-delivery by secondary source; negative values indicate under-delivery.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyPercentage rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Percentage' ;
    rdfs:comment 'Percentage variance between primary and secondary counts. Calculated as (discrepancy_count / primary_count) * 100. Used to assess materiality against MRC 10 percent threshold.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyStatus rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Status' ;
    rdfs:comment 'Current lifecycle status of the discrepancy investigation and resolution workflow. Open indicates newly detected. Under investigation indicates active analysis. Resolved indicates root cause identified and remediation applied. Closed indicates final disposition complete. Escalated indicates elevated to senior management or vendor. Pending vendor indicates awaiting external party response.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the discrepancy. Count variance represents differences between ad server and vendor reported metrics. Data quality check represents automated validation failures. Latency issue represents delayed data delivery. Schema validation represents structural data problems. Deduplication represents duplicate event detection. Completeness check represents missing data detection.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Monetary value of the discrepancy impact in the media buy currency. Calculated based on the discrepancy count multiplied by the contracted CPM, CPC, or CPA rate. Represents the dollar value at stake requiring financial resolution.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialResolutionType rdf:type rdf:Property ;
    rdfs:label 'Financial Resolution Type' ;
    rdfs:comment 'Classification of the financial remedy applied to compensate for the measurement discrepancy. Credit represents monetary refund from vendor. Makegood represents additional ad delivery at no cost. Write-off represents agency absorbing the variance. No adjustment represents variance accepted within tolerance. Pending represents resolution not yet determined.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationAssignedTo rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned To' ;
    rdfs:comment 'Name or identifier of the individual or team assigned to investigate and resolve the discrepancy. Typically a media operations analyst, data quality engineer, or account manager.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Timestamp' ;
    rdfs:comment 'Date and time when formal investigation of the discrepancy began. Marks the transition from detection to active analysis.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mrcThresholdBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Mrc Threshold Breach Flag' ;
    rdfs:comment 'Boolean indicator whether the discrepancy percentage exceeds the MRC 10 percent materiality threshold. True indicates breach requiring formal investigation and potential financial adjustment. False indicates variance within acceptable tolerance.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryCount rdf:type rdf:Property ;
    rdfs:label 'Primary Count' ;
    rdfs:comment 'The metric count reported by the primary source system (ad server of record). Represents the baseline measurement for discrepancy calculation.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationActionTaken rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Taken' ;
    rdfs:comment 'Description of the corrective action applied to resolve the discrepancy or data quality issue. Documents data reprocessing, manual adjustments, system configuration changes, vendor notifications, or process improvements implemented.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the discrepancy was resolved and remediation action completed. Marks the conclusion of the investigation and correction workflow.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Classification of the identified or suspected root cause of the discrepancy. Tag latency represents delayed pixel firing. Filtering methodology represents different data cleansing rules. Timezone mismatch represents reporting period alignment issues. IVT filtering delta represents invalid traffic detection differences. Ad blocking represents client-side blocking. Viewability criteria represents MRC viewability standard interpretation differences. Attribution window represents conversion lookback period differences. Sampling methodology represents statistical sampling variance. Technical error represents system malfunction. Unknown represents unresolved cause. [ENUM-REF-CANDIDATE: tag_latency|filtering_methodology|timezone_mismatch|ivt_filtering_delta|ad_blocking|viewability_criteria|attribution_window|sampling_methodology|technical_error|unknown — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative explanation of the root cause analysis findings. Documents the investigation process, evidence reviewed, technical factors identified, and conclusion reached regarding why the discrepancy occurred.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryCount rdf:type rdf:Property ;
    rdfs:label 'Secondary Count' ;
    rdfs:comment 'The metric count reported by the secondary source system (vendor or publisher). Represents the comparison measurement for discrepancy calculation.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Boolean indicator whether the discrepancy represents a breach of contractual service level agreement for data quality, delivery accuracy, or reporting timeliness. True indicates SLA breach requiring escalation. False indicates within SLA tolerance.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemPrimary rdf:type rdf:Property ;
    rdfs:label 'Source System Primary' ;
    rdfs:comment 'Name of the primary measurement source system reporting the baseline count. Typically the ad server of record such as Google Campaign Manager 360 or The Trade Desk.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemSecondary rdf:type rdf:Property ;
    rdfs:label 'Source System Secondary' ;
    rdfs:comment 'Name of the secondary measurement source system reporting the comparison count. Typically the media vendor, publisher ad server, or third-party verification vendor such as Nielsen or Comscore.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Notification Sent Flag' ;
    rdfs:comment 'Boolean indicator whether the media vendor or publisher was formally notified of the discrepancy. True indicates notification sent. False indicates internal-only issue or notification not yet sent.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorResponseNotes rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Notes' ;
    rdfs:comment 'Free-text field capturing the vendor or publisher explanation, justification, or proposed resolution for the discrepancy. Documents external party perspective and commitments.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorResponseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Received Flag' ;
    rdfs:comment 'Boolean indicator whether the media vendor or publisher provided a formal response to the discrepancy notification. True indicates response received. False indicates no response or response pending.' ;
    rdfs:domain ind:MeasurementDiscrepancy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertEnabled rdf:type rdf:Property ;
    rdfs:label 'Alert Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automated alerts should be triggered when performance deviates from target thresholds. True = alerts active, False = monitoring only without alerts.' ;
    rdfs:domain ind:PerformanceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertFrequency rdf:type rdf:Property ;
    rdfs:label 'Alert Frequency' ;
    rdfs:comment 'Frequency at which performance is evaluated against thresholds and alerts are generated. Real-time for critical KPIs, daily or weekly for less time-sensitive metrics.' ;
    rdfs:domain ind:PerformanceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isContractualCommitment rdf:type rdf:Property ;
    rdfs:label 'Is Contractual Commitment' ;
    rdfs:comment 'Boolean flag indicating whether this KPI target represents a contractual commitment to the client (typically from Insertion Order or Statement of Work). True = contractual obligation, False = internal goal or aspiration.' ;
    rdfs:domain ind:PerformanceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerThreshold rdf:type rdf:Property ;
    rdfs:label 'Lower Threshold' ;
    rdfs:comment 'The minimum acceptable value for this KPI. Performance below this threshold triggers alerts or corrective actions. Calculated as target_value minus tolerance band or set explicitly.' ;
    rdfs:domain ind:PerformanceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Target Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for monetary KPI targets (CPM, CPC, CPA, ROAS). Nullable for non-monetary KPIs.' ;
    rdfs:domain ind:PerformanceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Target Period End Date' ;
    rdfs:comment 'The end date of the period for which this KPI target is applicable. Used for time-bound performance measurement and pacing analysis.' ;
    rdfs:domain ind:PerformanceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Period Start Date' ;
    rdfs:comment 'The start date of the period for which this KPI target is applicable. Used for time-bound performance measurement and pacing analysis.' ;
    rdfs:domain ind:PerformanceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetSource rdf:type rdf:Property ;
    rdfs:label 'Target Source' ;
    rdfs:comment 'The origin or basis for this KPI target. Insertion Order (IO) commitment represents contractual obligation, client brief represents client expectation, internal benchmark represents agency standard, historical average represents past performance baseline.' ;
    rdfs:domain ind:PerformanceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage' ;
    rdfs:comment 'Acceptable variance percentage from the target value before triggering alerts or escalations. For example, 10.00 means ±10% from target is acceptable. Used for pacing alerts and performance monitoring.' ;
    rdfs:domain ind:PerformanceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperThreshold rdf:type rdf:Property ;
    rdfs:label 'Upper Threshold' ;
    rdfs:comment 'The maximum acceptable value for this KPI (relevant for cost-based metrics where exceeding target is negative). Performance above this threshold triggers alerts. Calculated as target_value plus tolerance band or set explicitly.' ;
    rdfs:domain ind:PerformanceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtbBidEventId rdf:type rdf:Property ;
    rdfs:label 'Rtb Bid Event Id' ;
    rdfs:comment 'Unique identifier for the RTB bid event record. Primary key for the bid event entity.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appBundle rdf:type rdf:Property ;
    rdfs:label 'App Bundle' ;
    rdfs:comment 'The bundle or package name of the mobile application where the ad will be served (e.g., com.cnn.mobile.android). Null for web inventory.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appName rdf:type rdf:Property ;
    rdfs:label 'App Name' ;
    rdfs:comment 'Human-readable name of the mobile application (e.g., CNN Mobile App). Null for web inventory.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auctionCode rdf:type rdf:Property ;
    rdfs:label 'Auction Code' ;
    rdfs:comment 'Unique identifier for the programmatic auction instance. Multiple bid events may share the same auction ID when multiple DSPs participate.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidRequestReference rdf:type rdf:Property ;
    rdfs:label 'Bid Request Reference' ;
    rdfs:comment 'Unique identifier for the bid request received from the SSP or ad exchange. Links this bid event to the originating auction request.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Bid Response Time Ms' ;
    rdfs:comment 'Time taken by the DSP to respond to the bid request, measured in milliseconds. Critical for auction participation and timeout analysis.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bidStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Status' ;
    rdfs:comment 'Outcome status of the bid event indicating whether the bid won the auction, lost, was not submitted, timed out, or encountered an error.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidStrategy rdf:type rdf:Property ;
    rdfs:label 'Bid Strategy' ;
    rdfs:comment 'Name or identifier of the bidding strategy applied by the DSP (e.g., maximize conversions, target CPA, target ROAS, fixed CPM).' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Bid Timestamp' ;
    rdfs:comment 'Exact timestamp when the bid was submitted to the SSP or ad exchange. Represents the real-world event time of the bid participation.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clearingPriceCpm rdf:type rdf:Property ;
    rdfs:label 'Clearing Price Cpm' ;
    rdfs:comment 'The actual price paid for the impression if the bid won the auction, expressed in CPM. May be lower than bid price in second-price auctions. Null if bid lost.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:domain rdf:type rdf:Property ;
    rdfs:label 'Domain' ;
    rdfs:comment 'The domain of the website where the ad impression will be served (e.g., cnn.com, espn.com). Used for brand safety and supply path transparency.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorPriceCpm rdf:type rdf:Property ;
    rdfs:label 'Floor Price Cpm' ;
    rdfs:comment 'Minimum bid price set by the publisher or SSP for this impression, expressed in CPM. Bids below this floor are automatically rejected.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryType rdf:type rdf:Property ;
    rdfs:label 'Inventory Type' ;
    rdfs:comment 'Type of digital inventory being auctioned: web (desktop browser), mobile web, mobile app, CTV (Connected TV), or DOOH (Digital Out-of-Home).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sspName rdf:type rdf:Property ;
    rdfs:label 'Ssp Name' ;
    rdfs:comment 'Name of the SSP or ad exchange that sent the bid request and conducted the auction (e.g., Google Ad Manager, Magnite, PubMatic, OpenX).' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyPathCost rdf:type rdf:Property ;
    rdfs:label 'Supply Path Cost' ;
    rdfs:comment 'Total cost incurred through the supply path (SSP fees, exchange fees, reseller margins) expressed as a percentage or absolute amount. Used for supply path optimization (SPO) analysis.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:userIdHashed rdf:type rdf:Property ;
    rdfs:label 'User Id Hashed' ;
    rdfs:comment 'Hashed or anonymized user identifier passed by the SSP for frequency capping and audience targeting. Complies with privacy regulations (GDPR, CCPA).' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winIndicator rdf:type rdf:Property ;
    rdfs:label 'Win Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this bid won the auction (True) or lost (False). Derived from bid_status for simplified win rate analysis.' ;
    rdfs:domain ind:RtbBidEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:browserName rdf:type rdf:Property ;
    rdfs:label 'Browser Name' ;
    rdfs:comment 'Name of the web browser in which the pixel fired, parsed from the user agent string.' ;
    rdfs:domain ind:TrackingPixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Required Flag' ;
    rdfs:comment 'Indicates whether user consent is required before the pixel can fire, per privacy regulations.' ;
    rdfs:domain ind:TrackingPixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Conversion Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the conversion value.' ;
    rdfs:domain ind:TrackingPixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentEnvironment rdf:type rdf:Property ;
    rdfs:label 'Deployment Environment' ;
    rdfs:comment 'The digital environment or platform type where the pixel is implemented.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current operational status of the tracking pixel in the measurement infrastructure.' ;
    rdfs:domain ind:TrackingPixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Technical error code returned when a pixel fire fails, used for troubleshooting and data quality monitoring.' ;
    rdfs:domain ind:TrackingPixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireStatus rdf:type rdf:Property ;
    rdfs:label 'Fire Status' ;
    rdfs:comment 'Outcome status of the pixel fire attempt, indicating whether the tracking event was successfully recorded.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fire Timestamp' ;
    rdfs:comment 'Exact date and time when the pixel fire event occurred, representing the principal business event for this tracking record.' ;
    rdfs:domain ind:TrackingPixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:implementationMethod rdf:type rdf:Property ;
    rdfs:label 'Implementation Method' ;
    rdfs:comment 'Technical method used to deploy and fire the tracking pixel on the target property.' ;
    rdfs:domain ind:TrackingPixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddressHash rdf:type rdf:Property ;
    rdfs:label 'Ip Address Hash' ;
    rdfs:comment 'One-way cryptographic hash of the user IP address, stored for fraud detection and geographic analysis while maintaining GDPR compliance.' ;
    rdfs:domain ind:TrackingPixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pixelUrl rdf:type rdf:Property ;
    rdfs:label 'Pixel Url' ;
    rdfs:comment 'Full URL endpoint that the pixel fires to when triggered, including protocol and domain.' ;
    rdfs:domain ind:TrackingPixel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of the video that was viewed, calculated as (time_to_completion_seconds / video_duration_seconds) * 100. Supports VTR (View-Through Rate) calculation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionQuartile rdf:type rdf:Property ;
    rdfs:label 'Completion Quartile' ;
    rdfs:comment 'The quartile milestone reached in video playback: start (0%), first_quartile (25%), midpoint (50%), third_quartile (75%), or complete (100%). Used to calculate VTR (View-Through Rate) and engagement depth.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddressHashed rdf:type rdf:Property ;
    rdfs:label 'Ip Address Hashed' ;
    rdfs:comment 'Hashed IP address of the device that viewed the video ad. Used for fraud detection and geo-verification while maintaining privacy compliance.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFullscreen rdf:type rdf:Property ;
    rdfs:label 'Is Fullscreen' ;
    rdfs:comment 'Boolean flag indicating whether the video was playing in fullscreen mode at the time of the completion event (True) or in standard embedded player (False).' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSkipped rdf:type rdf:Property ;
    rdfs:label 'Is Skipped' ;
    rdfs:comment 'Boolean flag indicating whether the user actively skipped the video ad before completion (True) or allowed it to play through the recorded quartile (False).' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSoundOn rdf:type rdf:Property ;
    rdfs:label 'Is Sound On' ;
    rdfs:comment 'Boolean flag indicating whether the video ad played with sound enabled (True) or muted (False). Critical metric for video engagement quality and IO (Insertion Order) compliance.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isViewable rdf:type rdf:Property ;
    rdfs:label 'Is Viewable' ;
    rdfs:comment 'Boolean flag indicating whether the video ad met MRC (Media Rating Council) viewability standards at the time of the completion event: 50% of pixels in-view for 2+ consecutive seconds. Used for viewable VTR (View-Through Rate) calculation.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerHeightPixels rdf:type rdf:Property ;
    rdfs:label 'Player Height Pixels' ;
    rdfs:comment 'Height of the video player in pixels at the time of the completion event. Used for precise viewability and player size analysis.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerSize rdf:type rdf:Property ;
    rdfs:label 'Player Size' ;
    rdfs:comment 'Size classification of the video player at the time of the event: small (<400x300), medium (400x300 to 640x480), large (>640x480 but not fullscreen), or fullscreen. Impacts viewability measurement.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerWidthPixels rdf:type rdf:Property ;
    rdfs:label 'Player Width Pixels' ;
    rdfs:comment 'Width of the video player in pixels at the time of the completion event. Used for precise viewability and player size analysis.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skipOffsetSeconds rdf:type rdf:Property ;
    rdfs:label 'Skip Offset Seconds' ;
    rdfs:comment 'Number of seconds into the video when the skip button became available to the user. Null if video was non-skippable.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeToCompletionSeconds rdf:type rdf:Property ;
    rdfs:label 'Time To Completion Seconds' ;
    rdfs:comment 'Actual elapsed time in seconds from video start to the recorded completion quartile. May differ from video_duration_seconds if user paused, rewound, or fast-forwarded.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoFormat rdf:type rdf:Property ;
    rdfs:label 'Video Format' ;
    rdfs:comment 'Format type of the video ad: linear (pre-roll, mid-roll, post-roll that interrupts content), non_linear (overlay ads that run concurrently with content), or companion (static/rich media ads displayed alongside video).' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoPosition rdf:type rdf:Property ;
    rdfs:label 'Video Position' ;
    rdfs:comment 'Position of the video ad within the content stream: pre_roll (before content), mid_roll (during content), or post_roll (after content). Applies to linear video formats only.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewablePercentage rdf:type rdf:Property ;
    rdfs:label 'Viewable Percentage' ;
    rdfs:comment 'Percentage of the video player that was in the viewable area of the browser viewport at the time of the completion event. Used for granular viewability analysis beyond binary MRC threshold.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vpaidVersion rdf:type rdf:Property ;
    rdfs:label 'Vpaid Version' ;
    rdfs:comment 'Version of the VPAID (Video Player-Ad Interface Definition) specification used for interactive video ads (e.g., 1.0, 2.0). Null for standard VAST-only video ads.' ;
    rdfs:domain ind:VideoCompletionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audibleOnCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Audible On Complete Flag' ;
    rdfs:comment 'For video ads, indicates whether the ad was audible when the video completed. Supports audible and viewable measurement.' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandSafetyFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Flag' ;
    rdfs:comment 'Indicates whether the placement passed brand safety verification at the time of viewability measurement.' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environment rdf:type rdf:Property ;
    rdfs:label 'Environment' ;
    rdfs:comment 'The digital environment where the ad was served (web browser, in-app, CTV, DOOH).' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedViewabilityThreshold rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Viewability Threshold' ;
    rdfs:comment 'The contractual viewability rate threshold (percentage) guaranteed in the insertion order, if applicable.' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inViewPercentage rdf:type rdf:Property ;
    rdfs:label 'In View Percentage' ;
    rdfs:comment 'The percentage of the ad creative pixels that were visible in the viewport at the time of measurement.' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invalidTrafficFlag rdf:type rdf:Property ;
    rdfs:label 'Invalid Traffic Flag' ;
    rdfs:comment 'Indicates whether the impression was flagged as invalid traffic (bot, fraud, or non-human traffic) by the measurement vendor.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurabilityRate rdf:type rdf:Property ;
    rdfs:label 'Measurability Rate' ;
    rdfs:comment 'The percentage of total impressions that were measurable for viewability, calculated as (measurable_impression_count / total_impression_count) * 100.' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurableImpressionCount rdf:type rdf:Property ;
    rdfs:label 'Measurable Impression Count' ;
    rdfs:comment 'The total number of impressions for which viewability could be measured (excludes unmeasurable impressions due to technical limitations).' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The technical methodology used to measure viewability (geometric, browser optimization, or reach extension).' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'The current status of the viewability measurement record (measured, unmeasurable, pending, error).' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerSizeHeight rdf:type rdf:Property ;
    rdfs:label 'Player Size Height' ;
    rdfs:comment 'The height of the video player or ad container in pixels at the time of measurement.' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playerSizeWidth rdf:type rdf:Property ;
    rdfs:label 'Player Size Width' ;
    rdfs:comment 'The width of the video player or ad container in pixels at the time of measurement.' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalImpressionCount rdf:type rdf:Property ;
    rdfs:label 'Total Impression Count' ;
    rdfs:comment 'The total number of ad impressions served, including both measurable and unmeasurable impressions.' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unmeasurableReason rdf:type rdf:Property ;
    rdfs:label 'Unmeasurable Reason' ;
    rdfs:comment 'The reason why viewability could not be measured for this impression (e.g., cross-domain iframe, ad blocker, technical limitation).' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoQuartileReached rdf:type rdf:Property ;
    rdfs:label 'Video Quartile Reached' ;
    rdfs:comment 'For video ads, the furthest quartile reached while the ad was viewable (0%, 25%, 50%, 75%, 100%). Not applicable for non-video formats.' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityGuaranteedIoFlag rdf:type rdf:Property ;
    rdfs:label 'Viewability Guaranteed Io Flag' ;
    rdfs:comment 'Indicates whether this impression is part of a viewability-guaranteed insertion order commitment.' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewableImpressionCount rdf:type rdf:Property ;
    rdfs:label 'Viewable Impression Count' ;
    rdfs:comment 'The number of impressions that met the MRC viewability standard (50% of pixels in-view for 1 second for display, 2 seconds for video).' ;
    rdfs:domain ind:ViewabilityMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryApprovalWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Approval Worker Id' ;
    rdfs:comment 'Reference to the specific individual or user assigned as approver for the current stage.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:projectTemplateId rdf:type rdf:Property ;
    rdfs:label 'Project Template Id' ;
    rdfs:comment 'Reference to the workflow template or approval process definition used for this instance.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectTemplate .

ind:approverComments rdf:type rdf:Property ;
    rdfs:label 'Approver Comments' ;
    rdfs:comment 'Textual comments, feedback, or notes provided by the approver when rendering their decision.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'Role or function of the approver for the current stage (e.g., Creative Director, Account Manager, Client Stakeholder, Legal Counsel, Finance Manager).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactName rdf:type rdf:Property ;
    rdfs:label 'Artifact Name' ;
    rdfs:comment 'Human-readable name or title of the artifact being approved.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactReference rdf:type rdf:Property ;
    rdfs:label 'Artifact Reference' ;
    rdfs:comment 'Reference identifier or code of the specific artifact being approved (e.g., creative asset ID, brief document ID, change request number).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactType rdf:type rdf:Property ;
    rdfs:label 'Artifact Type' ;
    rdfs:comment 'Type of project artifact requiring approval: brief (project brief, campaign brief), deliverable (creative asset, media plan), change request (scope change, timeline change), budget (budget allocation, budget revision), plan (media plan, campaign plan), or proof (creative proof, design proof).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedApproverName rdf:type rdf:Property ;
    rdfs:label 'Assigned Approver Name' ;
    rdfs:comment 'Full name of the individual assigned as approver for the current stage.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Timestamp when the approval workflow was fully completed (all stages approved or workflow terminated).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentStage rdf:type rdf:Property ;
    rdfs:label 'Current Stage' ;
    rdfs:comment 'Name or identifier of the current approval stage in the workflow (e.g., Creative Review, Client Review, Legal Review, Final Approval).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decision rdf:type rdf:Property ;
    rdfs:label 'Decision' ;
    rdfs:comment 'Decision rendered by the approver for the current stage: approved (unconditional approval), rejected (approval denied), approved_with_comments (conditional approval with feedback), pending (decision not yet made).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the operational system from which this approval workflow record originated (e.g., Workfront, Monday.com, Asana).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Source System Workflow Code' ;
    rdfs:comment 'Original workflow instance identifier from the source system of record (e.g., Workfront approval ID, Monday.com approval ID).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageSequence rdf:type rdf:Property ;
    rdfs:label 'Stage Sequence' ;
    rdfs:comment 'Numeric sequence position of the current stage within the overall workflow (e.g., 1 for first stage, 2 for second stage).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submitterName rdf:type rdf:Property ;
    rdfs:label 'Submitter Name' ;
    rdfs:comment 'Full name of the individual who submitted the artifact for approval.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStages rdf:type rdf:Property ;
    rdfs:label 'Total Stages' ;
    rdfs:comment 'Total number of approval stages defined in this workflow instance.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowInstanceReference rdf:type rdf:Property ;
    rdfs:label 'Workflow Instance Reference' ;
    rdfs:comment 'Business-readable reference number or code for this workflow instance, used for tracking and communication.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current overall status of the approval workflow instance: pending (not yet started), in_progress (awaiting approver action), approved (all stages approved), rejected (one or more stages rejected), cancelled (workflow terminated), escalated (sent to higher authority).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Project Assignment Id' ;
    rdfs:comment 'Unique identifier for the assignment record. Primary key.' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Foreign key linking to talent.position. Business justification: Assignments staff workers into project roles; linking to position enables position utilization tracking, role-based capacity planning, position cost rate application for billing, and position-level re' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:primaryProjectWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Project Worker Id' ;
    rdfs:comment 'Reference to the worker or team member assigned to the task. Links to talent workforce data.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:talentEngagementId rdf:type rdf:Property ;
    rdfs:label 'Talent Engagement Id' ;
    rdfs:comment 'Foreign key linking to talent.engagement. Business justification: When assignments staff external talent (freelancers, contractors), linking to engagement enables contract compliance tracking, rate validation against agreed terms, usage rights verification, and enga' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentEngagement .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'The percentage of the worker\'s capacity allocated to this assignment, expressed as a decimal (e.g., 50.00 for 50% allocation).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'The date and time when the assignment was created or assigned to the worker.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentRole rdf:type rdf:Property ;
    rdfs:label 'Assignment Role' ;
    rdfs:comment 'The role or capacity in which the worker is assigned to the task (e.g., lead, contributor, reviewer, approver, observer, consultant).' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRate rdf:type rdf:Property ;
    rdfs:label 'Billing Rate' ;
    rdfs:comment 'The hourly billing rate applied to this assignment for client invoicing purposes. Confidential business data.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costRate rdf:type rdf:Property ;
    rdfs:label 'Cost Rate' ;
    rdfs:comment 'The internal cost rate per hour for the worker on this assignment, used for profitability analysis. Confidential business data.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible Flag' ;
    rdfs:comment 'Indicates whether the worker is eligible for overtime compensation on this assignment (True) or not (False).' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'The estimated number of hours allocated for the worker to complete the assigned task.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reassignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reassigned Timestamp' ;
    rdfs:comment 'The date and time when the assignment was reassigned to a different worker, if applicable.' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reassignmentReason rdf:type rdf:Property ;
    rdfs:label 'Reassignment Reason' ;
    rdfs:comment 'Free-text explanation for why the assignment was reassigned to a different worker, if applicable.' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillRequired rdf:type rdf:Property ;
    rdfs:label 'Skill Required' ;
    rdfs:comment 'The primary skill or competency required for this assignment (e.g., copywriting, art direction, media planning, data analysis).' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationCategory rdf:type rdf:Property ;
    rdfs:label 'Utilization Category' ;
    rdfs:comment 'Classification of the assignment for workforce utilization reporting (e.g., client billable, internal project, training, administrative, bench).' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocation rdf:type rdf:Property ;
    rdfs:label 'Work Location' ;
    rdfs:comment 'Indicates whether the assignment is to be performed on-site at the client or agency location, remotely, or in a hybrid arrangement.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverContactClientContactId rdf:type rdf:Property ;
    rdfs:label 'Approver Contact Client Contact Id' ;
    rdfs:comment 'Identifier of the individual authorized to approve or reject the change request.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:primaryChangeClientContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Change Client Contact Id' ;
    rdfs:comment 'Identifier of the individual contact who submitted the change request.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Comments or rationale provided by the approver regarding the approval or rejection decision.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Impact Flag' ;
    rdfs:comment 'Indicates whether this change request has an impact on client billing (True) or not (False).' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeRequestDescription rdf:type rdf:Property ;
    rdfs:label 'Change Request Description' ;
    rdfs:comment 'Detailed narrative describing the requested change, including rationale, context, and business justification.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestStatus rdf:type rdf:Property ;
    rdfs:label 'Change Request Status' ;
    rdfs:comment 'Current lifecycle status of the change request: submitted, under review, approved, rejected, deferred, or implemented.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the change request by the dimension being modified: scope addition, scope reduction, timeline extension, budget increase, resource change, or deliverable modification.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Client Approval Required Flag' ;
    rdfs:comment 'Indicates whether formal client approval is required for this change request (True) or if internal approval is sufficient (False).' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deferralReason rdf:type rdf:Property ;
    rdfs:label 'Deferral Reason' ;
    rdfs:comment 'Explanation for why the change request was deferred to a later date or phase, if applicable.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Notes' ;
    rdfs:comment 'Detailed narrative describing the assessed impact of the change request on scope, schedule, budget, quality, and resources.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Impact Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the impact cost delta.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactCostDelta rdf:type rdf:Property ;
    rdfs:label 'Impact Cost Delta' ;
    rdfs:comment 'Estimated financial impact of the change request, expressed as a positive or negative delta from the original budget.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactEffortHoursDelta rdf:type rdf:Property ;
    rdfs:label 'Impact Effort Hours Delta' ;
    rdfs:comment 'Estimated change in effort hours required to implement this change request, expressed as a positive or negative delta from the original project plan.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactTimelineDeltaDays rdf:type rdf:Property ;
    rdfs:label 'Impact Timeline Delta Days' ;
    rdfs:comment 'Estimated change in project timeline measured in days, expressed as a positive or negative delta from the original schedule.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Date on which the approved change request was implemented into the project plan.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date on which the review of the change request was completed.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date on which the formal review of the change request began.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeCreepFlag rdf:type rdf:Property ;
    rdfs:label 'Scope Creep Flag' ;
    rdfs:comment 'Indicates whether this change request represents scope creep (True) or a legitimate change within project governance (False).' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sowAmendmentReference rdf:type rdf:Property ;
    rdfs:label 'Sow Amendment Reference' ;
    rdfs:comment 'Reference number or identifier of the SOW amendment document generated as a result of this approved change request.' ;
    rdfs:domain ind:ChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableTrackerId rdf:type rdf:Property ;
    rdfs:label 'Deliverable Tracker Id' ;
    rdfs:comment 'Unique identifier for the deliverable tracking record. Primary key for operational tracking of project deliverables from brief through final delivery.' ;
    rdfs:domain ind:DeliverableTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the team responsible for this deliverable (e.g., creative team, media planning team, analytics team).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Status of regulatory and brand compliance review. Ensures deliverable meets legal, regulatory, and brand guideline requirements before delivery.' ;
    rdfs:domain ind:DeliverableTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'Precise timestamp when the deliverable was marked as delivered. Provides exact delivery time for Service Level Agreement (SLA) measurement.' ;
    rdfs:domain ind:DeliverableTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'Method or platform through which the deliverable was or will be transmitted to the recipient (e.g., email, client portal, FTP, DAM system). [ENUM-REF-CANDIDATE: email|client_portal|ftp|dam|cloud_storage|physical_delivery|api|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliverableTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileReference rdf:type rdf:Property ;
    rdfs:label 'File Reference' ;
    rdfs:comment 'File path, URL, or Digital Asset Management (DAM) system reference pointing to the deliverable asset location.' ;
    rdfs:domain ind:DeliverableTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatSpecification rdf:type rdf:Property ;
    rdfs:label 'Format Specification' ;
    rdfs:comment 'Technical format requirements for the deliverable (e.g., \'MP4 1920x1080 30fps\', \'PDF print-ready CMYK\', \'HTML5 300x250\'). Ensures deliverable meets technical specifications.' ;
    rdfs:domain ind:DeliverableTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Internal Approval Status' ;
    rdfs:comment 'Internal agency approval status before client submission. Ensures quality control and brand compliance before external delivery.' ;
    rdfs:domain ind:DeliverableTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'Target date by which the deliverable is scheduled to be completed and delivered to the client or internal stakeholder.' ;
    rdfs:domain ind:DeliverableTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewRoundCount rdf:type rdf:Property ;
    rdfs:label 'Review Round Count' ;
    rdfs:comment 'Number of review cycles the deliverable has undergone. Tracks iteration intensity and helps identify scope creep or unclear requirements.' ;
    rdfs:domain ind:DeliverableTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemDeliverableCode rdf:type rdf:Property ;
    rdfs:label 'Source System Deliverable Code' ;
    rdfs:comment 'Original identifier from the source project management or work management system (e.g., Workfront task ID, Monday.com item ID).' ;
    rdfs:domain ind:DeliverableTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyId rdf:type rdf:Property ;
    rdfs:label 'Dependency Id' ;
    rdfs:comment 'Unique identifier for the project dependency record.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successorEntityTaskId rdf:type rdf:Property ;
    rdfs:label 'Successor Entity Task Id' ;
    rdfs:comment 'Reference to the specific task or milestone that depends on the predecessor. The entity type is determined by successor_entity_type.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:constraintType rdf:type rdf:Property ;
    rdfs:label 'Constraint Type' ;
    rdfs:comment 'Rigidity level of the dependency constraint. Hard: must be enforced, cannot be violated. Soft: should be enforced but can be overridden with approval. Preferred: advisory only, used for optimization.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyCategory rdf:type rdf:Property ;
    rdfs:label 'Dependency Category' ;
    rdfs:comment 'Classification of the dependency nature. Mandatory: legally or contractually required. Discretionary: based on best practices or preferences. External: involves third parties or external entities. Internal: within the organization\'s control.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyStatus rdf:type rdf:Property ;
    rdfs:label 'Dependency Status' ;
    rdfs:comment 'Current state of the dependency relationship. Active: dependency is enforced. Waived: dependency temporarily ignored by project manager approval. Violated: successor started before predecessor completed. Suspended: dependency enforcement paused. Resolved: dependency satisfied and closed.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyType rdf:type rdf:Property ;
    rdfs:label 'Dependency Type' ;
    rdfs:comment 'Logical relationship type between predecessor and successor. Finish-to-start (FS): successor cannot start until predecessor finishes. Start-to-start (SS): successor cannot start until predecessor starts. Finish-to-finish (FF): successor cannot finish until predecessor finishes. Start-to-finish (SF): successor cannot finish until predecessor starts.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floatDays rdf:type rdf:Property ;
    rdfs:label 'Float Days' ;
    rdfs:comment 'Total float or slack time available in this dependency relationship. Number of days the successor can be delayed without impacting the project completion date.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Indicates whether this dependency is part of the project critical path. True when any delay in this dependency directly impacts the project completion date.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCrossProject rdf:type rdf:Property ;
    rdfs:label 'Is Cross Project' ;
    rdfs:comment 'Indicates whether this dependency spans across multiple projects. True when predecessor and successor belong to different projects, enabling portfolio-level critical path analysis.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lagDays rdf:type rdf:Property ;
    rdfs:label 'Lag Days' ;
    rdfs:comment 'Number of working days to delay the successor after the predecessor relationship is satisfied. Positive values create a waiting period between activities.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadDays rdf:type rdf:Property ;
    rdfs:label 'Lead Days' ;
    rdfs:comment 'Number of working days the successor can start before the predecessor relationship is satisfied. Allows overlapping or fast-tracking of activities.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predecessorEntityType rdf:type rdf:Property ;
    rdfs:label 'Predecessor Entity Type' ;
    rdfs:comment 'Type of the predecessor entity in the dependency relationship. Indicates whether the predecessor is a task or milestone.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Impact Level' ;
    rdfs:comment 'Assessment of schedule risk if this dependency is violated or delayed. Critical: project completion at risk. High: major milestone impact. Medium: moderate schedule impact. Low: minor impact. Negligible: no material impact.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Unique identifier of this dependency record in the source operational system. Enables traceability and reconciliation with upstream systems.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successorEntityType rdf:type rdf:Property ;
    rdfs:label 'Successor Entity Type' ;
    rdfs:comment 'Type of the successor entity in the dependency relationship. Indicates whether the successor is a task or milestone.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDate rdf:type rdf:Property ;
    rdfs:label 'Violation Date' ;
    rdfs:comment 'Date when the dependency was violated, if applicable. Recorded when successor activity started or finished before the predecessor relationship was satisfied.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the project manager or authority who approved the dependency waiver.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Date' ;
    rdfs:comment 'Date when the dependency waiver was formally approved.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business justification for waiving or suspending the dependency. Captures the rationale when project manager overrides the dependency constraint.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDirectorWorkerId rdf:type rdf:Property ;
    rdfs:label 'Account Director Worker Id' ;
    rdfs:comment 'Reference to the account director overseeing client relationship and project governance.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:actualDurationDays rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Days' ;
    rdfs:comment 'Actual elapsed duration of the project in calendar days. Populated upon project completion.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Commercial model under which the project is billed to the client.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Client Satisfaction Score' ;
    rdfs:comment 'Client-reported satisfaction rating for the project, typically on a scale of 1.00 to 5.00. Captured post-delivery or at milestones.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryMethodology rdf:type rdf:Property ;
    rdfs:label 'Delivery Methodology' ;
    rdfs:comment 'Project management methodology applied for planning and execution (e.g., agile sprints, waterfall phases, hybrid approach).' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthIndicator rdf:type rdf:Property ;
    rdfs:label 'Health Indicator' ;
    rdfs:comment 'Overall health status of the project based on schedule, budget, scope, and quality metrics. Green indicates on-track, yellow indicates at-risk, red indicates critical issues.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeName rdf:type rdf:Property ;
    rdfs:label 'Initiative Name' ;
    rdfs:comment 'Human-readable name of the project or engagement, used for identification and reporting.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeStatus rdf:type rdf:Property ;
    rdfs:label 'Initiative Status' ;
    rdfs:comment 'Current lifecycle status of the project indicating its stage in the execution workflow.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Days' ;
    rdfs:comment 'Originally estimated duration of the project in calendar days from start to end.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the project for client communication and billing. Typically follows agency naming convention.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the project based on the primary service offering or deliverable type. [ENUM-REF-CANDIDATE: campaign_production|brand_strategy|media_planning|creative_development|pr_activation|digital_marketing|content_creation|market_research|event_management|retainer_services — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyNotes rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Notes' ;
    rdfs:comment 'Brand safety considerations, content adjacency guidelines, and risk mitigation measures for media placement.' ;
    rdfs:domain ind:ProjectBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeDirectionNotes rdf:type rdf:Property ;
    rdfs:label 'Creative Direction Notes' ;
    rdfs:comment 'High-level creative direction, brand guidelines, tone, messaging themes, and creative considerations for the project.' ;
    rdfs:domain ind:ProjectBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Start Timestamp' ;
    rdfs:comment 'Timestamp when project execution officially began following brief approval.' ;
    rdfs:domain ind:ProjectBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:keyDeliverables rdf:type rdf:Property ;
    rdfs:label 'Key Deliverables' ;
    rdfs:comment 'Comprehensive list of key deliverables, outputs, and work products expected from this project.' ;
    rdfs:domain ind:ProjectBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyStakeholders rdf:type rdf:Property ;
    rdfs:label 'Key Stakeholders' ;
    rdfs:comment 'List of key stakeholders, decision-makers, and approvers involved in this project from both agency and client sides.' ;
    rdfs:domain ind:ProjectBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFramework rdf:type rdf:Property ;
    rdfs:label 'Measurement Framework' ;
    rdfs:comment 'Description of the measurement and analytics framework to be used for tracking project performance and outcomes.' ;
    rdfs:domain ind:ProjectBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Planned completion date for project execution as defined in the project brief.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Planned start date for project execution as defined in the project brief.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskConsiderations rdf:type rdf:Property ;
    rdfs:label 'Risk Considerations' ;
    rdfs:comment 'Identified risks, dependencies, and mitigation strategies relevant to project execution.' ;
    rdfs:domain ind:ProjectBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicObjectives rdf:type rdf:Property ;
    rdfs:label 'Strategic Objectives' ;
    rdfs:comment 'High-level strategic goals and business objectives that this project aims to achieve for the client.' ;
    rdfs:domain ind:ProjectBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSummary rdf:type rdf:Property ;
    rdfs:label 'Target Audience Summary' ;
    rdfs:comment 'Summary description of the target audience demographics, psychographics, and behavioral characteristics for this project.' ;
    rdfs:domain ind:ProjectBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineConstraints rdf:type rdf:Property ;
    rdfs:label 'Timeline Constraints' ;
    rdfs:comment 'Description of any timeline constraints, critical milestones, or deadline dependencies that impact project scheduling.' ;
    rdfs:domain ind:ProjectBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineBudgetFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Budget Flag' ;
    rdfs:comment 'Boolean flag indicating whether this budget version represents the original approved baseline for the project. True for the baseline version, False for revisions.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget: draft (in preparation), submitted (pending approval), approved (active), locked (no further changes), over-budget (exceeded threshold), or closed (project complete).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Approved Flag' ;
    rdfs:comment 'Boolean flag indicating whether this budget version has been formally approved by the client. True if client-approved, False otherwise.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contingencyReserve rdf:type rdf:Property ;
    rdfs:label 'Contingency Reserve' ;
    rdfs:comment 'Budget reserve allocated for identified risks and known-unknowns. Typically controlled by the project manager and released as needed for scope changes or risk mitigation.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creativeProductionBudget rdf:type rdf:Property ;
    rdfs:label 'Creative Production Budget' ;
    rdfs:comment 'Portion of the total budget allocated to creative development and production activities, including design, video production, photography, and Digital Asset Management (DAM).' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborBudget rdf:type rdf:Property ;
    rdfs:label 'Labor Budget' ;
    rdfs:comment 'Portion of the total budget allocated to labor costs, including salaries, contractor fees, and Full-Time Equivalent (FTE) resources.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Locked Timestamp' ;
    rdfs:comment 'Timestamp when this budget version was locked to prevent further modifications. Null if the budget is still open for changes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:managementReserve rdf:type rdf:Property ;
    rdfs:label 'Management Reserve' ;
    rdfs:comment 'Budget reserve allocated for unknown-unknowns and unplanned scope changes. Typically controlled by senior management and requires formal approval to access.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaBudget rdf:type rdf:Property ;
    rdfs:label 'Media Budget' ;
    rdfs:comment 'Portion of the total budget allocated to media buying and placement costs across all channels (digital, broadcast, print, Out-of-Home (OOH), etc.).' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemBudgetCode rdf:type rdf:Property ;
    rdfs:label 'Source System Budget Code' ;
    rdfs:comment 'Original budget identifier from the source system (e.g., Workfront project budget ID, SAP Project Systems (PS) budget ID). Enables traceability and reconciliation.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyBudget rdf:type rdf:Property ;
    rdfs:label 'Technology Budget' ;
    rdfs:comment 'Portion of the total budget allocated to technology costs, including ad serving platforms, Demand-Side Platform (DSP), Data Management Platform (DMP), analytics tools, and Application Programming Interface (API) integrations.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyVendorBudget rdf:type rdf:Property ;
    rdfs:label 'Third Party Vendor Budget' ;
    rdfs:comment 'Portion of the total budget allocated to external vendor services, including research firms, data providers, freelancers, and specialized consultants.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalActualSpend rdf:type rdf:Property ;
    rdfs:label 'Total Actual Spend' ;
    rdfs:comment 'Cumulative amount of budget that has been actually spent (invoiced and paid or accrued) against this project budget.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalApprovedBudget rdf:type rdf:Property ;
    rdfs:label 'Total Approved Budget' ;
    rdfs:comment 'The total financial envelope approved for this project budget version. Represents the authorized spending limit.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of the total approved budget that has been utilized (committed or spent). Calculated as ((total_committed_spend + total_actual_spend) / total_approved_budget) * 100.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workBreakdownStructureCode rdf:type rdf:Property ;
    rdfs:label 'Work Breakdown Structure Code' ;
    rdfs:comment 'Work Breakdown Structure (WBS) element code associated with this budget. Enables hierarchical project decomposition and budget tracking at the work package level.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'Actual date the milestone was achieved or completed. Null if milestone has not yet been reached.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dependencyCount rdf:type rdf:Property ;
    rdfs:label 'Dependency Count' ;
    rdfs:comment 'Number of predecessor tasks or milestones that must be completed before this milestone can be achieved. Used for dependency analysis and scheduling.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBillingTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Billing Trigger' ;
    rdfs:comment 'Boolean flag indicating whether achievement of this milestone triggers invoice generation or payment milestone per the client contract.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isContractualGate rdf:type rdf:Property ;
    rdfs:label 'Is Contractual Gate' ;
    rdfs:comment 'Boolean flag indicating whether this milestone is a contractually binding checkpoint defined in the SOW, requiring formal client sign-off before proceeding.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Detailed description of the milestone deliverable, acceptance criteria, and business significance.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Project Milestone Status' ;
    rdfs:comment 'Current lifecycle status of the milestone: upcoming (not yet started), in_progress (work underway toward milestone), achieved (successfully completed on or before planned date), missed (completed after planned date or not completed by deadline), deferred (postponed to future date), cancelled (no longer required).' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowMilestoneReference rdf:type rdf:Property ;
    rdfs:label 'Sow Milestone Reference' ;
    rdfs:comment 'External reference code linking this milestone to a contractual milestone defined in the client Statement of Work (SOW). Used for contractual compliance and billing trigger validation.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetRangeMax rdf:type rdf:Property ;
    rdfs:label 'Budget Range Max' ;
    rdfs:comment 'The maximum typical project budget in agency currency for which this template is appropriate, used to guide template selection based on client budget constraints.' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetRangeMin rdf:type rdf:Property ;
    rdfs:label 'Budget Range Min' ;
    rdfs:comment 'The minimum typical project budget in agency currency for which this template is appropriate, used to guide template selection based on client budget constraints.' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complexityLevel rdf:type rdf:Property ;
    rdfs:label 'Complexity Level' ;
    rdfs:comment 'Classification of the project complexity this template is designed for, indicating the scale, coordination requirements, and resource intensity (low, medium, high, enterprise).' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultDurationDays rdf:type rdf:Property ;
    rdfs:label 'Default Duration Days' ;
    rdfs:comment 'The standard number of calendar days from project kickoff to final delivery that this template is designed to accommodate, used for initial timeline estimation.' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectTemplateDescription rdf:type rdf:Property ;
    rdfs:label 'Project Template Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and intended use cases for this project template, including what types of client engagements it best serves.' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedTeamComposition rdf:type rdf:Property ;
    rdfs:label 'Recommended Team Composition' ;
    rdfs:comment 'Structured description of the recommended team roles and Full-Time Equivalent (FTE) allocations for this template (e.g., Account Director 0.2 FTE, Creative Director 0.3 FTE, Media Planner 0.5 FTE, Copywriter 0.4 FTE) to guide resource assignment.' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresLegalReview rdf:type rdf:Property ;
    rdfs:label 'Requires Legal Review' ;
    rdfs:comment 'Boolean flag indicating whether projects using this template require legal or compliance review (e.g., for regulatory advertising claims, data privacy, or contractual obligations), triggering appropriate review workflows.' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardMilestones rdf:type rdf:Property ;
    rdfs:label 'Standard Milestones' ;
    rdfs:comment 'Comma-separated or structured list of key milestone events and deliverables that are standard checkpoints in projects using this template (e.g., Creative Approval, Media Plan Sign-off, Campaign Launch, QBR).' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardPhases rdf:type rdf:Property ;
    rdfs:label 'Standard Phases' ;
    rdfs:comment 'Comma-separated or structured list of the standard project phases included in this template (e.g., Discovery, Strategy, Creative Development, Production, Launch, Optimization) defining the high-level work breakdown structure (WBS).' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTaskList rdf:type rdf:Property ;
    rdfs:label 'Standard Task List' ;
    rdfs:comment 'Structured or delimited list of the standard tasks and activities that comprise this template, defining the detailed work breakdown and task sequences for typical project execution.' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Success Rate Percentage' ;
    rdfs:comment 'The percentage of projects created from this template that were completed on time and within budget, used to assess template quality and refine best practices.' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetClientSegment rdf:type rdf:Property ;
    rdfs:label 'Target Client Segment' ;
    rdfs:comment 'Description of the client segment or industry vertical this template is optimized for (e.g., CPG brands, automotive, financial services, retail, technology) to aid in template selection.' ;
    rdfs:domain ind:ProjectTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Short alphanumeric code used as a business identifier for the template in project planning and resource management systems.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourcePlanId rdf:type rdf:Property ;
    rdfs:label 'Resource Plan Id' ;
    rdfs:comment 'Unique identifier for the resource plan record. Primary key for the resource plan entity.' ;
    rdfs:domain ind:ResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'The priority level for securing this resource allocation (critical, high, medium, low), used for capacity planning and resource conflict resolution.' ;
    rdfs:domain ind:ResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Rate Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the cost rate (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The code representing the department or cost center responsible for this resource allocation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'The name of the department or cost center responsible for this resource allocation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discipline rdf:type rdf:Property ;
    rdfs:label 'Discipline' ;
    rdfs:comment 'The broad functional discipline or department to which the role belongs (creative, strategy, media, account management, production, analytics, technology, operations). [ENUM-REF-CANDIDATE: creative|strategy|media|account|production|analytics|technology|operations — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationPreference rdf:type rdf:Property ;
    rdfs:label 'Location Preference' ;
    rdfs:comment 'The preferred work location for this resource allocation (onsite, remote, hybrid, or any).' ;
    rdfs:domain ind:ResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'The specific office or geographic location from which the resource is expected to work (e.g., New York, London, Remote).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedFte rdf:type rdf:Property ;
    rdfs:label 'Planned Fte' ;
    rdfs:comment 'The planned Full-Time Equivalent (FTE) allocation for this role during the planning period. 1.0 represents one full-time resource; 0.5 represents half-time allocation.' ;
    rdfs:domain ind:ResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'The time granularity used for resource planning (week, sprint, month, quarter, or project phase).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCode rdf:type rdf:Property ;
    rdfs:label 'Role Code' ;
    rdfs:comment 'The standardized code representing the role or discipline required for this resource plan (e.g., ACD for Art Creative Director, CPY for Copywriter, STR for Strategist).' ;
    rdfs:domain ind:ResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleName rdf:type rdf:Property ;
    rdfs:label 'Role Name' ;
    rdfs:comment 'The human-readable name of the role or discipline required (e.g., Art Director, Copywriter, Media Planner, Account Executive).' ;
    rdfs:domain ind:ResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillRequirements rdf:type rdf:Property ;
    rdfs:label 'Skill Requirements' ;
    rdfs:comment 'Specific skills, competencies, or certifications required for the role (e.g., Adobe Creative Suite, Google Ads Certification, Salesforce CRM, Spanish language fluency).' ;
    rdfs:domain ind:ResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPlannedCost rdf:type rdf:Property ;
    rdfs:label 'Total Planned Cost' ;
    rdfs:comment 'The total planned cost for this resource allocation, calculated as planned hours multiplied by cost rate.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Unique identifier for the risk or issue record in the project risk register.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRiskWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Worker Id' ;
    rdfs:comment 'Reference to the individual accountable for monitoring the risk or issue and executing the mitigation strategy, typically a project manager, account lead, or functional manager.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Date when the risk was successfully mitigated or closed, or the issue was resolved, enabling measurement of resolution cycle time and effectiveness.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientCommunicatedDate rdf:type rdf:Property ;
    rdfs:label 'Client Communicated Date' ;
    rdfs:comment 'Date when the risk or issue was formally communicated to the client, tracking transparency and compliance with contractual reporting obligations.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Timestamp when the risk or issue was formally closed, supporting cycle time analysis and resolution effectiveness measurement.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan' ;
    rdfs:comment 'Fallback plan or alternative course of action to be executed if the risk materializes or the mitigation strategy proves insufficient.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Indicates the organizational level to which the risk or issue has been escalated for decision-making or additional resources, supporting governance and accountability.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'Projected financial impact on project budget if the risk materializes or the issue is not resolved, expressed in the project currency, supporting budget contingency planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedScheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Schedule Impact Days' ;
    rdfs:comment 'Projected delay in project timeline measured in days if the risk materializes or the issue is not resolved, supporting schedule contingency and client expectation management.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date when the risk or issue was first identified and logged in the register, establishing the baseline for tracking age and response time.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactRating rdf:type rdf:Property ;
    rdfs:label 'Impact Rating' ;
    rdfs:comment 'Qualitative assessment of the severity of consequences if the risk materializes or the issue is not resolved, considering effects on timeline, budget, quality, and client satisfaction.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Planned actions and approach to reduce the probability or impact of the risk, or to resolve the issue, including preventive measures and corrective actions.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityRating rdf:type rdf:Property ;
    rdfs:label 'Probability Rating' ;
    rdfs:comment 'Qualitative assessment of the likelihood that the risk will occur, used in conjunction with impact rating to calculate risk score and prioritize mitigation efforts.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskIssueNumber rdf:type rdf:Property ;
    rdfs:label 'Risk Issue Number' ;
    rdfs:comment 'Business-facing identifier or tracking number for the risk or issue, often used in client communications and status reports.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRegisterCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Register Category' ;
    rdfs:comment 'Business domain or functional area affected by the risk or issue, enabling categorization for reporting and trend analysis across the agency portfolio. [ENUM-REF-CANDIDATE: resource|timeline|budget|client|technical|regulatory|creative|vendor|scope|quality — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRegisterDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Register Description' ;
    rdfs:comment 'Detailed narrative describing the nature, context, and potential consequences of the risk or issue.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Register Status' ;
    rdfs:comment 'Current lifecycle state of the risk or issue, tracking progression from identification through resolution or escalation.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRegisterType rdf:type rdf:Property ;
    rdfs:label 'Risk Register Type' ;
    rdfs:comment 'Classification indicating whether this entry is a potential risk (future threat or opportunity), an active issue (current problem), or an assumption underlying project planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Quantitative risk priority score calculated from probability and impact ratings, used to rank and prioritize risks for management attention and resource allocation.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemRiskCode rdf:type rdf:Property ;
    rdfs:label 'Source System Risk Code' ;
    rdfs:comment 'Original identifier from the upstream project management system of record such as Workfront or Monday.com, enabling traceability and reconciliation with operational tools.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Planned or committed date by which the risk mitigation actions should be completed or the issue should be resolved, used for tracking adherence to resolution commitments.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleBaselineId rdf:type rdf:Property ;
    rdfs:label 'Schedule Baseline Id' ;
    rdfs:comment 'Unique identifier for the schedule baseline record. Primary key.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineDescription rdf:type rdf:Property ;
    rdfs:label 'Baseline Description' ;
    rdfs:comment 'Detailed description of the baseline scope, assumptions, and context at the time of approval.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineName rdf:type rdf:Property ;
    rdfs:label 'Baseline Name' ;
    rdfs:comment 'Human-readable name or label for this baseline (e.g., \'Q1 2024 Client Approved Baseline\', \'Post-Scope-Change Baseline\').' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineNotes rdf:type rdf:Property ;
    rdfs:label 'Baseline Notes' ;
    rdfs:comment 'Additional notes, comments, or context provided by the project manager or approver at the time of baseline creation.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineSnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Baseline Snapshot Timestamp' ;
    rdfs:comment 'Exact timestamp when this baseline snapshot was captured from the project management system (Workfront, Monday.com).' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:baselineStatus rdf:type rdf:Property ;
    rdfs:label 'Baseline Status' ;
    rdfs:comment 'Current lifecycle status of the baseline (draft during creation, pending-approval awaiting sign-off, approved and locked, active as current baseline, superseded by newer version, or archived for historical reference).' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineType rdf:type rdf:Property ;
    rdfs:label 'Baseline Type' ;
    rdfs:comment 'Classification of the baseline indicating its purpose or trigger (original baseline at project start, re-baseline after scope change, client-approved milestone baseline, internal planning baseline, interim checkpoint, or final approved baseline).' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Baseline Version Number' ;
    rdfs:comment 'Sequential version number of this baseline. Increments with each re-baseline event (e.g., 1 for original, 2 for first re-baseline).' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalPathDurationDays rdf:type rdf:Property ;
    rdfs:label 'Critical Path Duration Days' ;
    rdfs:comment 'Duration in days of the critical path as identified in this baseline schedule.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCurrentBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Current Baseline' ;
    rdfs:comment 'Boolean flag indicating whether this is the currently active baseline against which project performance is being measured (True) or a historical/superseded baseline (False).' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of milestones included in this baseline schedule.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total planned cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reBaselineReason rdf:type rdf:Property ;
    rdfs:label 'Re Baseline Reason' ;
    rdfs:comment 'Explanation or justification for creating a new baseline (e.g., \'Scope change approved by client\', \'Resource reallocation\', \'Major milestone shift\'). Null for original baseline.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reBaselineTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Re Baseline Trigger Event' ;
    rdfs:comment 'Specific event or change request that triggered the re-baseline (e.g., change request number, client directive reference).' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemBaselineCode rdf:type rdf:Property ;
    rdfs:label 'Source System Baseline Code' ;
    rdfs:comment 'Native baseline identifier or version key from the source project management system.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCount rdf:type rdf:Property ;
    rdfs:label 'Task Count' ;
    rdfs:comment 'Total number of tasks or work packages included in this baseline schedule.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFloatDays rdf:type rdf:Property ;
    rdfs:label 'Total Float Days' ;
    rdfs:comment 'Total float or slack available in the baseline schedule (difference between latest and earliest finish dates).' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPlannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Total Planned Duration Days' ;
    rdfs:comment 'Total planned duration of the project in calendar days as captured in this baseline.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPlannedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Total Planned Effort Hours' ;
    rdfs:comment 'Total planned effort in hours across all tasks and resources as captured in this baseline. Used for Earned Value Management (EVM) calculations.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sprintId rdf:type rdf:Property ;
    rdfs:label 'Sprint Id' ;
    rdfs:comment 'Unique identifier for the sprint record. Primary key.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sprintProductOwnerWorkerId rdf:type rdf:Property ;
    rdfs:label 'Sprint Product Owner Worker Id' ;
    rdfs:comment 'Reference to the product owner responsible for backlog prioritization and sprint goal definition.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:sprintWorkerId rdf:type rdf:Property ;
    rdfs:label 'Sprint Worker Id' ;
    rdfs:comment 'Reference to the scrum master facilitating this sprint. Responsible for removing blockers and ensuring agile process adherence.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:blockersIdentified rdf:type rdf:Property ;
    rdfs:label 'Blockers Identified' ;
    rdfs:comment 'List or description of impediments, blockers, or risks encountered during the sprint that hindered progress.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryOverStoryPoints rdf:type rdf:Property ;
    rdfs:label 'Carry Over Story Points' ;
    rdfs:comment 'Story points from incomplete work carried forward to the next sprint. Indicates scope creep or planning accuracy issues.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedStoryPoints rdf:type rdf:Property ;
    rdfs:label 'Completed Story Points' ;
    rdfs:comment 'Total story points or effort units actually completed by sprint end. Used to calculate velocity and team performance.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'The length of the sprint in calendar days. Typically 1-4 weeks (7-28 days) in agile practice.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goal rdf:type rdf:Property ;
    rdfs:label 'Goal' ;
    rdfs:comment 'The primary objective or outcome the team commits to achieving during this sprint. Defines the sprint\'s business purpose.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Planned Capacity Hours' ;
    rdfs:comment 'Total available team hours for the sprint, accounting for vacations, meetings, and other commitments. Used for capacity planning.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStoryPoints rdf:type rdf:Property ;
    rdfs:label 'Planned Story Points' ;
    rdfs:comment 'Total story points or effort units committed at sprint planning. Represents the team\'s capacity forecast.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retrospectiveDate rdf:type rdf:Property ;
    rdfs:label 'Retrospective Date' ;
    rdfs:comment 'Date when the sprint retrospective ceremony was conducted for team reflection and process improvement.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retrospectiveNotes rdf:type rdf:Property ;
    rdfs:label 'Retrospective Notes' ;
    rdfs:comment 'Summary of lessons learned, team feedback, and improvement actions identified during the sprint retrospective ceremony.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemSprintCode rdf:type rdf:Property ;
    rdfs:label 'Source System Sprint Code' ;
    rdfs:comment 'Original sprint identifier from the source project management system (Workfront, Monday.com, Jira). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sprintName rdf:type rdf:Property ;
    rdfs:label 'Sprint Name' ;
    rdfs:comment 'Human-readable name or label for the sprint (e.g., \'Q1 Campaign Launch Sprint\', \'Creative Development Sprint 3\').' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sprintNumber rdf:type rdf:Property ;
    rdfs:label 'Sprint Number' ;
    rdfs:comment 'Sequential number of the sprint within the project (e.g., Sprint 1, Sprint 2). Used for ordering and identification.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sprintStatus rdf:type rdf:Property ;
    rdfs:label 'Sprint Status' ;
    rdfs:comment 'Current lifecycle status of the sprint. Tracks progression through agile ceremonies and execution phases.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Number of team members assigned to this sprint. Used for capacity and velocity normalization.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:velocity rdf:type rdf:Property ;
    rdfs:label 'Velocity' ;
    rdfs:comment 'The rate of story points completed per sprint. Key metric for forecasting future sprint capacity and project timelines.' ;
    rdfs:domain ind:Sprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusUpdateId rdf:type rdf:Property ;
    rdfs:label 'Status Update Id' ;
    rdfs:comment 'Unique identifier for the project status update record. Primary key.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStatusWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Status Worker Id' ;
    rdfs:comment 'Reference to the employee or user who authored and submitted this status update. Links to the employee or user master record in Workday HCM or identity management system.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:accomplishments rdf:type rdf:Property ;
    rdfs:label 'Accomplishments' ;
    rdfs:comment 'Narrative description of key accomplishments, milestones achieved, and deliverables completed during the reporting period.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Full name of the person who authored this status update. Typically the project manager or account lead.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetBurnToDate rdf:type rdf:Property ;
    rdfs:label 'Budget Burn To Date' ;
    rdfs:comment 'Cumulative budget spent or committed to date as of the end of this reporting period. Represents actual cost incurred against the total project budget.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional comments, notes, or context provided by the author or reviewers. Free-form text field for supplementary information.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionsRequired rdf:type rdf:Property ;
    rdfs:label 'Decisions Required' ;
    rdfs:comment 'Narrative description of pending decisions, approvals, or actions required from stakeholders or leadership to unblock progress or resolve issues.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuesAndBlockers rdf:type rdf:Property ;
    rdfs:label 'Issues And Blockers' ;
    rdfs:comment 'Narrative description of current issues, blockers, impediments, and challenges affecting project progress. Includes problem statements and impact assessment.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMilestoneDate rdf:type rdf:Property ;
    rdfs:label 'Next Milestone Date' ;
    rdfs:comment 'Scheduled date for the next major milestone or deliverable.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Status' ;
    rdfs:comment 'Overall health status of the project using RAG (Red/Amber/Green) or equivalent traffic-light indicator. Red indicates critical issues, Amber indicates caution or risk, Green indicates on track.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedActivities rdf:type rdf:Property ;
    rdfs:label 'Planned Activities' ;
    rdfs:comment 'Narrative description of planned activities, tasks, and milestones scheduled for the next reporting period.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceStatus rdf:type rdf:Property ;
    rdfs:label 'Resource Status' ;
    rdfs:comment 'Status of resource availability and allocation for the project. Indicates whether resources are adequate, constrained, critically short, over-allocated, or under-allocated.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Overall risk level for the project during this reporting period. Indicates the severity of identified risks: low, medium, high, critical, or none.' ;
    rdfs:domain ind:StatusUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedWorkerId rdf:type rdf:Property ;
    rdfs:label 'Assigned Worker Id' ;
    rdfs:comment 'Reference to the individual worker or employee assigned to complete this task.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:predecessorTaskId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Task Id' ;
    rdfs:comment 'Reference to the task that must be completed or started before this task can proceed, based on the dependency type.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual date when this task was completed.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The actual date when work on this task began.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockedReason rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason' ;
    rdfs:comment 'Description of the reason why this task is blocked or cannot proceed.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loggedHours rdf:type rdf:Property ;
    rdfs:label 'Logged Hours' ;
    rdfs:comment 'The actual number of hours logged or worked on this task.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemTaskCode rdf:type rdf:Property ;
    rdfs:label 'Source System Task Code' ;
    rdfs:comment 'The unique identifier for this task in the source system (Workfront or Monday.com).' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed description of the work to be performed in this task.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskName rdf:type rdf:Property ;
    rdfs:label 'Task Name' ;
    rdfs:comment 'The name or title of the task.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the task (not started, in progress, blocked, complete, cancelled, on hold).' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'The category or type of work this task represents (e.g., creative production, copywriting, media trafficking, client review, quality assurance, approval).' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique identifier for the time entry record. Primary key for the time entry entity.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimeWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Worker Id' ;
    rdfs:comment 'Reference to the agency staff member who logged this time entry. Links to the talent domain worker entity.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The type of work activity performed during this time entry. Categorizes time for resource utilization analysis and billing purposes. [ENUM-REF-CANDIDATE: creative_development|strategy|client_management|production|media_planning|quality_assurance|account_services|research|copywriting|design|video_editing|project_management|administrative — promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date on which the work was performed. Used for timesheet aggregation and project timeline tracking.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hoursLogged rdf:type rdf:Property ;
    rdfs:label 'Hours Logged' ;
    rdfs:comment 'The number of hours worked on this task for the entry date. Supports fractional hours (e.g., 1.5 hours, 0.25 hours).' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this time entry is locked and cannot be edited. True when the entry has been processed for payroll or billing. False for editable entries.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertime rdf:type rdf:Property ;
    rdfs:label 'Is Overtime' ;
    rdfs:comment 'Indicates whether this time entry represents overtime hours. True for overtime, False for regular hours. Used for payroll processing and labor cost analysis.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentWorkPackageId rdf:type rdf:Property ;
    rdfs:label 'Parent Work Package Id' ;
    rdfs:comment 'Reference to the parent work package in the hierarchical WBS structure. Null for top-level packages.' ;
    rdfs:domain ind:WorkPackage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkPackage .

ind:plannedCost rdf:type rdf:Property ;
    rdfs:label 'Planned Cost' ;
    rdfs:comment 'Budgeted cost for this work package including labor, materials, and other direct costs. Baseline for Earned Value Management (EVM).' ;
    rdfs:domain ind:WorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Planned Effort Hours' ;
    rdfs:comment 'Estimated total labor hours required to complete this work package. Used for resource capacity planning and baseline cost estimation.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Code' ;
    rdfs:comment 'Hierarchical alphanumeric code representing the work package position in the WBS (e.g., 1.2.3.1). Enables structured decomposition and rollup reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Level' ;
    rdfs:comment 'Numeric depth of this work package in the WBS hierarchy (1 = top level, 2 = second level, etc.). Enables level-based filtering and rollup.' ;
    rdfs:domain ind:WorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workPackageDescription rdf:type rdf:Property ;
    rdfs:label 'Work Package Description' ;
    rdfs:comment 'Detailed narrative describing the scope, deliverables, and objectives of this work package. Provides context for resource planning and execution.' ;
    rdfs:domain ind:WorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPackageName rdf:type rdf:Property ;
    rdfs:label 'Work Package Name' ;
    rdfs:comment 'Short, descriptive name of the work package that clearly identifies the deliverable or work scope (e.g., \'Creative Concept Development\', \'Media Buy Execution\').' ;
    rdfs:domain ind:WorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPackageStatus rdf:type rdf:Property ;
    rdfs:label 'Work Package Status' ;
    rdfs:comment 'Current lifecycle status of the work package indicating progress and execution state.' ;
    rdfs:domain ind:WorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPackageType rdf:type rdf:Property ;
    rdfs:label 'Work Package Type' ;
    rdfs:comment 'Classification of the work package within the WBS structure (deliverable-oriented, milestone, phase, task group, or control account).' ;
    rdfs:domain ind:WorkPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Id' ;
    rdfs:comment 'Unique system-generated identifier for the capacity plan record. Primary key for the capacity_plan data product in the talent domain.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCapacityOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Capacity Org Unit Id' ;
    rdfs:comment 'Identifier of the agency department or business unit for which this capacity plan is prepared (e.g., Creative, Media, Strategy, Account Management, Production). Links to the organizational hierarchy.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryCapacityWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Capacity Worker Id' ;
    rdfs:comment 'Identifier of the employee (typically a Resource Manager, Department Head, or Operations Lead) responsible for authoring, maintaining, and approving this capacity plan. Maps to Workday HCM worker record.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:workfrontPlanId rdf:type rdf:Property ;
    rdfs:label 'Workfront Plan Id' ;
    rdfs:comment 'External reference identifier for the corresponding resource plan record in Workfront Resource Planning module. Enables bi-directional synchronization between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:availableHours rdf:type rdf:Property ;
    rdfs:label 'Available Hours' ;
    rdfs:comment 'Total available productive hours across all planned FTE-equivalent resources for the planning period, net of holidays, PTO, and non-billable overhead. Primary supply-side metric for capacity gap analysis.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignPipelineIds rdf:type rdf:Property ;
    rdfs:label 'Campaign Pipeline Ids' ;
    rdfs:comment 'Comma-separated list of pipeline campaign or pitch identifiers whose forecasted resource demand is incorporated into this capacity plan. Links capacity planning to new business development activity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityGapHours rdf:type rdf:Property ;
    rdfs:label 'Capacity Gap Hours' ;
    rdfs:comment 'Net difference between available_hours and forecasted_demand_hours for the planning period. Negative values indicate a capacity shortfall requiring freelancer augmentation or scope negotiation; positive values indicate surplus bench capacity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedDemandHours rdf:type rdf:Property ;
    rdfs:label 'Confirmed Demand Hours' ;
    rdfs:comment 'Hours of resource demand backed by signed SOWs, confirmed Insertion Orders (IOs), or approved campaign briefs. Subset of forecasted_demand_hours representing firm commitments, used for conservative capacity planning.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedDemandHours rdf:type rdf:Property ;
    rdfs:label 'Forecasted Demand Hours' ;
    rdfs:comment 'Total estimated hours of resource demand for the planning period, derived from confirmed SOWs, active campaign schedules, and pipeline-weighted new business opportunities. Primary demand-side metric for capacity gap analysis.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freelancerHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Freelancer Hours Planned' ;
    rdfs:comment 'Total hours planned to be sourced from freelancers and contractors (non-FTE resources) during the planning period. Informs freelancer budget allocation and vendor management.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freelancerPoolSize rdf:type rdf:Property ;
    rdfs:label 'Freelancer Pool Size' ;
    rdfs:comment 'Number of freelance or contract resources planned to be available in the talent pool for this discipline/team during the planning period. Used for bench management and rapid campaign ramp-up planning.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fteHeadcountContractor rdf:type rdf:Property ;
    rdfs:label 'Fte Headcount Contractor' ;
    rdfs:comment 'Count of fixed-term contractors and agency-of-record staff included in this capacity plan. Distinct from permanent FTEs and freelancers for cost classification and P&L reporting purposes.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fteHeadcountPermanent rdf:type rdf:Property ;
    rdfs:label 'Fte Headcount Permanent' ;
    rdfs:comment 'Count of permanent, full-time employees included in this capacity plan for the planning period. Excludes contractors and freelancers. Used for P&L headcount reporting and EBITDA margin analysis.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isNewBusinessPitch rdf:type rdf:Property ;
    rdfs:label 'Is New Business Pitch' ;
    rdfs:comment 'Indicates whether this capacity plan was created specifically to support a new business pitch or RFP response, as opposed to ongoing campaign delivery. Enables separate tracking of pitch-related resource commitments.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCostBudget rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Budget' ;
    rdfs:comment 'Total planned labor cost (in base currency) for the team/discipline during the planning period, covering salaries, contractor fees, and freelancer rates. Key input to finance for margin planning and P&L forecasting.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineDemandHours rdf:type rdf:Property ;
    rdfs:label 'Pipeline Demand Hours' ;
    rdfs:comment 'Hours of resource demand attributable to pipeline opportunities (RFPs, pitches, and proposals in progress) weighted by probability of conversion. Supports new business pitch resourcing and bench management decisions.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the capacity plan, used in cross-system references, SOW alignment, and finance reporting (e.g., CP-BRAND01-2025).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Last calendar date of the planning period covered by this capacity plan. Defines the effective end of the capacity window. Nullable for rolling/open-ended plans.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text field for resource managers to document planning assumptions, risk factors, scenario rationale, or escalation notes associated with this capacity plan version.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'First calendar date of the planning period covered by this capacity plan. Defines the effective start of the capacity window for resource allocation and demand matching.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedHeadcountFte rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount Fte' ;
    rdfs:comment 'Total planned headcount expressed in Full-Time Equivalent (FTE) units for the planning period, combining permanent employees, contractors, and freelancers normalized to a standard 40-hour work week. Core input to utilization target setting.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Forecast Amount' ;
    rdfs:comment 'Projected revenue attributable to the team/discipline for the planning period, derived from confirmed SOW values and pipeline-weighted opportunities. Used by finance for revenue forecasting and EBITDA planning.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioType rdf:type rdf:Property ;
    rdfs:label 'Scenario Type' ;
    rdfs:comment 'Scenario modeling classification for this capacity plan version — best case (maximum pipeline win rate), expected (most likely outcome), worst case (minimum pipeline conversion), or base (approved baseline). Supports sensitivity analysis for finance margin planning.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowReferenceIds rdf:type rdf:Property ;
    rdfs:label 'Sow Reference Ids' ;
    rdfs:comment 'Comma-separated list of SOW identifiers whose confirmed resource demand is incorporated into this capacity plan. Provides traceability between capacity commitments and contractual obligations.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationTargetPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Target Pct' ;
    rdfs:comment 'Target billable utilization rate (as a percentage of available hours) set by finance for this team/discipline during the planning period. Drives margin planning and FTE sizing decisions. Typically 65–85% for agency talent.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreedRate rdf:type rdf:Property ;
    rdfs:label 'Agreed Rate' ;
    rdfs:comment 'The contractually agreed compensation rate for this engagement, expressed in the billing arrangement unit (per hour, per day, per project, per month for retainer, or per usage unit). This is the base rate before adjustments or markups.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedHours rdf:type rdf:Property ;
    rdfs:label 'Allocated Hours' ;
    rdfs:comment 'The total number of hours budgeted or contracted for this engagement over its full duration. Used for time tracking, capacity planning, and billing reconciliation against actuals.' ;
    rdfs:domain ind:TalentEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingArrangement rdf:type rdf:Property ;
    rdfs:label 'Billing Arrangement' ;
    rdfs:comment 'The commercial billing model governing how the talent is compensated or charged — hourly rate, day rate, fixed project fee, retainer, or usage-based (e.g., residuals, licensing). Drives invoice generation and financial reconciliation.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Classification of the contractual engagement arrangement — Full-Time Equivalent (FTE) employment, freelance Statement of Work (SOW), contractor agreement, influencer partnership, or production crew booking. Drives billing, compliance, and HR treatment.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteEquivalent rdf:type rdf:Property ;
    rdfs:label 'Fte Equivalent' ;
    rdfs:comment 'The Full-Time Equivalent (FTE) fraction representing the proportion of a full working week this talent is allocated to this engagement (e.g., 1.0 = full-time, 0.5 = half-time). Used for capacity planning and resource utilization reporting.' ;
    rdfs:domain ind:TalentEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onSiteRequired rdf:type rdf:Property ;
    rdfs:label 'On Site Required' ;
    rdfs:comment 'Indicates whether the talent is required to work on-site at the agency, client premises, or production location, as opposed to working remotely. Impacts resource logistics, travel budgeting, and production planning.' ;
    rdfs:domain ind:TalentEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known alphanumeric reference code for this engagement, used in purchase orders, invoices, and communications with talent or agencies. Corresponds to the work order or booking reference number.' ;
    rdfs:domain ind:TalentEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentEngagementStatus rdf:type rdf:Property ;
    rdfs:label 'Talent Engagement Status' ;
    rdfs:comment 'Current lifecycle state of the talent engagement. Draft indicates the engagement is being configured; active means the talent is currently assigned; on_hold indicates a temporary pause; completed means the engagement concluded successfully; terminated indicates early cessation.' ;
    rdfs:domain ind:TalentEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'The tax treatment classification for this engagement, determining withholding obligations, VAT applicability, and reporting requirements (e.g., W-2 employee, 1099 contractor, corp-to-corp, VAT registered). Critical for payroll and tax compliance.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEngagementValue rdf:type rdf:Property ;
    rdfs:label 'Total Engagement Value' ;
    rdfs:comment 'The total contracted monetary value of this engagement for its full duration (e.g., total project fee, total retainer value, or estimated total for hourly/day-rate engagements). Used for budget management, Profit and Loss (P&L) reporting, and financial forecasting.' ;
    rdfs:domain ind:TalentEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Included' ;
    rdfs:comment 'Indicates whether usage rights for creative output (e.g., image, video, likeness) are included in the agreed engagement rate. When True, no separate usage licensing fee applies. Critical for talent rights management and compliance.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsScope rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Scope' ;
    rdfs:comment 'Description of the permitted usage scope for creative output produced under this engagement, including media channels, geographic territories, and duration of use (e.g., \'Digital only, North America, 12 months\'). Governs rights management and residual payments.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildMembershipId rdf:type rdf:Property ;
    rdfs:label 'Guild Membership Id' ;
    rdfs:comment 'Unique identifier for the guild membership record. Primary key.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:talentProfileId rdf:type rdf:Property ;
    rdfs:label 'Talent Profile Id' ;
    rdfs:comment 'Reference to the talent (worker) who holds this guild membership. Links to the talent_profile or worker entity.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:annualDuesAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Dues Amount' ;
    rdfs:comment 'Annual membership dues amount required for this membership tier.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityRestriction rdf:type rdf:Property ;
    rdfs:label 'Availability Restriction' ;
    rdfs:comment 'Free-text description of any availability restrictions imposed by union rules (e.g., mandatory rest periods, maximum consecutive work days, blackout dates).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Booking Eligibility Flag' ;
    rdfs:comment 'Indicates whether the talent is currently eligible for booking based on their guild membership status and compliance (True/False). Critical for production compliance.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes regarding compliance requirements, special conditions, or exceptions related to this guild membership.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Contract Agreement Code' ;
    rdfs:comment 'Code or reference number of the collective bargaining agreement (CBA) or master contract that governs this membership (e.g., SAG-AFTRA Commercials Contract 2022).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duesCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Dues Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for membership dues (e.g., USD, CAD, GBP for UK unions).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duesStatus rdf:type rdf:Property ;
    rdfs:label 'Dues Status' ;
    rdfs:comment 'Current status of membership dues payment obligations (e.g., current, overdue, delinquent, exempt for honorary members).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityRestriction rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Restriction' ;
    rdfs:comment 'Level of exclusivity restrictions imposed by union rules (e.g., none, partial exclusivity for certain product categories, full exclusivity).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthBenefitsEligible rdf:type rdf:Property ;
    rdfs:label 'Health Benefits Eligible' ;
    rdfs:comment 'Indicates whether this membership tier qualifies the talent for union-sponsored health insurance benefits (True/False).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:joinDate rdf:type rdf:Property ;
    rdfs:label 'Join Date' ;
    rdfs:comment 'Date when the talent officially joined or was admitted to the union or guild.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Three-letter country code representing the primary jurisdiction of the union or guild (e.g., USA for SAG-AFTRA, CAN for ACTRA, GBR for BECTU).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDuesPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Dues Payment Date' ;
    rdfs:comment 'Date of the most recent membership dues payment received by the union.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localChapterCode rdf:type rdf:Property ;
    rdfs:label 'Local Chapter Code' ;
    rdfs:comment 'Code identifying the local chapter, branch, or regional office of the union to which this membership is affiliated.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'The externally-issued membership number or identifier assigned by the union or guild (e.g., SAG-AFTRA membership card number).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipType rdf:type rdf:Property ;
    rdfs:label 'Membership Type' ;
    rdfs:comment 'Classification of the membership level or tier within the union (e.g., full member, associate member, honorary member, lifetime member).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRateSchedule rdf:type rdf:Property ;
    rdfs:label 'Minimum Rate Schedule' ;
    rdfs:comment 'Reference to the union minimum rate schedule or scale that applies to this membership (e.g., SAG-AFTRA Scale 2023, DGA Minimum Basic Agreement rates).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDuesDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Dues Due Date' ;
    rdfs:comment 'Date when the next membership dues payment is due.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pensionEligible rdf:type rdf:Property ;
    rdfs:label 'Pension Eligible' ;
    rdfs:comment 'Indicates whether this membership tier qualifies the talent for union pension plan contributions (True/False).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualPaymentEligible rdf:type rdf:Property ;
    rdfs:label 'Residual Payment Eligible' ;
    rdfs:comment 'Indicates whether this membership entitles the talent to residual payments for reuse of their work (True/False).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Signatory Requirement Flag' ;
    rdfs:comment 'Indicates whether the talent can only work with union signatory production companies (True) or can work with non-signatory companies (False).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Code representing the union or guild affiliation (e.g., SAG-AFTRA for Screen Actors Guild - American Federation of Television and Radio Artists, DGA for Directors Guild of America). [ENUM-REF-CANDIDATE: SAG-AFTRA|ACTRA|BECTU|DGA|WGA|IATSE|AEA|AFM|OTHER — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionName rdf:type rdf:Property ;
    rdfs:label 'Union Name' ;
    rdfs:comment 'Full legal name of the union or guild organization (e.g., Screen Actors Guild - American Federation of Television and Radio Artists).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the membership credentials were last verified with the union or guild.' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of internal verification of the membership credentials (e.g., verified with union, pending verification, unverified, expired credentials).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Work Permit Required' ;
    rdfs:comment 'Indicates whether a special work permit or clearance is required from the union for certain types of engagements (True/False).' ;
    rdfs:domain ind:GuildMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique system-generated identifier for each employee leave and absence request record in the Workday HCM Absence Management module. Serves as the primary key for this entity.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLeaveWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Worker Id' ;
    rdfs:comment 'Reference to the employee (Full-Time Equivalent, freelancer, contractor, or production crew member) who submitted this leave request. Links to the talent/employee master record.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'The actual date the employee returned to work, which may differ from the planned return_to_work_date due to early return, extension, or medical clearance requirements. Used for reconciling capacity plans and updating resource availability in Workfront.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Approved Duration Days' ;
    rdfs:comment 'Total number of working days formally approved for the leave period. May differ from requested_duration_days if the approver modified the leave window or partial approval was granted.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedEndDate rdf:type rdf:Property ;
    rdfs:label 'Approved End Date' ;
    rdfs:comment 'The last calendar date of the leave period as formally approved. May differ from the requested end date if the approver modified the leave window.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedStartDate rdf:type rdf:Property ;
    rdfs:label 'Approved Start Date' ;
    rdfs:comment 'The first calendar date of the leave period as formally approved by the manager or HR. May differ from the requested start date if the approver modified the leave window.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backfillRequired rdf:type rdf:Property ;
    rdfs:label 'Backfill Required' ;
    rdfs:comment 'Indicates whether a temporary replacement (freelancer, contractor, or internal reallocation) is required to cover the employee\'s responsibilities during the leave period. Triggers talent acquisition or resource reallocation workflows.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backfillType rdf:type rdf:Property ;
    rdfs:label 'Backfill Type' ;
    rdfs:comment 'The type of resource used to cover the employee\'s responsibilities during the leave period. Supports financial reconciliation in SAP S/4HANA and talent cost tracking for the P&L (Profit and Loss) of the talent domain.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNotes rdf:type rdf:Property ;
    rdfs:label 'Employee Notes' ;
    rdfs:comment 'Free-text comments entered by the employee when submitting the leave request, providing additional context or supporting information. May contain sensitive personal information; classified as confidential per GDPR Article 5 data minimisation principles.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermittentLeave rdf:type rdf:Property ;
    rdfs:label 'Intermittent Leave' ;
    rdfs:comment 'Indicates whether the leave is taken intermittently (non-consecutive days or partial days) rather than as a continuous block. Common for FMLA qualifying conditions. Affects capacity planning granularity and Workfront resource scheduling.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFmlaQualifying rdf:type rdf:Property ;
    rdfs:label 'Is Fmla Qualifying' ;
    rdfs:comment 'Indicates whether this leave request qualifies under the Family and Medical Leave Act (FMLA), entitling the employee to job-protected unpaid leave. Relevant for US-based employees. Drives compliance reporting and payroll processing in SAP S/4HANA.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaid rdf:type rdf:Property ;
    rdfs:label 'Is Paid' ;
    rdfs:comment 'Indicates whether the approved leave is paid (True) or unpaid (False). Drives payroll processing in Workday HCM Payroll and SAP S/4HANA FI/CO for accurate compensation calculations during the leave period.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobProfile rdf:type rdf:Property ;
    rdfs:label 'Job Profile' ;
    rdfs:comment 'The employee\'s job profile or role title as defined in Workday HCM at the time of the leave request (e.g., Creative Director, Media Planner, Account Manager, FTE). Used to assess skill-based resource impact and inform backfill sourcing decisions.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveBalanceAfterDays rdf:type rdf:Property ;
    rdfs:label 'Leave Balance After Days' ;
    rdfs:comment 'The employee\'s remaining leave balance in days for the applicable leave type after the approved leave is deducted. Sourced from Workday HCM Absence Management. Used for capacity planning and leave entitlement monitoring.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveBalanceBeforeDays rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Before Days' ;
    rdfs:comment 'The employee\'s available leave balance in days for the applicable leave type at the time the request was submitted. Sourced from Workday HCM Absence Management leave accrual records. Supports leave entitlement validation and HR reporting.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveReason rdf:type rdf:Property ;
    rdfs:label 'Leave Reason' ;
    rdfs:comment 'Free-text or coded reason provided by the employee for the leave request, as captured in Workday HCM. May contain sensitive health or personal information; classified as confidential. Used for HR reporting and compliance with FMLA and GDPR Article 9 sensitive data provisions.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveSubtype rdf:type rdf:Property ;
    rdfs:label 'Leave Subtype' ;
    rdfs:comment 'Further classification within a leave type, such as maternity, paternity, or adoption under parental leave; or short-term versus long-term under sick leave. Sourced from Workday HCM Absence Management leave plan configuration.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Classification of the leave request by category as defined in Workday HCM Absence Management. Common types include annual (vacation), sick, parental, unpaid, FMLA (Family and Medical Leave Act), and bereavement. [ENUM-REF-CANDIDATE: annual|sick|parental|unpaid|fmla|bereavement|jury_duty|military|sabbatical|personal — promote to reference product]' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificationReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Received' ;
    rdfs:comment 'Indicates whether the required medical certification or documentation has been received and validated by HR. Null or False when medical_certification_required is False. Supports FMLA compliance tracking and leave approval gating.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Required' ;
    rdfs:comment 'Indicates whether a medical certificate or healthcare provider documentation is required to support this leave request (e.g., for extended sick leave or FMLA qualifying events). Drives HR compliance workflows in Workday HCM.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Requested Duration Days' ;
    rdfs:comment 'Total number of working days requested for the leave period, as calculated by Workday HCM based on the employee\'s work schedule and calendar. Supports capacity planning and leave balance deduction calculations.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested End Date' ;
    rdfs:comment 'The last calendar date of the leave period as requested by the employee. Combined with requested_start_date to determine the total requested leave duration.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'The first calendar date of the leave period as requested by the employee. Used for scheduling, capacity planning, and project allocation impact assessment in Workfront.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resourceImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Resource Impact Assessment' ;
    rdfs:comment 'Assessment of the operational impact this leave request has on active campaign projects and resource allocations in Workfront. Levels range from none (no active project assignments) to critical (key FTE on active campaign delivery). Informs backfill and freelancer sourcing decisions.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'The confirmed or expected date on which the employee is scheduled to return to active work following the leave period. Critical for resource availability calculations in Workfront and capacity planning for campaign and production teams.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workdayAbsenceRequestReference rdf:type rdf:Property ;
    rdfs:label 'Workday Absence Request Reference' ;
    rdfs:comment 'The externally-known unique identifier assigned by Workday HCM Absence Management to this leave request. Used for cross-system traceability and reconciliation with the source system of record.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerType rdf:type rdf:Property ;
    rdfs:label 'Worker Type' ;
    rdfs:comment 'Classification of the employee\'s engagement type within the agency workforce as defined in Workday HCM. Determines applicable leave entitlements, payroll treatment, and regulatory compliance requirements (e.g., FMLA eligibility for FTEs). [ENUM-REF-CANDIDATE: fte|freelancer|contractor|influencer|actor|photographer|director|production_crew — promote to reference product]' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent organizational unit in the agency hierarchy. Enables traversal of the full organizational tree for headcount, financial, and capacity roll-ups.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryOrgWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Org Worker Id' ;
    rdfs:comment 'Identifier of the employee who is the designated manager or head of this organizational unit. References the talent/employee entity for reporting line and org chart construction.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:tertiaryOrgManagerEmployeeWorkerId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Org Manager Employee Worker Id' ;
    rdfs:comment 'FK to talent.worker' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:annualBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Usd' ;
    rdfs:comment 'The total annual operating budget allocated to this organizational unit in US dollars for the current fiscal year. Used for P&L management, EBITDA tracking, and QBR financial reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Approved Headcount' ;
    rdfs:comment 'The total approved headcount (FTE plus contractors and freelancers) authorized for this organizational unit in the current fiscal period. Distinct from actual FTE count; used for budget and capacity gap analysis.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUtilizationTargetPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Target Pct' ;
    rdfs:comment 'The target resource utilization rate (as a percentage) for this organizational unit, representing the proportion of available FTE hours expected to be allocated to billable or productive work. Used in Workfront resource planning.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataPrivacyRegion rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Region' ;
    rdfs:comment 'The primary data privacy regulatory framework applicable to this organizational unit based on its operating jurisdiction (e.g., GDPR for EU-based units, CCPA for California-based units). Governs data handling and consent management practices.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReportingFlag rdf:type rdf:Property ;
    rdfs:label 'External Reporting Flag' ;
    rdfs:comment 'Indicates whether this organizational unit\'s performance metrics and financials are included in external client-facing reporting, QBR presentations, or regulatory submissions to bodies such as the FTC or ASA.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headCountFte rdf:type rdf:Property ;
    rdfs:label 'Head Count Fte' ;
    rdfs:comment 'The current approved Full-Time Equivalent (FTE) headcount for this organizational unit as maintained in Workday HCM. Used for capacity planning, resource utilization, and workforce analytics.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Free-text narrative description of the organizational unit\'s mandate, scope of services, and primary business functions within the agency (e.g., \'Responsible for all programmatic media buying and DSP/SSP management for North American clients\').' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broad geographic region classification for the organizational unit. Used for regional performance reporting, media planning alignment, and multi-market campaign resource allocation.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorganizationDate rdf:type rdf:Property ;
    rdfs:label 'Reorganization Date' ;
    rdfs:comment 'The date of the most recent organizational restructuring event affecting this unit (e.g., merger with another department, split into sub-units, reclassification of discipline). Supports change management and audit trails.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sharedServicesFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Services Flag' ;
    rdfs:comment 'Indicates whether this organizational unit operates as a shared services center providing support across multiple client accounts or practice groups (e.g., centralized analytics, production services, finance operations).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sowOwnershipFlag rdf:type rdf:Property ;
    rdfs:label 'Sow Ownership Flag' ;
    rdfs:comment 'Indicates whether this organizational unit is designated as the primary owner and delivery accountable party for client Statements of Work (SOWs). Used in account management and contract attribution.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the organizational unit across agency systems. Used in financial reporting, headcount roll-ups, and resource planning integrations (e.g., Workfront, SAP S/4HANA CO).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full human-readable name of the organizational unit as defined in Workday HCM (e.g., \'Creative Studio – North America\', \'Programmatic Media Buying\', \'Analytics & Audience Insights\').' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. \'active\' indicates the unit is operational; \'dissolved\' indicates it has been disbanded; \'restructuring\' indicates it is undergoing reorganization.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classifies the organizational unit into its structural category within the agency hierarchy. [ENUM-REF-CANDIDATE: department|practice_group|discipline|cost_center|office|team|division — promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayOrgUnitReference rdf:type rdf:Property ;
    rdfs:label 'Workday Org Unit Reference' ;
    rdfs:comment 'The native identifier assigned to this organizational unit within Workday HCM organizational management module. Used for system-of-record cross-referencing and integration.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workfrontGroupReference rdf:type rdf:Property ;
    rdfs:label 'Workfront Group Reference' ;
    rdfs:comment 'The corresponding group or team identifier in Workfront project management and resource planning. Used to synchronize capacity planning, resource allocation, and WIP tracking between Workday HCM and Workfront.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Payroll Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each processed payroll record in the Workday HCM Payroll module. Primary key for the payroll_record data product. TRANSACTION_HEADER role — canonical entity for compensation disbursement history.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPayrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Original Payroll Record Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original payroll record that this record corrects or reverses. Null for original records. Enables audit trail reconstruction for payroll corrections and compliance investigations.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRecord .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Reference to the payroll run batch that generated this record. A single payroll run processes all eligible workers for a given pay period and company code.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:bankAccountLast4 rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last4' ;
    rdfs:comment 'Last four digits of the worker\'s bank account number to which direct deposit was made. Stored for reconciliation and worker inquiry resolution without exposing full account details. Full account data is managed in Workday HCM.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePayAmount rdf:type rdf:Property ;
    rdfs:label 'Base Pay Amount' ;
    rdfs:comment 'The fixed salary or hourly wage component of gross pay for the pay period, excluding variable compensation such as overtime, bonuses, and commissions. Used for FTE cost benchmarking and P&L labor cost analysis.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitsDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Benefits Deduction Amount' ;
    rdfs:comment 'Total employee-paid benefits contributions deducted in this pay period, including health insurance premiums, dental, vision, life insurance, and flexible spending account (FSA) contributions. Sourced from Workday HCM Benefits module elections.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Discretionary or performance-based bonus payment included in this pay period disbursement. May reflect campaign performance bonuses, new business win incentives, or annual performance awards tied to KPI achievement.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerTaxContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Tax Contribution' ;
    rdfs:comment 'Total employer-side payroll tax obligations for this worker in this pay period, including employer FICA (Social Security and Medicare match) and FUTA/SUTA contributions. Used for total labor cost reporting in SAP S/4HANA CO.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Federal Tax Withheld' ;
    rdfs:comment 'Amount of federal income tax withheld from the worker\'s gross pay in this pay period. Calculated based on the worker\'s W-4 elections and applicable IRS tax tables. Required for IRS Form W-2 and 941 reporting.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Pay Amount' ;
    rdfs:comment 'Total compensation earned by the worker before any deductions, taxes, or withholdings for the pay period. Includes base salary/wages, overtime, bonuses, commissions, and allowances. Core component of the MONETARY_TRIPLET for this transaction.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total regular hours worked by the worker during the pay period as recorded in Workday HCM Time Tracking or Workfront resource management. Used for hourly rate reconciliation, project cost allocation, and FLSA compliance.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOffCycle rdf:type rdf:Property ;
    rdfs:label 'Is Off Cycle' ;
    rdfs:comment 'Indicates whether this payroll record was generated as part of an off-cycle payroll run (e.g., termination pay, correction run, bonus payout) rather than the standard scheduled payroll cycle. Off-cycle runs require additional approval in Workday HCM.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicareTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax Withheld' ;
    rdfs:comment 'Employee portion of Medicare (HI) tax withheld in this pay period, including the Additional Medicare Tax for high earners where applicable. Required for IRS Form W-2 reporting.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayAmount rdf:type rdf:Property ;
    rdfs:label 'Net Pay Amount' ;
    rdfs:comment 'The take-home amount disbursed to the worker after all deductions, tax withholdings, and benefits contributions have been subtracted from gross pay. Represents the actual cash transferred to the worker. Core component of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of hours worked beyond the standard scheduled hours in the pay period that qualify for overtime pay. Sourced from Workday HCM Time Tracking. Required for FLSA compliance and production cost reporting.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePayAmount rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay Amount' ;
    rdfs:comment 'Compensation paid for hours worked beyond the standard work schedule in the pay period. Relevant for production crews, shoot days, and campaign crunch periods. Tracked separately for FLSA compliance and project cost allocation.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payDate rdf:type rdf:Property ;
    rdfs:label 'Pay Date' ;
    rdfs:comment 'The actual date on which compensation was disbursed to the worker. This is the BUSINESS_EVENT_TIMESTAMP (date-precision) for the payroll transaction — the real-world event date when funds were released.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'The cadence at which the worker is paid. Drives payroll run scheduling and annualization of compensation figures for P&L reporting and FTE cost analysis.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last calendar date of the pay period covered by this payroll record. Defines the closing boundary of the earnings window.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first calendar date of the pay period covered by this payroll record. Together with pay_period_end_date, defines the earnings window for gross pay calculation.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payRate rdf:type rdf:Property ;
    rdfs:label 'Pay Rate' ;
    rdfs:comment 'The worker\'s compensation rate applicable for this pay period — expressed as hourly rate for non-exempt workers or as the annualized salary divided by pay periods for exempt employees. Sourced from Workday HCM Compensation module.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateType rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Type' ;
    rdfs:comment 'Indicates whether the worker\'s compensation is structured as an hourly rate, fixed salary, daily rate (common for freelancers and production crew), or project-based flat rate. Determines how pay_rate is applied to calculate base_pay_amount.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollNumber rdf:type rdf:Property ;
    rdfs:label 'Payroll Number' ;
    rdfs:comment 'Externally-known business identifier for this payroll record, formatted as PR-{YYYY}-{MM}-{sequence}. Used for reconciliation with SAP S/4HANA FI/CO postings and Mediaocean Prisma billing reconciliation.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Status' ;
    rdfs:comment 'Current lifecycle state of this payroll record within the payroll processing workflow. Tracks progression from initial calculation through final disbursement or reversal. LIFECYCLE_STATUS for this TRANSACTION_HEADER entity.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Retirement Contribution Amount' ;
    rdfs:comment 'Employee pre-tax or Roth retirement plan contribution (e.g., 401(k), 403(b)) deducted from gross pay in this pay period. Tracked separately from other benefits deductions for IRS Form W-2 Box 12 reporting.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax Withheld' ;
    rdfs:comment 'Employee portion of Social Security (OASDI) tax withheld in this pay period. Calculated at the statutory rate on wages up to the annual wage base. Required for IRS Form W-2 reporting.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'State Tax Withheld' ;
    rdfs:comment 'Amount of state income tax withheld from the worker\'s gross pay in this pay period. Varies by state of employment. Relevant for agencies with multi-state operations and talent working across production locations.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Deductions Amount' ;
    rdfs:comment 'Aggregate of all pre-tax and post-tax deductions applied in this pay period, including benefits contributions, garnishments, and voluntary deductions. Represents the adjustment component of the MONETARY_TRIPLET (gross_pay_amount minus total_deductions_amount yields net_pay_amount).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdGrossPay rdf:type rdf:Property ;
    rdfs:label 'Ytd Gross Pay' ;
    rdfs:comment 'Cumulative gross pay earned by the worker from the start of the calendar year through this pay period. Required for W-2 preparation, Social Security wage base tracking, and annual compensation reporting.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Ytd Tax Withheld' ;
    rdfs:comment 'Cumulative total of all federal, state, and local taxes withheld from the worker\'s pay from the start of the calendar year through this pay period. Required for W-2 preparation and tax reconciliation.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique surrogate identifier for each formal talent performance evaluation record in the Workday HCM Talent Management module.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Worker Id' ;
    rdfs:comment 'Reference to the talent record of the employee being evaluated in this performance review cycle.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:reviewerWorkerId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Worker Id' ;
    rdfs:comment 'Reference to the talent record of the manager or designated reviewer who conducted and submitted this performance evaluation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:calibratedRating rdf:type rdf:Property ;
    rdfs:label 'Calibrated Rating' ;
    rdfs:comment 'The final performance rating assigned after the HR calibration session, which may differ from the reviewer\'s initial overall_rating. This is the authoritative rating used for compensation and talent decisions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientServiceCompetencyScore rdf:type rdf:Property ;
    rdfs:label 'Client Service Competency Score' ;
    rdfs:comment 'Numeric score for the client service and account management competency dimension, reflecting the employee\'s effectiveness in managing client relationships, QBRs, and SOW delivery.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collaborationScore rdf:type rdf:Property ;
    rdfs:label 'Collaboration Score' ;
    rdfs:comment 'Numeric score for the collaboration and teamwork competency dimension, assessing cross-functional cooperation across campaign, media, creative, and analytics teams.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competencyScoreAvg rdf:type rdf:Property ;
    rdfs:label 'Competency Score Avg' ;
    rdfs:comment 'Average numeric score across all evaluated competency dimensions (e.g., strategic thinking, client service, creative excellence, collaboration, leadership) for this review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creativeExcellenceScore rdf:type rdf:Property ;
    rdfs:label 'Creative Excellence Score' ;
    rdfs:comment 'Numeric score for the creative excellence competency dimension, evaluating the quality, originality, and effectiveness of creative output produced during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentAreasSummary rdf:type rdf:Property ;
    rdfs:label 'Development Areas Summary' ;
    rdfs:comment 'Narrative text identifying the employee\'s key development areas, skill gaps, and recommended improvement actions for the next review period, as documented by the reviewer.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalAnalyticsScore rdf:type rdf:Property ;
    rdfs:label 'Digital Analytics Score' ;
    rdfs:comment 'Numeric score for the digital marketing and data analytics competency dimension, reflecting proficiency in performance optimization, DSP/SSP platforms, ROAS analysis, and data-driven decision-making.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Date' ;
    rdfs:comment 'The date on which the employee formally acknowledged receipt and review of their performance evaluation in Workday HCM. Null if not yet acknowledged.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment' ;
    rdfs:comment 'Free-text self-evaluation submitted by the employee prior to the manager review, capturing their own perspective on goal attainment, contributions, and development needs.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAttainmentScore rdf:type rdf:Property ;
    rdfs:label 'Goal Attainment Score' ;
    rdfs:comment 'Percentage or weighted score (0.00–100.00) reflecting the degree to which the employee achieved their defined KPI and business goals during the review period, as assessed in Workday HCM.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goalsAchievedCount rdf:type rdf:Property ;
    rdfs:label 'Goals Achieved Count' ;
    rdfs:comment 'Number of formally defined performance goals that the employee fully achieved during the review period, as assessed by the reviewer in Workday HCM.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalsSetCount rdf:type rdf:Property ;
    rdfs:label 'Goals Set Count' ;
    rdfs:comment 'Total number of formal performance goals established for the employee at the start of or during the review period, as recorded in Workday HCM goal management.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadershipCompetencyScore rdf:type rdf:Property ;
    rdfs:label 'Leadership Competency Score' ;
    rdfs:comment 'Numeric score for the leadership and people management competency dimension, assessing the employee\'s ability to inspire, direct, and develop team members on campaigns and accounts.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meritIncreasePct rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Pct' ;
    rdfs:comment 'Recommended merit salary increase expressed as a percentage of the employee\'s current base compensation. Populated only when merit_increase_recommended is True and subject to HR calibration approval.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meritIncreaseRecommended rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Recommended' ;
    rdfs:comment 'Indicates whether the reviewing manager has recommended a merit-based salary increase for the employee as an outcome of this performance review, subject to compensation calibration.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'The holistic performance rating assigned to the employee for the review period, reflecting aggregate assessment across all competencies and goals. Sourced from Workday HCM rating scale. [ENUM-REF-CANDIDATE: exceptional|exceeds_expectations|meets_expectations|needs_improvement|unsatisfactory — promote to reference product if rating scale changes]' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score corresponding to the overall performance rating on the agency\'s defined scale (e.g., 1.00–5.00), enabling quantitative ranking, trend analysis, and compensation calibration.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipRequired rdf:type rdf:Property ;
    rdfs:label 'Pip Required' ;
    rdfs:comment 'Indicates whether a formal Performance Improvement Plan (PIP) has been initiated as a result of this review, typically triggered by an unsatisfactory or needs_improvement overall rating.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionRecommended rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommended' ;
    rdfs:comment 'Indicates whether the reviewing manager has formally recommended the employee for promotion to a higher job level or title as an outcome of this performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionTargetLevel rdf:type rdf:Property ;
    rdfs:label 'Promotion Target Level' ;
    rdfs:comment 'The proposed job level or title to which the employee is recommended for promotion (e.g., Senior Account Manager, Associate Creative Director). Populated only when promotion_recommended is True.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Externally-known business identifier for this performance review record, used in HR correspondence, audit trails, and Workday HCM reference. Format: PR-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The last date of the performance evaluation period being assessed in this review (e.g., 2024-12-31 for an annual review covering calendar year 2024).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'The first date of the performance evaluation period being assessed in this review (e.g., 2024-01-01 for an annual review covering calendar year 2024).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewTemplateVersion rdf:type rdf:Property ;
    rdfs:label 'Review Template Version' ;
    rdfs:comment 'Version identifier of the performance review template used in Workday HCM for this evaluation (e.g., v2024.1), enabling tracking of template changes and ensuring consistent year-over-year comparisons.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the review cycle type: annual (full-year evaluation), mid_year (half-year check-in), probationary (new hire or role transition), project_based (post-campaign or project completion), or pip (Performance Improvement Plan review). [ENUM-REF-CANDIDATE: annual|mid_year|probationary|project_based|pip|ad_hoc — promote to reference product if additional types are added]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Narrative text summarizing the employee\'s key strengths and notable achievements during the review period, as documented by the reviewer in Workday HCM.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionCandidate rdf:type rdf:Property ;
    rdfs:label 'Succession Candidate' ;
    rdfs:comment 'Indicates whether the employee has been identified as a succession candidate for a critical role within the agency as an outcome of this performance review cycle.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentSegment rdf:type rdf:Property ;
    rdfs:label 'Talent Segment' ;
    rdfs:comment 'HR talent segmentation classification assigned to the employee as an outcome of this review and calibration, used for succession planning, retention strategy, and FTE investment decisions. [ENUM-REF-CANDIDATE: high_potential|key_talent|core_talent|developing|at_risk — promote to reference product]' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Id' ;
    rdfs:comment 'Reference to the active job requisition in Workday HCM Recruiting associated with filling this open position. Links position management to the talent acquisition workflow.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Acquisition .

ind:headcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Id' ;
    rdfs:comment 'Reference to the annual or quarterly headcount plan under which this position was authorized. Links to the agency\'s workforce planning cycle in SAP S/4HANA or Workday HCM.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityPlan .

ind:incumbentWorkerId rdf:type rdf:Property ;
    rdfs:label 'Incumbent Worker Id' ;
    rdfs:comment 'Foreign key linking to talent.worker. Business justification: Position can be filled by a worker (the incumbent). This is the current occupant of the position. One position has one current incumbent; one worker can hold one primary position at a time. The FK col' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Reference to the standardized Workday HCM job profile that defines the competencies, qualifications, and pay range associated with this position. Enables consistent role definition across the agency.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:positionOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Position Org Unit Id' ;
    rdfs:comment 'Reference to the agency department to which this position belongs (e.g., Creative, Media, Account Management, Analytics, PR). Links to the department master in Workday HCM.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:positionSupervisoryOrgOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Position Supervisory Org Org Unit Id' ;
    rdfs:comment 'Reference to the Workday HCM supervisory organization unit that owns this position. Defines the management hierarchy and reporting structure within the agency.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Self-referencing identifier of the parent position in the organizational hierarchy to which this position reports. Enables org chart traversal, span-of-control analysis, and management reporting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:availableForOverlap rdf:type rdf:Property ;
    rdfs:label 'Available For Overlap' ;
    rdfs:comment 'Indicates whether the position allows an overlap period where both an outgoing and incoming worker can be simultaneously active. True = overlap permitted; False = single occupancy only. Supports transition planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetedAnnualSalary rdf:type rdf:Property ;
    rdfs:label 'Budgeted Annual Salary' ;
    rdfs:comment 'The approved annual salary budget allocated for this position in the agency headcount plan. Used for P&L, EBITDA reporting, and budget reconciliation in SAP S/4HANA. Expressed in the agency\'s base currency.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Nature of the employment arrangement for the position — full-time, part-time, fixed-term, or casual. Distinct from worker_type; governs scheduling, benefits, and labor law compliance.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteCapacity rdf:type rdf:Property ;
    rdfs:label 'Fte Capacity' ;
    rdfs:comment 'The authorized FTE capacity of the position expressed as a decimal (e.g., 1.0 = full-time, 0.5 = half-time). Used for resource planning, capacity planning, and FTE headcount reporting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBudgeted rdf:type rdf:Property ;
    rdfs:label 'Is Budgeted' ;
    rdfs:comment 'Indicates whether this position has an approved budget allocation in the agency\'s annual headcount plan. True = budgeted; False = unbudgeted or pending approval. Used for P&L and EBITDA reporting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCriticalRole rdf:type rdf:Property ;
    rdfs:label 'Is Critical Role' ;
    rdfs:comment 'Flags whether this position is designated as a critical or key role within the agency\'s talent strategy. Critical roles receive priority in succession planning and talent acquisition pipelines.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFilled rdf:type rdf:Property ;
    rdfs:label 'Is Filled' ;
    rdfs:comment 'Indicates whether the position is currently occupied by an active worker. True = filled; False = vacant. Supports headcount gap analysis and capacity planning in Workfront resource management.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broad grouping of related job functions within the agency (e.g., Creative, Media, Client Services, Technology, Finance, Operations). Used for compensation benchmarking, career pathing, and workforce analytics in Workday HCM.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxIncumbents rdf:type rdf:Property ;
    rdfs:label 'Max Incumbents' ;
    rdfs:comment 'The maximum number of workers that can simultaneously occupy this position. Typically 1 for standard positions; may be greater for shared or pooled roles. Enforced in Workday HCM position restrictions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Compensation grade or band assigned to the position, defining the salary range and benefits tier. Confidential business data used for compensation benchmarking and P&L management. Sourced from Workday HCM compensation structure.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the position as assigned in Workday HCM (e.g., POS-ART001). Used for cross-system referencing, reporting, and integration with Workfront resource management.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle state of the position within the agency headcount plan. Open = authorized and vacant; Filled = occupied by a worker; Frozen = authorized but hiring suspended; Eliminated = decommissioned; Proposed = pending budget approval.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Standard Hours Per Week' ;
    rdfs:comment 'The standard contracted working hours per week for this position. Used for time tracking, capacity planning, and overtime compliance in Workday HCM and Workfront resource management.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFillDate rdf:type rdf:Property ;
    rdfs:label 'Target Fill Date' ;
    rdfs:comment 'The target date by which an open position should be filled. Used by talent acquisition teams to track recruiting timelines and manage agency capacity gaps.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workArrangement rdf:type rdf:Property ;
    rdfs:label 'Work Arrangement' ;
    rdfs:comment 'The approved work arrangement for the position — on-site, remote, or hybrid. Reflects post-pandemic workforce policies and impacts resource planning and office capacity management.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayPositionReference rdf:type rdf:Property ;
    rdfs:label 'Workday Position Reference' ;
    rdfs:comment 'The native position identifier from the Workday HCM source system. Used for system-of-record traceability, ETL reconciliation, and integration with Workfront resource management.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workfrontRoleReference rdf:type rdf:Property ;
    rdfs:label 'Workfront Role Reference' ;
    rdfs:comment 'The corresponding job role identifier in Workfront resource management that maps to this position. Enables cross-system resource allocation, capacity planning, and project staffing.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceAllocationId rdf:type rdf:Property ;
    rdfs:label 'Resource Allocation Id' ;
    rdfs:comment 'Unique system-generated identifier for each resource allocation record. Serves as the primary key for the resource_allocation data product in the talent domain. Entity role: TRANSACTION_HEADER — represents a discrete booking/assignment event with a clear lifecycle (tentative through released).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResourceAllocation .

ind:primaryResourceProjectAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Resource Project Assignment Id' ;
    rdfs:comment 'The native assignment or resource pool record identifier from Workfront, used for system-of-record traceability and data lineage back to the source project management system.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectAssignment .

ind:allocatedHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Allocated Hours Per Week' ;
    rdfs:comment 'The number of hours per week the worker is allocated to this project or campaign. Used for capacity planning, utilization tracking, and resource conflict detection. Typically ranges from 0.00 to 40.00 for FTE workers.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally-known business identifier for the allocation record, used in Workfront and cross-system references. Format: RA-{YYYY}-{NNNNNN}. Serves as the BUSINESS_IDENTIFIER for this transaction header.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingType rdf:type rdf:Property ;
    rdfs:label 'Booking Type' ;
    rdfs:comment 'Indicates the commitment level of the resource booking. Hard Book: firm, committed allocation; Soft Book: provisional hold subject to confirmation; Option: first right of refusal on the worker\'s availability. Critical for production scheduling and talent management.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callTime rdf:type rdf:Property ;
    rdfs:label 'Call Time' ;
    rdfs:comment 'For production shoot assignments: the scheduled time the worker is required to report to the set or location (call time). Null for non-production office-based assignments. Critical for production crew scheduling and logistics.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crewRoleDesignation rdf:type rdf:Property ;
    rdfs:label 'Crew Role Designation' ;
    rdfs:comment 'For production shoot assignments: the specific on-set crew role designation (e.g., Director of Photography, Gaffer, Key Grip, Production Assistant, Makeup Artist, Wardrobe Stylist). More granular than worker_role and specific to production context. Null for non-production assignments. [ENUM-REF-CANDIDATE: director_of_photography|gaffer|key_grip|production_assistant|makeup_artist|wardrobe_stylist|sound_mixer|camera_operator — promote to reference product]' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shootLocation rdf:type rdf:Property ;
    rdfs:label 'Shoot Location' ;
    rdfs:comment 'For production shoot assignments: the physical location or studio address where the production takes place (e.g., \'Studio A - Soho, NYC\', \'Location: Malibu Beach, CA\'). Null for office-based project work. Used for crew logistics and travel planning.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAllocatedHours rdf:type rdf:Property ;
    rdfs:label 'Total Allocated Hours' ;
    rdfs:comment 'The total number of hours allocated for the entire duration of this assignment (from start_date to end_date). Calculated at booking time and stored for scheduling and billing purposes. Distinct from allocated_hours_per_week which is the weekly rate.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Target Percentage' ;
    rdfs:comment 'The target billable utilization percentage for this worker on this allocation, as set by resource management. Used to measure actual vs. planned utilization and inform capacity planning decisions. Distinct from allocation_percentage which reflects scheduled capacity.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wrapTime rdf:type rdf:Property ;
    rdfs:label 'Wrap Time' ;
    rdfs:comment 'For production shoot assignments: the scheduled time the worker is expected to complete their duties and wrap for the day. Null for non-production assignments. Used for crew scheduling, overtime calculation, and production logistics.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:candidateId rdf:type rdf:Property ;
    rdfs:label 'Candidate Id' ;
    rdfs:comment 'Reference to the candidate profile record associated with this talent acquisition pipeline entry. Links to the candidate master record in the talent domain.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Candidate .

ind:hiringOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Hiring Org Unit Id' ;
    rdfs:comment 'Foreign key linking to talent.org_unit. Business justification: Talent acquisition requisition is for a position within a specific organizational unit. One requisition targets one org_unit; one org_unit can have many requisitions over time. This links the recruitm' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Reference to the parent job requisition that initiated this talent acquisition record. Links to the requisition that authorized the open headcount.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:agencyFeePct rdf:type rdf:Property ;
    rdfs:label 'Agency Fee Pct' ;
    rdfs:comment 'Agreed fee percentage of the hired candidate\'s first-year base salary payable to the external staffing agency upon successful placement. Used for cost-per-hire calculation and vendor cost management.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Name of the external staffing or executive search agency engaged to source candidates for this requisition, if applicable. Null for direct-sourced or internally recruited positions.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date on which the candidate submitted their application for the position. Marks the entry point of the candidate into the recruiting pipeline for this requisition.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedHeadcountCount rdf:type rdf:Property ;
    rdfs:label 'Approved Headcount Count' ;
    rdfs:comment 'Number of approved positions authorized under this requisition. Most requisitions are for a single hire, but bulk requisitions for production crews, campaign teams, or seasonal staff may authorize multiple hires.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the offered compensation amounts. Required for multi-currency agencies operating across global markets. Examples: USD, GBP, EUR.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Reason recorded when a candidate declines an offer or is rejected during the pipeline. Examples include \'Compensation Below Expectation\', \'Accepted Competing Offer\', \'Skills Mismatch\', \'Culture Fit\'. Used for pipeline quality analysis and offer competitiveness benchmarking. [ENUM-REF-CANDIDATE: Compensation Below Expectation|Accepted Competing Offer|Skills Mismatch|Culture Fit|Role Changed|Candidate Withdrew|Failed Assessment — promote to reference product]' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountType rdf:type rdf:Property ;
    rdfs:label 'Headcount Type' ;
    rdfs:comment 'Classification of whether this requisition represents a replacement for a departing employee (Backfill), a net-new addition to the team (New Headcount), a conversion from contractor to FTE (Conversion), or a role upgrade/reclassification (Upgrade). Drives budget approval workflows.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewRoundsCount rdf:type rdf:Property ;
    rdfs:label 'Interview Rounds Count' ;
    rdfs:comment 'Total number of interview rounds completed for this candidate on this requisition. Used to measure interview process efficiency and candidate experience quality.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRemoteEligible rdf:type rdf:Property ;
    rdfs:label 'Is Remote Eligible' ;
    rdfs:comment 'Indicates whether the position is eligible for fully remote or hybrid work arrangements. Relevant for talent pool expansion and workforce flexibility planning in the advertising industry.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Seniority level of the open position within the agency\'s career framework. Drives compensation banding, approval workflows, and resource planning capacity calculations. [ENUM-REF-CANDIDATE: Junior|Mid-Level|Senior|Lead|Manager|Director|VP|C-Suite — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'Date on which the formal employment offer was extended to the candidate. Used to calculate offer-to-acceptance cycle time and to track offer expiry.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Offer Expiry Date' ;
    rdfs:comment 'Date by which the candidate must accept or decline the offer. After this date, the offer is automatically rescinded if no response is received.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current status of the employment offer extended to the candidate. Tracks the offer lifecycle from issuance through acceptance or decline. Critical for headcount forecasting and onboarding planning.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeredBaseSalary rdf:type rdf:Property ;
    rdfs:label 'Offered Base Salary' ;
    rdfs:comment 'Annual base salary amount offered to the candidate in the employment offer. Expressed in the local currency of the office location. Sensitive compensation data used in offer approval workflows and P&L headcount cost planning.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offeredBonusTargetPct rdf:type rdf:Property ;
    rdfs:label 'Offered Bonus Target Pct' ;
    rdfs:comment 'Target annual bonus as a percentage of base salary included in the offer. Reflects the variable compensation component of the total compensation package offered to the candidate.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the candidate in the recruiting pipeline as tracked in Workday HCM. Represents the candidate\'s progression from application through onboarding. Drives recruiter workflow and hiring velocity reporting. [ENUM-REF-CANDIDATE: Applied|Screening|Interview|Assessment|Offer|Onboarding|Withdrawn|Rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingChannel rdf:type rdf:Property ;
    rdfs:label 'Posting Channel' ;
    rdfs:comment 'Primary external channel on which the job was posted to attract candidates. Examples include \'LinkedIn\', \'Indeed\', \'Glassdoor\', \'Agency Website\', \'Industry Boards (4As, ANA)\'. Distinct from source_of_hire which tracks where the hired candidate originated. [ENUM-REF-CANDIDATE: LinkedIn|Indeed|Glassdoor|Agency Website|4As Job Board|ANA Job Board|Campus Portal|Internal Portal — promote to reference product]' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruiterName rdf:type rdf:Property ;
    rdfs:label 'Recruiter Name' ;
    rdfs:comment 'Name of the internal recruiter or talent acquisition specialist assigned to manage this requisition and candidate pipeline. Used for workload distribution and recruiter performance reporting.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionCloseDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Close Date' ;
    rdfs:comment 'Date on which the requisition was formally closed, either because the position was filled, cancelled, or put on indefinite hold. Used to calculate time-to-fill metrics.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Externally visible, human-readable requisition number assigned by Workday HCM at the time the job requisition is created. Used in communications with candidates, agencies, and job boards.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionOpenDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Open Date' ;
    rdfs:comment 'Date on which the job requisition was formally opened and approved for recruiting. Used as the start point for time-to-fill and time-to-hire KPI calculations.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the job requisition. Tracks whether the headcount need is actively being recruited against, paused, or resolved. Used in open headcount reporting and budget reconciliation.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryBandMax rdf:type rdf:Property ;
    rdfs:label 'Salary Band Max' ;
    rdfs:comment 'Maximum of the approved compensation band for this job level and family. Used to validate that the offered salary falls within the approved range and to support pay equity analysis.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryBandMin rdf:type rdf:Property ;
    rdfs:label 'Salary Band Min' ;
    rdfs:comment 'Minimum of the approved compensation band for this job level and family. Used to validate that the offered salary falls within the approved range and to support pay equity analysis.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceOfHire rdf:type rdf:Property ;
    rdfs:label 'Source Of Hire' ;
    rdfs:comment 'Channel or method through which the candidate was sourced. Examples include \'LinkedIn\', \'Employee Referral\', \'Agency\', \'Job Board\', \'Direct Application\', \'Campus Recruiting\'. Used to measure recruiting channel effectiveness and cost-per-hire by source. [ENUM-REF-CANDIDATE: LinkedIn|Employee Referral|Staffing Agency|Job Board|Direct Application|Campus Recruiting|Internal Transfer|Social Media — promote to reference product]' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Planned date on which the hired candidate is expected to begin employment. Used for onboarding scheduling, resource capacity planning in Workfront, and campaign staffing alignment.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'Candidate\'s legal authorization to work in the country of the office location. Determines whether visa sponsorship is required and impacts time-to-start planning. Relevant for global advertising agencies with international talent pools.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTalentWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Talent Worker Id' ;
    rdfs:comment 'Reference to the parent worker identity record (employee, freelancer, contractor, influencer, actor, photographer, director, or crew member). This profile is distinct from the identity record and captures professional capability dimensions.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:audiencePrimaryAgeRange rdf:type rdf:Property ;
    rdfs:label 'Audience Primary Age Range' ;
    rdfs:comment 'The dominant age demographic of the influencer\'s audience, used for campaign audience targeting alignment and media planning. Sourced from platform analytics dashboards. Applicable to influencer talent type only.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audiencePrimaryGender rdf:type rdf:Property ;
    rdfs:label 'Audience Primary Gender' ;
    rdfs:comment 'The dominant gender composition of the influencer\'s audience (male, female, or mixed when no single gender exceeds 60%). Used for campaign audience alignment and GRP/TRP planning. Applicable to influencer talent type only.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardCount rdf:type rdf:Property ;
    rdfs:label 'Award Count' ;
    rdfs:comment 'Total number of industry awards won by the talent (e.g., Cannes Lions, Clio Awards, D&AD, One Show, Effie Awards). Used as a market-value indicator for talent positioning, new business pitches, and rate negotiations.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Capacity Hours Per Week' ;
    rdfs:comment 'Standard weekly available hours for campaign work, used in Workfront resource planning and FTE (Full-Time Equivalent) capacity calculations. For part-time or fractional workers, reflects contracted hours.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'The earliest expiry date among the talent\'s active certifications. Used to trigger renewal workflows and ensure compliance with client contractual requirements for certified practitioners.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifications rdf:type rdf:Property ;
    rdfs:label 'Certifications' ;
    rdfs:comment 'Pipe-delimited list of active professional certifications held by the talent (e.g., Google Ads Certified|IAB Digital Media Buying|Meta Blueprint|The Trade Desk Edge Academy|HubSpot Inbound). Used for compliance verification and capability credentialing.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentNiche rdf:type rdf:Property ;
    rdfs:label 'Content Niche' ;
    rdfs:comment 'The primary content category or vertical the influencer creates content in (e.g., beauty, fitness, gaming, finance, travel, food, fashion, technology, parenting). Used for brand-audience alignment and campaign targeting strategy. [ENUM-REF-CANDIDATE: beauty|fitness|gaming|finance|travel|food|fashion|technology|parenting|lifestyle — promote to reference product]' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayRateUsd rdf:type rdf:Property ;
    rdfs:label 'Day Rate Usd' ;
    rdfs:comment 'The standard daily billing rate for the talent in US Dollars. Used for project cost estimation, SOW budgeting, and P&L management. For FTE employees, this is the internal cost rate; for freelancers and contractors, this is the contracted rate.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'The professional or stage name by which the talent is known in the market and on creative briefs, campaign credits, and influencer contracts. May differ from legal name on the worker identity record.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRate rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate' ;
    rdfs:comment 'Average engagement rate (likes + comments + shares divided by impressions or followers) across the influencer\'s primary platform, expressed as a decimal (e.g., 0.0325 = 3.25%). A key KPI for influencer selection and CPM/CPA rate negotiation. Applicable to influencer talent type only.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Expiry Date' ;
    rdfs:comment 'The date on which the current exclusivity restriction expires, enabling the talent to work with competing brands. Used to trigger availability alerts and plan future campaign assignments.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityRestrictions rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Restrictions' ;
    rdfs:comment 'Description of any active brand category exclusivity restrictions on the talent (e.g., \'exclusive to automotive category through 2025-12-31\', \'no competing beverage brands\'). Critical for conflict-of-interest checks during campaign staffing and IO execution. Applicable primarily to influencer and on-screen talent.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:influencerTier rdf:type rdf:Property ;
    rdfs:label 'Influencer Tier' ;
    rdfs:comment 'Industry-standard tier classification for influencer talent based on total follower count across platforms: nano (<10K), micro (10K–100K), macro (100K–1M), mega (>1M). Drives influencer rate card selection, campaign eligibility, and brand partnership strategy. Null for non-influencer talent types.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instagramHandle rdf:type rdf:Property ;
    rdfs:label 'Instagram Handle' ;
    rdfs:comment 'The talent\'s Instagram social media handle (username prefixed with @). Used for influencer campaign trafficking, audience verification, and platform-specific performance tracking. Applicable to influencer talent type only.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCapabilities rdf:type rdf:Property ;
    rdfs:label 'Language Capabilities' ;
    rdfs:comment 'Pipe-delimited list of languages the talent can work in professionally, using ISO 639-1 codes (e.g., en|es|fr|de|zh). Essential for multilingual campaign staffing and international client servicing.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaChannelExpertise rdf:type rdf:Property ;
    rdfs:label 'Media Channel Expertise' ;
    rdfs:comment 'Pipe-delimited list of media channels in which the talent has demonstrated expertise (e.g., SEM|programmatic|OOH|CTV|DOOH|social|print|radio). Used for campaign staffing and capability gap analysis. Stored as a delimited string per Silver Layer conventions; normalized in Gold Layer.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notableAwardNames rdf:type rdf:Property ;
    rdfs:label 'Notable Award Names' ;
    rdfs:comment 'Pipe-delimited list of the most significant industry awards won by the talent (e.g., Cannes Lions Gold|D&AD Black Pencil|Effie Gold). Used in agency credentials, pitch decks, and talent marketing materials.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notableBrandCredits rdf:type rdf:Property ;
    rdfs:label 'Notable Brand Credits' ;
    rdfs:comment 'Pipe-delimited list of notable brand or client names the talent has worked with in prior campaigns. Used for capability demonstration in new business pitches and talent positioning. Excludes current client names subject to confidentiality.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pastBrandPartnerships rdf:type rdf:Property ;
    rdfs:label 'Past Brand Partnerships' ;
    rdfs:comment 'Pipe-delimited list of notable past brand partnership names for influencer talent (e.g., Nike|L\'Oreal|Samsung). Used for brand alignment assessment, conflict-of-interest screening, and influencer credentialing in pitch materials.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioUrl rdf:type rdf:Property ;
    rdfs:label 'Portfolio Url' ;
    rdfs:comment 'URL to the talent\'s professional portfolio, showreel, or Digital Asset Management (DAM) collection in Workfront. Used during pitching, new business development, and talent acquisition evaluation.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDiscipline rdf:type rdf:Property ;
    rdfs:label 'Primary Discipline' ;
    rdfs:comment 'The principal creative or functional discipline of the talent (e.g., Art Direction, Copywriting, Motion Design, Media Planning, Programmatic Buying, Account Management, Photography, Film Direction). Used for resource planning and capability matching in Workfront. [ENUM-REF-CANDIDATE: art_direction|copywriting|motion_design|media_planning|programmatic_buying|account_management|photography|film_direction|strategy|data_analytics — promote to reference product]' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the talent\'s day rate (e.g., USD, GBP, EUR). Supports multi-currency rate management for international talent and global campaign staffing.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareProficiencies rdf:type rdf:Property ;
    rdfs:label 'Software Proficiencies' ;
    rdfs:comment 'Pipe-delimited list of software tools and platforms the talent is proficient in (e.g., Adobe CC|The Trade Desk|CM360|Salesforce|Workfront|Mediaocean Prisma|Google Analytics|DV360). Critical for project staffing and tool-specific campaign execution.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'Secondary or niche specialization within the primary discipline (e.g., CTV/OTT media buying, DOOH planning, SEM campaign management, influencer strategy, brand identity design). Enables granular capability matching for complex campaign requirements.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentType rdf:type rdf:Property ;
    rdfs:label 'Talent Type' ;
    rdfs:comment 'Categorical classification of the talent worker type, determining applicable rate cards, rights management rules, and compliance requirements. [ENUM-REF-CANDIDATE: employee|freelancer|contractor|influencer|actor|photographer|director|production_crew — promote to reference product]' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiktokHandle rdf:type rdf:Property ;
    rdfs:label 'Tiktok Handle' ;
    rdfs:comment 'The talent\'s TikTok social media handle. Used for influencer campaign trafficking, content verification, and short-form video performance analytics. Applicable to influencer talent type only.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFollowerCount rdf:type rdf:Property ;
    rdfs:label 'Total Follower Count' ;
    rdfs:comment 'Aggregate follower count across all active social media platforms for influencer talent. Used for influencer tier classification, CPM rate card assignment, and campaign reach estimation. Refreshed periodically from platform APIs.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageRightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Expiry Date' ;
    rdfs:comment 'The date on which the talent\'s current usage rights grant expires. After this date, creative assets featuring the talent may not be used without renegotiation. Triggers rights renewal workflows and asset retirement processes.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageRightsSummary rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Summary' ;
    rdfs:comment 'Summary of the talent\'s granted usage rights for creative assets produced (e.g., \'digital worldwide 2 years\', \'broadcast North America 1 year\', \'social media unlimited\'). Governs how produced creative assets may be deployed across channels and geographies. Critical for rights management and compliance.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xHandle rdf:type rdf:Property ;
    rdfs:label 'X Handle' ;
    rdfs:comment 'The talent\'s X (formerly Twitter) social media handle. Used for influencer campaign trafficking and social listening integration. Applicable to influencer talent type only.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of professional experience in the talent\'s primary discipline. Used for rate benchmarking, capability assessment, and talent acquisition scoring.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:youtubeChannelUrl rdf:type rdf:Property ;
    rdfs:label 'Youtube Channel Url' ;
    rdfs:comment 'The talent\'s YouTube channel URL. Used for influencer campaign trafficking, video content verification, and CTV/OTT audience analytics. Applicable to influencer talent type only.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentRateCardId rdf:type rdf:Property ;
    rdfs:label 'Talent Rate Card Id' ;
    rdfs:comment 'Unique surrogate identifier for each talent rate card record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationFeePct rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Pct' ;
    rdfs:comment 'Percentage of the agreed day rate or booking fee charged as a cancellation penalty if a booking is cancelled within the notice period defined in the associated contract or SOW. Used in financial reconciliation and dispute management.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelSpecialization rdf:type rdf:Property ;
    rdfs:label 'Channel Specialization' ;
    rdfs:comment 'The media or delivery channel for which this rate applies, reflecting the talent\'s area of expertise (e.g., digital, social, OOH, CTV, OTT, DOOH, print, radio, experiential). Enables channel-specific cost estimation in media planning and campaign budgeting. [ENUM-REF-CANDIDATE: digital|social|ooh|ctv|ott|dooh|print|radio|experiential|search|programmatic — promote to reference product]' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayRate rdf:type rdf:Property ;
    rdfs:label 'Day Rate' ;
    rdfs:comment 'Standard or negotiated billing rate per full working day for this talent role, seniority tier, and channel specialization. Used in SOW pricing, resource cost estimation, and Workday HCM payroll reconciliation. Serves as the principal MEASUREMENT_OR_VALUE for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:halfDayRate rdf:type rdf:Property ;
    rdfs:label 'Half Day Rate' ;
    rdfs:comment 'Billing rate for a half-day engagement (typically 4 hours). Used in production scheduling and SOW pricing where partial-day bookings are standard practice for talent such as photographers, directors, and actors.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'Standard or negotiated billing rate per hour for this talent role and tier. Used for partial-day engagements, time-tracking reconciliation in Workfront, and overtime calculations.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBookingHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Booking Hours' ;
    rdfs:comment 'Minimum number of hours that must be booked and billed for a single engagement under this rate card. Prevents under-billing for short engagements and is used in Workfront resource planning and SOW cost estimation.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'Multiplier applied to the hourly or day rate for overtime hours (e.g., 1.5 for time-and-a-half, 2.0 for double time). Used in payroll reconciliation and SOW cost estimation for production-heavy engagements.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Card Status' ;
    rdfs:comment 'Current lifecycle state of the rate card. \'draft\' indicates under review; \'active\' means currently in use for billing and SOW pricing; \'superseded\' means replaced by a newer version; \'expired\' means past effective end date; \'archived\' means retired from use. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTierType rdf:type rdf:Property ;
    rdfs:label 'Rate Tier Type' ;
    rdfs:comment 'Indicates whether this rate card represents a market-standard rate, a client-specific negotiated rate, a preferred vendor rate, a blended rate across seniority levels, or a custom negotiated rate. Drives which rate schedule is applied during SOW pricing and resource cost estimation.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'The functional role category this rate card applies to (e.g., Art Director, Copywriter, Media Planner, Account Manager, Director, Photographer, Motion Designer, Data Analyst, Producer). Serves as the primary CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE entity. [ENUM-REF-CANDIDATE: art_director|copywriter|media_planner|account_manager|director|photographer|motion_designer|data_analyst|producer|strategist|editor|developer — promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityTier rdf:type rdf:Property ;
    rdfs:label 'Seniority Tier' ;
    rdfs:comment 'Experience and seniority level associated with this rate card, used to differentiate billing rates and resource cost estimation in SOW pricing. Maps to Workday HCM compensation grade levels.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentCategory rdf:type rdf:Property ;
    rdfs:label 'Talent Category' ;
    rdfs:comment 'Broad workforce classification indicating the engagement model for the talent: Full-Time Equivalent (FTE) employee, freelancer, contractor, influencer, actor, or production crew. Drives payroll treatment, billing rules, and compliance obligations under GDPR/CCPA.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDayRate rdf:type rdf:Property ;
    rdfs:label 'Travel Day Rate' ;
    rdfs:comment 'Billing rate applicable for travel days when talent is in transit for production or client engagements. Typically a reduced rate versus the standard day rate, used in production crew and director rate cards.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageRightsDurationDays rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Duration Days' ;
    rdfs:comment 'Number of days for which usage rights are granted under this rate card. Relevant for talent categories such as actors, influencers, and photographers where time-limited usage rights are standard practice.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weeklyRate rdf:type rdf:Property ;
    rdfs:label 'Weekly Rate' ;
    rdfs:comment 'Negotiated flat weekly billing rate for sustained engagements, typically offering a discount versus the sum of five day rates. Used for long-term freelancer and contractor engagements in Workday HCM payroll.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workdayCompensationGrade rdf:type rdf:Property ;
    rdfs:label 'Workday Compensation Grade' ;
    rdfs:comment 'The compensation grade identifier from Workday HCM that this rate card maps to, enabling synchronization between the rate card schedule and the HR compensation structure for payroll reconciliation.' ;
    rdfs:domain ind:TalentRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Id' ;
    rdfs:comment 'Unique system-generated identifier for each timesheet record. Serves as the primary key for the timesheet entity in the Workday HCM Time Tracking module silver layer.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holidayCalendarId rdf:type rdf:Property ;
    rdfs:label 'Holiday Calendar Id' ;
    rdfs:comment 'Reference to the jurisdiction-specific holiday calendar applied to this timesheet for holiday hours identification and overtime rule application. Supports multi-jurisdiction time capture.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HolidayCalendar .

ind:originalTimesheetId rdf:type rdf:Property ;
    rdfs:label 'Original Timesheet Id' ;
    rdfs:comment 'For amended timesheets (is_amended = true), references the original timesheet record that this amendment supersedes. Null for original submissions. Supports audit trail and payroll adjustment reconciliation.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timesheet .

ind:timesheetWorkerId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Worker Id' ;
    rdfs:comment 'Reference to the worker (employee, freelancer, contractor, or production crew member) who submitted this timesheet. Links to the talent/worker master record in Workday HCM.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:billableHours rdf:type rdf:Property ;
    rdfs:label 'Billable Hours' ;
    rdfs:comment 'Total hours within this timesheet classified as billable to clients. Foundation for client invoicing, ROAS analysis, and agency utilization rate calculations.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holidayHours rdf:type rdf:Property ;
    rdfs:label 'Holiday Hours' ;
    rdfs:comment 'Total hours worked on public holidays within this pay period, as determined by the jurisdiction-specific holiday calendar. Used for holiday pay premium calculations.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAmended rdf:type rdf:Property ;
    rdfs:label 'Is Amended' ;
    rdfs:comment 'Indicates whether this timesheet is an amendment to a previously approved timesheet. Amended timesheets trigger payroll adjustment processing and client billing correction workflows.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLateSubmission rdf:type rdf:Property ;
    rdfs:label 'Is Late Submission' ;
    rdfs:comment 'Indicates whether the timesheet was submitted after the defined deadline for the pay period. Used for compliance monitoring, payroll delay risk management, and manager escalation workflows.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonBillableHours rdf:type rdf:Property ;
    rdfs:label 'Non Billable Hours' ;
    rdfs:comment 'Total hours within this timesheet classified as non-billable (internal meetings, training, admin, business development). Used for overhead cost analysis and FTE utilization benchmarking.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payPeriodType rdf:type rdf:Property ;
    rdfs:label 'Pay Period Type' ;
    rdfs:comment 'The frequency classification of the pay period covered by this timesheet. Determines payroll processing cadence and aligns with Workday HCM payroll group configurations.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Channel or interface through which the timesheet was submitted. Supports audit and system integration analysis. Values: web (Workday web portal), mobile (Workday mobile app), api (programmatic submission via API integration), manual_entry (back-office data entry).' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetNumber rdf:type rdf:Property ;
    rdfs:label 'Timesheet Number' ;
    rdfs:comment 'Externally-known business identifier for the timesheet, used in payroll processing, client billing, and audit references. Formatted as TS-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHours rdf:type rdf:Property ;
    rdfs:label 'Total Hours' ;
    rdfs:comment 'Sum of all hours recorded across all time entries within this timesheet for the pay period. Used as the header-level control total for payroll processing and utilization reporting.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationRate rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate' ;
    rdfs:comment 'The ratio of billable hours to total hours for this timesheet period (billable_hours / total_hours). A key FTE productivity KPI used in agency capacity planning, QBR reporting, and resource optimization. Stored as a decimal (e.g., 0.7500 = 75%).' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipCode rdf:type rdf:Property ;
    rdfs:label 'Wip Code' ;
    rdfs:comment 'The Work in Progress (WIP) accounting code associated with this timesheet for financial reconciliation. Used in SAP S/4HANA project accounting to track unbilled labor costs against active client engagements.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerNotes rdf:type rdf:Property ;
    rdfs:label 'Worker Notes' ;
    rdfs:comment 'Free-text notes entered by the worker at the timesheet header level to provide context for the pay period\'s time allocation. May include project status updates, absence explanations, or billing clarifications.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightId rdf:type rdf:Property ;
    rdfs:label 'Usage Right Id' ;
    rdfs:comment 'Unique system-generated identifier for the usage right record. Primary key for the usage_right data product within the talent domain.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workdayWorkerId rdf:type rdf:Property ;
    rdfs:label 'Workday Worker Id' ;
    rdfs:comment 'The Workday HCM system worker identifier for the talent, enabling integration between the usage rights record and the talent\'s HR, payroll, and time-tracking records in Workday. Supports residual payment processing through the payroll module.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:ccpaOptOutStatus rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Status' ;
    rdfs:comment 'The California Consumer Privacy Act (CCPA) opt-out status for the talent\'s personal data usage in California-targeted campaigns. \'opted_in\' permits use; \'opted_out\' restricts use of personal data for California audiences; \'not_applicable\' for non-California markets.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Date' ;
    rdfs:comment 'The date on which the usage right was formally cleared by the legal or business affairs team, confirming all contractual and union obligations have been satisfied and the creative asset may be deployed.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Defines whether the usage right is exclusive to this agency/client, non-exclusive (talent may appear in competing campaigns), or category-exclusive (exclusive within a specific product/service category). Exclusive rights typically command higher fees and restrict talent from competitor engagements.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'The agreed monetary fee paid to the talent or their representative for this usage right grant. For buyout structures, this is the total one-time fee. For residual structures, this is the base session fee. Expressed in the currency specified by fee_currency_code.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:influencerDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Influencer Disclosure Required' ;
    rdfs:comment 'Indicates whether the talent (influencer) is contractually and regulatorily required to disclose the paid/sponsored nature of content under FTC Endorsement Guidelines or ASA CAP Code. Applicable primarily when talent_role is \'influencer\'. Critical for regulatory compliance.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPerpetual rdf:type rdf:Property ;
    rdfs:label 'Is Perpetual' ;
    rdfs:comment 'Indicates whether this usage right is granted in perpetuity with no expiration date. When True, rights_end_date should be null. Perpetual rights are typically associated with full buyout arrangements and carry higher upfront fees.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalGrantDate rdf:type rdf:Property ;
    rdfs:label 'Original Grant Date' ;
    rdfs:comment 'The date on which the usage right was first granted, regardless of subsequent renewals or extensions. Provides the anchor point for tracking the full lifecycle of the rights relationship with the talent.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStructure rdf:type rdf:Property ;
    rdfs:label 'Payment Structure' ;
    rdfs:comment 'The fee arrangement governing talent compensation for this usage right. \'buyout\' means a one-time payment granting unlimited use within agreed scope; \'residual\' means ongoing payments per use cycle per union scale; \'session_fee\' means payment for the recording session only with limited use; \'hybrid\' combines upfront buyout with residual obligations for certain use categories.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformRestrictions rdf:type rdf:Property ;
    rdfs:label 'Platform Restrictions' ;
    rdfs:comment 'Specific digital platforms or media outlets explicitly excluded from or restricted within this usage right (e.g., \'no TikTok\', \'YouTube only\', \'no competitor-owned media\'). Null if no platform-specific restrictions apply beyond the usage_type classification.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Count' ;
    rdfs:comment 'The number of times this usage right has been renewed or extended since the original grant. Tracks the full renewal history lifecycle and informs cumulative cost analysis and talent relationship management.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOptionDeadline rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Deadline' ;
    rdfs:comment 'The date by which the agency must exercise the renewal option to extend the usage right period. Missing this deadline forfeits the renewal option and may require renegotiation at potentially higher rates. Critical for proactive rights management.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualRate rdf:type rdf:Property ;
    rdfs:label 'Residual Rate' ;
    rdfs:comment 'The per-use or per-cycle residual payment rate applicable when payment_structure is \'residual\' or \'hybrid\'. Expressed as a monetary amount per broadcast cycle or as a percentage of the original session fee per union scale. Null for pure buyout arrangements.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Right Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this usage right, used in correspondence with talent unions, legal teams, and talent agencies. Follows the agency\'s internal rights numbering convention (e.g., UR-2024-00123).' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightStatus rdf:type rdf:Property ;
    rdfs:label 'Right Status' ;
    rdfs:comment 'Current lifecycle status of the usage right. \'active\' indicates rights are cleared and in use; \'pending_clearance\' indicates awaiting legal or union approval; \'expired\' indicates the usage period has lapsed; \'suspended\' indicates rights are temporarily halted pending dispute resolution; \'renewed\' indicates an extension has been executed; \'terminated\' indicates rights have been revoked or cancelled.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentRole rdf:type rdf:Property ;
    rdfs:label 'Talent Role' ;
    rdfs:comment 'The professional role or category of the talent whose rights are being managed. Determines applicable union agreements, rate scales, and rights clearance requirements. [ENUM-REF-CANDIDATE: actor|model|photographer|director|influencer|voice_talent|musician|dancer|stunt_performer|extra|presenter — promote to reference product]' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code(s) or region designator indicating the geographic market(s) where the usage right is valid. Multiple territories may be pipe-delimited (e.g., \'USA|CAN|GBR\'). \'WW\' denotes worldwide rights. Critical for determining applicable union agreements and residual payment obligations.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Union Agreement Code' ;
    rdfs:comment 'The talent union or guild agreement governing this usage right and its associated payment obligations. Determines applicable scale rates, residual schedules, and usage restrictions. \'NON-UNION\' indicates talent not covered by a collective bargaining agreement.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionContractNumber rdf:type rdf:Property ;
    rdfs:label 'Union Contract Number' ;
    rdfs:comment 'The specific union contract or signatory agreement number under which this usage right is administered. Required for SAG-AFTRA, ACTRA, and BECTU residual reporting and audit compliance. Null for non-union talent.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitationNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Limitation Notes' ;
    rdfs:comment 'Free-text field capturing any specific usage restrictions, conditions, or limitations not captured in structured fields (e.g., \'talent must be credited\', \'no political advertising use\', \'no alteration of likeness permitted\', \'must not be used in conjunction with alcohol brands\').' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usagePeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Usage Period Months' ;
    rdfs:comment 'The total duration of the usage right period expressed in months, calculated from rights_start_date to rights_end_date. Used for residual cycle calculations, budget forecasting, and rights expiry alerting.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageSubtype rdf:type rdf:Property ;
    rdfs:label 'Usage Subtype' ;
    rdfs:comment 'Granular classification within the usage type, specifying the exact format or placement (e.g., \'pre-roll video\', \'banner display\', \'story ad\', \'billboard static\', \'magazine full-page\'). Provides precision for rights clearance and union residual calculations.' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerWorkerId rdf:type rdf:Property ;
    rdfs:label 'Manager Worker Id' ;
    rdfs:comment 'The worker_id of the direct line manager or supervisor for this worker, enabling organizational hierarchy traversal. Used for approval workflows, performance management, and org chart reporting in Workday HCM.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'The worker\'s date of birth. Used for age verification, benefits eligibility determination, and compliance with child labor laws. Stored in compliance with GDPR Article 9 and CCPA data minimization principles.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'The worker\'s Full-Time Equivalent (FTE) percentage representing their capacity relative to a standard full-time position (e.g., 100.00 for full-time, 50.00 for half-time). Used for headcount reporting, capacity planning, and P&L cost allocation.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'The worker\'s self-identified gender, collected voluntarily for DEI (Diversity, Equity, and Inclusion) reporting and workforce analytics. Stored in compliance with GDPR Article 9 special category data protections. [ENUM-REF-CANDIDATE: male|female|non_binary|prefer_not_to_say|other — promote to reference product]' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'The official date the worker commenced employment or engagement with the agency, as recorded in Workday HCM. Used for tenure calculations, benefits eligibility, probation period tracking, and anniversary reporting.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceCertificateRef rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Ref' ;
    rdfs:comment 'Document reference identifier for the worker\'s professional liability, general liability, or errors and omissions insurance certificate. Required for freelancers and contractors engaged on client-facing production work. Stored as a DAM reference to the Workfront DAM or agency document management system.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'The worker\'s legal given name as it appears on government-issued identification documents. Used for payroll, tax filings, and work authorization verification.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'The worker\'s legal family name as it appears on government-issued identification documents. Used for payroll, tax filings, and work authorization verification.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdReference rdf:type rdf:Property ;
    rdfs:label 'National Id Reference' ;
    rdfs:comment 'A tokenized or masked reference to the worker\'s national identification number (e.g., SSN, NIN, SIN). The actual value is stored in Workday HCM encrypted vault; this field holds a non-reversible reference token for cross-system reconciliation without exposing the raw identifier.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'The worker\'s nationality expressed as an ISO 3166-1 alpha-3 country code (e.g., USA, GBR, DEU). Used for work authorization verification, tax treaty eligibility, and international assignment management.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocationCode rdf:type rdf:Property ;
    rdfs:label 'Office Location Code' ;
    rdfs:comment 'The agency office or work location code where the worker is primarily based (e.g., NYC-HQ, LAX-WEST, LON-SOHO). Used for tax jurisdiction determination, resource planning, and facilities management.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code for the worker\'s pay rate (e.g., USD, GBP, EUR). Required for multi-currency payroll processing and international contractor management.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalEmail rdf:type rdf:Property ;
    rdfs:label 'Personal Email' ;
    rdfs:comment 'The worker\'s personal email address used for onboarding communications, offboarding notifications, and contact when work email is unavailable (e.g., for freelancers and contractors).' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the worker prefers to be addressed by in day-to-day agency operations, project assignments, and internal communications. May differ from legal name.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardWeeklyHours rdf:type rdf:Property ;
    rdfs:label 'Standard Weekly Hours' ;
    rdfs:comment 'The contracted or expected number of working hours per week for the worker. Used for capacity planning in Workfront resource management, overtime threshold calculations, and FTE equivalency reporting.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:talentSpecialization rdf:type rdf:Property ;
    rdfs:label 'Talent Specialization' ;
    rdfs:comment 'The worker\'s primary creative or technical specialization relevant to advertising and marketing production (e.g., Art Director, Copywriter, Director of Photography, Influencer, Actor, Motion Designer, Media Planner, Programmatic Trader, Data Analyst). Used for talent matching and resource allocation in Workfront.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCountry rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Country' ;
    rdfs:comment 'The primary country tax jurisdiction for the worker expressed as an ISO 3166-1 alpha-3 country code. Determines applicable tax treaties, withholding rates, and payroll processing rules in SAP S/4HANA FI.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction State' ;
    rdfs:comment 'The state or province tax jurisdiction for the worker (e.g., NY, CA, TX for US workers). Used for state income tax withholding, nexus determination, and multi-state payroll compliance in SAP S/4HANA Payroll.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Visa Expiry Date' ;
    rdfs:comment 'The expiration date of the worker\'s visa or work permit. Used to trigger renewal workflows and ensure continuous work authorization compliance. Null for workers with unrestricted authorization.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visaType rdf:type rdf:Property ;
    rdfs:label 'Visa Type' ;
    rdfs:comment 'The type of visa or work permit held by the worker where applicable (e.g., H-1B, L-1, O-1, Tier 2, EU Blue Card). Null for workers with unrestricted work authorization. Used for immigration compliance tracking.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'The agency-issued or primary professional email address for the worker. Used for system access provisioning, Workfront project assignments, and internal communications.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitRef rdf:type rdf:Property ;
    rdfs:label 'Work Permit Ref' ;
    rdfs:comment 'Document reference identifier for the worker\'s work permit or right-to-work documentation stored in the agency\'s DAM or Workday HCM document vault. Used for immigration compliance audits and I-9 reverification tracking.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayWorkerReference rdf:type rdf:Property ;
    rdfs:label 'Workday Worker Reference' ;
    rdfs:comment 'The native worker identifier assigned by Workday HCM Core HR module. Used for system-of-record cross-referencing and integration with Workday Payroll, Time Tracking, and Talent Management modules.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerStatus rdf:type rdf:Property ;
    rdfs:label 'Worker Status' ;
    rdfs:comment 'Current lifecycle status of the worker record within the agency. Drives access provisioning, payroll processing, and resource availability in Workfront. \'pending_onboard\' indicates pre-start date; \'on_leave\' covers parental, medical, and sabbatical leave.' ;
    rdfs:domain ind:Worker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current validity status of the accreditation record. \'active\' indicates the certification is current and enforceable; \'expired\' indicates the certification period has lapsed; \'suspended\' indicates temporary hold pending review; \'revoked\' indicates the certifying body has withdrawn the certification; \'pending\' indicates an application in progress.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationTier rdf:type rdf:Property ;
    rdfs:label 'Accreditation Tier' ;
    rdfs:comment 'The tier or level of the accreditation where the certifying body defines multiple levels (e.g., IAB Gold Standard tiers, MRC provisional vs. full accreditation). Supports vendor segmentation and preferential buying decisions.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antiFraudCertified rdf:type rdf:Property ;
    rdfs:label 'Anti Fraud Certified' ;
    rdfs:comment 'Indicates whether this accreditation record confers TAG Certified Against Fraud status on the vendor. True when the certification type is TAG Certified Against Fraud and status is active. Supports invalid traffic (IVT) mitigation in programmatic buying.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditCycle rdf:type rdf:Property ;
    rdfs:label 'Audit Cycle' ;
    rdfs:comment 'The frequency at which the certifying body requires the vendor to undergo re-audit or re-assessment to maintain the accreditation (e.g., annual TAG re-certification, biennial MRC audit). Drives renewal workflow scheduling.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyCertified rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Certified' ;
    rdfs:comment 'Indicates whether this accreditation record confers TAG Brand Safety Certified status on the vendor. True when the certification type is TAG Brand Safety Certified and status is active. Enables rapid brand safety filtering in media buying workflows.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Reference Number' ;
    rdfs:comment 'The official certificate or registration number issued by the certifying body (e.g., TAG seal ID, MRC accreditation number, IAB Gold Standard reference). Used for external verification and audit trail.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'The full official name of the certification or accreditation program as designated by the certifying body (e.g., \'TAG Brand Safety Certified Seal\', \'MRC Digital Audience-Based Buying Accreditation\'). Provides human-readable identification beyond the type code.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The specific type of accreditation or certification held by the vendor. Covers brand safety, anti-fraud, audience measurement, content standards, and regulatory compliance certifications. [ENUM-REF-CANDIDATE: TAG Brand Safety Certified|TAG Certified Against Fraud|MRC Accredited|IAB Gold Standard|ASA Compliant|FTC Compliant|EASA Compliant|4As Member|ANA Member — promote to reference product]' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'The governing or standards body that issued the accreditation or certification (e.g., TAG, MRC, IAB, ASA, FTC). Determines the authority and scope of the certification. [ENUM-REF-CANDIDATE: TAG|MRC|IAB|ASA|FTC|EASA|4As|ANA|NAI|ICC — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBodyContact rdf:type rdf:Property ;
    rdfs:label 'Certifying Body Contact' ;
    rdfs:comment 'Name or email of the primary contact at the certifying body responsible for managing this accreditation record. Used for renewal correspondence and audit coordination.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeUsd rdf:type rdf:Property ;
    rdfs:label 'Fee Usd' ;
    rdfs:comment 'The fee paid by the vendor to the certifying body to obtain or renew this accreditation, denominated in US Dollars. Supports vendor cost tracking, budget management, and P&L reconciliation for supply chain compliance expenditure.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iabGoldStandard rdf:type rdf:Property ;
    rdfs:label 'Iab Gold Standard' ;
    rdfs:comment 'Indicates whether the vendor holds IAB Gold Standard certification as part of this accreditation record. Covers ads.txt/sellers.json adoption, brand safety, and anti-fraud commitments.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'The date on which a previously suspended or revoked accreditation was reinstated by the certifying body. Supports vendor lifecycle management and historical compliance audit trails.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalAlertDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Alert Days' ;
    rdfs:comment 'Number of days before expiry_date at which automated renewal alerts should be triggered for this accreditation. Configurable per certification type to support proactive compliance management (e.g., 90 days for TAG, 60 days for MRC).' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Url' ;
    rdfs:comment 'URL pointing to the official certificate document, audit report, or compliance evidence stored in the DAM (Digital Asset Management) system or secure document repository. Enables direct access to certification evidence for brand safety audits.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date on which the certifying body suspended or revoked this accreditation. Populated only when accreditation_status is \'suspended\' or \'revoked\'. Enables point-in-time compliance reporting.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Narrative explanation of why the accreditation was suspended or revoked by the certifying body. Populated only when accreditation_status is \'suspended\' or \'revoked\'. Supports vendor risk management and supply chain transparency reporting.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the vendor\'s internal contact responsible for managing and renewing this accreditation. Used for renewal notifications and audit correspondence. Classified as confidential PII.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Full name of the vendor\'s internal contact responsible for managing and renewing this accreditation. Business-confidential as it identifies a named individual within a commercial partner organization.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Agency Discount Amount' ;
    rdfs:comment 'The monetary value of agency commission or trade discount deducted from the gross invoice amount, as negotiated in the vendor contract or IO. Typically expressed as a percentage of gross media spend.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBillingAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Billing Amount' ;
    rdfs:comment 'The final approved amount authorized for payment after reconciliation and dispute resolution. May differ from the original net_amount if adjustments were made during the reconciliation or dispute process. This is the amount posted to SAP S/4HANA FI-AP for payment.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'The end date of the media flight, production period, or service period covered by this invoice. Together with billing_period_start, defines the reconciliation window for delivery data matching.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'The start date of the media flight, production period, or service period covered by this invoice. Used to align invoice charges with campaign delivery windows and IO-authorized spend periods.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:brandSafetyCompliant rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Compliant' ;
    rdfs:comment 'Indicates whether the media inventory delivered by the vendor during the billing period was verified as brand-safe per TAG (Trustworthy Accountability Group) and internal brand safety standards. A value of False may trigger invoice dispute or vendor review.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveredSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Delivered Spend Amount' ;
    rdfs:comment 'The actual ad spend amount as recorded by the ad server (Google CM360) or DSP (The Trade Desk) for the billing period. Represents the verified delivery data used in post-buy reconciliation against the vendor invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDataSource rdf:type rdf:Property ;
    rdfs:label 'Delivery Data Source' ;
    rdfs:comment 'The ad server or measurement platform used as the authoritative source of delivery data for reconciliation (e.g., Google CM360, The Trade Desk). Determines which system\'s impression and spend data is used to validate the vendor invoice. [ENUM-REF-CANDIDATE: cm360|the_trade_desk|mediaocean_prisma|nielsen|comscore|vendor_reported|other — promote to reference product]' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the reconciliation variance. Delivery shortfall: vendor delivered less than invoiced. Overbilling: vendor charged above IO rate. Trafficking error: ad server setup error. Invalid traffic: IVT/fraud detected. Make good: compensatory delivery. [ENUM-REF-CANDIDATE: delivery_shortfall|overbilling|trafficking_error|data_discrepancy|invalid_traffic|make_good|other — promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Unique identifier for the formal dispute case raised against this invoice when the variance exceeds the acceptable threshold. Links to the dispute management workflow in SAP S/4HANA or Mediaocean Prisma.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'The date on which a formal billing dispute was raised with the vendor. Initiates the dispute resolution clock and triggers vendor notification per contractual SLA terms.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which the billing dispute was formally resolved and the approved billing amount was agreed upon with the vendor. Marks the transition from \'disputed\' to \'approved\' status.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ioAuthorizedAmount rdf:type rdf:Property ;
    rdfs:label 'Io Authorized Amount' ;
    rdfs:comment 'The total spend amount authorized under the associated Insertion Order (IO) for the billing period. Used as the baseline for reconciliation against the vendor invoice gross amount to identify overbilling or underbilling.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:number rdf:type rdf:Property ;
    rdfs:label 'Number' ;
    rdfs:comment 'Externally-assigned invoice number as provided by the vendor on the invoice document. Used as the primary business identifier for matching vendor invoices to internal purchase orders and IOs. Must be unique per vendor.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'The payment transaction reference number generated by SAP S/4HANA FI-AP when the payment run is executed. Used to trace the payment in bank statements and vendor remittance advice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The date the invoice was received and logged into the accounts payable system. May differ from the issue date due to postal or electronic delivery lag. Used for aging analysis and payment terms compliance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period End' ;
    rdfs:comment 'The end date of the reconciliation window used to pull delivery data from CM360 or The Trade Desk for matching against this invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period Start' ;
    rdfs:comment 'The start date of the reconciliation window used to pull delivery data from CM360 or The Trade Desk for matching against this invoice. May differ from billing_period_start if reconciliation covers a different date range.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payable Amount' ;
    rdfs:comment 'The final total amount payable to the vendor, calculated as net_amount plus tax_amount. This is the amount that will be disbursed in the payment run in SAP S/4HANA FI-AP.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference Number' ;
    rdfs:comment 'Vendor\'s own internal reference or purchase order number included on the invoice, used to cross-reference the vendor\'s billing system and facilitate dispute resolution.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Performance Evaluation Id' ;
    rdfs:comment 'Unique system-generated identifier for each vendor performance evaluation record. Primary key for the performance_evaluation product.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliveredUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Delivered Units' ;
    rdfs:comment 'Total number of impressions, clicks, or deliverable units actually delivered by the vendor during the evaluation period as recorded in the ad server (e.g., Google Campaign Manager 360). Numerator for delivery fulfillment rate calculation.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSafetyIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Incident Count' ;
    rdfs:comment 'Number of brand safety incidents recorded against the vendor during the evaluation period, including ad placements adjacent to harmful, inappropriate, or non-brand-safe content. Critical metric for TAG (Trustworthy Accountability Group) compliance and preferred vendor list eligibility.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSafetyIncidentSeverity rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Incident Severity' ;
    rdfs:comment 'Highest severity level of brand safety incidents recorded against the vendor during the evaluation period. Aligned to GARM (Global Alliance for Responsible Media) brand safety floor and suitability framework tiers.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRenewalRecommendation rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Recommendation' ;
    rdfs:comment 'Formal recommendation for contract renewal action based on the outcome of this performance evaluation. Feeds directly into the contract management workflow and vendor relationship strategy decisions.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFulfillmentRate rdf:type rdf:Property ;
    rdfs:label 'Delivery Fulfillment Rate' ;
    rdfs:comment 'Percentage of Insertion Order (IO) committed impressions, units, or deliverables that were actually fulfilled by the vendor during the evaluation period. Calculated as (actual_delivered / io_committed) * 100. Core KPI for media vendor accountability.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputedInvoicesCount rdf:type rdf:Property ;
    rdfs:label 'Disputed Invoices Count' ;
    rdfs:comment 'Number of invoices submitted by the vendor during the evaluation period that required dispute resolution, credit notes, or correction due to billing inaccuracies. Feeds into invoice accuracy rate and financial risk assessment.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationCycle rdf:type rdf:Property ;
    rdfs:label 'Evaluation Cycle' ;
    rdfs:comment 'The fiscal quarter in which this evaluation was conducted, aligned to the QBR (Quarterly Business Review) cycle. Used to track cadence and trend analysis across periods.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'The principal business date on which the formal vendor performance evaluation was conducted or finalized, typically the QBR session date.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text qualitative commentary from the evaluator capturing context, mitigating factors, notable incidents, or strategic observations not captured in the quantitative scorecard metrics. Used in QBR presentations and vendor relationship management.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationNumber rdf:type rdf:Property ;
    rdfs:label 'Evaluation Number' ;
    rdfs:comment 'Externally-visible business identifier for this evaluation record, used in QBR documentation, vendor communications, and preferred vendor list reviews. Format: VPE-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance measurement period covered by this evaluation, typically aligned to the quarterly QBR cycle (e.g., last day of the quarter).' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance measurement period covered by this evaluation, typically aligned to the quarterly QBR cycle (e.g., first day of the quarter).' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle state of the vendor performance evaluation record. Draft indicates data collection in progress; in_review indicates pending stakeholder sign-off; completed indicates finalized; approved indicates accepted by vendor management; disputed indicates vendor has raised a formal objection.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationYear rdf:type rdf:Property ;
    rdfs:label 'Evaluation Year' ;
    rdfs:comment 'The fiscal year in which this evaluation was conducted. Combined with evaluation_cycle to uniquely identify the QBR period for trend and year-over-year comparison.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Name of the internal agency staff member or team lead responsible for conducting and submitting this vendor performance evaluation, typically the media buyer, account director, or vendor management lead.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invalidTrafficRate rdf:type rdf:Property ;
    rdfs:label 'Invalid Traffic Rate' ;
    rdfs:comment 'Percentage of impressions delivered by the vendor during the evaluation period classified as invalid traffic (IVT) including general invalid traffic (GIVT) and sophisticated invalid traffic (SIVT) per MRC and TAG standards. Critical for fraud prevention and supply chain transparency.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage of vendor invoices submitted during the evaluation period that matched the reconciled billing amounts within the agreed tolerance threshold, without requiring correction or credit notes. Calculated as (accurate_invoices / total_invoices) * 100. Sourced from Mediaocean Prisma reconciliation data.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioCommittedUnits rdf:type rdf:Property ;
    rdfs:label 'Io Committed Units' ;
    rdfs:comment 'Total number of impressions, clicks, or deliverable units committed by the vendor across all active Insertion Orders (IOs) during the evaluation period. Denominator for delivery fulfillment rate calculation.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodFulfilledCount rdf:type rdf:Property ;
    rdfs:label 'Makegood Fulfilled Count' ;
    rdfs:comment 'Number of make-good obligations that were successfully fulfilled by the vendor during the evaluation period. Compared against makegood_obligation_count to assess vendor responsiveness to under-delivery.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodObligationCount rdf:type rdf:Property ;
    rdfs:label 'Makegood Obligation Count' ;
    rdfs:comment 'Number of make-good obligations raised against the vendor during the evaluation period due to under-delivery against IO commitments. A make-good is compensatory inventory provided by the vendor to offset shortfalls.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrcAccreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Status' ;
    rdfs:comment 'Current MRC (Media Rating Council) accreditation status of the vendor at the time of evaluation. MRC accreditation validates the vendor\'s measurement methodologies and is required for audience measurement and impression counting credibility.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallScorecardRating rdf:type rdf:Property ;
    rdfs:label 'Overall Scorecard Rating' ;
    rdfs:comment 'Composite weighted scorecard rating for the vendor for the evaluation period, typically on a scale of 0.00 to 10.00 or 0.00 to 100.00. Aggregates delivery fulfillment, invoice accuracy, SLA adherence, brand safety, and viewability dimensions into a single performance score used for preferred vendor list tier assignment.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendorTier rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Tier' ;
    rdfs:comment 'Preferred vendor list tier assignment resulting from this evaluation. Tier 1 indicates top-performing strategic partners; Tier 2 indicates approved vendors; Tier 3 indicates conditional approval; Probation indicates performance improvement required; Disqualified indicates removal from preferred vendor list.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPreferredVendorTier rdf:type rdf:Property ;
    rdfs:label 'Prior Preferred Vendor Tier' ;
    rdfs:comment 'The vendor\'s preferred vendor list tier from the immediately preceding evaluation period. Used to track tier movement (promotion or demotion) resulting from this evaluation cycle.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorScorecardRating rdf:type rdf:Property ;
    rdfs:label 'Prior Scorecard Rating' ;
    rdfs:comment 'The vendor\'s overall scorecard rating from the immediately preceding evaluation period. Enables quarter-over-quarter trend analysis and identification of improving or declining vendor performance trajectories.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimeSlaAdherenceRate rdf:type rdf:Property ;
    rdfs:label 'Response Time Sla Adherence Rate' ;
    rdfs:comment 'Percentage of vendor response obligations (e.g., campaign issue resolution, data discrepancy responses, creative trafficking requests) fulfilled within the contractually agreed SLA response time during the evaluation period.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardRatingScale rdf:type rdf:Property ;
    rdfs:label 'Scorecard Rating Scale' ;
    rdfs:comment 'The numeric scale used for the overall_scorecard_rating in this evaluation (e.g., 0-10, 0-100, 1-5). Ensures correct interpretation of the rating value across different evaluation frameworks or vendor categories.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachesCount rdf:type rdf:Property ;
    rdfs:label 'Sla Breaches Count' ;
    rdfs:comment 'Number of SLA response obligations that were not fulfilled within the contractually agreed timeframe during the evaluation period. Used to identify chronic SLA non-compliance patterns.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaIncidentsTotal rdf:type rdf:Property ;
    rdfs:label 'Sla Incidents Total' ;
    rdfs:comment 'Total number of SLA-governed response obligations raised against the vendor during the evaluation period. Denominator for response_time_sla_adherence_rate calculation.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tagCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Tag Certification Status' ;
    rdfs:comment 'Current TAG (Trustworthy Accountability Group) certification status of the vendor at the time of evaluation. TAG certification is a prerequisite for preferred vendor list tier 1 eligibility and indicates compliance with anti-fraud, brand safety, and supply chain transparency standards.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInvoicesSubmitted rdf:type rdf:Property ;
    rdfs:label 'Total Invoices Submitted' ;
    rdfs:comment 'Total number of invoices submitted by the vendor during the evaluation period. Denominator for invoice accuracy rate calculation. Sourced from Mediaocean Prisma billing records.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Category' ;
    rdfs:comment 'Classification of the vendor type being evaluated. Determines which performance dimensions and benchmarks are applicable. [ENUM-REF-CANDIDATE: media_publisher|dsp|ssp|dmp|cdp|production_supplier|technology_partner|research_vendor — promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorDisputeFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Dispute Flag' ;
    rdfs:comment 'Indicates whether the vendor has formally disputed the findings of this performance evaluation. When True, the evaluation status should reflect \'disputed\' and a resolution process must be initiated.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorDisputeNotes rdf:type rdf:Property ;
    rdfs:label 'Vendor Dispute Notes' ;
    rdfs:comment 'Free-text notes capturing the vendor\'s formal objection or dispute rationale when vendor_dispute_flag is True. Documents the basis of the dispute for audit trail and resolution tracking purposes.' ;
    rdfs:domain ind:PerformanceEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorListId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor List Id' ;
    rdfs:comment 'Unique surrogate identifier for each preferred vendor list entry. Primary key for the preferred_vendor_list data product within the vendor domain.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPreferredSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Preferred Supplier Id' ;
    rdfs:comment 'Reference to the vendor record in the vendor master. Identifies the third-party media vendor, publisher, technology partner (DSP, SSP, DMP, CDP), or production supplier designated on this PVL entry.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:adsTxtCompliant rdf:type rdf:Property ;
    rdfs:label 'Ads Txt Compliant' ;
    rdfs:comment 'Indicates whether the vendor (publisher or SSP) is compliant with the IAB Tech Lab ads.txt standard for authorized digital sellers. Critical for programmatic buying fraud prevention and supply path optimization (SPO).' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvingStakeholder rdf:type rdf:Property ;
    rdfs:label 'Approving Stakeholder' ;
    rdfs:comment 'Name or role of the internal stakeholder (e.g., Chief Procurement Officer, Group Media Director, Client Lead) who authorized this vendor\'s inclusion on the PVL. Supports governance accountability and audit requirements.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingStakeholderEmail rdf:type rdf:Property ;
    rdfs:label 'Approving Stakeholder Email' ;
    rdfs:comment 'Email address of the internal stakeholder who approved this PVL entry. Used for audit trail, escalation routing, and review cycle notifications. Classified confidential as it is an internal business contact.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Rating' ;
    rdfs:comment 'Agency-assigned or third-party brand safety rating for the vendor. Reflects the vendor\'s compliance with brand safety standards including content adjacency, fraud prevention, and viewability benchmarks. Informs media planner decisions.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignTypeScope rdf:type rdf:Property ;
    rdfs:label 'Campaign Type Scope' ;
    rdfs:comment 'Specifies the campaign type(s) for which this vendor designation applies (e.g., brand awareness, performance, direct response, ABM, retargeting). Null if applicable to all campaign types. Supports campaign strategy and planning alignment.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingAgreementSigned rdf:type rdf:Property ;
    rdfs:label 'Data Processing Agreement Signed' ;
    rdfs:comment 'Indicates whether a formal Data Processing Agreement has been executed with this vendor. Required under GDPR Article 28 for any vendor processing personal data on behalf of the agency or its clients.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Dpa Expiry Date' ;
    rdfs:comment 'Date on which the vendor\'s Data Processing Agreement expires and must be renewed. Null if the DPA is perpetual or not applicable. Triggers compliance renewal workflows.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which this PVL entry expires and the vendor designation ceases to be enforceable. Null for open-ended designations. Triggers review cycle notifications when approaching expiry.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iabMember rdf:type rdf:Property ;
    rdfs:label 'Iab Member' ;
    rdfs:comment 'Indicates whether the vendor is a current member of the IAB (Interactive Advertising Bureau). IAB membership signals adherence to industry standards for digital advertising, viewability, and data practices.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumSpendCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend Commitment' ;
    rdfs:comment 'Contractually committed minimum annual or period spend with this vendor as part of the preferred partner agreement. Expressed in the agency\'s base currency. Used in budget management and financial reconciliation to track commitment utilization.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingCompleted rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completed' ;
    rdfs:comment 'Indicates whether the vendor has completed the agency\'s full onboarding process including legal, compliance, financial, and technical setup steps. Vendors must be fully onboarded before being activated on the PVL.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredPartnerAgreement rdf:type rdf:Property ;
    rdfs:label 'Preferred Partner Agreement' ;
    rdfs:comment 'Indicates whether the agency has a formal preferred partner agreement (e.g., volume commitment, rebate arrangement, or strategic partnership MOU) with this vendor. Preferred partner agreements typically carry negotiated CPM/CPC rates and added-value commitments.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pvlEntryCode rdf:type rdf:Property ;
    rdfs:label 'Pvl Entry Code' ;
    rdfs:comment 'Human-readable, externally-known business identifier for this PVL entry (e.g., PVL-2024-0042). Used in agency communications, audit trails, and vendor onboarding correspondence.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionReason rdf:type rdf:Property ;
    rdfs:label 'Restriction Reason' ;
    rdfs:comment 'Documented reason for a \'restricted\' or \'blacklisted\' vendor tier designation. Required when vendor_tier is restricted or blacklisted. Supports compliance audit trails and media planner guidance. Examples: brand safety incident, fraud detection, client conflict, regulatory non-compliance.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeNotes rdf:type rdf:Property ;
    rdfs:label 'Scope Notes' ;
    rdfs:comment 'Free-text field capturing any specific conditions, restrictions, or qualifications on the vendor\'s PVL designation. Examples include geographic restrictions, format limitations, client-specific exclusions, or campaign type caveats not captured in structured fields.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainTransparencyScore rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Transparency Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) reflecting the vendor\'s supply chain transparency rating based on ads.txt/sellers.json compliance, TAG certification, and programmatic path quality assessments. Supports programmatic operations and brand safety governance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Agency-assigned designation indicating the vendor\'s standing on the preferred vendor list. \'preferred\' = actively recommended partner with negotiated rates; \'approved\' = cleared for use without special authorization; \'restricted\' = requires client or management sign-off before use; \'blacklisted\' = prohibited from use; \'under_review\' = pending re-evaluation.' ;
    rdfs:domain ind:PreferredVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPublisherId rdf:type rdf:Property ;
    rdfs:label 'Parent Publisher Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent publisher entity, enabling hierarchical modelling of publisher groups and media conglomerates (e.g., a local TV station under a national broadcast network). Null for top-level publishers.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Publisher .

ind:adsTxtVerified rdf:type rdf:Property ;
    rdfs:label 'Ads Txt Verified' ;
    rdfs:comment 'Indicates whether the publisher\'s ads.txt file has been validated, confirming that authorized digital sellers are declared and reducing the risk of unauthorized inventory reselling. Critical for supply path optimization (SPO) and programmatic fraud prevention.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audienceMeasurementSource rdf:type rdf:Property ;
    rdfs:label 'Audience Measurement Source' ;
    rdfs:comment 'Identifies the third-party audience measurement provider or methodology used to validate the publisher\'s audience reach figures. Determines the credibility and comparability of audience data for media planning and post-campaign reporting.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCpmRate rdf:type rdf:Property ;
    rdfs:label 'Base Cpm Rate' ;
    rdfs:comment 'Publisher\'s standard base CPM (Cost Per Mille) rate in the agency\'s operating currency, representing the cost per 1,000 ad impressions. Serves as the benchmark rate for media planning, rate card negotiations, and budget estimation in Mediaocean Prisma. Classified as confidential commercial pricing data.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grpEnabled rdf:type rdf:Property ;
    rdfs:label 'Grp Enabled' ;
    rdfs:comment 'Indicates whether the publisher supports Gross Rating Point (GRP) or Target Rating Point (TRP) based audience buying and reporting, typically applicable to broadcast, CTV/OTT, and premium digital video inventory. Enables GRP-based media planning in Nielsen Ad Intel integrated workflows.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iabContentCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Iab Content Category Code' ;
    rdfs:comment 'Primary IAB Content Taxonomy category code (e.g., IAB1, IAB2-1) classifying the publisher\'s editorial content vertical. Used for audience targeting, brand safety filtering, and contextual advertising alignment per IAB Content Taxonomy v3.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrcAccreditationScope rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Scope' ;
    rdfs:comment 'Description of the specific measurement types and platforms covered under the publisher\'s MRC accreditation (e.g., \'Display Impressions, Video Viewability, Cross-Platform\'). Null if mrc_audited is false.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSsp rdf:type rdf:Property ;
    rdfs:label 'Preferred Ssp' ;
    rdfs:comment 'Name of the publisher\'s primary or preferred Supply-Side Platform (SSP) used for programmatic inventory monetization (e.g., Google Ad Manager, Magnite, PubMatic, Index Exchange). Used for supply path optimization (SPO) and deal activation in The Trade Desk.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publisherType rdf:type rdf:Property ;
    rdfs:label 'Publisher Type' ;
    rdfs:comment 'Classification of the publisher by inventory channel category. Distinguishes digital publishers, broadcast networks, Out-of-Home (OOH) operators, Digital Out-of-Home (DOOH) networks, Connected TV (CTV) / Over-the-Top (OTT) platforms, and print media owners. Drives channel-specific buying workflows and rate card application.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the publisher\'s rate card pricing (e.g., USD, GBP, EUR). Ensures correct currency conversion and financial reconciliation in SAP S/4HANA and Mediaocean Prisma billing workflows.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryIabCategoryCodes rdf:type rdf:Property ;
    rdfs:label 'Secondary Iab Category Codes' ;
    rdfs:comment 'Pipe-delimited list of secondary IAB Content Taxonomy category codes representing additional content verticals covered by the publisher. Supports multi-category targeting and brand safety analysis beyond the primary classification.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellersJsonVerified rdf:type rdf:Property ;
    rdfs:label 'Sellers Json Verified' ;
    rdfs:comment 'Indicates whether the publisher\'s sellers.json file has been validated, providing transparency into the supply chain by identifying all entities authorized to sell the publisher\'s inventory. Supports supply path optimization (SPO) and anti-fraud compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spoTier rdf:type rdf:Property ;
    rdfs:label 'Spo Tier' ;
    rdfs:comment 'Supply Path Optimization (SPO) classification indicating the preferred supply path designation for this publisher. \'Direct\' = direct publisher relationship; \'Preferred\' = approved SSP path; \'Standard\' = open market; \'Excluded\' = removed from programmatic buying paths. Used by The Trade Desk and DSP buying teams to optimize supply chain efficiency.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Id' ;
    rdfs:comment 'Unique surrogate identifier for the media cost reconciliation record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adserverDeliveredAmount rdf:type rdf:Property ;
    rdfs:label 'Adserver Delivered Amount' ;
    rdfs:comment 'Actual media cost derived from ad server delivery data (Google Campaign Manager 360 or The Trade Desk) for the reconciliation period. Used as the authoritative delivery benchmark in post-buy reconciliation.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adserverSource rdf:type rdf:Property ;
    rdfs:label 'Adserver Source' ;
    rdfs:comment 'Identifies the authoritative ad serving or DSP platform from which delivery data was sourced for this reconciliation (e.g., Google Campaign Manager 360, The Trade Desk). Ensures traceability of delivery benchmarks.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Note Amount' ;
    rdfs:comment 'Monetary value of the vendor-issued credit note applied to resolve an overbilling discrepancy. Reduces the net payable amount in SAP S/4HANA Accounts Payable.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Note Number' ;
    rdfs:comment 'Vendor-issued credit note reference number when a credit adjustment is issued to resolve an overbilling discrepancy. Linked to SAP S/4HANA Accounts Payable credit memo processing.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Free-text narrative explaining the specific nature of the billing discrepancy, including details of delivery shortfalls, trafficking errors, or vendor disputes not fully captured by the reason code.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prismaReconciliationRef rdf:type rdf:Property ;
    rdfs:label 'Prisma Reconciliation Ref' ;
    rdfs:comment 'Reference identifier from Mediaocean Prisma post-buy reconciliation module corresponding to this record. Enables traceability between the lakehouse Silver Layer and the source system of record.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Externally-known business identifier for this reconciliation record, used in Mediaocean Prisma post-buy workflows and SAP S/4HANA financial close correspondence with vendors.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Type' ;
    rdfs:comment 'Classification of the reconciliation record indicating whether it covers standard media buys, programmatic (RTB/DSP) activity, make-good placements, credit adjustments, or final billing close.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP S/4HANA FI accounting document number generated upon financial close posting of the approved billing amount. Provides the audit link between media reconciliation and the general ledger.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Pct' ;
    rdfs:comment 'Agreed acceptable variance percentage threshold below which discrepancies are considered immaterial and do not require formal dispute resolution. Typically set per vendor contract or IAB industry standard (commonly 10%).' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'Variance expressed as a percentage of the IO-authorized amount ((variance_amount / io_authorized_amount) * 100). Used to assess materiality of discrepancy against agency tolerance thresholds (typically ±10% per IAB guidelines).' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorInvoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoiced Amount' ;
    rdfs:comment 'Total gross amount billed by the vendor on their invoice for the reconciliation period. Primary input to variance calculation against IO-authorized spend.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withinToleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Within Tolerance Flag' ;
    rdfs:comment 'Indicates whether the variance percentage falls within the agreed tolerance threshold, determining whether formal dispute escalation is required.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Unique identifier for the vendor risk assessment record. Primary key.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the risk assessment was conducted or completed.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business-facing unique identifier for the risk assessment, used in communications and reporting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the risk assessment record.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the assessment based on the trigger or purpose (initial onboarding, annual refresh, triggered by incident, ad-hoc review, or client-mandated due diligence).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Name of the individual or team who conducted the risk assessment.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyRisk rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Risk' ;
    rdfs:comment 'Assessment of risk related to brand safety incidents, including ad placement near inappropriate content, fraud, or reputational damage.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessContinuityPlanVerified rdf:type rdf:Property ;
    rdfs:label 'Business Continuity Plan Verified' ;
    rdfs:comment 'Indicates whether the vendor\'s business continuity plan has been reviewed and verified as adequate.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessContinuityRisk rdf:type rdf:Property ;
    rdfs:label 'Business Continuity Risk' ;
    rdfs:comment 'Assessment of risk related to the vendor\'s ability to maintain operations during disruptions, including disaster recovery and business continuity planning.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliance Status' ;
    rdfs:comment 'Assessment of the vendor\'s compliance with CCPA requirements for consumer data privacy.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Ccpa Risk Level' ;
    rdfs:comment 'Risk level associated with the vendor\'s CCPA compliance posture and consumer data handling practices.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientMandatedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Mandated Flag' ;
    rdfs:comment 'Indicates whether this risk assessment was mandated by a specific client as part of their vendor due diligence requirements.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concentrationRisk rdf:type rdf:Property ;
    rdfs:label 'Concentration Risk' ;
    rdfs:comment 'Risk level associated with revenue dependency on this vendor, assessing the impact if the vendor relationship were to terminate.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataBreachCount rdf:type rdf:Property ;
    rdfs:label 'Data Breach Count' ;
    rdfs:comment 'Number of documented data breaches or significant security incidents involving the vendor in the assessment period.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataBreachHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Data Breach History Flag' ;
    rdfs:comment 'Indicates whether the vendor has a documented history of data breaches or security incidents.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSecurityPosture rdf:type rdf:Property ;
    rdfs:label 'Data Security Posture' ;
    rdfs:comment 'Overall assessment of the vendor\'s data security capabilities, controls, and practices.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialRiskScore rdf:type rdf:Property ;
    rdfs:label 'Financial Risk Score' ;
    rdfs:comment 'Numeric score representing the financial risk level of the vendor, typically on a scale of 0-100 where higher values indicate higher risk.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialStabilityRating rdf:type rdf:Property ;
    rdfs:label 'Financial Stability Rating' ;
    rdfs:comment 'Credit or financial health rating of the vendor, indicating their ability to continue operations and fulfill contractual obligations. Ratings follow standard credit rating scale. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliance Status' ;
    rdfs:comment 'Assessment of the vendor\'s compliance with GDPR requirements for data processing and privacy.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Gdpr Risk Level' ;
    rdfs:comment 'Risk level associated with the vendor\'s GDPR compliance posture and data processing activities.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Total amount of insurance coverage held by the vendor, typically in USD.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageVerified rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Verified' ;
    rdfs:comment 'Indicates whether the vendor\'s insurance coverage (general liability, professional indemnity, cyber liability) has been verified and meets requirements.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the insurance coverage amount.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso27001CertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso27001 Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the vendor\'s ISO 27001 certification.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso27001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso27001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds ISO 27001 certification for information security management systems.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallRiskRating rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Rating' ;
    rdfs:comment 'Composite risk rating summarizing all risk dimensions (financial, security, compliance, continuity, concentration) into a single overall assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRiskScore rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Score' ;
    rdfs:comment 'Numeric composite risk score aggregating all risk dimensions, typically on a scale of 0-100 where higher values indicate higher risk.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueDependencyPct rdf:type rdf:Property ;
    rdfs:label 'Revenue Dependency Pct' ;
    rdfs:comment 'Percentage of agency revenue that is dependent on or flows through this vendor, used to assess concentration risk.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soc2Compliant rdf:type rdf:Property ;
    rdfs:label 'Soc2 Compliant' ;
    rdfs:comment 'Indicates whether the vendor has achieved SOC 2 Type II compliance, demonstrating controls for security, availability, processing integrity, confidentiality, and privacy.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soc2ReportDate rdf:type rdf:Property ;
    rdfs:label 'Soc2 Report Date' ;
    rdfs:comment 'Date of the most recent SOC 2 audit report received from the vendor.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyRelationshipOwner rdf:type rdf:Property ;
    rdfs:label 'Agency Relationship Owner' ;
    rdfs:comment 'Name or identifier of the primary agency employee (e.g., media director, programmatic lead, or account director) responsible for managing the commercial relationship with this supplier. Used for accountability, QBR scheduling, and escalation routing.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Api Integration Status' ;
    rdfs:comment 'Current status of the API integration between the agency\'s technology stack and the supplier\'s platform. Applicable primarily to tech_platform vendor types. Tracks whether automated data exchange (bid management, reporting, audience sync) is live, pending setup, inactive, or not applicable.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceReach rdf:type rdf:Property ;
    rdfs:label 'Audience Reach' ;
    rdfs:comment 'Estimated total unique audience reach of the supplier\'s media properties, expressed as number of unique users/devices per month. Sourced from Comscore or Nielsen Ad Intel measurement. Used in media planning for reach and frequency analysis and GRP/TRP calculations.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cm360VendorCode rdf:type rdf:Property ;
    rdfs:label 'Cm360 Vendor Code' ;
    rdfs:comment 'Unique vendor or site identifier assigned to the supplier within Google Campaign Manager 360 for ad trafficking, placement management, and delivery reporting. Enables reconciliation between CM360 delivery data and the vendor master.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Expiry date of the master service agreement (MSA) or master vendor contract with the supplier. Triggers contract renewal workflows and controls whether new insertion orders (IOs) can be issued against this supplier in Mediaocean Prisma.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSharingAgreement rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement' ;
    rdfs:comment 'Indicates whether a formal data sharing agreement is in place with the supplier, governing the exchange of audience data, campaign performance data, and measurement signals. Required for GDPR/CCPA compliance when audience data flows between the agency and the supplier.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversityCertType rdf:type rdf:Property ;
    rdfs:label 'Diversity Cert Type' ;
    rdfs:comment 'Specific type of diversity certification held by the supplier (e.g., MBE, WBE, LGBTBE, VOSB, SDVOSB, SBE). Populated only when diversity_certified is True. Used for granular diversity spend categorization and client reporting. [ENUM-REF-CANDIDATE: MBE|WBE|LGBTBE|VOSB|SDVOSB|SBE|HUBZone|other — promote to reference product]' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityCertified rdf:type rdf:Property ;
    rdfs:label 'Diversity Certified' ;
    rdfs:comment 'Indicates whether the supplier holds a recognized diversity certification (e.g., MBE - Minority Business Enterprise, WBE - Women Business Enterprise, LGBTBE, VOSB). Supports client diversity spend reporting mandates and ANA supplier diversity program compliance.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the supplier entity as filed with the relevant government authority. Used for contract execution, insertion orders (IOs), and financial reconciliation in SAP S/4HANA and Mediaocean Prisma.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaoceanVendorCode rdf:type rdf:Property ;
    rdfs:label 'Mediaocean Vendor Code' ;
    rdfs:comment 'Unique vendor identifier assigned within Mediaocean Prisma, the agency\'s primary media planning, buying, and billing system of record. Used for cross-system reconciliation between the lakehouse silver layer and Mediaocean operational records.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticSupplyRole rdf:type rdf:Property ;
    rdfs:label 'Programmatic Supply Role' ;
    rdfs:comment 'Defines the supplier\'s role in the programmatic supply chain as declared in ads.txt/sellers.json: direct (authorized direct seller of inventory), reseller (authorized to resell another seller\'s inventory), both (acts as both), or not_applicable (non-programmatic supplier). Used for supply chain transparency and SPO analysis.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'Unique account identifier for the supplier record in Salesforce CRM (Sales Cloud). Enables cross-system linkage between the vendor master in the lakehouse and the CRM account for relationship management, contract tracking, and QBR reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spoEnabled rdf:type rdf:Property ;
    rdfs:label 'Spo Enabled' ;
    rdfs:comment 'Indicates whether the supplier participates in the agency\'s Supply Path Optimization (SPO) program, meaning the agency has a direct or preferred supply relationship with this vendor to reduce intermediary hops, improve transparency, and lower CPM costs in programmatic buying via The Trade Desk.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tagCertifiedAgainstFraud rdf:type rdf:Property ;
    rdfs:label 'Tag Certified Against Fraud' ;
    rdfs:comment 'Indicates whether the supplier holds current TAG Certified Against Fraud certification, a key brand safety and ad fraud prevention credential. Required for programmatic supply curation and brand safety tier assignment. Sourced from TAG registry.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tagSealCertificationCode rdf:type rdf:Property ;
    rdfs:label 'Tag Seal Certification Code' ;
    rdfs:comment 'The unique TAG Seal identifier issued to the supplier upon achieving TAG certification (e.g., TAG Certified Against Fraud, TAG Brand Safety Certified). Used to verify certification authenticity via the TAG registry and enforce brand safety compliance in programmatic buying.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax identification number (e.g., EIN in the US, VAT number in the EU) for the supplier\'s legal entity. Required for W-9/W-8 compliance, SAP S/4HANA vendor master setup, and financial reconciliation in Mediaocean Prisma.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDeskPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trade Desk Partner Code' ;
    rdfs:comment 'Unique partner or supply partner identifier assigned to the supplier within The Trade Desk DSP platform. Used for programmatic buying configuration, bid management, and supply path optimization (SPO) tracking.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Primary classification of the supplier within the advertising ecosystem. Drives downstream workflow routing, rate card applicability, and compliance checks. Enum: publisher (media owner), tech_platform (DSP/SSP/DMP/CDP/ad server/verification/attribution), production (creative/production house), research (audience/measurement provider), other.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainProfileId rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Profile Id' ;
    rdfs:comment 'Unique identifier for the supply chain profile record. Primary key.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adsTxtAuthorized rdf:type rdf:Property ;
    rdfs:label 'Ads Txt Authorized' ;
    rdfs:comment 'Indicates whether the vendor is authorized in relevant publisher ads.txt files for inventory authenticity.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentVersion rdf:type rdf:Property ;
    rdfs:label 'Assessment Version' ;
    rdfs:comment 'Version number of this supply chain profile assessment, used for tracking updates and revisions.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageViewabilityRate rdf:type rdf:Property ;
    rdfs:label 'Average Viewability Rate' ;
    rdfs:comment 'Average percentage of viewable impressions delivered by the vendor, measured per MRC standards.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandSafetyVerificationScore rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Verification Score' ;
    rdfs:comment 'Numerical score (0-100) representing the vendor\'s brand safety verification performance and compliance level.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentAdjacencyRiskRating rdf:type rdf:Property ;
    rdfs:label 'Content Adjacency Risk Rating' ;
    rdfs:comment 'Risk rating for potential brand-unsafe content adjacency based on inventory quality and content categorization.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Critical Incident Count' ;
    rdfs:comment 'Number of critical-severity brand safety or fraud incidents that resulted in immediate action or vendor suspension.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataResidencyRegion rdf:type rdf:Property ;
    rdfs:label 'Data Residency Region' ;
    rdfs:comment 'Geographic region where the vendor stores and processes advertising data, relevant for data sovereignty compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionReason rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason' ;
    rdfs:comment 'Detailed explanation if the vendor is excluded or restricted from preferred status due to supply chain or brand safety concerns.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Total number of brand safety or supply chain transparency incidents recorded for this vendor during the assessment period.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intermediaryCount rdf:type rdf:Property ;
    rdfs:label 'Intermediary Count' ;
    rdfs:comment 'Number of intermediary hops in the programmatic supply chain between the advertiser and the publisher.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorStatus rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Status' ;
    rdfs:comment 'Vendor\'s status on the agency\'s preferred vendor list based on supply chain transparency and brand safety performance.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Reference Number' ;
    rdfs:comment 'Business-readable unique reference number for this supply chain profile assessment.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellersJsonUrl rdf:type rdf:Property ;
    rdfs:label 'Sellers Json Url' ;
    rdfs:comment 'URL to the vendor\'s published sellers.json file for programmatic supply chain transparency.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spoDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Spo Documentation Url' ;
    rdfs:comment 'URL reference to the vendor\'s supply path optimization documentation and transparency disclosures.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainDocumentationComplete rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Documentation Complete' ;
    rdfs:comment 'Indicates whether the vendor has provided complete supply chain documentation including all intermediaries and fee structures.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyPathOptimizationTier rdf:type rdf:Property ;
    rdfs:label 'Supply Path Optimization Tier' ;
    rdfs:comment 'Classification tier for programmatic supply path optimization indicating the vendor\'s preferred routing status in the supply chain.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityStandardMet rdf:type rdf:Property ;
    rdfs:label 'Viewability Standard Met' ;
    rdfs:comment 'Indicates whether the vendor meets MRC viewability standards for display and video ad impressions.' ;
    rdfs:domain ind:SupplyChainProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyPathRecordId rdf:type rdf:Property ;
    rdfs:label 'Supply Path Record Id' ;
    rdfs:comment 'Unique identifier for the supply path transparency record. Primary key for programmatic supply chain tracking.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publisherAccountPublisherId rdf:type rdf:Property ;
    rdfs:label 'Publisher Account Publisher Id' ;
    rdfs:comment 'The publisher\'s account identifier within the SSP\'s system, as declared in ads.txt, used to uniquely identify the business relationship.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Publisher .

ind:sellerPublisherId rdf:type rdf:Property ;
    rdfs:label 'Seller Publisher Id' ;
    rdfs:comment 'The unique seller identifier as declared in the SSP\'s sellers.json file, used to match publisher relationships across the supply chain.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Publisher .

ind:adsTxtEntry rdf:type rdf:Property ;
    rdfs:label 'Ads Txt Entry' ;
    rdfs:comment 'The complete ads.txt entry line from the publisher\'s ads.txt file that authorizes this supply path, including domain, publisher ID, relationship type, and TAG ID.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adsTxtVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Ads Txt Verification Date' ;
    rdfs:comment 'Date when the ads.txt file was last verified for this supply path, ensuring current authorization status.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedSellerFlag rdf:type rdf:Property ;
    rdfs:label 'Authorized Seller Flag' ;
    rdfs:comment 'Boolean flag indicating whether the SSP is explicitly authorized to sell the publisher\'s inventory as declared in the publisher\'s ads.txt file.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'Date when the supply path was last verified for ads.txt, sellers.json, and brand safety compliance.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Record Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for this supply path transparency record, used for auditing and reconciliation.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the supply path record indicating whether the path is currently valid and authorized for programmatic transactions.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerDomain rdf:type rdf:Property ;
    rdfs:label 'Seller Domain' ;
    rdfs:comment 'The seller\'s domain as declared in the SSP\'s sellers.json file, used for cross-verification with ads.txt declarations.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerName rdf:type rdf:Property ;
    rdfs:label 'Seller Name' ;
    rdfs:comment 'The seller name as declared in the SSP\'s sellers.json file, providing human-readable identification of the publisher or intermediary.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerType rdf:type rdf:Property ;
    rdfs:label 'Seller Type' ;
    rdfs:comment 'Classification indicating whether the SSP has a direct relationship with the publisher or is acting as a reseller, as declared in ads.txt and sellers.json.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellersJsonVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Sellers Json Verification Date' ;
    rdfs:comment 'Date when the sellers.json file was last verified for this supply path, ensuring transparency compliance.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sspDomain rdf:type rdf:Property ;
    rdfs:label 'Ssp Domain' ;
    rdfs:comment 'The domain of the SSP or exchange as declared in ads.txt, used for supply path identification and verification.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyPathQualityScore rdf:type rdf:Property ;
    rdfs:label 'Supply Path Quality Score' ;
    rdfs:comment 'Calculated quality score for this supply path based on transparency, verification status, intermediary count, and brand safety compliance. Scale 0.00 to 100.00.' ;
    rdfs:domain ind:SupplyPathRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:techPartnerId rdf:type rdf:Property ;
    rdfs:label 'Tech Partner Id' ;
    rdfs:comment 'Unique surrogate identifier for the advertising technology platform partner record in the vendor master. Primary key for the tech_partner data product.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechPartner .

ind:annualPlatformFee rdf:type rdf:Property ;
    rdfs:label 'Annual Platform Fee' ;
    rdfs:comment 'Annual licensing or platform access fee payable to the tech partner, denominated in the contract currency. Used for budget planning, P&L reporting, and financial reconciliation in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionModelSupport rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Support' ;
    rdfs:comment 'Attribution modeling methodology supported by the tech partner\'s platform for campaign performance measurement. Informs ROAS and CPA reporting configurations in Google CM360 and The Trade Desk. [ENUM-REF-CANDIDATE: last_click|first_click|linear|data_driven|multi_touch|time_decay|position_based|none — promote to reference product]' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement Flag' ;
    rdfs:comment 'Indicates whether a formal data sharing agreement (DSA) is in place with the tech partner governing the exchange of audience data, campaign performance data, and first-party data. Required for DMP/CDP integrations under GDPR and CCPA.' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement Ref' ;
    rdfs:comment 'Reference number or document identifier for the executed data sharing agreement with the tech partner. Links to the contract management system (SAP S/4HANA PS or Workfront DAM) for legal and compliance audit purposes.' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabTechLabMember rdf:type rdf:Property ;
    rdfs:label 'Iab Tech Lab Member' ;
    rdfs:comment 'Indicates whether the tech partner is an active member of the IAB Tech Lab, which governs programmatic standards including OpenRTB, VAST, VPAID, and ads.txt. Membership status informs standards compliance expectations.' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementCapability rdf:type rdf:Property ;
    rdfs:label 'Measurement Capability' ;
    rdfs:comment 'Indicates whether the tech partner provides independent measurement, viewability verification, or attribution services (e.g., IAS, DoubleVerify, Nielsen, Comscore). Determines eligibility as a third-party measurement vendor on campaign IOs.' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtbProtocolVersion rdf:type rdf:Property ;
    rdfs:label 'Rtb Protocol Version' ;
    rdfs:comment 'OpenRTB protocol version supported by the tech partner for programmatic buying and selling (e.g., OpenRTB 2.5, OpenRTB 2.6, OpenRTB 3.0). Governs bid request/response schema compatibility with The Trade Desk and other DSP integrations.' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soc2Certified rdf:type rdf:Property ;
    rdfs:label 'Soc2 Certified' ;
    rdfs:comment 'Indicates whether the tech partner holds a current SOC 2 Type II certification, confirming security, availability, and confidentiality controls. Required for partners handling first-party audience data or campaign performance data.' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyChainRole rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Role' ;
    rdfs:comment 'The partner\'s functional role within the programmatic advertising supply chain as defined by IAB ads.txt and sellers.json standards. Supports supply chain transparency audits and brand safety compliance. Values: buyer (DSP), seller (SSP/publisher), intermediary (reseller), data_provider, measurement.' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedChannels rdf:type rdf:Property ;
    rdfs:label 'Supported Channels' ;
    rdfs:comment 'Comma-separated list of advertising channels supported by the tech partner\'s platform (e.g., Display, Video, CTV, OTT, DOOH, Audio, Native, Search). Informs media planning channel eligibility in Mediaocean Prisma and The Trade Desk.' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techFeeRate rdf:type rdf:Property ;
    rdfs:label 'Tech Fee Rate' ;
    rdfs:comment 'Percentage-based technology fee charged by the partner per media dollar transacted through their platform (e.g., DSP tech fee as a percentage of media spend). Used in CPM/CPC rate card calculations and ROAS reporting in Mediaocean Prisma.' ;
    rdfs:domain ind:TechPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Indicates that this vendor contact has requested to not be contacted, or has been flagged by the agency as inactive for outreach. Ensures compliance with communication preferences and prevents unsolicited contact in line with GDPR and CCPA opt-out requirements.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExecutiveSponsor rdf:type rdf:Property ;
    rdfs:label 'Is Executive Sponsor' ;
    rdfs:comment 'Indicates whether this vendor contact holds an executive sponsor role, typically a senior stakeholder engaged for Quarterly Business Reviews (QBRs), strategic negotiations, and escalation resolution at the executive level.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTechnicalContact rdf:type rdf:Property ;
    rdfs:label 'Is Technical Contact' ;
    rdfs:comment 'Indicates whether this vendor contact is the designated technical integration lead responsible for API connections, tag implementation, DSP/SSP platform integrations, and VAST/VPAID troubleshooting.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'LinkedIn public profile URL for the vendor contact. Used for professional background verification, relationship intelligence, and executive engagement preparation ahead of QBRs and pitch meetings.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offboardingDate rdf:type rdf:Property ;
    rdfs:label 'Offboarding Date' ;
    rdfs:comment 'Date on which this vendor contact was offboarded or deactivated from the agency\'s vendor management system, typically due to departure from the vendor organisation or role change. Triggers deactivation workflows and access revocation.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesforceContactCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Contact Code' ;
    rdfs:comment 'The native 18-character Salesforce CRM Contact object identifier (Sales Cloud). Used for bi-directional synchronisation between the lakehouse Silver Layer and the Salesforce system of record.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorIoMediaInsertionOrderId rdf:type rdf:Property ;
    rdfs:label 'Vendor Io Media Insertion Order Id' ;
    rdfs:comment 'Foreign key reference to the parent Insertion Order header that this line item belongs to. Satisfies TRANSACTION_LINE HEADER_REFERENCE category — mandatory link to the parent IO.' ;
    rdfs:domain ind:IoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaInsertionOrder .

ind:actualUnitsDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Units Delivered' ;
    rdfs:comment 'The actual number of units (impressions, clicks, GRPs, etc.) delivered by the vendor for this line item as reported by the ad server or third-party measurement provider. Used in reconciliation against contracted_units to identify under- or over-delivery.' ;
    rdfs:domain ind:IoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandSafetySegments rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Segments' ;
    rdfs:comment 'Comma-separated list of brand safety and content suitability categories applied to this line item to prevent ad adjacency with inappropriate content. Aligned with TAG Brand Safety Standards and IAB Content Taxonomy.' ;
    rdfs:domain ind:IoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedSpend rdf:type rdf:Property ;
    rdfs:label 'Contracted Spend' ;
    rdfs:comment 'The total authorized spend amount for this line item as agreed in the Insertion Order (rate × contracted_units for unit-based buys, or flat rate for flat buys). Represents the financial commitment to the vendor. Core to Mediaocean Prisma billing and budget management.' ;
    rdfs:domain ind:IoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dspLineCode rdf:type rdf:Property ;
    rdfs:label 'Dsp Line Code' ;
    rdfs:comment 'The external line item identifier assigned by the Demand-Side Platform (DSP), such as The Trade Desk, for programmatic buys. Enables cross-system reconciliation between Mediaocean Prisma and the DSP platform.' ;
    rdfs:domain ind:IoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prismaLineCode rdf:type rdf:Property ;
    rdfs:label 'Prisma Line Code' ;
    rdfs:comment 'The native line item identifier from Mediaocean Prisma, the system of record for media planning, buying, billing, and reconciliation. Used for cross-system traceability and audit.' ;
    rdfs:domain ind:IoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rate rdf:type rdf:Property ;
    rdfs:label 'Rate' ;
    rdfs:comment 'The negotiated unit rate for this line item expressed in the currency of the IO. Interpretation depends on buying_type: CPM rate per 1,000 impressions, CPC rate per click, CPA rate per acquisition, flat rate for the full flight, or GRP/TRP rate per rating point. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT category.' ;
    rdfs:domain ind:IoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetingDescription rdf:type rdf:Property ;
    rdfs:label 'Targeting Description' ;
    rdfs:comment 'Free-text description of the audience targeting parameters applied to this line item, including demographic, geographic, behavioral, contextual, or keyword targeting criteria as configured in The Trade Desk or Google Campaign Manager 360.' ;
    rdfs:domain ind:IoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trpContracted rdf:type rdf:Property ;
    rdfs:label 'Trp Contracted' ;
    rdfs:comment 'The total Target Rating Points (TRPs) contracted for this line item, representing GRPs delivered specifically to the defined target audience demographic. Used for audience-guaranteed buys tracked via Nielsen Ad Intel.' ;
    rdfs:domain ind:IoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorOnboardingId rdf:type rdf:Property ;
    rdfs:label 'Vendor Onboarding Id' ;
    rdfs:comment 'Unique surrogate identifier for each vendor onboarding attempt record. One record represents one end-to-end onboarding workflow instance for one vendor (supplier). Role: TRANSACTION_HEADER — primary key.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVendorWorkerId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Worker Id' ;
    rdfs:comment 'Reference to the internal employee or team member assigned as the primary reviewer and owner of this onboarding workflow. Drives task assignment in Salesforce CRM and Workfront.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:brandSafetyReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Review Status' ;
    rdfs:comment 'Status of the brand safety compliance review, assessing whether the vendor\'s inventory, content adjacency, and operational practices meet the agency\'s brand safety standards per TAG and IAB guidelines.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaDpaExecutedDate rdf:type rdf:Property ;
    rdfs:label 'Ccpa Dpa Executed Date' ;
    rdfs:comment 'The date on which the CCPA Data Processing Agreement was formally executed and signed by both parties.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ccpaDpaStatus rdf:type rdf:Property ;
    rdfs:label 'Ccpa Dpa Status' ;
    rdfs:comment 'Status of the CCPA-compliant data processing agreement with the vendor, required for vendors processing personal information of California consumers on behalf of the agency.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligenceChecklistComplete rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Checklist Complete' ;
    rdfs:comment 'Indicates whether all items on the vendor due diligence checklist have been reviewed and signed off, covering financial, legal, operational, and compliance dimensions.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDiligenceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completion Date' ;
    rdfs:comment 'The date on which all due diligence checklist items were completed and signed off by the assigned reviewer.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Approval Date' ;
    rdfs:comment 'The date on which the final approval or rejection decision was recorded for this onboarding attempt.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Final Approval Status' ;
    rdfs:comment 'The final approval determination for the vendor onboarding attempt, granted by the designated approval authority after all review stages are complete.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialVettingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Financial Vetting Completion Date' ;
    rdfs:comment 'The date on which the financial vetting review was completed and a determination recorded.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialVettingStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Vetting Status' ;
    rdfs:comment 'Current status of the financial vetting stage, including credit checks, financial stability assessment, and payment history review conducted via SAP S/4HANA FI.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDpaExecutedDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Dpa Executed Date' ;
    rdfs:comment 'The date on which the GDPR Data Processing Agreement was formally executed and signed by both parties.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprDpaStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Dpa Status' ;
    rdfs:comment 'Status of the GDPR-compliant Data Processing Agreement (DPA) with the vendor, required for any vendor processing personal data of EU data subjects on behalf of the agency.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date on which the vendor onboarding process was formally initiated — i.e., when the RFI/RFP response was received and the workflow was opened. Serves as the principal business event date for this transaction.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:integrationTestCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Integration Test Completion Date' ;
    rdfs:comment 'The date on which system integration testing was completed and a pass/fail determination was recorded.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:integrationTestNotes rdf:type rdf:Property ;
    rdfs:label 'Integration Test Notes' ;
    rdfs:comment 'Free-text notes capturing the results, issues identified, and remediation actions from the system integration testing phase. Supports UAT (User Acceptance Testing) documentation.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationTestStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Test Status' ;
    rdfs:comment 'Status of the technical system integration testing phase, covering API connectivity, ad serving tag validation (VAST/VPAID), DSP/SSP bid stream testing, and data feed verification with The Trade Desk and Google Campaign Manager 360.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completion Date' ;
    rdfs:comment 'The date on which the legal review was completed and a final determination (approved or rejected) was recorded.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Payment Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the agreed payment currency with the vendor (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfiReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Rfi Received Date' ;
    rdfs:comment 'The date on which the vendor\'s completed RFI response was received, marking the formal start of the qualification review.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfiResponseReceived rdf:type rdf:Property ;
    rdfs:label 'Rfi Response Received' ;
    rdfs:comment 'Indicates whether the vendor has submitted a completed Request for Information (RFI) response as part of the initial qualification step of the onboarding process.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapVendorAccountCode rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Account Code' ;
    rdfs:comment 'The vendor account code assigned in SAP S/4HANA upon successful completion of onboarding, enabling financial transactions, purchase orders, and invoice processing in the ERP system.' ;
    rdfs:domain ind:VendorOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRateCardVendorRateCardId rdf:type rdf:Property ;
    rdfs:label 'Source System Rate Card Vendor Rate Card Id' ;
    rdfs:comment 'The native identifier of this rate card record in the originating source system (Mediaocean Prisma). Enables lineage tracing and reconciliation between the Silver Layer lakehouse and the operational system of record.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorRateCard .

ind:addedValueDescription rdf:type rdf:Property ;
    rdfs:label 'Added Value Description' ;
    rdfs:comment 'Free-text description of any added-value elements bundled with this rate card (e.g., bonus impressions, free creative production, data targeting inclusion, brand safety tools). Common in direct media deals and IO negotiations.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentLabel rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Label' ;
    rdfs:comment 'The audience segment or demographic targeting profile for which this rate applies (e.g., \'Adults 18-34\', \'In-Market Auto Buyers\', \'Lookalike High-Value\'). Supports audience-based rate differentiation used in DMP/CDP-driven buying on The Trade Desk.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'Broad channel classification for the media inventory covered by this rate card (e.g., digital, traditional broadcast/print, programmatic, direct-sold, out-of-home). Supports media planning and channel mix analytics.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRatePct rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Pct' ;
    rdfs:comment 'The percentage discount applied to the base_rate to arrive at the negotiated net rate (e.g., 15.00 for a 15% agency discount). Expressed as a percentage. Used in Mediaocean Prisma billing and SAP S/4HANA financial reconciliation.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoMarket rdf:type rdf:Property ;
    rdfs:label 'Geo Market' ;
    rdfs:comment 'The geographic market or region for which this rate card applies (e.g., \'USA\', \'GBR\', \'New York DMA\', \'EMEA\'). Rates may vary by market due to inventory supply and demand dynamics.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedViewabilityPct rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Viewability Pct' ;
    rdfs:comment 'The minimum viewability percentage guaranteed by the vendor for inventory sold under this rate card (e.g., 70.00 for 70% viewability guarantee). Null if no viewability guarantee is offered. Supports campaign performance KPI tracking.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ioTermsReference rdf:type rdf:Property ;
    rdfs:label 'Io Terms Reference' ;
    rdfs:comment 'Reference identifier or URL to the vendor\'s standard Insertion Order (IO) terms and conditions document associated with this rate card. Links rate card pricing to contractual obligations in Mediaocean Prisma.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNegotiatedRate rdf:type rdf:Property ;
    rdfs:label 'Is Negotiated Rate' ;
    rdfs:comment 'Indicates whether this rate is a negotiated/contracted rate (True) as opposed to the vendor\'s published open-market rate (False). Negotiated rates are commercially sensitive and used in IO reconciliation and P&L reporting.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumSpend rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend' ;
    rdfs:comment 'The minimum monetary commitment required by the vendor to activate this rate card or rate tier. Expressed in the currency defined by currency_code. Relevant for IO negotiation and budget planning.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementPosition rdf:type rdf:Property ;
    rdfs:label 'Placement Position' ;
    rdfs:comment 'The placement position or contextual location of the ad unit on the publisher\'s inventory (e.g., above_the_fold, pre_roll, homepage_takeover). Position premiums are a standard component of vendor rate cards. [ENUM-REF-CANDIDATE: above_the_fold|below_the_fold|pre_roll|mid_roll|post_roll|interstitial|homepage_takeover|run_of_site — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'The date on which the vendor formally published or issued this rate card version. Distinct from effective_start_date; a rate card may be published in advance of its effective period.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'The unit of measure against which the base_rate is applied (e.g., per_mille for CPM, per_click for CPC, per_grp for GRP-based broadcast buying, flat for fixed-fee placements). Ensures correct billing calculation in Mediaocean Prisma. [ENUM-REF-CANDIDATE: per_mille|per_click|per_acquisition|per_view|per_grp|per_day|per_week|per_month|flat — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Max' ;
    rdfs:comment 'The upper bound of the volume or spend range that qualifies for this rate tier. Nullable for the highest open-ended tier. Used with volume_threshold_min to define tier eligibility.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Min' ;
    rdfs:comment 'The lower bound of the volume or spend range (in impressions, clicks, or currency units per currency_code) that qualifies for this rate tier. Used in conjunction with volume_threshold_max to define tier eligibility.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Unit' ;
    rdfs:comment 'The unit of measure for the volume thresholds (volume_threshold_min and volume_threshold_max). Specifies whether thresholds are in impressions, clicks, currency spend, GRP points, or other measurable units.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTierLabel rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Label' ;
    rdfs:comment 'Human-readable label identifying the volume or spend tier this rate applies to (e.g., \'Tier 1: $0–$50K\', \'Tier 2: $50K–$250K\', \'Enterprise\'). Supports tiered pricing structures common in programmatic and direct media deals.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Talent Assignment Id' ;
    rdfs:comment 'Primary key for talent_assignment' ;
    rdfs:domain ind:TalentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientEngagementId rdf:type rdf:Property ;
    rdfs:label 'Client Engagement Id' ;
    rdfs:comment 'Primary key for client_engagement' ;
    rdfs:domain ind:ClientEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementId rdf:type rdf:Property ;
    rdfs:label 'Engagement Id' ;
    rdfs:comment 'Unique surrogate identifier for this engagement record in the Silver Layer lakehouse' ;
    rdfs:domain ind:ClientEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentEngagement .

ind:clientEngagementStatus rdf:type rdf:Property ;
    rdfs:label 'Client Engagement Status' ;
    rdfs:comment 'Current lifecycle state of the engagement. Active engagements are eligible for campaign assignment and time tracking. Drives workflow routing and capacity planning visibility.' ;
    rdfs:domain ind:ClientEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when this engagement record was first created in the system. Used for audit trail and engagement velocity analytics.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Unique surrogate identifier for this preferred vendor relationship record' ;
    rdfs:domain ind:PreferredVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateCardId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Id' ;
    rdfs:comment 'Reference to the negotiated rate card or pricing agreement specific to this advertiser-supplier relationship, capturing custom pricing terms' ;
    rdfs:domain ind:PreferredVendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorRateCard .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Strategic tier classification for this advertiser-supplier relationship indicating priority level, volume commitment, and preferential treatment (platinum = highest priority, approved = baseline)' ;
    rdfs:domain ind:PreferredVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAgreementId rdf:type rdf:Property ;
    rdfs:label 'Vendor Agreement Id' ;
    rdfs:comment 'Unique identifier for this vendor agreement association record. Primary key.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Supplier performance classification under this agreement based on historical delivery, compliance, and relationship quality. Drives preferential treatment, volume commitments, or probationary status.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTarget rdf:type rdf:Property ;
    rdfs:label 'Sla Target' ;
    rdfs:comment 'Service Level Agreement performance target specific to this supplier under this agreement. Examples: 99.9% uptime, 24-hour response time, viewability threshold, brand safety score minimum.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Agreement Status' ;
    rdfs:comment 'Current lifecycle status of this vendor-specific agreement. Allows individual vendor relationships to be suspended or terminated while the master agreement remains active with other vendors.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeUsageId rdf:type rdf:Property ;
    rdfs:label 'Creative Usage Id' ;
    rdfs:comment 'Unique identifier for this creative usage record. Primary key.' ;
    rdfs:domain ind:CreativeUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'Timestamp when this usage record was created in the system' ;
    rdfs:domain ind:CreativeUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spendAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Amount' ;
    rdfs:comment 'Total media spend allocated to this specific asset within this campaign. Enables asset-level budget tracking and ROI analysis.' ;
    rdfs:domain ind:CreativeUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'Timestamp when this usage record was last updated' ;
    rdfs:domain ind:CreativeUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingId rdf:type rdf:Property ;
    rdfs:label 'Booking Id' ;
    rdfs:comment 'Unique identifier for this placement booking record. Primary key.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingCode rdf:type rdf:Property ;
    rdfs:label 'Booking Code' ;
    rdfs:comment 'External business identifier for this placement booking, used in ad server trafficking and billing reconciliation.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Creative Assignment Id' ;
    rdfs:comment 'Unique identifier for this creative assignment record. Primary key.' ;
    rdfs:domain ind:CreativeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentCreatedByWorkerId rdf:type rdf:Property ;
    rdfs:label 'Assignment Created By Worker Id' ;
    rdfs:comment 'Reference to the user who created this creative assignment. Establishes accountability for trafficking decisions.' ;
    rdfs:domain ind:CreativeAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:assignmentCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Date' ;
    rdfs:comment 'Timestamp when this creative assignment was created in the system. Audit trail for trafficking workflow.' ;
    rdfs:domain ind:CreativeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Timestamp of the most recent modification to this assignment record. Supports change tracking and audit.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'The priority or sequence order of this creative within the line item\'s rotation. Used when rotation is not purely weight-based but follows a priority waterfall.' ;
    rdfs:domain ind:CreativeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rotationWeight rdf:type rdf:Property ;
    rdfs:label 'Rotation Weight' ;
    rdfs:comment 'The percentage or weight assigned to this creative asset within the line item\'s creative rotation. Used for A/B testing and dynamic creative optimization. Sum of weights across all assignments for a line item typically equals 100.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewCount rdf:type rdf:Property ;
    rdfs:label 'View Count' ;
    rdfs:comment 'The number of video views or viewable impressions for this specific creative asset on this specific line item. Applicable to video and viewability-measured formats.' ;
    rdfs:domain ind:CreativeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentActivationId rdf:type rdf:Property ;
    rdfs:label 'Segment Activation Id' ;
    rdfs:comment 'Unique identifier for this segment activation record. Primary key.' ;
    rdfs:domain ind:SegmentActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationEndDate rdf:type rdf:Property ;
    rdfs:label 'Activation End Date' ;
    rdfs:comment 'Date when this specific segment stops being targeted within this insertion order. May differ from the IO flight_end_date if segments are phased out or rotated during the campaign. Segment-level flight control.' ;
    rdfs:domain ind:SegmentActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activationStartDate rdf:type rdf:Property ;
    rdfs:label 'Activation Start Date' ;
    rdfs:comment 'Date when this specific segment becomes active for targeting within this insertion order. May differ from the IO flight_start_date if segments are phased in during the campaign flight. Segment-level flight control.' ;
    rdfs:domain ind:SegmentActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocatedBudget rdf:type rdf:Property ;
    rdfs:label 'Allocated Budget' ;
    rdfs:comment 'Portion of the insertion order\'s total_authorized_spend allocated to this segment. Used for budget pacing and segment-level ROI tracking. Sum of allocated_budget across all segments should not exceed the IO\'s total_authorized_spend.' ;
    rdfs:domain ind:SegmentActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedImpressions rdf:type rdf:Property ;
    rdfs:label 'Allocated Impressions' ;
    rdfs:comment 'Number of impressions allocated to this segment within the insertion order\'s total committed impressions. Used for pacing and delivery forecasting. Sum of allocated_impressions across all segments should not exceed the IO\'s committed_impressions.' ;
    rdfs:domain ind:SegmentActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:representationId rdf:type rdf:Property ;
    rdfs:label 'Representation Id' ;
    rdfs:comment 'Unique surrogate identifier for the representation agreement record. Primary key for the association.' ;
    rdfs:domain ind:Representation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'The commission percentage charged by the supplier agency for bookings made under this representation agreement, expressed as a decimal (e.g., 0.15 for 15%). Varies by supplier-talent combination based on negotiated terms.' ;
    rdfs:domain ind:Representation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this supplier is the primary or preferred agency contact for the talent when multiple non-exclusive representation agreements exist. Used to route initial booking inquiries and campaign briefs.' ;
    rdfs:domain ind:Representation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:representationStatus rdf:type rdf:Property ;
    rdfs:label 'Representation Status' ;
    rdfs:comment 'Current lifecycle state of the representation agreement. Values: active (currently in force), suspended (temporarily inactive), terminated (ended), pending (signed but not yet effective). Only active agreements are used for commission calculation and booking workflow.' ;
    rdfs:domain ind:Representation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Territory Restrictions' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes or region identifiers defining the geographic scope of the representation agreement (e.g., USA|CAN|MEX for North America). Used to determine which agency to contact for bookings in specific markets.' ;
    rdfs:domain ind:Representation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pixelDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Pixel Deployment Id' ;
    rdfs:comment 'Primary key for the pixel_deployment association' ;
    rdfs:domain ind:PixelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Date when this pixel was deployed through this specific tech partner platform. Tracks when the integration was established.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:errorRate rdf:type rdf:Property ;
    rdfs:label 'Error Rate' ;
    rdfs:comment 'Calculated error rate (0.00000 to 1.00000) for pixel fires through this tech partner platform over the monitoring window. Key vendor performance metric.' ;
    rdfs:domain ind:PixelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastFireTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Fire Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful pixel fire through this tech partner platform. Used to detect stale or broken integrations.' ;
    rdfs:domain ind:PixelDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adPlacementRotationId rdf:type rdf:Property ;
    rdfs:label 'Ad Placement Rotation Id' ;
    rdfs:comment 'Unique identifier for this ad-placement rotation assignment. Primary key.' ;
    rdfs:domain ind:AdPlacementRotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelSupplierAgreementId rdf:type rdf:Property ;
    rdfs:label 'Channel Supplier Agreement Id' ;
    rdfs:comment 'Unique identifier for this channel-supplier agreement record. Primary key.' ;
    rdfs:domain ind:ChannelSupplierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatedCommissionPct rdf:type rdf:Property ;
    rdfs:label 'Negotiated Commission Pct' ;
    rdfs:comment 'Agency commission percentage negotiated with this supplier for media bought through this specific channel. Channel-supplier specific rate that may differ from standard supplier terms.' ;
    rdfs:domain ind:ChannelSupplierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredStatus rdf:type rdf:Property ;
    rdfs:label 'Preferred Status' ;
    rdfs:comment 'Indicates the supplier\'s preferred vendor status for this specific channel. Preferred suppliers receive priority consideration in media planning. Values: preferred, approved, restricted, inactive.' ;
    rdfs:domain ind:ChannelSupplierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTerms rdf:type rdf:Property ;
    rdfs:label 'Sla Terms' ;
    rdfs:comment 'Free-text description of service level agreement terms specific to this channel-supplier relationship, including response times, reporting frequency, and performance guarantees.' ;
    rdfs:domain ind:ChannelSupplierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Format Availability Id' ;
    rdfs:comment 'Unique identifier for this publisher-format availability record. Primary key.' ;
    rdfs:domain ind:FormatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealId rdf:type rdf:Property ;
    rdfs:label 'Deal Id' ;
    rdfs:comment 'Programmatic deal ID for preferred access to this format from this publisher, if applicable. Links to PMP or programmatic guaranteed deals.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgrammaticDeal .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Date when availability, pricing, or performance metrics were last refreshed for this publisher-format combination.' ;
    rdfs:domain ind:FormatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advertiserSegmentLicenseId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Segment License Id' ;
    rdfs:comment 'Unique surrogate identifier for this advertiser-segment license relationship. Primary key.' ;
    rdfs:domain ind:AdvertiserSegmentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Defines the scope of permissions the advertiser has for this segment: full_access (can view, activate, and export), read_only (can view segment definition and size), activation_only (can target but not view underlying data), reporting_only (can see performance metrics only), restricted (limited by contract terms). Enforced by DSP and DMP access control systems.' ;
    rdfs:domain ind:AdvertiserSegmentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Code' ;
    rdfs:comment 'Reference identifier for the legal contract or data partnership agreement governing this license. Links to contract management system (e.g., DocuSign envelope ID, SAP Ariba contract number). Used for compliance audits and renewal tracking.' ;
    rdfs:domain ind:AdvertiserSegmentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Pct' ;
    rdfs:comment 'Percentage of segment licensing or data acquisition costs allocated to this advertiser, expressed as decimal (0.00 to 100.00). Used for shared segments where multiple advertisers split costs (e.g., co-op segments, agency-negotiated bulk licenses). Null for first-party owned segments with no external cost.' ;
    rdfs:domain ind:AdvertiserSegmentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataProviderName rdf:type rdf:Property ;
    rdfs:label 'Data Provider Name' ;
    rdfs:comment 'Name of the third-party data provider or partner who supplies this segment (e.g., Nielsen, Experian, LiveRamp, Acxiom). Null for first-party owned segments. Used for vendor management, contract tracking, and data lineage.' ;
    rdfs:domain ind:AdvertiserSegmentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseCostAmount rdf:type rdf:Property ;
    rdfs:label 'License Cost Amount' ;
    rdfs:comment 'Total cost amount for this advertiser to license or access this segment, in the currency specified by license_cost_currency. Null for first-party owned segments. Used for cost attribution, budget tracking, and ROI analysis.' ;
    rdfs:domain ind:AdvertiserSegmentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseCostCurrency rdf:type rdf:Property ;
    rdfs:label 'License Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the license cost amount (e.g., USD, EUR, GBP). Null if license_cost_amount is null.' ;
    rdfs:domain ind:AdvertiserSegmentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseCostModel rdf:type rdf:Property ;
    rdfs:label 'License Cost Model' ;
    rdfs:comment 'Pricing model for this segment license: flat_fee (fixed annual or monthly cost), cpm (cost per thousand impressions), per_activation (cost per campaign activation), revenue_share (percentage of media spend), no_cost (first-party owned or complimentary access).' ;
    rdfs:domain ind:AdvertiserSegmentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Classification of the relationship between advertiser and segment: first_party_owned (advertiser owns the underlying data), second_party_licensed (direct data partnership), third_party_licensed (purchased from data vendor), co_op_shared (industry consortium segment), lookalike_derived (modeled from advertiser seed data). Drives cost allocation and data governance policies.' ;
    rdfs:domain ind:AdvertiserSegmentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelPlatformConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Model Platform Configuration Id' ;
    rdfs:comment 'Unique identifier for this attribution model platform configuration record. Primary key.' ;
    rdfs:domain ind:ModelPlatformConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Lifecycle status of this model-platform configuration. Values: active (in production use), inactive (disabled), testing (pilot/QA), deprecated (scheduled for removal). Governs whether this configuration is used for live attribution processing.' ;
    rdfs:domain ind:ModelPlatformConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataFeedFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Feed Frequency' ;
    rdfs:comment 'Frequency at which conversion and touchpoint data is synchronized between the tech partner platform and the attribution model processing engine. Values: real-time, hourly, daily, weekly, on-demand. Impacts attribution latency and reporting freshness.' ;
    rdfs:domain ind:ModelPlatformConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseTier rdf:type rdf:Property ;
    rdfs:label 'License Tier' ;
    rdfs:comment 'Licensing tier or service level for this specific model-platform combination. Values: basic, standard, premium, enterprise. Determines feature availability, data volume limits, and support entitlements.' ;
    rdfs:domain ind:ModelPlatformConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelDeploymentDate rdf:type rdf:Property ;
    rdfs:label 'Model Deployment Date' ;
    rdfs:comment 'Date when this attribution model was first deployed and activated on this specific tech partner platform. Used for tracking model lifecycle and historical analysis.' ;
    rdfs:domain ind:ModelPlatformConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformVersion rdf:type rdf:Property ;
    rdfs:label 'Platform Version' ;
    rdfs:comment 'Version of the technology platform on which this attribution model is deployed (e.g., Google Analytics 4 v2.1, Adobe Analytics 2.8). Critical for compatibility tracking and troubleshooting.' ;
    rdfs:domain ind:ModelPlatformConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportSlaLevel rdf:type rdf:Property ;
    rdfs:label 'Support Sla Level' ;
    rdfs:comment 'Service level agreement tier for technical support and issue resolution for this model-platform configuration. Values: bronze, silver, gold, platinum. Defines response times and escalation procedures.' ;
    rdfs:domain ind:ModelPlatformConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Competitive Monitoring Id' ;
    rdfs:comment 'Unique surrogate identifier for the competitive monitoring assignment record. Serves as the primary key.' ;
    rdfs:domain ind:CompetitiveMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileBrandProfileId rdf:type rdf:Property ;
    rdfs:label 'Profile Brand Profile Id' ;
    rdfs:comment 'Foreign key linking to the client brand being monitored in the competitive intelligence program' ;
    rdfs:domain ind:CompetitiveMonitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandProfile .

ind:monitoringCadence rdf:type rdf:Property ;
    rdfs:label 'Monitoring Cadence' ;
    rdfs:comment 'The frequency at which competitive intelligence is collected and updated for this specific monitoring assignment' ;
    rdfs:domain ind:CompetitiveMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovComparisonEnabled rdf:type rdf:Property ;
    rdfs:label 'Sov Comparison Enabled' ;
    rdfs:comment 'Indicates whether Share of Voice (SOV) comparative tracking is enabled for this brand-competitor pairing' ;
    rdfs:domain ind:CompetitiveMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campaignSpokespersonId rdf:type rdf:Property ;
    rdfs:label 'Campaign Spokesperson Id' ;
    rdfs:comment 'Primary key for campaign_spokesperson' ;
    rdfs:domain ind:CampaignSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spokespersonId rdf:type rdf:Property ;
    rdfs:label 'Spokesperson Id' ;
    rdfs:comment 'Unique identifier for this campaign-spokesperson assignment record. Primary key.' ;
    rdfs:domain ind:CampaignSpokesperson ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandSpokesperson .

ind:appearanceCount rdf:type rdf:Property ;
    rdfs:label 'Appearance Count' ;
    rdfs:comment 'Number of times this spokesperson appears or is featured in creative assets for this campaign. Identified in detection phase relationship data.' ;
    rdfs:domain ind:CampaignSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when this spokesperson\'s engagement with this campaign ends.' ;
    rdfs:domain ind:CampaignSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when this spokesperson\'s engagement with this campaign begins.' ;
    rdfs:domain ind:CampaignSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'Compensation amount paid to this spokesperson specifically for this campaign engagement. Identified in detection phase relationship data.' ;
    rdfs:domain ind:CampaignSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaFormats rdf:type rdf:Property ;
    rdfs:label 'Media Formats' ;
    rdfs:comment 'Comma-separated list of media formats where this spokesperson appears in this campaign (TV, digital, print, radio, social, OOH). Identified in detection phase relationship data.' ;
    rdfs:domain ind:CampaignSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleInCampaign rdf:type rdf:Property ;
    rdfs:label 'Role In Campaign' ;
    rdfs:comment 'The role this spokesperson plays in this specific campaign: primary (lead spokesperson), supporting (secondary role), featured (guest appearance), testimonial (customer testimonial role). Identified in detection phase relationship data.' ;
    rdfs:domain ind:CampaignSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsPeriod rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Period' ;
    rdfs:comment 'Time period for which the advertiser has rights to use this spokesperson\'s likeness and content from this campaign (e.g., 12 months, perpetual, campaign duration only). Identified in detection phase relationship data.' ;
    rdfs:domain ind:CampaignSpokesperson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSupplierApprovalId rdf:type rdf:Property ;
    rdfs:label 'Brand Supplier Approval Id' ;
    rdfs:comment 'Unique surrogate identifier for the brand-supplier approval record. Primary key.' ;
    rdfs:domain ind:BrandSupplierApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandClientBrandId rdf:type rdf:Property ;
    rdfs:label 'Brand Client Brand Id' ;
    rdfs:comment 'Foreign key linking to the client brand that has approved this supplier relationship' ;
    rdfs:domain ind:BrandSupplierApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientBrand .

ind:annualSpendCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Commitment' ;
    rdfs:comment 'The committed annual media spend from this brand to this supplier, as negotiated in the commercial agreement. Used for volume-based rate negotiations and supplier relationship management.' ;
    rdfs:domain ind:BrandSupplierApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentCurrency rdf:type rdf:Property ;
    rdfs:label 'Commitment Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annual spend commitment (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:BrandSupplierApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionList rdf:type rdf:Property ;
    rdfs:label 'Exclusion List' ;
    rdfs:comment 'Brand-specific content exclusion keywords or categories for this supplier relationship. Defines content adjacency restrictions beyond the supplier\'s default brand safety tier.' ;
    rdfs:domain ind:BrandSupplierApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFormats rdf:type rdf:Property ;
    rdfs:label 'Preferred Formats' ;
    rdfs:comment 'Comma-separated list of preferred ad formats for this brand-supplier relationship (e.g., 300x250, 728x90, video_15s, native). Format preferences may vary by brand even for the same supplier.' ;
    rdfs:domain ind:BrandSupplierApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAccountManager rdf:type rdf:Property ;
    rdfs:label 'Primary Account Manager' ;
    rdfs:comment 'Name or identifier of the agency account manager responsible for this brand-supplier relationship.' ;
    rdfs:domain ind:BrandSupplierApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateNegotiationStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Negotiation Status' ;
    rdfs:comment 'Status of commercial rate negotiation between this brand and supplier. Indicates whether brand-specific rates have been negotiated or standard rates apply.' ;
    rdfs:domain ind:BrandSupplierApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioCreativeTraffickingId rdf:type rdf:Property ;
    rdfs:label 'Io Creative Trafficking Id' ;
    rdfs:comment 'Unique surrogate identifier for this IO-creative trafficking assignment record' ;
    rdfs:domain ind:IoCreativeTrafficking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Worker Id' ;
    rdfs:comment 'Reference to the user who approved this creative asset for this IO. Establishes accountability for creative approval decisions' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:creativeStatus rdf:type rdf:Property ;
    rdfs:label 'Creative Status' ;
    rdfs:comment 'Current workflow status of this creative asset within this IO. Tracks progression from trafficking through live execution to completion. Values: pending_trafficking, trafficked, live, paused, completed, rejected' ;
    rdfs:domain ind:IoCreativeTrafficking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationId rdf:type rdf:Property ;
    rdfs:label 'Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for this allocation record linking a work package to a media plan' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Allocation .

ind:actualSpendFromWorkPackage rdf:type rdf:Property ;
    rdfs:label 'Actual Spend From Work Package' ;
    rdfs:comment 'Actual cost incurred from the work package allocated to this media plan. Derived from work_package.actual_cost multiplied by allocation_percentage. Used for cost variance analysis and billing attribution.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Allocated Effort Hours' ;
    rdfs:comment 'Planned labor hours from the work package allocated to this media plan. Derived from work_package.planned_effort_hours multiplied by allocation_percentage. Used for resource capacity planning and utilization tracking.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Timestamp when this allocation record was last modified. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'Percentage of the work package effort and cost allocated to this specific media plan. Enables proportional distribution when one work package supports multiple media plans. Sum of allocation_percentage across all media plans for a given work package should equal 100.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSpendFromWorkPackage rdf:type rdf:Property ;
    rdfs:label 'Planned Spend From Work Package' ;
    rdfs:comment 'Planned cost amount from the work package budget allocated to this media plan. Derived from work_package.planned_cost multiplied by allocation_percentage. Used for budget planning and cost forecasting at the media plan level.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planAssetAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Plan Asset Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for the plan-asset assignment record' ;
    rdfs:domain ind:PlanAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedByWorkerId rdf:type rdf:Property ;
    rdfs:label 'Assigned By Worker Id' ;
    rdfs:comment 'Reference to the media planner or user who assigned this creative asset to the media plan. Supports accountability and audit trail.' ;
    rdfs:domain ind:PlanAssetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Timestamp when this creative asset was assigned to the media plan. Tracks planning workflow history.' ;
    rdfs:domain ind:PlanAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelAssignment rdf:type rdf:Property ;
    rdfs:label 'Channel Assignment' ;
    rdfs:comment 'Comma-separated list of specific media channels for which this asset is assigned within the plan (e.g., digital_display, social_paid, video_pre_roll). Enables channel-specific creative assignments when a plan spans multiple channels.' ;
    rdfs:domain ind:PlanAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketAssignment rdf:type rdf:Property ;
    rdfs:label 'Market Assignment' ;
    rdfs:comment 'Comma-separated list of specific geographic markets or DMAs for which this asset is assigned within the plan. Enables market-specific creative localization (e.g., NYC gets one asset, LA gets another).' ;
    rdfs:domain ind:PlanAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedUsageEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned Usage End Date' ;
    rdfs:comment 'The date on which this creative asset is planned to stop running as part of this media plan. Enables phased creative rotation strategies.' ;
    rdfs:domain ind:PlanAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedUsageStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Usage Start Date' ;
    rdfs:comment 'The date on which this creative asset is planned to begin running as part of this media plan. May differ from the overall plan flight dates if assets are rotated or phased.' ;
    rdfs:domain ind:PlanAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:traffickingPriority rdf:type rdf:Property ;
    rdfs:label 'Trafficking Priority' ;
    rdfs:comment 'Priority level for trafficking this asset to media vendors and platforms (high, medium, low, standard). Indicates urgency and sequencing for the trafficking team during campaign execution.' ;
    rdfs:domain ind:PlanAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentUsageId rdf:type rdf:Property ;
    rdfs:label 'Segment Usage Id' ;
    rdfs:comment 'Unique identifier for this segment usage record. Primary key.' ;
    rdfs:domain ind:SegmentUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clicksDelivered rdf:type rdf:Property ;
    rdfs:label 'Clicks Delivered' ;
    rdfs:comment 'Total number of clicks generated from this segment within this initiative. Populated from ad server or DSP reporting.' ;
    rdfs:domain ind:SegmentUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Conversions Delivered' ;
    rdfs:comment 'Total number of conversions attributed to this segment within this initiative. Populated from attribution platform.' ;
    rdfs:domain ind:SegmentUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Total number of ad impressions delivered to this segment within this initiative. Populated from ad server or DSP reporting.' ;
    rdfs:domain ind:SegmentUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentRole rdf:type rdf:Property ;
    rdfs:label 'Segment Role' ;
    rdfs:comment 'The tactical role this segment plays within the initiative: primary_target (main audience), secondary_target (additional reach), exclusion (negative targeting), lookalike_seed (modeling source), suppression (frequency cap), control_group, or test_group. Identified in detection phase as core relationship data.' ;
    rdfs:domain ind:SegmentUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformActivationId rdf:type rdf:Property ;
    rdfs:label 'Platform Activation Id' ;
    rdfs:comment 'Unique surrogate identifier for this platform activation record. Primary key.' ;
    rdfs:domain ind:PlatformActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiCredentialsRef rdf:type rdf:Property ;
    rdfs:label 'Api Credentials Ref' ;
    rdfs:comment 'Reference identifier or vault key for project-specific API credentials used to integrate with this tech platform. Supports secure credential management per initiative.' ;
    rdfs:domain ind:PlatformActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when the tech platform was deactivated or integration was terminated for this initiative. Null if still active. Supports historical tracking of platform usage across project lifecycle.' ;
    rdfs:domain ind:PlatformActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:integrationScope rdf:type rdf:Property ;
    rdfs:label 'Integration Scope' ;
    rdfs:comment 'Defines the scope of platform integration for this specific initiative (e.g., full programmatic integration, limited pilot, measurement only, data sharing only). Varies by project needs and budget.' ;
    rdfs:domain ind:PlatformActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformFeeAllocated rdf:type rdf:Property ;
    rdfs:label 'Platform Fee Allocated' ;
    rdfs:comment 'Portion of the tech partner\'s platform fee allocated to this specific initiative, denominated in the project\'s budget currency. Used for project cost accounting and budget tracking.' ;
    rdfs:domain ind:PlatformActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageVolume rdf:type rdf:Property ;
    rdfs:label 'Usage Volume' ;
    rdfs:comment 'Quantitative measure of platform usage for this initiative (e.g., impressions served, data records processed, API calls made). Unit of measure depends on platform type and billing model.' ;
    rdfs:domain ind:PlatformActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advertiserCostCenterAllocationId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Cost Center Allocation Id' ;
    rdfs:comment 'Primary key for advertiser_cost_center_allocation' ;
    rdfs:domain ind:AdvertiserCostCenterAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The driver or methodology used to determine the allocation percentage. Examples: headcount, revenue, square footage, FTE hours, transaction volume. Provides transparency for allocation logic.' ;
    rdfs:domain ind:AdvertiserCostCenterAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the allocation method. Direct allocations are costs incurred specifically for the advertiser. Indirect allocations are shared costs distributed based on allocation drivers. Overhead allocations are general agency costs. Shared service allocations are for centralized functions.' ;
    rdfs:domain ind:AdvertiserCostCenterAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Amount' ;
    rdfs:comment 'The budgeted amount allocated from this cost center to this advertiser for the effective period. Used for budget-vs-actual variance analysis.' ;
    rdfs:domain ind:AdvertiserCostCenterAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAllocationReference rdf:type rdf:Property ;
    rdfs:label 'Sap Allocation Reference' ;
    rdfs:comment 'Reference identifier for the corresponding allocation record in SAP S/4HANA CO module. Enables reconciliation between the data lake and ERP system.' ;
    rdfs:domain ind:AdvertiserCostCenterAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Asset Deployment Id' ;
    rdfs:comment 'Unique system-generated identifier for each asset deployment record. Primary key.' ;
    rdfs:domain ind:AssetDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Asset Performance Score' ;
    rdfs:comment 'Performance score measuring the effectiveness of this specific asset within this specific PR campaign context. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AssetDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deploymentEndDate rdf:type rdf:Property ;
    rdfs:label 'Deployment End Date' ;
    rdfs:comment 'The date when the asset deployment concluded or was deactivated from the PR campaign.' ;
    rdfs:domain ind:AssetDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaPlacementCount rdf:type rdf:Property ;
    rdfs:label 'Media Placement Count' ;
    rdfs:comment 'The number of media placements or appearances this specific asset achieved within this PR campaign. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AssetDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'Descriptive context of how and where the asset is being used within the PR campaign (e.g., press kit header, media release logo, event backdrop). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AssetDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetApprovalId rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Id' ;
    rdfs:comment 'Unique identifier for this budget approval authority record. Primary key.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'The hierarchical approval authority level assigned to this worker for this budget (e.g., department_head, finance_controller, CFO). Determines approval workflow routing and escalation paths. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Limit Amount' ;
    rdfs:comment 'The maximum budget amount this worker is authorized to approve in the budgets currency. Amounts exceeding this limit require escalation to higher authority levels. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedBy rdf:type rdf:Property ;
    rdfs:label 'Assigned By' ;
    rdfs:comment 'Name or identifier of the individual who assigned this approval authority. Used for audit trail and accountability.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'The date when this approval authority was originally assigned to the worker for this budget. Used for audit trail and governance reporting.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delegationEndDate rdf:type rdf:Property ;
    rdfs:label 'Delegation End Date' ;
    rdfs:comment 'The date when this workers approval authority for this budget expires. Nullable for permanent authority assignments. Supports temporary delegation scenarios. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delegationStartDate rdf:type rdf:Property ;
    rdfs:label 'Delegation Start Date' ;
    rdfs:comment 'The date when this workers approval authority for this budget becomes effective. Supports temporary delegation scenarios (e.g., during manager absence). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'The workers preferred notification channel for budget approval requests related to this specific budget (email, SMS, Slack, Teams). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveTargetingId rdf:type rdf:Property ;
    rdfs:label 'Competitive Targeting Id' ;
    rdfs:comment 'Unique identifier for this campaign-competitive brand targeting relationship. Primary key.' ;
    rdfs:domain ind:CompetitiveTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocatedVsCompetitor rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Vs Competitor' ;
    rdfs:comment 'Portion of campaign budget specifically allocated to competitive tactics against this competitor brand' ;
    rdfs:domain ind:CompetitiveTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveResponseType rdf:type rdf:Property ;
    rdfs:label 'Competitive Response Type' ;
    rdfs:comment 'The type of competitive strategy employed against this specific competitor brand in this campaign (e.g., conquest, defensive, comparative advertising, share steal, awareness parity)' ;
    rdfs:domain ind:CompetitiveTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterStrategyNotes rdf:type rdf:Property ;
    rdfs:label 'Counter Strategy Notes' ;
    rdfs:comment 'Free-text notes documenting the specific counter-strategy, tactics, messaging, and creative approach used to target this competitor brand within this campaign' ;
    rdfs:domain ind:CompetitiveTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shareOfVoiceTargetVsCompetitor rdf:type rdf:Property ;
    rdfs:label 'Share Of Voice Target Vs Competitor' ;
    rdfs:comment 'Target share of voice percentage relative to this specific competitor brand. Represents the desired ratio of campaign impressions to competitor impressions in the target market.' ;
    rdfs:domain ind:CompetitiveTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetingStatus rdf:type rdf:Property ;
    rdfs:label 'Targeting Status' ;
    rdfs:comment 'Current status of the competitive targeting for this campaign-competitor pair' ;
    rdfs:domain ind:CompetitiveTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefApproverId rdf:type rdf:Property ;
    rdfs:label 'Brief Approver Id' ;
    rdfs:comment 'Unique surrogate identifier for each brief approver record. Primary key.' ;
    rdfs:domain ind:BriefApprover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalChain rdf:type rdf:Property ;
    rdfs:label 'Approval Chain' ;
    rdfs:comment 'Ordered list of stakeholders and roles who must review and approve the creative brief and resulting assets, including sequence and approval authority. [Moved from creative_brief: The approval_chain attribute in creative_brief is a denormalized representation of the approval workflow. The proper normalized model stores each approver as a separate record in the brief_approver association with their role, sequence, and status. This allows for operational management of individual approvals rather than storing a static string.]' ;
    rdfs:domain ind:BriefApprover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRole rdf:type rdf:Property ;
    rdfs:label 'Approval Role' ;
    rdfs:comment 'The functional role this contact plays in the approval process for this specific brief. Defines their approval authority and perspective (e.g., Brand Manager, Legal Reviewer, Finance Approver). Sourced from detection phase relationship data.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalSequence rdf:type rdf:Property ;
    rdfs:label 'Approval Sequence' ;
    rdfs:comment 'The position of this approver in the approval chain workflow. Defines the order in which approvals must be obtained (e.g., 1 = first approver, 2 = second approver). Sourced from detection phase relationship data.' ;
    rdfs:domain ind:BriefApprover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedbackProvided rdf:type rdf:Property ;
    rdfs:label 'Feedback Provided' ;
    rdfs:comment 'Comments, feedback, or conditions provided by this approver during their review. Captures approval notes, requested changes, or rejection reasons. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:BriefApprover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRequiredApprover rdf:type rdf:Property ;
    rdfs:label 'Is Required Approver' ;
    rdfs:comment 'Indicates whether this approver\'s approval is mandatory for the brief to proceed to production, or if they are an optional/advisory reviewer.' ;
    rdfs:domain ind:BriefApprover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notifiedDate rdf:type rdf:Property ;
    rdfs:label 'Notified Date' ;
    rdfs:comment 'Date when this approver was notified that the brief is ready for their review. Used to track approval cycle time and SLA compliance.' ;
    rdfs:domain ind:BriefApprover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proofReviewId rdf:type rdf:Property ;
    rdfs:label 'Proof Review Id' ;
    rdfs:comment 'Unique identifier for this proof review record. Primary key.' ;
    rdfs:domain ind:ProofReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactClientContactId rdf:type rdf:Property ;
    rdfs:label 'Contact Client Contact Id' ;
    rdfs:comment 'Foreign key linking to the client contact who participated in this proof review' ;
    rdfs:domain ind:ProofReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:commentsCount rdf:type rdf:Property ;
    rdfs:label 'Comments Count' ;
    rdfs:comment 'Number of comments and annotations this specific reviewer submitted on this proof. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:ProofReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRequiredReviewer rdf:type rdf:Property ;
    rdfs:label 'Is Required Reviewer' ;
    rdfs:comment 'Indicates whether this reviewer\'s approval was mandatory for the proof to proceed (true) or if they were an optional/informational reviewer (false). Used for approval workflow logic.' ;
    rdfs:domain ind:ProofReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDurationHours rdf:type rdf:Property ;
    rdfs:label 'Review Duration Hours' ;
    rdfs:comment 'Calculated time in hours this reviewer took to complete their review, from proof submission to their decision timestamp. Used for stakeholder engagement analytics.' ;
    rdfs:domain ind:ProofReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewRound rdf:type rdf:Property ;
    rdfs:label 'Review Round' ;
    rdfs:comment 'The review round number in which this contact participated for this proof (1 = first client review, 2 = second round after revisions, etc.). Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:ProofReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ioAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Io Authorization Id' ;
    rdfs:comment 'Unique surrogate identifier for each IO authorization record' ;
    rdfs:domain ind:IoAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date on which the authorizing party formally approved this IO. Establishes the legal effective date of the contractual commitment. [Moved from media_insertion_order: This attribute currently stores a single authorization date on the IO record, but in reality multiple contacts sign at different times. This should be removed from media_insertion_order and replaced by signature_date in the io_authorization association, which tracks the specific timestamp for each signatory.]' ;
    rdfs:domain ind:IoAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'The level or tier of authorization this signature represents (e.g., primary approver, secondary approver, conditional approval). Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:IoAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationMethod rdf:type rdf:Property ;
    rdfs:label 'Authorization Method' ;
    rdfs:comment 'Method by which the IO was authorized by the client or agency. Supports legal audit trails and e-signature compliance under applicable regulations. [Moved from media_insertion_order: This attribute currently stores a single authorization method on the IO record, but different signatories may use different methods (e.g., legal uses DocuSign, finance uses email approval). This should be removed from media_insertion_order and replaced by signature_method in the io_authorization association, which tracks the method used by each specific signatory.]' ;
    rdfs:domain ind:IoAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationNotes rdf:type rdf:Property ;
    rdfs:label 'Authorization Notes' ;
    rdfs:comment 'Free-text notes or conditions attached to this authorization by the signatory (e.g., \'Approved pending legal review\', \'Conditional on budget availability\').' ;
    rdfs:domain ind:IoAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current status of this specific authorization record. Tracks whether the signature is still valid or has been revoked/expired.' ;
    rdfs:domain ind:IoAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizingPartyName rdf:type rdf:Property ;
    rdfs:label 'Authorizing Party Name' ;
    rdfs:comment 'Full name of the individual (client or agency representative) who authorized and signed off on this IO. Required for legal enforceability and audit compliance. [Moved from media_insertion_order: This attribute currently stores a single authorizing party name on the IO record, but in reality multiple contacts authorize each IO in different roles. This attribute should be removed from media_insertion_order and replaced by the io_authorization association, which properly models the many-to-many relationship and captures which specific contact authorized in which role.]' ;
    rdfs:domain ind:IoAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryRole rdf:type rdf:Property ;
    rdfs:label 'Signatory Role' ;
    rdfs:comment 'The functional role in which this contact authorized the IO. Multiple contacts may sign the same IO in different capacities (e.g., legal signatory, budget approver). Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:IoAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Precise timestamp when this contact completed their signature or authorization action for this IO. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:IoAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureMethod rdf:type rdf:Property ;
    rdfs:label 'Signature Method' ;
    rdfs:comment 'The mechanism used to capture this contacts authorization (e.g., DocuSign, wet signature, email approval). Supports legal audit requirements. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:IoAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetBudgetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Asset Budget Allocation Id' ;
    rdfs:comment 'Unique identifier for this asset-budget allocation record. Primary key for the association.' ;
    rdfs:domain ind:AssetBudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placementId rdf:type rdf:Property ;
    rdfs:label 'Placement Id' ;
    rdfs:comment 'Primary key for placement' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Placement .

ind:channelPreference rdf:type rdf:Property ;
    rdfs:label 'Channel Preference' ;
    rdfs:comment 'Preferred communication channel for reaching recipients in this group.' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Unique business code or identifier for the recipient group used in external systems and reporting.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLevel rdf:type rdf:Property ;
    rdfs:label 'Consent Level' ;
    rdfs:comment 'Level of consent obtained from recipients in this group for marketing communications.' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed business description of the recipient group, including segmentation criteria and intended use cases.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Estimated total business value or revenue potential of this recipient group.' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDynamic rdf:type rdf:Property ;
    rdfs:label 'Is Dynamic' ;
    rdfs:comment 'Indicates whether the recipient group membership is dynamically updated based on criteria (true) or is a static list (false).' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSuppressionList rdf:type rdf:Property ;
    rdfs:label 'Is Suppression List' ;
    rdfs:comment 'Indicates whether this recipient group is used as a suppression or exclusion list to prevent message delivery.' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of individual recipients currently included in this group.' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Human-readable name of the recipient group used for identification and display purposes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Timestamp' ;
    rdfs:comment 'Scheduled date and time for the next refresh of the recipient group membership.' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optInRequired rdf:type rdf:Property ;
    rdfs:label 'Opt In Required' ;
    rdfs:comment 'Indicates whether explicit opt-in consent is required for recipients in this group to receive communications.' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentationCriteria rdf:type rdf:Property ;
    rdfs:label 'Segmentation Criteria' ;
    rdfs:comment 'Detailed criteria and rules used to define membership in this recipient group, including filters, conditions, and logic.' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceListCode rdf:type rdf:Property ;
    rdfs:label 'Source List Code' ;
    rdfs:comment 'External identifier of the source list or audience segment in the originating system.' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the recipient group indicating whether it is actively used in campaigns.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceProfile rdf:type rdf:Property ;
    rdfs:label 'Target Audience Profile' ;
    rdfs:comment 'Summary profile of the target audience characteristics for this recipient group, including key demographic and behavioral attributes.' ;
    rdfs:domain ind:RecipientGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:type rdf:type rdf:Property ;
    rdfs:label 'Type' ;
    rdfs:comment 'Classification of the recipient group based on segmentation methodology (demographic, behavioral, geographic, psychographic, custom, or lookalike).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predecessorStepId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Step Id' ;
    rdfs:comment 'Reference to the workflow step that must be completed before this step can begin.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkflowStep .

ind:workflowId rdf:type rdf:Property ;
    rdfs:label 'Workflow Id' ;
    rdfs:comment 'Reference to the parent workflow or process template that this step belongs to.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovalWorkflow .

ind:assignedRole rdf:type rdf:Property ;
    rdfs:label 'Assigned Role' ;
    rdfs:comment 'The default role or position assigned to execute this workflow step.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationEnabled rdf:type rdf:Property ;
    rdfs:label 'Automation Enabled' ;
    rdfs:comment 'Indicates whether this workflow step can be executed automatically without manual intervention.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationScript rdf:type rdf:Property ;
    rdfs:label 'Automation Script' ;
    rdfs:comment 'Reference to the automation script or integration endpoint used to execute this step automatically.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center or department code associated with this workflow step for financial tracking and allocation.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRole rdf:type rdf:Property ;
    rdfs:label 'Escalation Role' ;
    rdfs:comment 'The role or position to which this workflow step should be escalated if threshold is exceeded.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Hours' ;
    rdfs:comment 'Number of hours after which this step should be escalated if not completed.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Standard estimated time in hours required to complete this workflow step.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalSystemCode rdf:type rdf:Property ;
    rdfs:label 'External System Code' ;
    rdfs:comment 'Identifier for this workflow step in external project management systems such as Workfront or Monday.com.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isParallelEligible rdf:type rdf:Property ;
    rdfs:label 'Is Parallel Eligible' ;
    rdfs:comment 'Indicates whether this step can be executed in parallel with other steps in the workflow.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTemplate rdf:type rdf:Property ;
    rdfs:label 'Notification Template' ;
    rdfs:comment 'Reference to the notification or communication template triggered when this step is reached or completed.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityChecklist rdf:type rdf:Property ;
    rdfs:label 'Quality Checklist' ;
    rdfs:comment 'Reference to the quality assurance checklist or criteria that must be met for this step to be considered complete.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Approval' ;
    rdfs:comment 'Indicates whether this workflow step requires formal approval before proceeding to the next step.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDurationHours rdf:type rdf:Property ;
    rdfs:label 'Sla Duration Hours' ;
    rdfs:comment 'Maximum time in hours allowed for this step to be completed per service level agreement.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepCategory rdf:type rdf:Property ;
    rdfs:label 'Step Category' ;
    rdfs:comment 'Business domain or functional area that this workflow step belongs to.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCode rdf:type rdf:Property ;
    rdfs:label 'Step Code' ;
    rdfs:comment 'Unique business code or identifier for the workflow step used across systems and reporting.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepName rdf:type rdf:Property ;
    rdfs:label 'Step Name' ;
    rdfs:comment 'Human-readable name of the workflow step (e.g., \'Creative Review\', \'Client Approval\', \'Media Placement\').' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Classification of the workflow step indicating its functional purpose within the workflow.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'The type of action the rule will execute when its conditions are met (e.g., increase bid, decrease bid, pause campaign, resume campaign, adjust budget, rotate creative, exclude placement). [ENUM-REF-CANDIDATE: increase_bid|decrease_bid|pause_campaign|resume_campaign|adjust_budget|rotate_creative|exclude_placement|send_alert|change_targeting — promote to reference product]' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionUnit rdf:type rdf:Property ;
    rdfs:label 'Action Unit' ;
    rdfs:comment 'The unit of measure for the action value (e.g., percentage, absolute currency amount, multiplier, count, impressions, clicks).' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionValue rdf:type rdf:Property ;
    rdfs:label 'Action Value' ;
    rdfs:comment 'The numeric value associated with the action (e.g., bid adjustment percentage, budget increase amount, frequency cap limit).' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliesToScope rdf:type rdf:Property ;
    rdfs:label 'Applies To Scope' ;
    rdfs:comment 'The level of the campaign hierarchy to which this rule applies (e.g., campaign, ad group, ad, keyword, placement, creative).' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApply rdf:type rdf:Property ;
    rdfs:label 'Auto Apply' ;
    rdfs:comment 'Indicates whether the rule automatically applies changes when triggered (true) or requires manual approval (false).' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelFilter rdf:type rdf:Property ;
    rdfs:label 'Channel Filter' ;
    rdfs:comment 'Comma-separated list of advertising channels to which this rule applies (e.g., search, display, social, video, native). Empty means applies to all channels.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionLogic rdf:type rdf:Property ;
    rdfs:label 'Condition Logic' ;
    rdfs:comment 'The logical expression or criteria that must be met for the rule to trigger. May include thresholds, comparisons, and boolean operators.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooldownPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Cooldown Period Hours' ;
    rdfs:comment 'The minimum number of hours that must elapse between consecutive executions of the rule, preventing rapid successive changes.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Days Of Week' ;
    rdfs:comment 'Comma-separated list of days of the week when the rule is active (e.g., Monday, Tuesday, Wednesday). Empty means applies to all days.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFilter rdf:type rdf:Property ;
    rdfs:label 'Device Filter' ;
    rdfs:comment 'Comma-separated list of device types to which this rule applies (e.g., desktop, mobile, tablet). Empty means applies to all devices.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationWindowHours rdf:type rdf:Property ;
    rdfs:label 'Evaluation Window Hours' ;
    rdfs:comment 'The time window in hours over which the rule evaluates performance data before triggering an action.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionCount rdf:type rdf:Property ;
    rdfs:label 'Execution Count' ;
    rdfs:comment 'The total number of times the optimization rule has been executed since creation.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionFrequency rdf:type rdf:Property ;
    rdfs:label 'Execution Frequency' ;
    rdfs:comment 'How often the rule is evaluated and potentially executed (e.g., real-time, hourly, daily, weekly, on-demand).' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoFilter rdf:type rdf:Property ;
    rdfs:label 'Geo Filter' ;
    rdfs:comment 'Comma-separated list of geographic locations (countries, regions, cities) to which this rule applies. Empty means applies to all locations.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExecutedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Executed Timestamp' ;
    rdfs:comment 'The date and time when the optimization rule was last executed and triggered an action. Nullable if never executed.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxExecutionsPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Executions Per Day' ;
    rdfs:comment 'The maximum number of times the rule can be executed within a single day, used to prevent over-optimization or excessive changes.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled' ;
    rdfs:comment 'Indicates whether notifications should be sent when the rule is triggered and executed.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses or user identifiers who should receive notifications when the rule executes.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdMetric rdf:type rdf:Property ;
    rdfs:label 'Threshold Metric' ;
    rdfs:comment 'The performance metric or key performance indicator (KPI) that the rule monitors (e.g., cost per acquisition, click-through rate, return on ad spend, impressions, conversions).' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'The comparison operator used to evaluate the threshold condition (e.g., greater than, less than, equal to, greater or equal, less or equal, not equal).' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The numeric threshold value that triggers the rule when the monitored metric crosses this boundary.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeOfDayEnd rdf:type rdf:Property ;
    rdfs:label 'Time Of Day End' ;
    rdfs:comment 'The end time of day (HH:MM format, 24-hour) when the rule is active for dayparting rules. Nullable if not applicable.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOfDayStart rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Start' ;
    rdfs:comment 'The start time of day (HH:MM format, 24-hour) when the rule is active for dayparting rules. Nullable if not applicable.' ;
    rdfs:domain ind:OptimizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementAlgorithmId rdf:type rdf:Property ;
    rdfs:label 'Replacement Algorithm Id' ;
    rdfs:comment 'Reference to the successor algorithm that replaces this one, if deprecated.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OptimizationAlgorithm .

ind:algorithmCategory rdf:type rdf:Property ;
    rdfs:label 'Algorithm Category' ;
    rdfs:comment 'Technical category describing the underlying approach of the algorithm (machine learning, rule-based, heuristic, or hybrid).' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmCode rdf:type rdf:Property ;
    rdfs:label 'Algorithm Code' ;
    rdfs:comment 'Unique business identifier code for the algorithm, used in system integrations and reporting.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmName rdf:type rdf:Property ;
    rdfs:label 'Algorithm Name' ;
    rdfs:comment 'Human-readable name of the optimization algorithm (e.g., \'Budget Pacing\', \'Bid Optimization\', \'Creative Rotation\').' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableChannels rdf:type rdf:Property ;
    rdfs:label 'Applicable Channels' ;
    rdfs:comment 'Comma-separated list of advertising channels where this algorithm can be applied (e.g., \'display,video,social,search,audio\').' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableFormats rdf:type rdf:Property ;
    rdfs:label 'Applicable Formats' ;
    rdfs:comment 'Comma-separated list of creative formats supported by this algorithm (e.g., \'banner,video,native,rich_media\').' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averagePerformanceLiftPercent rdf:type rdf:Property ;
    rdfs:label 'Average Performance Lift Percent' ;
    rdfs:comment 'Historical average performance improvement percentage achieved by this algorithm compared to baseline or control campaigns.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceThreshold rdf:type rdf:Property ;
    rdfs:label 'Confidence Threshold' ;
    rdfs:comment 'Minimum confidence level required for the algorithm to make optimization decisions, expressed as a decimal (0.0 to 1.0).' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerUse rdf:type rdf:Property ;
    rdfs:label 'Cost Per Use' ;
    rdfs:comment 'Cost incurred per execution or application of the algorithm, if usage-based pricing applies.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'Web address linking to detailed technical and business documentation for the algorithm.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProprietary rdf:type rdf:Property ;
    rdfs:label 'Is Proprietary' ;
    rdfs:comment 'Indicates whether the algorithm is proprietary intellectual property developed in-house (true) or licensed from external vendor (false).' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:learningRate rdf:type rdf:Property ;
    rdfs:label 'Learning Rate' ;
    rdfs:comment 'Rate at which the algorithm adapts to new data and performance signals, typically between 0.0001 and 1.0.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lookbackWindowHours rdf:type rdf:Property ;
    rdfs:label 'Lookback Window Hours' ;
    rdfs:comment 'Time window in hours that the algorithm considers when analyzing historical performance data for optimization decisions.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Budget Amount' ;
    rdfs:comment 'Minimum campaign budget amount required for the algorithm to be applied, if applicable.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumDataPoints rdf:type rdf:Property ;
    rdfs:label 'Minimum Data Points' ;
    rdfs:comment 'Minimum number of data observations required before the algorithm begins making optimization decisions.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceBenchmarkMetric rdf:type rdf:Property ;
    rdfs:label 'Performance Benchmark Metric' ;
    rdfs:comment 'Primary key performance indicator (KPI) used to measure and benchmark the algorithm\'s effectiveness (e.g., \'CTR improvement %\', \'CPA reduction %\').' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresMinimumBudget rdf:type rdf:Property ;
    rdfs:label 'Requires Minimum Budget' ;
    rdfs:comment 'Indicates whether the algorithm requires a minimum campaign budget threshold to function effectively.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsCrossChannel rdf:type rdf:Property ;
    rdfs:label 'Supports Cross Channel' ;
    rdfs:comment 'Indicates whether the algorithm can optimize across multiple advertising channels (display, video, social, search).' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsProgrammaticGuaranteed rdf:type rdf:Property ;
    rdfs:label 'Supports Programmatic Guaranteed' ;
    rdfs:comment 'Indicates whether the algorithm is compatible with programmatic guaranteed deal types.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRealTimeBidding rdf:type rdf:Property ;
    rdfs:label 'Supports Real Time Bidding' ;
    rdfs:comment 'Indicates whether the algorithm can operate in real-time bidding environments with sub-second decision requirements.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updateFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Update Frequency Minutes' ;
    rdfs:comment 'Frequency in minutes at which the algorithm recalculates and applies optimization adjustments.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the technology vendor or provider of the algorithm, if sourced externally.' ;
    rdfs:domain ind:OptimizationAlgorithm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyId rdf:type rdf:Property ;
    rdfs:label 'Survey Id' ;
    rdfs:comment 'Reference to the parent survey program or study to which this wave belongs.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Survey .

ind:actualSampleSize rdf:type rdf:Property ;
    rdfs:label 'Actual Sample Size' ;
    rdfs:comment 'Actual number of completed survey responses collected during this wave.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageCompletionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Completion Time Minutes' ;
    rdfs:comment 'Mean time in minutes required for respondents to complete the survey in this wave.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Primary mode or channel through which survey responses are collected.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldEndDate rdf:type rdf:Property ;
    rdfs:label 'Field End Date' ;
    rdfs:comment 'Date when data collection for this survey wave ends or is scheduled to end.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldStartDate rdf:type rdf:Property ;
    rdfs:label 'Field Start Date' ;
    rdfs:comment 'Date when data collection for this survey wave begins or began.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Incentive Description' ;
    rdfs:comment 'Description of the incentive or compensation offered to respondents (e.g., \'$10 gift card\', \'500 loyalty points\').' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveOffered rdf:type rdf:Property ;
    rdfs:label 'Incentive Offered' ;
    rdfs:comment 'Indicates whether respondents were offered compensation or incentives for completing the survey.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidenceRatePercent rdf:type rdf:Property ;
    rdfs:label 'Incidence Rate Percent' ;
    rdfs:comment 'Percentage of screened respondents who qualify for the survey based on targeting criteria.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:questionnaireVersion rdf:type rdf:Property ;
    rdfs:label 'Questionnaire Version' ;
    rdfs:comment 'Version identifier of the survey questionnaire instrument used in this wave.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseRatePercent rdf:type rdf:Property ;
    rdfs:label 'Response Rate Percent' ;
    rdfs:comment 'Percentage of invited or contacted respondents who completed the survey, calculated as (completes / contacts) * 100.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'Statistical sampling methodology used to select respondents for this survey wave.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSampleSize rdf:type rdf:Property ;
    rdfs:label 'Target Sample Size' ;
    rdfs:comment 'Planned number of completed survey responses to be collected during this wave.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waveName rdf:type rdf:Property ;
    rdfs:label 'Wave Name' ;
    rdfs:comment 'Human-readable name or label for the survey wave (e.g., \'Q1 2024 Brand Tracker\', \'Post-Campaign Pulse\').' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Sequential number identifying the wave within a survey series (e.g., Wave 1, Wave 2, Wave 3).' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waveStatus rdf:type rdf:Property ;
    rdfs:label 'Wave Status' ;
    rdfs:comment 'Current lifecycle status of the survey wave indicating its operational state.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveType rdf:type rdf:Property ;
    rdfs:label 'Wave Type' ;
    rdfs:comment 'Classification of the survey wave based on its timing and purpose within the research program.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightingApplied rdf:type rdf:Property ;
    rdfs:label 'Weighting Applied' ;
    rdfs:comment 'Indicates whether statistical weighting has been applied to the survey data to correct for sampling bias.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightingMethodology rdf:type rdf:Property ;
    rdfs:label 'Weighting Methodology' ;
    rdfs:comment 'Description of the statistical weighting approach and variables used to adjust survey results.' ;
    rdfs:domain ind:SurveyWave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Assigned To User Worker Id' ;
    rdfs:comment 'Reference to the user or reviewer currently assigned to complete this review cycle.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:escalatedToUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Escalated To User Worker Id' ;
    rdfs:comment 'Reference to the user or manager to whom this review cycle has been escalated. Null if not escalated.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:reviewGroupId rdf:type rdf:Property ;
    rdfs:label 'Review Group Id' ;
    rdfs:comment 'Reference to the review group or team responsible for this cycle (e.g., Creative Team, Legal Department, Client Stakeholders).' ;
    rdfs:domain ind:Creative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewGroup .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether formal approval is required to complete this review cycle (true) or if it is informational only (false).' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Actual date when the review cycle was completed or closed. Null if still in progress.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name or label for this review cycle (e.g., \'Initial Brand Review\', \'Legal Compliance Check\').' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cycle Number' ;
    rdfs:comment 'Sequential number of this review cycle within the asset\'s review history (e.g., 1st review, 2nd review).' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionSummary rdf:type rdf:Property ;
    rdfs:label 'Decision Summary' ;
    rdfs:comment 'Summary of the final decision or outcome of the review cycle (e.g., \'Approved with minor changes\', \'Rejected due to brand non-compliance\').' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReviewUrl rdf:type rdf:Property ;
    rdfs:label 'External Review Url' ;
    rdfs:comment 'URL link to external review platform or proofing tool where this review cycle is being conducted (e.g., Adobe Workfront Proof link).' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationSystem rdf:type rdf:Property ;
    rdfs:label 'Integration System' ;
    rdfs:comment 'Name of the external system integrated for this review cycle (e.g., \'Adobe Workfront\', \'Frame.io\', \'Wrike Proof\').' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether notification has been sent to reviewers about this review cycle (true) or not (false).' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejection Timestamp' ;
    rdfs:comment 'Precise timestamp when the review cycle was rejected. Null if not rejected.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reminderSentCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Count' ;
    rdfs:comment 'Number of reminder notifications sent to reviewers for this review cycle.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewInstructions rdf:type rdf:Property ;
    rdfs:label 'Review Instructions' ;
    rdfs:comment 'Specific instructions or guidance provided to reviewers for this cycle (e.g., focus areas, checklist items, brand guidelines to verify).' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewersCompleted rdf:type rdf:Property ;
    rdfs:label 'Reviewers Completed' ;
    rdfs:comment 'Count of reviewers who have completed their review within this cycle.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaActualHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Hours' ;
    rdfs:comment 'Actual number of hours taken to complete this review cycle. Null if not yet completed.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Indicates whether the review cycle was completed within the SLA target hours (true) or exceeded the target (false). Null if not yet completed.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalComments rdf:type rdf:Property ;
    rdfs:label 'Total Comments' ;
    rdfs:comment 'Total number of comments or feedback items submitted during this review cycle.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalReviewers rdf:type rdf:Property ;
    rdfs:label 'Total Reviewers' ;
    rdfs:comment 'Total count of reviewers assigned to participate in this review cycle.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unanimousApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Unanimous Approval Required' ;
    rdfs:comment 'Indicates whether all assigned reviewers must approve (true) or if majority/single approval is sufficient (false).' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unresolvedComments rdf:type rdf:Property ;
    rdfs:label 'Unresolved Comments' ;
    rdfs:comment 'Count of comments or feedback items that remain unresolved or unaddressed.' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionReviewed rdf:type rdf:Property ;
    rdfs:label 'Version Reviewed' ;
    rdfs:comment 'Version identifier of the creative asset that was reviewed in this cycle (e.g., \'v1.2\', \'Draft 3\').' ;
    rdfs:domain ind:ReviewCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity that owns or controls this bank account.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountClosedDate rdf:type rdf:Property ;
    rdfs:label 'Account Closed Date' ;
    rdfs:comment 'The date on which the bank account was closed or deactivated, if applicable.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The unique account number assigned by the financial institution. May be domestic format or IBAN.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Account Opened Date' ;
    rdfs:comment 'The date on which the bank account was originally opened with the financial institution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'The primary business purpose or function for which this bank account is designated within the agency\'s financial operations.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achEnabled rdf:type rdf:Property ;
    rdfs:label 'Ach Enabled' ;
    rdfs:comment 'Indicates whether ACH transactions are enabled for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceAmount rdf:type rdf:Property ;
    rdfs:label 'Balance Amount' ;
    rdfs:comment 'The current balance of the bank account as of the last reconciliation or statement date.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Balance As Of Date' ;
    rdfs:comment 'The date on which the current balance amount was last updated or verified.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankIdentifierCode rdf:type rdf:Property ;
    rdfs:label 'Bank Identifier Code' ;
    rdfs:comment 'The BIC or SWIFT code uniquely identifying the financial institution for international transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'The legal name of the financial institution holding the account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementFrequency rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Frequency' ;
    rdfs:comment 'The frequency at which the bank provides account statements.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCode rdf:type rdf:Property ;
    rdfs:label 'Branch Code' ;
    rdfs:comment 'The unique code identifying the bank branch within the financial institution\'s network.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'The name of the specific bank branch where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkWritingEnabled rdf:type rdf:Property ;
    rdfs:label 'Check Writing Enabled' ;
    rdfs:comment 'Indicates whether check writing privileges are enabled for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestRatePercent rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percent' ;
    rdfs:comment 'The annual interest rate percentage applied to the account balance, if applicable.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryAccount rdf:type rdf:Property ;
    rdfs:label 'Is Primary Account' ;
    rdfs:comment 'Indicates whether this is the primary or default bank account for the associated legal entity or cost center.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumBalanceRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Required' ;
    rdfs:comment 'The minimum balance that must be maintained in the account as per bank or internal policy requirements.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiCurrencyEnabled rdf:type rdf:Property ;
    rdfs:label 'Multi Currency Enabled' ;
    rdfs:comment 'Indicates whether the account supports transactions in multiple currencies.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineBankingEnabled rdf:type rdf:Property ;
    rdfs:label 'Online Banking Enabled' ;
    rdfs:comment 'Indicates whether online banking access is enabled for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'The maximum overdraft or credit facility limit approved for this bank account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'The scheduled frequency at which bank reconciliation is performed for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The domestic routing number (ABA routing number in US, sort code in UK) used for electronic funds transfers.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Statement Delivery Method' ;
    rdfs:comment 'The method by which bank statements are delivered to the account holder.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireTransferEnabled rdf:type rdf:Property ;
    rdfs:label 'Wire Transfer Enabled' ;
    rdfs:comment 'Indicates whether wire transfer functionality is enabled for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersedesPolicyId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Policy Id' ;
    rdfs:comment 'Reference to the previous version of the policy that this version replaces, enabling policy lineage tracking.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdvertiserPolicy .

ind:allowedContentCategories rdf:type rdf:Property ;
    rdfs:label 'Allowed Content Categories' ;
    rdfs:comment 'Comma-separated list of content categories that are explicitly permitted under this policy for targeted placements.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToChannels rdf:type rdf:Property ;
    rdfs:label 'Applies To Channels' ;
    rdfs:comment 'Comma-separated list of media channels to which this policy applies, such as display, video, social, search, or broadcast.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoEnforcementEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Enforcement Enabled' ;
    rdfs:comment 'Indicates whether the policy is automatically enforced by system rules and algorithms or requires manual review.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRestrictions rdf:type rdf:Property ;
    rdfs:label 'Geographic Restrictions' ;
    rdfs:comment 'Comma-separated list of countries or regions where the policy imposes specific restrictions or prohibitions on advertising activities.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether stakeholders must be notified when this policy is triggered or violated.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Category' ;
    rdfs:comment 'High-level categorization of the policy for organizational and governance purposes.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed narrative explanation of the policy terms, conditions, restrictions, and requirements that govern advertiser activities.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name or title of the advertiser policy for identification and reporting purposes.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Externally-known unique business identifier for the advertiser policy, typically used in client communications and contracts.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the policy indicating its primary purpose and scope within the advertising operations framework.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedContentCategories rdf:type rdf:Property ;
    rdfs:label 'Restricted Content Categories' ;
    rdfs:comment 'Comma-separated list of content categories that are prohibited or restricted under this policy for brand safety purposes.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled interval at which the policy is reviewed and updated to ensure continued relevance and compliance.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Geographic, channel, or operational boundary within which the policy applies.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationConsequence rdf:type rdf:Property ;
    rdfs:label 'Violation Consequence' ;
    rdfs:comment 'Action or penalty that will be applied if the policy is violated by campaigns or media placements.' ;
    rdfs:domain ind:AdvertiserPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Total number of ad clicks recorded during the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversions rdf:type rdf:Property ;
    rdfs:label 'Conversions' ;
    rdfs:comment 'Total number of conversions attributed to the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'Unique identifier of the device used during the session.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitPageUrl rdf:type rdf:Property ;
    rdfs:label 'Exit Page Url' ;
    rdfs:comment 'The URL of the last page viewed before the session ended.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'Total number of ad impressions served during the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBot rdf:type rdf:Property ;
    rdfs:label 'Is Bot' ;
    rdfs:comment 'Indicates whether the session was identified as bot traffic.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medium rdf:type rdf:Property ;
    rdfs:label 'Medium' ;
    rdfs:comment 'The medium through which the session was acquired (e.g., cpc, organic, email).' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageViews rdf:type rdf:Property ;
    rdfs:label 'Page Views' ;
    rdfs:comment 'Total number of pages viewed during the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screenResolution rdf:type rdf:Property ;
    rdfs:label 'Screen Resolution' ;
    rdfs:comment 'Screen resolution of the device during the session (e.g., 1920x1080).' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total duration of the session measured in seconds.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'The exact date and time when the session ended.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionKey rdf:type rdf:Property ;
    rdfs:label 'Session Key' ;
    rdfs:comment 'External business identifier for the session, used for tracking and reporting purposes.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'The exact date and time when the session started.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Classification of the session based on traffic source type.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:source rdf:type rdf:Property ;
    rdfs:label 'Source' ;
    rdfs:comment 'The origin or source of the session traffic (e.g., google, facebook, direct).' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userCode rdf:type rdf:Property ;
    rdfs:label 'User Code' ;
    rdfs:comment 'Identifier of the user associated with this session.' ;
    rdfs:domain ind:Session ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auctionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Auction Completion Timestamp' ;
    rdfs:comment 'Date and time when the auction was resolved and a winning bid was selected or the auction was closed without a winner.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auctionExternalCode rdf:type rdf:Property ;
    rdfs:label 'Auction External Code' ;
    rdfs:comment 'External business identifier for the auction, typically provided by the ad exchange or supply-side platform (SSP). Used for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auctionStatus rdf:type rdf:Property ;
    rdfs:label 'Auction Status' ;
    rdfs:comment 'Current lifecycle state of the auction event. Tracks progression from initiation through bid collection to final resolution or failure.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auctionTimeoutMs rdf:type rdf:Property ;
    rdfs:label 'Auction Timeout Ms' ;
    rdfs:comment 'Maximum time in milliseconds allowed for the auction to complete before timing out. Typical values range from 100-500ms.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auctionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Auction Timestamp' ;
    rdfs:comment 'Precise date and time when the auction event was initiated by the ad exchange or SSP. Represents the real-world business event time for auction start.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auctionType rdf:type rdf:Property ;
    rdfs:label 'Auction Type' ;
    rdfs:comment 'Classification of the auction mechanism used for ad inventory pricing. First-price auctions award to highest bidder at their bid price; second-price auctions award at second-highest bid price plus increment.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidCount rdf:type rdf:Property ;
    rdfs:label 'Bid Count' ;
    rdfs:comment 'Total number of bids received during the auction from all participating demand-side platforms (DSPs) and bidders.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Code' ;
    rdfs:comment 'Reference to the ad exchange or supply-side platform (SSP) that conducted the auction.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorPrice rdf:type rdf:Property ;
    rdfs:label 'Floor Price' ;
    rdfs:comment 'Minimum acceptable bid price set by the publisher or exchange for this auction. Bids below this threshold are rejected.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteCategory rdf:type rdf:Property ;
    rdfs:label 'Site Category' ;
    rdfs:comment 'IAB content category classification of the publisher site or app. Used for contextual targeting and brand safety.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChain rdf:type rdf:Property ;
    rdfs:label 'Supply Chain' ;
    rdfs:comment 'Serialized ads.txt or sellers.json supply chain transparency data. Identifies all intermediaries in the ad transaction chain for fraud prevention.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityPrediction rdf:type rdf:Property ;
    rdfs:label 'Viewability Prediction' ;
    rdfs:comment 'Pre-bid predicted probability (0-100%) that the impression will meet viewability standards (MRC: 50% of pixels in view for 1 second for display, 2 seconds for video).' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winningBidAmount rdf:type rdf:Property ;
    rdfs:label 'Winning Bid Amount' ;
    rdfs:comment 'The monetary value of the winning bid in the auction. Represents the clearing price paid by the advertiser for the impression.' ;
    rdfs:domain ind:Auction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Created By User Worker Id' ;
    rdfs:comment 'Reference to the user who initiated or created this payroll run.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:modifiedByUserWorkerId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Worker Id' ;
    rdfs:comment 'Reference to the user who last modified this payroll run record.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:originalPayrollRunId rdf:type rdf:Property ;
    rdfs:label 'Original Payroll Run Id' ;
    rdfs:comment 'Reference to the original payroll run that this run reverses or corrects, populated only when is_reversal is true.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:payrollCalendarId rdf:type rdf:Property ;
    rdfs:label 'Payroll Calendar Id' ;
    rdfs:comment 'Reference to the payroll calendar that governs the schedule and timing rules for this payroll run.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollCalendar .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'External batch identifier assigned by the payroll processing system for tracking and reconciliation purposes.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Number of employees, contractors, freelancers, and talent included in this payroll run.' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employerTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Tax Amount' ;
    rdfs:comment 'Total employer-side tax obligations for this payroll run including employer portion of social security, Medicare, unemployment taxes, and other statutory contributions.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'The recurring schedule frequency for this payroll run: weekly, biweekly (every two weeks), semimonthly (twice per month), monthly, quarterly, or annual.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerPostingDate rdf:type rdf:Property ;
    rdfs:label 'General Ledger Posting Date' ;
    rdfs:comment 'Date on which payroll expenses and liabilities from this run are posted to the general ledger for financial accounting.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when this payroll run completed processing and payments were initiated.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingSystem rdf:type rdf:Property ;
    rdfs:label 'Processing System' ;
    rdfs:comment 'Name or identifier of the payroll processing system or platform used to execute this payroll run (e.g., Workday HCM, ADP, internal system).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business identifier for the payroll run, typically formatted as PR-YYYYMMDD or similar convention used for external reference and reporting.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payroll run indicating the purpose: regular scheduled payroll, off-cycle payment, bonus distribution, commission payout, adjustment run, or final settlement.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedToBankTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted To Bank Timestamp' ;
    rdfs:comment 'Date and time when payment instructions were transmitted to the banking institution for disbursement.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Primary tax jurisdiction or geographic region governing tax withholding and reporting requirements for this payroll run (e.g., state, province, country).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToProfileId rdf:type rdf:Property ;
    rdfs:label 'Reports To Profile Id' ;
    rdfs:comment 'Job profile identifier of the direct supervisor role in the organizational hierarchy.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure used for capacity planning and resource allocation for this job profile.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'Primary classification of the job profile indicating the type of talent resource.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationRequirement rdf:type rdf:Property ;
    rdfs:label 'Education Requirement' ;
    rdfs:comment 'Minimum educational qualification required for this job profile (e.g., Bachelor\'s Degree in Marketing, Portfolio-based, No formal requirement).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeoCategory rdf:type rdf:Property ;
    rdfs:label 'Eeo Category' ;
    rdfs:comment 'EEO-1 job category for regulatory reporting and diversity analytics.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'FLSA classification indicating whether the job profile is exempt or non-exempt from overtime regulations.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for this job profile.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether resources in this job profile are eligible for overtime compensation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredSkills rdf:type rdf:Property ;
    rdfs:label 'Preferred Skills' ;
    rdfs:comment 'Additional desirable skills that enhance candidate suitability but are not mandatory for the role.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible' ;
    rdfs:comment 'Indicates whether this job profile can be performed remotely or requires on-site presence.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredSkills rdf:type rdf:Property ;
    rdfs:label 'Required Skills' ;
    rdfs:comment 'Core competencies and technical skills required for this job profile, used for talent matching and capacity planning.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCapacityPerPeriod rdf:type rdf:Property ;
    rdfs:label 'Standard Capacity Per Period' ;
    rdfs:comment 'Standard available capacity per planning period (e.g., 40 hours per week, 160 hours per month) for resource planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardRate rdf:type rdf:Property ;
    rdfs:label 'Standard Rate' ;
    rdfs:comment 'Standard billing or compensation rate for this job profile used in resource planning and project budgeting. Currency is USD unless otherwise specified in rate_currency.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Expected percentage of time requiring business travel for this job profile (0-100).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation' ;
    rdfs:comment 'Labor union or guild affiliation applicable to this job profile (e.g., SAG-AFTRA, DGA, IATSE), if any.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsRequired rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Required' ;
    rdfs:comment 'Indicates whether this job profile requires explicit usage rights management for work produced (e.g., actors, photographers, directors).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Reference to the primary work location for this position.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:recruiterWorkerId rdf:type rdf:Property ;
    rdfs:label 'Recruiter Worker Id' ;
    rdfs:comment 'Reference to the talent acquisition specialist assigned to manage this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:budgetApproved rdf:type rdf:Property ;
    rdfs:label 'Budget Approved' ;
    rdfs:comment 'Indicates whether the financial budget for this requisition has been formally approved.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:educationLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Education Level Required' ;
    rdfs:comment 'Minimum educational qualification required for the position.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyRateMaximum rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate Maximum' ;
    rdfs:comment 'Upper bound of the approved hourly rate for contractor or freelancer positions.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hourlyRateMinimum rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate Minimum' ;
    rdfs:comment 'Lower bound of the approved hourly rate for contractor or freelancer positions.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Minimum Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for the role.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the requisition was officially opened and made available for candidate sourcing.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionCount rdf:type rdf:Property ;
    rdfs:label 'Position Count' ;
    rdfs:comment 'Number of positions to be filled under this single requisition (typically 1, but may be higher for bulk hiring).' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingTitle rdf:type rdf:Property ;
    rdfs:label 'Posting Title' ;
    rdfs:comment 'Public-facing job title used in external job postings and advertisements (may differ from internal job title).' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingVisibility rdf:type rdf:Property ;
    rdfs:label 'Posting Visibility' ;
    rdfs:comment 'Defines whether the requisition is advertised internally only, externally, or both.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkPolicy rdf:type rdf:Property ;
    rdfs:label 'Remote Work Policy' ;
    rdfs:comment 'Defines the remote work arrangement permitted for this position.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the employment relationship being recruited for.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Maximum' ;
    rdfs:comment 'Upper bound of the approved salary range for this position in the agency\'s base currency.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Minimum' ;
    rdfs:comment 'Lower bound of the approved salary range for this position in the agency\'s base currency.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'Number of calendar days from requisition opening to closure, used for recruiting performance metrics.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hiringManagerWorkerId rdf:type rdf:Property ;
    rdfs:label 'Hiring Manager Worker Id' ;
    rdfs:comment 'Identifier of the hiring manager or department head who is evaluating this candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Worker .

ind:jobRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Job Requisition Id' ;
    rdfs:comment 'Identifier of the job requisition or open position the candidate is being considered for.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:availabilityDate rdf:type rdf:Property ;
    rdfs:label 'Availability Date' ;
    rdfs:comment 'The date when the candidate is available to start work if hired.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:candidateType rdf:type rdf:Property ;
    rdfs:label 'Candidate Type' ;
    rdfs:comment 'Classification of the candidate based on the type of talent role they are being considered for (employee, freelancer, contractor, influencer, actor, photographer, director, production crew).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'Name of the candidate\'s current employer or most recent employer if currently unemployed.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'The candidate\'s current or most recent job title or role.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeField rdf:type rdf:Property ;
    rdfs:label 'Degree Field' ;
    rdfs:comment 'The primary field of study or major for the candidate\'s highest degree.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:desiredSalary rdf:type rdf:Property ;
    rdfs:label 'Desired Salary' ;
    rdfs:comment 'The candidate\'s desired or expected salary amount for the position.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'The highest level of education attained by the candidate (high school, associate, bachelor, master, doctorate, professional degree).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewCount rdf:type rdf:Property ;
    rdfs:label 'Interview Count' ;
    rdfs:comment 'Total number of interviews conducted with this candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languages rdf:type rdf:Property ;
    rdfs:label 'Languages' ;
    rdfs:comment 'List of languages the candidate speaks and their proficiency levels.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Interview Date' ;
    rdfs:comment 'Date of the most recent interview conducted with the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfile rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile' ;
    rdfs:comment 'URL to the candidate\'s LinkedIn professional profile.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCity rdf:type rdf:Property ;
    rdfs:label 'Location City' ;
    rdfs:comment 'City where the candidate is currently located or resides.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCountry rdf:type rdf:Property ;
    rdfs:label 'Location Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the candidate\'s current location (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationState rdf:type rdf:Property ;
    rdfs:label 'Location State' ;
    rdfs:comment 'State, province, or region where the candidate is currently located.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Date' ;
    rdfs:comment 'Date when the candidate accepted the job offer.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerExtendedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Extended Date' ;
    rdfs:comment 'Date when a job offer was extended to the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Name of the person or entity who referred the candidate, if applicable.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resumeUrl rdf:type rdf:Property ;
    rdfs:label 'Resume Url' ;
    rdfs:comment 'URL or file path to the candidate\'s resume or curriculum vitae document.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Salary Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the desired salary (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningScore rdf:type rdf:Property ;
    rdfs:label 'Screening Score' ;
    rdfs:comment 'Numerical score assigned during initial screening or assessment of the candidate\'s qualifications (0-100 scale).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skills rdf:type rdf:Property ;
    rdfs:label 'Skills' ;
    rdfs:comment 'Comma-separated list or text description of the candidate\'s key skills, competencies, and areas of expertise relevant to advertising and marketing roles.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willingToRelocate rdf:type rdf:Property ;
    rdfs:label 'Willing To Relocate' ;
    rdfs:comment 'Indicates whether the candidate is willing to relocate for the position (True/False).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToContractors rdf:type rdf:Property ;
    rdfs:label 'Applies To Contractors' ;
    rdfs:comment 'Indicates whether this holiday calendar applies to contractors and freelancers. True if contractors observe these holidays; false if they follow different schedules.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToFullTimeEmployees rdf:type rdf:Property ;
    rdfs:label 'Applies To Full Time Employees' ;
    rdfs:comment 'Indicates whether this holiday calendar applies to full-time employees. True if FTE staff observe these holidays; false if excluded.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToProductionCrew rdf:type rdf:Property ;
    rdfs:label 'Applies To Production Crew' ;
    rdfs:comment 'Indicates whether this holiday calendar applies to production crews (directors, photographers, actors, production staff). True if production schedules must respect these holidays; false if production operates independently.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calendarCode rdf:type rdf:Property ;
    rdfs:label 'Calendar Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the calendar for system integration and reference (e.g., \'US_FED_2024\', \'UK_BANK\', \'PROD_CAL\').' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarName rdf:type rdf:Property ;
    rdfs:label 'Calendar Name' ;
    rdfs:comment 'Business-friendly name of the holiday calendar (e.g., \'US Federal Holidays 2024\', \'UK Bank Holidays\', \'Agency Production Calendar\').' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarType rdf:type rdf:Property ;
    rdfs:label 'Calendar Type' ;
    rdfs:comment 'Classification of the holiday calendar indicating its scope and purpose: national (country-wide public holidays), regional (state/province holidays), organizational (company-specific holidays), production (shoot/production blackout dates), project (campaign-specific non-working days).' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCalendarCode rdf:type rdf:Property ;
    rdfs:label 'External Calendar Code' ;
    rdfs:comment 'The unique identifier for this holiday calendar in the source system (e.g., Workday calendar ID, Workfront calendar GUID). Used for integration and synchronization with upstream systems.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observanceRule rdf:type rdf:Property ;
    rdfs:label 'Observance Rule' ;
    rdfs:comment 'Defines how holidays that fall on weekends are observed. Values: actual_date (holiday observed on the actual date regardless of day of week), nearest_weekday (shifted to nearest weekday), following_monday (shifted to following Monday if on weekend), preceding_friday (shifted to preceding Friday if on weekend).' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'State, province, or regional subdivision code for calendars that apply to specific geographic regions within a country (e.g., \'CA\' for California, \'ON\' for Ontario, \'NSW\' for New South Wales). Nullable for national or organizational calendars.' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHolidays rdf:type rdf:Property ;
    rdfs:label 'Total Holidays' ;
    rdfs:comment 'The total number of distinct holiday dates defined in this calendar. Used for quick reference and capacity planning calculations.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekendPattern rdf:type rdf:Property ;
    rdfs:label 'Weekend Pattern' ;
    rdfs:comment 'Defines the standard weekend days for this calendar. Values: sat_sun (Saturday and Sunday, common in Western countries), fri_sat (Friday and Saturday, common in Middle East), sun_only (Sunday only), none (no standard weekend, e.g., shift-based operations).' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingDaysPerYear rdf:type rdf:Property ;
    rdfs:label 'Working Days Per Year' ;
    rdfs:comment 'The calculated number of working days in the calendar year after excluding weekends and holidays. Used for resource capacity planning, project scheduling, and workload forecasting.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'The calendar year (YYYY) for which this holiday calendar is defined. Many organizations maintain separate calendar records per year to accommodate year-specific holiday variations.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDisputeId rdf:type rdf:Property ;
    rdfs:label 'Invoice Dispute Id' ;
    rdfs:comment 'Primary key for invoice_dispute' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the person or team currently responsible for resolving the dispute.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Flag indicating whether the dispute involves a compliance or regulatory issue requiring special handling.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeCategory rdf:type rdf:Property ;
    rdfs:label 'Dispute Category' ;
    rdfs:comment 'Secondary classification providing additional context for the dispute reason.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally-known unique business identifier for the dispute, formatted as DSP-NNNNNNNN.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeOpenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispute Opened Timestamp' ;
    rdfs:comment 'The precise timestamp when the dispute was formally opened, representing the principal business event time.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the dispute in the resolution workflow.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the dispute based on the nature of the disagreement.' ;
    rdfs:domain ind:InvoiceDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The monetary value being contested in the dispute. Expressed in the invoice currency.' ;
