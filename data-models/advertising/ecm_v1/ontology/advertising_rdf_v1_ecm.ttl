ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Budget optimization scenarios model allocation strategies for specific client budgets and must reference the budget being optimized to support budget planning, reallocation decisions, and scenario com' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBudget .

ind:incrementalityTestId rdf:type rdf:Property ;
