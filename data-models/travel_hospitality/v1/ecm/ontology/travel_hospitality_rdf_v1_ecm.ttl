    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classBenefits rdf:type rdf:Property ;
    rdfs:label 'Class Benefits' ;
    rdfs:comment 'Summary of the health, wellness, and fitness benefits guests will gain from participating in this class.' ;
    rdfs:domain ind:FitnessClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Unique business identifier code for the fitness class used in scheduling and booking systems.' ;
    rdfs:domain ind:FitnessClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classDescription rdf:type rdf:Property ;
    rdfs:label 'Class Description' ;
    rdfs:comment 'Detailed narrative description of the class content, benefits, and what guests can expect during the session.' ;
    rdfs:domain ind:FitnessClass ;
