    rdfs:comment 'Date when the equipment was purchased or acquired by the property.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementCost rdf:type rdf:Property ;
