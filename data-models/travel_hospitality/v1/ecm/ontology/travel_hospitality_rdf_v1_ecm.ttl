    rdfs:comment 'The numeric score assigned during the last health inspection (typically 0-100 scale, where higher is better).' ;
    rdfs:domain ind:FoodSafetyCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'The full name of the regulatory jurisdiction (e.g., Los Angeles County Health Department, New York State Department of Health).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'The date on which the most recent food safety training was completed for staff covered by this certification.' ;
