ind:primaryFitnessEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fitness Employee Id' ;
    rdfs:comment 'Reference to the fitness instructor or therapist leading this session. Enables instructor utilization tracking, performance analysis, and guest preference matching.' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:classFormat rdf:type rdf:Property ;
    rdfs:label 'Class Format' ;
    rdfs:comment 'The delivery format of the session. In Person: traditional on-site class. Virtual: online streaming or video conference. Hybrid: simultaneous in-person and virtual. Outdoor: held in outdoor spaces. Poolside: aquatic or pool-adjacent class.' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:difficultyLevel rdf:type rdf:Property ;
    rdfs:label 'Difficulty Level' ;
    rdfs:comment 'The skill or fitness level required for this session. Helps guests select appropriate classes and ensures safety. All Levels: suitable for any fitness level. Adaptive: modified for special needs or limitations.' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrolledCount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Count' ;
    rdfs:comment 'The current number of guests enrolled in this session. Updated in real-time as bookings are made or cancelled. Used to determine session availability and trigger waitlist processing.' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsValue rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Value' ;
    rdfs:comment 'The number of loyalty program points awarded to guests who attend this session. Null if loyalty_points_eligible_flag is false.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumAge rdf:type rdf:Property ;
    rdfs:label 'Minimum Age' ;
    rdfs:comment 'The minimum age in years required to participate in this session. Used for booking validation and liability management. Null if no minimum age applies.' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueCenter rdf:type rdf:Property ;
    rdfs:label 'Revenue Center' ;
    rdfs:comment 'The revenue center or department code to which session revenue is allocated. Aligns with property accounting structure and USALI reporting requirements.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDate rdf:type rdf:Property ;
    rdfs:label 'Session Date' ;
    rdfs:comment 'The calendar date on which the fitness class session is scheduled. Used for daily scheduling, capacity planning, and historical analysis.' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sessionName rdf:type rdf:Property ;
    rdfs:label 'Session Name' ;
    rdfs:comment 'Display name for the session, often including class name and time (e.g., \'Morning Yoga Flow - 7am\'). Used in guest-facing schedules and marketing materials.' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionPrice rdf:type rdf:Property ;
    rdfs:label 'Session Price' ;
    rdfs:comment 'The standard price charged per guest for this session. May be zero for complimentary classes included in resort amenities. Actual guest charges may vary based on packages, memberships, or promotions.' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the session. Scheduled: session created but not yet open for booking. Open: accepting enrollments. Full: at maximum capacity. Cancelled: session will not occur. In Progress: session currently underway. Completed: session finished. No Show: session scheduled but no attendees. [ENUM-REF-CANDIDATE: scheduled|open|full|cancelled|in_progress|completed|no_show — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Classification of the session based on delivery model and pricing structure. Group: standard multi-guest class. Private: one-on-one instruction. Semi-Private: small group with personalized attention. Complimentary: included in resort amenities. Premium: upcharge class. Special Event: one-time or themed session.' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistCount rdf:type rdf:Property ;
    rdfs:label 'Waitlist Count' ;
    rdfs:comment 'The number of guests on the waitlist for this session. Indicates demand exceeding capacity and informs decisions about adding additional sessions or larger facilities.' ;
    rdfs:domain ind:FitnessClassSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:golfTeeTimeId rdf:type rdf:Property ;
    rdfs:label 'Golf Tee Time Id' ;
    rdfs:comment 'Unique identifier for the golf tee time booking record. Primary key for the golf tee time transaction.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caddieFeePerCaddie rdf:type rdf:Property ;
    rdfs:label 'Caddie Fee Per Caddie' ;
    rdfs:comment 'The service fee charged per caddie. Does not include gratuity.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caddieRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Caddie Requested Flag' ;
    rdfs:comment 'Indicates whether caddie service was requested for this tee time. True if caddie is requested, False otherwise.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cartFeePerCart rdf:type rdf:Property ;
    rdfs:label 'Cart Fee Per Cart' ;
    rdfs:comment 'The rental fee charged per golf cart.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cartRentalFlag rdf:type rdf:Property ;
    rdfs:label 'Cart Rental Flag' ;
    rdfs:comment 'Indicates whether golf cart rental is included in this tee time booking. True if cart is rented, False otherwise.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clubRentalFeePerSet rdf:type rdf:Property ;
    rdfs:label 'Club Rental Fee Per Set' ;
    rdfs:comment 'The rental fee charged per set of golf clubs.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clubRentalFlag rdf:type rdf:Property ;
    rdfs:label 'Club Rental Flag' ;
    rdfs:comment 'Indicates whether golf club rental is included in this tee time booking. True if clubs are rented, False otherwise.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:greenFeePerPlayer rdf:type rdf:Property ;
    rdfs:label 'Green Fee Per Player' ;
    rdfs:comment 'The green fee charged per player for this tee time. Does not include cart, club rental, or caddie fees.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfCaddies rdf:type rdf:Property ;
    rdfs:label 'Number Of Caddies' ;
    rdfs:comment 'Number of caddies assigned to this tee time. May be one per player or one per group depending on service level.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfCarts rdf:type rdf:Property ;
    rdfs:label 'Number Of Carts' ;
    rdfs:comment 'Number of golf carts rented for this tee time. Typically one cart per two players.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfClubSets rdf:type rdf:Property ;
    rdfs:label 'Number Of Club Sets' ;
    rdfs:comment 'Number of golf club sets rented for this tee time.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfHoles rdf:type rdf:Property ;
    rdfs:label 'Number Of Holes' ;
    rdfs:comment 'Number of holes booked for this tee time. Common values are 9 or 18 holes.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfPlayers rdf:type rdf:Property ;
    rdfs:label 'Number Of Players' ;
    rdfs:comment 'Total number of players in the tee time booking. Typically ranges from 1 to 4 players per tee time slot.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teeTime rdf:type rdf:Property ;
    rdfs:label 'Tee Time' ;
    rdfs:comment 'The exact date and time when the players are scheduled to tee off. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:teeTimeDate rdf:type rdf:Property ;
    rdfs:label 'Tee Time Date' ;
    rdfs:comment 'The date on which the tee time is scheduled. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teeTimeStatus rdf:type rdf:Property ;
    rdfs:label 'Tee Time Status' ;
    rdfs:comment 'Current lifecycle status of the tee time booking. Values: booked (initial reservation), confirmed (guest confirmed attendance), checked_in (guest arrived at pro shop), completed (round finished), cancelled (booking cancelled), no_show (guest did not arrive).' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCharge rdf:type rdf:Property ;
    rdfs:label 'Total Charge' ;
    rdfs:comment 'Total charge for the tee time booking including green fees, cart rental, club rental, caddie fees, and any applicable taxes or surcharges.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherCancellationFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Cancellation Flag' ;
    rdfs:comment 'Indicates whether the tee time was cancelled due to weather conditions. True if weather-related cancellation, False otherwise.' ;
    rdfs:domain ind:GolfTeeTime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intakeFormId rdf:type rdf:Property ;
    rdfs:label 'Intake Form Id' ;
    rdfs:comment 'Unique identifier for the spa guest health intake and consultation form. Primary key.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allergyDetails rdf:type rdf:Property ;
    rdfs:label 'Allergy Details' ;
    rdfs:comment 'Free-text description of specific allergies disclosed by the guest, including product ingredients, essential oils, nuts, latex, or other substances. Essential for safe treatment delivery.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areasToAvoid rdf:type rdf:Property ;
    rdfs:label 'Areas To Avoid' ;
    rdfs:comment 'Free-text description of specific body areas the guest requests to avoid during treatment due to injury, sensitivity, discomfort, or personal preference.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aromatherapyPreference rdf:type rdf:Property ;
    rdfs:label 'Aromatherapy Preference' ;
    rdfs:comment 'Guest preference for aromatherapy scent during treatment. Enhances personalized spa experience and guest satisfaction. [ENUM-REF-CANDIDATE: lavender|eucalyptus|peppermint|citrus|rose|sandalwood|unscented|no_preference — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardiovascularConditionDetails rdf:type rdf:Property ;
    rdfs:label 'Cardiovascular Condition Details' ;
    rdfs:comment 'Free-text description of specific cardiovascular conditions disclosed by the guest. Provides therapist with detailed health context for treatment planning.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentMedications rdf:type rdf:Property ;
    rdfs:label 'Current Medications' ;
    rdfs:comment 'Free-text list of medications currently being taken by the guest. Important for identifying potential interactions with spa treatments or products.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyAcknowledgment rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Acknowledgment' ;
    rdfs:comment 'Indicates whether the guest has acknowledged the spa data privacy policy and understands how their personal and health information will be used and protected.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPrivacyAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the guest acknowledged the data privacy policy. Required for GDPR and CCPA compliance documentation.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:formExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Form Expiration Date' ;
    rdfs:comment 'Date when the intake form expires and must be renewed. Typically 6-12 months from completion date to ensure health information remains current.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formNumber rdf:type rdf:Property ;
    rdfs:label 'Form Number' ;
    rdfs:comment 'Human-readable business identifier for the intake form, typically formatted as IF- followed by numeric sequence. Used for guest communication and record retrieval.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formStatus rdf:type rdf:Property ;
    rdfs:label 'Form Status' ;
    rdfs:comment 'Current lifecycle status of the intake form. Tracks progression from guest completion through therapist review and approval.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasAllergies rdf:type rdf:Property ;
    rdfs:label 'Has Allergies' ;
    rdfs:comment 'Indicates whether the guest has disclosed any allergies to products, ingredients, or environmental factors. Critical for preventing allergic reactions during treatment.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasCardiovascularCondition rdf:type rdf:Property ;
    rdfs:label 'Has Cardiovascular Condition' ;
    rdfs:comment 'Indicates whether the guest has disclosed any cardiovascular conditions such as hypertension, heart disease, or circulatory disorders. Critical for treatment safety assessment.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPreviousSpaExperience rdf:type rdf:Property ;
    rdfs:label 'Has Previous Spa Experience' ;
    rdfs:comment 'Indicates whether the guest has received spa treatments before. Helps therapist adjust communication and service delivery approach.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasRecentSurgery rdf:type rdf:Property ;
    rdfs:label 'Has Recent Surgery' ;
    rdfs:comment 'Indicates whether the guest has undergone surgery within the past 6-12 months. Important for identifying treatment contraindications and areas to avoid.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasSkinCondition rdf:type rdf:Property ;
    rdfs:label 'Has Skin Condition' ;
    rdfs:comment 'Indicates whether the guest has disclosed any skin conditions such as eczema, psoriasis, rashes, or sensitivities. Important for product selection and treatment modifications.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPregnant rdf:type rdf:Property ;
    rdfs:label 'Is Pregnant' ;
    rdfs:comment 'Indicates whether the guest is currently pregnant. Critical for treatment contraindications and liability management.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photographyConsentGiven rdf:type rdf:Property ;
    rdfs:label 'Photography Consent Given' ;
    rdfs:comment 'Indicates whether the guest has consented to photography or videography during their spa visit for marketing or promotional purposes.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pregnancyTrimester rdf:type rdf:Property ;
    rdfs:label 'Pregnancy Trimester' ;
    rdfs:comment 'Current trimester of pregnancy if guest is pregnant. Used to determine appropriate treatment modifications and contraindications.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousSpaExperienceNotes rdf:type rdf:Property ;
    rdfs:label 'Previous Spa Experience Notes' ;
    rdfs:comment 'Free-text description of guest previous spa experiences, preferences, or concerns based on past treatments. Supports personalized service delivery.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skinConditionDetails rdf:type rdf:Property ;
    rdfs:label 'Skin Condition Details' ;
    rdfs:comment 'Free-text description of specific skin conditions disclosed by the guest. Guides therapist in selecting appropriate products and techniques.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surgeryDetails rdf:type rdf:Property ;
    rdfs:label 'Surgery Details' ;
    rdfs:comment 'Free-text description of recent surgeries including type, date, and location on body. Helps therapist identify areas requiring special care or avoidance.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapistReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Therapist Review Timestamp' ;
    rdfs:comment 'Date and time when the therapist completed their review of the intake form. Creates audit trail for quality assurance and compliance.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:therapistReviewed rdf:type rdf:Property ;
    rdfs:label 'Therapist Reviewed' ;
    rdfs:comment 'Indicates whether a licensed therapist has reviewed and approved the intake form prior to treatment. Required workflow step for quality assurance and liability management.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentConsentGiven rdf:type rdf:Property ;
    rdfs:label 'Treatment Consent Given' ;
    rdfs:comment 'Indicates whether the guest has provided informed consent to receive the spa treatment. Required for legal liability protection and regulatory compliance.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Treatment Consent Timestamp' ;
    rdfs:comment 'Date and time when the guest provided treatment consent. Creates audit trail for legal and compliance purposes.' ;
    rdfs:domain ind:IntakeForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:annualFee rdf:type rdf:Property ;
    rdfs:label 'Annual Fee' ;
    rdfs:comment 'Total annual membership fee. For annual memberships this is the upfront payment amount. For monthly memberships this represents the total annual cost (monthly fee times 12). Zero for complimentary memberships.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyTerminationFee rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee' ;
    rdfs:comment 'Fee charged if the member cancels before the end of the contract term. Zero for month-to-month memberships with no commitment. Used to enforce contract terms and recover acquisition costs.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedFitnessAccess rdf:type rdf:Property ;
    rdfs:label 'Included Fitness Access' ;
    rdfs:comment 'Indicates whether the membership includes unlimited access to fitness center facilities including gym equipment, group fitness classes, and personal training consultations. True if fitness access is included, False if not included or requires additional fees.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includedGuestPasses rdf:type rdf:Property ;
    rdfs:label 'Included Guest Passes' ;
    rdfs:comment 'Number of complimentary guest passes included with the membership per billing period. Guest passes allow the member to bring non-member guests to use spa and fitness facilities. Zero indicates no guest passes included.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includedTreatmentCredits rdf:type rdf:Property ;
    rdfs:label 'Included Treatment Credits' ;
    rdfs:comment 'Number of complimentary spa treatment credits included with the membership per billing period. Credits can typically be redeemed for massages, facials, body treatments, and other spa services. Zero indicates no included treatments.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date when the most recent membership fee payment was successfully processed. Used to track payment history and identify delinquent accounts.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Tier level of the spa membership indicating the level of benefits and access. Basic provides limited access, Premium includes enhanced benefits, Elite offers priority booking and exclusive treatments, Unlimited provides unrestricted access to all spa facilities and services.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipType rdf:type rdf:Property ;
    rdfs:label 'Membership Type' ;
    rdfs:comment 'Type of membership based on billing frequency and enrollment channel. Monthly memberships renew each month, Annual memberships are paid yearly, Corporate memberships are sponsored by employer organizations, Complimentary memberships are granted as loyalty rewards or promotional offers.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyFee rdf:type rdf:Property ;
    rdfs:label 'Monthly Fee' ;
    rdfs:comment 'Recurring monthly membership fee charged to the guest. Applicable for monthly and annual memberships (annual divided by 12). Zero for complimentary memberships.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'Date when the next membership fee payment is scheduled to be processed. Null for cancelled or expired memberships. Used for billing cycle management and revenue forecasting.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodToken rdf:type rdf:Property ;
    rdfs:label 'Payment Method Token' ;
    rdfs:comment 'Tokenized reference to the payment method on file for recurring membership charges. Token is stored securely in PCI-compliant payment gateway and used for auto-renewal billing. Does not contain actual card numbers.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Type of payment method used for membership billing. Credit card and debit card are most common for individual memberships, bank account for direct debit, corporate billing for employer-sponsored memberships, room charge for in-house guests who want membership fees added to their folio.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Member\'s preferred channel for receiving membership communications including billing notifications, appointment reminders, and promotional offers. Used to personalize communication strategy and improve member engagement.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Code' ;
    rdfs:comment 'Promotional or discount code applied at enrollment. Used to track marketing campaign effectiveness and apply special pricing or benefits. Null if no promotion was used.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Date when the membership suspension is scheduled to end and membership will return to active status. Null if not currently suspended or if suspension is indefinite pending member action.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Date when the membership was suspended. Null if membership has never been suspended or is not currently suspended. Used to track suspension periods for billing adjustments and benefit calculations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipVisitId rdf:type rdf:Property ;
    rdfs:label 'Membership Visit Id' ;
    rdfs:comment 'Unique identifier for the spa membership visit transaction. Primary key for this entity.' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:additionalServiceCharge rdf:type rdf:Property ;
    rdfs:label 'Additional Service Charge' ;
    rdfs:comment 'Monetary charge for services beyond membership benefits (upgrades, extended time, premium products). Separate from credit redemption.' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditsConsumed rdf:type rdf:Property ;
    rdfs:label 'Credits Consumed' ;
    rdfs:comment 'Number of membership credits deducted from the member\'s balance for this visit. Zero for included benefits or complimentary access.' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guestCount rdf:type rdf:Property ;
    rdfs:label 'Guest Count' ;
    rdfs:comment 'Number of guests included in this visit (member plus any authorized guests under guest pass privileges). Used for capacity planning and revenue allocation.' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingCreditBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Credit Balance' ;
    rdfs:comment 'Snapshot of the membership credit balance remaining after this visit transaction. Enables point-in-time balance tracking and reconciliation.' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Retail Purchase Amount' ;
    rdfs:comment 'Total monetary value of spa retail products purchased during this visit. Separate from membership credits. Tracked for cross-sell revenue analysis.' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialRequest rdf:type rdf:Property ;
    rdfs:label 'Special Request' ;
    rdfs:comment 'Guest-provided special requests or preferences for this visit (room temperature, music preference, pressure level, accessibility needs). Used for personalized service delivery.' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitDate rdf:type rdf:Property ;
    rdfs:label 'Visit Date' ;
    rdfs:comment 'Calendar date on which the spa facility visit occurred. Primary business event date for utilization tracking and reporting.' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitNumber rdf:type rdf:Property ;
    rdfs:label 'Visit Number' ;
    rdfs:comment 'Business identifier for the visit transaction. Externally visible reference number used for guest communication and service tracking.' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitStatus rdf:type rdf:Property ;
    rdfs:label 'Visit Status' ;
    rdfs:comment 'Current lifecycle status of the membership visit. Tracks progression from scheduling through completion or cancellation.' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitType rdf:type rdf:Property ;
    rdfs:label 'Visit Type' ;
    rdfs:comment 'Classification of the type of spa facility visit or membership benefit utilized. Determines credit consumption rules and access privileges. [ENUM-REF-CANDIDATE: fitness_access|pool_access|treatment_redemption|guest_pass|wellness_class|golf_access|spa_day_pass — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MembershipVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailInventoryId rdf:type rdf:Property ;
    rdfs:label 'Retail Inventory Id' ;
    rdfs:comment 'Unique identifier for the retail inventory record. Primary key for the retail inventory product.' ;
    rdfs:domain ind:RetailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retailProductId rdf:type rdf:Property ;
    rdfs:label 'Retail Product Id' ;
    rdfs:comment 'Reference to the retail product master record. Identifies the specific spa retail product (skincare, wellness items, accessories) being tracked in inventory.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailProduct .

ind:currentStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Stock Quantity' ;
    rdfs:comment 'The current on-hand quantity of the retail product at this facility. Represents the total physical inventory available including reserved items.' ;
    rdfs:domain ind:RetailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValue rdf:type rdf:Property ;
    rdfs:label 'Inventory Value' ;
    rdfs:comment 'The total value of current stock at unit cost. Calculated as current stock quantity multiplied by unit cost. Used for financial reporting and asset valuation.' ;
    rdfs:domain ind:RetailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Date' ;
    rdfs:comment 'The date when the most recent inventory replenishment was received for this product. Used to track replenishment frequency and supplier performance.' ;
    rdfs:domain ind:RetailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReplenishmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Quantity' ;
    rdfs:comment 'The quantity received in the most recent replenishment delivery. Used for replenishment pattern analysis and order optimization.' ;
    rdfs:domain ind:RetailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Sale Date' ;
    rdfs:comment 'The date when this product was last sold at this facility. Used to identify slow-moving inventory and optimize product mix.' ;
    rdfs:domain ind:RetailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reorderTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Reorder Triggered Flag' ;
    rdfs:comment 'Indicates whether the reorder point has been reached and a replenishment request should be generated. True when available quantity is at or below reorder point.' ;
    rdfs:domain ind:RetailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'The quantity of product reserved for pending guest purchases or spa treatment packages but not yet fulfilled. Reduces available quantity for new sales.' ;
    rdfs:domain ind:RetailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Retail Price' ;
    rdfs:comment 'The current selling price per unit of the retail product. Used for Point of Sale (POS) transactions and revenue calculation.' ;
    rdfs:domain ind:RetailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between system inventory quantity and physical count quantity. Positive values indicate overage, negative values indicate shortage. Used for shrinkage analysis and inventory accuracy metrics.' ;
    rdfs:domain ind:RetailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailTransactionId rdf:type rdf:Property ;
    rdfs:label 'Retail Transaction Id' ;
    rdfs:comment 'Unique identifier for the spa retail transaction record. Primary key.' ;
    rdfs:domain ind:RetailTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTransactionRetailTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Retail Transaction Id' ;
    rdfs:comment 'Reference to the original retail transaction ID if this transaction is a refund or exchange.' ;
    rdfs:domain ind:RetailTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailTransaction .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Printed receipt number provided to the guest as proof of purchase.' ;
    rdfs:domain ind:RetailTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReason rdf:type rdf:Property ;
    rdfs:label 'Refund Reason' ;
    rdfs:comment 'Reason code or description for refunded or voided transactions, if applicable.' ;
    rdfs:domain ind:RetailTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Channel through which the retail transaction was initiated (e.g., in-person at spa shop, online store, mobile app, phone order).' ;
    rdfs:domain ind:RetailTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Total quantity of all products sold in this transaction, summed across all line items.' ;
    rdfs:domain ind:RetailTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeId rdf:type rdf:Property ;
    rdfs:label 'Charge Id' ;
    rdfs:comment 'Unique identifier for the spa charge transaction. Primary key for the spa charge record.' ;
    rdfs:domain ind:Charge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Charge Employee Id' ;
    rdfs:comment 'System user ID of the staff member who posted the charge transaction. Used for audit trail and accountability.' ;
    rdfs:domain ind:Charge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:chargeVoidedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Charge Voided By User Employee Id' ;
    rdfs:comment 'System user ID of the staff member who voided the charge, if applicable. Used for audit trail and fraud prevention.' ;
    rdfs:domain ind:Charge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originalChargeId rdf:type rdf:Property ;
    rdfs:label 'Original Charge Id' ;
    rdfs:comment 'Reference to the original spa charge record if this is an adjustment or reversal. Links corrected charges to their source transactions.' ;
    rdfs:domain ind:Charge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Charge .

ind:chargeDate rdf:type rdf:Property ;
    rdfs:label 'Charge Date' ;
    rdfs:comment 'Business date when the spa charge was incurred. Used for revenue recognition and daily operations reporting.' ;
    rdfs:domain ind:Charge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargeNumber rdf:type rdf:Property ;
    rdfs:label 'Charge Number' ;
    rdfs:comment 'Externally-known unique reference number for the spa charge transaction, used for guest communication and reconciliation.' ;
    rdfs:domain ind:Charge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Charge Timestamp' ;
    rdfs:comment 'Precise date and time when the spa charge transaction was posted to the system. Principal business event timestamp for the transaction.' ;
    rdfs:domain ind:Charge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of the spa charge indicating the nature of the transaction: treatment (spa service), retail (product sale), membership (club fee), day_pass (facility access), gratuity (tip), or cancellation_fee (no-show penalty).' ;
    rdfs:domain ind:Charge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charge Amount' ;
    rdfs:comment 'Final total amount of the spa charge including all adjustments, taxes, and fees. Net amount posted to guest folio or POS transaction.' ;
    rdfs:domain ind:Charge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyVisitors rdf:type rdf:Property ;
    rdfs:label 'Average Daily Visitors' ;
    rdfs:comment 'Average number of unique guests visiting the facility per day, calculated over a rolling 90-day period. Used for capacity planning and staffing optimization.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationAccreditation rdf:type rdf:Property ;
    rdfs:label 'Certification Accreditation' ;
    rdfs:comment 'Comma-separated list of industry certifications, accreditations, or awards held by the facility (e.g., \'Forbes Five Star Spa, LEED Gold Certified, International Spa Association Member\'). Supports marketing and quality assurance.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current operational lifecycle status of the facility: active (open and operational), inactive (permanently closed), under_renovation (closed for Property Improvement Plan execution), temporarily_closed (short-term closure), seasonal (operates only during specific seasons).' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSafetyComplianceDate rdf:type rdf:Property ;
    rdfs:label 'Fire Safety Compliance Date' ;
    rdfs:comment 'Date of the most recent fire safety inspection and compliance certification. Required for local fire code adherence and insurance purposes.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:genderDesignation rdf:type rdf:Property ;
    rdfs:label 'Gender Designation' ;
    rdfs:comment 'Gender access policy for the facility: co_ed (open to all genders), female_only (restricted to female guests), male_only (restricted to male guests), gender_neutral (inclusive non-binary policy).' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestAccessPolicy rdf:type rdf:Property ;
    rdfs:label 'Guest Access Policy' ;
    rdfs:comment 'Policy governing who may access the facility: hotel_guests_only (restricted to registered guests), members_only (membership or loyalty program required), public_access (open to general public), day_pass_available (non-guests may purchase day access).' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthSafetyComplianceDate rdf:type rdf:Property ;
    rdfs:label 'Health Safety Compliance Date' ;
    rdfs:comment 'Date of the most recent health and safety inspection or compliance audit. Supports regulatory reporting and operational risk management.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockerRoomCapacity rdf:type rdf:Property ;
    rdfs:label 'Locker Room Capacity' ;
    rdfs:comment 'Total number of lockers available in changing and locker room facilities. Indicates maximum concurrent guest capacity for facility usage.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledRenovationDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Renovation Date' ;
    rdfs:comment 'Planned date for the next major renovation or facility upgrade. Supports long-term capital planning and guest communication regarding temporary closures.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursFriday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Friday' ;
    rdfs:comment 'Facility operating hours on Friday in 24-hour format (HH:MM-HH:MM) or \'closed\' if not operational.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursMonday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Monday' ;
    rdfs:comment 'Facility operating hours on Monday in 24-hour format (HH:MM-HH:MM) or \'closed\' if not operational. Example: \'06:00-22:00\'.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursSaturday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Saturday' ;
    rdfs:comment 'Facility operating hours on Saturday in 24-hour format (HH:MM-HH:MM) or \'closed\' if not operational.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursSunday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Sunday' ;
    rdfs:comment 'Facility operating hours on Sunday in 24-hour format (HH:MM-HH:MM) or \'closed\' if not operational.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursThursday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Thursday' ;
    rdfs:comment 'Facility operating hours on Thursday in 24-hour format (HH:MM-HH:MM) or \'closed\' if not operational.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursTuesday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Tuesday' ;
    rdfs:comment 'Facility operating hours on Tuesday in 24-hour format (HH:MM-HH:MM) or \'closed\' if not operational.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWednesday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Wednesday' ;
    rdfs:comment 'Facility operating hours on Wednesday in 24-hour format (HH:MM-HH:MM) or \'closed\' if not operational.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outdoorSpaceFlag rdf:type rdf:Property ;
    rdfs:label 'Outdoor Space Flag' ;
    rdfs:comment 'Indicates whether the facility includes outdoor amenities or treatment areas (e.g., outdoor pools, rooftop yoga decks, garden relaxation areas). True if outdoor space exists.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakSeasonMonths rdf:type rdf:Property ;
    rdfs:label 'Peak Season Months' ;
    rdfs:comment 'Comma-separated list of month names or numbers representing peak demand periods for the facility (e.g., \'June,July,August\' or \'6,7,8\'). Supports revenue management and staffing planning.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relaxationLoungeCapacity rdf:type rdf:Property ;
    rdfs:label 'Relaxation Lounge Capacity' ;
    rdfs:comment 'Maximum seating capacity in relaxation lounges and quiet areas where guests rest before or after treatments. Measured in number of seats.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retailAreaFlag rdf:type rdf:Property ;
    rdfs:label 'Retail Area Flag' ;
    rdfs:comment 'Indicates whether the facility includes a retail area for selling spa products, wellness merchandise, or branded goods. True if retail space exists.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalTreatmentRooms rdf:type rdf:Property ;
    rdfs:label 'Total Treatment Rooms' ;
    rdfs:comment 'Total number of individual treatment rooms available for spa services, massages, facials, and body treatments. Used for capacity planning and scheduling.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wetAreaCapacity rdf:type rdf:Property ;
    rdfs:label 'Wet Area Capacity' ;
    rdfs:comment 'Maximum guest capacity for wet amenities including steam rooms, saunas, whirlpools, and hydrotherapy pools. Measured in number of guests.' ;
    rdfs:domain ind:SpaFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amenitiesIncluded rdf:type rdf:Property ;
    rdfs:label 'Amenities Included' ;
    rdfs:comment 'Description of facility amenities included with the package such as pool access, fitness center, relaxation lounge, or refreshments.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationHoursNotice rdf:type rdf:Property ;
    rdfs:label 'Cancellation Hours Notice' ;
    rdfs:comment 'Number of hours notice required for cancellation without penalty. Industry standard ranges from 24 to 72 hours for spa packages.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genderRestriction rdf:type rdf:Property ;
    rdfs:label 'Gender Restriction' ;
    rdfs:comment 'Gender-based restriction for package booking. Used for gender-specific facilities or cultural requirements.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Guest Type Eligibility' ;
    rdfs:comment 'Defines which guest segments are eligible to book this package. Supports targeted offerings and loyalty program benefits.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPartySize rdf:type rdf:Property ;
    rdfs:label 'Maximum Party Size' ;
    rdfs:comment 'Maximum number of guests allowed in a single booking of this package. Constrained by facility capacity and therapist availability.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPartySize rdf:type rdf:Property ;
    rdfs:label 'Minimum Party Size' ;
    rdfs:comment 'Minimum number of guests required to book this package. Typically used for couples or group packages.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalRate rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate' ;
    rdfs:comment 'Discounted or promotional price for the spa package during specific campaigns or seasons. Null when no promotion is active.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyAvailability rdf:type rdf:Property ;
    rdfs:label 'Property Availability' ;
    rdfs:comment 'Comma-separated list of property codes where this package is available. Supports multi-property package offerings.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresDeposit rdf:type rdf:Property ;
    rdfs:label 'Requires Deposit' ;
    rdfs:comment 'Indicates whether a deposit is required at time of booking to secure the package reservation.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retailProductsIncluded rdf:type rdf:Property ;
    rdfs:label 'Retail Products Included' ;
    rdfs:comment 'List of retail product codes or descriptions included as part of the package. Supports spa retail integration and inventory management.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceChargeIncluded rdf:type rdf:Property ;
    rdfs:label 'Service Charge Included' ;
    rdfs:comment 'Indicates whether gratuity or service charge is included in the package price. Important for guest communication and revenue allocation.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Duration Minutes' ;
    rdfs:comment 'Total duration of all included treatments and transitions in minutes. Used for scheduling and capacity planning.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilitySchedule rdf:type rdf:Property ;
    rdfs:label 'Availability Schedule' ;
    rdfs:comment 'Standard weekly availability pattern for the therapist (e.g., days of week, shift preferences). Used for automated scheduling and shift planning.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the therapist\'s employment relationship with the property. Determines scheduling rules, benefit eligibility, and commission structures.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestRatingAverage rdf:type rdf:Property ;
    rdfs:label 'Guest Rating Average' ;
    rdfs:comment 'Average guest satisfaction rating for the therapist across all completed appointments, typically on a 1-5 scale. Used for performance management, guest matching, and service quality monitoring.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'Base hourly compensation rate for the therapist. Used for payroll calculations, labor cost analysis, and service pricing models. Excludes commissions and tips.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:languagesSpoken rdf:type rdf:Property ;
    rdfs:label 'Languages Spoken' ;
    rdfs:comment 'Comma-separated list of languages the therapist can communicate in fluently. Used to match therapists with international guests and enhance guest experience through native-language service.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAppointmentsPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Appointments Per Day' ;
    rdfs:comment 'Maximum number of treatment appointments the therapist can perform in a single day. Used for scheduling optimization and therapist wellness management to prevent burnout.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextCertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Certification Due Date' ;
    rdfs:comment 'Date by which the therapist must complete their next certification renewal or continuing education requirement. Used for proactive compliance management and training scheduling.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Name the therapist prefers to use in guest-facing interactions and on spa schedules. May differ from legal name for cultural, personal, or professional branding reasons.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Primary License Expiry Date' ;
    rdfs:comment 'Expiration date of the therapist\'s primary professional license. Monitored for compliance; therapists cannot perform services after expiry without renewal.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Primary License Number' ;
    rdfs:comment 'State or national professional license number for massage therapy, esthetics, or other regulated spa services. Required for regulatory compliance and insurance coverage.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseState rdf:type rdf:Property ;
    rdfs:label 'Primary License State' ;
    rdfs:comment 'Two-letter state code where the primary professional license was issued. Used to verify jurisdiction-specific compliance and reciprocity eligibility.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryLicenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Secondary License Expiry Date' ;
    rdfs:comment 'Expiration date of the therapist\'s secondary professional license. Monitored for compliance in multi-license scenarios.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondaryLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Secondary License Number' ;
    rdfs:comment 'Additional professional license number for therapists certified in multiple disciplines (e.g., both massage therapy and esthetics) or holding licenses in multiple states.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryLicenseState rdf:type rdf:Property ;
    rdfs:label 'Secondary License State' ;
    rdfs:comment 'Two-letter state code where the secondary professional license was issued. Supports multi-state operations and cross-property assignments.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializations rdf:type rdf:Property ;
    rdfs:label 'Specializations' ;
    rdfs:comment 'Comma-separated list of treatment modalities and techniques the therapist is certified to perform (e.g., Swedish massage, deep tissue, hot stone, Ayurvedic, reflexology, aromatherapy, prenatal, sports massage, esthetics, body wraps). Used for service matching and guest preference fulfillment.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapistCode rdf:type rdf:Property ;
    rdfs:label 'Therapist Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the therapist for scheduling, Point of Sale (POS) transactions, and operational reporting. Used in spa management systems and guest-facing booking interfaces.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapistStatus rdf:type rdf:Property ;
    rdfs:label 'Therapist Status' ;
    rdfs:comment 'Current operational status of the therapist. Active therapists are available for scheduling; inactive, on-leave, suspended, or terminated therapists are excluded from guest-facing booking systems.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tipEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Tip Eligible Flag' ;
    rdfs:comment 'Indicates whether the therapist is eligible to receive gratuities from guests. Varies by employment type and local labor regulations.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAppointmentsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Appointments Completed' ;
    rdfs:comment 'Cumulative count of all spa appointments completed by the therapist since hire date. Used for productivity tracking, milestone recognition, and experience validation.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of professional experience as a spa therapist, including prior employment at other properties or spas. Used for skill-based pricing, guest matching, and training program placement.' ;
    rdfs:domain ind:Therapist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spaTherapistCertificationId rdf:type rdf:Property ;
    rdfs:label 'Spa Therapist Certification Id' ;
    rdfs:comment 'Unique identifier for the therapist certification record. Primary key.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certification Document Url' ;
    rdfs:comment 'The storage location or URL of the scanned certification document or digital credential. Enables audit trail and verification support.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Completed' ;
    rdfs:comment 'The number of continuing education hours the therapist has completed toward the current renewal cycle. Enables proactive management of renewal readiness.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuingEducationHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Required' ;
    rdfs:comment 'The number of continuing education hours required for renewal of this certification. Used to track therapist compliance with professional development requirements.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'The cost incurred to obtain or renew this certification, including exam fees, training fees, and application fees. Used for workforce development budgeting and ROI analysis.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBrandRequired rdf:type rdf:Property ;
    rdfs:label 'Is Brand Required' ;
    rdfs:comment 'Indicates whether this certification is mandated by brand service standards for therapists to perform certain treatments. Used to enforce brand compliance.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryCertification rdf:type rdf:Property ;
    rdfs:label 'Is Primary Certification' ;
    rdfs:comment 'Indicates whether this is the therapist\'s primary professional certification. Used to identify the main credential under which the therapist practices.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStateRequired rdf:type rdf:Property ;
    rdfs:label 'Is State Required' ;
    rdfs:comment 'Indicates whether this certification is required by state or local regulatory authorities for the therapist to legally practice. Critical for compliance and risk management.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Jurisdiction' ;
    rdfs:comment 'The state, province, or country where the certification was issued. Critical for multi-property operations to ensure therapists hold valid licenses for the jurisdictions where they practice.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Status' ;
    rdfs:comment 'Indicates whether the certification cost was reimbursed by the employer. Used to track workforce development investments and employee benefit utilization.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyArea rdf:type rdf:Property ;
    rdfs:label 'Specialty Area' ;
    rdfs:comment 'The specific treatment specialty or modality covered by this certification (e.g., \'Deep Tissue Massage\', \'Hot Stone Therapy\', \'Aromatherapy\', \'Facial Treatments\', \'Body Wraps\'). Enables matching therapist qualifications to guest service requests.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'The date the therapist completed the training program associated with this certification. Relevant for brand certifications and specialty training.' ;
    rdfs:domain ind:SpaTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingHours rdf:type rdf:Property ;
    rdfs:label 'Training Hours' ;
    rdfs:comment 'The total number of training hours completed to earn this certification. Used to assess depth of qualification and compare against brand standards.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:therapistScheduleId rdf:type rdf:Property ;
    rdfs:label 'Therapist Schedule Id' ;
    rdfs:comment 'Unique identifier for the therapist schedule record. Primary key for the therapist schedule entity.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualClockInTime rdf:type rdf:Property ;
    rdfs:label 'Actual Clock In Time' ;
    rdfs:comment 'The actual timestamp when the therapist clocked in or checked in for their shift. Used for payroll processing, attendance tracking, and variance analysis against scheduled start time.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualClockOutTime rdf:type rdf:Property ;
    rdfs:label 'Actual Clock Out Time' ;
    rdfs:comment 'The actual timestamp when the therapist clocked out or checked out from their shift. Used for payroll processing, attendance tracking, and variance analysis against scheduled end time.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Worked' ;
    rdfs:comment 'The actual number of hours the therapist worked during this shift, calculated from clock-in and clock-out times. Used for payroll processing and labor cost analysis.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakEndTime rdf:type rdf:Property ;
    rdfs:label 'Break End Time' ;
    rdfs:comment 'The timestamp when the therapist\'s scheduled break period ends. Used to resume appointment availability after the break period.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overtimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible Flag' ;
    rdfs:comment 'Indicates whether this shift qualifies for overtime compensation based on labor regulations and the therapist\'s employment classification. True if overtime rules apply, false otherwise.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'The number of hours worked during this shift that qualify as overtime. Used for payroll processing and labor cost management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTreatmentSpecialty rdf:type rdf:Property ;
    rdfs:label 'Primary Treatment Specialty' ;
    rdfs:comment 'The primary type of spa treatment the therapist is scheduled to provide during this shift (e.g., massage, facial, body treatment, nail services). Used for matching therapist skills with guest appointment requests.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomAssignment rdf:type rdf:Property ;
    rdfs:label 'Room Assignment' ;
    rdfs:comment 'The specific treatment room or station assigned to the therapist for this shift. Used for facility management and guest wayfinding.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to this schedule entry. May include information about special events, training sessions, equipment needs, or other operational details.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Minutes' ;
    rdfs:comment 'The difference in minutes between scheduled hours and actual hours worked. Positive values indicate overtime, negative values indicate undertime. Used for schedule accuracy analysis and labor forecasting.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledTreatmentSlots rdf:type rdf:Property ;
    rdfs:label 'Scheduled Treatment Slots' ;
    rdfs:comment 'The number of discrete treatment appointment slots scheduled during this shift. Used for capacity planning and appointment availability management.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAvailableHours rdf:type rdf:Property ;
    rdfs:label 'Total Available Hours' ;
    rdfs:comment 'The total number of hours the therapist is available for treatment appointments, excluding break periods and administrative time. Used for capacity planning and appointment scheduling.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBookedHours rdf:type rdf:Property ;
    rdfs:label 'Total Booked Hours' ;
    rdfs:comment 'The total number of hours that have been booked with guest appointments during this shift. Used to calculate therapist utilization and identify available capacity.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalScheduledHours rdf:type rdf:Property ;
    rdfs:label 'Total Scheduled Hours' ;
    rdfs:comment 'The total number of hours the therapist is scheduled to work during this shift, calculated as the difference between shift end time and shift start time minus break periods. Used for labor cost planning and compliance with labor regulations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'The percentage of available hours that have been booked with appointments, calculated as (total_booked_hours / total_available_hours) * 100. Key performance indicator (KPI) for spa productivity and revenue optimization.' ;
    rdfs:domain ind:TherapistSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfGoods rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods' ;
    rdfs:comment 'Standard cost of consumable products, oils, lotions, and supplies used in delivering this treatment. Used for margin analysis and profitability reporting.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genderPreference rdf:type rdf:Property ;
    rdfs:label 'Gender Preference' ;
    rdfs:comment 'Indicates whether the treatment is designed for specific gender or can be offered to any guest. Used for marketing segmentation and therapist assignment.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCertification rdf:type rdf:Property ;
    rdfs:label 'Minimum Certification' ;
    rdfs:comment 'Minimum professional certification, license, or credential required to perform this treatment (e.g., Licensed Massage Therapist, Esthetician License, Cosmetology License).' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Recommended Retail Price' ;
    rdfs:comment 'Corporate-recommended retail price for this treatment in the base currency. Individual properties may adjust based on local market conditions and positioning.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredEquipment rdf:type rdf:Property ;
    rdfs:label 'Required Equipment' ;
    rdfs:comment 'List of specialized equipment, tools, or facilities required to deliver this treatment (e.g., hydrotherapy tub, vichy shower, hot stone warmer, facial steamer).' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailProductsUsed rdf:type rdf:Property ;
    rdfs:label 'Retail Products Used' ;
    rdfs:comment 'List of retail product SKUs or product lines used during the treatment. Supports cross-sell opportunities and inventory planning.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Room Type Required' ;
    rdfs:comment 'Type of treatment room or facility required to deliver this service (e.g., single room, couples suite, wet room, outdoor cabana). Used for facility scheduling and capacity planning.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentCategory rdf:type rdf:Property ;
    rdfs:label 'Treatment Category' ;
    rdfs:comment 'Primary classification of the spa treatment type. Used for menu organization, revenue reporting, and therapist skill matching.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Code' ;
    rdfs:comment 'Unique alphanumeric business identifier for the treatment used across all properties and systems. This is the externally-known catalog code used in PMS, POS, and booking systems.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Description' ;
    rdfs:comment 'Detailed narrative description of the treatment including techniques, benefits, and guest experience. Used in spa menus, websites, and booking confirmations.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentName rdf:type rdf:Property ;
    rdfs:label 'Treatment Name' ;
    rdfs:comment 'Full marketing name of the spa treatment as displayed to guests in menus, booking systems, and promotional materials.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Treatment Status' ;
    rdfs:comment 'Current lifecycle status of the treatment in the master catalog. Controls availability for booking and display in guest-facing systems.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upsellTreatments rdf:type rdf:Property ;
    rdfs:label 'Upsell Treatments' ;
    rdfs:comment 'List of complementary treatment codes that can be recommended as add-ons or follow-up services. Supports revenue optimization and guest experience enhancement.' ;
    rdfs:domain ind:Treatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentMenuId rdf:type rdf:Property ;
    rdfs:label 'Treatment Menu Id' ;
    rdfs:comment 'Unique identifier for the property-level spa treatment menu. Primary key.' ;
    rdfs:domain ind:TreatmentMenu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTreatmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Treatment Employee Id' ;
    rdfs:comment 'Reference to the user (spa manager, revenue manager, or property director) who approved this treatment menu for publication.' ;
    rdfs:domain ind:TreatmentMenu ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bookingChannelAvailability rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Availability' ;
    rdfs:comment 'Comma-separated list of channels where this menu is available for booking (e.g., \'web,mobile,front_desk,concierge,spa_reception\').' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuBrochureUrl rdf:type rdf:Property ;
    rdfs:label 'Menu Brochure Url' ;
    rdfs:comment 'URL to the downloadable PDF brochure or detailed menu document for guest reference and marketing distribution.' ;
    rdfs:domain ind:TreatmentMenu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuImageUrl rdf:type rdf:Property ;
    rdfs:label 'Menu Image Url' ;
    rdfs:comment 'URL to the primary marketing image or hero image representing this treatment menu in digital channels.' ;
    rdfs:domain ind:TreatmentMenu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuVersion rdf:type rdf:Property ;
    rdfs:label 'Menu Version' ;
    rdfs:comment 'Version number of the treatment menu to track revisions and updates over time (e.g., \'1.0\', \'2.1\', \'3.0.1\').' ;
    rdfs:domain ind:TreatmentMenu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date when the treatment menu was officially published and made available to guests.' ;
    rdfs:domain ind:TreatmentMenu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publishedStatus rdf:type rdf:Property ;
    rdfs:label 'Published Status' ;
    rdfs:comment 'Current publication state of the treatment menu indicating whether it is visible to guests and available for booking.' ;
    rdfs:domain ind:TreatmentMenu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ambianceFeatures rdf:type rdf:Property ;
    rdfs:label 'Ambiance Features' ;
    rdfs:comment 'Descriptive text listing special ambiance and sensory features of the treatment room (e.g., ocean view, fireplace, aromatherapy diffuser, Himalayan salt wall). Used for marketing and guest preference matching.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentList rdf:type rdf:Property ;
    rdfs:label 'Equipment List' ;
    rdfs:comment 'Comma-separated list of major equipment and fixtures installed in the treatment room (e.g., massage table, hydrotherapy tub, steam generator, chromotherapy system). Used for treatment compatibility verification and maintenance planning.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffeValue rdf:type rdf:Property ;
    rdfs:label 'Ffe Value' ;
    rdfs:comment 'Total capitalized value of furniture, fixtures, and equipment installed in the treatment room. Used for asset management, depreciation calculations, and insurance purposes.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasChromotherapy rdf:type rdf:Property ;
    rdfs:label 'Has Chromotherapy' ;
    rdfs:comment 'Indicates whether the treatment room is equipped with chromotherapy (color therapy) lighting system. Premium feature for holistic wellness treatments.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasHeatedTable rdf:type rdf:Property ;
    rdfs:label 'Has Heated Table' ;
    rdfs:comment 'Indicates whether the treatment room is equipped with a heated massage table. Premium amenity that affects treatment offerings and guest experience.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasMusicSystem rdf:type rdf:Property ;
    rdfs:label 'Has Music System' ;
    rdfs:comment 'Indicates whether the treatment room has an integrated audio system for ambient music and guided meditation. Enhances guest relaxation experience.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasOutdoorAccess rdf:type rdf:Property ;
    rdfs:label 'Has Outdoor Access' ;
    rdfs:comment 'Indicates whether the treatment room has direct access to outdoor space (terrace, garden, or private patio). Premium feature for resort spa properties.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPrivateShower rdf:type rdf:Property ;
    rdfs:label 'Has Private Shower' ;
    rdfs:comment 'Indicates whether the treatment room includes an en-suite shower facility. Premium amenity that enables extended treatment packages and hydrotherapy services.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance or inspection of the treatment room. Used for capacity planning and maintenance workflow management.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roomCode rdf:type rdf:Property ;
    rdfs:label 'Room Code' ;
    rdfs:comment 'Short standardized code for the treatment room used in scheduling systems and operational reports (e.g., TR01, VIP-A, WET-3).' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomName rdf:type rdf:Property ;
    rdfs:label 'Room Name' ;
    rdfs:comment 'Human-readable name of the treatment room used for guest communication and staff scheduling (e.g., Serenity Suite, Ocean View Room, Couples Retreat).' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanitationProtocol rdf:type rdf:Property ;
    rdfs:label 'Sanitation Protocol' ;
    rdfs:comment 'Level of sanitation and hygiene protocol applied to the treatment room. Determines cleaning frequency, products used, and turnaround time between appointments.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlType rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Type' ;
    rdfs:comment 'Type of climate control system available in the treatment room. Affects guest comfort customization and energy management.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to clean, sanitize, and prepare the treatment room between guest appointments. Critical for accurate scheduling and capacity optimization.' ;
    rdfs:domain ind:TreatmentRoom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wellnessProgramId rdf:type rdf:Property ;
    rdfs:label 'Wellness Program Id' ;
    rdfs:comment 'Unique identifier for the wellness program. Primary key for the wellness program entity.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WellnessProgram .

ind:dietaryMenuId rdf:type rdf:Property ;
    rdfs:label 'Dietary Menu Id' ;
    rdfs:comment 'Foreign key linking to fnb.menu. Business justification: Wellness programs include prescribed meal plans (detox menus, anti-inflammatory diets, nutrition programs). Programs reference specific F&B menus designed for dietary components. Essential for program' ;
    rdfs:domain ind:WellnessProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Menu .

ind:primaryWellnessEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Wellness Employee Id' ;
    rdfs:comment 'Identifier of the user (spa director, revenue manager, or general manager) who approved this wellness program for operational deployment and guest booking.' ;
    rdfs:domain ind:WellnessProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWellnessLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Wellness Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who most recently modified this wellness program record. Enables change tracking and accountability for program updates.' ;
    rdfs:domain ind:WellnessProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dietaryComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Dietary Component Flag' ;
    rdfs:comment 'Indicates whether the wellness program includes a specialized dietary or nutrition component such as meal plans, nutritional counseling, or detox menus.' ;
    rdfs:domain ind:WellnessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includedFitnessSessions rdf:type rdf:Property ;
    rdfs:label 'Included Fitness Sessions' ;
    rdfs:comment 'Number of fitness or exercise sessions included in the wellness program (e.g., yoga classes, personal training, group fitness). Zero indicates no fitness component.' ;
    rdfs:domain ind:WellnessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalSupervisionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Supervision Required Flag' ;
    rdfs:comment 'Indicates whether the wellness program requires medical supervision, physician consultation, or health screening prior to participation. Critical for liability and guest safety.' ;
    rdfs:domain ind:WellnessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumAdvanceBookingDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Advance Booking Days' ;
    rdfs:comment 'Minimum number of days in advance that a guest must book before the program start date. Ensures adequate preparation time for therapist scheduling, dietary planning, and facility readiness.' ;
    rdfs:domain ind:WellnessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programBrochureUrl rdf:type rdf:Property ;
    rdfs:label 'Program Brochure Url' ;
    rdfs:comment 'URL to the downloadable PDF brochure or detailed program guide. Provides comprehensive information for guest decision-making and pre-arrival preparation.' ;
    rdfs:domain ind:WellnessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programImageUrl rdf:type rdf:Property ;
    rdfs:label 'Program Image Url' ;
    rdfs:comment 'URL to the primary marketing image or hero photo for the wellness program. Used in digital marketing, website display, and booking confirmation materials.' ;
    rdfs:domain ind:WellnessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programPrice rdf:type rdf:Property ;
    rdfs:label 'Program Price' ;
    rdfs:comment 'Base price for the complete wellness program package per guest. Excludes taxes, gratuities, and optional add-on services. Used for revenue forecasting and yield management.' ;
    rdfs:domain ind:WellnessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Unique identifier for the benefit plan. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:acaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Aca Compliant Flag' ;
    rdfs:comment 'Indicates whether the benefit plan meets ACA minimum essential coverage and affordability requirements. True if compliant, False otherwise.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'Policy or contract number assigned by the insurance carrier for this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Flag' ;
    rdfs:comment 'Indicates whether the benefit plan is eligible for COBRA continuation coverage after employment termination. True if eligible, False otherwise.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'Percentage of covered costs the employee pays after meeting the deductible (e.g., 20% coinsurance means employee pays 20%, carrier pays 80%).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Frequency at which employee and employer contributions are deducted or paid (e.g., biweekly, monthly).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Fixed dollar amount the employee pays for specific services (e.g., $25 copay for doctor visit, $10 copay for generic prescription).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage provided by the plan, indicating who is covered (employee only, employee plus dependents, family).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Annual deductible amount the employee must pay before the insurance carrier begins coverage. Applicable to health, dental, and vision plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dependentCoverageAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Dependent Coverage Allowed Flag' ;
    rdfs:comment 'Indicates whether the benefit plan allows coverage for employee dependents (spouse, children). True if dependents can be covered, False otherwise.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'Dollar amount the employee contributes per pay period toward the benefit plan premium or cost.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'Dollar amount the employer contributes per pay period toward the benefit plan premium or cost. Used for total compensation cost tracking per USALI.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Period End Date' ;
    rdfs:comment 'End date of the open enrollment period. Employees must complete enrollment actions by this date.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Period Start Date' ;
    rdfs:comment 'Start date of the open enrollment period when employees can elect or change their benefit plan selections.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifeEventEnrollmentAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Life Event Enrollment Allowed Flag' ;
    rdfs:comment 'Indicates whether employees can enroll or make changes to this benefit plan outside of open enrollment due to qualifying life events (marriage, birth, adoption). True if allowed, False otherwise.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumDependentAge rdf:type rdf:Property ;
    rdfs:label 'Maximum Dependent Age' ;
    rdfs:comment 'Maximum age at which a dependent child can remain covered under the benefit plan (e.g., 26 per ACA for health plans).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfPocketMaximum rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Maximum' ;
    rdfs:comment 'Maximum amount the employee will pay out-of-pocket for covered services in a plan year. After this limit, the carrier pays 100%.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the benefit plan including coverage details, exclusions, and key features provided to employees.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'URL or file path to the official plan document, summary plan description (SPD), or benefits guide for employee reference.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Full descriptive name of the benefit plan as displayed to employees and in HR systems.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the benefit plan. Indicates whether the plan is available for enrollment and active for coverage.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Category of benefit plan. Classifies the plan into major benefit types offered to hospitality employees. [ENUM-REF-CANDIDATE: health|dental|vision|life_insurance|disability|retirement_401k|employee_assistance_program|hotel_rate_discount|flexible_spending_account|health_savings_account — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'Calendar year or fiscal year for which the benefit plan is active (e.g., 2024).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Days' ;
    rdfs:comment 'Number of days an employee must wait after hire date before becoming eligible to enroll in the benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationPlanId rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Id' ;
    rdfs:comment 'Unique identifier for the compensation plan definition. Primary key.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCompensationApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compensation Approved By Employee Id' ;
    rdfs:comment 'Employee ID of the HR or compensation leader who approved this plan. Null if not yet approved.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:benefitsPackageCode rdf:type rdf:Property ;
    rdfs:label 'Benefits Package Code' ;
    rdfs:comment 'Code identifying the standard benefits package associated with this compensation plan (health, dental, retirement, etc.).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusEligible rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligible' ;
    rdfs:comment 'Indicates whether employees under this plan are eligible for discretionary or performance-based bonuses (True/False).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percentage' ;
    rdfs:comment 'Standard commission rate as a percentage of sales or revenue (e.g., 5.00 for 5%). Null if not commission eligible.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compaRatioTarget rdf:type rdf:Property ;
    rdfs:label 'Compa Ratio Target' ;
    rdfs:comment 'Target compa-ratio for employees in this plan (actual pay divided by midpoint). Typically 1.00 (100%) for market-competitive positioning.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Description' ;
    rdfs:comment 'Detailed description of the compensation plan, including eligibility criteria, special provisions, and business rationale.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Status' ;
    rdfs:comment 'Current lifecycle status of the compensation plan: active (in use), inactive (temporarily suspended), pending (awaiting approval), obsolete (retired).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Status' ;
    rdfs:comment 'FLSA classification: exempt (not eligible for overtime) or non_exempt (eligible for overtime pay). Critical for compliance and labor cost forecasting.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isUnionized rdf:type rdf:Property ;
    rdfs:label 'Is Unionized' ;
    rdfs:comment 'Indicates whether this compensation plan is subject to collective bargaining agreements (True/False).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketPricingDate rdf:type rdf:Property ;
    rdfs:label 'Market Pricing Date' ;
    rdfs:comment 'Date of the market pricing data used to establish or update this compensation plan.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketPricingSource rdf:type rdf:Property ;
    rdfs:label 'Market Pricing Source' ;
    rdfs:comment 'External compensation survey or benchmarking source used to establish pay ranges (e.g., Mercer, Willis Towers Watson, Salary.com).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRate rdf:type rdf:Property ;
    rdfs:label 'Maximum Rate' ;
    rdfs:comment 'Maximum pay rate for this plan, representing the ceiling for this grade. Used for pay equity and budget planning.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meritIncreaseCycle rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Cycle' ;
    rdfs:comment 'Frequency of merit increase reviews for this plan: annual, biannual, quarterly, or none.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIncreaseEligible rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Eligible' ;
    rdfs:comment 'Indicates whether employees under this plan are eligible for annual merit increases based on performance (True/False).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:midpointRate rdf:type rdf:Property ;
    rdfs:label 'Midpoint Rate' ;
    rdfs:comment 'Midpoint or target pay rate for this plan, representing the market-competitive rate for fully competent performance.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Rate' ;
    rdfs:comment 'Minimum pay rate for this plan (hourly rate for hourly plans, annual salary for salaried plans). Used for pay equity and compliance analysis.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether employees under this plan are eligible for overtime compensation (True/False). Aligns with FLSA status.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'Multiplier applied to base rate for overtime hours (e.g., 1.5 for time-and-a-half, 2.0 for double-time). Null if not overtime eligible.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'Frequency at which employees under this plan are paid (weekly, biweekly, semimonthly, monthly).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'Unit of measure for the compensation rate: hour (hourly wage), year (annual salary), month (monthly salary), week (weekly wage), day (daily rate).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceChargeEligible rdf:type rdf:Property ;
    rdfs:label 'Service Charge Eligible' ;
    rdfs:comment 'Indicates whether employees under this plan are eligible to receive a share of service charges (True/False). Common in banquet and group dining operations.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetBonusPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Bonus Percentage' ;
    rdfs:comment 'Target bonus as a percentage of base compensation (e.g., 10.00 for 10% target bonus). Null if not bonus eligible.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tipCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Tip Credit Eligible' ;
    rdfs:comment 'Indicates whether this plan is eligible for tip credit under FLSA (True/False). Applicable to tipped positions in Food and Beverage (F&B) operations.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation' ;
    rdfs:comment 'Name of the labor union associated with this compensation plan, if applicable. Null if non-union.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usaliDepartment rdf:type rdf:Property ;
    rdfs:label 'Usali Department' ;
    rdfs:comment 'USALI department classification for labor cost reporting (e.g., Rooms, Food and Beverage, Administrative and General, Sales and Marketing).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Id' ;
    rdfs:comment 'Unique identifier for the disciplinary action record. Primary key for the disciplinary action entity.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDisciplinaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Disciplinary Employee Id' ;
    rdfs:comment 'Unique identifier of the employee subject to the disciplinary action. Links to the employee master record in Oracle HCM Cloud or SAP S/4HANA HCM.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDisciplinaryHrBusinessPartnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disciplinary Hr Business Partner Employee Id' ;
    rdfs:comment 'Unique identifier of the HR business partner involved in reviewing and approving the disciplinary action. Links to the employee master record. Ensures HR oversight and policy compliance.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workforceSafetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Workforce Safety Incident Id' ;
    rdfs:comment 'Unique identifier linking this disciplinary action to an OSHA recordable incident record if applicable. Null if not an OSHA recordable incident. Supports integrated safety and HR compliance reporting.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceSafetyIncident .

ind:actionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Action Effective Date' ;
    rdfs:comment 'The date on which the disciplinary action officially takes effect. For suspensions, this is the start date. For terminations, this is the last day of employment. May differ from incident date or issuance date.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the disciplinary action record. Statuses include draft (being prepared), issued (formally communicated to employee), active (in effect), completed (action period concluded), overturned (reversed on appeal), or expunged (removed from record per policy or legal requirement).' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Description of the corrective actions required of the employee to address the violation and prevent recurrence. May include training, coaching, behavioral expectations, or performance targets. Part of progressive discipline and performance improvement process.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Date' ;
    rdfs:comment 'The date on which the employee acknowledged receipt and understanding of the disciplinary action documentation. Null if not yet acknowledged. Critical for documentation completeness and legal defensibility.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgmentMethod rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Method' ;
    rdfs:comment 'The method by which the employee acknowledged receipt of the disciplinary action. Methods include in-person signature, electronic signature, certified mail, email confirmation, or refused (employee declined to sign). Used for documentation audit trail.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expungedDate rdf:type rdf:Property ;
    rdfs:label 'Expunged Date' ;
    rdfs:comment 'The date on which the disciplinary action record was expunged from the employees active record. Null if not expunged. Used for data retention and compliance tracking.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expungedReason rdf:type rdf:Property ;
    rdfs:label 'Expunged Reason' ;
    rdfs:comment 'Explanation of why the disciplinary action record was expunged. Reasons may include policy expiration, grievance settlement, legal requirement, or administrative correction. Null if not expunged.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceFiled rdf:type rdf:Property ;
    rdfs:label 'Grievance Filed' ;
    rdfs:comment 'Indicates whether the employee has filed a formal grievance or appeal against the disciplinary action. True if grievance filed, false otherwise. Critical for union contract compliance and legal risk management.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grievanceOutcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Grievance Outcome Notes' ;
    rdfs:comment 'Detailed notes on the outcome of the grievance or appeal process, including any modifications to the original disciplinary action, settlements, or arbitration decisions. Null if no grievance filed.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Grievance Resolution Date' ;
    rdfs:comment 'The date on which the grievance or appeal was formally resolved. Null if no grievance filed or if grievance is still pending. Used for labor relations reporting and compliance tracking.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grievanceStatus rdf:type rdf:Property ;
    rdfs:label 'Grievance Status' ;
    rdfs:comment 'Current status of the grievance or appeal process if a grievance has been filed. Statuses include pending, under review, upheld (action stands), overturned (action reversed), settled, or withdrawn. Null if no grievance filed.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEligibleForRehire rdf:type rdf:Property ;
    rdfs:label 'Is Eligible For Rehire' ;
    rdfs:comment 'Indicates whether the employee is eligible for rehire following termination. True if eligible, false if not. Null for non-termination actions. Used by talent acquisition and background screening processes.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExpunged rdf:type rdf:Property ;
    rdfs:label 'Is Expunged' ;
    rdfs:comment 'Indicates whether the disciplinary action record has been expunged (removed from the employees active record) per policy, legal requirement, or grievance settlement. True if expunged, false otherwise. Expunged records are retained for audit but not used in progressive discipline tracking.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaidSuspension rdf:type rdf:Property ;
    rdfs:label 'Is Paid Suspension' ;
    rdfs:comment 'Indicates whether the suspension is paid or unpaid. True if paid, false if unpaid. Impacts payroll processing and labor cost allocation. Null for non-suspension actions.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHold rdf:type rdf:Property ;
    rdfs:label 'Legal Hold' ;
    rdfs:comment 'Indicates whether this disciplinary action record is subject to a legal hold due to pending or threatened litigation, regulatory investigation, or other legal proceedings. True if under legal hold, false otherwise. Records under legal hold must not be deleted or modified.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Case Number' ;
    rdfs:comment 'Reference number of the legal case or investigation that triggered the legal hold on this record. Null if not under legal hold. Used for legal department tracking and e-discovery management.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordableIncident rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Incident' ;
    rdfs:comment 'Indicates whether the incident that led to the disciplinary action is also an OSHA recordable safety incident. True if OSHA recordable, false otherwise. Links disciplinary actions to workplace safety compliance reporting.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionDays rdf:type rdf:Property ;
    rdfs:label 'Suspension Days' ;
    rdfs:comment 'The total number of days of suspension if the action type is suspension. Null for non-suspension actions. Used for labor cost analysis and CPOR (Cost Per Occupied Room) labor component tracking.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for termination if the action type is termination. Categories include voluntary resignation, involuntary for cause, involuntary for performance, involuntary for conduct, layoff, or mutual separation. Used for unemployment claims and compliance reporting.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Union Representative Name' ;
    rdfs:comment 'Name of the union representative who was notified or involved in the disciplinary action process. Null if employee is not union-represented or if no representative was involved.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresentativeNotified rdf:type rdf:Property ;
    rdfs:label 'Union Representative Notified' ;
    rdfs:comment 'Indicates whether the employees union representative was notified of the disciplinary action as required by union contract. True if notified, false otherwise. Null if employee is not union-represented. Critical for labor relations compliance.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'The category of policy violation that triggered the disciplinary action. Categories include attendance issues, conduct violations, performance deficiencies, safety violations, general policy breaches, guest service failures, or theft/fraud. Used for trend analysis and compliance reporting. [ENUM-REF-CANDIDATE: attendance|conduct|performance|safety|policy_breach|guest_service|theft_fraud — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessNames rdf:type rdf:Property ;
    rdfs:label 'Witness Names' ;
    rdfs:comment 'Comma-separated list of names of witnesses to the incident or policy violation. Used for investigation documentation and wrongful termination defense. May be redacted in certain reporting contexts.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaAccommodationDescription rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Description' ;
    rdfs:comment 'Description of the specific workplace accommodations provided to the employee under ADA or equivalent legislation. Highly sensitive health-related information. Used for accommodation implementation and compliance documentation.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaAccommodationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee requires workplace accommodations under ADA or equivalent disability legislation. Used for compliance tracking and accommodation management. Confidential but not direct health information.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact to the employee (e.g., spouse, parent, sibling, friend). Used for emergency response prioritization and communication.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'Human-readable employee number or badge number assigned by the organization. Used for timekeeping, access control, payroll identification, and operational reference. May differ from system employee_id.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Food Safety Certification Expiry Date' ;
    rdfs:comment 'Date when the employee\'s food safety certification expires. Null if not applicable to role. Used for proactive recertification scheduling and F&B compliance management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foodSafetyCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Food Safety Certification Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee holds a current food safety certification (e.g., ServSafe, ISO 22000). Required for Food and Beverage department employees. Used for compliance with health department regulations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'Full-Time Equivalent percentage representing the employee\'s work commitment relative to a full-time position. 1.0 = 100% full-time, 0.5 = 50% part-time. Critical for workforce capacity planning and labor cost analysis.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number (e.g., Social Security Number in USA, National Insurance Number in UK). Used for tax reporting, payroll processing, and employment verification. Highly sensitive PII.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oracleHcmEmployeeCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Hcm Employee Code' ;
    rdfs:comment 'External employee identifier from Oracle HCM Cloud system. Used for integration and reconciliation between lakehouse and source HCM system. Critical for maintaining data lineage from system of record.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaTrainingCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Training Current Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee\'s required OSHA safety training is current and up-to-date. Used for workplace safety compliance, audit readiness, and training program management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaTrainingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Osha Training Expiry Date' ;
    rdfs:comment 'Date when the employee\'s current OSHA safety training certification expires. Used for proactive training renewal scheduling and compliance management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Compensation grade or band assigned to the employee\'s position. Used for salary administration, compensation benchmarking, and pay equity analysis. Business-confidential but not direct PII.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payType rdf:type rdf:Property ;
    rdfs:label 'Pay Type' ;
    rdfs:comment 'Classification of how the employee is compensated (hourly wages, salaried, commission-based, or contract). Critical for payroll processing, labor cost calculation, and USALI reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Standard Hours Per Week' ;
    rdfs:comment 'Standard number of hours the employee is scheduled to work per week based on their employment type. Used for FTE calculation, scheduling, and labor cost forecasting. Typically 40 for full-time, variable for part-time.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Code identifying the specific labor union to which the employee belongs, if applicable. Null for non-union employees. Used for contract administration and labor relations tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMembershipFlag rdf:type rdf:Property ;
    rdfs:label 'Union Membership Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee is a member of a labor union. Used for labor relations management, collective bargaining compliance, and union dues processing.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workAuthorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Expiry Date' ;
    rdfs:comment 'Date when the employee\'s work authorization expires (if applicable). Null for citizens and permanent residents. Used for proactive renewal tracking and compliance management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'Current status of the employee\'s legal authorization to work in the jurisdiction. Critical for compliance with immigration and employment laws. Used for I-9 compliance tracking in USA and equivalent requirements in other jurisdictions.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationType rdf:type rdf:Property ;
    rdfs:label 'Work Location Type' ;
    rdfs:comment 'Classification of where the employee primarily performs their work. Indicates whether the employee works on-property at a hotel/resort, remotely, in a hybrid arrangement, at corporate office, or across multiple properties.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Job Requisition Id' ;
    rdfs:comment 'Unique identifier for the job requisition record. Primary key for the talent acquisition lifecycle tracking.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJobEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Job Employee Id' ;
    rdfs:comment 'Reference to the employee who is the hiring manager responsible for the position and final candidate selection.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryJobApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Job Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved the requisition (typically department head, general manager, or HR director depending on approval hierarchy).' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backgroundCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Background Check Required Flag' ;
    rdfs:comment 'Indicates whether a background check is required for this position. Typically true for all guest-facing roles and positions with financial or security responsibilities.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the salary range (e.g., USD, EUR, GBP). Supports multi-country property operations.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationFrequency rdf:type rdf:Property ;
    rdfs:label 'Compensation Frequency' ;
    rdfs:comment 'Pay frequency for the position: hourly (most operational roles), annual (salaried management), monthly, or weekly.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugScreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Drug Screening Required Flag' ;
    rdfs:comment 'Indicates whether pre-employment drug screening is required. Common for safety-sensitive positions and jurisdictions where permitted by law.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eeoJobCategory rdf:type rdf:Property ;
    rdfs:label 'Eeo Job Category' ;
    rdfs:comment 'Equal Employment Opportunity Commission job category for regulatory reporting (e.g., Executive/Senior Level Officials and Managers, First/Mid-Level Officials and Managers, Professionals, Service Workers). Required for EEO-1 compliance reporting.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPostingFlag rdf:type rdf:Property ;
    rdfs:label 'External Posting Flag' ;
    rdfs:comment 'Indicates whether the requisition is posted to external job boards, career sites, and recruiting channels.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'Fair Labor Standards Act classification determining overtime eligibility: exempt (salaried, not eligible for overtime) or non-exempt (hourly, eligible for overtime). Critical for labor cost management and compliance.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountRequested rdf:type rdf:Property ;
    rdfs:label 'Headcount Requested' ;
    rdfs:comment 'Number of positions to be filled under this requisition. Typically 1 for individual roles, may be higher for bulk hiring (e.g., seasonal housekeeping staff).' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Posting Flag' ;
    rdfs:comment 'Indicates whether the requisition is posted internally for current employees before external candidates. Supports internal mobility and career development programs.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Detailed description of the role, responsibilities, qualifications, and expectations. Used for job postings and candidate communication.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumQualifications rdf:type rdf:Property ;
    rdfs:label 'Minimum Qualifications' ;
    rdfs:comment 'Required education, certifications, experience, and skills for the position (e.g., high school diploma, hospitality degree, PMS system experience, food handler certification).' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingEndDate rdf:type rdf:Property ;
    rdfs:label 'Posting End Date' ;
    rdfs:comment 'Date when the job posting will close and no longer accept new applications. May be extended if position remains unfilled.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingLocation rdf:type rdf:Property ;
    rdfs:label 'Posting Location' ;
    rdfs:comment 'Geographic location description for the job posting (city, state, country). Used for candidate search and location-based job board distribution.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStartDate rdf:type rdf:Property ;
    rdfs:label 'Posting Start Date' ;
    rdfs:comment 'Date when the job requisition was or will be posted to internal and external job boards and career sites.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredQualifications rdf:type rdf:Property ;
    rdfs:label 'Preferred Qualifications' ;
    rdfs:comment 'Desired but not mandatory qualifications that would make a candidate more competitive (e.g., bilingual, luxury hotel experience, revenue management certification).' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionClosedDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Closed Date' ;
    rdfs:comment 'Date when the requisition was closed (filled, cancelled, or otherwise completed). Used to calculate time-to-fill metrics.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionJustification rdf:type rdf:Property ;
    rdfs:label 'Requisition Justification' ;
    rdfs:comment 'Business rationale for the hiring request, including operational need, budget impact, and strategic alignment. Used for approval workflow and headcount planning.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Opened Date' ;
    rdfs:comment 'Date when the requisition was approved and moved to open status, marking the start of active recruiting.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salaryRangeMax rdf:type rdf:Property ;
    rdfs:label 'Salary Range Max' ;
    rdfs:comment 'Maximum annual salary or hourly rate for the position, aligned with compensation bands and market benchmarks.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMin rdf:type rdf:Property ;
    rdfs:label 'Salary Range Min' ;
    rdfs:comment 'Minimum annual salary or hourly rate for the position, aligned with compensation bands and market benchmarks.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired date for the new hire to begin employment. Critical for seasonal hiring and operational planning.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'Number of calendar days from requisition opened date to requisition closed date. Key talent acquisition performance metric tracked against industry benchmarks.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelRequirement rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement' ;
    rdfs:comment 'Expected travel frequency for the role: none (property-based), occasional (less than 25%), frequent (25-50%), extensive (over 50%). Relevant for regional managers, corporate roles, and multi-property positions.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Required' ;
    rdfs:comment 'Description of work authorization requirements for the position (e.g., must be authorized to work in the United States, visa sponsorship available, etc.). Critical for international hiring and compliance.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteCourseLearningCourseId rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Course Learning Course Id' ;
    rdfs:comment 'Reference to another learning course that must be completed before this course can be taken. Null if no prerequisite exists.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LearningCourse .

ind:assessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Required Flag' ;
    rdfs:comment 'Indicates whether learners must complete a graded assessment or examination to pass the course. True for courses with tests, false for attendance-only or participation-based courses.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Certificate Template Code' ;
    rdfs:comment 'Identifier for the certificate template used to generate completion certificates for this course. Links to document generation system. Null if course does not issue certificates.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Flag' ;
    rdfs:comment 'Indicates whether this course fulfills a regulatory or legal compliance requirement such as OSHA mandatory training, food safety certification, ADA training, or other jurisdiction-specific requirements.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentVersion rdf:type rdf:Property ;
    rdfs:label 'Content Version' ;
    rdfs:comment 'Version number of the course content. Incremented when course materials are updated to reflect regulatory changes, brand standard updates, or content improvements.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationCredits rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Credits' ;
    rdfs:comment 'Number of continuing education units or credits awarded upon course completion. Used for professional development tracking and license renewal requirements. Null if course does not award CEUs.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerLearner rdf:type rdf:Property ;
    rdfs:label 'Cost Per Learner' ;
    rdfs:comment 'Cost to deliver the course per individual learner. Includes instructor fees, materials, platform fees, and external vendor costs. Used for training budget planning and CPOR (Cost Per Occupied Room) labor component analysis.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCategory rdf:type rdf:Property ;
    rdfs:label 'Course Category' ;
    rdfs:comment 'Primary classification of the course type. Compliance courses are mandatory regulatory training, skills courses develop job-specific competencies, leadership courses develop management capabilities, brand standards ensure consistent guest experience, food safety covers ISO 22000 requirements, OSHA covers workplace safety, ADA covers accessibility compliance. [ENUM-REF-CANDIDATE: compliance|skills|leadership|brand_standards|food_safety|osha|ada — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseStatus rdf:type rdf:Property ;
    rdfs:label 'Course Status' ;
    rdfs:comment 'Current lifecycle status of the course. Active courses are available for enrollment, inactive courses are temporarily unavailable, under development courses are being created, retired courses are no longer offered, suspended courses are on hold pending review.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseTitle rdf:type rdf:Property ;
    rdfs:label 'Course Title' ;
    rdfs:comment 'Full name of the learning course as displayed to employees and managers.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'Indicates whether the course is mandatory for specific roles, optional for employee development, recommended by management, or required for professional certification.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the course in hours. Used for scheduling, labor planning, and compliance tracking. Supports OSHA 10-hour and 30-hour certification requirements.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentCapacity rdf:type rdf:Property ;
    rdfs:label 'Enrollment Capacity' ;
    rdfs:comment 'Maximum number of learners that can be enrolled in a single offering of the course. Relevant for instructor-led and virtual classroom courses. Null for unlimited capacity online courses.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastContentUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Content Update Date' ;
    rdfs:comment 'Date when the course content was last revised or updated. Critical for ensuring compliance training reflects current regulations.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Attempts' ;
    rdfs:comment 'Maximum number of attempts allowed for course completion or assessment. Null if unlimited attempts are permitted.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScore rdf:type rdf:Property ;
    rdfs:label 'Passing Score' ;
    rdfs:comment 'Minimum score percentage required to successfully complete the course. Null if course does not have a scored assessment.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Validity Period Days' ;
    rdfs:comment 'Number of days the course completion remains valid before recertification is required. Critical for compliance courses like food handler certification, OSHA training, and CPR certification. Null if course completion does not expire.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique identifier for the leave request record. Primary key.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualPlanId rdf:type rdf:Property ;
    rdfs:label 'Accrual Plan Id' ;
    rdfs:comment 'Identifier of the leave accrual plan governing this leave type for the employee, defining accrual rates, carryover rules, and maximum balances.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:primaryLeaveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Employee Id' ;
    rdfs:comment 'Identifier of the employee submitting the leave request.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Foreign key linking to workforce.schedule. Business justification: Leave requests impact published schedules and require coverage planning. This FK links absence management to scheduling, enabling coverage_status tracking (leave_request.coverage_status, coverage_empl' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:accrualPeriod rdf:type rdf:Property ;
    rdfs:label 'Accrual Period' ;
    rdfs:comment 'Time period for which the accrual balance is calculated, such as calendar year, fiscal year, or rolling 12 months.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Comments or notes provided by the approving manager regarding the approval or denial decision.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Balance As Of Date' ;
    rdfs:comment 'Date as of which the accrual balance figures are calculated in yyyy-MM-dd format.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carryoverHours rdf:type rdf:Property ;
    rdfs:label 'Carryover Hours' ;
    rdfs:comment 'Number of unused leave hours carried over from the previous accrual period, subject to plan carryover limits.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Certification Received Date' ;
    rdfs:comment 'Date when required medical certification or supporting documentation was received by HR in yyyy-MM-dd format.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Status of scheduling coverage arrangements for the employees absence: not required, pending, arranged, or confirmed.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Explanation provided by the approving manager for denying the leave request, such as staffing constraints, blackout period, or insufficient accrual balance.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Fmla Case Number' ;
    rdfs:comment 'Unique case identifier for tracking FMLA leave usage and compliance, assigned when FMLA eligibility is established.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursAccrued rdf:type rdf:Property ;
    rdfs:label 'Hours Accrued' ;
    rdfs:comment 'Total leave hours earned or accrued during the accrual period up to the request date.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursRequested rdf:type rdf:Property ;
    rdfs:label 'Hours Requested' ;
    rdfs:comment 'Number of leave hours being requested in this leave request, which will be deducted from the accrual balance if approved.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursTaken rdf:type rdf:Property ;
    rdfs:label 'Hours Taken' ;
    rdfs:comment 'Total leave hours used or taken during the accrual period prior to this request.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAdaAccommodation rdf:type rdf:Property ;
    rdfs:label 'Is Ada Accommodation' ;
    rdfs:comment 'Indicates whether this leave is granted as a reasonable accommodation under ADA (true) or not (false).' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFmlaQualifying rdf:type rdf:Property ;
    rdfs:label 'Is Fmla Qualifying' ;
    rdfs:comment 'Indicates whether this leave request qualifies for FMLA protection (true) or not (false), based on reason and employee eligibility.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIntermittent rdf:type rdf:Property ;
    rdfs:label 'Is Intermittent' ;
    rdfs:comment 'Indicates whether the leave is intermittent (true) or continuous (false). Intermittent leave is taken in separate blocks of time rather than one continuous period.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaid rdf:type rdf:Property ;
    rdfs:label 'Is Paid' ;
    rdfs:comment 'Indicates whether the leave is paid (true) or unpaid (false) based on leave type and accrual balance.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveSubtype rdf:type rdf:Property ;
    rdfs:label 'Leave Subtype' ;
    rdfs:comment 'Detailed classification within the leave type, such as continuous FMLA, intermittent FMLA, maternity, paternity, adoption leave, or COVID-19 sick leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Category of leave being requested: vacation, sick, FMLA (Family and Medical Leave Act), personal, bereavement, jury duty, military, unpaid, parental, or sabbatical. [ENUM-REF-CANDIDATE: vacation|sick|fmla|personal|bereavement|jury_duty|military|unpaid|parental|sabbatical — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openingBalanceHours rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Hours' ;
    rdfs:comment 'Leave accrual balance in hours at the start of the accrual period before this request.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Payroll Impact Amount' ;
    rdfs:comment 'Estimated financial impact on payroll for this leave request, including accrued vacation liability or unpaid leave deductions.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingBalanceHours rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance Hours' ;
    rdfs:comment 'Projected leave accrual balance in hours after this request is approved and hours are deducted.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresMedicalCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Medical Certification' ;
    rdfs:comment 'Indicates whether the leave request requires supporting medical documentation or certification (true) or not (false).' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDays rdf:type rdf:Property ;
    rdfs:label 'Total Days' ;
    rdfs:comment 'Total number of calendar days covered by the leave request, including weekends and holidays if applicable.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHours rdf:type rdf:Property ;
    rdfs:label 'Total Hours' ;
    rdfs:comment 'Total number of work hours covered by the leave request, used for accrual deduction and payroll calculations.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy. Enables multi-level organizational structure modeling (e.g., department within division).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:actualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Headcount' ;
    rdfs:comment 'Current number of active employees assigned to this organizational unit. Used to track variance against budgeted headcount.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Headcount' ;
    rdfs:comment 'Planned number of full-time equivalent (FTE) employees allocated to this organizational unit. Used for workforce planning and labor cost budgeting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full hierarchical path from root to this unit, typically represented as slash-separated IDs or codes (e.g., /CORP/ROOMS/FRONTDESK). Enables efficient hierarchy queries.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGuestFacing rdf:type rdf:Property ;
    rdfs:label 'Is Guest Facing' ;
    rdfs:comment 'Indicates whether this organizational unit has direct guest interaction (e.g., Front Desk, Concierge, F&B service) or is back-of-house (e.g., Housekeeping, Engineering). Used for service quality and NPS tracking.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCostPercentageTarget rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Percentage Target' ;
    rdfs:comment 'Target labor cost as percentage of revenue for this organizational unit. Key metric for GOP (Gross Operating Profit) management and USALI labor cost reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborProductivityStandard rdf:type rdf:Property ;
    rdfs:label 'Labor Productivity Standard' ;
    rdfs:comment 'Standard productivity measure for this organizational unit, expressed as units per labor hour (e.g., rooms cleaned per hour, covers served per hour, check-ins per hour). Used for optimal staffing calculations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Physical location code or building identifier where this organizational unit operates (e.g., Main Building, Tower A, Spa Building). Used for facility management and space allocation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitCode rdf:type rdf:Property ;
    rdfs:label 'Org Unit Code' ;
    rdfs:comment 'Short alphanumeric code identifying the organizational unit. Used in payroll, scheduling, and financial reporting systems. Typically 2-10 characters.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organizational unit\'s purpose, responsibilities, and scope of operations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitName rdf:type rdf:Property ;
    rdfs:label 'Org Unit Name' ;
    rdfs:comment 'Full business name of the organizational unit (e.g., Front Desk Operations, Housekeeping, Food and Beverage, Engineering, Sales and Marketing).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current operational status of the organizational unit. Indicates whether the unit is actively staffed and operational.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitType rdf:type rdf:Property ;
    rdfs:label 'Org Unit Type' ;
    rdfs:comment 'Classification of the organizational unit level in the hierarchy. Defines whether this is a division, department, team, cost center, or work group.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productivityTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Productivity Target Percentage' ;
    rdfs:comment 'Target productivity achievement percentage for this organizational unit. Typically 85-100%, representing expected efficiency relative to standard time.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productivityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Productivity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for labor productivity standard. Defines how productivity is measured for this organizational unit (e.g., rooms per hour for housekeeping, covers per hour for F&B).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Certification' ;
    rdfs:comment 'Indicates whether employees in this organizational unit require specific certifications or licenses (e.g., food safety for F&B, engineering licenses, lifeguard certification). Used for compliance tracking.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard shift pattern for this organizational unit. Defines typical scheduling model (e.g., 24x7 for front desk, AM/PM for housekeeping, business hours for sales).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTimePerUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Time Per Unit' ;
    rdfs:comment 'Standard time in minutes required to complete one unit of work (e.g., 30 minutes to clean one room, 15 minutes per banquet setup). Used for scheduling and labor planning.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usaliClassification rdf:type rdf:Property ;
    rdfs:label 'Usali Classification' ;
    rdfs:comment 'USALI department classification for financial reporting. Aligns organizational unit to standard hospitality accounting categories (Rooms, F&B, Spa, Engineering, Sales, Admin). [ENUM-REF-CANDIDATE: rooms|food_and_beverage|spa|golf|recreation|engineering|sales_marketing|admin_general|property_operations|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity responsible for payroll obligations and tax reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:calculatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculated Timestamp' ;
    rdfs:comment 'Date and time when payroll calculations were completed for this run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Total number of employees included in this payroll run.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Status' ;
    rdfs:comment 'Indicates whether payroll entries have been posted to the general ledger.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oraclePayrollRunCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Payroll Run Code' ;
    rdfs:comment 'External reference identifier from Oracle HCM Cloud payroll system for reconciliation and audit trail.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paid Timestamp' ;
    rdfs:comment 'Date and time when employee payments were disbursed for this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payDate rdf:type rdf:Property ;
    rdfs:label 'Pay Date' ;
    rdfs:comment 'Date on which employees receive payment for this payroll run.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Period End Date' ;
    rdfs:comment 'Last day of the payroll period covered by this run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Period Start Date' ;
    rdfs:comment 'First day of the payroll period covered by this run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollRunNumber rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Number' ;
    rdfs:comment 'Business identifier for the payroll run, typically formatted as YYYY-MM-PP where PP is the pay period sequence.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Status' ;
    rdfs:comment 'Current lifecycle status of the payroll run indicating its processing stage. [ENUM-REF-CANDIDATE: draft|in_progress|calculated|approved|posted|paid|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunType rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Type' ;
    rdfs:comment 'Classification of the payroll run indicating whether it is a regular scheduled run, off-cycle payment, bonus distribution, correction, or final payment.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPayrollRunCode rdf:type rdf:Property ;
    rdfs:label 'Sap Payroll Run Code' ;
    rdfs:comment 'External reference identifier from SAP S/4HANA HCM payroll system for reconciliation and audit trail.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBonusPay rdf:type rdf:Property ;
    rdfs:label 'Total Bonus Pay' ;
    rdfs:comment 'Sum of discretionary and non-discretionary bonuses paid to employees in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommissionPay rdf:type rdf:Property ;
    rdfs:label 'Total Commission Pay' ;
    rdfs:comment 'Sum of commission earnings for sales and revenue-generating roles (e.g., event sales, group sales) in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmployerTaxes rdf:type rdf:Property ;
    rdfs:label 'Total Employer Taxes' ;
    rdfs:comment 'Sum of employer-paid payroll taxes (employer FICA, FUTA, SUTA) for this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFederalTax rdf:type rdf:Property ;
    rdfs:label 'Total Federal Tax' ;
    rdfs:comment 'Sum of federal income tax withheld from all employees in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossPay rdf:type rdf:Property ;
    rdfs:label 'Total Gross Pay' ;
    rdfs:comment 'Sum of all gross earnings for all employees in this payroll run before any deductions.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLocalTax rdf:type rdf:Property ;
    rdfs:label 'Total Local Tax' ;
    rdfs:comment 'Sum of local or municipal income tax withheld from all employees in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMedicareTax rdf:type rdf:Property ;
    rdfs:label 'Total Medicare Tax' ;
    rdfs:comment 'Sum of Medicare tax withheld from all employees in this payroll run, including additional Medicare tax for high earners.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetPay rdf:type rdf:Property ;
    rdfs:label 'Total Net Pay' ;
    rdfs:comment 'Sum of net pay (take-home pay) for all employees in this payroll run after all taxes and deductions.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOvertimePay rdf:type rdf:Property ;
    rdfs:label 'Total Overtime Pay' ;
    rdfs:comment 'Sum of overtime earnings for all employees in this payroll run, typically at 1.5x or 2x regular rate.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPostTaxDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Post Tax Deductions' ;
    rdfs:comment 'Sum of all post-tax deductions (garnishments, union dues, Roth 401k) for all employees in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPreTaxDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Pre Tax Deductions' ;
    rdfs:comment 'Sum of all pre-tax deductions (401k, health insurance premiums, FSA contributions) for all employees in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRegularPay rdf:type rdf:Property ;
    rdfs:label 'Total Regular Pay' ;
    rdfs:comment 'Sum of regular hourly or salaried earnings for all employees in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalServiceCharge rdf:type rdf:Property ;
    rdfs:label 'Total Service Charge' ;
    rdfs:comment 'Sum of mandatory service charges distributed to employees in this payroll run, common in banquet and group events.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSocialSecurityTax rdf:type rdf:Property ;
    rdfs:label 'Total Social Security Tax' ;
    rdfs:comment 'Sum of Social Security (OASDI) tax withheld from all employees in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStateTax rdf:type rdf:Property ;
    rdfs:label 'Total State Tax' ;
    rdfs:comment 'Sum of state income tax withheld from all employees in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxWithholding rdf:type rdf:Property ;
    rdfs:label 'Total Tax Withholding' ;
    rdfs:comment 'Sum of all federal, state, and local income tax withholdings for all employees in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTipAllocation rdf:type rdf:Property ;
    rdfs:label 'Total Tip Allocation' ;
    rdfs:comment 'Sum of tip income allocated to tipped employees (servers, bartenders, bellhops) in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key for the performance review entity.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:developmentAreasSummary rdf:type rdf:Property ;
    rdfs:label 'Development Areas Summary' ;
    rdfs:comment 'Narrative summary of areas where the employee needs improvement or further development.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlanNotes rdf:type rdf:Property ;
    rdfs:label 'Development Plan Notes' ;
    rdfs:comment 'Detailed notes on the employee development plan, including recommended training, mentoring, or stretch assignments to support career growth.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Date' ;
    rdfs:comment 'The date when the employee acknowledged receipt and review of their performance evaluation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeComments rdf:type rdf:Property ;
    rdfs:label 'Employee Comments' ;
    rdfs:comment 'Comments provided by the employee in response to the performance review, including self-assessment and feedback on the review process.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalsMetCount rdf:type rdf:Property ;
    rdfs:label 'Goals Met Count' ;
    rdfs:comment 'The number of performance goals or objectives that the employee successfully met during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalsTotalCount rdf:type rdf:Property ;
    rdfs:label 'Goals Total Count' ;
    rdfs:comment 'The total number of performance goals or objectives assigned to the employee for the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guestServiceRating rdf:type rdf:Property ;
    rdfs:label 'Guest Service Rating' ;
    rdfs:comment 'Competency rating for guest service excellence, a critical competency in hospitality operations. Assesses employee\'s ability to deliver exceptional guest experiences.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadershipRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Rating' ;
    rdfs:comment 'Competency rating for leadership and people management skills. Applicable to supervisory and management roles; marked not-applicable for individual contributors.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIncreaseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee is eligible for a merit-based salary increase based on this performance review outcome.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score representing the overall performance rating, typically on a scale (e.g., 1.00 to 5.00). Enables quantitative analysis and compensation modeling.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceImprovementPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Improvement Plan Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee has been placed on a formal Performance Improvement Plan due to unsatisfactory performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommended Flag' ;
    rdfs:comment 'Boolean indicator of whether the reviewer recommends the employee for promotion based on performance and readiness.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reliabilityRating rdf:type rdf:Property ;
    rdfs:label 'Reliability Rating' ;
    rdfs:comment 'Competency rating for reliability, punctuality, and attendance. Critical for 24/7 hospitality operations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'The date when the reviewer completed and submitted the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'The target date by which the performance review should be completed, based on organizational policy and review cycle.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The end date of the performance evaluation period being assessed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'The start date of the performance evaluation period being assessed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current workflow status of the performance review (pending initiation, in-progress, completed by reviewer, acknowledged by employee, or cancelled).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Review Template Code' ;
    rdfs:comment 'The code identifying the performance review template or form used, which may vary by job level, department, or review type.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'The type or category of performance review being conducted (annual, mid-year, probationary, 90-day, project-based, or ad-hoc).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Additional comments and observations from the reviewer providing context and detail beyond the structured ratings.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Narrative summary of the employee\'s key strengths and positive contributions during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanningFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee has been identified for succession planning and leadership pipeline development.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teamworkRating rdf:type rdf:Property ;
    rdfs:label 'Teamwork Rating' ;
    rdfs:comment 'Competency rating for teamwork and collaboration with colleagues across departments and shifts.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSkillsRating rdf:type rdf:Property ;
    rdfs:label 'Technical Skills Rating' ;
    rdfs:comment 'Competency rating for job-specific technical skills (e.g., PMS proficiency for front desk, culinary skills for F&B, housekeeping standards).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Reference to the supervisory position to which this position reports in the organizational hierarchy. Enables organizational chart construction.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:adaAccommodationRequired rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Required' ;
    rdfs:comment 'Indicates whether this position has been identified as requiring reasonable accommodation under ADA compliance guidelines.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetedAnnualSalary rdf:type rdf:Property ;
    rdfs:label 'Budgeted Annual Salary' ;
    rdfs:comment 'Planned annual base salary for this position as defined in the labor budget. Used for CPOR (Cost Per Occupied Room) labor cost calculations.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Full-time equivalent allocation for this position expressed as a decimal (1.00 = full-time, 0.50 = half-time). Used for headcount planning and labor cost budgeting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBudgeted rdf:type rdf:Property ;
    rdfs:label 'Is Budgeted' ;
    rdfs:comment 'Indicates whether this position is included in the approved annual labor budget and headcount plan.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExempt rdf:type rdf:Property ;
    rdfs:label 'Is Exempt' ;
    rdfs:comment 'Indicates whether this position is exempt from overtime pay requirements under the Fair Labor Standards Act (FLSA). Used for payroll and labor cost compliance.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSupervisory rdf:type rdf:Property ;
    rdfs:label 'Is Supervisory' ;
    rdfs:comment 'Indicates whether this position has direct supervisory or management responsibilities over other employees.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnion rdf:type rdf:Property ;
    rdfs:label 'Is Union' ;
    rdfs:comment 'Indicates whether this position is covered by a collective bargaining agreement or union contract.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'Username or identifier of the system user who most recently modified this position record.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum educational qualification required for this position as defined in the job profile.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Minimum Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for this position.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalRequirements rdf:type rdf:Property ;
    rdfs:label 'Physical Requirements' ;
    rdfs:comment 'Description of physical demands and working conditions for this position (e.g., standing for extended periods, lifting up to 50 lbs, exposure to kitchen heat). Used for ADA compliance and OSHA safety planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the position within the enterprise position catalog. Used for workforce planning and budgeting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed narrative description of the position\'s responsibilities, duties, and scope. Used for job postings and talent acquisition.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position. Active = authorized and available for assignment; Frozen = temporarily unavailable; Eliminated = removed from headcount plan; Proposed = pending approval.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Classification of the position based on employment duration and nature. Regular = permanent; Seasonal = recurring high-demand periods; Temporary = fixed-term; Contract = third-party; On-Call = as-needed.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of mandatory certifications, licenses, or credentials required for this position (e.g., ServSafe Food Handler, CPR/First Aid, Certified Revenue Management Executive). Used for compliance tracking per OSHA and ADA requirements.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftEligibility rdf:type rdf:Property ;
    rdfs:label 'Shift Eligibility' ;
    rdfs:comment 'Shift pattern or time-of-day eligibility for this position. Used for scheduling and labor management in 24/7 hotel operations.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Schedule Approved By User Employee Id' ;
    rdfs:comment 'Reference to the senior manager or director who approved this schedule for finalization and payroll processing.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scheduleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Schedule Employee Id' ;
    rdfs:comment 'Reference to the manager or scheduler who initially created this schedule.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:schedulePublishedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Schedule Published By User Employee Id' ;
    rdfs:comment 'Reference to the manager who published this schedule, making it visible to employees.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shiftTemplateId rdf:type rdf:Property ;
    rdfs:label 'Shift Template Id' ;
    rdfs:comment 'Reference to the reusable shift template used as the basis for this schedule. Shift templates define standard shift patterns (e.g., morning, evening, overnight) with default start/end times and break rules.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftTemplate .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'Actual total labor cost incurred during this schedule period, including wages, overtime premiums, and shift differentials. Sourced from payroll system for variance analysis.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cporLabor rdf:type rdf:Property ;
    rdfs:label 'Cpor Labor' ;
    rdfs:comment 'Estimated labor cost per occupied room for this schedule period, calculated as estimated_labor_cost divided by forecasted occupied rooms. Used for labor efficiency benchmarking.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Forecasted total labor cost for this schedule period, calculated from scheduled hours and average wage rates. Used for budgeting and GOPPAR (Gross Operating Profit Per Available Room) planning.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finalized Timestamp' ;
    rdfs:comment 'Date and time when this schedule was locked for payroll processing. After finalization, no further changes are permitted without creating a schedule adjustment record.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastOccupancyRate rdf:type rdf:Property ;
    rdfs:label 'Forecast Occupancy Rate' ;
    rdfs:comment 'Forecasted hotel occupancy rate (percentage) for this schedule period, used to align labor scheduling with anticipated guest volume. Sourced from Revenue Management System (RMS).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastRevpar rdf:type rdf:Property ;
    rdfs:label 'Forecast Revpar' ;
    rdfs:comment 'Forecasted Revenue Per Available Room for this schedule period, calculated as forecast_occupancy_rate multiplied by forecast_adr. Used for labor cost as percentage of revenue planning.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOvertimeApproved rdf:type rdf:Property ;
    rdfs:label 'Is Overtime Approved' ;
    rdfs:comment 'Indicates whether overtime hours are pre-approved for this schedule period. True if overtime is authorized; false if all hours must remain within standard limits.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCostPercentage rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Percentage' ;
    rdfs:comment 'Estimated labor cost as a percentage of forecasted revenue for this schedule period. Key metric for USALI labor cost reporting and GOP analysis.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborVarianceHours rdf:type rdf:Property ;
    rdfs:label 'Labor Variance Hours' ;
    rdfs:comment 'Difference between total_actual_hours and total_scheduled_hours. Positive values indicate overtime or unplanned coverage; negative values indicate understaffing or no-shows.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Human-readable business identifier for the schedule, typically formatted as property-department-period (e.g., HTL001-HSKP-2024W15).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the schedule based on operational context: regular (standard weekly/biweekly), seasonal (high/low season adjustments), event (MICE or special events), emergency (unplanned coverage), training (learning and development sessions).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalActualHours rdf:type rdf:Property ;
    rdfs:label 'Total Actual Hours' ;
    rdfs:comment 'Sum of actual hours worked by all employees during this schedule period, captured from time and attendance systems. Used for labor variance reporting (actual vs. scheduled).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalScheduledFte rdf:type rdf:Property ;
    rdfs:label 'Total Scheduled Fte' ;
    rdfs:comment 'Full-time equivalent headcount for this schedule period, calculated as total_scheduled_hours divided by standard full-time hours (typically 40 hours per week). Used for labor productivity analysis and GOP (Gross Operating Profit) reporting.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Center Id' ;
    rdfs:comment 'Reference to the cost center where labor hours for this shift template are charged. Used for USALI departmental labor cost reporting and CPOR (Cost Per Occupied Room) calculations.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:primaryShiftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shift Employee Id' ;
    rdfs:comment 'Reference to the user (typically HR manager or department head) who created this shift template. Used for accountability and audit purposes.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:consecutiveDaysLimit rdf:type rdf:Property ;
    rdfs:label 'Consecutive Days Limit' ;
    rdfs:comment 'Maximum number of consecutive days an employee can be scheduled for this shift template before a mandatory rest day, per labor regulations and fatigue management policies.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holidayShiftFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Shift Flag' ;
    rdfs:comment 'Indicates whether this shift template is designated for holiday scheduling, which typically carries premium pay rates (True/False).' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumStaffingLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Staffing Level' ;
    rdfs:comment 'Maximum number of employees that can be scheduled for this shift pattern based on operational capacity and labor budget constraints.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mealAllowanceEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Allowance Eligible Flag' ;
    rdfs:comment 'Indicates whether employees working this shift are eligible for complimentary or subsidized meals as part of compensation (True/False).' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumStaffingLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Staffing Level' ;
    rdfs:comment 'Minimum number of employees required to work this shift pattern to meet operational standards and guest service levels (e.g., 2 front desk agents, 5 housekeepers).' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paidBreakMinutes rdf:type rdf:Property ;
    rdfs:label 'Paid Break Minutes' ;
    rdfs:comment 'Portion of break time that is compensated (e.g., 15-minute paid rest breaks). Used to calculate net paid hours.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paidHours rdf:type rdf:Property ;
    rdfs:label 'Paid Hours' ;
    rdfs:comment 'Net paid hours for the shift, excluding unpaid breaks (e.g., 7.50 for an 8-hour shift with 30-minute unpaid lunch). Used for payroll and labor cost calculations.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Rest Hours Required' ;
    rdfs:comment 'Minimum number of hours required between the end of this shift and the start of the next shift for the same employee, per labor regulations.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rotationPattern rdf:type rdf:Property ;
    rdfs:label 'Rotation Pattern' ;
    rdfs:comment 'Describes how this shift template fits into a rotation schedule (e.g., \'5-on-2-off\', \'4-on-3-off\', \'rotating weekends\'). Used for fair scheduling and work-life balance.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalApplicability rdf:type rdf:Property ;
    rdfs:label 'Seasonal Applicability' ;
    rdfs:comment 'Defines when this shift template is active based on hotel seasonality patterns. Year-round templates apply continuously; seasonal templates apply during high/low demand periods.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDifferentialRate rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Rate' ;
    rdfs:comment 'Additional hourly pay rate or percentage premium applied to this shift (e.g., night shift differential, weekend premium). Used for labor cost calculations.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDurationHours rdf:type rdf:Property ;
    rdfs:label 'Shift Duration Hours' ;
    rdfs:comment 'Total duration of the shift in hours, including break time (e.g., 8.00, 8.50, 12.00). Used for labor cost calculations and CPOR (Cost Per Occupied Room) reporting.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftTemplateStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Template Status' ;
    rdfs:comment 'Current lifecycle status of the shift template. Active templates are available for scheduling; Draft templates are under review; Inactive/Archived templates are no longer used.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Skill Requirement Level' ;
    rdfs:comment 'Minimum skill or experience level required for employees assigned to this shift template (e.g., entry-level housekeepers vs. expert front desk supervisors).' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Short alphanumeric code for the shift template used in scheduling systems and reports (e.g., \'FD-AM\', \'HK-PM\', \'FB-SPLIT\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Business-friendly name for the shift template (e.g., \'Front Desk Morning\', \'Housekeeping Evening\', \'F&B Split Shift\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationAllowanceEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Transportation Allowance Eligible Flag' ;
    rdfs:comment 'Indicates whether employees working this shift (especially late-night or early-morning shifts) are eligible for transportation reimbursement or shuttle service (True/False).' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uniformCode rdf:type rdf:Property ;
    rdfs:label 'Uniform Code' ;
    rdfs:comment 'Code identifying the required uniform or dress code for this shift template (e.g., \'FD-FORMAL\', \'HK-STANDARD\', \'FB-BANQUET\'). Links to uniform inventory and standards.' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weekendShiftFlag rdf:type rdf:Property ;
    rdfs:label 'Weekend Shift Flag' ;
    rdfs:comment 'Indicates whether this shift template is designated for weekend scheduling, which may carry premium pay or differential rates (True/False).' ;
    rdfs:domain ind:ShiftTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique identifier for the time entry record. Primary key for the time entry entity.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollPeriodId rdf:type rdf:Property ;
    rdfs:label 'Payroll Period Id' ;
    rdfs:comment 'Identifier of the payroll period to which this time entry is assigned. Used to group time entries for payroll processing in SAP S/4HANA HCM.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollPeriod .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Identifier of the employee who recorded this time entry. Links to the employee master record in Oracle HCM Cloud or SAP S/4HANA HCM.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTimeEditedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Time Edited By Employee Id' ;
    rdfs:comment 'Identifier of the user who edited or adjusted the time entry. Nullable if never edited.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'The precise date and time when the employee clocked in or started their shift. Captured from time clock, mobile app, or manager entry.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock Out Timestamp' ;
    rdfs:comment 'The precise date and time when the employee clocked out or ended their shift. Nullable for open shifts not yet completed.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Device Identifier' ;
    rdfs:comment 'Unique identifier of the device or time clock used to record the time entry. Used for audit trail and fraud prevention.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Double Time Hours' ;
    rdfs:comment 'Number of hours worked that qualify for double-time pay, typically for work on holidays or beyond a certain daily threshold in some jurisdictions.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:editedFlag rdf:type rdf:Property ;
    rdfs:label 'Edited Flag' ;
    rdfs:comment 'Indicates whether the time entry was manually edited or adjusted after initial capture. True if edited, False if original entry.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:editedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edited Timestamp' ;
    rdfs:comment 'Date and time when the time entry was last edited. Nullable if never edited.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date on which the work was performed. Used for daily labor reporting and payroll period assignment.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entrySource rdf:type rdf:Property ;
    rdfs:label 'Entry Source' ;
    rdfs:comment 'The system or method through which the time entry was captured. Supports audit trail and data quality analysis. [ENUM-REF-CANDIDATE: time_clock|mobile_app|web_portal|manager_entry|biometric_scanner|telephony|kiosk — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code indicating any time entry exception or anomaly (e.g., missed punch, late clock-in, early departure, unauthorized overtime). Used for compliance monitoring and manager review.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'Latitude coordinate where the clock-in or clock-out occurred, captured from mobile app entries. Used for location verification and compliance with remote work policies.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'Longitude coordinate where the clock-in or clock-out occurred, captured from mobile app entries. Used for location verification and compliance with remote work policies.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total labor cost for this time entry, calculated as hours worked multiplied by applicable pay rates including overtime premiums. Used for USALI labor cost reporting and CPOR calculation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidBreakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Paid Break Duration Minutes' ;
    rdfs:comment 'Total duration of paid breaks or rest periods during the shift, measured in minutes. Included in total hours worked for payroll calculation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed Flag' ;
    rdfs:comment 'Indicates whether this time entry has been processed in a payroll run. True if processed, False if pending.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Number of hours worked at the regular pay rate, typically up to 40 hours per week or 8 hours per day depending on jurisdiction. Used for payroll calculation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialCode rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Code' ;
    rdfs:comment 'Code indicating any shift differential pay applicable to this time entry (e.g., night shift, weekend shift). Used for premium pay calculation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tipsReportedAmount rdf:type rdf:Property ;
    rdfs:label 'Tips Reported Amount' ;
    rdfs:comment 'Total amount of tips reported by the employee for this time entry. Relevant for F&B and guest-facing roles. Used for payroll tax calculation and FLSA tip credit compliance.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Total Hours Worked' ;
    rdfs:comment 'Total number of hours worked during this time entry, calculated as the difference between clock-out and clock-in minus break duration. Used for payroll processing and labor hour reporting per USALI standards.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryWorkforceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Employee Id' ;
    rdfs:comment 'Identifier of the employee involved in the safety incident.' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'Specific body part or parts injured in the incident (e.g., lower back, right hand, left knee, head).' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Date' ;
    rdfs:comment 'Date when corrective actions were completed and implemented.' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOnRestrictedDuty rdf:type rdf:Property ;
    rdfs:label 'Days On Restricted Duty' ;
    rdfs:comment 'Number of calendar days the employee was on job transfer or restricted work activity due to the incident.' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Business-assigned unique incident reference number for tracking and reporting purposes.' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalTreatmentFacility rdf:type rdf:Property ;
    rdfs:label 'Medical Treatment Facility' ;
    rdfs:comment 'Name and location of the medical facility where the employee received treatment.' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osha300LogEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Osha 300 Log Entry Number' ;
    rdfs:comment 'Reference number assigned to this incident in the OSHA 300 log if recordable.' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianName rdf:type rdf:Property ;
    rdfs:label 'Physician Name' ;
    rdfs:comment 'Name of the physician or healthcare provider who treated the employee.' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyCaseFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Case Flag' ;
    rdfs:comment 'Indicates whether the incident qualifies as a privacy case under OSHA regulations (e.g., mental health, sexual assault).' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the person who reported the incident (employee, supervisor, witness).' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the incident was formally reported to management or human resources.' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Date when the employee returned to full or modified work duties following the incident.' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workersCompensationClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Workers Compensation Claim Number' ;
    rdfs:comment 'Claim number assigned by the workers compensation insurance carrier for this incident.' ;
    rdfs:domain ind:WorkforceSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporatePropertyContractId rdf:type rdf:Property ;
    rdfs:label 'Corporate Property Contract Id' ;
    rdfs:comment 'Primary key for the corporate_property_contract association' ;
    rdfs:domain ind:CorporatePropertyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPickupReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Pickup Review Date' ;
    rdfs:comment 'Date of the most recent pickup review meeting for this property-specific contract. Revenue management teams review actual vs. target room nights quarterly or monthly per property.' ;
    rdfs:domain ind:CorporatePropertyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:propertyAccountManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Property Account Manager Email' ;
    rdfs:comment 'Email of the property-level account manager. Property-level contacts manage day-to-day contract execution and pickup tracking.' ;
    rdfs:domain ind:CorporatePropertyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyAccountManagerName rdf:type rdf:Property ;
    rdfs:label 'Property Account Manager Name' ;
    rdfs:comment 'Name of the property-level sales manager or DOS responsible for managing this corporate account relationship at this specific property.' ;
    rdfs:domain ind:CorporatePropertyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Procurement Enrollment Id' ;
    rdfs:comment 'Primary key for procurement_enrollment' ;
    rdfs:domain ind:ProcurementEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'Name of the primary beneficiary designated for this enrollment (applicable for life insurance and similar plans). Captured from detection phase relationship data.' ;
    rdfs:domain ind:ProcurementEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Number of dependents covered under this enrollment. Captured from detection phase relationship data.' ;
    rdfs:domain ind:ProcurementEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentCode rdf:type rdf:Property ;
    rdfs:label 'Enrollment Code' ;
    rdfs:comment 'Unique identifier for this enrollment record. Primary key for the enrollment association.' ;
    rdfs:domain ind:ProcurementEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifeEventDate rdf:type rdf:Property ;
    rdfs:label 'Life Event Date' ;
    rdfs:comment 'Date of the qualifying life event. Null if not a life event enrollment.' ;
    rdfs:domain ind:ProcurementEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifeEventType rdf:type rdf:Property ;
    rdfs:label 'Life Event Type' ;
    rdfs:comment 'Type of qualifying life event that allowed mid-year enrollment change (marriage, birth, adoption, loss of other coverage). Null if not a life event enrollment.' ;
    rdfs:domain ind:ProcurementEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oracleHcmEnrollmentCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Hcm Enrollment Code' ;
    rdfs:comment 'External enrollment identifier from Oracle HCM Cloud Benefits module. Used for integration and reconciliation.' ;
    rdfs:domain ind:ProcurementEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Procurement Enrollment Date' ;
    rdfs:comment 'Date when the employee elected or enrolled in this benefit plan. Captured from detection phase relationship data.' ;
    rdfs:domain ind:ProcurementEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procurementEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Procurement Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of this enrollment record (pending, active, terminated, waived). Captured from detection phase relationship data.' ;
    rdfs:domain ind:ProcurementEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivedFlag rdf:type rdf:Property ;
    rdfs:label 'Waived Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee explicitly waived this benefit plan. Captured from detection phase relationship data.' ;
    rdfs:domain ind:ProcurementEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupFunctionSpaceBookingId rdf:type rdf:Property ;
    rdfs:label 'Group Function Space Booking Id' ;
    rdfs:comment 'Unique surrogate identifier for this group function space booking record. Primary key.' ;
    rdfs:domain ind:GroupFunctionSpaceBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cateringMinimumMet rdf:type rdf:Property ;
    rdfs:label 'Catering Minimum Met' ;
    rdfs:comment 'Indicates whether the contractual minimum catering spend for this meeting space was met by the group function. Null if no minimum applies.' ;
    rdfs:domain ind:GroupFunctionSpaceBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Event End Datetime' ;
    rdfs:comment 'Scheduled end date and time for the group function or event in this meeting space. Used for space turnover planning and billing.' ;
    rdfs:domain ind:GroupFunctionSpaceBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Event Start Datetime' ;
    rdfs:comment 'Scheduled start date and time for the group function or event in this meeting space. Critical for space scheduling and setup coordination.' ;
    rdfs:domain ind:GroupFunctionSpaceBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rentalAmount rdf:type rdf:Property ;
    rdfs:label 'Rental Amount' ;
    rdfs:comment 'Meeting space rental charge for this specific function booking. May vary based on duration, setup complexity, and negotiated group rates.' ;
    rdfs:domain ind:GroupFunctionSpaceBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupType rdf:type rdf:Property ;
    rdfs:label 'Setup Type' ;
    rdfs:comment 'Room setup configuration requested for this specific group function (theater, classroom, banquet, reception, u-shape, hollow square, boardroom, custom). Determines labor requirements and capacity.' ;
    rdfs:domain ind:GroupFunctionSpaceBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialSetupNotes rdf:type rdf:Property ;
    rdfs:label 'Special Setup Notes' ;
    rdfs:comment 'Free-text notes capturing special setup instructions, décor requirements, accessibility needs, or other function-specific details for operations and banquet teams.' ;
    rdfs:domain ind:GroupFunctionSpaceBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAgreementId rdf:type rdf:Property ;
    rdfs:label 'Vendor Agreement Id' ;
    rdfs:comment 'Unique identifier for this property-vendor agreement record. Primary key.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localContactEmail rdf:type rdf:Property ;
    rdfs:label 'Local Contact Email' ;
    rdfs:comment 'The email address for the local vendor representative servicing this property. Used for order confirmations, delivery notifications, and operational communications.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localContactName rdf:type rdf:Property ;
    rdfs:label 'Local Contact Name' ;
    rdfs:comment 'The name of the vendor representative assigned to service this specific property. May differ from the vendors primary contact in the vendor master record.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localContactPhone rdf:type rdf:Property ;
    rdfs:label 'Local Contact Phone' ;
    rdfs:comment 'The direct phone number for the local vendor representative servicing this property. Used for urgent order inquiries, delivery coordination, and issue escalation.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'The minimum order value required by this vendor for deliveries to this property. Used to enforce ordering thresholds and optimize procurement batching.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsOverride rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Override' ;
    rdfs:comment 'Property-specific payment terms that override the vendors standard payment terms. Examples: Net 30, Net 45, 2/10 Net 30. Null if standard vendor payment terms apply.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorTier rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Tier' ;
    rdfs:comment 'The vendor preference tier assigned to this vendor for this specific property. Indicates procurement priority and influences ordering workflows. Values: Preferred, Standard, Approved, Conditional.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertySpecificDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Property Specific Discount Pct' ;
    rdfs:comment 'The negotiated discount percentage that this vendor provides to this specific property, which may differ from corporate-level or other property-level agreements. Used for invoice validation and cost analysis.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'The date on which this property-vendor relationship ended or is scheduled to end. Null for active relationships. Used for historical analysis and vendor transition planning.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'The date on which this property began procuring from this vendor under the current agreement terms. Used for relationship tenure analysis and contract renewal planning.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratePlanRoomTypeAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Room Type Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each rate plan room type assignment record. Primary key for the association.' ;
    rdfs:domain ind:RatePlanRoomTypeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomTypeVendorSupplyId rdf:type rdf:Property ;
    rdfs:label 'Room Type Vendor Supply Id' ;
    rdfs:comment 'Unique identifier for this room type vendor supply relationship. Primary key.' ;
    rdfs:domain ind:RoomTypeVendorSupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Date of the most recent purchase order placed with this vendor for this room type category. Used for vendor activity tracking and relationship health monitoring.' ;
    rdfs:domain ind:RoomTypeVendorSupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyCategory rdf:type rdf:Property ;
    rdfs:label 'Supply Category' ;
    rdfs:comment 'Category of goods or services this vendor provides for this room type. Examples: FF&E (furniture, fixtures, equipment), Amenities, Housekeeping Supplies, Linens, Technology.' ;
    rdfs:domain ind:RoomTypeVendorSupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programTreatmentId rdf:type rdf:Property ;
    rdfs:label 'Program Treatment Id' ;
    rdfs:comment 'Unique identifier for this program-treatment inclusion record. Primary key.' ;
    rdfs:domain ind:ProgramTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayNumber rdf:type rdf:Property ;
    rdfs:label 'Day Number' ;
    rdfs:comment 'The day within the multi-day wellness program when this treatment is scheduled (e.g., Day 1, Day 3). Used for program sequencing and guest itinerary generation.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyPerWeek rdf:type rdf:Property ;
    rdfs:label 'Frequency Per Week' ;
    rdfs:comment 'Number of times this treatment is delivered per week within the program for programs spanning multiple weeks. Used for recurring wellness programs.' ;
    rdfs:domain ind:ProgramTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includedTreatmentsList rdf:type rdf:Property ;
    rdfs:label 'Included Treatments List' ;
    rdfs:comment 'Comma-separated list of treatment codes or names included in the wellness program package. References spa treatment catalog for detailed service descriptions. [Moved from wellness_program: This STRING field currently stores a comma-separated list of treatments in wellness_program. This denormalized representation should be replaced by the structured program_treatment association, which allows proper relational querying, scheduling, and therapeutic sequencing with granular attributes per treatment inclusion.]' ;
    rdfs:domain ind:ProgramTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionalFlag rdf:type rdf:Property ;
    rdfs:label 'Optional Flag' ;
    rdfs:comment 'Indicates whether this treatment is mandatory or optional within the program. Optional treatments allow guest customization while maintaining program integrity.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preTreatmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Pre Treatment Requirements' ;
    rdfs:comment 'Specific preparation or prerequisites required before this treatment within the program context (e.g., \'fasting 2 hours\', \'hydration protocol\', \'prior consultation\'). Used for guest communication and compliance.' ;
    rdfs:domain ind:ProgramTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceWithinDay rdf:type rdf:Property ;
    rdfs:label 'Sequence Within Day' ;
    rdfs:comment 'The order in which this treatment occurs within the specified day when multiple treatments are scheduled (e.g., 1=morning, 2=afternoon). Used for scheduling and therapist allocation.' ;
    rdfs:domain ind:ProgramTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:therapeuticGoal rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Goal' ;
    rdfs:comment 'The specific therapeutic objective this treatment serves within the overall program (e.g., \'deep tissue release\', \'stress reduction\', \'detoxification support\'). Used for outcome tracking and medical supervision.' ;
    rdfs:domain ind:ProgramTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Treatment Duration Minutes' ;
    rdfs:comment 'Duration in minutes for this treatment within the program context. May differ from the standard treatment duration to accommodate program pacing and therapeutic goals.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignTreatmentPromotionId rdf:type rdf:Property ;
    rdfs:label 'Campaign Treatment Promotion Id' ;
    rdfs:comment 'Unique identifier for this campaign-treatment promotional relationship. Primary key.' ;
    rdfs:domain ind:CampaignTreatmentPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignEndDate rdf:type rdf:Property ;
    rdfs:label 'Campaign End Date' ;
    rdfs:comment 'Date when the promotional pricing for this treatment expires within this campaign. May differ from the overall campaign end date if treatments are phased. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignStartDate rdf:type rdf:Property ;
    rdfs:label 'Campaign Start Date' ;
    rdfs:comment 'Date when this treatment becomes available at the promotional price within this campaign. May differ from the overall campaign start date if treatments are phased. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:featuredPosition rdf:type rdf:Property ;
    rdfs:label 'Featured Position' ;
    rdfs:comment 'Display order or prominence ranking for this treatment within the campaign (e.g., 1 for hero treatment, 2 for secondary feature). Used for email layout, landing page design, and promotional material sequencing. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CampaignTreatmentPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Campaign-specific promotional code that guests use to receive the promotional price for this treatment. Enables tracking and attribution of bookings to this campaign-treatment combination.' ;
    rdfs:domain ind:CampaignTreatmentPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalPrice rdf:type rdf:Property ;
    rdfs:label 'Promotional Price' ;
    rdfs:comment 'Campaign-specific promotional price for this treatment, overriding the standard recommended retail price during the campaign period. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CampaignTreatmentPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueGenerated rdf:type rdf:Property ;
    rdfs:label 'Revenue Generated' ;
    rdfs:comment 'Total revenue generated from bookings of this treatment attributed to this campaign. Performance metric for ROI analysis and campaign optimization. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CampaignTreatmentPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fnbSupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Fnb Supply Agreement Id' ;
    rdfs:comment 'Primary key for fnb_supply_agreement' ;
    rdfs:domain ind:FnbSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Id' ;
    rdfs:comment 'Unique identifier for this supply agreement record. Primary key.' ;
    rdfs:domain ind:FnbSupplyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementSupplyAgreement .

ind:agreementEndDate rdf:type rdf:Property ;
    rdfs:label 'Agreement End Date' ;
    rdfs:comment 'Date when this supply agreement expires or was terminated. Null for ongoing agreements. Used for contract renewal planning and vendor relationship lifecycle management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Start Date' ;
    rdfs:comment 'Date when this supply agreement became effective. Used for contract management and historical tracking of vendor-item relationships.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:propertySpaceAllocationId rdf:type rdf:Property ;
    rdfs:label 'Property Space Allocation Id' ;
    rdfs:comment 'Primary key for property_space_allocation' ;
    rdfs:domain ind:PropertySpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spaceAllocationId rdf:type rdf:Property ;
    rdfs:label 'Space Allocation Id' ;
    rdfs:comment 'Unique identifier for this space allocation record. Primary key.' ;
    rdfs:domain ind:PropertySpaceAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EventSpaceAllocation .

ind:allocationCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Created Timestamp' ;
    rdfs:comment 'Timestamp when this space allocation was created in the system. Used for audit trail and booking history.' ;
    rdfs:domain ind:PropertySpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Modified Timestamp' ;
    rdfs:comment 'Timestamp when this space allocation was last modified. Tracks changes to timing, setup, or status.' ;
    rdfs:domain ind:PropertySpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rentalCharge rdf:type rdf:Property ;
    rdfs:label 'Rental Charge' ;
    rdfs:comment 'The rental fee charged for this specific space allocation. Calculated based on space rental_rate_tier, duration, and negotiated event terms. Each allocation may have different charges.' ;
    rdfs:domain ind:PropertySpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagePurchaseId rdf:type rdf:Property ;
    rdfs:label 'Package Purchase Id' ;
    rdfs:comment 'Unique identifier for this package purchase transaction. Primary key.' ;
    rdfs:domain ind:PackagePurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseChannel rdf:type rdf:Property ;
    rdfs:label 'Purchase Channel' ;
    rdfs:comment 'Channel through which the member purchased this spa package. Used for channel attribution and member behavior analysis.' ;
    rdfs:domain ind:PackagePurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasePrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Price' ;
    rdfs:comment 'Actual price paid by the member for this package purchase. May differ from rack rate due to promotions, member discounts, or dynamic pricing.' ;
    rdfs:domain ind:PackagePurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sessionsIncluded rdf:type rdf:Property ;
    rdfs:label 'Sessions Included' ;
    rdfs:comment 'Total number of spa sessions or treatments included in this package purchase. Defines the entitlement quantity.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionsUsed rdf:type rdf:Property ;
    rdfs:label 'Sessions Used' ;
    rdfs:comment 'Number of sessions or treatments from this package that the member has already consumed. Used to track remaining entitlement.' ;
    rdfs:domain ind:PackagePurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guestEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Guest Enrollment Id' ;
    rdfs:comment 'Primary key for guest_enrollment' ;
    rdfs:domain ind:GuestEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentReference rdf:type rdf:Property ;
    rdfs:label 'Enrollment Reference' ;
    rdfs:comment 'Unique surrogate identifier for this promotion enrollment record. Primary key.' ;
    rdfs:domain ind:GuestEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guestEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Guest Enrollment Date' ;
    rdfs:comment 'The date on which the member enrolled or was auto-enrolled in this promotion. Used to determine eligibility window and track campaign velocity.' ;
    rdfs:domain ind:GuestEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guestEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Guest Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of this member\'s participation in the promotion. Values: enrolled (registered but no qualifying activity yet), in-progress (actively working toward criteria), completed (met all criteria, awaiting award), expired (promotion ended before completion), awarded (bonus posted to account), opted-out (member withdrew from promotion).' ;
    rdfs:domain ind:GuestEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelConnectionId rdf:type rdf:Property ;
    rdfs:label 'Channel Connection Id' ;
    rdfs:comment 'Unique surrogate identifier for each property-channel connection record' ;
    rdfs:domain ind:ChannelConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionRateOverride rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Override' ;
    rdfs:comment 'Property-specific commission rate override for this channel, expressed as a percentage. Overrides the channel\'s standard commission_rate_pct when negotiated at the property level. Null if standard channel rate applies.' ;
    rdfs:domain ind:ChannelConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Connectivity Status' ;
    rdfs:comment 'Current operational status of the connectivity between this property and this channel. Tracks whether the technical integration is live, suspended, or experiencing issues.' ;
    rdfs:domain ind:ChannelConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentLastUpdated rdf:type rdf:Property ;
    rdfs:label 'Content Last Updated' ;
    rdfs:comment 'Timestamp of the last content update (room descriptions, images, amenities) pushed from this property to this channel. Used to track content freshness and synchronization status.' ;
    rdfs:domain ind:ChannelConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'Timestamp when this property-channel connection record was first created in the system' ;
    rdfs:domain ind:ChannelConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastBookingReceived rdf:type rdf:Property ;
    rdfs:label 'Last Booking Received' ;
    rdfs:comment 'Timestamp of the most recent booking received from this channel for this property. Used to monitor channel performance and identify inactive connections.' ;
    rdfs:domain ind:ChannelConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateParityException rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Exception' ;
    rdfs:comment 'Indicates whether this specific property has negotiated an exception to the channel\'s standard rate parity requirements. True if property is exempt from rate parity obligations for this channel.' ;
    rdfs:domain ind:ChannelConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'Timestamp when this property-channel connection record was last modified' ;
    rdfs:domain ind:ChannelConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:programEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Id' ;
    rdfs:comment 'Unique identifier for this wellness program enrollment record. Primary key.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customizationNotes rdf:type rdf:Property ;
    rdfs:label 'Customization Notes' ;
    rdfs:comment 'Free-text notes capturing guest-specific customizations to the standard wellness program (e.g., treatment substitutions, schedule adjustments, intensity modifications).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryPreferences rdf:type rdf:Property ;
    rdfs:label 'Dietary Preferences' ;
    rdfs:comment 'Guest\'s dietary preferences and restrictions specific to this wellness program enrollment (e.g., vegan, gluten-free, allergies). Used to coordinate F&B for program meals.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentPrice rdf:type rdf:Property ;
    rdfs:label 'Enrollment Price' ;
    rdfs:comment 'Actual price paid for this wellness program enrollment. May differ from program_price due to discounts, packages, or seasonal pricing.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Date' ;
    rdfs:comment 'Date when medical clearance was obtained for programs requiring physician approval or health screening. Required for programs with medical_supervision_required_flag = true.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Status' ;
    rdfs:comment 'Status of medical clearance for this enrollment. Controls whether guest can proceed with program participation.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'Actual end date of the wellness program for this guest. Used to calculate program duration and completion.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Start Date' ;
    rdfs:comment 'Actual start date of the wellness program for this guest. May differ from reservation arrival date if program begins mid-stay.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:progressNotes rdf:type rdf:Property ;
    rdfs:label 'Progress Notes' ;
    rdfs:comment 'Wellness coordinator notes tracking guest progress through the program (e.g., treatment attendance, fitness session participation, goal achievement).' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistFlag rdf:type rdf:Property ;
    rdfs:label 'Waitlist Flag' ;
    rdfs:comment 'Indicates whether this enrollment was initially placed on a waitlist due to program capacity constraints.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roomMaterialInstallationId rdf:type rdf:Property ;
    rdfs:label 'Room Material Installation Id' ;
    rdfs:comment 'Unique identifier for this specific installation record. Primary key.' ;
    rdfs:domain ind:RoomMaterialInstallation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationNotes rdf:type rdf:Property ;
    rdfs:label 'Installation Notes' ;
    rdfs:comment 'Free-text notes about the installation including installer, special configuration, or issues encountered. Audit trail for property management.' ;
    rdfs:domain ind:RoomMaterialInstallation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReplacementDate rdf:type rdf:Property ;
    rdfs:label 'Last Replacement Date' ;
    rdfs:comment 'Date when this material was last replaced in the room. Tracks replacement history for lifecycle analysis and budgeting.' ;
    rdfs:domain ind:RoomMaterialInstallation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityInstalled rdf:type rdf:Property ;
    rdfs:label 'Quantity Installed' ;
    rdfs:comment 'Number of units of this material installed in the room (e.g., 2 nightstands, 1 desk, 4 pillows). Critical for inventory valuation and replacement planning.' ;
    rdfs:domain ind:RoomMaterialInstallation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCostAtInstallation rdf:type rdf:Property ;
    rdfs:label 'Unit Cost At Installation' ;
    rdfs:comment 'Actual cost per unit paid at time of installation. Captured for asset valuation, depreciation calculation, and ROI analysis. May differ from current material_master.standard_price.' ;
    rdfs:domain ind:RoomMaterialInstallation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageTreatmentId rdf:type rdf:Property ;
    rdfs:label 'Package Treatment Id' ;
    rdfs:comment 'Unique identifier for this package-treatment association record. Primary key.' ;
    rdfs:domain ind:PackageTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spaPackageId rdf:type rdf:Property ;
    rdfs:label 'Spa Package Id' ;
    rdfs:comment 'Foreign key to spa_package. Part of the many-to-many relationship.' ;
    rdfs:domain ind:PackageTreatment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:includedTreatments rdf:type rdf:Property ;
    rdfs:label 'Included Treatments' ;
    rdfs:comment 'Comma-separated or structured list of treatment codes or names included in the package. Defines the service bundle composition. [Moved from spa_package: This STRING field currently stores a comma-separated list of treatments, which is a denormalized representation of the many-to-many relationship. Moving to the association table enables structured querying, proper referential integrity, and relationship-specific attributes like sequence and duration overrides.]' ;
    rdfs:domain ind:PackageTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Order in which this treatment is performed within the package. Used for scheduling, guest communication, and therapist workflow. Explicitly identified in detection phase.' ;
    rdfs:domain ind:PackageTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeOfDayPreference rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Preference' ;
    rdfs:comment 'Recommended or required time of day for this treatment within the package (morning, afternoon, evening, flexible). Used for scheduling optimization and guest experience design. Explicitly identified in detection phase.' ;
    rdfs:domain ind:PackageTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Available Flag' ;
    rdfs:comment 'Indicates whether the guest can upgrade this treatment to a premium version for an additional fee. Supports upsell opportunities. Explicitly identified in detection phase.' ;
    rdfs:domain ind:PackageTreatment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procurementSupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Procurement Supply Agreement Id' ;
    rdfs:comment 'Primary key for procurement_supply_agreement' ;
    rdfs:domain ind:ProcurementSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Negotiated Unit Price' ;
    rdfs:comment 'The per-unit price negotiated with this specific vendor for this material. Varies by vendor-material combination and is central to sourcing decisions.' ;
    rdfs:domain ind:ProcurementSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Code' ;
    rdfs:comment 'Unique identifier for this vendor-material supply agreement record. Primary key.' ;
    rdfs:domain ind:ProcurementSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Vendor Lead Time Days' ;
    rdfs:comment 'Number of days from purchase order placement to goods receipt for this vendor-material combination. Vendor-specific and critical for inventory planning.' ;
    rdfs:domain ind:ProcurementSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorCategoryQualificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Category Qualification Id' ;
    rdfs:comment 'Unique identifier for this vendor-category qualification record. Primary key for the association.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualSpendActual rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Actual' ;
    rdfs:comment 'Actual annual procurement spend (in USD) with this vendor in this category. Used for vendor performance analysis and spend allocation optimization.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Category Performance Score' ;
    rdfs:comment 'Vendor performance score specific to this procurement category, typically on a 0-100 scale. Reflects quality, delivery timeliness, pricing competitiveness, and compliance specific to this category. Performance varies by category for multi-category vendors. Identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Specific certifications or quality standards required for this vendor to supply this category (e.g., HACCP for food suppliers, LEED for sustainable FF&E vendors, ISO certifications for engineering contractors).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTerms rdf:type rdf:Property ;
    rdfs:label 'Contract Terms' ;
    rdfs:comment 'Category-specific contract terms and conditions negotiated for this vendor-category pairing. May include volume commitments, pricing structures, delivery terms, or quality standards specific to this category. Identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the vendor was initially qualified to supply goods or services in this procurement category. Identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes documenting qualification decisions, performance issues, or special considerations for this vendor-category relationship. Supports audit trail and knowledge transfer.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Spend Allocation Percentage' ;
    rdfs:comment 'Target percentage of category spend allocated to this vendor as part of vendor panel optimization strategy. Used in multi-sourcing strategies to balance risk and leverage competition. Identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorProgramParticipationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Program Participation Id' ;
    rdfs:comment 'Unique identifier for this vendor-program participation record. Primary key.' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:experienceProgramId rdf:type rdf:Property ;
    rdfs:label 'Experience Program Id' ;
    rdfs:comment 'Foreign key to experience.experience_program.experience_program_id' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:capacityLimit rdf:type rdf:Property ;
    rdfs:label 'Capacity Limit' ;
    rdfs:comment 'Maximum number of concurrent guests or service instances this vendor can support for this program. Null indicates no defined limit. Used for program enrollment capacity planning.' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Responsibility Flag' ;
    rdfs:comment 'Indicates whether this vendor has primary fulfillment responsibility for their service component within this program. True means the vendor is accountable for end-to-end delivery; false means they provide support services only.' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumNoticeHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Notice Hours' ;
    rdfs:comment 'Minimum number of hours advance notice required for this vendor to fulfill service requests under this program. Varies by program complexity and vendor capacity.' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participationEndDate rdf:type rdf:Property ;
    rdfs:label 'Participation End Date' ;
    rdfs:comment 'Date when the vendor\'s participation in this experience program ends or ended. Null indicates ongoing participation. Critical for tracking vendor contract lifecycles per program.' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationStartDate rdf:type rdf:Property ;
    rdfs:label 'Participation Start Date' ;
    rdfs:comment 'Date when the vendor began participating in this experience program. Tracks the effective start of the vendor\'s service delivery commitment for this specific program.' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the program-specific pricing.' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programSpecificPricing rdf:type rdf:Property ;
    rdfs:label 'Program Specific Pricing' ;
    rdfs:comment 'The negotiated price or rate for this vendor\'s services within this specific experience program. Pricing varies by program based on volume, exclusivity, and service scope. Different from the vendor\'s standard pricing.' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceDeliverySla rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Sla' ;
    rdfs:comment 'Service level agreement terms specific to this vendor-program combination. Defines response times, quality standards, availability requirements, and performance metrics the vendor must meet for this program.' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorProgramStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Program Status' ;
    rdfs:comment 'Current operational status of the vendor\'s participation in this specific program. Tracks whether the vendor is actively delivering services, temporarily suspended, or no longer participating. Status is program-specific; a vendor may be active in some programs and suspended in others.' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorRoleInProgram rdf:type rdf:Property ;
    rdfs:label 'Vendor Role In Program' ;
    rdfs:comment 'The specific role or service type the vendor provides within this experience program. A vendor may have different roles across different programs (e.g., spa operator for wellness programs, transportation for adventure programs).' ;
    rdfs:domain ind:VendorProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTouchpointServiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Touchpoint Service Id' ;
    rdfs:comment 'Unique identifier for this vendor-touchpoint service relationship. Primary key.' ;
    rdfs:domain ind:VendorTouchpointService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerTouchpointInteraction rdf:type rdf:Property ;
    rdfs:label 'Cost Per Touchpoint Interaction' ;
    rdfs:comment 'The negotiated cost per guest interaction at this touchpoint. Used for cost allocation and vendor performance analysis. Identified in detection phase.' ;
    rdfs:domain ind:VendorTouchpointService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityThresholdScore rdf:type rdf:Property ;
    rdfs:label 'Quality Threshold Score' ;
    rdfs:comment 'Minimum quality score the vendor must maintain for this touchpoint to remain in compliance. Identified in detection phase.' ;
    rdfs:domain ind:VendorTouchpointService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Time Minutes' ;
    rdfs:comment 'Maximum response time in minutes the vendor must meet for this touchpoint (e.g., valet retrieval time, concierge callback time). Identified in detection phase.' ;
    rdfs:domain ind:VendorTouchpointService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'The SLA tier or contract terms governing vendor performance at this touchpoint. Identified in detection phase.' ;
    rdfs:domain ind:VendorTouchpointService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current operational status of this vendor-touchpoint service relationship.' ;
    rdfs:domain ind:VendorTouchpointService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointActivationDate rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Activation Date' ;
    rdfs:comment 'The date this vendor began servicing this touchpoint. Used to track vendor tenure and historical performance. Identified in detection phase.' ;
    rdfs:domain ind:VendorTouchpointService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:touchpointDeactivationDate rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Deactivation Date' ;
    rdfs:comment 'The date this vendor stopped servicing this touchpoint, if applicable. Supports historical tracking of vendor-touchpoint relationships.' ;
    rdfs:domain ind:VendorTouchpointService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorStaffCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Staff Certification Required Flag' ;
    rdfs:comment 'Indicates whether vendor staff must hold specific certifications to deliver this touchpoint (e.g., sommelier certification for wine service touchpoint). Identified in detection phase.' ;
    rdfs:domain ind:VendorTouchpointService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorTouchpointRole rdf:type rdf:Property ;
    rdfs:label 'Vendor Touchpoint Role' ;
    rdfs:comment 'The role this vendor plays in delivering this touchpoint (e.g., primary valet provider, backup spa operator, seasonal transportation partner). Identified in detection phase.' ;
    rdfs:domain ind:VendorTouchpointService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:housekeepingTrainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Housekeeping Training Completion Id' ;
    rdfs:comment 'Primary key for housekeeping_training_completion' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instructorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Instructor Employee Id' ;
    rdfs:comment 'Reference to the employee who served as instructor or facilitator for this specific course delivery. Null for self-paced or vendor-delivered courses. Used for instructor effectiveness tracking and quality assurance.' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Training Completion Id' ;
    rdfs:comment 'Unique identifier for this training completion record. Primary key for the association.' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceTrainingCompletion .

ind:bloodbornePathogenCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Bloodborne Pathogen Certification Date' ;
    rdfs:comment 'Date the attendant completed their most recent bloodborne pathogen safety certification. OSHA requires annual refresher training for all employees with potential occupational exposure. [Moved from attendant: This date represents the completion_date of the most recent bloodborne pathogen training completion record. It belongs in the association as it is specific to a particular course enrollment, not an inherent attribute of the attendant.]' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bloodbornePathogenCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Bloodborne Pathogen Certified Flag' ;
    rdfs:comment 'Indicates whether the attendant has completed OSHA-required bloodborne pathogen training. Housekeeping staff may encounter blood, bodily fluids, or contaminated materials during room cleaning and must be trained in proper handling, disposal, and exposure response protocols. [Moved from attendant: This flag represents the CURRENT certification status derived from the most recent completed training_completion record for bloodborne pathogen courses. It should be computed from the association rather than stored redundantly on attendant.]' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Flag' ;
    rdfs:comment 'Indicates whether a completion certificate was issued to the attendant for this training. True for completed courses where learning_course.certification_issued_flag is true.' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chemicalHandlingCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Chemical Handling Certification Date' ;
    rdfs:comment 'Date the attendant completed their most recent chemical handling safety certification. Certifications typically require annual renewal to maintain compliance with OSHA standards. [Moved from attendant: This date represents the completion_date of the most recent chemical handling training completion record. It belongs in the association as it is specific to a particular course enrollment, not an inherent attribute of the attendant.]' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chemicalHandlingCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Chemical Handling Certified Flag' ;
    rdfs:comment 'Indicates whether the attendant has completed required training for safe handling, storage, and use of cleaning chemicals. Certification includes OSHA Hazard Communication Standard (HCS) training and property-specific chemical safety protocols. [Moved from attendant: This flag represents the CURRENT certification status derived from the most recent completed training_completion record for chemical handling courses. It should be computed from the association rather than stored redundantly on attendant. The source of truth is the training completion record with its expiry date.]' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Percentage score achieved by the attendant on the course assessment or examination. Null if course does not require assessment. Compared against learning_course.passing_score to determine completion eligibility.' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suiteQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Suite Qualified Flag' ;
    rdfs:comment 'Indicates whether the attendant is certified to clean suite-level accommodations. Suite cleaning requires additional training for handling luxury amenities, multiple rooms, and higher guest expectations. Suite-qualified attendants typically receive higher credit values per room. [Moved from attendant: This flag represents certification status that is earned through completion of suite service training courses. The qualification is derived from training_completion records for suite-related courses, making the association the proper source of truth.]' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Hours Completed' ;
    rdfs:comment 'Actual number of training hours the attendant completed for this course. May differ from learning_course.duration_hours for partial completions or extended sessions. Used for labor cost tracking and continuing education credit calculation.' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vipCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Certified Flag' ;
    rdfs:comment 'Indicates whether the attendant is certified to service VIP guest rooms. VIP certification requires demonstrated excellence in cleaning standards, attention to detail, discretion, and ability to handle special requests. VIP rooms receive enhanced amenities and white-glove service. [Moved from attendant: This flag represents certification status that is earned through completion of VIP service training courses. The qualification is derived from training_completion records for VIP-related courses, making the association the proper source of truth.]' ;
    rdfs:domain ind:HousekeepingTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageRateId rdf:type rdf:Property ;
    rdfs:label 'Package Rate Id' ;
    rdfs:comment 'Unique identifier for this channel-package rate configuration. Primary key.' ;
    rdfs:domain ind:PackageRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationPolicyOverride rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy Override' ;
    rdfs:comment 'Channel-specific cancellation policy code that overrides the packages default cancellation policy. Used when channel agreements require different cancellation terms (e.g., OTAs may require more flexible cancellation than direct bookings).' ;
    rdfs:domain ind:PackageRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPackagePrice rdf:type rdf:Property ;
    rdfs:label 'Channel Package Price' ;
    rdfs:comment 'Channel-specific price for this spa package. May differ from rack rate due to channel agreements, commissions, or promotional strategies. This is the price displayed and charged through this specific channel.' ;
    rdfs:domain ind:PackageRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRateUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Rate Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent rate update pushed to this channel for this package. Used for rate synchronization monitoring and troubleshooting.' ;
    rdfs:domain ind:PackageRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:minimumAdvanceBooking rdf:type rdf:Property ;
    rdfs:label 'Minimum Advance Booking' ;
    rdfs:comment 'Channel-specific minimum advance booking requirement in hours. May override the packages default minimum advance booking to accommodate channel-specific operational constraints or SLAs.' ;
    rdfs:domain ind:PackageRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Timestamp of the most recent modification to this channel-package rate configuration.' ;
    rdfs:domain ind:PackageRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:programTreatmentInclusionId rdf:type rdf:Property ;
    rdfs:label 'Program Treatment Inclusion Id' ;
    rdfs:comment 'Unique identifier for this program-treatment inclusion record. Primary key.' ;
    rdfs:domain ind:ProgramTreatmentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inclusionSequence rdf:type rdf:Property ;
    rdfs:label 'Inclusion Sequence' ;
    rdfs:comment 'Order in which this treatment should be delivered within the experience program journey. Used for scheduling and guest communication.' ;
    rdfs:domain ind:ProgramTreatmentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current status of this treatment inclusion in the program (active, suspended, discontinued). Allows temporary removal without deleting the inclusion record.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityIncluded rdf:type rdf:Property ;
    rdfs:label 'Quantity Included' ;
    rdfs:comment 'Number of sessions or instances of this treatment included in the experience program (e.g., 2 massages, 1 facial).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upgradeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligible Flag' ;
    rdfs:comment 'Indicates whether the guest can upgrade this treatment to a premium version within the program (e.g., upgrade 60-min massage to 90-min).' ;
    rdfs:domain ind:ProgramTreatmentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otaCampaignParticipationId rdf:type rdf:Property ;
    rdfs:label 'Ota Campaign Participation Id' ;
    rdfs:comment 'Unique identifier for this OTA partner\'s participation in a specific campaign. Primary key.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualBookingVolume rdf:type rdf:Property ;
    rdfs:label 'Actual Booking Volume' ;
    rdfs:comment 'Actual number of bookings generated by this OTA partner during the campaign period. Updated as campaign progresses.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue Amount' ;
    rdfs:comment 'Actual revenue generated from bookings attributed to this OTA partner during the campaign period.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementReference rdf:type rdf:Property ;
    rdfs:label 'Agreement Reference' ;
    rdfs:comment 'Reference number or identifier for the co-marketing agreement or insertion order governing this OTA partner\'s participation in this campaign.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coopMarketingBudget rdf:type rdf:Property ;
    rdfs:label 'Coop Marketing Budget' ;
    rdfs:comment 'Total co-operative marketing budget allocated for this OTA partner\'s participation in this specific campaign. Represents the combined hotel and partner investment.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hotelContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Hotel Contribution Amount' ;
    rdfs:comment 'The monetary amount contributed by the hotel or brand toward this OTA partner\'s participation in the campaign.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otaCoopBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Ota Coop Budget Amount' ;
    rdfs:comment 'Budget allocated specifically for OTA cooperative marketing programs within this campaign. [Moved from campaign: This attribute currently exists at the campaign level as a total OTA co-op budget, but in reality, co-op budgets are negotiated and tracked per OTA partner per campaign. The attribute should be decomposed into partner-specific participation records with coop_marketing_budget and partner_contribution_amount tracked for each OTA partner\'s participation.]' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current status of the OTA partner\'s participation in this campaign indicating operational state of the co-marketing agreement.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Partner Contribution Amount' ;
    rdfs:comment 'The monetary amount contributed by the OTA partner toward this campaign as part of the co-marketing agreement. May be cash, media credits, or promotional placement value.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBonusEarned rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Earned' ;
    rdfs:comment 'Performance-based bonus amount earned by the OTA partner for exceeding agreed campaign targets (bookings, revenue, conversion rate). Tracked per participation agreement.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPlacementType rdf:type rdf:Property ;
    rdfs:label 'Promotional Placement Type' ;
    rdfs:comment 'Type of promotional placement provided by the OTA partner for this campaign (e.g., homepage banner, email feature, search boost, mobile app placement).' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBookingVolume rdf:type rdf:Property ;
    rdfs:label 'Target Booking Volume' ;
    rdfs:comment 'Target number of bookings expected from this OTA partner during the campaign period. Used for performance tracking and bonus calculation.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Amount' ;
    rdfs:comment 'Target revenue expected from this OTA partner\'s campaign participation. Used for ROI measurement and performance bonus calculation.' ;
    rdfs:domain ind:OtaCampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'Unique surrogate identifier for this guest-to-segment membership record. Primary key.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionDistributionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Distribution Id' ;
    rdfs:comment 'Unique identifier for this promotion-channel distribution record. Primary key.' ;
    rdfs:domain ind:PromotionDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualBookings rdf:type rdf:Property ;
    rdfs:label 'Actual Bookings' ;
    rdfs:comment 'Cumulative count of bookings generated by this promotion through this channel. Updated as bookings are attributed to the promotion-channel combination.' ;
    rdfs:domain ind:PromotionDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Amount' ;
    rdfs:comment 'Portion of the total promotion budget allocated specifically to this distribution channel. Sum of all channel allocations should not exceed promotion.budget_cap_amount. Identified in detection phase.' ;
    rdfs:domain ind:PromotionDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTargetBookings rdf:type rdf:Property ;
    rdfs:label 'Performance Target Bookings' ;
    rdfs:comment 'Target number of qualifying bookings expected from this promotion through this channel. Used for channel performance tracking and ROI analysis. Identified in detection phase.' ;
    rdfs:domain ind:PromotionDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Promotion Rate Multiplier' ;
    rdfs:comment 'Channel-specific adjustment multiplier applied to the base promotion bonus for this distribution channel. Allows different bonus rates by channel (e.g., 2.0x for direct web, 1.5x for OTA). Identified in detection phase.' ;
    rdfs:domain ind:PromotionDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionTreatmentRuleId rdf:type rdf:Property ;
    rdfs:label 'Promotion Treatment Rule Id' ;
    rdfs:comment 'Unique identifier for this promotion-treatment rule. Primary key.' ;
    rdfs:domain ind:PromotionTreatmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentRedemptions rdf:type rdf:Property ;
    rdfs:label 'Current Redemptions' ;
    rdfs:comment 'Running count of how many times this promotion-treatment combination has been redeemed to date. Updated at point-of-sale.' ;
    rdfs:domain ind:PromotionTreatmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumRedemptions rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemptions' ;
    rdfs:comment 'Maximum number of times this promotion can be applied to this treatment across all members. Used to cap exposure on high-value treatments within a broader promotion.' ;
    rdfs:domain ind:PromotionTreatmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumSpend rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend' ;
    rdfs:comment 'Minimum spend amount required on this specific treatment to qualify for the promotion bonus or discount. Treatment-specific threshold within the promotion.' ;
    rdfs:domain ind:PromotionTreatmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupSpaPackageContractId rdf:type rdf:Property ;
    rdfs:label 'Group Spa Package Contract Id' ;
    rdfs:comment 'Unique identifier for this group spa package contract record. Primary key.' ;
    rdfs:domain ind:GroupSpaPackageContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advanceBookingDeadline rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Deadline' ;
    rdfs:comment 'Deadline date by which group members must book their spa package appointments to receive the contracted group rate and guarantee availability.' ;
    rdfs:domain ind:GroupSpaPackageContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingArrangement rdf:type rdf:Property ;
    rdfs:label 'Billing Arrangement' ;
    rdfs:comment 'Defines how spa package charges are billed for this group. Values: master_account (all charges to group master account), individual_folio (each guest pays separately), split_billing (partial group subsidy), prepaid (included in group package price).' ;
    rdfs:domain ind:GroupSpaPackageContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedPackageCount rdf:type rdf:Property ;
    rdfs:label 'Contracted Package Count' ;
    rdfs:comment 'Number of spa package instances contracted or committed as part of the group block agreement. Represents the minimum guaranteed bookings.' ;
    rdfs:domain ind:GroupSpaPackageContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coordinatorContact rdf:type rdf:Property ;
    rdfs:label 'Coordinator Contact' ;
    rdfs:comment 'Name and contact information for the group coordinator or event planner responsible for managing spa package bookings for this group block.' ;
    rdfs:domain ind:GroupSpaPackageContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Group Discount Percentage' ;
    rdfs:comment 'Percentage discount off the spa package rack rate negotiated for this group block. Applied to all bookings of this package by group members.' ;
    rdfs:domain ind:GroupSpaPackageContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockWashFactorApplicationId rdf:type rdf:Property ;
    rdfs:label 'Block Wash Factor Application Id' ;
    rdfs:comment 'Primary key for the block_wash_factor_application association' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWashPct rdf:type rdf:Property ;
    rdfs:label 'Actual Wash Pct' ;
    rdfs:comment 'The actual attrition percentage observed after the block concluded, calculated as (contracted_room_nights - picked_up_room_nights) / contracted_room_nights. Used for post-event analysis.' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationReason rdf:type rdf:Property ;
    rdfs:label 'Application Reason' ;
    rdfs:comment 'Free-text explanation of why this specific wash factor was selected for this block (e.g., \'Corporate group, 90-day lead time, 50-room block matches historical profile\').' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Lifecycle status of this application record. \'active\' = currently used for forecasting; \'superseded\' = replaced by a newer application; \'final\' = block concluded, actual wash recorded.' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedBy rdf:type rdf:Property ;
    rdfs:label 'Applied By' ;
    rdfs:comment 'Name or user identifier of the revenue manager who applied or approved this wash factor application, or \'SYSTEM\' if automatically applied by RMS.' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedWashPct rdf:type rdf:Property ;
    rdfs:label 'Applied Wash Pct' ;
    rdfs:comment 'The wash factor percentage that was applied to this specific block during forecasting. This is the predicted attrition rate used by the RMS.' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockSizeTierMatch rdf:type rdf:Property ;
    rdfs:label 'Block Size Tier Match' ;
    rdfs:comment 'Indicates whether the block size matched the wash factor\'s block_size_tier exactly, required interpolation between tiers, or used a default factor. Supports wash factor selection audit trail.' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastRunCode rdf:type rdf:Property ;
    rdfs:label 'Forecast Run Code' ;
    rdfs:comment 'Identifier of the RMS forecast run during which this wash factor was applied. Links to the specific forecast cycle for audit and reproducibility.' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeBucketMatch rdf:type rdf:Property ;
    rdfs:label 'Lead Time Bucket Match' ;
    rdfs:comment 'Indicates whether the booking lead time matched the wash factor\'s booking_lead_time_bucket exactly, required interpolation, or used a default factor. Supports wash factor selection audit trail.' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'The difference between applied wash percentage and actual wash percentage (actual_wash_pct - applied_wash_pct). Positive variance indicates the block washed more than predicted; negative indicates better pickup than predicted.' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:washFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Wash Factor Percentage' ;
    rdfs:comment 'Expected percentage of block rooms that will not be picked up, used for revenue forecasting and inventory planning. Expressed as percentage (e.g., 15.00 for 15%). [Moved from room_block: This attribute in room_block represents a specific wash factor percentage applied to the block. However, a block may have multiple wash factors applied over time (initial forecast, revised forecast, post-event analysis) or may be evaluated against multiple factor configurations. This attribute should move to the association to support tracking of multiple applications with their effective dates and contexts.]' ;
    rdfs:domain ind:BlockWashFactorApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomTypePromotionId rdf:type rdf:Property ;
    rdfs:label 'Room Type Promotion Id' ;
    rdfs:comment 'Unique identifier for this room type promotion configuration record. Primary key.' ;
    rdfs:domain ind:RoomTypePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryAllocationCap rdf:type rdf:Property ;
    rdfs:label 'Inventory Allocation Cap' ;
    rdfs:comment 'Maximum number of rooms of this type allocated to this promotion. Used by revenue management to control promotional inventory and protect higher-rated business. Null if no cap applies.' ;
    rdfs:domain ind:RoomTypePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalRateAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate Amount' ;
    rdfs:comment 'Special promotional rate (in property currency) offered for this room type under this promotion. Overrides standard BAR or member rates. Null if promotion does not include rate discount.' ;
    rdfs:domain ind:RoomTypePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomsBookedCount rdf:type rdf:Property ;
    rdfs:label 'Rooms Booked Count' ;
    rdfs:comment 'Cumulative count of rooms of this type booked under this promotion to date. Updated in real-time by reservation system. Used to enforce inventory_allocation_cap.' ;
    rdfs:domain ind:RoomTypePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomTypeCompetitiveBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Room Type Competitive Benchmark Id' ;
    rdfs:comment 'Primary key for room_type_competitive_benchmark' ;
    rdfs:domain ind:RoomTypeCompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueCompetitiveSetId rdf:type rdf:Property ;
    rdfs:label 'Revenue Competitive Set Id' ;
    rdfs:comment 'Foreign key linking to the competitive set used for benchmarking this room type' ;
    rdfs:domain ind:RoomTypeCompetitiveBenchmark ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetitiveSet .

ind:benchmarkRoomTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Benchmark Room Type Category' ;
    rdfs:comment 'The STR room type category classification used for this specific room type when benchmarking against this competitive set. Maps property-specific room types to standardized STR categories for apples-to-apples comparison. Examples: STANDARD, DELUXE, SUITE, PREMIUM.' ;
    rdfs:domain ind:RoomTypeCompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkWeight rdf:type rdf:Property ;
    rdfs:label 'Benchmark Weight' ;
    rdfs:comment 'The weighting percentage applied to this competitive set when calculating blended benchmark metrics for this room type. Used when a room type is benchmarked against multiple competitive sets with different importance levels. Sum of weights across all comp sets for a room type should equal 100.' ;
    rdfs:domain ind:RoomTypeCompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryCompCategory rdf:type rdf:Property ;
    rdfs:label 'Is Primary Comp Category' ;
    rdfs:comment 'Indicates whether this is the primary competitive set used for benchmarking this room type. A room type may be mapped to multiple competitive sets (primary luxury set, secondary airport set), but only one is designated as primary for executive reporting and KPI dashboards.' ;
    rdfs:domain ind:RoomTypeCompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roomTypeCompetitiveBenchmarkStatus rdf:type rdf:Property ;
    rdfs:label 'Room Type Competitive Benchmark Status' ;
    rdfs:comment 'Current operational status of this benchmark configuration. ACTIVE configurations are used in live rate shopping and STR reporting. INACTIVE configurations are historical. SUSPENDED configurations are temporarily disabled but may be reactivated.' ;
    rdfs:domain ind:RoomTypeCompetitiveBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventClassEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Event Class Enrollment Id' ;
    rdfs:comment 'Primary key for event_class_enrollment' ;
    rdfs:domain ind:EventClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendanceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Attendance Confirmed' ;
    rdfs:comment 'Boolean flag indicating whether the attendee\'s attendance at this session has been confirmed through check-in or instructor verification. Used for capacity management and post-event reporting.' ;
    rdfs:domain ind:EventClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargeMethod rdf:type rdf:Property ;
    rdfs:label 'Charge Method' ;
    rdfs:comment 'Indicates how this enrollment is billed. Values: included_in_package (covered by event registration fee), separate_charge (billed separately to attendee or master account), complimentary (no charge, promotional), loyalty_redemption (paid with loyalty points).' ;
    rdfs:domain ind:EventClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Sent Timestamp' ;
    rdfs:comment 'Date and time when enrollment confirmation communication was sent to the attendee (email, SMS, or app notification). Used for communication tracking and guest service verification.' ;
    rdfs:domain ind:EventClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventClassEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Event Class Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the enrollment. Tracks progression from initial registration through attendance confirmation. Values: pending (awaiting confirmation), confirmed (enrollment confirmed), waitlisted (session full, on waitlist), cancelled (attendee cancelled), attended (attendee participated), no_show (confirmed but did not attend).' ;
    rdfs:domain ind:EventClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includedInEventPackage rdf:type rdf:Property ;
    rdfs:label 'Included In Event Package' ;
    rdfs:comment 'Boolean flag indicating whether this fitness class session is included in the attendee\'s event registration package at no additional charge. Determines billing treatment and revenue allocation.' ;
    rdfs:domain ind:EventClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timestamp rdf:type rdf:Property ;
    rdfs:label 'Timestamp' ;
    rdfs:comment 'Date and time when the attendee enrolled in this fitness class session. Used for waitlist priority, early registration tracking, and audit purposes.' ;
    rdfs:domain ind:EventClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:beoAttendantAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Beo Attendant Assignment Id' ;
    rdfs:comment 'Unique identifier for this BEO attendant assignment record. Primary key.' ;
    rdfs:domain ind:BeoAttendantAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned By Employee Id' ;
    rdfs:comment 'Reference to the event manager or housekeeping supervisor who made this assignment. Used for accountability and assignment pattern analysis.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Actual hours worked by the attendant on this BEO. Used for labor costing, payroll validation, and productivity analysis.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'The specific role the attendant performs for this BEO (e.g., setup crew, service staff, breakdown crew, supervisor, runner). Determines labor rate and performance expectations.' ;
    rdfs:domain ind:BeoAttendantAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryBuyerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Category Buyer Assignment Id' ;
    rdfs:comment 'Unique identifier for the category buyer assignment record. Primary key.' ;
    rdfs:domain ind:CategoryBuyerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBackupFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Backup Flag' ;
    rdfs:comment 'Boolean indicator of whether this is a primary (true) or backup (false) assignment. Used for requisition routing logic to determine first-line responsibility.' ;
    rdfs:domain ind:CategoryBuyerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendAuthorityLimit rdf:type rdf:Property ;
    rdfs:label 'Spend Authority Limit' ;
    rdfs:comment 'Maximum purchase order value (in USD) that this buyer can approve for this category without escalation. Authority limits vary by buyer experience level and category risk profile.' ;
    rdfs:domain ind:CategoryBuyerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workloadPercentage rdf:type rdf:Property ;
    rdfs:label 'Workload Percentage' ;
    rdfs:comment 'Percentage of the buyer\'s time allocated to managing this category. Used for workload balancing and capacity planning across the procurement team.' ;
    rdfs:domain ind:CategoryBuyerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementTherapistCertificationId rdf:type rdf:Property ;
    rdfs:label 'Procurement Therapist Certification Id' ;
    rdfs:comment 'Primary key for procurement_therapist_certification' ;
    rdfs:domain ind:ProcurementTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:therapistCertificationId rdf:type rdf:Property ;
    rdfs:label 'Therapist Certification Id' ;
    rdfs:comment 'Unique identifier for this therapist-treatment certification record. Primary key for the association.' ;
    rdfs:domain ind:ProcurementTherapistCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpaTherapistCertification .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date when the therapist was certified to perform this specific treatment. Used for compliance tracking and recertification scheduling.' ;
    rdfs:domain ind:ProcurementTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPerformedDate rdf:type rdf:Property ;
    rdfs:label 'Last Performed Date' ;
    rdfs:comment 'Most recent date the therapist performed this treatment on a guest. Used to identify skill currency and trigger refresher training requirements.' ;
    rdfs:domain ind:ProcurementTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredForTreatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred For Treatment Flag' ;
    rdfs:comment 'Indicates whether this therapist is designated as a preferred or specialist provider for this treatment. Used for VIP guest scheduling and premium service delivery.' ;
    rdfs:domain ind:ProcurementTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level' ;
    rdfs:comment 'Current skill proficiency level of the therapist for this specific treatment. Used for scheduling optimization, quality assurance, and identifying training needs. Values: TRAINEE, COMPETENT, PROFICIENT, EXPERT.' ;
    rdfs:domain ind:ProcurementTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentsPerformedCount rdf:type rdf:Property ;
    rdfs:label 'Treatments Performed Count' ;
    rdfs:comment 'Total number of times this therapist has performed this specific treatment. Used for experience tracking and proficiency assessment.' ;
    rdfs:domain ind:ProcurementTherapistCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Program Assignment Id' ;
    rdfs:comment 'Unique identifier for this employee-program assignment record. Primary key.' ;
    rdfs:domain ind:ProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when the employee\'s assignment to this experience program ended. Null indicates an active ongoing assignment. This attribute was explicitly identified in the detection phase as relationship data.' ;
    rdfs:domain ind:ProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when the employee began their assignment to this experience program. This attribute was explicitly identified in the detection phase as relationship data.' ;
    rdfs:domain ind:ProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Responsibility Level' ;
    rdfs:comment 'Level of responsibility the employee has for this program (e.g., primary, secondary, backup, trainee). This attribute was explicitly identified in the detection phase as relationship data.' ;
    rdfs:domain ind:ProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleInProgram rdf:type rdf:Property ;
    rdfs:label 'Role In Program' ;
    rdfs:comment 'The specific role the employee performs within this experience program (e.g., coordinator, instructor, concierge, specialist). This attribute was explicitly identified in the detection phase as relationship data.' ;
    rdfs:domain ind:ProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experienceEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Experience Enrollment Id' ;
    rdfs:comment 'Unique identifier for this event-experience enrollment record. Primary key.' ;
    rdfs:domain ind:ExperienceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coordinatorNotes rdf:type rdf:Property ;
    rdfs:label 'Coordinator Notes' ;
    rdfs:comment 'Free-text notes from the event coordinator regarding this specific program enrollment, including special requests, customizations, or operational considerations for this event.' ;
    rdfs:domain ind:ExperienceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Treatment Allocation Id' ;
    rdfs:comment 'Unique identifier for this event treatment allocation record. Primary key.' ;
    rdfs:domain ind:TreatmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendeeAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Attendee Allocation Method' ;
    rdfs:comment 'Method by which event attendees access the allocated treatments (e.g., first-come-first-served, pre-assigned slots, voucher distribution, unlimited access within booking window).' ;
    rdfs:domain ind:TreatmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Booking Window End' ;
    rdfs:comment 'Timestamp when the booking window closes for this treatment allocation. Typically aligned with event departure or post-event grace periods.' ;
    rdfs:domain ind:TreatmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingWindowStart rdf:type rdf:Property ;
    rdfs:label 'Booking Window Start' ;
    rdfs:comment 'Timestamp when event attendees can begin booking this treatment. Typically aligned with event arrival dates or pre-event access periods.' ;
    rdfs:domain ind:TreatmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:negotiatedRate rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate' ;
    rdfs:comment 'Special event pricing negotiated for this treatment as part of the MICE contract. May differ from the standard recommended retail price based on volume and event value.' ;
    rdfs:domain ind:TreatmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffingAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Staffing Assignment Id' ;
    rdfs:comment 'Unique identifier for this event staffing assignment record. Primary key.' ;
    rdfs:domain ind:StaffingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'Timestamp when this staffing assignment was created in the system.' ;
    rdfs:domain ind:StaffingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Flag' ;
    rdfs:comment 'Indicates whether this assignment included overtime hours requiring premium pay rates.' ;
    rdfs:domain ind:StaffingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programFitnessInclusionId rdf:type rdf:Property ;
    rdfs:label 'Program Fitness Inclusion Id' ;
    rdfs:comment 'Unique identifier for this program-fitness class inclusion relationship. Primary key.' ;
    rdfs:domain ind:ProgramFitnessInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advanceBookingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Required Flag' ;
    rdfs:comment 'Indicates whether guests enrolled in this program must book this fitness class in advance or can attend walk-in. This attribute was explicitly identified in the detection phase relationship data.' ;
    rdfs:domain ind:ProgramFitnessInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:classSelectionFlexibility rdf:type rdf:Property ;
    rdfs:label 'Class Selection Flexibility' ;
    rdfs:comment 'Indicates whether guests must attend specific scheduled sessions (fixed), can choose any available session (flexible), or can choose from a subset (choice_of_n). This attribute was explicitly identified in the detection phase relationship data.' ;
    rdfs:domain ind:ProgramFitnessInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityBookingFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Booking Flag' ;
    rdfs:comment 'Indicates whether guests enrolled in this program receive priority booking access for this fitness class over non-program guests.' ;
    rdfs:domain ind:ProgramFitnessInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentProgramEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Segment Program Eligibility Id' ;
    rdfs:comment 'Unique surrogate identifier for the segment-program eligibility record. Primary key.' ;
    rdfs:domain ind:SegmentProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Enrollment Eligibility Flag' ;
    rdfs:comment 'Indicates whether guests in this market segment are eligible to enroll in this experience program. False may indicate restricted or conditional eligibility.' ;
    rdfs:domain ind:SegmentProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Program Discount Pct' ;
    rdfs:comment 'Segment-specific discount percentage applied to this experience program for guests in this market segment. Null indicates standard program pricing applies.' ;
    rdfs:domain ind:SegmentProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryAllocationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Allocation Id' ;
    rdfs:comment 'Primary key for inventory_allocation' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByRequirementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Requirement Id' ;
    rdfs:comment 'Identifier of the regulatory requirement that supersedes or replaces this requirement. Null if not superseded.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Description of which properties, business units, or operations are subject to this requirement (e.g., all properties, luxury segment only, properties with food service).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligation rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation' ;
    rdfs:comment 'Specific actions or conditions that must be met to satisfy the regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description of the regulatory requirement, including what is mandated and the scope of applicability.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Indicates whether formal documentation or records must be maintained to demonstrate compliance (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Level of government or regulatory authority (international, federal, national, state, provincial, local, municipal).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum monetary penalty or fine amount that can be imposed for non-compliance, in the currency specified.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of penalties, fines, or sanctions that may be imposed for non-compliance.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Record Retention Years' ;
    rdfs:comment 'Number of years that compliance records must be retained as mandated by the requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceUrl rdf:type rdf:Property ;
    rdfs:label 'Reference Url' ;
    rdfs:comment 'Web link to the official text or authoritative source of the regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationSection rdf:type rdf:Property ;
    rdfs:label 'Regulation Section' ;
    rdfs:comment 'Specific section, article, or clause within the source regulation that defines this requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Period Months' ;
    rdfs:comment 'Number of months between required renewals of certification or compliance verification. Null if no renewal is required.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementCode rdf:type rdf:Property ;
    rdfs:label 'Requirement Code' ;
    rdfs:comment 'Externally-known unique code or reference number for the regulatory requirement (e.g., GDPR-ART-6, OSHA-1910.38, ADA-Title-III).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementName rdf:type rdf:Property ;
    rdfs:label 'Requirement Name' ;
    rdfs:comment 'Human-readable name or title of the regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementType rdf:type rdf:Property ;
    rdfs:label 'Requirement Type' ;
    rdfs:comment 'Categorical classification of the regulatory requirement domain (e.g., data privacy, health and safety, accessibility, fire safety, food safety, liquor licensing, environmental, labor, financial, building code).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRegulation rdf:type rdf:Property ;
    rdfs:label 'Source Regulation' ;
    rdfs:comment 'Name or citation of the parent regulation, statute, or legal framework from which this requirement derives (e.g., GDPR, OSHA 1910, ADA Title III, CCPA).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory requirement (active, inactive, pending, superseded, repealed, draft).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingFrequency rdf:type rdf:Property ;
    rdfs:label 'Training Frequency' ;
    rdfs:comment 'Required frequency of employee training to maintain compliance (annual, biennial, one-time, as-needed).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether employee training is mandated by the requirement (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsAnonymousResponses rdf:type rdf:Property ;
    rdfs:label 'Allows Anonymous Responses' ;
    rdfs:comment 'Indicates whether guests can submit responses to this survey without providing identifying information, supporting privacy preferences.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoCaseCreationEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Case Creation Enabled' ;
    rdfs:comment 'Indicates whether low-scoring survey responses automatically create service recovery cases in Salesforce CRM for immediate guest outreach.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewed rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewed' ;
    rdfs:comment 'Indicates whether this survey template has been reviewed for compliance with privacy regulations and data protection requirements.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveOffered rdf:type rdf:Property ;
    rdfs:label 'Incentive Offered' ;
    rdfs:comment 'Type of incentive offered to guests for completing this survey, used for response rate optimization and program cost tracking.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveValue rdf:type rdf:Property ;
    rdfs:label 'Incentive Value' ;
    rdfs:comment 'Monetary or points value of the incentive offered for survey completion, used for program cost analysis and ROI measurement.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includesCsatQuestion rdf:type rdf:Property ;
    rdfs:label 'Includes Csat Question' ;
    rdfs:comment 'Indicates whether this survey template includes a Customer Satisfaction (CSAT) rating question for overall satisfaction measurement.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesNpsQuestion rdf:type rdf:Property ;
    rdfs:label 'Includes Nps Question' ;
    rdfs:comment 'Indicates whether this survey template includes the standard NPS question for measuring guest loyalty and likelihood to recommend.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesOpenFeedback rdf:type rdf:Property ;
    rdfs:label 'Includes Open Feedback' ;
    rdfs:comment 'Indicates whether this survey template includes open-ended text fields for qualitative guest feedback and comments.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Default Template' ;
    rdfs:comment 'Indicates whether this is the default survey template for its type and segment, used for automated survey distribution logic.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Most recent date this survey template was distributed to a guest, used for template lifecycle management and archival decisions.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medalliaTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Medallia Template Code' ;
    rdfs:comment 'External identifier for this survey template in the Medallia experience analytics platform, used for system integration and data synchronization.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyTier rdf:type rdf:Property ;
    rdfs:label 'Property Tier' ;
    rdfs:comment 'Hotel property tier or brand segment for which this survey template is designed, enabling tier-specific experience measurement.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseWindowDays rdf:type rdf:Property ;
    rdfs:label 'Response Window Days' ;
    rdfs:comment 'Number of days the survey remains open for guest responses after distribution, balancing recency and response opportunity.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saltProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Salt Program Eligible' ;
    rdfs:comment 'Indicates whether responses from this survey template are eligible for inclusion in SALT program metrics and service recovery workflows.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the survey template by its primary purpose: Net Promoter Score (NPS), Customer Satisfaction (CSAT), Guest Satisfaction Score (GSS), post-stay feedback, pre-arrival expectations, or service recovery assessment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerDelayHours rdf:type rdf:Property ;
    rdfs:label 'Trigger Delay Hours' ;
    rdfs:comment 'Number of hours to wait after the trigger event before sending the survey to the guest, optimizing response timing and quality.' ;
    rdfs:domain ind:SurveyTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this payment run. Required for audit trails and segregation of duties per SOX controls.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:glBatchId rdf:type rdf:Property ;
    rdfs:label 'Gl Batch Id' ;
    rdfs:comment 'Reference to the GL batch in SAP S/4HANA where payment run transactions were posted for financial consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlBatch .

ind:failedAmount rdf:type rdf:Property ;
    rdfs:label 'Failed Amount' ;
    rdfs:comment 'The total amount from payments that failed processing and were not disbursed.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Count' ;
    rdfs:comment 'The number of payment transactions that failed during processing due to validation errors, insufficient funds, or other issues.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Disbursement Amount' ;
    rdfs:comment 'The net amount disbursed after deducting processing fees and adjustments from the total successful payment amount.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFileFormat rdf:type rdf:Property ;
    rdfs:label 'Payment File Format' ;
    rdfs:comment 'The technical format of the payment file: NACHA for ACH, ISO20022 for international standards, BAI2 for bank reconciliation, MT940 for SWIFT, proprietary for custom bank formats.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFileName rdf:type rdf:Property ;
    rdfs:label 'Payment File Name' ;
    rdfs:comment 'The name of the payment file generated for bank transmission (e.g., NACHA file for ACH, SWIFT file for wire transfers).' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Amount' ;
    rdfs:comment 'Total fees charged by payment processors, banks, or payment networks for executing this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date when this payment run was successfully reconciled against bank statements.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'The number of times this payment run has been retried after initial failure, used for monitoring and escalation thresholds.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business identifier for the payment run, formatted as PR-YYYYMMDD-NNNN for external reference and audit trails.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payment run based on its purpose and scheduling: scheduled for regular cycles, ad_hoc for one-time payments, emergency for urgent disbursements, payroll for employee compensation, vendor for supplier payments, refund for guest reimbursements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successfulAmount rdf:type rdf:Property ;
    rdfs:label 'Successful Amount' ;
    rdfs:comment 'The total amount successfully disbursed from payments that completed without errors.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successfulPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Successful Payment Count' ;
    rdfs:comment 'The number of payment transactions that were successfully processed and disbursed.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Count' ;
    rdfs:comment 'The total number of individual payment transactions included in this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requestor Employee Id' ;
    rdfs:comment 'Identifier of the employee who initiated the capital expenditure request.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Total capital expenditure amount approved by management, which may differ from the requested amount. Null if not yet approved.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Rationale and business case for the capital expenditure, including strategic alignment and expected benefits.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment' ;
    rdfs:comment 'Assessment level of environmental impact associated with the capital expenditure project, supporting sustainability reporting.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiYearProject rdf:type rdf:Property ;
    rdfs:label 'Is Multi Year Project' ;
    rdfs:comment 'Indicates whether the capital expenditure project spans multiple fiscal years requiring phased budgeting and approval.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Planned date for the capital expenditure project to be completed and the asset placed in service.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Planned date for the capital expenditure project to commence.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative description of the capital expenditure project, including scope, objectives, and expected outcomes.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedAmount rdf:type rdf:Property ;
    rdfs:label 'Requested Amount' ;
    rdfs:comment 'Total capital expenditure amount requested for the project in the property\'s functional currency.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the employee who initiated the capital expenditure request.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Percentage' ;
    rdfs:comment 'Estimated return on investment percentage for the capital expenditure project, used in financial justification.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soxControlRequired rdf:type rdf:Property ;
    rdfs:label 'Sox Control Required' ;
    rdfs:comment 'Indicates whether this capital expenditure request is subject to SOX financial controls and audit requirements for publicly traded entities.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlId rdf:type rdf:Property ;
    rdfs:label 'Sox Control Id' ;
    rdfs:comment 'Reference identifier linking this template to specific SOX financial controls for publicly traded entities.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Control .

ind:amountType rdf:type rdf:Property ;
    rdfs:label 'Amount Type' ;
    rdfs:comment 'Indicates whether the journal entry amount is a fixed value, variable (entered at generation time), or calculated using a formula.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'Role or position authorized to approve journal entries generated from this template (e.g., Controller, Finance Manager, Property Accountant).' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPostFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Post Flag' ;
    rdfs:comment 'Indicates whether journal entries generated from this template are automatically posted to the general ledger (true) or require manual review and approval (false).' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationFormula rdf:type rdf:Property ;
    rdfs:label 'Calculation Formula' ;
    rdfs:comment 'Formula or calculation logic used to determine the journal entry amount when amount_type is formula_based. May reference other GL accounts, percentages, or system variables.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexFfeFlag rdf:type rdf:Property ;
    rdfs:label 'Capex Ffe Flag' ;
    rdfs:comment 'Indicates whether this template relates to capital expenditure or FF&E reserve tracking, critical for hotel asset management and lender covenant compliance.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Amount' ;
    rdfs:comment 'Fixed monetary amount to be used when generating journal entries from this template. Only applicable when amount_type is fixed.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gaapReference rdf:type rdf:Property ;
    rdfs:label 'Gaap Reference' ;
    rdfs:comment 'Citation to specific GAAP or IFRS accounting standard that governs this recurring entry (e.g., ASC 606, IFRS 15).' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCredit rdf:type rdf:Property ;
    rdfs:label 'Gl Account Credit' ;
    rdfs:comment 'General ledger account number to be credited when this template generates a journal entry. Must conform to the USALI chart of accounts structure.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountDebit rdf:type rdf:Property ;
    rdfs:label 'Gl Account Debit' ;
    rdfs:comment 'General ledger account number to be debited when this template generates a journal entry. Must conform to the USALI chart of accounts structure.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this template generates intercompany journal entries requiring elimination in consolidated financial statements.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastGeneratedDate rdf:type rdf:Property ;
    rdfs:label 'Last Generated Date' ;
    rdfs:comment 'Date when this template last generated a journal entry, used for tracking and scheduling next occurrence.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Date' ;
    rdfs:comment 'Date when this template is scheduled to generate its next journal entry based on recurrence frequency.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'Frequency at which this template generates journal entries (daily, weekly, monthly, quarterly, semi-annually, or annually).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalPeriodOffset rdf:type rdf:Property ;
    rdfs:label 'Reversal Period Offset' ;
    rdfs:comment 'Number of accounting periods after the original entry when the reversal should occur. Typically 1 for next-period reversals.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Required Flag' ;
    rdfs:comment 'Indicates whether entries generated from this template require automatic reversal in the subsequent accounting period (true for accruals and certain adjusting entries).' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Sap Integration Flag' ;
    rdfs:comment 'Indicates whether this template is integrated with SAP S/4HANA for automated journal entry posting and synchronization.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Impact Flag' ;
    rdfs:comment 'Indicates whether entries from this template have income tax implications requiring coordination with tax accounting and reporting.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the recurring entry template including its purpose, business rationale, and any special instructions for processing.' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usaliCategory rdf:type rdf:Property ;
    rdfs:label 'Usali Category' ;
    rdfs:comment 'USALI financial statement category or line item that this recurring entry impacts (e.g., Rooms Revenue, F&B Cost of Sales, GOP, EBITDA).' ;
    rdfs:domain ind:RecurringEntryTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRuleSetId rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Set Id' ;
    rdfs:comment 'Reference to the predefined set of allocation rules and parameters applied in this run.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRuleSet .

ind:approvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved this allocation run for execution, ensuring segregation of duties.' ;
    rdfs:domain ind:AllocationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reversedRunId rdf:type rdf:Property ;
    rdfs:label 'Reversed Run Id' ;
    rdfs:comment 'Reference to the original allocation run that this run is reversing. Populated only when reversal_flag is True.' ;
    rdfs:domain ind:AllocationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRun .

ind:sourceCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Source Cost Center Id' ;
    rdfs:comment 'Reference to the originating cost center from which costs are being allocated.' ;
    rdfs:domain ind:AllocationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'The accounting period in YYYY-MM format for which allocations are being processed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Execution Timestamp' ;
    rdfs:comment 'The actual date and time when the allocation run processing was initiated.' ;
    rdfs:domain ind:AllocationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'Detailed description of the allocation basis or driver used for cost distribution (e.g., occupied room nights, revenue percentage, employee count, square footage).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationLineCount rdf:type rdf:Property ;
    rdfs:label 'Allocation Line Count' ;
    rdfs:comment 'The total number of individual allocation line items generated in this run.' ;
    rdfs:domain ind:AllocationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Indicates whether this allocation run was executed automatically by the system (True) or manually triggered by a user (False).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Execution Date' ;
    rdfs:comment 'The planned date for executing this allocation run as part of the monthly close calendar.' ;
    rdfs:domain ind:AllocationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetCostCenterCount rdf:type rdf:Property ;
    rdfs:label 'Target Cost Center Count' ;
    rdfs:comment 'The number of distinct cost centers or departments that received allocated costs in this run.' ;
    rdfs:domain ind:AllocationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAmountAllocated rdf:type rdf:Property ;
    rdfs:label 'Total Amount Allocated' ;
    rdfs:comment 'The total monetary value of costs distributed in this allocation run across all target cost centers or departments.' ;
    rdfs:domain ind:AllocationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorPartyId rdf:type rdf:Property ;
    rdfs:label 'Operator Party Id' ;
    rdfs:comment 'Identifier of the hotel operator party responsible for managing the property under this agreement.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Financial accounting standard framework required for property financial reporting under the contract, such as USALI, US GAAP, or IFRS.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of formal amendments or modifications executed since the original contract signing.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Assignment Rights Flag' ;
    rdfs:comment 'Indicates whether either party has the right to assign or transfer the contract to a third party without consent.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether the owner has contractual rights to audit the operators books and records related to property operations and fee calculations.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseManagementFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Base Management Fee Percentage' ;
    rdfs:comment 'Percentage of gross operating revenue or other defined base that the operator receives as base management fee under the contract terms.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Authority' ;
    rdfs:comment 'Party or governance structure with authority to approve annual operating budgets and capital expenditure plans for the property.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalExpenditureReservePercentage rdf:type rdf:Property ;
    rdfs:label 'Capital Expenditure Reserve Percentage' ;
    rdfs:comment 'Percentage of gross revenue required to be set aside annually for capital expenditure and furniture, fixtures, and equipment (FF&E) reserves.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Period Years' ;
    rdfs:comment 'Duration in years that confidentiality obligations survive after contract termination or expiration.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractNotes rdf:type rdf:Property ;
    rdfs:label 'Contract Notes' ;
    rdfs:comment 'Free-form text field for additional notes, special provisions, or contextual information about the hotel management agreement contract.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Primary method specified in the contract for resolving disputes between owner and operator parties.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Calculation Basis' ;
    rdfs:comment 'The financial metric or basis upon which management fees are calculated, such as gross operating revenue, gross operating profit, or adjusted gross operating profit.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause Flag' ;
    rdfs:comment 'Indicates whether the contract includes force majeure provisions that excuse performance obligations during extraordinary events beyond parties control.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law specified in the contract for dispute resolution and contract interpretation.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Incentive Fee Percentage' ;
    rdfs:comment 'Percentage of gross operating profit (GOP) or adjusted gross operating profit (AGOP) that the operator receives as incentive fee when performance thresholds are met.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indemnificationCapAmount rdf:type rdf:Property ;
    rdfs:label 'Indemnification Cap Amount' ;
    rdfs:comment 'Maximum liability amount for indemnification obligations between parties under the contract terms, if capped.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Insurance Responsibility' ;
    rdfs:comment 'Party responsible for procuring and maintaining required property and liability insurance coverage under the contract.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAnnualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Annual Fee Amount' ;
    rdfs:comment 'Guaranteed minimum annual management fee amount payable to the operator regardless of property performance, if applicable.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonCompetePeriodYears rdf:type rdf:Property ;
    rdfs:label 'Non Compete Period Years' ;
    rdfs:comment 'Duration in years of non-compete restrictions applicable to parties after contract termination, if specified.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceTestFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Test Flag' ;
    rdfs:comment 'Indicates whether the contract includes performance test provisions that allow the owner to terminate if specified performance metrics are not met.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionYears rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Years' ;
    rdfs:comment 'Duration in years of each renewal option period if the contract is extended.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Required frequency for financial and operational reporting from operator to owner under the contract terms.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termYears rdf:type rdf:Property ;
    rdfs:label 'Term Years' ;
    rdfs:comment 'Initial term duration of the hotel management agreement contract expressed in years.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Working Capital Amount' ;
    rdfs:comment 'Initial working capital amount required to be provided or maintained for property operations under the contract terms.' ;
    rdfs:domain ind:HmaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Primary key for storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Security classification defining who has authorized access to this storage location for inventory control and loss prevention.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date from which this storage location became operational and available for inventory storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeUntilDate rdf:type rdf:Property ;
    rdfs:label 'Active Until Date' ;
    rdfs:comment 'Date until which this storage location is scheduled to remain operational. Null for indefinite operation.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allergenSegregationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Segregation Required Flag' ;
    rdfs:comment 'Indicates whether this location requires allergen segregation protocols to prevent cross-contamination per food safety standards.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Barcode identifier used for scanning and tracking inventory movements to and from this storage location.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingName rdf:type rdf:Property ;
    rdfs:label 'Building Name' ;
    rdfs:comment 'Name of the building or structure where the storage location is situated within the property.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Capacity Cubic Meters' ;
    rdfs:comment 'Total storage capacity of the location measured in cubic meters for space planning and inventory management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when this storage location was permanently decommissioned and removed from active inventory use.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Business reason for decommissioning this storage location (e.g., renovation, consolidation, safety concerns).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Approved Flag' ;
    rdfs:comment 'Indicates whether this storage location is approved for storing hazardous materials such as cleaning chemicals per safety regulations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name of the storage location (e.g., Main Kitchen Dry Storage, Bar Cooler 1, Banquet Freezer).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage location based on storage conditions and purpose.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryUseDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Use Description' ;
    rdfs:comment 'Detailed description of the primary intended use and contents of this storage location for operational reference.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'RFID tag identifier for automated inventory tracking and access control at this storage location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCategory rdf:type rdf:Property ;
    rdfs:label 'Storage Category' ;
    rdfs:comment 'Primary category of items stored in this location for inventory segregation and food safety compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Max Celsius' ;
    rdfs:comment 'Maximum target temperature in Celsius for temperature-controlled storage locations to maintain food safety standards.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Min Celsius' ;
    rdfs:comment 'Minimum target temperature in Celsius for temperature-controlled storage locations to maintain food safety standards.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Counter Employee Id' ;
    rdfs:comment 'Reference to the employee who performed the physical count, ensuring accountability and traceability.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentCountId rdf:type rdf:Property ;
    rdfs:label 'Parent Count Id' ;
    rdfs:comment 'Reference to the original physical count if this record represents a recount or follow-up count, establishing the audit trail.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PhysicalCount .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Reference to the supervisor or manager who reviewed and approved the physical count results.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentPosted rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted' ;
    rdfs:comment 'Indicates whether the inventory adjustments resulting from this physical count have been posted to the general ledger and inventory system (True if posted).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentPostedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Timestamp' ;
    rdfs:comment 'The date and time when the inventory adjustments were posted to the financial and inventory systems.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentRequired rdf:type rdf:Property ;
    rdfs:label 'Adjustment Required' ;
    rdfs:comment 'Indicates whether inventory adjustments are required to reconcile the physical count with the system book quantities (True if variances exist and adjustments are needed).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceVerified rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified' ;
    rdfs:comment 'Indicates whether the physical count procedures and results have been verified for compliance with ISO 22000 food safety standards and USALI reporting requirements (True if verified).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The business date (day-level) on which the physical count was performed, used for period-end reporting and financial close alignment.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'The precise date and time when the physical count activity was completed, marking the end of the inventory freeze period.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'The method used to perform the physical count: manual (visual count and paper recording), barcode_scan (handheld scanner), rfid (radio frequency identification), weight_scale (automated weighing), hybrid (combination of methods).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Business identifier for the physical count event, typically formatted as PC-YYYYMMDD-NNNN for traceability and audit purposes.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countReason rdf:type rdf:Property ;
    rdfs:label 'Count Reason' ;
    rdfs:comment 'The business reason or trigger for this physical count event (e.g., Month-end close, Annual audit, Suspected theft, System migration, New outlet opening).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'The precise date and time when the physical count activity began, marking the start of the inventory freeze period.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the physical count event: scheduled (planned but not started), in_progress (counting underway), completed (count finished, pending review), approved (verified and accepted), rejected (discrepancies require recount), cancelled (count aborted).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the physical count: full (complete inventory), partial (selected items), cycle (scheduled rotation), spot (random check), variance_recount (follow-up after discrepancy), opening (new outlet), closing (outlet shutdown).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemIntegration rdf:type rdf:Property ;
    rdfs:label 'Pos System Integration' ;
    rdfs:comment 'The POS system from which inventory consumption data is sourced for variance analysis: oracle_micros (Oracle Hospitality MICROS), simphony (Oracle MICROS Simphony), opera (Oracle OPERA Property Management), manual (no system integration), other (third-party system).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountReason rdf:type rdf:Property ;
    rdfs:label 'Recount Reason' ;
    rdfs:comment 'Explanation for why a recount was required, such as variance exceeds threshold, counting errors detected, or supervisor challenge.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountRequired rdf:type rdf:Property ;
    rdfs:label 'Recount Required' ;
    rdfs:comment 'Indicates whether a recount is required due to significant variances, procedural errors, or supervisor review findings (True if recount needed).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalItemsCounted rdf:type rdf:Property ;
    rdfs:label 'Total Items Counted' ;
    rdfs:comment 'The total number of distinct inventory items (SKUs) included in this physical count event.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVarianceItems rdf:type rdf:Property ;
    rdfs:label 'Total Variance Items' ;
    rdfs:comment 'The number of inventory items where the physical count differed from the system book quantity, requiring investigation.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVarianceValue rdf:type rdf:Property ;
    rdfs:label 'Total Variance Value' ;
    rdfs:comment 'The aggregate monetary value of all inventory variances (positive and negative) identified during the physical count, used for shrinkage and loss analysis.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance value expressed as a percentage of the total book inventory value, used as a key performance indicator for inventory accuracy.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mergedIntoHouseholdId rdf:type rdf:Property ;
    rdfs:label 'Merged Into Household Id' ;
    rdfs:comment 'Reference to the target household ID if this household record has been merged into another household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:preferredPropertyId rdf:type rdf:Property ;
    rdfs:label 'Preferred Property Id' ;
    rdfs:comment 'Reference to the property most frequently visited or designated as preferred by the household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'External identifier linking this household to the corresponding account in the CRM system (e.g., Salesforce).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdName rdf:type rdf:Property ;
    rdfs:label 'Household Name' ;
    rdfs:comment 'The name or label assigned to the household for identification purposes.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle status of the household record (active, inactive, merged into another household, or archived).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Classification of the household structure (e.g., family, couple, single traveler, group, corporate).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergeDate rdf:type rdf:Property ;
    rdfs:label 'Merge Date' ;
    rdfs:comment 'Date when this household record was merged into another household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address for household communications and correspondence.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary contact phone number for the household.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To Employee Id' ;
    rdfs:comment 'Reference to the housekeeping staff member or maintenance technician assigned to complete this work order.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedToTeamId rdf:type rdf:Property ;
    rdfs:label 'Assigned To Team Id' ;
    rdfs:comment 'Reference to the housekeeping team assigned to this work order when team-based assignments are used.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:inspectedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspected By Employee Id' ;
    rdfs:comment 'Reference to the supervisor or quality assurance staff member who performed the inspection of the completed work order.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:maintenanceRequestId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Request Id' ;
    rdfs:comment 'Reference to the maintenance request created as a result of issues identified during this housekeeping work order.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceRequest .

ind:requestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requested By Employee Id' ;
    rdfs:comment 'Reference to the employee who initiated or requested this work order, typically a supervisor, front desk agent, or guest services representative.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Time' ;
    rdfs:comment 'The actual timestamp when the work order was completed by the assigned staff member, used for calculating service duration and labor costs.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:amenityReplenishmentRequired rdf:type rdf:Property ;
    rdfs:label 'Amenity Replenishment Required' ;
    rdfs:comment 'Boolean flag indicating whether guest amenities (toiletries, coffee, water) need to be replenished during this service.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestRequestNotes rdf:type rdf:Property ;
    rdfs:label 'Guest Request Notes' ;
    rdfs:comment 'Notes capturing specific requests made by the guest related to this work order, such as extra towels, hypoallergenic products, or do-not-disturb preferences.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Time' ;
    rdfs:comment 'The timestamp when the completed work was inspected by a supervisor or quality assurance team member.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linenChangeRequired rdf:type rdf:Property ;
    rdfs:label 'Linen Change Required' ;
    rdfs:comment 'Boolean flag indicating whether full linen change (sheets, pillowcases, towels) is required for this work order, used for linen inventory planning.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceHandoffRequired rdf:type rdf:Property ;
    rdfs:label 'Maintenance Handoff Required' ;
    rdfs:comment 'Boolean flag indicating whether this work order identified issues requiring handoff to the maintenance department, such as broken fixtures or equipment malfunctions.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Time' ;
    rdfs:comment 'The target timestamp by which the work order should be completed, often driven by guest check-in times or operational deadlines.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplyCostAmount rdf:type rdf:Property ;
    rdfs:label 'Supply Cost Amount' ;
    rdfs:comment 'The total cost of housekeeping supplies and amenities consumed during this work order, including linens, toiletries, and cleaning materials, used for CPOR tracking.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vipService rdf:type rdf:Property ;
    rdfs:label 'Vip Service' ;
    rdfs:comment 'Boolean flag indicating whether this work order is for a VIP guest requiring enhanced service standards, premium amenities, or special attention.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the work order indicating the nature of service required: routine cleaning, deep cleaning, quality inspection, maintenance handoff, turndown service, or mid-stay refresh.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Communication Template Id' ;
    rdfs:comment 'Primary key for communication_template' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aBTestEnabled rdf:type rdf:Property ;
    rdfs:label 'A B Test Enabled' ;
    rdfs:comment 'Indicates whether this template is part of an A/B testing experiment.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aBTestVariant rdf:type rdf:Property ;
    rdfs:label 'A B Test Variant' ;
    rdfs:comment 'Identifies which variant this template represents in an A/B test.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToActionText rdf:type rdf:Property ;
    rdfs:label 'Call To Action Text' ;
    rdfs:comment 'Primary call-to-action button or link text in the template.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToActionUrl rdf:type rdf:Property ;
    rdfs:label 'Call To Action Url' ;
    rdfs:comment 'Target URL for the primary call-to-action link.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceApproved rdf:type rdf:Property ;
    rdfs:label 'Compliance Approved' ;
    rdfs:comment 'Indicates whether the template has been reviewed and approved for regulatory compliance.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designVersion rdf:type rdf:Property ;
    rdfs:label 'Design Version' ;
    rdfs:comment 'Version number of the template design for change tracking.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:footerText rdf:type rdf:Property ;
    rdfs:label 'Footer Text' ;
    rdfs:comment 'Standard footer text including legal disclaimers, privacy policy links, and contact information.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htmlContent rdf:type rdf:Property ;
    rdfs:label 'Html Content' ;
    rdfs:comment 'HTML-formatted version of the template body for rich email rendering.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Date and time when the template was last used to send a communication.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mergeFields rdf:type rdf:Property ;
    rdfs:label 'Merge Fields' ;
    rdfs:comment 'Comma-separated list of available merge field placeholders for personalization (e.g., guest_name, property_name, reservation_number).' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled' ;
    rdfs:comment 'Indicates whether the template supports dynamic personalization with guest data merge fields.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plainTextContent rdf:type rdf:Property ;
    rdfs:label 'Plain Text Content' ;
    rdfs:comment 'Plain text version of the template body for fallback rendering and accessibility.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preheaderText rdf:type rdf:Property ;
    rdfs:label 'Preheader Text' ;
    rdfs:comment 'Preview text displayed in email client inbox before opening the email.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCriteria rdf:type rdf:Property ;
    rdfs:label 'Segment Criteria' ;
    rdfs:comment 'Target audience segment criteria or rules for this template (e.g., loyalty tier, booking history, geographic region).' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCategory rdf:type rdf:Property ;
    rdfs:label 'Template Category' ;
    rdfs:comment 'Business category classification of the template purpose.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unsubscribeLinkRequired rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Link Required' ;
    rdfs:comment 'Indicates whether an unsubscribe link must be included per regulatory requirements.' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the supplier contract or purchasing agreement governing this requisition line. Used for contract compliance tracking and pricing validation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementContract .

ind:deliveryAddressId rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Id' ;
    rdfs:comment 'Reference to the specific delivery address or receiving location within the property. May differ from the property main address for large resorts with multiple receiving points.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryAddress .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Reference to the capital project or Property Improvement Plan (PIP) project if this requisition line is part of a specific project initiative. Applicable primarily for CapEx procurement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Reference to the parent purchase requisition header that contains this line item.' ;
    rdfs:domain ind:RequisitionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:expenditureType rdf:type rdf:Property ;
    rdfs:label 'Expenditure Type' ;
    rdfs:comment 'Classification of the expenditure as Operating Expense (OpEx) for day-to-day operations or Capital Expenditure (CapEx) for Property Improvement Plan (PIP) projects and long-term assets.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External reference or tracking number from the source system or vendor. Used for cross-system reconciliation and vendor communication.' ;
    rdfs:domain ind:RequisitionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Logical deletion flag indicating whether this requisition line has been soft-deleted. Used for data retention and audit compliance without physical deletion.' ;
    rdfs:domain ind:RequisitionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'Remaining quantity yet to be received for this requisition line. Calculated as requisitioned quantity minus goods receipt quantity.' ;
    rdfs:domain ind:RequisitionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'High-level classification of the procurement spend category. Used for spend analytics, category management, and strategic sourcing initiatives.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Number' ;
    rdfs:comment 'Line number on the purchase order that corresponds to this requisition line. Used for traceability between requisition and purchase order.' ;
    rdfs:domain ind:RequisitionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Approved By User Code' ;
    rdfs:comment 'Identifier of the user who approved this payroll period for payment.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The calendar month number (1-12) in which this payroll period starts.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year in which this payroll period starts (e.g., 2024).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'The date printed on payroll checks or used for electronic payment transactions for this period.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Closed By User Code' ;
    rdfs:comment 'Identifier of the user or system account that closed this payroll period.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'The fiscal month number within the fiscal year (1-12).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter within the fiscal year (1, 2, 3, or 4).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Indicates whether this is a special adjustment or correction period (true) or a regular payroll period (false).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Year End Period' ;
    rdfs:comment 'Indicates whether this payroll period is the final period of the fiscal or calendar year (true/false).' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollGroupCode rdf:type rdf:Property ;
    rdfs:label 'Payroll Group Code' ;
    rdfs:comment 'Code identifying the payroll group or employee segment (e.g., hourly, salaried, executive, union) to which this period applies.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Business identifier code for the payroll period, typically used in payroll systems and reporting (e.g., PP202401, 2024-W01).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name or label for the payroll period (e.g., January 2024 - Period 1, Week Ending 2024-01-07).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential number of this payroll period within the fiscal or calendar year (e.g., 1-52 for weekly, 1-26 for bi-weekly, 1-12 for monthly).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the payroll period frequency (weekly, bi-weekly, semi-monthly, monthly, quarterly, annual).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing End Timestamp' ;
    rdfs:comment 'The date and time when payroll processing was completed for this period.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'The tax year to which this payroll period belongs for tax reporting purposes.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDaysCount rdf:type rdf:Property ;
    rdfs:label 'Total Days Count' ;
    rdfs:comment 'Total number of calendar days in this payroll period.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingDaysCount rdf:type rdf:Property ;
    rdfs:label 'Working Days Count' ;
    rdfs:comment 'Number of standard working days (typically Monday-Friday) within this payroll period, excluding holidays.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Reference to the specific asset or equipment that is the subject of the work order.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the person, team, or vendor responsible for executing the work order.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Budget or cost center code against which the work order costs are charged.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes documenting work performed, issues encountered, and final outcomes upon completion.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Compliance Flag' ;
    rdfs:comment 'Indicates whether the work order adheres to the terms, pricing, and service levels defined in the vendor contract.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Property department or cost center responsible for the work order (e.g., Engineering, Housekeeping, Food & Beverage).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Specific location within the property where work is to be performed (e.g., Room 305, Lobby, Kitchen).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCost rdf:type rdf:Property ;
    rdfs:label 'Material Cost' ;
    rdfs:comment 'Total cost of materials, parts, and supplies consumed in executing the work order.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedBy rdf:type rdf:Property ;
    rdfs:label 'Requested By' ;
    rdfs:comment 'Name or identifier of the person or department who initiated the work order request.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'Date when the work order was originally requested or initiated.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP S/4HANA MM module document number for integration and traceability with the ERP system.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCost rdf:type rdf:Property ;
    rdfs:label 'Service Cost' ;
    rdfs:comment 'Total cost of external services or contractor fees associated with the work order.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle status of the work order: draft, submitted, approved, in progress, on hold, completed, or cancelled.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorYearPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Year Period Id' ;
    rdfs:comment 'Reference to the corresponding fiscal period in the prior year. Used for year-over-year variance analysis and comparative financial reporting.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:businessDaysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Business Days In Period' ;
    rdfs:comment 'Total number of business days (excluding weekends and holidays) in this fiscal period. Used for operational metrics and productivity calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarQuarter rdf:type rdf:Property ;
    rdfs:label 'Calendar Quarter' ;
    rdfs:comment 'The calendar quarter number (1-4) in which the period starts. Used for calendar-based comparisons and external benchmarking.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'The actual date when the fiscal period was closed for transaction posting. Null if period is still open. Used for financial close tracking and SOX compliance.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Days In Period' ;
    rdfs:comment 'Total number of calendar days in this fiscal period. Used for daily average calculations (e.g., Average Daily Rate, Revenue Per Available Room).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalWeek rdf:type rdf:Property ;
    rdfs:label 'Fiscal Week' ;
    rdfs:comment 'The fiscal week number within the fiscal year (1-52 or 1-53). Null for non-weekly periods. Used for weekly operational and revenue reporting in hospitality operations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLeapYear rdf:type rdf:Property ;
    rdfs:label 'Is Leap Year' ;
    rdfs:comment 'Indicates whether this fiscal period falls within a leap year. True if leap year, False otherwise. Used for accurate daily average calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'The date when the fiscal period was locked and finalized. Null if period is not yet locked. Used for audit trail and financial statement finalization.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reopenDate rdf:type rdf:Property ;
    rdfs:label 'Reopen Date' ;
    rdfs:comment 'The date when a previously closed period was reopened for adjustments. Null if period has never been reopened. Used for audit trail and SOX compliance monitoring.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code used for financial reporting in this period (e.g., USD, EUR, GBP). Used for multi-currency consolidation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineId rdf:type rdf:Property ;
    rdfs:label 'Product Line Id' ;
    rdfs:comment 'Identifier linking the product to a broader product line or collection (e.g., signature wellness collection, luxury skincare line).' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductLine .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Standard retail or service price for the product in the property\'s base currency before discounts, taxes, or gratuities.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Booking Lead Time Hours' ;
    rdfs:comment 'Minimum advance notice required for booking this treatment, in hours.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gratuityEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Gratuity Eligible Flag' ;
    rdfs:comment 'Indicates whether the product is eligible for automatic or suggested gratuity calculations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryTrackedFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Tracked Flag' ;
    rdfs:comment 'Indicates whether the product requires inventory tracking (typically true for retail products, false for services).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'High-level classification of the product type within spa operations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Unique business identifier code for the spa product used in catalogs, point-of-sale systems, and inventory management.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Full name of the spa product, treatment, or retail item as displayed to guests and staff.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Detailed classification of the product within its category (e.g., massage, facial, body treatment, skincare, wellness supplement).' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockKeepingUnit rdf:type rdf:Property ;
    rdfs:label 'Stock Keeping Unit' ;
    rdfs:comment 'Unique inventory identifier for retail products used in warehouse and inventory management systems.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapistCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Therapist Certification Required' ;
    rdfs:comment 'Specific professional certification or training required for therapists to perform this treatment (e.g., licensed massage therapist, esthetician, aromatherapist).' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupBookingId rdf:type rdf:Property ;
    rdfs:label 'Group Booking Id' ;
    rdfs:comment 'Primary key for group_booking' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAddress rdf:type rdf:Property ;
    rdfs:label 'Billing Address' ;
    rdfs:comment 'Full billing address for invoicing and payment processing for the group booking.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingName rdf:type rdf:Property ;
    rdfs:label 'Booking Name' ;
    rdfs:comment 'Descriptive name or title for the group booking, typically reflecting the event, organization, or purpose of the group visit.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingType rdf:type rdf:Property ;
    rdfs:label 'Booking Type' ;
    rdfs:comment 'Classification of the group booking based on the nature and purpose of the group visit.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'Reference link or storage location for the signed group booking contract document.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSpaceRequired rdf:type rdf:Property ;
    rdfs:label 'Event Space Required' ;
    rdfs:comment 'Indicates whether the group booking includes requirements for meeting rooms, ballrooms, or event spaces.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadGuestEmail rdf:type rdf:Property ;
    rdfs:label 'Lead Guest Email' ;
    rdfs:comment 'Primary email address of the lead guest for booking correspondence and confirmations.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadGuestName rdf:type rdf:Property ;
    rdfs:label 'Lead Guest Name' ;
    rdfs:comment 'Full name of the primary contact or lead guest responsible for the group booking.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadGuestPhone rdf:type rdf:Property ;
    rdfs:label 'Lead Guest Phone' ;
    rdfs:comment 'Primary contact phone number for the lead guest or group coordinator.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationRequired rdf:type rdf:Property ;
    rdfs:label 'Transportation Required' ;
    rdfs:comment 'Indicates whether the group requires transportation services such as airport transfers or shuttle services.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'Primary classification of the retail product by type of spa or wellness merchandise.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crueltyFree rdf:type rdf:Property ;
    rdfs:label 'Cruelty Free' ;
    rdfs:comment 'Indicates whether the product is certified as not tested on animals.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when the product was or will be removed from active sales, if applicable.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Height dimension of the product package in centimeters.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingredients rdf:type rdf:Property ;
    rdfs:label 'Ingredients' ;
    rdfs:comment 'List of ingredients or components contained in the product, particularly important for skincare and wellness items for allergy and regulatory compliance.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Length dimension of the product package in centimeters.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyPoints rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points' ;
    rdfs:comment 'Number of loyalty program points awarded to guests upon purchase of this product.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level' ;
    rdfs:comment 'Minimum inventory quantity threshold that triggers reorder alerts for the product.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organicCertified rdf:type rdf:Property ;
    rdfs:label 'Organic Certified' ;
    rdfs:comment 'Indicates whether the product has organic certification from a recognized certifying body.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalProduct rdf:type rdf:Property ;
    rdfs:label 'Seasonal Product' ;
    rdfs:comment 'Indicates whether the product is available only during specific seasons or holiday periods.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageRequirements rdf:type rdf:Property ;
    rdfs:label 'Storage Requirements' ;
    rdfs:comment 'Special storage conditions required for the product (e.g., refrigeration, temperature range, humidity control).' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vegan rdf:type rdf:Property ;
    rdfs:label 'Vegan' ;
    rdfs:comment 'Indicates whether the product contains no animal-derived ingredients or by-products.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Width dimension of the product package in centimeters.' ;
    rdfs:domain ind:RetailProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the legal entity was officially dissolved, liquidated, or ceased to exist. Null if entity is still active.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'Trade name or fictitious business name under which the entity operates, if different from legal name.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitySubtype rdf:type rdf:Property ;
    rdfs:label 'Entity Subtype' ;
    rdfs:comment 'More granular classification of entity structure (e.g., S-Corp, C-Corp, LLP, GP, LP) specific to jurisdiction.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndDay rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Day' ;
    rdfs:comment 'The day of the month (1-31) on which the legal entity\'s fiscal year ends.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'The month (1-12) in which the legal entity\'s fiscal year ends for financial reporting purposes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:franchiseeName rdf:type rdf:Property ;
    rdfs:label 'Franchisee Name' ;
    rdfs:comment 'Name of the franchisee organization or individual if this entity operates under a franchise model.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The official date on which the legal entity was incorporated or registered with the governing authority.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incorporationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Incorporation Jurisdiction' ;
    rdfs:comment 'The country, state, or province where the legal entity was originally incorporated or registered.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFranchiseEntity rdf:type rdf:Property ;
    rdfs:label 'Is Franchise Entity' ;
    rdfs:comment 'Indicates whether this legal entity operates under a franchise agreement rather than as a wholly-owned subsidiary.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPubliclyTraded rdf:type rdf:Property ;
    rdfs:label 'Is Publicly Traded' ;
    rdfs:comment 'Indicates whether the legal entity is publicly traded on a stock exchange.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The official registered legal name of the entity as it appears on incorporation documents and legal filings.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment '20-character ISO 17442 Legal Entity Identifier used for financial transaction reporting and regulatory compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit code classifying the primary business activity of the legal entity according to NAICS standards.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership held by the parent entity, if applicable. Represents equity stake in subsidiary relationships.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Id' ;
    rdfs:comment 'Reference to the parent legal entity if this entity is a subsidiary or controlled entity within a corporate hierarchy.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBusinessActivity rdf:type rdf:Property ;
    rdfs:label 'Primary Business Activity' ;
    rdfs:comment 'Textual description of the main business activities and operations conducted by the legal entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBusinessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Primary Business Address Line 1' ;
    rdfs:comment 'First line of the primary business operating address, which may differ from the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBusinessCity rdf:type rdf:Property ;
    rdfs:label 'Primary Business City' ;
    rdfs:comment 'City of the primary business operating address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBusinessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Business Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the primary business operating country.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line 1' ;
    rdfs:comment 'First line of the official registered address of the legal entity as filed with the incorporation authority.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line 2' ;
    rdfs:comment 'Second line of the registered address (suite, floor, building name) if applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official government-issued registration or incorporation number assigned to the legal entity by the jurisdiction of incorporation.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Four-digit code classifying the primary industry of the legal entity according to SIC standards.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchangeCode rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange Code' ;
    rdfs:comment 'Code identifying the primary stock exchange where the entity\'s securities are listed (e.g., NYSE, NASDAQ, LSE), if publicly traded.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker Symbol' ;
    rdfs:comment 'The ticker symbol under which the entity\'s stock is traded, if publicly traded.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ultimateParentEntityId rdf:type rdf:Property ;
    rdfs:label 'Ultimate Parent Entity Id' ;
    rdfs:comment 'Reference to the top-level parent entity in the corporate ownership structure, representing the ultimate controlling entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchName rdf:type rdf:Property ;
    rdfs:label 'Batch Name' ;
    rdfs:comment 'Descriptive name or title assigned to the GL batch to identify its purpose or content (e.g., \'Monthly Accruals - January 2024\', \'Payroll Posting - Week 12\').' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the GL batch: draft (being prepared), pending_approval (submitted for review), approved (authorized for posting), posted (committed to the general ledger), rejected (not approved), or cancelled (voided before posting).' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the GL batch based on its accounting purpose: standard (regular transactions), recurring (automated periodic entries), adjustment (correcting entries), accrual (period-end accruals), reversal (reversing prior entries), or closing (period/year-end closing entries).' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlTotal rdf:type rdf:Property ;
    rdfs:label 'Control Total' ;
    rdfs:comment 'Optional control total amount provided by the batch creator for validation purposes. Used to verify that the sum of batch entries matches the expected total before posting.' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryCount rdf:type rdf:Property ;
    rdfs:label 'Entry Count' ;
    rdfs:comment 'Total number of individual journal entries or line items contained within this GL batch. Used for validation and reconciliation purposes.' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalReference rdf:type rdf:Property ;
    rdfs:label 'External Reference' ;
    rdfs:comment 'External reference number or identifier from the source system or business process that originated this GL batch (e.g., invoice number, payroll run ID, bank statement reference). Used for cross-system reconciliation.' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBalanced rdf:type rdf:Property ;
    rdfs:label 'Is Balanced' ;
    rdfs:comment 'Indicates whether the GL batch is in balance (total debits equal total credits). True if balanced, False if out of balance. Out-of-balance batches cannot be posted.' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalBatchId rdf:type rdf:Property ;
    rdfs:label 'Original Batch Id' ;
    rdfs:comment 'Reference to the original GL batch that this batch reverses, if this is a reversal batch. Used to track the relationship between reversal entries and their original accruals. Null if this is not a reversal batch.' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postedBy rdf:type rdf:Property ;
    rdfs:label 'Posted By' ;
    rdfs:comment 'User ID or name of the person who posted the GL batch to the general ledger. Required for audit trail and SOX compliance. Null if batch has not been posted.' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurring Frequency' ;
    rdfs:comment 'For recurring batches, specifies the frequency at which the batch is automatically generated: daily, weekly, monthly, quarterly, or annually. Null for non-recurring batches.' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalBatchId rdf:type rdf:Property ;
    rdfs:label 'Reversal Batch Id' ;
    rdfs:comment 'Reference to the GL batch that reverses this batch, if applicable. Used to track the relationship between original accrual entries and their subsequent reversals. Null if batch has not been reversed.' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceModule rdf:type rdf:Property ;
    rdfs:label 'Source Module' ;
    rdfs:comment 'Specific module or sub-system within the source system that generated the batch (e.g., \'Accounts Payable\', \'Accounts Receivable\', \'Fixed Assets\', \'Payroll\').' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'Sum of all credit entries in the GL batch. Must equal total_debit_amount for the batch to be in balance per double-entry accounting principles.' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'Sum of all debit entries in the GL batch. Must equal total_credit_amount for the batch to be in balance per double-entry accounting principles.' ;
    rdfs:domain ind:GlBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationFrequency rdf:type rdf:Property ;
    rdfs:label 'Allocation Frequency' ;
    rdfs:comment 'The cadence at which this allocation rule set is executed in the financial close process.' ;
    rdfs:domain ind:AllocationRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Fixed percentage used for allocation when the allocation method is percentage-based. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:AllocationRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Id' ;
    rdfs:comment 'Reference to the approval workflow configuration that governs the review and approval process for allocations generated by this rule set.' ;
    rdfs:domain ind:AllocationRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUserId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Id' ;
    rdfs:comment 'Identifier of the user who approved this allocation rule set for active use in financial processing.' ;
    rdfs:domain ind:AllocationRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUserId rdf:type rdf:Property ;
    rdfs:label 'Created By User Id' ;
    rdfs:comment 'Identifier of the user who created this allocation rule set record in the system.' ;
    rdfs:domain ind:AllocationRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentFilter rdf:type rdf:Property ;
    rdfs:label 'Department Filter' ;
    rdfs:comment 'Comma-separated list or pattern of department codes to which this allocation rule set applies. Used to scope the rule set to specific departments.' ;
    rdfs:domain ind:AllocationRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceId rdf:type rdf:Property ;
    rdfs:label 'External Reference Id' ;
    rdfs:comment 'External system identifier or reference number for this allocation rule set used for integration and reconciliation with source financial systems.' ;
    rdfs:domain ind:AllocationRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountFilter rdf:type rdf:Property ;
    rdfs:label 'Gl Account Filter' ;
    rdfs:comment 'Comma-separated list or pattern of GL account codes to which this allocation rule set applies. Used to scope the rule set to specific account ranges.' ;
    rdfs:domain ind:AllocationRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReciprocalAllocation rdf:type rdf:Property ;
    rdfs:label 'Is Reciprocal Allocation' ;
    rdfs:comment 'Boolean flag indicating whether this rule set supports reciprocal allocation where departments can allocate costs to each other iteratively.' ;
    rdfs:domain ind:AllocationRuleSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Id' ;
    rdfs:comment 'Identifier of the user who most recently modified this allocation rule set record.' ;
