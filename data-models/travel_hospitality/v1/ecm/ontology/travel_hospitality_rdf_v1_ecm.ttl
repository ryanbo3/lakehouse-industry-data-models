    rdfs:comment 'Indicates whether this equipment requires periodic safety certification or inspection.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Service Contract Number' ;
    rdfs:comment 'Reference number for the maintenance service contract covering this equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Service Interval Days' ;
