    rdfs:comment 'The maximum number of guests allowed to register for this class based on facility capacity and safety requirements.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberPrice rdf:type rdf:Property ;
    rdfs:label 'Member Price' ;
    rdfs:comment 'The discounted price offered to loyalty program members or spa membership holders.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumParticipants rdf:type rdf:Property ;
    rdfs:label 'Minimum Participants' ;
    rdfs:comment 'The minimum number of registered guests required for the class to proceed; classes below this threshold may be cancelled.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
