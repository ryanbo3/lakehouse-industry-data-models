ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Description of corrective actions required to address violations or deficiencies identified during the last inspection.' ;
    rdfs:domain ind:TravelHospitality ;
