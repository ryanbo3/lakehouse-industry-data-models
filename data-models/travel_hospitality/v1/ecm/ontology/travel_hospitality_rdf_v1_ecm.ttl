ind:attritionAmount rdf:type rdf:Property ;
    rdfs:label 'Attrition Amount' ;
    rdfs:comment 'Monetary penalty or fee amount charged if the group fails to meet the contracted room pickup threshold. Calculated based on attrition percentage and contracted value.' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attritionPercentage rdf:type rdf:Property ;
    rdfs:label 'Attrition Percentage' ;
    rdfs:comment 'Contractual attrition threshold percentage. If pickup falls below this percentage of contracted rooms, the group may incur attrition fees or penalties.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableRoomCount rdf:type rdf:Property ;
    rdfs:label 'Available Room Count' ;
    rdfs:comment 'Number of rooms still available for pickup within the group block. Calculated as contracted minus picked up.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockCode rdf:type rdf:Property ;
    rdfs:label 'Block Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the group room block for reservation booking and tracking. Used by guests and agents to access group rates.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockEndDate rdf:type rdf:Property ;
    rdfs:label 'Block End Date' ;
    rdfs:comment 'Last night of the group room block allocation period. Represents the latest departure date for group attendees.' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockName rdf:type rdf:Property ;
    rdfs:label 'Block Name' ;
    rdfs:comment 'Descriptive name of the group room block, typically including the event or organization name.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockNotes rdf:type rdf:Property ;
    rdfs:label 'Block Notes' ;
    rdfs:comment 'Internal operational notes and comments related to the group room block management. Used for communication between sales, reservations, and operations teams.' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockReleasePolicy rdf:type rdf:Property ;
    rdfs:label 'Block Release Policy' ;
    rdfs:comment 'Policy governing how unused rooms are released back to general inventory. Automatic releases at cutoff date, manual requires explicit action, rolling releases incrementally, none retains all rooms until event end.' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockStartDate rdf:type rdf:Property ;
    rdfs:label 'Block Start Date' ;
    rdfs:comment 'First night of the group room block allocation period. Represents the earliest arrival date for group attendees.' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockStatus rdf:type rdf:Property ;
    rdfs:label 'Block Status' ;
    rdfs:comment 'Current lifecycle status of the group room block. Tentative indicates preliminary hold, definite indicates contracted commitment, actual indicates active pickup phase, cancelled indicates terminated block, waitlist indicates overflow demand, released indicates inventory returned to general availability.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingSourceCode rdf:type rdf:Property ;
    rdfs:label 'Booking Source Code' ;
    rdfs:comment 'Code identifying the channel or source through which the group block was booked (e.g., DIRECT, GDS, OTA, THIRD_PARTY_PLANNER).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complimentaryRoomCount rdf:type rdf:Property ;
    rdfs:label 'Complimentary Room Count' ;
    rdfs:comment 'Number of complimentary (free) rooms provided to the group as part of the contract negotiation. Typically based on a ratio of paid rooms (e.g., 1 comp per 50 paid).' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedRoomCount rdf:type rdf:Property ;
    rdfs:label 'Contracted Room Count' ;
    rdfs:comment 'Total number of rooms contracted in the group block for this room type. Represents the commitment between the property and the group organizer.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cutoffDate rdf:type rdf:Property ;
    rdfs:label 'Cutoff Date' ;
    rdfs:comment 'Date by which the group must pick up their contracted room block or release unused rooms back to general inventory. Critical for revenue management and inventory control.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Deposit Required Flag' ;
    rdfs:comment 'Indicates whether a deposit is required to secure the group room block.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedTotalRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Revenue' ;
    rdfs:comment 'Estimated total room revenue for this group block if fully picked up. Calculated as total_room_nights multiplied by group_rate_amount. Used for group pace reporting and revenue forecasting.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupRateAmount rdf:type rdf:Property ;
    rdfs:label 'Group Rate Amount' ;
    rdfs:comment 'Negotiated nightly room rate for this group block, excluding taxes and fees. Represents the group ADR (Average Daily Rate) for revenue analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who last modified the group room block record. Audit trail for accountability.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerCode rdf:type rdf:Property ;
    rdfs:label 'Owner Code' ;
    rdfs:comment 'Code identifying the sales manager, event coordinator, or staff member responsible for managing this group block.' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedUpRoomCount rdf:type rdf:Property ;
    rdfs:label 'Picked Up Room Count' ;
    rdfs:comment 'Current number of rooms actually reserved by group attendees against this block. Used to calculate pickup-to-block ratio and attrition risk.' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupToBlockRatio rdf:type rdf:Property ;
    rdfs:label 'Pickup To Block Ratio' ;
    rdfs:comment 'Percentage of contracted rooms that have been picked up by group attendees. Key performance metric for group pace analysis and attrition risk assessment. Calculated as (picked_up_room_count / contracted_room_count) * 100.' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the group rate amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'Percentage rebate or kickback paid to the group organizer based on total room revenue generated. Common in association and corporate group contracts.' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shoulderDatesAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Shoulder Dates Allowed Flag' ;
    rdfs:comment 'Indicates whether group attendees are permitted to book rooms at the group rate on dates outside the official block period (shoulder nights).' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:syncedToCrsTimestamp rdf:type rdf:Property ;
    rdfs:label 'Synced To Crs Timestamp' ;
    rdfs:comment 'Date and time when the group room block was last synchronized to the Central Reservation System (Sabre SynXis CRS) for distribution and rate availability.' ;
    rdfs:domain ind:EventGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalRoomNights rdf:type rdf:Property ;
    rdfs:label 'Total Room Nights' ;
    rdfs:comment 'Total number of room nights represented by this group block. Calculated as contracted_room_count multiplied by the number of nights in the block period. Key metric for group revenue contribution analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientAccountId rdf:type rdf:Property ;
    rdfs:label 'Client Account Id' ;
    rdfs:comment 'Reference to the corporate or individual client account being billed for the event. Links to the party responsible for payment.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:offerRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Offer Redemption Id' ;
    rdfs:comment 'Foreign key linking to marketing.offer_redemption. Business justification: Event invoices include redeemed promotional offers and campaign discounts that must be reconciled for accurate revenue recognition and offer performance tracking. Essential for discount validation, re' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfferRedemption .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Total amount that has been paid against this invoice to date. Used to track partial payments and outstanding balance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arPostingReference rdf:type rdf:Property ;
    rdfs:label 'Ar Posting Reference' ;
    rdfs:comment 'Reference number or identifier for the corresponding accounts receivable ledger entry in the finance system (SAP S/4HANA AR). Used for cross-domain reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avEquipmentAmount rdf:type rdf:Property ;
    rdfs:label 'Av Equipment Amount' ;
    rdfs:comment 'Revenue from audio-visual equipment rental and technical services provided for the event.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the billing contact for invoice delivery and payment correspondence.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Full name of the primary contact person for billing and payment inquiries related to this invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'Phone number of the billing contact for payment-related inquiries.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the period covered by this invoice. Typically the last day of the event or the end of the service period.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this invoice. Typically the first day of the event or the start of the service period.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date when the invoice was flagged as disputed by the client or internally.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Description of the reason for dispute if the invoice status is disputed. Captures client objections or billing discrepancies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fbRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Fb Revenue Amount' ;
    rdfs:comment 'Total revenue from food and beverage services provided during the event. Includes catering, banquet meals, and beverage packages.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the event invoice. Tracks progression from draft through payment and any exceptions. [ENUM-REF-CANDIDATE: draft|issued|sent|paid|partially_paid|overdue|disputed|cancelled|void — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:miscellaneousChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Miscellaneous Charges Amount' ;
    rdfs:comment 'Revenue from other event-related charges not categorized elsewhere, such as decor, entertainment, special services, or incidentals.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Calculated as total_amount_due minus amount_paid.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method by which the client is expected to or has made payment for this invoice.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when full or final payment was received for this invoice. Null if invoice remains unpaid or partially paid.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when a disputed invoice was resolved and moved back to an active billing status.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roomRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Room Revenue Amount' ;
    rdfs:comment 'Total revenue from group room block pickups associated with this event. Represents accommodation charges for event attendees.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spaceRentalAmount rdf:type rdf:Property ;
    rdfs:label 'Space Rental Amount' ;
    rdfs:comment 'Revenue from rental of meeting rooms, ballrooms, and other function spaces used for the event.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all revenue line items before taxes and service charges are applied.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'Final total amount due on the invoice after all charges, taxes, and service charges are applied. This is the amount the client is expected to pay.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventRevenueId rdf:type rdf:Property ;
    rdfs:label 'Event Revenue Id' ;
    rdfs:comment 'Unique identifier for the event revenue record. Primary key for this transactional revenue fact.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fnbRevenueCenterId rdf:type rdf:Property ;
    rdfs:label 'Fnb Revenue Center Id' ;
    rdfs:comment 'Foreign key linking to fnb.revenue_center. Business justification: Event F&B revenue must be allocated to proper F&B revenue centers for USALI-compliant financial reporting, departmental P&L analysis, cost center tracking, and performance management. Critical for hot' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueCenter .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Event revenue recognition posts to general ledger via journal entries. Auditors trace event revenue to GL for SOX compliance, revenue recognition standard (ASC 606) validation, and financial statement' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual revenue amount recognized for this category on this date, in the property\'s base currency.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'The amount of any revenue adjustment applied (positive for additions, negative for reductions).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Reason for any revenue adjustment or correction applied to this line (e.g., discount, refund, billing correction, service recovery).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Number of attendees at the event, used to calculate per-person revenue metrics and analyze event profitability.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedAmount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Amount' ;
    rdfs:comment 'The budgeted or forecasted revenue amount for this category on this date, used for variance analysis.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'The type of MICE event that generated this revenue (meeting, conference, wedding, banquet, exhibition, incentive trip, etc.).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionSpaceCode rdf:type rdf:Property ;
    rdfs:label 'Function Space Code' ;
    rdfs:comment 'Code identifying the function space or meeting room where this event took place and revenue was generated.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupAdr rdf:type rdf:Property ;
    rdfs:label 'Group Adr' ;
    rdfs:comment 'Average Daily Rate for group room nights associated with this event. Calculated as group room revenue divided by group room nights.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupRoomNights rdf:type rdf:Property ;
    rdfs:label 'Group Room Nights' ;
    rdfs:comment 'Number of group room nights associated with this event revenue, used to calculate group ADR (Average Daily Rate) contribution.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isVoided rdf:type rdf:Property ;
    rdfs:label 'Is Voided' ;
    rdfs:comment 'Boolean flag indicating whether this revenue line has been voided or reversed. True if voided, False if active.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perAttendee rdf:type rdf:Property ;
    rdfs:label 'Per Attendee' ;
    rdfs:comment 'Average revenue generated per event attendee. Calculated as total event revenue divided by attendee count.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date this revenue was posted to the general ledger in the financial system.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'The accounting method used to recognize this revenue (accrual basis, cash basis, or deferred revenue).' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Date' ;
    rdfs:comment 'The business date on which this revenue was recognized per USALI revenue recognition standards. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueSource rdf:type rdf:Property ;
    rdfs:label 'Revenue Source' ;
    rdfs:comment 'The channel or source through which this event revenue was generated (direct booking, OTA, GDS, corporate account, group sales).' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revparContribution rdf:type rdf:Property ;
    rdfs:label 'Revpar Contribution' ;
    rdfs:comment 'The contribution of this event\'s group room revenue to the property\'s overall RevPAR (Revenue Per Available Room) metric.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trevparContribution rdf:type rdf:Property ;
    rdfs:label 'Trevpar Contribution' ;
    rdfs:comment 'The contribution of this event\'s total revenue (rooms plus F&B plus other) to the property\'s TRevPAR (Total Revenue Per Available Room) metric.' ;
    rdfs:domain ind:EventRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The variance between actual and budgeted revenue (actual minus budgeted). Positive indicates revenue overperformance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Reason provided for voiding this revenue line (e.g., billing error, event cancellation, duplicate entry).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Void Timestamp' ;
    rdfs:comment 'Timestamp when this revenue line was voided. Null if the line has not been voided.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:functionSpaceId rdf:type rdf:Property ;
    rdfs:label 'Function Space Id' ;
    rdfs:comment 'Unique identifier for the function space. Primary key.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionSpace .

ind:accessibilityCompliant rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliant' ;
    rdfs:comment 'Indicates whether the function space meets ADA (Americans with Disabilities Act) accessibility requirements including wheelchair access, ramps, and accessible restrooms.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:avInfrastructure rdf:type rdf:Property ;
    rdfs:label 'Av Infrastructure' ;
    rdfs:comment 'Description of built-in AV equipment and infrastructure including screens, projectors, sound systems, lighting rigs, and control systems.' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityBanquet rdf:type rdf:Property ;
    rdfs:label 'Capacity Banquet' ;
    rdfs:comment 'Maximum guest capacity when the space is configured for banquet-style seating (round tables with chairs).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityCabaret rdf:type rdf:Property ;
    rdfs:label 'Capacity Cabaret' ;
    rdfs:comment 'Maximum guest capacity when the space is configured in cabaret-style seating (round tables with chairs on three sides only).' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityClassroom rdf:type rdf:Property ;
    rdfs:label 'Capacity Classroom' ;
    rdfs:comment 'Maximum guest capacity when the space is configured in classroom-style seating (rows of tables and chairs).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityHollowSquare rdf:type rdf:Property ;
    rdfs:label 'Capacity Hollow Square' ;
    rdfs:comment 'Maximum guest capacity when the space is configured in hollow square seating (tables arranged in square formation).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityReception rdf:type rdf:Property ;
    rdfs:label 'Capacity Reception' ;
    rdfs:comment 'Maximum guest capacity when the space is configured for reception-style standing events (cocktail, networking).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityTheater rdf:type rdf:Property ;
    rdfs:label 'Capacity Theater' ;
    rdfs:comment 'Maximum guest capacity when the space is configured in theater-style seating (rows of chairs facing front).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUShape rdf:type rdf:Property ;
    rdfs:label 'Capacity U Shape' ;
    rdfs:comment 'Maximum guest capacity when the space is configured in U-shape seating (tables arranged in U formation).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cateringKitchenAccess rdf:type rdf:Property ;
    rdfs:label 'Catering Kitchen Access' ;
    rdfs:comment 'Indicates whether the function space has direct access to a catering kitchen or prep area for Food and Beverage (F&B) service.' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceilingHeightFeet rdf:type rdf:Property ;
    rdfs:label 'Ceiling Height Feet' ;
    rdfs:comment 'Height of the ceiling in feet, critical for AV setup, lighting design, and event feasibility assessment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateControl rdf:type rdf:Property ;
    rdfs:label 'Climate Control' ;
    rdfs:comment 'Type of climate control system available in the function space for temperature and air quality management.' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisible rdf:type rdf:Property ;
    rdfs:label 'Divisible' ;
    rdfs:comment 'Indicates whether the function space can be divided into smaller sub-spaces using partitions or airwalls.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Physical floor or level where the function space is located within the property (e.g., Ground Floor, Mezzanine, 2nd Floor, Rooftop).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internetConnectivity rdf:type rdf:Property ;
    rdfs:label 'Internet Connectivity' ;
    rdfs:comment 'Type of internet connectivity available in the function space for event attendees and organizers.' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naturalLightAvailable rdf:type rdf:Property ;
    rdfs:label 'Natural Light Available' ;
    rdfs:comment 'Indicates whether the function space has natural daylight through windows, skylights, or outdoor exposure.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational availability status of the function space for booking and event allocation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outdoorSpace rdf:type rdf:Property ;
    rdfs:label 'Outdoor Space' ;
    rdfs:comment 'Indicates whether the function space is an outdoor venue or has outdoor components (terrace, garden, rooftop).' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partitionConfiguration rdf:type rdf:Property ;
    rdfs:label 'Partition Configuration' ;
    rdfs:comment 'Description of how the space can be divided, including the number of sub-spaces and their names (e.g., Ballroom A, B, C).' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentalRateFullDay rdf:type rdf:Property ;
    rdfs:label 'Rental Rate Full Day' ;
    rdfs:comment 'Standard rental rate for booking the function space for a full day (typically 8-12 hours), in property base currency.' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentalRateHalfDay rdf:type rdf:Property ;
    rdfs:label 'Rental Rate Half Day' ;
    rdfs:comment 'Standard rental rate for booking the function space for a half day (typically 4-6 hours), in property base currency.' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentalRateHourly rdf:type rdf:Property ;
    rdfs:label 'Rental Rate Hourly' ;
    rdfs:comment 'Standard rental rate for booking the function space on an hourly basis, in property base currency.' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupTimeHours rdf:type rdf:Property ;
    rdfs:label 'Setup Time Hours' ;
    rdfs:comment 'Standard time required in hours for event setup including furniture arrangement, AV installation, and decoration before the event start.' ;
    rdfs:domain ind:FunctionSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spaceCode rdf:type rdf:Property ;
    rdfs:label 'Space Code' ;
    rdfs:comment 'Unique business identifier code for the function space within the property, used in PMS and event management systems.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceName rdf:type rdf:Property ;
    rdfs:label 'Space Name' ;
    rdfs:comment 'Full business name of the function space (e.g., Grand Ballroom, Executive Boardroom, Terrace Garden).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceType rdf:type rdf:Property ;
    rdfs:label 'Space Type' ;
    rdfs:comment 'Classification of the function space by its primary use and configuration characteristics.' ;
