# --- Attribute Properties ---
ind:bookingSourceId rdf:type rdf:Property ;
    rdfs:label 'Booking Source Id' ;
    rdfs:comment 'Unique surrogate identifier for each booking source attribution record in the channel distribution master. Primary key for the booking_source reference master. [ROLE: REFERENCE_LOOKUP — this entity is a reference master / code list for booking source attribution codes; per canonical-attrs-enforced rule, REFERENCE_LOOKUP role is exempt from per-role minimums. _canonical_skip_reason: booking_source is a reference master / code table classifying reservation origin at sub-channel granularity; it does not represent a party, agreement, resource, transaction, or event log.]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BookingSource .

ind:distributionChannelId rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Booking source is a granular attribution code that rolls up to a parent distribution channel. Many booking sources belong to one channel. Removes redundant parent_channel_code and parent_channel_name ' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:otaPartnerId rdf:type rdf:Property ;
    rdfs:label 'Ota Partner Id' ;
    rdfs:comment 'Foreign key linking to channel.ota_partner. Business justification: Booking sources may be associated with specific OTA partners for attribution and commission tracking. Many booking sources can belong to one OTA partner. Removes redundant ota_partner_code which can b' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OtaPartner .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date on which this booking source was first activated and made live for reservation acceptance in the CRS and PMS. Used for channel performance benchmarking (measuring ramp-up period) and historical channel mix analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:apiConnectivityType rdf:type rdf:Property ;
    rdfs:label 'Api Connectivity Type' ;
    rdfs:comment 'Technical connectivity method used to exchange availability, rates, and inventory (ARI) data between the hotel\'s CRS/PMS and this booking source. Determines integration complexity, latency, and update frequency for rate and inventory distribution.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Attribution Hierarchy Level' ;
    rdfs:comment 'Numeric level in the booking source attribution hierarchy used for revenue reporting roll-ups. Level 1 = top-level channel (e.g., OTA), Level 2 = sub-channel (e.g., OTA Desktop), Level 3 = specific source (e.g., Expedia Desktop US). Enables hierarchical channel mix analysis from property to brand level.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingSourceStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Source Status' ;
    rdfs:comment 'Current lifecycle status of the booking source record. \'active\' = currently receiving reservations; \'inactive\' = temporarily disabled; \'pending\' = configured but not yet live; \'suspended\' = paused due to contract or compliance issue; \'retired\' = permanently decommissioned. Used for channel activation management in Sabre SynXis CRS.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingWindowMaxDays rdf:type rdf:Property ;
    rdfs:label 'Booking Window Max Days' ;
    rdfs:comment 'Maximum advance booking window in days applicable to this booking source, as configured in the CRS. Defines the furthest point in advance that a reservation can be made through this channel. Used for long-range demand forecasting and group block management.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingWindowMinDays rdf:type rdf:Property ;
    rdfs:label 'Booking Window Min Days' ;
    rdfs:comment 'Minimum advance booking window in days applicable to this booking source, as configured in the CRS and RMS. Defines the earliest point before arrival that a reservation can be made through this channel. Used for demand forecasting and inventory control in IDeaS G3 RMS.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy Code' ;
    rdfs:comment 'Code referencing the default cancellation policy applied to reservations booked through this source, as configured in Oracle OPERA PMS. Determines refundability rules (e.g., Non-Refundable Rate (NRR), flexible cancellation). Impacts revenue recognition and overbooking strategy.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'High-level classification of the distribution channel type indicating whether the booking originates from a direct brand channel, an indirect intermediary (OTA/GDS/Wholesale), a voice channel (call center/reservation agent), or a group/MICE channel. Used for strategic channel mix reporting and direct booking ratio KPI tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionBasis rdf:type rdf:Property ;
    rdfs:label 'Commission Basis' ;
    rdfs:comment 'Defines the basis on which commission is calculated for this booking source: net_rate (commission on net room rate), gross_rate (commission on gross rate including taxes), flat_fee (fixed amount per booking), or per_segment (GDS segment fee per booking). Drives commission calculation logic in accounts payable processing.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Standard commission percentage payable to the booking source intermediary (OTA, travel agency, GDS) per confirmed reservation. Expressed as a percentage of the net room revenue. Used for cost-of-acquisition (COA) calculation, channel profitability analysis, and accounts payable commission processing in SAP S/4HANA. Null for direct/zero-commission channels.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectivityFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Connectivity Fee Amount' ;
    rdfs:comment 'Fixed monetary fee charged per booking or per GDS segment for this booking source, expressed in the property\'s base currency (USD). Applicable when connectivity_fee_applicable is True. Used alongside commission_rate to compute total cost of acquisition (COA) per channel.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectivityFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Connectivity Fee Applicable' ;
    rdfs:comment 'Indicates whether a GDS or channel connectivity fee is charged per booking for this source, in addition to or instead of a commission. True for GDS sources with per-segment fees (Amadeus, Sabre, Travelport). Used for total cost-of-acquisition calculation and channel profitability reporting.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiration date of the distribution agreement or contract with this booking source partner. Null for open-ended agreements. Used for contract renewal alerts, commission rate expiry management, and channel deactivation planning.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the distribution agreement or contract with this booking source partner. Used for contract lifecycle management, commission rate validity tracking, and channel activation scheduling in SAP S/4HANA contract management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this booking source record was first created in the data platform. Used for data lineage, audit trail, and reference data change management. Conforms to ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crsSourceCode rdf:type rdf:Property ;
    rdfs:label 'Crs Source Code' ;
    rdfs:comment 'Source code as configured in Sabre SynXis CRS for this booking source. This is the operational identifier used during reservation creation and rate distribution. May differ from the internal source_code when CRS uses a legacy or partner-assigned code.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which commissions and connectivity fees for this booking source are settled. Used for multi-currency commission processing in SAP S/4HANA accounts payable and foreign exchange reconciliation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which this booking source was deactivated or retired from the CRS and PMS. Null for currently active sources. Used for channel lifecycle management, historical reporting continuity, and audit trail maintenance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdsCode rdf:type rdf:Property ;
    rdfs:label 'Gds Code' ;
    rdfs:comment 'Standard GDS identifier code for the booking source when the channel is a Global Distribution System participant. Applicable values include Amadeus (1A), Sabre (1S), Travelport Galileo (1G), Travelport Worldspan (1P). Null for non-GDS sources. Used for GDS connectivity reconciliation and GDS segment fee billing.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Defines the geographic reach of this booking source: global (worldwide distribution), regional (specific world region), domestic (single country), or property_specific (single property only). Used for channel distribution strategy and regional channel mix analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment 'IATA-assigned numeric agency code for travel agency or OTA booking sources participating in IATA-governed distribution. Used for agency commission processing, GDS segment attribution, and travel agency performance reporting. Null for non-agency sources.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryUpdateFrequency rdf:type rdf:Property ;
    rdfs:label 'Inventory Update Frequency' ;
    rdfs:comment 'Frequency at which room inventory and rate availability are pushed or synchronized to this booking source channel. Real-time channels receive instant updates via API; others receive batch updates. Impacts overbooking risk management and rate parity compliance.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDirectChannel rdf:type rdf:Property ;
    rdfs:label 'Is Direct Channel' ;
    rdfs:comment 'Indicates whether this booking source is a direct brand channel (True) or an indirect intermediary channel (False). Direct channels include brand website, brand app, call center, and walk-in. Used for direct booking ratio KPI tracking and cost-of-acquisition benchmarking against indirect channels.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRoomAvailability rdf:type rdf:Property ;
    rdfs:label 'Last Room Availability' ;
    rdfs:comment 'Indicates whether this booking source has Last Room Availability (LRA) contractual rights, meaning the channel must be offered inventory even when only the last room is available. LRA is a common contractual obligation in corporate and GDS agreements. Impacts inventory control rules in IDeaS G3 RMS.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingAttributionModel rdf:type rdf:Property ;
    rdfs:label 'Marketing Attribution Model' ;
    rdfs:comment 'Defines the marketing attribution model applied to bookings from this source for campaign effectiveness measurement and marketing ROI (Return on Investment) reporting. Used by Salesforce CRM and marketing analytics to attribute revenue to marketing campaigns. \'none\' for channels not subject to marketing attribution (e.g., GDS corporate).' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentModel rdf:type rdf:Property ;
    rdfs:label 'Payment Model' ;
    rdfs:comment 'Defines the payment collection model for this booking source: merchant (OTA collects payment from guest and remits net to hotel), agency (hotel collects and pays commission to channel), net_rate (channel marks up a net rate), or direct_bill (corporate direct billing). Impacts revenue recognition, accounts receivable, and cash flow management.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmsSourceCode rdf:type rdf:Property ;
    rdfs:label 'Pms Source Code' ;
    rdfs:comment 'Source code as configured in Oracle OPERA PMS for this booking source. Used for front desk reservation attribution, daily operations reporting (DOR), and property-level channel mix analysis. May differ from CRS source code due to property-level configuration.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPartnerTier rdf:type rdf:Property ;
    rdfs:label 'Preferred Partner Tier' ;
    rdfs:comment 'OTA or channel partner tier classification indicating the level of preferred partnership status. Preferred partners typically receive enhanced placement, lower commission rates, or co-marketing benefits. Used for OTA partnership management and channel strategy prioritization.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateParityMonitored rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Monitored' ;
    rdfs:comment 'Indicates whether this booking source is subject to rate parity monitoring as part of the OTA contract or channel distribution agreement. When True, the Revenue Management System (RMS) and channel manager enforce rate parity rules to prevent undercutting on this channel. Critical for OTA contract compliance.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateParityType rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Type' ;
    rdfs:comment 'Specifies the rate parity obligation for this booking source: full_parity (rates must match all channels), narrow_parity (rates must match other OTAs but may differ from direct), or no_parity (no rate parity obligation). Drives rate distribution rules in Sabre SynXis CRS and IDeaS G3 RMS.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sort order for displaying booking source records in PMS, CRS, and reporting tool dropdown lists and channel mix reports. Lower values appear first. Used for UI configuration in Oracle OPERA PMS and Sabre SynXis CRS administration screens.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceCategory rdf:type rdf:Property ;
    rdfs:label 'Source Category' ;
    rdfs:comment 'Standardized sub-channel category classifying the booking source by interface type and traveler segment. Drives cost-of-acquisition attribution, commission tier assignment, and channel mix optimization analysis. [ENUM-REF-CANDIDATE: ota_desktop|ota_mobile|gds_corporate|direct_web|direct_app|voice|group|wholesale — promote to reference product]' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCode rdf:type rdf:Property ;
    rdfs:label 'Source Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the booking source within the Central Reservation System (CRS) and Property Management System (PMS). This is the operational key used in Oracle OPERA PMS and Sabre SynXis CRS for source attribution on reservations. Examples: \'EXPEDIA_WEB\', \'GDS_AMADEUS\', \'DIRECT_APP\'.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDescription rdf:type rdf:Property ;
    rdfs:label 'Source Description' ;
    rdfs:comment 'Detailed narrative description of the booking source, including its operational context, target traveler segment, and how it integrates with the distribution ecosystem. Used for onboarding documentation and channel strategy reference.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceName rdf:type rdf:Property ;
    rdfs:label 'Source Name' ;
    rdfs:comment 'Human-readable display name of the booking source as used in reporting dashboards, revenue management analysis, and channel mix reports. Examples: \'Expedia Desktop\', \'Amadeus GDS Corporate\', \'Brand Direct App\'.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsBestAvailableRate rdf:type rdf:Property ;
    rdfs:label 'Supports Best Available Rate' ;
    rdfs:comment 'Indicates whether this booking source is eligible to receive and display the Best Available Rate (BAR) as distributed through the CRS. Channels with full rate parity obligations typically receive BAR. Used in rate distribution configuration in Sabre SynXis CRS and IDeaS G3 RMS.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsLoyaltyAccrual rdf:type rdf:Property ;
    rdfs:label 'Supports Loyalty Accrual' ;
    rdfs:comment 'Indicates whether reservations booked through this source are eligible for loyalty program points accrual. Some OTA and wholesale channels contractually exclude loyalty point earning. Used by Salesforce CRM loyalty management module to determine points posting eligibility at check-in.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelerSegment rdf:type rdf:Property ;
    rdfs:label 'Traveler Segment' ;
    rdfs:comment 'Primary traveler segment targeted by this booking source. Classifies whether the channel primarily serves leisure travelers, corporate travelers, group bookings, MICE (Meetings Incentives Conferences Exhibitions), wholesale/tour operators, or Free Independent Travelers (FIT). Used for demand segmentation and revenue mix analysis.' ;
    rdfs:domain ind:BookingSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when this booking source record was last modified in the data platform. Used for incremental ETL processing, change data capture, and audit trail maintenance. Conforms to ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Primary key for channel' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Distribution channels incur operating costs (connectivity fees, commissions, marketing) that must be allocated to cost centers for USALI-compliant departmental P&L reporting and budget variance analys' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Channel managers are employees who own distribution channel relationships, manage OTA partnerships, and handle channel performance. Standard hospitality practice tracks which employee owns each channe' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCampaignId rdf:type rdf:Property ;
    rdfs:label 'Primary Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Distribution channels often have primary marketing campaigns driving bookings. This FK enables attribution analysis and campaign performance tracking by channel. Essential for marketing ROI measuremen' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:barEligible rdf:type rdf:Property ;
    rdfs:label 'Bar Eligible' ;
    rdfs:comment 'Indicates whether this channel is eligible to display and sell the Best Available Rate (BAR) — the lowest publicly available rate at the time of booking. True = BAR rates are distributed to this channel; False = channel receives only specific contracted or negotiated rates. Drives rate distribution strategy in IDeaS G3 RMS and Sabre SynXis CRS.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookingFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Booking Fee Usd' ;
    rdfs:comment 'Per-transaction booking fee charged by the channel in addition to or instead of a commission percentage, expressed in USD. Common in GDS channels (e.g., GDS segment fee per booking). Used in cost-of-acquisition and channel profitability analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'High-level grouping of the channel by booking relationship: DIRECT = guest books directly with the property (web, mobile, voice, corporate direct); INDIRECT = third-party intermediary involved (OTA, GDS, wholesaler, metasearch); OPAQUE = rate and property identity concealed until after booking (e.g., Hotwire, Priceline opaque). Drives cost-of-acquisition analysis and channel mix strategy.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the distribution channel across enterprise systems including Sabre SynXis CRS, Oracle OPERA PMS, and IDeaS G3 RMS. Used for channel mapping and cross-system reconciliation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Free-text description of the distribution channel, including its market positioning, target guest segment, special contractual terms, or operational notes. Used for channel management documentation and onboarding reference.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Human-readable name of the distribution channel (e.g., \'Expedia Partner Central\', \'Booking.com Extranet\', \'Sabre GDS\', \'Direct Web\', \'Voice Reservations\'). Used in reporting, dashboards, and channel mix analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational lifecycle status of the distribution channel. active = channel is live and accepting bookings; inactive = channel is configured but not currently selling; suspended = channel temporarily halted (e.g., rate parity violation, connectivity issue); pending_activation = channel onboarded but not yet live; decommissioned = channel permanently retired.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePct rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Pct' ;
    rdfs:comment 'Standard commission percentage charged by this distribution channel on each booking, expressed as a percentage of the room revenue (e.g., 15.00 for 15%). Drives cost-of-acquisition calculations and net revenue reporting per USALI standards. Confidential as it reflects negotiated commercial terms.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectivityFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Connectivity Fee Usd' ;
    rdfs:comment 'Annual or periodic connectivity/subscription fee charged by the channel or switch provider for maintaining the technical integration, expressed in USD. Included in total cost-of-acquisition analysis alongside commission. Confidential as it reflects negotiated commercial terms.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectivityMethod rdf:type rdf:Property ;
    rdfs:label 'Connectivity Method' ;
    rdfs:comment 'Technical integration method used to connect the property management system or CRS to this distribution channel. API = RESTful or SOAP API integration; XML = XML-based messaging (e.g., OTA XML); SFTP = file-based batch transfer; DIRECT_CONNECT = proprietary direct connection; SWITCH = via a channel manager switch (e.g., SiteMinder, Channex); MANUAL = manually managed extranet updates. Impacts SLA and rate update latency.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDistributionEnabled rdf:type rdf:Property ;
    rdfs:label 'Content Distribution Enabled' ;
    rdfs:comment 'Indicates whether property content (room descriptions, images, amenities, policies) is actively distributed to this channel via a content API or content management system. True = content is pushed/synced to this channel; False = content is managed manually or not distributed. Relevant for OTA and metasearch channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crsChannelCode rdf:type rdf:Property ;
    rdfs:label 'Crs Channel Code' ;
    rdfs:comment 'Channel identifier as configured in the Sabre SynXis Central Reservation System (CRS). Used for cross-system reconciliation between the enterprise data lakehouse and the CRS source of record. Enables traceability of bookings back to the originating CRS channel configuration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDataProcessor rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Processor' ;
    rdfs:comment 'Indicates whether this distribution channel acts as a GDPR data processor for guest personal data collected during the booking process. True = a Data Processing Agreement (DPA) is in place with this channel; False = channel does not process personal data on behalf of the property. Required for GDPR compliance and data governance.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsChainCode rdf:type rdf:Property ;
    rdfs:label 'Gds Chain Code' ;
    rdfs:comment 'Two-letter GDS chain code assigned to the hotel brand or property group within Global Distribution Systems (Sabre, Amadeus, Galileo/Travelport, Worldspan). Required for GDS-type channels to route availability and rate requests correctly. Null for non-GDS channels.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Allocation Method' ;
    rdfs:comment 'Method by which room inventory is allocated to this distribution channel. POOLED = channel draws from the shared central inventory pool (real-time); ALLOTMENT = a fixed block of rooms is pre-allocated to the channel; FREE_SALE = channel can sell without prior allocation up to a defined limit; ON_REQUEST = bookings require manual confirmation. Managed in IDeaS G3 RMS and Sabre SynXis CRS.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this distribution channel record was most recently modified in the enterprise data platform. Stored in yyyy-MM-ddTHH:mm:ss.SSSXXX format. Used for change tracking, data freshness monitoring, and audit compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyBookingsEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Bookings Eligible' ;
    rdfs:comment 'Indicates whether bookings made through this channel are eligible for loyalty program points accrual and redemption. True = loyalty points are awarded and redeemable; False = bookings through this channel do not qualify for loyalty benefits (common for opaque OTA channels). Managed in Salesforce CRM Loyalty Management.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:miceBookingsSupported rdf:type rdf:Property ;
    rdfs:label 'Mice Bookings Supported' ;
    rdfs:comment 'Indicates whether this distribution channel supports group and MICE (Meetings, Incentives, Conferences, Exhibitions) bookings in addition to transient reservations. True = MICE/group bookings can be sourced through this channel; False = transient bookings only. Relevant for event sales and Delphi by Amadeus integration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nrrEligible rdf:type rdf:Property ;
    rdfs:label 'Nrr Eligible' ;
    rdfs:comment 'Indicates whether Non-Refundable Rate (NRR) products are distributed through this channel. True = NRR fences are available on this channel; False = only flexible/refundable rates are distributed. Impacts revenue management yield strategy and cancellation policy enforcement.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciCompliant rdf:type rdf:Property ;
    rdfs:label 'Pci Compliant' ;
    rdfs:comment 'Indicates whether this distribution channel is certified as compliant with PCI DSS (Payment Card Industry Data Security Standard) for handling cardholder data. True = channel holds current PCI DSS certification; False = channel is not PCI compliant or certification has lapsed. Required for risk management and payment security governance.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryMarketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Market Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary market served by this distribution channel (e.g., \'USA\', \'GBR\', \'DEU\'). Used for geographic channel mix analysis, market penetration reporting, and regulatory compliance (e.g., GDPR for EU-based channels).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric rank indicating the strategic priority of this channel in the distribution mix, where lower numbers indicate higher priority (e.g., 1 = highest priority, typically direct web). Used by revenue management to determine inventory release sequencing and rate strategy. Configured in IDeaS G3 RMS and Sabre SynXis CRS.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateParityRequired rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Required' ;
    rdfs:comment 'Indicates whether this distribution channel contractually requires rate parity — i.e., the property must offer the same or lower rates on this channel as on any other channel. True = rate parity clause is active in the channel agreement; False = no rate parity obligation. Critical for revenue management compliance and rate strategy.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remittanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Remittance Frequency' ;
    rdfs:comment 'Frequency at which the channel remits collected payments to the property for CHANNEL_COLLECT payment model bookings. Applicable only when payment_model is CHANNEL_COLLECT or SPLIT. Drives accounts receivable forecasting and cash flow management in SAP S/4HANA.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Seconds' ;
    rdfs:comment 'Maximum allowable response time in seconds for availability and rate queries from this channel, as defined in the channel\'s Service Level Agreement (SLA). Used to monitor channel connectivity performance and enforce SLA compliance. Typical values: 3 seconds for OTA/GDS, 5 seconds for XML channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePct rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Pct' ;
    rdfs:comment 'Contractually committed uptime percentage for this channel\'s connectivity, expressed as a percentage (e.g., 99.90 for 99.9% uptime). Used to monitor channel reliability and enforce SLA penalties. Managed against actual uptime metrics in channel performance reporting.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedCurrencies rdf:type rdf:Property ;
    rdfs:label 'Supported Currencies' ;
    rdfs:comment 'Comma-separated list of ISO 4217 three-letter currency codes supported by this distribution channel for booking and payment (e.g., \'USD,EUR,GBP,JPY\'). Relevant for multi-currency rate distribution and foreign exchange management. Managed in Sabre SynXis CRS.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedLanguages rdf:type rdf:Property ;
    rdfs:label 'Supported Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 two-letter language codes supported by this channel for content display and guest communication (e.g., \'en,fr,de,zh,ja\'). Relevant for content localization strategy and international market reach.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelBookingId rdf:type rdf:Property ;
    rdfs:label 'Channel Booking Id' ;
    rdfs:comment 'Unique surrogate identifier for each channel booking transaction record in the Silver layer lakehouse. Primary key for this fact table. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelBooking .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Channel bookings result from marketing campaigns; attribution tracking requires linking bookings to originating campaigns for ROI measurement, campaign performance analysis, and marketing spend reconc' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:channelRatePlanId rdf:type rdf:Property ;
    rdfs:label 'Channel Rate Plan Id' ;
    rdfs:comment 'Foreign key linking to channel.channel_rate_plan. Business justification: Channel bookings use channel-specific rate plans. The channel_booking table currently has rate_plan_id pointing to revenue.revenue_rate_plan (cross-domain) and rate_plan_code (STRING). Adding channel_' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelRatePlan .

ind:guestGroupBlockId rdf:type rdf:Property ;
    rdfs:label 'Guest Group Block Id' ;
    rdfs:comment 'Foreign key linking to guest.guest_group_block. Business justification: Group bookings made through distribution channels (GDS, OTA, direct) must link to the master group block for rooming list reconciliation, group pickup tracking, billing consolidation to master folio, ' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestGroupBlock .

ind:guestProfileId rdf:type rdf:Property ;
    rdfs:label 'Guest Profile Id' ;
    rdfs:comment 'Reference to the guest profile record associated with this booking. Enables guest-level channel attribution, loyalty linkage, and lifetime value analysis. PARTY_REFERENCE per TRANSACTION_HEADER canonical role.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:inventoryRoomTypeId rdf:type rdf:Property ;
    rdfs:label 'Inventory Room Type Id' ;
    rdfs:comment 'Foreign key linking to inventory.room_type. Business justification: Channel bookings must reference the actual inventory room type sold for revenue attribution by room category, inventory consumption tracking, channel performance analysis, and commission calculation a' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoomType .

ind:loyaltyMemberId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member. Business justification: Channel bookings must link to loyalty member for points accrual calculation, tier benefit application at booking time, member revenue attribution reporting, and loyalty program liability accounting. C' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:propertyId rdf:type rdf:Property ;
    rdfs:label 'Property Id' ;
    rdfs:comment 'Reference to the hotel or resort property at which the booking is made. Links to the property master record for property-level channel performance analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:reservationBookingId rdf:type rdf:Property ;
    rdfs:label 'Reservation Booking Id' ;
    rdfs:comment 'Reference to the parent reservation record in the PMS. Links the channel booking transaction to the operational reservation for end-to-end booking lifecycle tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReservationBooking .

ind:revenueRatePlanId rdf:type rdf:Property ;
    rdfs:label 'Revenue Rate Plan Id' ;
    rdfs:comment 'Reference to the rate plan applied to this booking (e.g., BAR, LRA, NRR, corporate, package). Used for rate parity monitoring and revenue contribution analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRatePlan .

ind:sanctionScreeningId rdf:type rdf:Property ;
    rdfs:label 'Sanction Screening Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanction_screening. Business justification: Bookings from international channels require sanctions screening of guest names against OFAC/EU/UN lists, especially for high-risk jurisdictions. Real business process: automated sanctions screening d' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionScreening .

ind:adr rdf:type rdf:Property ;
    rdfs:label 'Adr' ;
    rdfs:comment 'The Average Daily Rate (ADR) for this booking, calculated as gross booking value divided by length of stay nights. Stored as a business attribute to support channel-level ADR benchmarking and STR STAR Report comparisons without requiring runtime calculation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle status of the channel booking transaction. Drives channel performance reporting, cancellation rate analysis, and no-show tracking. LIFECYCLE_STATUS per TRANSACTION_HEADER canonical role. [ENUM-REF-CANDIDATE: confirmed|cancelled|modified|no_show|waitlisted|tentative — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Timestamp' ;
    rdfs:comment 'The exact date and time when the booking was received through the distribution channel. BUSINESS_EVENT_TIMESTAMP per TRANSACTION_HEADER canonical role. Used for booking pace analysis, lead time calculation, and channel demand pattern reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'The date and time when the booking was cancelled. Populated only when is_cancelled is True. Used for cancellation lead time analysis and channel cancellation pattern reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Channel Commission Amount' ;
    rdfs:comment 'The commission amount payable to the distribution channel partner for this booking. Represents the cost of acquisition for channel-sourced bookings. Part of MONETARY_TRIPLET per TRANSACTION_HEADER canonical role.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkInDate rdf:type rdf:Property ;
    rdfs:label 'Check In Date' ;
    rdfs:comment 'The scheduled guest arrival date for the stay associated with this booking. Used for stay date demand analysis, length-of-stay (LOS) calculation, and revenue period attribution.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkOutDate rdf:type rdf:Property ;
    rdfs:label 'Check Out Date' ;
    rdfs:comment 'The scheduled guest departure date for the stay associated with this booking. Combined with check_in_date to derive length of stay (LOS) and average length of stay (ALOS) metrics.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:corporateAccountCode rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Code' ;
    rdfs:comment 'The corporate account or negotiated rate code associated with this booking, if applicable. Used for corporate channel performance analysis, negotiated rate compliance monitoring, and corporate account revenue attribution.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsBookingReference rdf:type rdf:Property ;
    rdfs:label 'Crs Booking Reference' ;
    rdfs:comment 'The unique booking identifier assigned by the Central Reservation System (Sabre SynXis CRS). Used for cross-system reconciliation between CRS and PMS booking records.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsSegmentNumber rdf:type rdf:Property ;
    rdfs:label 'Gds Segment Number' ;
    rdfs:comment 'The segment identifier assigned by the Global Distribution System (GDS) for bookings originating through GDS channels (e.g., Sabre, Amadeus, Travelport). Used for GDS billing reconciliation and travel agent attribution.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossBookingValue rdf:type rdf:Property ;
    rdfs:label 'Gross Booking Value' ;
    rdfs:comment 'The total gross value of the booking as received from the distribution channel, inclusive of all room charges before deduction of channel commissions or fees. Expressed in the booking currency. Part of MONETARY_TRIPLET per TRANSACTION_HEADER canonical role.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCancelled rdf:type rdf:Property ;
    rdfs:label 'Is Cancelled' ;
    rdfs:comment 'Indicates whether this booking has been cancelled (True = cancelled, False = active). Used for channel-level cancellation rate analysis and net booking volume reporting.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isModified rdf:type rdf:Property ;
    rdfs:label 'Is Modified' ;
    rdfs:comment 'Indicates whether this booking has been modified after initial confirmation (True = modified, False = original booking). Used to track modification rates by channel and assess channel data quality.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRateParityCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Rate Parity Compliant' ;
    rdfs:comment 'Indicates whether the booked rate is compliant with the rate parity agreement for this channel (True = compliant, False = parity violation detected). Critical for OTA contract compliance monitoring and channel rate parity management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The timestamp when this channel booking transaction record was last updated in the Silver layer data product. RECORD_AUDIT_UPDATED per TRANSACTION_HEADER canonical role. Used for change data capture, incremental load processing, and audit compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The number of days between the booking timestamp and the check-in date. Stored as a business attribute to support lead time distribution analysis by channel, demand forecasting, and last-minute booking pattern identification.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lengthOfStayNights rdf:type rdf:Property ;
    rdfs:label 'Length Of Stay Nights' ;
    rdfs:comment 'The number of nights for the booked stay, derived from check-in and check-out dates. Stored as a business attribute to support LOS-based rate restriction analysis, minimum stay controls, and ALOS reporting without requiring date arithmetic at query time.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Market Segment Code' ;
    rdfs:comment 'The market segment classification code assigned to this booking (e.g., TRANS, GROUP, CORP, LEISURE, GOVT). Used for segmented revenue analysis, channel-to-segment attribution, and STR benchmarking alignment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'The net revenue retained by the property after deduction of channel commission from the gross booking value. Primary metric for channel contribution analysis and cost-of-acquisition benchmarking. Part of MONETARY_TRIPLET per TRANSACTION_HEADER canonical role.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfGuests rdf:type rdf:Property ;
    rdfs:label 'Number Of Guests' ;
    rdfs:comment 'The total number of guests included in this booking. Used for occupancy analysis, per-guest revenue calculations, and channel demand pattern reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfRooms rdf:type rdf:Property ;
    rdfs:label 'Number Of Rooms' ;
    rdfs:comment 'The number of rooms included in this booking transaction. Typically 1 for FIT (Free Independent Traveler) bookings; may be greater for group or multi-room bookings received through a channel.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otaConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Ota Confirmation Number' ;
    rdfs:comment 'The booking confirmation number assigned by the Online Travel Agency (OTA) platform (e.g., Booking.com, Expedia). Used for reconciliation with OTA partner systems and commission invoice matching.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmsConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Pms Confirmation Number' ;
    rdfs:comment 'The externally-communicated confirmation number generated by the Property Management System (Oracle OPERA PMS) for this booking. Serves as the primary guest-facing booking reference. BUSINESS_IDENTIFIER per TRANSACTION_HEADER canonical role.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the rate type applied to this booking. BAR (Best Available Rate), LRA (Last Room Availability), NRR (Non-Refundable Rate), corporate, package, promotional, or group. Critical for rate parity monitoring and revenue strategy analysis. [ENUM-REF-CANDIDATE: BAR|LRA|NRR|corporate|package|promotional|group — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCountry rdf:type rdf:Property ;
    rdfs:label 'Source Country' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the origin from which the booking was made through the channel. Used for geographic demand analysis, international vs. domestic channel mix reporting, and targeted marketing attribution.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelAgentIataNumber rdf:type rdf:Property ;
    rdfs:label 'Travel Agent Iata Number' ;
    rdfs:comment 'The 8-digit IATA (International Air Transport Association) accreditation number of the travel agency that made this booking. Used for travel agent commission processing, GDS attribution, and agency performance reporting.' ;
    rdfs:domain ind:ChannelBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelContractId rdf:type rdf:Property ;
    rdfs:label 'Channel Contract Id' ;
    rdfs:comment 'Unique surrogate identifier for the channel contract record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelContract .

ind:gdsConnectionId rdf:type rdf:Property ;
    rdfs:label 'Gds Connection Id' ;
    rdfs:comment 'Foreign key linking to channel.gds_connection. Business justification: Channel contracts may reference specific GDS connection configurations, particularly for chain-level GDS agreements that are implemented at the property connection level. Many contracts per GDS connec' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GdsConnection .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger. Business justification: Channel contracts create financial obligations requiring GL account assignment for proper revenue/expense recognition, audit trail compliance, and financial statement preparation per accounting standa' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_obligation. Business justification: Channel contracts create specific compliance obligations including rate parity enforcement, data processing requirements under GDPR DPAs, commission reporting, and content accuracy requirements. Real ' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Channel contracts require employee ownership for accountability in contract management, renewal tracking, and performance monitoring. Standard practice in hospitality to assign contract ownership to s' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:barAccess rdf:type rdf:Property ;
    rdfs:label 'Bar Access' ;
    rdfs:comment 'Indicates whether the channel is contractually entitled to receive the Best Available Rate (BAR) as defined in the Revenue Management System. Drives rate loading rules in Sabre SynXis CRS.' ;
    rdfs:domain ind:ChannelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:connectivityFee rdf:type rdf:Property ;
    rdfs:label 'Connectivity Fee' ;
    rdfs:comment 'Fixed or per-transaction fee charged by the channel or GDS for technical connectivity and distribution services. Distinct from commission which is percentage-based. Used in cost-of-acquisition (COA) analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectivityFeeType rdf:type rdf:Property ;
    rdfs:label 'Connectivity Fee Type' ;
    rdfs:comment 'Specifies how the connectivity fee is structured: per booking transaction, per GDS segment, annual flat fee, or monthly flat fee.' ;
    rdfs:domain ind:ChannelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRequirements rdf:type rdf:Property ;
    rdfs:label 'Content Requirements' ;
    rdfs:comment 'Free-text description of contractual obligations regarding property content (images, descriptions, amenities) that must be maintained on the channel platform, including minimum image counts, refresh frequency, and accuracy standards.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Human-readable descriptive name for the contract (e.g., \'Expedia 2025 Master Distribution Agreement — Americas\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known legal contract reference number assigned by the contracting parties or the legal department. Used for correspondence, audits, and dispute resolution.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the contract. Drives whether the channel is eligible to receive inventory and rates via the CRS.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the commercial agreement by channel category. Determines applicable commission structures, rate parity obligations, and connectivity requirements. [ENUM-REF-CANDIDATE: ota_distribution|gds_participation|direct_connect|wholesale|bed_bank|metasearch|corporate_negotiated — promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingAgreement rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement' ;
    rdfs:comment 'Indicates whether the contract includes a data sharing or data processing agreement governing the exchange of guest and booking data with the channel partner. Required for GDPR Article 28 compliance.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the legal jurisdiction governing dispute resolution and contract interpretation.' ;
    rdfs:domain ind:ChannelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving commercial disputes between the hotel and the channel partner.' ;
    rdfs:domain ind:ChannelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date on which the contract becomes legally binding and the channel is authorized to distribute inventory. Aligns with USALI period reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which the contract ceases to be binding. Null for evergreen contracts. Used to trigger renewal workflows and rate parity audits.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprDpaReference rdf:type rdf:Property ;
    rdfs:label 'Gdpr Dpa Reference' ;
    rdfs:comment 'Reference number or document identifier for the GDPR Data Processing Agreement (DPA) executed with the channel partner. Mandatory for EU-based OTA and GDS partnerships under GDPR Article 28.' ;
    rdfs:domain ind:ChannelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoice Frequency' ;
    rdfs:comment 'Frequency at which commission invoices or settlement statements are issued between the hotel and the channel partner.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lraObligation rdf:type rdf:Property ;
    rdfs:label 'Lra Obligation' ;
    rdfs:comment 'Indicates whether the contract includes a Last Room Availability (LRA) obligation, requiring the hotel to make the last available room accessible to this channel even when inventory is restricted for other channels.' ;
    rdfs:domain ind:ChannelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingCoopAmount rdf:type rdf:Property ;
    rdfs:label 'Marketing Coop Amount' ;
    rdfs:comment 'Annual or contract-period monetary commitment for co-operative marketing spend with the channel partner (e.g., sponsored listings, display advertising on OTA platform). Expressed in the contract currency.' ;
    rdfs:domain ind:ChannelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nrrAllowed rdf:type rdf:Property ;
    rdfs:label 'Nrr Allowed' ;
    rdfs:comment 'Indicates whether the contract permits the hotel to offer Non-Refundable Rates (NRR) through this channel. Relevant for revenue management strategy and cancellation policy governance.' ;
    rdfs:domain ind:ChannelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciComplianceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Confirmed' ;
    rdfs:comment 'Indicates whether the channel partner has confirmed PCI DSS compliance as required by the contract terms for handling payment card data.' ;
    rdfs:domain ind:ChannelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateParityClause rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Clause' ;
    rdfs:comment 'Indicates whether the contract includes a rate parity obligation requiring the hotel to offer the channel the same or better rates as other distribution channels. Critical for revenue management compliance and OTA relationship governance.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to expiration_date by which either party must provide written notice of intent to renew or terminate. Drives automated contract renewal alerts.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Specifies whether the contract auto-renews at expiration, requires manual renegotiation, or is a one-time non-renewable agreement.' ;
    rdfs:domain ind:ChannelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date on which all parties executed the contract. Used for legal audit trails and SOX compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Operational system of record from which this contract record was ingested into the lakehouse (e.g., SAP S/4HANA Contract Management, Sabre SynXis CRS, Oracle OPERA PMS, or manually entered).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date the contract was terminated early, if applicable. Distinct from expiration_date which is the scheduled end. Populated only when contract_status is \'terminated\'.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelNegotiatedRateId rdf:type rdf:Property ;
    rdfs:label 'Channel Negotiated Rate Id' ;
    rdfs:comment 'Primary key for negotiated_rate' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:corporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Id' ;
    rdfs:comment 'Reference to the corporate account entity that holds this negotiated rate agreement. Links to the CRM or PMS corporate account master.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:loadedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Loaded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Corporate rate loading by employees requires tracking for operational accountability and audit trails. Essential for understanding who loaded negotiated rates into systems and ensuring data quality in' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tmcCorporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Tmc Corporate Account Id' ;
    rdfs:comment 'Reference to the Travel Management Company (TMC) associated with this negotiated rate agreement. TMCs manage corporate travel programs and book through GDS channels.' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:advancePurchaseDays rdf:type rdf:Property ;
    rdfs:label 'Advance Purchase Days' ;
    rdfs:comment 'Minimum number of days in advance that a booking must be made to qualify for this negotiated rate. Zero indicates no advance purchase requirement.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the negotiated rate agreement. Controls whether the rate is bookable through distribution channels.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The agreed nightly room rate (ADR equivalent) for this corporate negotiated rate agreement, expressed in the agreement currency. This is the principal monetary value of the rate record.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Username or employee identifier of the revenue management leader or director who approved this negotiated rate agreement for loading and distribution.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutDates rdf:type rdf:Property ;
    rdfs:label 'Blackout Dates' ;
    rdfs:comment 'Comma-delimited list or date range expressions representing dates on which this negotiated rate is not available (e.g., peak demand periods, holidays, special events). Stored as a descriptive string; detailed blackout records managed in rate restriction tables.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiaCode rdf:type rdf:Property ;
    rdfs:label 'Consortia Code' ;
    rdfs:comment 'Identifier for the travel consortia (e.g., Virtuoso, Signature, Ensemble, Internova) through which this negotiated rate is distributed. Consortia rates are loaded separately from direct LNR agreements.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consortiaName rdf:type rdf:Property ;
    rdfs:label 'Consortia Name' ;
    rdfs:comment 'Full name of the travel consortia organization associated with this rate agreement (e.g., Virtuoso, Signature Travel Network).' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsRateCode rdf:type rdf:Property ;
    rdfs:label 'Crs Rate Code' ;
    rdfs:comment 'Native rate identifier as assigned by the Sabre SynXis Central Reservation System (CRS). Used for reconciliation between the lakehouse Silver Layer and the CRS source system.' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the negotiated rate agreement expires and is no longer bookable. Nullable for open-ended agreements.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdsLoadingStatus rdf:type rdf:Property ;
    rdfs:label 'Gds Loading Status' ;
    rdfs:comment 'Current status of the negotiated rate\'s loading into the GDS (e.g., Sabre, Amadeus, Travelport). Tracks whether the rate is live and bookable through GDS channels.' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLastRoomAvailability rdf:type rdf:Property ;
    rdfs:label 'Is Last Room Availability' ;
    rdfs:comment 'Indicates whether this negotiated rate carries Last Room Availability (LRA) status, meaning the rate must be offered as long as any room of the applicable type remains available, regardless of inventory controls.' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRateParityRequired rdf:type rdf:Property ;
    rdfs:label 'Is Rate Parity Required' ;
    rdfs:comment 'Indicates whether rate parity obligations apply to this negotiated rate across all distribution channels. Relevant for OTA and GDS channel compliance monitoring.' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxLos rdf:type rdf:Property ;
    rdfs:label 'Max Los' ;
    rdfs:comment 'Maximum number of nights permitted under this negotiated rate. Null indicates no upper LOS restriction.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minLos rdf:type rdf:Property ;
    rdfs:label 'Min Los' ;
    rdfs:comment 'Minimum number of nights required for a booking to qualify for this negotiated rate. LOS = Length of Stay restriction applied at the channel level.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiationYear rdf:type rdf:Property ;
    rdfs:label 'Negotiation Year' ;
    rdfs:comment 'Calendar year in which this negotiated rate agreement was contracted. Corporate LNR agreements are typically renegotiated annually; this field supports year-over-year production analysis.' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pmsRateCode rdf:type rdf:Property ;
    rdfs:label 'Pms Rate Code' ;
    rdfs:comment 'Rate code as configured in Oracle OPERA PMS for this negotiated rate. Used for cross-system reconciliation between CRS-distributed rates and PMS-posted rates.' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCategory rdf:type rdf:Property ;
    rdfs:label 'Rate Category' ;
    rdfs:comment 'Hotel segment category under which this negotiated rate is classified, aligning with the property\'s service tier (luxury, premium, select-service, standard).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLoadingDate rdf:type rdf:Property ;
    rdfs:label 'Rate Loading Date' ;
    rdfs:comment 'Date on which this negotiated rate was loaded into the GDS and/or CRS for distribution. Tracks operational readiness of the rate for booking.' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratePlanCode rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Code' ;
    rdfs:comment 'Alphanumeric rate plan code as loaded in the CRS and GDS systems (e.g., CORP01, LNR2025). Used for rate identification across distribution channels and PMS.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanName rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Name' ;
    rdfs:comment 'Human-readable name of the negotiated rate plan as displayed in the CRS, GDS, and TMC booking tools (e.g., \'Acme Corp 2025 LNR\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomTypeInclusion rdf:type rdf:Property ;
    rdfs:label 'Room Type Inclusion' ;
    rdfs:comment 'Comma-delimited list or description of room type codes included under this negotiated rate agreement (e.g., \'KING,DBLQ,SUITE\'). Defines which room categories the corporate rate applies to.' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmcName rdf:type rdf:Property ;
    rdfs:label 'Tmc Name' ;
    rdfs:comment 'Name of the Travel Management Company (TMC) managing the corporate travel program for this negotiated rate (e.g., American Express Global Business Travel, BCD Travel, CWT).' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentRoomNights rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Room Nights' ;
    rdfs:comment 'Contractually committed number of room nights the corporate account has agreed to consume during the agreement period. Used for production tracking and rate renegotiation.' ;
    rdfs:domain ind:ChannelNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignOfferId rdf:type rdf:Property ;
    rdfs:label 'Campaign Offer Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign_offer. Business justification: Promotional rate plans operationalize marketing offers; a "Summer Sale" campaign offer manifests as specific rate plans loaded into distribution channels. Linking rate plans to offers enables offer pe' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignOffer .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the revenue management or distribution team member who approved this channel rate plan configuration for publication. Supports governance, approval workflow tracking, and audit compliance for rate distribution decisions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'The base room rate amount (in property currency) from which the channel-specific rate is derived. For BAR-derived plans, this is the current BAR value. For flat rates, this is the fixed rate. Expressed per room per night. Supports rate parity monitoring and channel pricing strategy analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Booking Window End Date' ;
    rdfs:comment 'The last calendar date on which bookings can be made for stays under this channel rate plan. Defines the closing of the booking window. Nullable if the rate plan remains bookable indefinitely until the stay date.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Booking Window Start Date' ;
    rdfs:comment 'The earliest calendar date on which bookings can be made for stays under this channel rate plan. Defines the opening of the booking window for this rate plan on this channel. Used for promotional and advance purchase rate plan management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelRateAmount rdf:type rdf:Property ;
    rdfs:label 'Channel Rate Amount' ;
    rdfs:comment 'The final channel-specific rate amount (in property currency) published to this distribution channel after applying the rate derivation method and adjustment. This is the rate visible to consumers on the channel. Per room per night. Core metric for rate parity compliance monitoring.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelRatePlanStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Rate Plan Status' ;
    rdfs:comment 'Current lifecycle status of the channel rate plan configuration. Active = currently published and bookable on the channel; Inactive = deactivated and not available; Suspended = temporarily paused (e.g., rate parity violation); Pending = awaiting activation or approval; Expired = past effective end date; Draft = configured but not yet submitted for distribution.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeOutDays rdf:type rdf:Property ;
    rdfs:label 'Close Out Days' ;
    rdfs:comment 'Number of days before arrival after which this rate plan is closed out and no longer bookable on this channel. Complements advance_purchase_days to define the booking window. A value of 0 means the rate is bookable up to the day of arrival.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crsRatePlanCode rdf:type rdf:Property ;
    rdfs:label 'Crs Rate Plan Code' ;
    rdfs:comment 'The rate plan identifier as assigned in the Sabre SynXis Central Reservation System (CRS). Used for cross-system reconciliation between the lakehouse Silver Layer and the operational CRS. Enables traceability of rate plan configurations back to the source system.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOfWeekApplicable rdf:type rdf:Property ;
    rdfs:label 'Days Of Week Applicable' ;
    rdfs:comment 'A 7-character binary string indicating which days of the week (Mon-Sun) this rate plan is applicable on the channel. Each position represents a day: position 1=Monday through position 7=Sunday. \'1\' = applicable, \'0\' = not applicable. Example: \'1111100\' = Monday through Friday only. Supports weekday/weekend rate differentiation.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this channel rate plan configuration becomes active and the rate plan is published to the channel. Defines the start of the rate loading schedule for this channel-rate plan combination.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date on which this channel rate plan configuration expires and the rate plan is no longer published to the channel. Nullable for open-ended configurations. Supports rate loading schedule management and seasonal rate plan publishing.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPackageRate rdf:type rdf:Property ;
    rdfs:label 'Is Package Rate' ;
    rdfs:comment 'Indicates whether this channel rate plan is a package rate that bundles room accommodation with additional inclusions (e.g., breakfast, spa credit, parking, F&B voucher). True = package rate with inclusions; False = room-only rate. Supports package revenue attribution and channel mix analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRateParityApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Rate Parity Applicable' ;
    rdfs:comment 'Indicates whether rate parity rules apply to this channel rate plan configuration. True = this rate plan is subject to rate parity monitoring and must match rates across applicable channels; False = exempt from parity (e.g., opaque rates, member-only rates, negotiated corporate rates). Supports rate parity compliance management.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefundable rdf:type rdf:Property ;
    rdfs:label 'Is Refundable' ;
    rdfs:comment 'Indicates whether bookings made under this channel rate plan are eligible for a refund upon cancellation. True = refundable (flexible rate); False = non-refundable (NRR). Key attribute for consumer transparency and rate plan classification.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastLoadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Loaded Timestamp' ;
    rdfs:comment 'The date and time when this rate plan was most recently successfully loaded or updated on the distribution channel. Supports rate loading schedule management, troubleshooting, and audit of channel rate distribution operations.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mealPlanCode rdf:type rdf:Property ;
    rdfs:label 'Meal Plan Code' ;
    rdfs:comment 'Code indicating the meal plan inclusion for this channel rate plan. RO = Room Only; BB = Bed and Breakfast; HB = Half Board (breakfast + dinner); FB = Full Board (all meals); AI = All Inclusive; EP = European Plan (no meals); CP = Continental Plan (continental breakfast). Relevant for package rate plans. [ENUM-REF-CANDIDATE: RO|BB|HB|FB|AI|EP|CP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for operational notes, special instructions, or contextual information about this channel rate plan configuration. Examples: rate loading exceptions, channel-specific negotiation notes, promotional campaign references, or revenue strategy rationale.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmsRatePlanCode rdf:type rdf:Property ;
    rdfs:label 'Pms Rate Plan Code' ;
    rdfs:comment 'The rate plan code as configured in Oracle OPERA Property Management System (PMS). Used for reconciliation between CRS channel distribution and PMS rate plan setup. Ensures rate plan consistency between the CRS and PMS for accurate reservation processing.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAdjustmentType rdf:type rdf:Property ;
    rdfs:label 'Rate Adjustment Type' ;
    rdfs:comment 'Indicates whether the channel-specific pricing adjustment is a markup (rate higher than base, e.g., to cover OTA commission) or a markdown (rate lower than base, e.g., promotional discount). NONE indicates no adjustment is applied and the base rate is published as-is.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAdjustmentUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Adjustment Unit' ;
    rdfs:comment 'Specifies whether the rate_adjustment_value is expressed as a PERCENTAGE of the base rate or as a fixed AMOUNT in the property currency. Determines how the channel-specific rate is computed from the base rate and adjustment value.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAdjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Rate Adjustment Value' ;
    rdfs:comment 'The numeric value of the rate adjustment applied to derive the channel-specific rate from the base rate. Interpretation depends on rate_adjustment_unit: if PERCENTAGE, this is the percentage (e.g., 15.00 = 15%); if AMOUNT, this is the absolute currency amount. Used in conjunction with rate_adjustment_type to compute the final channel rate.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateDerivationMethod rdf:type rdf:Property ;
    rdfs:label 'Rate Derivation Method' ;
    rdfs:comment 'The method used to calculate the channel-specific rate from the base rate. FLAT = fixed absolute rate amount; PERCENTAGE = percentage markup or markdown applied to a base rate; BAR_DERIVED = derived as a percentage or offset from the Best Available Rate (BAR); YIELD_MANAGED = dynamically set by the Revenue Management System (RMS); NEGOTIATED_FIXED = fixed contracted rate for corporate or wholesale agreements.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLoadingStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Loading Status' ;
    rdfs:comment 'Operational status of the rate plan loading process to the channel. Loaded = successfully transmitted and active on the channel; Pending Load = queued for transmission to the channel; Load Failed = transmission error requiring remediation; Not Loaded = not yet submitted; Deactivated = previously loaded but now removed from the channel.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateParityGroupCode rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Group Code' ;
    rdfs:comment 'Code identifying the rate parity group to which this channel rate plan belongs. Rate plans within the same parity group are monitored for price consistency across channels. Enables grouping of comparable rate plans for parity compliance reporting.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanType rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Type' ;
    rdfs:comment 'Classification of the rate plan by its commercial structure. BAR = Best Available Rate (dynamic public rate); NRR = Non-Refundable Rate (discounted, no cancellation); LRA = Last Room Availability (guaranteed availability for corporate); CORPORATE = negotiated corporate rate; PACKAGE = bundled rate with inclusions; PROMOTIONAL = limited-time promotional rate; WHOLESALE = net rate for tour operators; NEGOTIATED = contracted rate; OPAQUE = channel-opaque pricing. [ENUM-REF-CANDIDATE: BAR|NRR|LRA|CORPORATE|PACKAGE|PROMOTIONAL|WHOLESALE|NEGOTIATED|OPAQUE — promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Room Type Applicability' ;
    rdfs:comment 'Comma-separated list of room type codes to which this channel rate plan applies. If null or \'ALL\', the rate plan applies to all room types at the property. Examples: \'STD,DLX,STE\' or \'ALL\'. Supports room-type-specific channel pricing strategies.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stayDateEnd rdf:type rdf:Property ;
    rdfs:label 'Stay Date End' ;
    rdfs:comment 'The latest arrival date for which this channel rate plan is valid. Bookings must have an arrival date on or before this date. Nullable for open-ended rate plans. Supports seasonal and promotional rate plan management.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stayDateStart rdf:type rdf:Property ;
    rdfs:label 'Stay Date Start' ;
    rdfs:comment 'The earliest arrival date for which this channel rate plan is valid. Bookings made under this rate plan must have an arrival date on or after this date. Supports seasonal rate plan publishing and blackout date management.' ;
    rdfs:domain ind:ChannelRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stopSellId rdf:type rdf:Property ;
    rdfs:label 'Stop Sell Id' ;
    rdfs:comment 'Unique surrogate identifier for each channel stop-sell, close-out, or restriction control record in the Silver layer lakehouse. Primary key for this transactional entity.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomTypeId rdf:type rdf:Property ;
    rdfs:label 'Room Type Id' ;
    rdfs:comment 'Identifier of the specific room type (e.g., King Deluxe, Double Standard) subject to the stop-sell restriction. Null indicates the restriction applies to all room types at the property.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoomType .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Type of inventory control action recorded in this transaction. apply: restriction manually applied; lift: restriction manually removed; modify: restriction parameters changed; auto_apply: restriction applied by RMS automation rule; auto_lift: restriction lifted by RMS automation rule.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adrAtApply rdf:type rdf:Property ;
    rdfs:label 'Adr At Apply' ;
    rdfs:comment 'Average Daily Rate (ADR) for the affected room type and date range at the time the restriction was applied. Provides revenue management context for the stop-sell decision and supports yield optimization analysis.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedByUser rdf:type rdf:Property ;
    rdfs:label 'Applied By User' ;
    rdfs:comment 'Username or employee identifier of the revenue management or channel management user who applied this restriction. Supports accountability and audit trail for inventory control actions.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether this restriction action required managerial approval before being applied. Supports internal control workflows and SOX compliance for material inventory control decisions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the restriction action was approved by the designated manager or supervisor. Null if no approval was required. Supports SOX audit trail for material inventory control decisions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelManagerReference rdf:type rdf:Property ;
    rdfs:label 'Channel Manager Reference' ;
    rdfs:comment 'External reference identifier assigned by the channel manager or connectivity platform (e.g., SiteMinder, Amadeus Central Reservations) when the restriction was transmitted to the distribution channel. Supports cross-system reconciliation.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOut rdf:type rdf:Property ;
    rdfs:label 'Days Out' ;
    rdfs:comment 'Number of days between the date the restriction was applied and the first affected stay date (stay_date_from). Represents the booking window horizon at which the restriction was enacted, used for revenue strategy analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'The real-world date and time when this restriction became active and was enforced across the channel. This is the principal business event timestamp for this transactional record, distinct from the audit creation timestamp.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAllChannels rdf:type rdf:Property ;
    rdfs:label 'Is All Channels' ;
    rdfs:comment 'Indicates whether this restriction applies to all distribution channels simultaneously rather than a single specific channel. True when a property-wide close-out is executed across all channels; False when scoped to a specific channel.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAllRoomTypes rdf:type rdf:Property ;
    rdfs:label 'Is All Room Types' ;
    rdfs:comment 'Indicates whether this restriction applies to all room types at the property rather than a specific room type. True when the restriction is property-wide across all room categories.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemGenerated rdf:type rdf:Property ;
    rdfs:label 'Is System Generated' ;
    rdfs:comment 'Indicates whether this restriction was automatically generated by the Revenue Management System (RMS) or channel manager automation rule, as opposed to being manually applied by a revenue manager.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liftReasonCode rdf:type rdf:Property ;
    rdfs:label 'Lift Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason for lifting the restriction. Examples: DEMAND_SOFTENED, RATE_PARITY_RESTORED, MANUAL_OVERRIDE, SCHEDULED_EXPIRY, CHANNEL_RENEGOTIATED. Null if restriction has not been lifted. [ENUM-REF-CANDIDATE: DEMAND_SOFTENED|RATE_PARITY_RESTORED|MANUAL_OVERRIDE|SCHEDULED_EXPIRY|CHANNEL_RENEGOTIATED|SYSTEM_AUTO — promote to reference product]' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lift Timestamp' ;
    rdfs:comment 'Date and time when the restriction was lifted or removed, re-opening inventory on the affected channel. Null if the restriction is still active or has not yet been lifted.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:liftedByUser rdf:type rdf:Property ;
    rdfs:label 'Lifted By User' ;
    rdfs:comment 'Username or employee identifier of the user who lifted or removed this restriction. Null if the restriction has not been lifted or was lifted automatically by the system.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupancyAtApply rdf:type rdf:Property ;
    rdfs:label 'Occupancy At Apply' ;
    rdfs:comment 'Property or room-type occupancy percentage at the time the restriction was applied. Provides context for the revenue management decision and supports post-hoc analysis of restriction effectiveness. Expressed as a percentage (e.g., 85.50 = 85.50%).' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateParityFlag rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Flag' ;
    rdfs:comment 'Indicates whether this stop-sell action was triggered by a rate parity breach on the affected channel. True when the restriction is applied to enforce rate parity compliance across distribution channels.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason for applying the stop-sell or restriction. Examples include: HIGH_DEMAND, RATE_PARITY_BREACH, CHANNEL_PERFORMANCE, OVERBOOKING_PROTECTION, RENOVATION, ALLOTMENT_EXHAUSTED. [ENUM-REF-CANDIDATE: HIGH_DEMAND|RATE_PARITY_BREACH|CHANNEL_PERFORMANCE|OVERBOOKING_PROTECTION|RENOVATION|ALLOTMENT_EXHAUSTED|SYSTEM_AUTO — promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context or justification for the restriction beyond the standardized reason code. Entered by the revenue manager or channel manager at the time of action.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Restriction Duration Days' ;
    rdfs:comment 'Number of calendar days spanned by the restriction date range (stay_date_to minus stay_date_from + 1). Supports analysis of restriction scope and revenue impact assessment.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Restriction Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this stop-sell or restriction control action, as generated by the CRS (Sabre SynXis) or channel manager. Used for cross-system traceability and audit reconciliation.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionStatus rdf:type rdf:Property ;
    rdfs:label 'Restriction Status' ;
    rdfs:comment 'Current lifecycle state of the stop-sell or restriction control record. active: restriction is currently enforced; lifted: restriction has been removed; pending: restriction is queued for activation; cancelled: restriction was voided before activation; expired: restriction passed its scheduled end without explicit lift.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of the inventory restriction being applied to the channel. stop_sell: no new bookings accepted; closed_to_arrival (CTA): no check-ins on the stay date; closed_to_departure (CTD): no check-outs on the stay date; min_los: minimum Length of Stay (LOS) required; max_los: maximum LOS allowed; close_out: full inventory closure.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revparAtApply rdf:type rdf:Property ;
    rdfs:label 'Revpar At Apply' ;
    rdfs:comment 'Revenue Per Available Room (RevPAR) for the affected property or room type at the time the restriction was applied. Key revenue management KPI used to contextualize the stop-sell decision and evaluate channel mix optimization outcomes.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stayDateFrom rdf:type rdf:Property ;
    rdfs:label 'Stay Date From' ;
    rdfs:comment 'First stay date (inclusive) in the date range to which this restriction applies. Represents the beginning of the affected inventory window in the property calendar.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stayDateTo rdf:type rdf:Property ;
    rdfs:label 'Stay Date To' ;
    rdfs:comment 'Last stay date (inclusive) in the date range to which this restriction applies. Represents the end of the affected inventory window in the property calendar.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Transmission Status' ;
    rdfs:comment 'Status of the restriction transmission to the distribution channel via the CRS or channel manager. pending: queued for transmission; transmitted: sent to channel; confirmed: acknowledged by channel; failed: transmission error; retrying: re-attempting after failure. Critical for ensuring inventory control actions are successfully propagated.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Date and time when the restriction was successfully transmitted to the distribution channel via the CRS or channel manager. Null if transmission is pending or failed. Supports SLA monitoring for inventory control propagation.' ;
    rdfs:domain ind:StopSell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:commissionAccrualId rdf:type rdf:Property ;
    rdfs:label 'Commission Accrual Id' ;
    rdfs:comment 'Unique surrogate identifier for each commission accrual record in the Databricks Silver Layer. Primary key for this transactional entity. ROLE: TRANSACTION_HEADER.' ;
    rdfs:domain ind:CommissionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: Commission accruals need to link to AR invoices for revenue recognition and reconciliation. When commissions are invoiced to OTA partners, this FK tracks the billing document. This is a standard finan' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:commissionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Commission Schedule Id' ;
    rdfs:comment 'Reference to the commission schedule or rate agreement applied to this accrual record. Determines the applicable commission rate tier, calculation method, and contractual terms with the OTA or GDS partner.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommissionSchedule .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Commission payments to foreign OTAs trigger tax withholding and regulatory filing requirements (IRS 1099 reporting, VAT filings, cross-border payment reporting). Real business process: tax compliance ' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:accrualDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Date' ;
    rdfs:comment 'The accounting date on which the commission liability was recognized in the general ledger. Aligns with USALI period-end accrual practices and SAP S/4HANA GL posting date. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:CommissionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle state of the commission accrual record. Drives AP (Accounts Payable) workflow in SAP S/4HANA: \'accrued\' = liability recognized; \'invoiced\' = OTA invoice received; \'paid\' = payment disbursed; \'disputed\' = under reconciliation review; \'cancelled\' = booking cancelled before stay; \'reversed\' = accrual reversed due to no-show or refund. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:CommissionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date on which the reservation was cancelled, if applicable. When populated, triggers commission accrual reversal logic per the cancellation policy terms. Null for active or completed bookings.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commissionAmountBase rdf:type rdf:Property ;
    rdfs:label 'Commission Amount Base' ;
    rdfs:comment 'The commission amount converted to the company\'s functional base currency (typically USD) for consolidated financial reporting and USALI-compliant P&L statements. Enables cross-property and cross-currency commission cost analysis. Part of TRANSACTION_HEADER MONETARY_TRIPLET.' ;
    rdfs:domain ind:CommissionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionAmountLocal rdf:type rdf:Property ;
    rdfs:label 'Commission Amount Local' ;
    rdfs:comment 'The calculated commission amount payable to the distribution channel partner in the local transaction currency (gross_booking_value × commission_rate). Used for OTA invoice reconciliation and AP liability posting. Part of TRANSACTION_HEADER MONETARY_TRIPLET.' ;
    rdfs:domain ind:CommissionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionType rdf:type rdf:Property ;
    rdfs:label 'Commission Type' ;
    rdfs:comment 'Classification of the commission arrangement: \'standard\' = default contractual rate; \'override\' = manually overridden rate approved by revenue management; \'promotional\' = time-limited promotional rate; \'group\' = group booking commission; \'negotiated\' = bilaterally negotiated rate outside standard schedule.' ;
    rdfs:domain ind:CommissionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Notes' ;
    rdfs:comment 'Free-text notes describing the nature of a commission dispute with the OTA or GDS partner. Populated when accrual_status is \'disputed\'. Supports the channel dispute resolution workflow and AP reconciliation process.' ;
    rdfs:domain ind:CommissionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'The exchange rate applied to convert the local currency commission amount to the base currency at the time of accrual. Sourced from SAP S/4HANA treasury rates. Required for accurate multi-currency financial reporting and audit trail.' ;
    rdfs:domain ind:CommissionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The SAP S/4HANA GL account code to which the commission expense is posted (e.g., USALI Schedule 6 - Sales and Marketing / Distribution Costs). Ensures correct financial statement classification per USALI and GAAP/IFRS.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date on the commission invoice received from the OTA or GDS partner. Used for AP aging analysis, payment due date calculation, and period-end accrual reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The OTA or GDS partner\'s invoice reference number received for commission payment. Used to match accrued commission liabilities against received invoices in SAP S/4HANA AP for three-way reconciliation. Null until invoice is received.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCommissionable rdf:type rdf:Property ;
    rdfs:label 'Is Commissionable' ;
    rdfs:comment 'Indicates whether the booking is eligible for commission payment (True) or is a non-commissionable booking (False), such as direct loyalty redemptions, staff rates, or complimentary stays. Drives commission accrual logic and AP posting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the transaction currency in which the booking was made and commission is denominated (e.g., USD, EUR, GBP). Required for multi-currency commission reconciliation and FX conversion. Part of TRANSACTION_HEADER MONETARY_TRIPLET.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date on which the commission payment was disbursed to the OTA or GDS partner. Populated when accrual_status transitions to \'paid\'. Used for AP reconciliation and cash flow reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The contractual due date by which the commission payment must be disbursed to the OTA or GDS partner per the commission schedule terms. Used for AP cash flow planning and SLA compliance monitoring.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'The payment transaction reference or bank transfer reference number from SAP S/4HANA AP when the commission is disbursed. Enables end-to-end traceability from accrual to cash payment for audit and reconciliation purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'The reason code for reversing a previously accrued commission. Populated when accrual_status is \'reversed\' or \'cancelled\'. Supports AP reconciliation and channel dispute management. [ENUM-REF-CANDIDATE: cancellation|no_show|rate_correction|duplicate|dispute_resolved|other — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomNights rdf:type rdf:Property ;
    rdfs:label 'Room Nights' ;
    rdfs:comment 'The number of room nights associated with the booking for which commission is being accrued. Used to calculate CPOR (Cost Per Occupied Room) and to normalize commission costs across bookings of varying LOS (Length of Stay).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCostOfAcquisition rdf:type rdf:Property ;
    rdfs:label 'Total Cost Of Acquisition' ;
    rdfs:comment 'The total distribution cost for this booking, combining commission_amount_local and connectivity_fee_amount. Represents the all-in cost of acquiring the booking through this channel. Used for channel profitability and net RevPAR analysis.' ;
    rdfs:domain ind:CommissionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the AP vendor master record in SAP S/4HANA for the channel partner, used for invoice processing, payment execution, and vendor reconciliation. Links commission schedules to the financial AP workflow.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:appliesToCancellations rdf:type rdf:Property ;
    rdfs:label 'Applies To Cancellations' ;
    rdfs:comment 'Indicates whether the commission or fee is still payable when a booking is cancelled (True = commission owed on cancellations, False = commission waived on cancellations). Critical for NRR (Non-Refundable Rate) commission accrual and cancellation cost management.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToNoShows rdf:type rdf:Property ;
    rdfs:label 'Applies To No Shows' ;
    rdfs:comment 'Indicates whether the commission or fee is payable on no-show bookings (True = commission owed on no-shows, False = commission waived). Affects no-show revenue net-of-commission calculations and OTA contract compliance.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoAccrualEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Accrual Enabled' ;
    rdfs:comment 'Indicates whether commission and fee accruals under this schedule are automatically calculated and posted to the GL upon booking confirmation (True) or require manual accrual processing (False). Supports automated AP accrual workflows in SAP S/4HANA.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which the channel partner invoices the property for commissions or fees: monthly (most common for OTA commissions), weekly, per_booking (real-time deduction), quarterly, annual (common for connectivity subscription fees). Drives AP accrual scheduling and cash flow forecasting.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the flat fee or tiered threshold amounts are denominated (e.g., USD, EUR, GBP). Required for multi-currency AP reconciliation and cost-of-acquisition reporting.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeStructure rdf:type rdf:Property ;
    rdfs:label 'Fee Structure' ;
    rdfs:comment 'Defines how the commission or fee is calculated: percentage (applied as a % of booking revenue or room revenue), flat (fixed monetary amount per booking or period), tiered (rate varies by volume or revenue thresholds), per_unit (fixed amount per room-night, segment, or transaction unit). Determines the accrual calculation method.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeType rdf:type rdf:Property ;
    rdfs:label 'Fee Type' ;
    rdfs:comment 'Classification of the cost type captured by this schedule: commission (percentage of booking revenue paid to OTA/agent), per_segment_fee (GDS per-segment charge), per_transaction_fee (CRS per-booking transaction fee), connectivity_fee (channel manager or switch connectivity charge), subscription_fee (fixed periodic platform fee), override_commission (negotiated override above standard rate). Drives AP coding and cost-of-acquisition (COA) categorization.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'Fixed monetary fee amount per booking, segment, transaction, or billing period, expressed in the schedule currency. Applicable when fee_structure is \'flat\' or \'per_unit\'. Used for GDS per-segment fees, CRS per-transaction fees, and connectivity subscription fees. Confidential as it reflects negotiated commercial terms.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:losMinNights rdf:type rdf:Property ;
    rdfs:label 'Los Min Nights' ;
    rdfs:comment 'Minimum Length of Stay (LOS) in nights required for this commission schedule to apply. Null indicates no LOS restriction. Supports commission scoping for extended-stay or minimum-stay rate plans.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Max Commission Amount' ;
    rdfs:comment 'Contractual cap on the commission or fee amount payable per booking or per billing period. Applicable for schedules with a commission ceiling clause. Expressed in fee_currency_code. Confidential as it reflects negotiated commercial terms.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Min Commission Amount' ;
    rdfs:comment 'Contractual minimum commission or fee amount payable per booking or per billing period, regardless of the calculated percentage amount. Applicable for schedules with a commission floor clause. Expressed in fee_currency_code. Confidential as it reflects negotiated commercial terms.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedBy rdf:type rdf:Property ;
    rdfs:label 'Negotiated By' ;
    rdfs:comment 'Name or identifier of the internal team or individual (e.g., Revenue Management, Channel Distribution, Procurement) responsible for negotiating this commission schedule. Used for accountability tracking and contract ownership.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice receipt within which payment to the channel partner is due (e.g., 30 = Net 30). Used in AP aging analysis and cash flow management per SAP S/4HANA payment terms configuration.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueBase rdf:type rdf:Property ;
    rdfs:label 'Revenue Base' ;
    rdfs:comment 'Defines the revenue component on which the commission percentage is calculated: room_revenue (room charges only), total_revenue (all charges including F&B and ancillaries), net_revenue (after discounts and taxes), gross_revenue (before deductions), f_and_b_revenue (food and beverage charges only). Critical for accurate commission accrual and invoice reconciliation.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this commission or fee schedule, used in AP reconciliation, contract references, and channel partner communications (e.g., OTA-EXP-COMM-2024, GDS-SAB-SEG-FEE).' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable descriptive name for the commission or fee schedule, used in reporting dashboards, AP workflows, and channel profitability analysis (e.g., \'Expedia Standard OTA Commission FY2024\', \'Sabre GDS Per-Segment Fee Q1 2024\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the commission schedule: active (currently in force), inactive (temporarily suspended), pending (approved but not yet effective), expired (past effective_until date), terminated (cancelled before expiry), draft (under negotiation, not yet approved). Drives AP processing eligibility and accrual inclusion.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier1RatePct rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Rate Pct' ;
    rdfs:comment 'Commission rate percentage applicable when booking volume or revenue falls within the Tier 1 threshold band in a tiered fee structure. Confidential as it reflects negotiated commercial terms.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Threshold' ;
    rdfs:comment 'Lower volume or revenue threshold (in booking count or currency amount) that triggers the Tier 1 commission or fee rate in a tiered fee structure. Applicable when fee_structure is \'tiered\'. Confidential as it reflects negotiated commercial terms.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2RatePct rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Rate Pct' ;
    rdfs:comment 'Commission rate percentage applicable when booking volume or revenue falls within the Tier 2 threshold band in a tiered fee structure. Confidential as it reflects negotiated commercial terms.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Threshold' ;
    rdfs:comment 'Upper volume or revenue threshold that triggers the Tier 2 commission or fee rate in a tiered fee structure. Applicable when fee_structure is \'tiered\'. Confidential as it reflects negotiated commercial terms.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectivityFeeId rdf:type rdf:Property ;
    rdfs:label 'Connectivity Fee Id' ;
    rdfs:comment 'Unique surrogate identifier for each connectivity fee record in the channel distribution cost management system. Primary key for the connectivity_fee data product.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ap_invoice. Business justification: Connectivity fees from channel managers and GDS providers generate AP invoices for payment processing. Required for three-way match validation, payment scheduling, and expense recognition in financial' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:crsChannelMappingId rdf:type rdf:Property ;
    rdfs:label 'Crs Channel Mapping Id' ;
    rdfs:comment 'The channel identifier as configured in the Sabre SynXis CRS channel management module. Maps this fee record to the specific CRS channel configuration for booking source attribution and rate distribution cost tracking.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrsChannelMapping .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The calendar date on which this connectivity fee schedule was formally approved by the authorized approver. Used for audit trail, financial controls compliance, and contract lifecycle management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingSegment rdf:type rdf:Property ;
    rdfs:label 'Booking Segment' ;
    rdfs:comment 'The market segment classification of bookings to which this connectivity fee applies. Transient covers FIT (Free Independent Traveler) bookings. Group covers MICE (Meetings, Incentives, Conferences, Exhibitions) and group blocks. Corporate covers negotiated corporate rate bookings. Loyalty covers bookings made through the loyalty program channel.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The SAP S/4HANA cost center code to which this connectivity fee is allocated for management accounting and OpEx (Operating Expenditure) reporting. Supports departmental cost attribution under USALI standards.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The calendar date on which this connectivity fee schedule becomes effective and begins to be applied to qualifying transactions. Used for fee schedule versioning and historical cost-of-acquisition analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The calendar date on which this connectivity fee schedule expires and ceases to be applied. Null for open-ended fee schedules with no defined end date. Used for contract lifecycle management and fee schedule versioning.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'The base monetary amount of the connectivity fee as specified in the fee schedule. For flat-rate and per-transaction fees, this is the fixed charge. For percentage-based fees, this field stores the rate value (e.g., 0.0350 for 3.50%). Currency is defined in the fee_currency field.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Basis' ;
    rdfs:comment 'The calculation basis for the connectivity fee. Flat rate is a fixed amount per billing period. Percentage is applied to the booking value. Tiered applies different rates based on volume thresholds. Per room night is charged for each room night booked. Per booking is charged once per reservation regardless of length of stay (LOS).' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the connectivity fee is denominated (e.g., USD, EUR, GBP). Required for multi-currency property portfolios to ensure accurate cost-of-acquisition calculations and financial reporting.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Description' ;
    rdfs:comment 'Free-text description of the connectivity fee as defined in the technology provider contract or fee schedule. Provides additional context beyond the fee_type classification, such as specific service scope, applicable booking conditions, or contractual notes.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fee Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned by the technology provider (GDS network, CRS provider, or channel manager) to uniquely identify this fee schedule or billing line item. Used for invoice reconciliation and vendor correspondence.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Status' ;
    rdfs:comment 'Current lifecycle state of the connectivity fee schedule record. Active indicates the fee is currently being applied to bookings. Inactive indicates the fee has been deactivated. Pending indicates the fee schedule is awaiting activation. Suspended indicates the fee is temporarily paused. Expired indicates the fee schedule has passed its effective end date.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNegotiatedRate rdf:type rdf:Property ;
    rdfs:label 'Is Negotiated Rate' ;
    rdfs:comment 'Indicates whether this connectivity fee was negotiated as part of a custom contract with the technology provider, as opposed to a standard published rate. True for negotiated fees; False for standard published fees. Supports contract performance monitoring.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWaived rdf:type rdf:Property ;
    rdfs:label 'Is Waived' ;
    rdfs:comment 'Indicates whether this connectivity fee has been waived by the technology provider, typically as part of a promotional arrangement or contract concession. True if the fee is waived; False if the fee is applicable. Waived fees are retained for audit and cost-of-acquisition baseline analysis.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Fee Amount' ;
    rdfs:comment 'The maximum monetary amount charged per billing period, acting as a cap on variable or percentage-based fees. Null if no maximum cap applies. Used in contract negotiations and cost forecasting.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Fee Amount' ;
    rdfs:comment 'The minimum monetary amount charged per billing period regardless of transaction volume. Applicable for tiered or percentage-based fee structures where the provider guarantees a floor charge. Null if no minimum applies.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'The payment terms agreed with the technology provider for settlement of connectivity fees (e.g., Net 30 days from invoice date). Used by accounts payable in SAP S/4HANA for payment scheduling and cash flow management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyScope rdf:type rdf:Property ;
    rdfs:label 'Property Scope' ;
    rdfs:comment 'Indicates whether this connectivity fee applies to a single property, a defined portfolio of properties, a brand segment, a geographic region, or the entire global estate. Determines how the fee is allocated across the property hierarchy for cost management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanApplicability rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Applicability' ;
    rdfs:comment 'Specifies the rate plan codes or rate plan categories (e.g., BAR, LRA, NRR, corporate negotiated) to which this connectivity fee applies. Null if the fee applies to all rate plans on the channel. Supports granular cost-of-acquisition analysis by rate type.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The timestamp when this connectivity fee record was first created in the system. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for audit trail, data lineage, and compliance with financial record-keeping requirements.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp when this connectivity fee record was last modified. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change tracking, audit trail, and incremental data pipeline processing in the Databricks Lakehouse Silver Layer.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxApplicable rdf:type rdf:Property ;
    rdfs:label 'Tax Applicable' ;
    rdfs:comment 'Indicates whether applicable taxes (e.g., VAT, GST, sales tax) are charged on top of this connectivity fee. True if taxes apply; False if the fee is tax-exempt. Supports accurate total cost-of-acquisition calculation and tax compliance reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The applicable tax rate as a decimal fraction applied to the connectivity fee amount when tax_applicable is True (e.g., 0.2000 for 20% VAT). Used for total cost-of-acquisition calculation and tax liability reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Number' ;
    rdfs:comment 'The accounts payable vendor account number in SAP S/4HANA (Finance AP) assigned to the technology connectivity provider. Used for invoice matching, payment processing, and financial reconciliation of connectivity costs.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTierThreshold rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold' ;
    rdfs:comment 'The transaction or segment volume threshold at which a tiered fee rate changes. For example, a threshold of 1000 means the fee rate changes after 1000 transactions per billing period. Null for flat-rate or non-tiered fee structures.' ;
    rdfs:domain ind:ConnectivityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Descriptive reason explaining why the connectivity fee was waived (e.g., promotional period, volume commitment met, contract renegotiation). Populated only when is_waived is True. Required for audit trail and financial controls compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelContractReference rdf:type rdf:Property ;
    rdfs:label 'Channel Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the commercial contract governing the distribution relationship with this channel (e.g., OTA master agreement number, GDS connectivity contract ID). Used for contract management, commission dispute resolution, and audit compliance.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Channel Property Code' ;
    rdfs:comment 'The property identifier code as recognized by the distribution channel (e.g., Booking.com hotel ID, Expedia property ID, GDS chain/property code). Used to match the CRS property to the channel\'s own property record during rate and availability pushes.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityProtocol rdf:type rdf:Property ;
    rdfs:label 'Connectivity Protocol' ;
    rdfs:comment 'The technical messaging protocol used for rate and availability distribution between Sabre SynXis CRS and the channel (e.g., OTA XML, HTNG, OpenTravel Alliance ARI). Determines the message format and integration method. [ENUM-REF-CANDIDATE: OTA_XML|HTNG|OpenTravel|ARI|TravelPort|Amadeus|direct_API — promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSyncEnabled rdf:type rdf:Property ;
    rdfs:label 'Content Sync Enabled' ;
    rdfs:comment 'Indicates whether property content (room descriptions, images, amenities) is synchronized to the channel through this mapping in addition to rates and availability. Relevant for OTA and metasearch channels that require content distribution alongside rate/inventory feeds.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crsPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Crs Property Code' ;
    rdfs:comment 'The property identifier code as registered in Sabre SynXis CRS. This is the CRS-side property reference used in all rate and availability distribution messages to channels. Distinct from the internal property_id.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteePolicyCode rdf:type rdf:Property ;
    rdfs:label 'Guarantee Policy Code' ;
    rdfs:comment 'Code identifying the payment guarantee policy required for bookings through this channel mapping (e.g., \'CC_REQUIRED\' for credit card guarantee, \'DEPOSIT\' for advance deposit). Ensures PCI DSS-compliant payment handling requirements are communicated to the channel.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryAllocationType rdf:type rdf:Property ;
    rdfs:label 'Inventory Allocation Type' ;
    rdfs:comment 'Defines how room inventory is allocated to this channel. \'pooled\' means the channel draws from the shared inventory pool; \'allotment\' means a fixed block is reserved for the channel; \'free_sell\' means unlimited sell without allocation; \'on_request\' means availability must be confirmed manually.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMobileOptimized rdf:type rdf:Property ;
    rdfs:label 'Is Mobile Optimized' ;
    rdfs:comment 'Indicates whether this channel mapping is configured to distribute mobile-specific rates or content optimized for mobile booking platforms. Supports mobile channel performance analytics and targeted mobile rate strategy.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful rate and availability synchronization push from Sabre SynXis CRS to the distribution channel for this mapping. Used to monitor channel connectivity health, detect stale distributions, and support SLA compliance reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lraFlag rdf:type rdf:Property ;
    rdfs:label 'Lra Flag' ;
    rdfs:comment 'Indicates whether this channel mapping is configured with Last Room Availability (LRA), meaning the channel has access to the last available room in the property\'s inventory. LRA is typically granted to GDS corporate accounts and preferred OTA partners under contractual obligation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mappingCode rdf:type rdf:Property ;
    rdfs:label 'Mapping Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying this CRS-to-channel mapping configuration within Sabre SynXis. Used as the business identifier for cross-system reference and audit. Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingName rdf:type rdf:Property ;
    rdfs:label 'Mapping Name' ;
    rdfs:comment 'Human-readable descriptive name for this CRS channel mapping configuration (e.g., \'Booking.com Standard Rate Mapping - NYC Midtown\'). Serves as the IDENTITY_LABEL for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingStatus rdf:type rdf:Property ;
    rdfs:label 'Mapping Status' ;
    rdfs:comment 'Current operational lifecycle status of this CRS channel mapping. \'active\' means the mapping is live and distributing rates/availability; \'suspended\' means temporarily halted; \'testing\' means in QA validation. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingType rdf:type rdf:Property ;
    rdfs:label 'Mapping Type' ;
    rdfs:comment 'Classification of what this mapping configuration governs — whether it maps rate plans, room types, inventory controls, packages, or promotional offers to the channel. Serves as the CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAdvanceBookingDays rdf:type rdf:Property ;
    rdfs:label 'Max Advance Booking Days' ;
    rdfs:comment 'Maximum number of days in advance that a booking can be made through this channel mapping (booking window). Controls how far into the future availability is published to the channel. Null indicates no maximum booking window restriction.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minAdvanceBookingDays rdf:type rdf:Property ;
    rdfs:label 'Min Advance Booking Days' ;
    rdfs:comment 'Minimum number of days in advance that a booking must be made through this channel mapping. Used to enforce advance purchase restrictions (e.g., NRR non-refundable rates requiring 7-day advance booking) as distributed via the CRS.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateOffsetType rdf:type rdf:Property ;
    rdfs:label 'Rate Offset Type' ;
    rdfs:comment 'Defines whether a rate adjustment (offset) is applied to the CRS rate before distribution to this channel. \'none\' means the CRS rate is published as-is; \'flat_amount\' means a fixed currency amount is added or subtracted; \'percentage\' means a percentage markup or markdown is applied.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateOffsetValue rdf:type rdf:Property ;
    rdfs:label 'Rate Offset Value' ;
    rdfs:comment 'The numeric value of the rate offset applied to the CRS rate before distribution to this channel. Positive values indicate a markup; negative values indicate a markdown. Interpreted as a currency amount or percentage depending on rate_offset_type. Null when rate_offset_type is \'none\'.' ;
    rdfs:domain ind:CrsChannelMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateParityEnforced rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Enforced' ;
    rdfs:comment 'Indicates whether rate parity rules are enforced for this channel mapping, requiring that the rates distributed to this channel match the Best Available Rate (BAR) published on other channels. Critical for OTA contract compliance and rate integrity monitoring.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sellLimit rdf:type rdf:Property ;
    rdfs:label 'Sell Limit' ;
    rdfs:comment 'Maximum number of rooms that can be sold through this channel per night under the current allocation configuration. A null or zero value indicates no sell limit is applied (free sell). Used to control channel-level inventory exposure and prevent overbooking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syncFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Sync Frequency Minutes' ;
    rdfs:comment 'Configured frequency in minutes at which rate and availability updates are pushed from the CRS to this channel. Lower values indicate near-real-time distribution (e.g., 5 minutes for OTA partners); higher values indicate batch distribution schedules.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdsAccountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Gds Account Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GDS account managers are employees managing GDS connectivity, troubleshooting technical issues, and optimizing GDS performance. Critical for operational accountability, issue escalation, and performan' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:thirdPartyDueDiligenceId rdf:type rdf:Property ;
    rdfs:label 'Third Party Due Diligence Id' ;
    rdfs:comment 'Foreign key linking to compliance.third_party_due_diligence. Business justification: GDS providers are third-party data processors handling guest PII and payment data, requiring due diligence for data security, sanctions compliance, and financial stability. Real business process: tech' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyDueDiligence .

ind:availabilitySyncMethod rdf:type rdf:Property ;
    rdfs:label 'Availability Sync Method' ;
    rdfs:comment 'Method by which room availability is synchronized between the property management system and the GDS. Real-time provides instant updates; batch updates on a scheduled interval; on_request queries availability at booking time; seamless provides live two-way availability.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainCode rdf:type rdf:Property ;
    rdfs:label 'Chain Code' ;
    rdfs:comment 'Two- to four-character hotel chain code registered with the GDS network, identifying the hotel brand or management company within the GDS. Assigned by the GDS provider and used for inventory and rate loading.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Status' ;
    rdfs:comment 'Current operational lifecycle status of the GDS connection. Active indicates live booking capability; suspended indicates temporary halt; pending_activation indicates setup in progress; decommissioned indicates permanently retired.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityFeeMonthlyUsd rdf:type rdf:Property ;
    rdfs:label 'Connectivity Fee Monthly Usd' ;
    rdfs:comment 'Fixed monthly fee charged by the GDS provider or switch vendor for maintaining the technical connectivity of this GDS connection. Distinct from per-segment fees; used for OpEx budgeting and channel cost allocation.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectivityType rdf:type rdf:Property ;
    rdfs:label 'Connectivity Type' ;
    rdfs:comment 'Technical connectivity model used for this GDS connection. Direct connect provides real-time two-way communication; switch connect routes through a switch provider; seamless provides full availability and rate transparency; standard uses batch updates.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateRateEnabled rdf:type rdf:Property ;
    rdfs:label 'Corporate Rate Enabled' ;
    rdfs:comment 'Indicates whether negotiated corporate rates are loaded and accessible through this GDS connection. Corporate rates are a primary revenue stream for GDS channels and require specific rate plan configuration in the CRS.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crsInterfaceCode rdf:type rdf:Property ;
    rdfs:label 'Crs Interface Code' ;
    rdfs:comment 'Identifier for the CRS-to-GDS interface configuration within Sabre SynXis CRS. Links the GDS connection to the specific CRS interface instance managing rate distribution and availability synchronization.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Numeric priority ranking that determines the property\'s display order in GDS search results for travel agents. Lower values indicate higher priority. Influenced by GDS tier, participation level, and performance metrics.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdsName rdf:type rdf:Property ;
    rdfs:label 'Gds Name' ;
    rdfs:comment 'Human-readable name of the GDS provider (Sabre, Amadeus, Galileo, Worldspan, Travelport). Used for reporting, dashboards, and channel mix analysis.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Gds Network Code' ;
    rdfs:comment 'Industry-standard two-character GDS network identifier assigned by IATA/ARC. 1S=Sabre, 1A=Amadeus, 1G=Galileo/Travelport, 1P=Worldspan. Used for routing and segment fee attribution.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsTier rdf:type rdf:Property ;
    rdfs:label 'Gds Tier' ;
    rdfs:comment 'Participation tier level for this GDS connection, reflecting the level of GDS merchandising, display priority, and content features contracted. Preferred tier provides enhanced display and content capabilities; standard is base participation; basic is minimal listing.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Health Check Status' ;
    rdfs:comment 'Result of the most recent automated health check for this GDS connection. Healthy indicates full two-way connectivity; degraded indicates partial functionality; failed indicates connectivity loss; unknown indicates health check has not been performed.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastHealthCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Health Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent automated connectivity health check performed for this GDS connection. Used for SLA monitoring, connectivity uptime reporting, and proactive issue detection.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lraEnabled rdf:type rdf:Property ;
    rdfs:label 'Lra Enabled' ;
    rdfs:comment 'Indicates whether Last Room Availability (LRA) is enabled for this GDS connection, requiring the property to make the last available room accessible to GDS bookers. LRA is a contractual obligation with some GDS providers and corporate accounts.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nrrSupported rdf:type rdf:Property ;
    rdfs:label 'Nrr Supported' ;
    rdfs:comment 'Indicates whether Non-Refundable Rates (NRR) can be loaded and booked through this GDS connection. NRR support is a key revenue management capability enabling advance purchase rate strategies via GDS.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:propertyCodeGds rdf:type rdf:Property ;
    rdfs:label 'Property Code Gds' ;
    rdfs:comment 'The unique property identifier as registered within the specific GDS network. May differ from the internal PMS property code. Used for inventory display and booking routing within the GDS.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pseudoCityCode rdf:type rdf:Property ;
    rdfs:label 'Pseudo City Code' ;
    rdfs:comment 'GDS-assigned Pseudo City Code (PCC) that identifies the travel agency or booking office within the GDS network. Used for commission tracking, segment attribution, and agency relationship management.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLoadingProtocol rdf:type rdf:Property ;
    rdfs:label 'Rate Loading Protocol' ;
    rdfs:comment 'The technical protocol or standard used to load and update rate plans into the GDS. HTNG and OTA are XML-based standards; DHISCO is a switch-based protocol; manual indicates rates are loaded via GDS terminal; API indicates direct programmatic loading.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanCount rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Count' ;
    rdfs:comment 'Number of distinct rate plans currently loaded and active for this GDS connection. Used to monitor rate plan coverage, identify gaps in GDS rate distribution, and support rate parity audits.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateUpdateFrequency rdf:type rdf:Property ;
    rdfs:label 'Rate Update Frequency' ;
    rdfs:comment 'Frequency at which rate updates are pushed from the Revenue Management System (RMS) or CRS to this GDS connection. Real-time supports dynamic pricing; scheduled frequencies reflect batch update configurations.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Segment Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the GDS segment fee. Enables multi-currency cost-of-acquisition reporting for properties operating in non-USD markets.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Segment Fee Usd' ;
    rdfs:comment 'Per-booking segment fee charged by the GDS provider in US dollars for each reservation booked through this GDS connection. A GDS segment is one hotel booking transaction. Used for cost-of-acquisition analysis and channel profitability reporting.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportContactEmail rdf:type rdf:Property ;
    rdfs:label 'Support Contact Email' ;
    rdfs:comment 'Email address for the GDS provider\'s technical support team for this connection. Used for connectivity issue escalation, health check alerts, and SLA breach notifications.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:switchProvider rdf:type rdf:Property ;
    rdfs:label 'Switch Provider' ;
    rdfs:comment 'Name of the third-party switch provider (e.g., DHISCO, TravelClick, Pegasus) used to route availability and rate data between the CRS and the GDS, when connectivity_type is switch_connect. Null for direct connect configurations.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimeSlaPct rdf:type rdf:Property ;
    rdfs:label 'Uptime Sla Pct' ;
    rdfs:comment 'Contractually agreed minimum uptime percentage for this GDS connection as specified in the GDS connectivity SLA. Used for vendor performance monitoring and contract compliance reporting.' ;
    rdfs:domain ind:GdsConnection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelInventoryAllocationId rdf:type rdf:Property ;
    rdfs:label 'Channel Inventory Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each inventory allocation record in the channel distribution system. Primary key for the inventory_allocation data product.' ;
    rdfs:domain ind:ChannelInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryChannelId rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Id' ;
    rdfs:comment 'Reference to the distribution channel (OTA, GDS, direct, voice, etc.) to which this inventory allocation applies. Sourced from Sabre SynXis CRS channel configuration.' ;
    rdfs:domain ind:ChannelInventoryAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:primaryChannelRoomTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Room Type Id' ;
    rdfs:comment 'Reference to the room type (e.g., standard king, deluxe double, suite) for which inventory is being allocated to the channel.' ;
    rdfs:domain ind:ChannelInventoryAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoomType .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current operational status of this channel inventory allocation. Active allocations are enforced by the channel management system.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedUnits rdf:type rdf:Property ;
    rdfs:label 'Allocated Units' ;
    rdfs:comment 'The total number of room nights (units) assigned to this channel for the specified stay date range and room type. Represents the allotment block size or sell limit granted to the channel.' ;
    rdfs:domain ind:ChannelInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned by the Central Reservation System (CRS) or Property Management System (PMS) to uniquely identify this inventory allocation action. Used for cross-system reconciliation between Sabre SynXis CRS and Oracle OPERA PMS.' ;
    rdfs:domain ind:ChannelInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of the inventory allocation record. ACTIVE indicates the allocation is live and controlling channel availability; INACTIVE means it has been superseded; EXPIRED means the stay date range has passed; CANCELLED means it was manually revoked; PENDING means it is awaiting activation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Method by which inventory is allocated to this channel for this room type. POOLED = shared inventory pool, ALLOCATED = fixed allocation, FREESALE = unlimited access, BLOCKED = no access.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allotmentType rdf:type rdf:Property ;
    rdfs:label 'Allotment Type' ;
    rdfs:comment 'Classification of the inventory allotment method applied to this channel. FREE_SELL allows the channel to sell without a fixed block; ALLOCATION assigns a fixed block of rooms; STOP_SELL halts sales on the channel; CLOSE_OUT removes all availability; ON_REQUEST requires manual confirmation before booking is confirmed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableUnits rdf:type rdf:Property ;
    rdfs:label 'Available Units' ;
    rdfs:comment 'The number of room nights currently available for sale on this channel, calculated as allocated_units minus consumed_units. Represents the real-time sellable inventory for the channel on the specified stay dates.' ;
    rdfs:domain ind:ChannelInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationCount rdf:type rdf:Property ;
    rdfs:label 'Cancellation Count' ;
    rdfs:comment 'The number of bookings cancelled on this channel allocation since the last reporting snapshot. Used to track net pickup and assess channel-level cancellation patterns for demand forecasting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Channel Allocation Pct' ;
    rdfs:comment 'Percentage of total room type inventory allocated to this channel. Used for allocation-based inventory management strategies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumedUnits rdf:type rdf:Property ;
    rdfs:label 'Consumed Units' ;
    rdfs:comment 'The number of allocated room nights that have been booked or consumed by the channel as of the last system update. Used to calculate remaining availability and monitor channel pickup performance.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when this allocation record was created in the system.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this channel inventory allocation configuration expires. Null for currently active allocations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this channel inventory allocation configuration becomes effective.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isClosedToArrival rdf:type rdf:Property ;
    rdfs:label 'Is Closed To Arrival' ;
    rdfs:comment 'Indicates whether arrivals are blocked on the first date of the stay period for this channel and room type. When TRUE, guests cannot check in on the stay_date_from date, preventing new bookings that start on that date.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClosedToDeparture rdf:type rdf:Property ;
    rdfs:label 'Is Closed To Departure' ;
    rdfs:comment 'Indicates whether departures are blocked on the stay_date_to date for this channel and room type. When TRUE, guests cannot check out on that date, preventing bookings that end on that date.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRmsGenerated rdf:type rdf:Property ;
    rdfs:label 'Is Rms Generated' ;
    rdfs:comment 'Indicates whether this inventory allocation action was automatically generated by the Revenue Management System (IDeaS G3 RMS or Infor EzRMS) as opposed to being manually entered by a revenue manager. Supports analysis of automation adoption and RMS recommendation acceptance rates.' ;
    rdfs:domain ind:ChannelInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStopSell rdf:type rdf:Property ;
    rdfs:label 'Is Stop Sell' ;
    rdfs:comment 'Indicates whether a stop-sell control has been applied to this channel for the specified stay dates and room type. When TRUE, the channel is prevented from accepting new bookings regardless of remaining available units.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Timestamp when this allocation record was last updated.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lraEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Lra Enabled Flag' ;
    rdfs:comment 'Indicates whether Last Room Availability is enabled for this room-type-channel combination, overriding property-level LRA settings.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumLosOverride rdf:type rdf:Property ;
    rdfs:label 'Maximum Los Override' ;
    rdfs:comment 'Channel-specific maximum length of stay restriction for this room type, overriding property-level defaults.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumLosOverride rdf:type rdf:Property ;
    rdfs:label 'Minimum Los Override' ;
    rdfs:comment 'Channel-specific minimum length of stay requirement for this room type, overriding property-level defaults.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingAllowance rdf:type rdf:Property ;
    rdfs:label 'Overbooking Allowance' ;
    rdfs:comment 'The number of additional room nights above the physical inventory that this channel is permitted to sell as part of the property\'s overbooking strategy. A value of 0 means no overbooking is permitted on this channel.' ;
    rdfs:domain ind:ChannelInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingLimitPct rdf:type rdf:Property ;
    rdfs:label 'Overbooking Limit Pct' ;
    rdfs:comment 'Maximum overbooking percentage allowed for this room type on this channel. Used for revenue management optimization.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupCount rdf:type rdf:Property ;
    rdfs:label 'Pickup Count' ;
    rdfs:comment 'The number of new bookings received on this channel allocation since the last reporting snapshot. Supports pickup reporting and demand forecasting in the Revenue Management System (RMS).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateParityEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Enforcement Flag' ;
    rdfs:comment 'Indicates whether rate parity rules are actively enforced for this room type on this channel.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'The date on which any unsold allocated inventory is released back to the general property inventory pool. After this date, the channel no longer holds exclusive rights to the allocated units, enabling the property to sell them through other channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Monotonically incrementing version counter for this inventory allocation record. Incremented each time the allocation is modified, enabling optimistic concurrency control and historical version tracking in the Silver layer.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metasearchListingId rdf:type rdf:Property ;
    rdfs:label 'Metasearch Listing Id' ;
    rdfs:comment 'Unique surrogate identifier for each metasearch listing record in the silver layer. Primary key for this data product. Entity role: MASTER_RESOURCE — represents a managed digital listing asset on a metasearch platform.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastBidUpdatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Bid Updated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Metasearch bid updates by employees require tracking for operational accountability and performance analysis. Essential for understanding who manages metasearch campaigns and optimizing bid strategies' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:platformAccountId rdf:type rdf:Property ;
    rdfs:label 'Platform Account Id' ;
    rdfs:comment 'The account or hotel ID assigned by the metasearch platform (e.g., Google Hotel Center property ID, TripAdvisor hotel ID) to identify this property on the platform. Used for API authentication, platform-side reporting reconciliation, and connectivity management.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:bidAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Amount' ;
    rdfs:comment 'The monetary bid amount configured for this listing under the active bid strategy. For CPC, represents the maximum cost-per-click in the listing currency. For CPA, represents the target cost-per-acquisition. For commission-based, this field is null (see commission_rate_pct). Serves as the principal quantitative fact (MEASUREMENT_OR_VALUE) for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bid Multiplier' ;
    rdfs:comment 'A multiplier applied to the base bid amount for specific market or device segments (e.g., 1.20 = 20% bid increase for mobile). Enables granular bid adjustment strategies without changing the base bid. Used in conjunction with bid_amount for effective bid calculation.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidStrategyType rdf:type rdf:Property ;
    rdfs:label 'Bid Strategy Type' ;
    rdfs:comment 'The bidding model applied to this metasearch listing. CPC (Cost Per Click) charges per user click; CPA (Cost Per Acquisition) charges per completed booking; commission-based charges a percentage of booking revenue; target_ROAS optimizes for return on ad spend; manual allows direct bid amount control. Drives cost-of-acquisition modeling and channel investment decisions.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingCount rdf:type rdf:Property ;
    rdfs:label 'Booking Count' ;
    rdfs:comment 'Total number of direct bookings attributed to this metasearch listing within the reporting period. Used to calculate conversion rate, cost-per-acquisition (CPA), and metasearch contribution to direct booking revenue. Attribution follows the platform\'s last-click or assisted-conversion model.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingRevenue rdf:type rdf:Property ;
    rdfs:label 'Booking Revenue' ;
    rdfs:comment 'Total gross booking revenue (in listing currency) attributed to direct bookings generated by this metasearch listing within the reporting period. Used to calculate return on ad spend (ROAS), channel contribution to revenue, and cost-of-acquisition metrics. Aligns with USALI revenue reporting.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clickCount rdf:type rdf:Property ;
    rdfs:label 'Click Count' ;
    rdfs:comment 'Total number of user clicks on this property listing that directed traffic to the hotel\'s direct booking engine or landing page within the reporting period. Used to calculate click-through rate (CTR) and cost-per-click (CPC) actuals.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickThroughRate rdf:type rdf:Property ;
    rdfs:label 'Click Through Rate' ;
    rdfs:comment 'The ratio of clicks to impressions for this listing within the reporting period, expressed as a decimal (e.g., 0.0350 = 3.50% CTR). Sourced directly from platform reporting APIs to ensure consistency with platform-side optimization signals. Used to assess listing creative and bid competitiveness.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionRate rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate' ;
    rdfs:comment 'The ratio of bookings to clicks for this listing within the reporting period, expressed as a decimal (e.g., 0.0250 = 2.50% conversion rate). Sourced from platform reporting. Measures the effectiveness of the direct booking engine in converting metasearch traffic. Key input for bid optimization and landing page performance analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpaActual rdf:type rdf:Property ;
    rdfs:label 'Cpa Actual' ;
    rdfs:comment 'The actual average cost per acquisition (CPA) realized for this listing within the reporting period, in listing currency. Calculated as total_spend divided by booking_count. Stored as a raw field sourced from platform reporting. Null for non-CPA bid strategies. Key metric for channel cost-of-acquisition benchmarking.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpcActual rdf:type rdf:Property ;
    rdfs:label 'Cpc Actual' ;
    rdfs:comment 'The actual average cost per click (CPC) realized for this listing within the reporting period, in listing currency. Calculated as total_spend divided by click_count. Stored as a raw field sourced from platform reporting to avoid recalculation discrepancies. Null for non-CPC bid strategies.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyBudgetCap rdf:type rdf:Property ;
    rdfs:label 'Daily Budget Cap' ;
    rdfs:comment 'Maximum daily spend limit configured for this metasearch listing in the listing currency. Controls total metasearch investment exposure per day. Null if no daily cap is set. Used for budget pacing and channel investment governance.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The device category for which this bid configuration applies. Metasearch platforms support device-level bid adjustments. \'all\' indicates a unified bid across all devices. Enables device-level performance analysis and bid optimization for direct booking conversion.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directBookingUrl rdf:type rdf:Property ;
    rdfs:label 'Direct Booking Url' ;
    rdfs:comment 'The landing page URL to which users are directed when clicking on this metasearch listing. Points to the hotel\'s direct booking engine (typically Sabre SynXis CRS-powered). Used for link validation, UTM parameter tracking, and ensuring correct booking attribution.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayRank rdf:type rdf:Property ;
    rdfs:label 'Display Rank' ;
    rdfs:comment 'The average position at which this property listing is displayed on the metasearch platform results page (e.g., rank 1 = top position). Lower rank numbers indicate higher visibility. Used to assess bid competitiveness and correlate rank with click-through and conversion performance.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveTo rdf:type rdf:Property ;
    rdfs:label 'Effective To' ;
    rdfs:comment 'The date on which this listing configuration ceases to be active. Null for currently active configurations. Enables slowly changing dimension (SCD) tracking of bid strategy and configuration changes over time. Serves as the EFFECTIVE_UNTIL category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impressionCount rdf:type rdf:Property ;
    rdfs:label 'Impression Count' ;
    rdfs:comment 'Total number of times this property listing was displayed to users on the metasearch platform within the reporting period. Foundational metric for calculating click-through rate (CTR) and measuring listing visibility. Sourced from platform reporting APIs.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDirectBookingEligible rdf:type rdf:Property ;
    rdfs:label 'Is Direct Booking Eligible' ;
    rdfs:comment 'Indicates whether this listing is configured to drive direct bookings through the hotel\'s own booking engine (True) versus redirecting to an OTA or third-party booking path (False). Key flag for measuring direct booking channel contribution and loyalty program integration.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRateParityMonitored rdf:type rdf:Property ;
    rdfs:label 'Is Rate Parity Monitored' ;
    rdfs:comment 'Indicates whether automated rate parity monitoring is enabled for this metasearch listing. When True, the system actively checks for rate disparities between this listing and the direct booking channel. Supports compliance with AHLA rate parity guidelines and OTA contract obligations.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastBidUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Bid Updated Timestamp' ;
    rdfs:comment 'The timestamp when the bid amount, bid strategy, or budget configuration for this listing was last modified. Enables audit trail of bid management changes and supports analysis of bid adjustment impact on performance metrics. Serves as the RECORD_AUDIT_UPDATED category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:listingReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Listing Reference Code' ;
    rdfs:comment 'Externally-known unique code or identifier assigned to this property listing on the metasearch platform. Used for reconciliation with platform-side reporting APIs and bid management systems. Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current lifecycle state of the metasearch listing. Controls whether the property is actively bidding and displaying on the platform. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity. \'active\' = live and bidding; \'paused\' = temporarily stopped; \'suspended\' = platform-enforced stop; \'pending_review\' = awaiting platform approval; \'inactive\' = deactivated; \'archived\' = historical record.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingType rdf:type rdf:Property ;
    rdfs:label 'Listing Type' ;
    rdfs:comment 'Classification of the metasearch listing placement type. \'standard\' = organic/paid standard placement; \'sponsored\' = premium paid placement; \'featured\' = highlighted featured listing; \'free_booking_links\' = Google\'s commission-free direct booking link program. Determines cost structure and visibility tier.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyBudgetCap rdf:type rdf:Property ;
    rdfs:label 'Monthly Budget Cap' ;
    rdfs:comment 'Maximum monthly spend limit configured for this metasearch listing in the listing currency. Governs total monthly metasearch investment for the property-platform combination. Null if no monthly cap is set. Supports channel mix optimization and CapEx/OpEx planning.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Name of the metasearch platform on which this listing is active. Identifies the specific metasearch engine for bid strategy configuration, performance benchmarking, and cost-of-acquisition analysis. [ENUM-REF-CANDIDATE: Google Hotel Ads|TripAdvisor|Trivago|Kayak|Skyscanner|Wego|HotelsCombined — promote to reference product]' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateParityStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Status' ;
    rdfs:comment 'Indicates whether the rates displayed on this metasearch listing are in parity with the Best Available Rate (BAR) across all channels. \'parity\' = rates match; \'disparity_detected\' = rates differ from direct channel; \'under_review\' = parity check in progress; \'exempt\' = contractual exemption applies. Critical for OTA contract compliance and direct booking channel protection.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'The end date of the performance reporting period for which metrics on this record apply. Used in conjunction with reporting_period_start to define the measurement window for all performance KPIs on this listing record.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'The start date of the performance reporting period for which impression, click, booking, spend, and rate metrics on this record apply. Enables time-series analysis of metasearch performance and aligns with STR benchmarking reporting cycles.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnOnAdSpend rdf:type rdf:Property ;
    rdfs:label 'Return On Ad Spend' ;
    rdfs:comment 'The ratio of booking revenue to total spend for this listing within the reporting period (e.g., 8.50 = $8.50 revenue per $1.00 spent). Sourced from platform reporting or CRS attribution data. Primary KPI for metasearch investment optimization and bid strategy evaluation.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'The geographic market or audience segment this listing bid configuration targets (e.g., US, UK, DE, APAC). Enables market-level bid differentiation and performance analysis. Aligns with Sabre SynXis CRS market segmentation and IDeaS G3 RMS demand forecasting by market.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSpend rdf:type rdf:Property ;
    rdfs:label 'Total Spend' ;
    rdfs:comment 'Total monetary amount spent on this metasearch listing (in listing currency) within the reporting period, including all click charges, acquisition fees, or commission payments depending on bid strategy. Core input for cost-of-acquisition (COA) and channel ROI calculations.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utmCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign Code' ;
    rdfs:comment 'The UTM campaign parameter appended to the direct booking URL for this listing, enabling attribution tracking in web analytics and CRM systems. Used to measure metasearch-sourced traffic and bookings in Salesforce CRM and digital analytics platforms.' ;
    rdfs:domain ind:MetasearchListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: OTA account managers are employees managing partner relationships, negotiating contracts, and resolving disputes. Essential for accountability in partnership management, performance tracking, and esca' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:marketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Marketing Brand Id' ;
    rdfs:comment 'Foreign key linking to marketing.brand. Business justification: OTA partnerships are brand-specific in multi-brand hospitality companies; Marriott Bonvoy partners differ from Ritz-Carlton partners. Brand-level partnership management, commission structures, and con' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:affiliateNetwork rdf:type rdf:Property ;
    rdfs:label 'Affiliate Network' ;
    rdfs:comment 'Indicates whether the OTA partner operates an affiliate or sub-distribution network through which third-party websites or agents can book on behalf of the OTA. True = affiliate network active; False = direct OTA platform only. Relevant for booking source attribution accuracy.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseCommissionRatePct rdf:type rdf:Property ;
    rdfs:label 'Base Commission Rate Pct' ;
    rdfs:comment 'Standard commission percentage charged by the OTA partner on each confirmed booking, expressed as a percentage of the gross booking value (e.g., 15.00 = 15%). Foundational input for cost-of-acquisition (COA) and channel profitability analysis.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationPolicyType rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy Type' ;
    rdfs:comment 'Default cancellation policy type applied to bookings made through this OTA channel. Flexible = free cancellation up to 24-48 hours; Moderate = partial penalty; Strict = high penalty; Non_Refundable = NRR (Non-Refundable Rate) — no refund on cancellation. Impacts revenue management and guest experience.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelManagerPlatform rdf:type rdf:Property ;
    rdfs:label 'Channel Manager Platform' ;
    rdfs:comment 'Name of the channel manager or switch platform used to manage the technical connectivity to this OTA partner (e.g., Sabre SynXis, Siteminder, Amadeus iHotelier, RateGain). Relevant when connectivity is not direct API-to-API.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionModel rdf:type rdf:Property ;
    rdfs:label 'Commission Model' ;
    rdfs:comment 'Commercial model governing how the OTA partner earns revenue. Net Rate = hotel sells at net, OTA marks up; Merchant = OTA collects full payment and remits net; Agency = OTA collects commission on hotel-collected payment; Retail = standard published rate with commission; Opaque = rate hidden from consumer until post-booking (e.g., Hotwire).' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityFeeFrequency rdf:type rdf:Property ;
    rdfs:label 'Connectivity Fee Frequency' ;
    rdfs:comment 'Frequency at which the connectivity fee is billed by the OTA partner or channel manager. Annual = yearly flat fee; Monthly = recurring monthly; Per_Booking = transactional fee per confirmed booking; One_Time = setup/onboarding fee only.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentScore rdf:type rdf:Property ;
    rdfs:label 'Content Score' ;
    rdfs:comment 'Numeric score (typically 0–100) representing the completeness and quality of the hotel\'s content (photos, descriptions, amenities) on the OTA partner\'s platform. Higher scores correlate with improved search ranking and conversion rates. Sourced from OTA partner reporting APIs.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date on which the master distribution agreement with the OTA partner becomes legally binding and operational. Governs the start of commission obligations and rate parity clauses.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Date on which the master distribution agreement with the OTA partner expires or is scheduled for renewal. Null indicates an evergreen/open-ended contract. Used for contract renewal management and risk monitoring.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Unique reference number of the master distribution agreement or contract executed with the OTA partner. Links to the contract management repository in SAP S/4HANA for financial and legal audit purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCountryCode rdf:type rdf:Property ;
    rdfs:label 'Hq Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the OTA partner\'s legal headquarters is registered. Used for tax treaty application, withholding tax determination, and regulatory jurisdiction identification.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryAllocationModel rdf:type rdf:Property ;
    rdfs:label 'Inventory Allocation Model' ;
    rdfs:comment 'Model governing how room inventory is made available to the OTA partner. Free_Sell = real-time availability from CRS with no pre-allocated block; Allotment = pre-contracted room block allocated to the OTA; On_Request = bookings require manual confirmation. Managed in IDeaS G3 RMS and Sabre SynXis.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full registered legal name of the OTA partner organisation as it appears on the master distribution agreement (e.g., Expedia, Inc.; Booking Holdings B.V.). Used for contract management, AP reconciliation, and regulatory filings.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCoverage rdf:type rdf:Property ;
    rdfs:label 'Market Coverage' ;
    rdfs:comment 'Description of the primary geographic markets or regions where the OTA partner has significant consumer reach and booking volume (e.g., \'North America, Western Europe\'; \'Asia-Pacific\'; \'Global\'). Used for channel mix optimisation and market-specific distribution strategy.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileAppChannel rdf:type rdf:Property ;
    rdfs:label 'Mobile App Channel' ;
    rdfs:comment 'Indicates whether the OTA partner operates a dedicated mobile application channel through which bookings are made. True = mobile app channel is active and tracked separately for attribution; False = desktop/web only. Supports channel mix and mobile booking trend analysis.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otaAccountManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Ota Account Manager Email' ;
    rdfs:comment 'Business email address of the OTA partner\'s designated account manager. Used for commercial communications, promotional campaign coordination, and escalation. Classified as confidential PII per GDPR Article 4.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaAccountManagerName rdf:type rdf:Property ;
    rdfs:label 'Ota Account Manager Name' ;
    rdfs:comment 'Full name of the OTA partner\'s designated account manager or market manager assigned to the hotel account. Primary point of contact for commercial negotiations, promotional campaigns, and issue resolution.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaAccountManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Ota Account Manager Phone' ;
    rdfs:comment 'Business phone number of the OTA partner\'s designated account manager. Used for urgent escalations and commercial negotiations. Classified as confidential PII per GDPR Article 4.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the OTA partner within the Central Reservation System (CRS) and Property Management System (PMS). Used for channel mapping, rate distribution, and booking source attribution in Sabre SynXis and Oracle OPERA.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Status' ;
    rdfs:comment 'Current lifecycle status of the OTA partner relationship. Active = live and distributing inventory; Pending = contract under negotiation or connectivity setup in progress; Suspended = temporarily halted (e.g., rate parity breach); Terminated = contract ended.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the distribution partner by channel category. OTA = Online Travel Agency (Expedia, Booking.com); GDS = Global Distribution System (Sabre, Amadeus); METASEARCH = price comparison engine (Google Hotel Ads, Trivago); DIRECT = brand.com or call centre; WHOLESALE = tour operator/bed bank; AFFILIATE = sub-affiliate network. [ENUM-REF-CANDIDATE: OTA|GDS|METASEARCH|DIRECT|WHOLESALE|AFFILIATE — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCollectionParty rdf:type rdf:Property ;
    rdfs:label 'Payment Collection Party' ;
    rdfs:comment 'Identifies which party collects payment from the guest. Hotel = property collects at check-in/check-out (agency model); OTA = OTA collects full payment and remits net to hotel (merchant model); Split = partial payment collected by each party.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommissionRatePct rdf:type rdf:Property ;
    rdfs:label 'Preferred Commission Rate Pct' ;
    rdfs:comment 'Negotiated commission rate applicable when the property holds preferred partner or sponsored placement status with the OTA. Typically lower than the base rate in exchange for enhanced visibility or placement. Null if preferred status is not applicable.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredPartner rdf:type rdf:Property ;
    rdfs:label 'Preferred Partner' ;
    rdfs:comment 'Indicates whether the hotel or brand holds preferred partner or sponsored placement status with this OTA, typically in exchange for a higher commission rate or marketing investment. Preferred partners receive enhanced search ranking and visibility on the OTA platform.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remittanceCycleDays rdf:type rdf:Property ;
    rdfs:label 'Remittance Cycle Days' ;
    rdfs:comment 'Number of days after the guest check-out date within which the OTA partner remits commission payments or net booking proceeds to the hotel. Used for cash flow forecasting and AP/AR reconciliation in SAP S/4HANA (e.g., 30 = net-30 terms).' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCount rdf:type rdf:Property ;
    rdfs:label 'Review Count' ;
    rdfs:comment 'Total number of guest reviews published on the OTA partner\'s platform for the hotel. Used alongside review_score to assess statistical significance and platform engagement. Sourced from OTA partner reporting APIs.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewScore rdf:type rdf:Property ;
    rdfs:label 'Review Score' ;
    rdfs:comment 'Average guest review score for the hotel as published on the OTA partner\'s platform (e.g., Booking.com score out of 10, Expedia score out of 5). Used for reputation management, competitive benchmarking, and NPS/GSS correlation analysis via Medallia.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'VAT, GST, or equivalent tax registration number of the OTA partner\'s legal entity. Required for tax invoice processing, withholding tax compliance, and AP reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:OtaPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Consumer-facing brand name under which the OTA partner operates (e.g., Hotels.com, Agoda). May differ from the legal entity name when the OTA operates multiple consumer brands under one legal umbrella.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateParityAuditId rdf:type rdf:Property ;
    rdfs:label 'Rate Parity Audit Id' ;
    rdfs:comment 'Unique surrogate identifier for each rate parity audit record captured during channel monitoring. Primary key for this transactional audit entity.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Reference Number' ;
    rdfs:comment 'Externally referenceable business identifier for this audit record, used in OTA contract compliance disputes and parity violation correspondence. Format: RPA-YYYY-MM-DD-XXXXXXXX.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle state of the rate parity audit record. \'open\' indicates a new observation; \'violation_confirmed\' indicates a confirmed parity breach; \'dispute_raised\' indicates a formal dispute filed with the OTA/channel; \'resolved\' indicates the channel corrected the rate; \'closed\' indicates no action required; \'waived\' indicates the violation was contractually waived.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Timestamp' ;
    rdfs:comment 'The precise date and time at which the rate observation was captured during the automated or manual parity monitoring scan. This is the principal business event timestamp for this audit record.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelRateUrl rdf:type rdf:Property ;
    rdfs:label 'Channel Rate Url' ;
    rdfs:comment 'The URL or deep link to the channel page where the rate was observed at the time of the audit scan. Used as evidence in OTA parity dispute resolution and contract compliance documentation.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedParityRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Parity Rate' ;
    rdfs:comment 'The contractually agreed parity rate threshold for this channel, rate plan, and property combination as defined in the OTA or GDS distribution agreement. May differ from the direct rate if a contracted rate floor or ceiling applies.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directRate rdf:type rdf:Property ;
    rdfs:label 'Direct Rate' ;
    rdfs:comment 'The rate available on the hotel\'s direct booking channel (own website or CRS direct) for the same room type, rate plan, stay date, and LOS at the time of the audit. Used as the parity benchmark for comparison.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'The date on which a formal parity dispute was raised with the OTA or distribution channel partner. Null if no dispute has been filed. Used to track SLA compliance for dispute resolution timelines.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference Number' ;
    rdfs:comment 'The reference number assigned when a formal parity dispute is raised with the OTA or distribution channel. Populated when audit_status transitions to \'dispute_raised\'. Used for tracking dispute resolution correspondence.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolvedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolved Date' ;
    rdfs:comment 'The date on which the parity dispute was resolved and the channel corrected the rate or the dispute was formally closed. Null if the dispute is still open. Used to measure dispute resolution cycle time.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isParityViolation rdf:type rdf:Property ;
    rdfs:label 'Is Parity Violation' ;
    rdfs:comment 'Indicates whether this audit record represents a confirmed rate parity violation, where the observed channel rate is lower than the direct booking rate or contracted parity rate beyond the allowable tolerance threshold. True = violation detected.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRateInclusive rdf:type rdf:Property ;
    rdfs:label 'Is Rate Inclusive' ;
    rdfs:comment 'Indicates whether the observed channel rate is inclusive of taxes and fees (True) or is a net/exclusive rate (False). Critical for accurate parity comparison as some channels display gross rates while others display net rates.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:losNights rdf:type rdf:Property ;
    rdfs:label 'Los Nights' ;
    rdfs:comment 'The length of stay in nights for which the rate was observed. Rate parity monitoring may vary by LOS as some channels offer LOS-based discounts that can trigger parity violations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringSource rdf:type rdf:Property ;
    rdfs:label 'Monitoring Source' ;
    rdfs:comment 'Identifies how the rate observation was captured. \'automated_scraper\' indicates a rate shopping tool or API; \'manual_review\' indicates a revenue manager manually checked; \'ota_alert\' indicates the OTA itself flagged the discrepancy; \'partner_report\' indicates a channel partner reported it; \'revenue_manager\' indicates direct CRS/PMS review.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observedRate rdf:type rdf:Property ;
    rdfs:label 'Observed Rate' ;
    rdfs:comment 'The actual room rate (in the property\'s local currency) observed on the audited channel at the time of the audit scan. This is the raw rate as displayed to the consumer on the channel.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateShoppingTool rdf:type rdf:Property ;
    rdfs:label 'Rate Shopping Tool' ;
    rdfs:comment 'Name of the rate shopping or competitive intelligence tool used to capture the channel rate observation (e.g., OTA Insight, RateGain, Duetto, Infor EzRMS). Relevant when monitoring_source is \'automated_scraper\'.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVariance rdf:type rdf:Property ;
    rdfs:label 'Rate Variance' ;
    rdfs:comment 'The absolute monetary difference between the observed channel rate and the direct booking rate (observed_rate minus direct_rate). A negative value indicates the channel is undercutting the direct rate, constituting a parity violation.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateVariancePct rdf:type rdf:Property ;
    rdfs:label 'Rate Variance Pct' ;
    rdfs:comment 'The percentage difference between the observed channel rate and the direct booking rate, calculated as (observed_rate - direct_rate) / direct_rate * 100. Used to assess the severity of a parity violation relative to the direct rate.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the outcome of the parity dispute, including the channel\'s response, corrective action taken, or reason for waiving the violation. Supports audit trail and OTA contract compliance documentation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'The date and time at which the parity audit record was reviewed by a revenue manager or channel distribution analyst. Supports audit trail and SLA compliance tracking for parity violation response times.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'The name or employee identifier of the revenue manager or channel distribution analyst who reviewed and actioned this parity audit record. Populated for manually reviewed or escalated records.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenshotReference rdf:type rdf:Property ;
    rdfs:label 'Screenshot Reference' ;
    rdfs:comment 'Reference identifier or storage path to the screenshot or screen capture taken of the channel rate at the time of the audit. Serves as evidentiary documentation for OTA parity dispute resolution.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stayDate rdf:type rdf:Property ;
    rdfs:label 'Stay Date' ;
    rdfs:comment 'The specific arrival or stay date for which the rate was observed on the channel. Rate parity is evaluated per stay date to detect date-specific pricing discrepancies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:toleranceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Pct' ;
    rdfs:comment 'The allowable percentage variance between the channel rate and the direct/contracted rate before a parity violation is flagged. Defined per channel contract or property policy. Violations are only flagged when rate_variance_pct exceeds this threshold.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:violationSeverity rdf:type rdf:Property ;
    rdfs:label 'Violation Severity' ;
    rdfs:comment 'Severity classification of the rate parity violation based on the magnitude of the rate variance percentage. \'critical\' typically indicates >10% variance; \'high\' 5-10%; \'medium\' 2-5%; \'low\' <2%; \'none\' for no violation. Drives escalation and dispute prioritization.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Classifies the nature of the rate parity violation. \'below_direct\' means the channel rate is lower than the direct booking rate; \'below_contracted\' means the channel rate is below the contracted parity rate; \'below_both\' means the channel rate violates both thresholds; \'no_violation\' means parity is maintained.' ;
    rdfs:domain ind:RateParityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wholesaleAllotmentId rdf:type rdf:Property ;
    rdfs:label 'Wholesale Allotment Id' ;
    rdfs:comment 'Unique surrogate identifier for the wholesale allotment record in the lakehouse Silver layer. Primary key for this entity.' ;
    rdfs:domain ind:WholesaleAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allotmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Allotment Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this allotment block, used in communications with the wholesale partner and in the Central Reservation System (CRS) via Sabre SynXis.' ;
    rdfs:domain ind:WholesaleAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allotmentStatus rdf:type rdf:Property ;
    rdfs:label 'Allotment Status' ;
    rdfs:comment 'Current lifecycle state of the wholesale allotment block. \'active\' indicates rooms are available for the wholesaler to sell; \'released\' indicates the release period has passed and unsold rooms have been returned to general inventory; \'suspended\' indicates temporarily blocked by revenue management. [ENUM-REF-CANDIDATE: active|suspended|released|expired|cancelled|pending — promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Booking Deadline Date' ;
    rdfs:comment 'Last date by which the wholesale partner must confirm bookings against this allotment block. After this date, unconfirmed allotment rooms may be released or renegotiated.' ;
    rdfs:domain ind:WholesaleAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractedAllotmentSize rdf:type rdf:Property ;
    rdfs:label 'Contracted Allotment Size' ;
    rdfs:comment 'Total number of room-nights contracted with the wholesale partner for the defined stay period and room type. This is the original block size as agreed in the wholesale contract.' ;
    rdfs:domain ind:WholesaleAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedNetRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Net Rate' ;
    rdfs:comment 'The pre-agreed net rate (exclusive of markup) payable by the wholesale partner per room per night under this allotment contract. This is the wholesale net rate model — the wholesaler adds their own markup before selling to the end consumer. Expressed in the contract currency.' ;
    rdfs:domain ind:WholesaleAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyAllotmentSize rdf:type rdf:Property ;
    rdfs:label 'Daily Allotment Size' ;
    rdfs:comment 'Number of rooms allocated per night within the stay period. Used when the allotment is expressed as a per-night room count rather than a total room-night block.' ;
    rdfs:domain ind:WholesaleAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rackRate rdf:type rdf:Property ;
    rdfs:label 'Rack Rate' ;
    rdfs:comment 'Published Best Available Rate (BAR) or rack rate for the room type at the property, used as the reference rate for calculating the wholesale discount depth and monitoring rate parity obligations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releasePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Release Period Days' ;
    rdfs:comment 'Number of days prior to the arrival date by which unsold allotment rooms must be released back to the property\'s general inventory. A key commercial term in wholesale contracts — e.g., a 21-day release means rooms not sold 21 days before check-in revert to the hotel.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingUnits rdf:type rdf:Property ;
    rdfs:label 'Remaining Units' ;
    rdfs:comment 'Number of room-nights still available for the wholesale partner to sell within this allotment block. Calculated as contracted_allotment_size minus consumed_units, maintained as a stored operational field for real-time availability checks.' ;
    rdfs:domain ind:WholesaleAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:washFactorPct rdf:type rdf:Property ;
    rdfs:label 'Wash Factor Pct' ;
    rdfs:comment 'Historical cancellation and no-show rate expressed as a percentage of contracted allotment, used to adjust effective allotment sizing in revenue forecasting. Derived from historical performance of this wholesaler-property-room type combination.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adaAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Ada Assessment Id' ;
    rdfs:comment 'Unique identifier for the ADA accessibility compliance assessment record.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdaAssessment .

ind:primaryAdaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ada Employee Id' ;
    rdfs:comment 'Identifier of the system user who created this ADA assessment record.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The date on which the ADA accessibility assessment was conducted at the property.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Assessment Frequency Months' ;
    rdfs:comment 'Standard frequency in months between scheduled ADA assessments for this property (e.g., 12, 24, 36 months).' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Additional free-text notes, observations, or recommendations from the assessor regarding ADA compliance, best practices, or areas of concern.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference Number' ;
    rdfs:comment 'External business reference number for the ADA assessment, used for tracking and reporting purposes.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportUrl rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Url' ;
    rdfs:comment 'URL or file path to the detailed ADA assessment report document containing findings, photographs, and recommendations.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScopeNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope Notes' ;
    rdfs:comment 'Free-text notes describing the specific scope, limitations, or special considerations of the ADA assessment (e.g., areas excluded, phased approach, weather constraints).' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the ADA assessment based on the trigger or purpose: initial baseline assessment, periodic scheduled review, complaint-triggered investigation, renovation-triggered evaluation, acquisition due diligence, or post-remediation verification.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorCredentials rdf:type rdf:Property ;
    rdfs:label 'Assessor Credentials' ;
    rdfs:comment 'Professional credentials, certifications, or qualifications of the assessor (e.g., Certified Access Specialist, ADA Coordinator, licensed architect).' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the individual or firm who conducted the ADA accessibility assessment.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorOrganization rdf:type rdf:Property ;
    rdfs:label 'Assessor Organization' ;
    rdfs:comment 'Name of the organization or consulting firm that the assessor represents.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barriersPendingRemediationCount rdf:type rdf:Property ;
    rdfs:label 'Barriers Pending Remediation Count' ;
    rdfs:comment 'Count of accessibility barriers that remain outstanding and require remediation to achieve full ADA compliance.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:barriersRemediatedCount rdf:type rdf:Property ;
    rdfs:label 'Barriers Remediated Count' ;
    rdfs:comment 'Count of accessibility barriers that have been successfully remediated and brought into ADA compliance as of the current date.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the ADA compliance certification, after which a new assessment is required to maintain certified status.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether a formal ADA compliance certification or letter of compliance was issued by the assessor following the assessment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Reference Number' ;
    rdfs:comment 'Reference number of the guest complaint, legal claim, or regulatory inquiry that triggered this ADA assessment, if applicable.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Calculated percentage of ADA compliance based on the ratio of compliant elements to total elements assessed, expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Overall ADA compliance status of the property based on the assessment findings: compliant (no barriers), substantially compliant (minor barriers only), partially compliant (moderate barriers present), non-compliant (significant barriers present), or under remediation (active remediation plan in progress).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entrancesEvaluatedFlag rdf:type rdf:Property ;
    rdfs:label 'Entrances Evaluated Flag' ;
    rdfs:comment 'Indicates whether building entrances, accessible routes, and entry points were included in the ADA assessment.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Remediation Cost' ;
    rdfs:comment 'Estimated total cost in the property\'s operating currency to remediate all identified ADA accessibility barriers and achieve full compliance.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fitnessFacilitiesEvaluatedFlag rdf:type rdf:Property ;
    rdfs:label 'Fitness Facilities Evaluated Flag' ;
    rdfs:comment 'Indicates whether fitness centers, gyms, and exercise facilities were included in the ADA assessment.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestRoomsEvaluatedFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Rooms Evaluated Flag' ;
    rdfs:comment 'Indicates whether guest rooms and sleeping accommodations were included in the scope of the ADA assessment.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highPriorityBarriersCount rdf:type rdf:Property ;
    rdfs:label 'High Priority Barriers Count' ;
    rdfs:comment 'Count of accessibility barriers classified as high priority due to significant impact on guest safety, access, or legal risk.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalCaseReference rdf:type rdf:Property ;
    rdfs:label 'Legal Case Reference' ;
    rdfs:comment 'Reference number or docket number of any legal case, lawsuit, or Department of Justice (DOJ) investigation related to this ADA assessment.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingSpacesEvaluatedFlag rdf:type rdf:Property ;
    rdfs:label 'Meeting Spaces Evaluated Flag' ;
    rdfs:comment 'Indicates whether meeting rooms, conference spaces, ballrooms, and event facilities were included in the ADA assessment for accessibility compliance.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic ADA accessibility assessment to ensure ongoing compliance and identify any new barriers.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parkingEvaluatedFlag rdf:type rdf:Property ;
    rdfs:label 'Parking Evaluated Flag' ;
    rdfs:comment 'Indicates whether parking facilities and accessible parking spaces were included in the ADA assessment.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poolsEvaluatedFlag rdf:type rdf:Property ;
    rdfs:label 'Pools Evaluated Flag' ;
    rdfs:comment 'Indicates whether swimming pools, spas, and aquatic facilities were included in the ADA assessment for accessibility features such as lifts and sloped entries.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicAreasEvaluatedFlag rdf:type rdf:Property ;
    rdfs:label 'Public Areas Evaluated Flag' ;
    rdfs:comment 'Indicates whether public areas such as lobbies, corridors, elevators, and common spaces were included in the ADA assessment.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Remediation Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated remediation cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlanReference rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Reference' ;
    rdfs:comment 'Reference number or identifier of the formal remediation plan document that outlines corrective actions, timelines, and responsibilities for addressing identified ADA barriers.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Email' ;
    rdfs:comment 'Email address of the individual responsible for ADA compliance and remediation at the property.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual or department responsible for overseeing ADA compliance and remediation efforts at the property (e.g., General Manager, Facilities Director, Compliance Officer).' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restaurantsEvaluatedFlag rdf:type rdf:Property ;
    rdfs:label 'Restaurants Evaluated Flag' ;
    rdfs:comment 'Indicates whether Food and Beverage (F&B) outlets, restaurants, bars, and dining areas were included in the ADA assessment.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restroomsEvaluatedFlag rdf:type rdf:Property ;
    rdfs:label 'Restrooms Evaluated Flag' ;
    rdfs:comment 'Indicates whether public restrooms and toilet facilities were included in the ADA assessment for accessibility features.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signageEvaluatedFlag rdf:type rdf:Property ;
    rdfs:label 'Signage Evaluated Flag' ;
    rdfs:comment 'Indicates whether directional, informational, and accessible signage (including Braille and tactile signs) were included in the ADA assessment.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalBarriersIdentified rdf:type rdf:Property ;
    rdfs:label 'Total Barriers Identified' ;
    rdfs:comment 'Total count of accessibility barriers, deficiencies, or non-compliant elements identified during the ADA assessment across all evaluated areas.' ;
    rdfs:domain ind:AdaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the audit finding record. Primary key for the audit finding entity.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Reference to the parent compliance audit or regulatory inspection during which this finding was identified.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the department responsible for addressing this finding (e.g., Housekeeping, Food and Beverage, Front Desk, Engineering).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Audit findings often relate to specific permit violations (e.g., liquor license violations, health permit deficiencies, fire safety certificate non-compliance). One finding relates to one permit. This' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Audit findings often cite specific policy violations (e.g., failure to follow Code of Conduct, non-compliance with Data Privacy Policy, violation of Safety Procedures). One finding relates to one poli' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:certificationImpact rdf:type rdf:Property ;
    rdfs:label 'Certification Impact' ;
    rdfs:comment 'Assessment of the findings impact on property certifications, accreditations, or licenses (e.g., ISO 22000, LEED, AAA Diamond Rating, liquor license). Indicates whether the finding jeopardizes certification status.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date on which the finding was formally closed in the audit management system after successful verification of corrective action.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceDomain rdf:type rdf:Property ;
    rdfs:label 'Compliance Domain' ;
    rdfs:comment 'High-level compliance domain or regulatory area to which this finding pertains, enabling categorization and trend analysis across compliance frameworks. [ENUM-REF-CANDIDATE: health_safety|data_privacy|accessibility|fire_safety|food_safety|liquor_licensing|financial_controls|environmental|labor_employment|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective action plan, remediation steps, and controls implemented to address the finding and prevent recurrence.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which corrective action must be completed and verified. Typically set based on finding severity: critical (immediate to 7 days), major (30 days), minor (60-90 days).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator of whether formal corrective action is mandated for this finding. True for critical, major, and most minor findings; False for observations that are advisory only.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date on which the finding was escalated to higher management levels, if applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean indicator of whether this finding has been escalated to senior management, corporate compliance, or executive leadership due to severity, repeat occurrence, or remediation delays.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Evidence Location' ;
    rdfs:comment 'File path, document reference, or storage location of supporting evidence, photographs, documentation, or records related to the finding and its remediation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorFlag rdf:type rdf:Property ;
    rdfs:label 'External Auditor Flag' ;
    rdfs:comment 'Boolean indicator of whether this finding was identified by an external third-party auditor, regulatory inspector, or certification body (as opposed to internal audit).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate' ;
    rdfs:comment 'Estimated financial impact of the finding in USD, including potential fines, penalties, remediation costs, or revenue at risk if not addressed.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Severity classification of the finding based on risk impact and regulatory significance. Critical findings require immediate action; major findings pose significant risk; minor findings are low-impact deficiencies; observations are improvement opportunities.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the deficiency, non-compliance, or gap identified during the audit, including specific observations and evidence.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this finding for tracking and reporting purposes. Typically follows format: AUDIT_TYPE-YEAR-SEQUENCE.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding. Open: newly identified; In Remediation: corrective action underway; Closed: remediation completed and verified; Disputed: finding contested by property; Deferred: remediation postponed with approval.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Brief descriptive title summarizing the nature of the finding for quick identification and reporting.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Impact Flag' ;
    rdfs:comment 'Boolean indicator of whether this finding has direct impact on guest safety, experience, or satisfaction, requiring elevated priority and communication protocols.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date on which the finding was first identified during the audit or inspection, representing the business event timestamp for the finding discovery.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the auditor, inspector, or compliance officer who identified and documented this finding.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorNotes rdf:type rdf:Property ;
    rdfs:label 'Inspector Notes' ;
    rdfs:comment 'Additional observations, context, recommendations, or clarifications provided by the inspector regarding the finding, remediation approach, or risk implications.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousFindingReference rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Reference' ;
    rdfs:comment 'Reference number of the prior finding if this is a repeat occurrence, enabling linkage and trend analysis of recurring issues.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date on which the finding was formally reported to the relevant regulatory authority or governing body, if applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this finding must be formally reported to external regulatory authorities, governing bodies, or certification agencies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryStandardViolated rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard Violated' ;
    rdfs:comment 'Specific regulatory standard, code section, policy requirement, or compliance framework provision that was violated or not met (e.g., OSHA 1910.22, ADA Title III, GDPR Article 32, Local Fire Code Section 5.3).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Boolean indicator of whether this finding is a recurrence of a previously identified and supposedly remediated deficiency, signaling potential systemic control weakness.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the individual assigned accountability for corrective action, used for notifications and follow-up communications.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the individual (typically department head or property manager) assigned accountability for ensuring corrective action completion.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Quantitative risk score assigned to the finding based on likelihood and impact assessment, typically on a scale of 0-100, used for prioritization and resource allocation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rootCauseClassification rdf:type rdf:Property ;
    rdfs:label 'Root Cause Classification' ;
    rdfs:comment 'Categorization of the underlying root cause that led to the finding, enabling systemic analysis and preventive action planning. [ENUM-REF-CANDIDATE: process_gap|training_deficiency|system_failure|resource_constraint|policy_violation|external_factor|design_flaw|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the corrective action was verified as complete and effective by the auditor or compliance officer, enabling closure of the finding.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programConfigId rdf:type rdf:Property ;
    rdfs:label 'Program Config Id' ;
    rdfs:comment 'Foreign key linking to loyalty.program_config. Business justification: Loyalty program compliance audits (points liability accounting, breakage assumptions, regulatory filings) must reference which program configuration version was in effect during the audit period. Esse' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramConfig .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The date on which the audit fieldwork was completed and exit conference conducted.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The date on which the audit fieldwork actually commenced. May differ from scheduled date due to operational constraints or rescheduling.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the areas, departments, processes, or compliance domains covered by the audit. May include specific operational areas such as front desk operations, housekeeping standards, food and beverage safety, fire safety systems, accessibility features, or financial controls.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on its purpose and conducting authority. Internal audits are conducted by company staff, brand standard audits verify adherence to brand requirements, regulatory audits are mandated by government agencies (health department, fire marshal, liquor control board), third-party audits are conducted by external certification bodies (Forbes Travel Guide, AAA), ADA accessibility audits verify compliance with Americans with Disabilities Act, and fire safety audits assess fire code compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Auditor Certification Number' ;
    rdfs:comment 'Professional certification or license number of the auditor, if applicable. Required for certain regulatory audits (e.g., health inspector license, fire marshal certification).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Auditor Contact Email' ;
    rdfs:comment 'Email address of the lead auditor for follow-up questions and corrective action verification.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Auditor Contact Phone' ;
    rdfs:comment 'Phone number of the lead auditor for urgent communications regarding audit findings or corrective actions.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor or inspector who conducted the audit.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Name of the organization or agency that the auditor represents. May be internal department name, regulatory agency (e.g., County Health Department, State Fire Marshal), or third-party certification body (e.g., Forbes Travel Guide, AAA, ISO certification body).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationAwarded rdf:type rdf:Property ;
    rdfs:label 'Certification Awarded' ;
    rdfs:comment 'Indicates whether a formal certification, accreditation, or rating was awarded as a result of this audit. True for third-party certification audits (Forbes Travel Guide star rating, AAA Diamond rating, ISO certification) where the audit resulted in certification issuance or renewal.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'The level or grade of certification awarded, if applicable. Examples include Forbes Travel Guide star ratings (4-star, 5-star), AAA Diamond ratings (3-Diamond, 4-Diamond, 5-Diamond), or ISO certification levels. Null if no certification was awarded or audit type does not involve certification.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Compliance Period End' ;
    rdfs:comment 'End date of the compliance period being audited. Used for periodic compliance audits that assess adherence over a defined time window.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compliancePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Compliance Period Start' ;
    rdfs:comment 'Start date of the compliance period being audited. Used for periodic compliance audits that assess adherence over a defined time window.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'Date by which all corrective actions must be completed and verified. Set by auditor or regulatory body based on finding severity. Null if no corrective action is required.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether the audit identified findings that require formal corrective action plans. True when property must submit remediation plans and evidence of correction.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Total cost incurred for the audit, including auditor fees, travel expenses, and administrative costs. Used for budgeting and cost analysis of compliance programs. Null for internal audits where costs are not separately tracked.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical non-compliance findings identified during the audit. Critical findings represent immediate health, safety, or legal risks requiring urgent remediation.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executiveSummary rdf:type rdf:Property ;
    rdfs:label 'Executive Summary' ;
    rdfs:comment 'High-level summary of audit findings, conclusions, and recommendations for executive reporting. Provides context for overall result and key takeaways.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'Scheduled date for the follow-up audit or re-inspection. Null if no follow-up is required.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required' ;
    rdfs:comment 'Indicates whether a follow-up audit or re-inspection is required to verify corrective actions have been implemented. True for audits with critical findings or regulatory enforcement actions.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic or legal jurisdiction under which the audit was conducted. Identifies the country, state, province, county, or municipality whose regulations apply. Critical for multi-jurisdictional compliance tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major non-compliance findings identified during the audit. Major findings represent significant deviations from standards that require corrective action but do not pose immediate risk.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor non-compliance findings or observations identified during the audit. Minor findings represent opportunities for improvement that do not constitute non-compliance.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallAuditResult rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Result' ;
    rdfs:comment 'Final outcome determination of the audit. Pass indicates full compliance with all standards, fail indicates critical non-compliance requiring immediate remediation, conditional pass indicates compliance achieved with minor corrective actions required, pending review indicates the audit report is under final review before result determination, and not applicable is used when the audit was cancelled or scope changed.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Numeric score assigned to the audit, typically on a scale of 0-100 or as defined by the auditing body. Used for brand standard audits and third-party certifications. Null for pass/fail regulatory audits that do not use scoring.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Property Contact Email' ;
    rdfs:comment 'Email address of the property contact for audit-related communications and corrective action tracking.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyContactName rdf:type rdf:Property ;
    rdfs:label 'Property Contact Name' ;
    rdfs:comment 'Name of the property representative who served as primary contact during the audit. Typically the General Manager, Director of Operations, or Compliance Manager.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'External reference number assigned to the audit for tracking and reporting purposes. Unique business identifier.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The specific regulatory framework, standard, or code against which the audit was conducted. Examples include USALI financial reporting standards, PCI DSS payment security standards, GDPR or CCPA data privacy regulations, ISO 22000 food safety standards, OSHA workplace safety regulations, ADA accessibility standards, or local fire and building codes.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReference rdf:type rdf:Property ;
    rdfs:label 'Report Reference' ;
    rdfs:comment 'Reference identifier or document management system location of the formal audit report. May be a document ID, file path, or URL to the report repository.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk rating assigned based on audit findings. Critical indicates immediate threat to guest safety, legal compliance, or brand reputation requiring executive escalation. High indicates significant risk requiring urgent management attention. Medium indicates moderate risk requiring corrective action within normal timeframes. Low indicates minimal risk with opportunities for improvement.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The date on which the audit was originally scheduled to be conducted. Used for planning and resource allocation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCalendarId rdf:type rdf:Property ;
    rdfs:label 'Compliance Calendar Id' ;
    rdfs:comment 'Unique identifier for the compliance calendar entry. Primary key for the compliance calendar product.' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Reference to the user or system account that created this compliance calendar entry. Provides audit trail for data governance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user or system account that last modified this compliance calendar entry. Provides audit trail for data governance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:linkedObligationComplianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Linked Obligation Compliance Obligation Id' ;
    rdfs:comment 'Reference to the parent compliance obligation record in the compliance obligation product. Establishes traceability between calendar entries and master obligation records.' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:linkedPermitId rdf:type rdf:Property ;
    rdfs:label 'Linked Permit Id' ;
    rdfs:comment 'Reference to the associated permit record if this calendar entry relates to permit renewal or permit-related compliance activity.' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:primaryComplianceResponsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Responsible Owner Employee Id' ;
    rdfs:comment 'Reference to the employee who is accountable for ensuring timely completion of this compliance obligation. Links to workforce master data.' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Actual date when the compliance obligation was fulfilled or completed. Null for upcoming or in-progress obligations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current lifecycle status of the compliance calendar entry. Tracks progress from upcoming through completion or waiver.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryReference rdf:type rdf:Property ;
    rdfs:label 'Document Repository Reference' ;
    rdfs:comment 'Reference identifier or path to the location where supporting documents for this compliance obligation are stored in the document management system.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which the compliance obligation must be completed to avoid regulatory lapse or penalty. Critical for proactive compliance management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether this compliance obligation requires escalation to senior management or executive leadership for awareness or approval.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Estimated financial cost to complete this compliance obligation including fees, external services, and internal resource costs.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Estimated number of labor hours required to complete this compliance obligation. Used for resource planning and workload management.' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Geographic or regulatory jurisdiction code under which this compliance obligation falls. May be country, state, province, or local authority code.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Notification Date' ;
    rdfs:comment 'Date when the most recent notification or reminder was sent to responsible parties regarding this compliance obligation.' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeAlertDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Alert Days' ;
    rdfs:comment 'Number of days before the due date when alerts and notifications should be triggered to responsible parties. Enables proactive compliance management.' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether alert notifications have been sent to responsible parties for this compliance calendar entry.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the compliance obligation including specific requirements, deliverables, and any special instructions or conditions.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Reference Number' ;
    rdfs:comment 'Business identifier for the compliance calendar entry. May reference external permit numbers, regulatory filing codes, or internal tracking identifiers.' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationTitle rdf:type rdf:Property ;
    rdfs:label 'Obligation Title' ;
    rdfs:comment 'Short descriptive title of the compliance obligation for display and reporting purposes.' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the compliance obligation. Defines the nature of the calendar entry and determines workflow and escalation rules. [ENUM-REF-CANDIDATE: permit_renewal|regulatory_filing|audit|training_deadline|policy_review|inspection|reporting_deadline — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to this compliance obligation based on risk, regulatory impact, and business criticality.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Frequency with which this compliance obligation recurs. Determines whether the calendar entry is a one-time event or repeating obligation. [ENUM-REF-CANDIDATE: one_time|daily|weekly|monthly|quarterly|semi_annual|annual|biennial — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the regulatory body, government agency, or authority that mandates this compliance obligation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department or functional area responsible for managing and completing this compliance obligation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of the risk exposure if this compliance obligation is not met on time. Considers regulatory penalties, operational impact, and reputational risk.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeLevel rdf:type rdf:Property ;
    rdfs:label 'Scope Level' ;
    rdfs:comment 'Organizational scope of the compliance obligation. Indicates whether the obligation applies to a single property, corporate entity, regional group, brand, or entire portfolio.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentsRequired rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents Required' ;
    rdfs:comment 'List or description of supporting documentation required to complete this compliance obligation such as certificates, reports, or attestations.' ;
    rdfs:domain ind:ComplianceCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'Date when the granted waiver expires and the compliance obligation becomes active again. Null for permanent waivers.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether a waiver or exemption was granted for this compliance obligation by the regulatory authority or internal governance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obligationCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Obligation Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that created this compliance obligation record.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:obligationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Obligation Employee Id' ;
    rdfs:comment 'Identifier of the employee or role responsible for ensuring compliance with this obligation at the property level.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:obligationUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Obligation Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that last modified this compliance obligation record.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Id' ;
    rdfs:comment 'Identifier of the specific regulatory requirement that creates this obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:applicableDepartment rdf:type rdf:Property ;
    rdfs:label 'Applicable Department' ;
    rdfs:comment 'Name or code of the department within the property that is primarily responsible for this compliance obligation (e.g., Food and Beverage, Housekeeping, Front Desk, Engineering, Security).' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking to detailed audit logs, inspection reports, or compliance documentation stored in external systems.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certification Issue Date' ;
    rdfs:comment 'Date on which the certification or license was issued by the regulatory authority.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Official certification, license, or permit number issued by the regulatory authority to satisfy this obligation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether this obligation requires formal certification, licensing, or documented proof of compliance. True indicates certification is required; False indicates no formal certification needed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the regulatory body, government agency, or certification authority that issued the certification or enforces this obligation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionNotes rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Notes' ;
    rdfs:comment 'Free-text notes capturing jurisdiction-specific nuances, local interpretations, or special conditions applicable to this obligation in this jurisdiction.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Assessment Date' ;
    rdfs:comment 'Date on which the compliance status was last formally assessed or updated.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date on which this compliance obligation was last reviewed or audited for compliance status.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next compliance review or audit of this obligation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting any non-compliance issues, corrective actions taken, or remediation plans in progress.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Business-assigned unique code for this compliance obligation, used for reporting and tracking purposes.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Short descriptive name of the compliance obligation for business user identification.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the compliance obligation. Active indicates the obligation is in force; pending indicates awaiting activation; waived indicates exemption granted; expired indicates obligation period has ended; suspended indicates temporarily inactive; terminated indicates permanently closed.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty amount assessed or potentially assessable for non-compliance with this obligation, in the property\'s local currency.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the penalty amount.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'Number of days between scheduled compliance reviews for this obligation. Used to calculate next review date automatically.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Unique identifier for the corrective action record. Primary key.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:fraudAlertId rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Id' ;
    rdfs:comment 'Foreign key linking to loyalty.fraud_alert. Business justification: When loyalty fraud alerts trigger corrective actions (account freezes, points reversals, investigation escalations), the CAPA record must reference the originating fraud alert for audit trail and effe' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudAlert .

ind:healthSafetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Health Safety Incident Id' ;
    rdfs:comment 'Reference to the risk incident or safety event that triggered this corrective action, if applicable.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthSafetyIncident .

ind:noteId rdf:type rdf:Property ;
    rdfs:label 'Note Id' ;
    rdfs:comment 'Foreign key linking to guest.guest_note. Business justification: CAPAs for service failures may require updating guest profiles with service recovery notes, VIP alerts, or handling instructions. Links corrective action to resulting guest profile updates for audit t' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Note .

ind:primaryCorrectiveAssignedOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Corrective Assigned Owner Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for implementing and completing the corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:privacyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Privacy Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_incident. Business justification: Privacy incidents require corrective actions (CAPA) to remediate data breaches and prevent recurrence. One privacy incident can generate multiple corrective actions addressing different aspects of the' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyIncident .

ind:whistleblowerReportId rdf:type rdf:Property ;
    rdfs:label 'Whistleblower Report Id' ;
    rdfs:comment 'Foreign key linking to compliance.whistleblower_report. Business justification: Whistleblower reports alleging ethics violations or compliance breaches require corrective actions to address the identified issues. One report can generate multiple corrective actions (disciplinary, ' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WhistleblowerReport .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the corrective action was completed and ready for verification.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual financial cost incurred to implement the corrective action.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Department' ;
    rdfs:comment 'Department or functional area responsible for implementing the corrective action (e.g., Housekeeping, Food and Beverage, Front Desk, Engineering).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this CAPA record, used in regulatory correspondence and audit documentation. Format: CAPA-YYYY-NNNNNN.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classification of the action as corrective (addresses existing issue), preventive (prevents future occurrence), or both.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'High-level category of compliance domain that this corrective action addresses. [ENUM-REF-CANDIDATE: data-privacy|health-safety|accessibility|fire-safety|food-safety|financial|environmental — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action. Open indicates newly created, in-progress indicates work underway, pending-verification indicates awaiting validation, closed indicates completed and verified, overdue indicates past target date, cancelled indicates action no longer required.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Assessment of how effective the corrective action was in resolving the issue and preventing recurrence.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Scheduled date for follow-up review to assess long-term effectiveness of the corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Indicates whether this corrective action requires escalation to senior management or regulatory authorities.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated financial cost to implement the corrective action, including labor, materials, and external services.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceOfCompletion rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Completion' ;
    rdfs:comment 'Description or reference to documentation, photos, certificates, or other evidence demonstrating completion of the corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Detailed description of the preventive measures implemented to prevent recurrence of the issue.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority level for completing this corrective action based on risk severity and regulatory impact.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceDetected rdf:type rdf:Property ;
    rdfs:label 'Recurrence Detected' ;
    rdfs:comment 'Indicates whether the same or similar issue recurred after the corrective action was implemented, suggesting ineffective remediation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date when regulatory authorities were notified of the corrective action completion.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether regulatory authorities must be notified of this corrective action and its completion.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Analysis of the underlying root cause that led to the compliance finding or incident, used to inform preventive actions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective action must be completed to meet regulatory or audit requirements.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that the corrective action was effectively implemented and resolved the issue.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Notes and observations from the verification process documenting the effectiveness of the corrective action.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiaId rdf:type rdf:Property ;
    rdfs:label 'Dpia Id' ;
    rdfs:comment 'Unique identifier for the Data Protection Impact Assessment record. Primary key.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dpia .

ind:dpiaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dpia Employee Id' ;
    rdfs:comment 'Identifier of the user who created this DPIA record, supporting audit trail and accountability requirements.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dpiaUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dpia Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last updated this DPIA record, supporting audit trail and accountability requirements.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the DPIA was formally approved.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current approval status of the DPIA within the organization\'s governance workflow.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Full name of the individual who approved the DPIA (typically a senior privacy officer, legal counsel, or executive).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'Job title or role of the assessor (e.g., Data Protection Officer, Privacy Manager, Compliance Analyst).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedDecisionLogic rdf:type rdf:Property ;
    rdfs:label 'Automated Decision Logic' ;
    rdfs:comment 'Description of the logic involved in automated decision-making processes, if applicable.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedDecisionMakingFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Decision Making Flag' ;
    rdfs:comment 'Indicates whether the processing involves automated decision-making, including profiling, that produces legal or similarly significant effects.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderTransferFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transfer Flag' ;
    rdfs:comment 'Indicates whether the processing involves transfer of personal data to third countries or international organizations.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSubjectConsultationFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Consultation Flag' ;
    rdfs:comment 'Indicates whether data subjects or their representatives were consulted during the DPIA process, as recommended under GDPR Article 35(9).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSubjectConsultationSummary rdf:type rdf:Property ;
    rdfs:label 'Data Subject Consultation Summary' ;
    rdfs:comment 'Summary of feedback or views obtained from data subjects or their representatives during the DPIA process.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Consultation Date' ;
    rdfs:comment 'Date on which the Data Protection Officer was consulted regarding the DPIA.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpoConsultationFlag rdf:type rdf:Property ;
    rdfs:label 'Dpo Consultation Flag' ;
    rdfs:comment 'Indicates whether the Data Protection Officer was consulted during the DPIA process as required under GDPR Article 35(2).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpoRecommendation rdf:type rdf:Property ;
    rdfs:label 'Dpo Recommendation' ;
    rdfs:comment 'Formal recommendation or advice provided by the Data Protection Officer regarding the processing activity and identified risks.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedPrivacyRisks rdf:type rdf:Property ;
    rdfs:label 'Identified Privacy Risks' ;
    rdfs:comment 'Comprehensive description of privacy risks identified during the assessment, including risks to data subject rights and freedoms.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'Legal basis under GDPR Article 6 that justifies the processing activity being assessed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures' ;
    rdfs:comment 'Detailed description of technical and organizational measures implemented or planned to mitigate identified privacy risks.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:necessityAssessment rdf:type rdf:Property ;
    rdfs:label 'Necessity Assessment' ;
    rdfs:comment 'Assessment of whether the data processing is necessary to achieve the stated purpose, documenting the business justification and legal basis.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Description' ;
    rdfs:comment 'Detailed description of the data processing activity, including purpose, scope, data subjects involved, and data categories processed.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityName rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Name' ;
    rdfs:comment 'Name of the personal data processing activity being assessed (e.g., Guest Loyalty Program Enrollment, Employee Background Screening, CCTV Surveillance in Public Areas).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proportionalityAssessment rdf:type rdf:Property ;
    rdfs:label 'Proportionality Assessment' ;
    rdfs:comment 'Assessment of whether the data processing is proportionate to the purpose, evaluating whether less intrusive alternatives exist.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Risk level remaining after mitigation measures have been applied, determining whether additional action or supervisory authority consultation is required.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriod rdf:type rdf:Property ;
    rdfs:label 'Retention Period' ;
    rdfs:comment 'Documented retention period for personal data processed under this activity, aligned with data minimization principles.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Frequency in months at which the DPIA should be reviewed and updated to ensure continued accuracy and compliance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskLikelihood rdf:type rdf:Property ;
    rdfs:label 'Risk Likelihood' ;
    rdfs:comment 'Likelihood rating of the identified privacy risks materializing before mitigation measures are applied.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSeverity rdf:type rdf:Property ;
    rdfs:label 'Risk Severity' ;
    rdfs:comment 'Overall severity rating of the identified privacy risks before mitigation measures are applied.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryDataFlag rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Flag' ;
    rdfs:comment 'Indicates whether the processing involves special categories of personal data as defined in GDPR Article 9 (e.g., health data, biometric data, racial or ethnic origin).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialCategoryJustification rdf:type rdf:Property ;
    rdfs:label 'Special Category Justification' ;
    rdfs:comment 'Justification and legal basis for processing special category data, if applicable, under GDPR Article 9(2).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Date' ;
    rdfs:comment 'Date on which the supervisory authority was consulted regarding the high-risk processing activity.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisoryAuthorityConsultationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Required Flag' ;
    rdfs:comment 'Indicates whether consultation with the supervisory authority is required due to high residual risk that cannot be adequately mitigated, as per GDPR Article 36.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityResponse rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Response' ;
    rdfs:comment 'Summary of the response or guidance received from the supervisory authority following consultation.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferSafeguards rdf:type rdf:Property ;
    rdfs:label 'Transfer Safeguards' ;
    rdfs:comment 'Description of safeguards in place for cross-border data transfers (e.g., Standard Contractual Clauses, Binding Corporate Rules, adequacy decision).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceId rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Id' ;
    rdfs:comment 'Unique identifier for the environmental compliance record. Primary key for this entity.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalCompliance .

ind:primaryEnvironmentalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Environmental Employee Id' ;
    rdfs:comment 'Identifier of the user who created this environmental compliance record.' ;
    rdfs:domain ind:EnvironmentalCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:carbonEmissionsFramework rdf:type rdf:Property ;
    rdfs:label 'Carbon Emissions Framework' ;
    rdfs:comment 'The carbon emissions or greenhouse gas reporting framework that this compliance obligation aligns with.' ;
    rdfs:domain ind:EnvironmentalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Email' ;
    rdfs:comment 'Email address of the environmental compliance officer responsible for this obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Name' ;
    rdfs:comment 'Name of the property or corporate environmental compliance officer responsible for managing this compliance obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerPhone rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Phone' ;
    rdfs:comment 'Phone number of the environmental compliance officer responsible for this obligation.' ;
    rdfs:domain ind:Compliance ;
