    rdfs:domain ind:FitnessClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'The marketing and display name of the fitness class as presented to guests.' ;
