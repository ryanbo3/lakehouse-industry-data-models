ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The type or category of food safety certification (e.g., HACCP, ServSafe, local health department grade, ISO 22000, food handler card, manager certification). [ENUM-REF-CANDIDATE: HACCP|ServSafe|Local Health Department|ISO 22000|Food Handler|Manager Certification|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
