    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryHealthEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Health Employee Id' ;
    rdfs:comment 'Identifier of the employee involved in the incident, if applicable. Nullable for non-employee incidents.' ;
