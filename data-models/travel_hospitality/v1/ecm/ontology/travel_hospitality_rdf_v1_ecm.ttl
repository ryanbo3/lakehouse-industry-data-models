    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturer\'s warranty coverage expires.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Physical weight of the equipment in kilograms.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fitnessClassId rdf:type rdf:Property ;
    rdfs:label 'Fitness Class Id' ;
    rdfs:comment 'Unique identifier for the fitness class. Primary key.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FitnessClass .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'Reference to the system user who last modified this fitness class record.' ;
    rdfs:domain ind:FitnessClass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advanceBookingRequiredHours rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Required Hours' ;
    rdfs:comment 'The minimum number of hours in advance that guests must book to reserve a spot in this class.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRestrictionMaximum rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Maximum' ;
    rdfs:comment 'The maximum age in years allowed for participation, if applicable (nullable for classes with no upper age limit).' ;
    rdfs:domain ind:FitnessClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRestrictionMinimum rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Minimum' ;
    rdfs:comment 'The minimum age in years required for a guest to participate in this fitness class.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationPolicyHours rdf:type rdf:Property ;
