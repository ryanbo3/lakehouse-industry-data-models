ind:clientContactEmail rdf:type rdf:Property ;
    rdfs:label 'Client Contact Email' ;
    rdfs:comment 'Email address of the primary contact person from the client organization.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactName rdf:type rdf:Property ;
    rdfs:label 'Client Contact Name' ;
    rdfs:comment 'Full name of the primary contact person from the client organization for this inquiry.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactPhone rdf:type rdf:Property ;
    rdfs:label 'Client Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person from the client organization.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Client Organization Name' ;
    rdfs:comment 'Name of the organization or company submitting the MICE inquiry.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the competitor property or venue that won the business if the inquiry was lost to competition.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Converted Timestamp' ;
    rdfs:comment 'Timestamp when the inquiry was converted to a definite booking or contract. Null if not yet converted.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decisionTimeline rdf:type rdf:Property ;
    rdfs:label 'Decision Timeline' ;
    rdfs:comment 'Expected date by which the prospective client will make a booking decision.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedAttendance rdf:type rdf:Property ;
    rdfs:label 'Estimated Attendance' ;
    rdfs:comment 'Estimated number of attendees or participants for the event as indicated in the inquiry.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionSpaceRequirements rdf:type rdf:Property ;
    rdfs:label 'Function Space Requirements' ;
    rdfs:comment 'Description of function space requirements including room types, capacities, setup styles, and special configurations needed for the event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupRoomBlockEstimate rdf:type rdf:Property ;
    rdfs:label 'Group Room Block Estimate' ;
    rdfs:comment 'Estimated number of guest rooms required for the group block to accommodate event attendees.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inquiryNumber rdf:type rdf:Property ;
    rdfs:label 'Inquiry Number' ;
    rdfs:comment 'Business-facing unique inquiry reference number generated by Delphi by Amadeus for tracking and communication with prospective clients.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryStatus rdf:type rdf:Property ;
    rdfs:label 'Inquiry Status' ;
    rdfs:comment 'Current lifecycle status of the MICE inquiry in the sales pipeline. Tracks progression from initial lead through conversion or closure. [ENUM-REF-CANDIDATE: new|qualified|proposal_sent|negotiation|converted|lost|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Lead Owner Email' ;
    rdfs:comment 'Email address of the sales manager or event coordinator assigned as the owner of this inquiry.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadOwnerName rdf:type rdf:Property ;
    rdfs:label 'Lead Owner Name' ;
    rdfs:comment 'Name of the sales manager or event coordinator assigned as the owner of this inquiry.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadScore rdf:type rdf:Property ;
    rdfs:label 'Lead Score' ;
    rdfs:comment 'Numeric score assigned to the inquiry based on qualification criteria such as budget fit, date flexibility, and conversion probability. Used for prioritization.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lostReason rdf:type rdf:Property ;
    rdfs:label 'Lost Reason' ;
    rdfs:comment 'Reason why the inquiry was lost or not converted (e.g., budget constraints, dates unavailable, competitor selected). Populated when inquiry_status is \'lost\'.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Market segment classification for the inquiry (corporate, association, government, SMERF, incentive, other). Used for revenue management and reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredEndDate rdf:type rdf:Property ;
    rdfs:label 'Preferred End Date' ;
    rdfs:comment 'Preferred or requested end date for the event as specified by the prospective client.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredStartDate rdf:type rdf:Property ;
    rdfs:label 'Preferred Start Date' ;
    rdfs:comment 'Preferred or requested start date for the event as specified by the prospective client.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Indicates whether the inquiry has been qualified as a viable sales opportunity based on budget, dates, and requirements alignment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Name or description of the referral source if the inquiry came through a referral (e.g., past client, partner organization, industry association).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomNightsEstimate rdf:type rdf:Property ;
    rdfs:label 'Room Nights Estimate' ;
    rdfs:comment 'Estimated total room nights (rooms × nights) for the group block.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the MICE inquiry was received (e.g., direct contact, OTA, GDS, referral, website form, email, phone call, walk-in). [ENUM-REF-CANDIDATE: direct|ota|gds|referral|website|email|phone|walk_in — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lostBusinessId rdf:type rdf:Property ;
    rdfs:label 'Lost Business Id' ;
    rdfs:comment 'Unique identifier for the lost business record. Primary key.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposalId rdf:type rdf:Property ;
    rdfs:label 'Proposal Id' ;
    rdfs:comment 'Foreign key linking to event.proposal. Business justification: lost_business currently only links to inquiry (lost_business.inquiry_id → inquiry). However, the sales lifecycle is inquiry → proposal → booking. Lost business can occur at the proposal stage (proposa' ;
    rdfs:domain ind:Event ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Proposal .

ind:competitorPropertyLocation rdf:type rdf:Property ;
    rdfs:label 'Competitor Property Location' ;
    rdfs:comment 'Geographic location of the competitor property, used for market analysis and competitive benchmarking.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPropertyName rdf:type rdf:Property ;
    rdfs:label 'Competitor Property Name' ;
    rdfs:comment 'Name of the competitor property that won the business, if known. Used for competitive intelligence and market positioning analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorQuotedRate rdf:type rdf:Property ;
    rdfs:label 'Competitor Quoted Rate' ;
    rdfs:comment 'The rate quoted by the competitor property, if known. Critical for competitive rate positioning analysis.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionMakerEmail rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Email' ;
    rdfs:comment 'Email address of the decision maker, used for follow-up and future sales opportunities.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakerName rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Name' ;
    rdfs:comment 'Name of the primary decision maker or meeting planner who made the final decision to book elsewhere or cancel.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakerPhone rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Phone' ;
    rdfs:comment 'Phone number of the decision maker for future contact and relationship management.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFbRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Fb Revenue' ;
    rdfs:comment 'Total estimated food and beverage revenue from catering and banquet services that would have been generated by the event.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMeetingSpaceRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Meeting Space Revenue' ;
    rdfs:comment 'Estimated revenue from function space rental fees that would have been generated.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedOtherRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Other Revenue' ;
    rdfs:comment 'Estimated revenue from other sources such as AV equipment, spa services, golf, or ancillary services that would have been generated.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedPeakRooms rdf:type rdf:Property ;
    rdfs:label 'Estimated Peak Rooms' ;
    rdfs:comment 'Maximum number of rooms that would have been occupied on the peak night of the event.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedRoomNights rdf:type rdf:Property ;
    rdfs:label 'Estimated Room Nights' ;
    rdfs:comment 'Total number of room nights that would have been generated by the group block if the business had been won.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedRoomRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Room Revenue' ;
    rdfs:comment 'Total estimated room revenue that would have been generated from the group block, used for lost revenue analysis.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpAction rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action' ;
    rdfs:comment 'Planned follow-up actions or next steps to maintain the relationship or pursue future opportunities with this client.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'The channel or source through which the original inquiry was received (e.g., direct, OTA, GDS, referral, website).' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossDate rdf:type rdf:Property ;
    rdfs:label 'Loss Date' ;
    rdfs:comment 'The date when the business was officially marked as lost or when the client declined or cancelled the opportunity.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Loss Reason Category' ;
    rdfs:comment 'Primary category explaining why the business was lost. Critical for competitive intelligence and win/loss analysis.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Loss Reason Detail' ;
    rdfs:comment 'Detailed explanation of the specific reason the business was lost, providing additional context beyond the category.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Loss Reference Number' ;
    rdfs:comment 'Business identifier or tracking number assigned to this lost business record for reporting and analysis purposes.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossStatus rdf:type rdf:Property ;
    rdfs:label 'Loss Status' ;
    rdfs:comment 'Current status of the lost business record indicating the stage of loss confirmation and tracking.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedGroupAdr rdf:type rdf:Property ;
    rdfs:label 'Quoted Group Adr' ;
    rdfs:comment 'The average daily rate that was quoted to the group in the proposal. Used for rate competitiveness analysis.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesManagerNotes rdf:type rdf:Property ;
    rdfs:label 'Sales Manager Notes' ;
    rdfs:comment 'Detailed notes from the sales manager capturing insights, client feedback, competitive intelligence, and lessons learned from the lost opportunity.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winBackProbability rdf:type rdf:Property ;
    rdfs:label 'Win Back Probability' ;
    rdfs:comment 'Sales manager assessment of the likelihood of winning back this client for future events.' ;
    rdfs:domain ind:LostBusiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:banquetMenuPackageId rdf:type rdf:Property ;
    rdfs:label 'Banquet Menu Package Id' ;
    rdfs:comment 'Foreign key linking to fnb.banquet_menu_package. Business justification: Proposals reference specific banquet packages when quoting F&B pricing to prospective group clients. Essential for accurate proposal costing, competitive positioning, client presentation materials, an' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BanquetMenuPackage .

ind:decisionMakerMemberId rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member. Business justification: Proposals are addressed to specific loyalty member decision-makers. Sales teams reference member tier when crafting proposals and pricing; loyalty status influences concessions and upgrade offers in g' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Foreign key linking to spa.spa_package. Business justification: Event proposals include spa packages as value-adds for wellness conferences, incentive trips, executive retreats. Sales process requires linking proposed spa packages to calculate total event value an' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:proposalApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Proposal Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager or director who approved the proposal terms and pricing.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:proposalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Proposal Employee Id' ;
    rdfs:comment 'Reference to the sales manager or event sales executive responsible for this proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the proposal was internally approved for submission to the client.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:avPackageAmount rdf:type rdf:Property ;
    rdfs:label 'Av Package Amount' ;
    rdfs:comment 'Total estimated cost for audio-visual equipment and services proposed.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avPackageDescription rdf:type rdf:Property ;
    rdfs:label 'Av Package Description' ;
    rdfs:comment 'Description of proposed audio-visual equipment, technology packages, and production services included in the proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientFeedback rdf:type rdf:Property ;
    rdfs:label 'Client Feedback' ;
    rdfs:comment 'Client comments, objections, or feedback received during proposal review and negotiation.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientResponseDate rdf:type rdf:Property ;
    rdfs:label 'Client Response Date' ;
    rdfs:comment 'Date when the client formally responded to the proposal with acceptance, decline, or request for revision.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitivePositioningNotes rdf:type rdf:Property ;
    rdfs:label 'Competitive Positioning Notes' ;
    rdfs:comment 'Internal notes capturing competitive intelligence, alternative venues being considered by the client, and strategic positioning rationale.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date by which the client is expected to make a decision on accepting or declining the proposal.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fbMinimumAmount rdf:type rdf:Property ;
    rdfs:label 'Fb Minimum Amount' ;
    rdfs:comment 'Minimum guaranteed spend commitment for catering and food and beverage services as part of the proposal terms.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposalName rdf:type rdf:Property ;
    rdfs:label 'Proposal Name' ;
    rdfs:comment 'Descriptive name or title of the proposal, typically reflecting the event name and client organization.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalNumber rdf:type rdf:Property ;
    rdfs:label 'Proposal Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the proposal, used in client communications and contract references.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current lifecycle status of the proposal in the negotiation and approval workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|revised|accepted|declined|expired|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomBlockQuantity rdf:type rdf:Property ;
    rdfs:label 'Room Block Quantity' ;
    rdfs:comment 'Total number of guest rooms proposed to be blocked for event attendees.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomBlockRate rdf:type rdf:Property ;
    rdfs:label 'Room Block Rate' ;
    rdfs:comment 'Proposed negotiated nightly rate for the group room block, typically below BAR (Best Available Rate).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEstimatedRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Revenue' ;
    rdfs:comment 'Total estimated event value including rooms, F&B, AV, and ancillary services, representing the full revenue opportunity.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validUntilDate rdf:type rdf:Property ;
    rdfs:label 'Valid Until Date' ;
    rdfs:comment 'Expiration date after which the proposal terms, rates, and availability are no longer guaranteed.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventSpaceAllocationId rdf:type rdf:Property ;
    rdfs:label 'Event Space Allocation Id' ;
    rdfs:comment 'Unique identifier for the function space allocation record. Primary key.' ;
    rdfs:domain ind:EventSpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:propertyFacilityId rdf:type rdf:Property ;
    rdfs:label 'Property Facility Id' ;
    rdfs:comment 'Foreign key linking to property.facility. Business justification: Event space allocations frequently use property facilities (pools, fitness centers, outdoor terraces) for breakout sessions, receptions, team-building activities. Essential for facility scheduling con' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PropertyFacility .

ind:actualAttendance rdf:type rdf:Property ;
    rdfs:label 'Actual Attendance' ;
    rdfs:comment 'The actual number of attendees who participated in the event. Captured post-event for reconciliation and future forecasting accuracy.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocated Timestamp' ;
    rdfs:comment 'Date and time when the space allocation record was created in the system. Represents the initial booking or hold timestamp.' ;
    rdfs:domain ind:EventSpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The calendar date on which the function space is allocated for the event. Used for space utilization tracking and conflict prevention.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Business identifier for the space allocation, typically generated by the event management system (Delphi). Used for operational reference and tracking.' ;
    rdfs:domain ind:EventSpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complimentaryReason rdf:type rdf:Property ;
    rdfs:label 'Complimentary Reason' ;
    rdfs:comment 'Business justification for providing complimentary space rental (e.g., minimum F&B spend met, VIP client, promotional package, contract terms). Populated when is_complimentary is true.' ;
    rdfs:domain ind:EventSpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the space allocation status changed from tentative to definite. Represents the point at which the booking became contractually binding.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External system identifier or client reference number for cross-system reconciliation and client communication. May contain third-party booking platform IDs or client internal event codes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isComplimentary rdf:type rdf:Property ;
    rdfs:label 'Is Complimentary' ;
    rdfs:comment 'Indicates whether the space rental is provided at no charge as part of a promotional offer, loyalty benefit, or contractual agreement. True if complimentary, false if charged.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the space allocation was released back to inventory. Populated when status changes to released or cancelled.' ;
    rdfs:domain ind:EventSpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rentalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Rental Charge Amount' ;
    rdfs:comment 'The monetary charge for renting the function space for the specified time period. May be zero if complimentary or included in package pricing.' ;
    rdfs:domain ind:EventSpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentalChargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Rental Charge Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rental charge amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:EventSpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupStartTime rdf:type rdf:Property ;
    rdfs:label 'Setup Start Time' ;
    rdfs:comment 'The date and time when setup activities begin for the event. Used to calculate total space occupancy time including pre-event preparation.' ;
    rdfs:domain ind:EventSpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spaceBlockType rdf:type rdf:Property ;
    rdfs:label 'Space Block Type' ;
    rdfs:comment 'Indicates whether the space allocation is exclusive to this event or shared with other concurrent activities. Exclusive means sole use, shared means multiple events may use portions, concurrent means back-to-back scheduling, overflow means secondary space for capacity overflow.' ;
    rdfs:domain ind:EventSpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownEndTime rdf:type rdf:Property ;
    rdfs:label 'Teardown End Time' ;
    rdfs:comment 'The date and time when teardown activities are completed and the space is released. Used to calculate total space occupancy time including post-event breakdown.' ;
    rdfs:domain ind:EventSpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:amenityFulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Amenity Fulfillment Id' ;
    rdfs:comment 'Unique identifier for the amenity fulfillment record. Primary key.' ;
    rdfs:domain ind:AmenityFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:experienceSpecialRequestId rdf:type rdf:Property ;
    rdfs:label 'Experience Special Request Id' ;
    rdfs:comment 'Foreign key linking to experience.experience_special_request. Business justification: Amenity fulfillments often originate from guest special requests (e.g., champagne on arrival, extra pillows, dietary accommodations). This FK links the fulfillment record to the originating request, e' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExperienceSpecialRequest .

ind:guestExperienceEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Guest Experience Enrollment Id' ;
    rdfs:comment 'Foreign key linking to experience.guest_experience_enrollment. Business justification: Amenities can be delivered as part of experience program enrollment (e.g., SALT program includes welcome amenity package, spa program includes in-room amenities). This FK links amenity delivery to the' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestExperienceEnrollment .

ind:roomAmenityId rdf:type rdf:Property ;
    rdfs:label 'Room Amenity Id' ;
    rdfs:comment 'Foreign key linking to inventory.room_amenity. Business justification: Links guest amenity consumption to inventory amenity records for tracking usage rates, replenishment scheduling, cost allocation, and identifying missing/damaged amenities. Essential for amenity inven' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoomAmenity .

ind:serviceRecoveryActionId rdf:type rdf:Property ;
    rdfs:label 'Service Recovery Action Id' ;
    rdfs:comment 'Foreign key linking to experience.service_recovery_action. Business justification: Amenity fulfillments are often part of service recovery actions (e.g., complimentary champagne after a complaint, upgraded amenities as compensation). This FK links the fulfillment to the service reco' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRecoveryAction .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'The actual date and time when the amenity was delivered to the guest room.' ;
    rdfs:domain ind:AmenityFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:amenityCategory rdf:type rdf:Property ;
    rdfs:label 'Amenity Category' ;
    rdfs:comment 'Classification of the amenity by purpose or program type. [ENUM-REF-CANDIDATE: welcome_gift|vip_package|loyalty_benefit|celebration_package|special_occasion|room_upgrade_amenity|complimentary_service — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityCode rdf:type rdf:Property ;
    rdfs:label 'Amenity Code' ;
    rdfs:comment 'Standardized code identifying the type of amenity (e.g., WINE_CHEESE, FRUIT_BASKET, FLOWERS, CHAMPAGNE, CHOCOLATE, WELCOME_KIT).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityDescription rdf:type rdf:Property ;
    rdfs:label 'Amenity Description' ;
    rdfs:comment 'Detailed description of the amenity contents and presentation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityName rdf:type rdf:Property ;
    rdfs:label 'Amenity Name' ;
    rdfs:comment 'Human-readable name of the amenity item or package.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason for cancellation if the amenity fulfillment was cancelled.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledBy rdf:type rdf:Property ;
    rdfs:label 'Cancelled By' ;
    rdfs:comment 'Name or identifier of the person who cancelled the amenity fulfillment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time when the amenity fulfillment was cancelled.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargePostedFlag rdf:type rdf:Property ;
    rdfs:label 'Charge Posted Flag' ;
    rdfs:comment 'Indicates whether a charge for the amenity has been posted to the guest folio (True/False).' ;
    rdfs:domain ind:AmenityFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryAgentName rdf:type rdf:Property ;
    rdfs:label 'Delivery Agent Name' ;
    rdfs:comment 'Name of the staff member who delivered the amenity.' ;
    rdfs:domain ind:AmenityFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:folioReference rdf:type rdf:Property ;
    rdfs:label 'Folio Reference' ;
    rdfs:comment 'Reference to the guest folio where the amenity charge was posted, if applicable.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current status of the amenity fulfillment workflow.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the guest acknowledged receipt of the amenity (True/False).' ;
    rdfs:domain ind:AmenityFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Guest Acknowledgment Timestamp' ;
    rdfs:comment 'The date and time when the guest acknowledged receipt of the amenity.' ;
    rdfs:domain ind:AmenityFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:guestFeedback rdf:type rdf:Property ;
    rdfs:label 'Guest Feedback' ;
    rdfs:comment 'Free-text feedback or comments provided by the guest regarding the amenity.' ;
    rdfs:domain ind:AmenityFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Guest Satisfaction Score' ;
    rdfs:comment 'Numeric satisfaction score provided by the guest for the amenity experience, typically on a scale of 1-5 or 1-10.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User or system identifier of the person or process that last modified the amenity fulfillment record.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'The guest\'s loyalty program tier at the time of amenity fulfillment (e.g., Silver, Gold, Platinum, Diamond).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occasionType rdf:type rdf:Property ;
    rdfs:label 'Occasion Type' ;
    rdfs:comment 'The special occasion or reason for the amenity delivery, if applicable. [ENUM-REF-CANDIDATE: birthday|anniversary|honeymoon|business_milestone|vip_visit|apology|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AmenityFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomNumber rdf:type rdf:Property ;
    rdfs:label 'Room Number' ;
    rdfs:comment 'The room number where the amenity is to be delivered.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'The date on which the amenity is scheduled to be delivered.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time' ;
    rdfs:comment 'The precise date and time when the amenity is scheduled to be delivered to the guest room.' ;
    rdfs:domain ind:AmenityFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost of the amenity fulfillment (quantity × unit cost) in the property\'s local currency.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per unit of the amenity item in the property\'s local currency.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseActivityId rdf:type rdf:Property ;
    rdfs:label 'Case Activity Id' ;
    rdfs:comment 'Unique identifier for the case activity record. Primary key for the case activity log.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onlineReviewId rdf:type rdf:Property ;
    rdfs:label 'Online Review Id' ;
    rdfs:comment 'Foreign key linking to experience.online_review. Business justification: Case activities can be triggered by online reviews requiring management response or service recovery. When a negative review is published, case activity tracks the response actions. This FK links the ' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnlineReview .

ind:primaryCaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Case Employee Id' ;
    rdfs:comment 'Reference to the employee or agent responsible for performing or logging this activity. Supports accountability and performance tracking.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:roomId rdf:type rdf:Property ;
    rdfs:label 'Room Id' ;
    rdfs:comment 'Foreign key linking to inventory.room. Business justification: Case activities (room inspections, follow-up visits, maintenance verification) require room linkage to document which specific unit was inspected/serviced. Critical for audit trail of room-specific se' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Room .

ind:serviceCaseId rdf:type rdf:Property ;
    rdfs:label 'Service Case Id' ;
    rdfs:comment 'Reference to the parent service recovery case that this activity belongs to. Links activity to the case lifecycle.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCase .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed narrative of the activity, actions taken, observations, or communications. Provides full context for audit trail and service recovery analysis.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityNumber rdf:type rdf:Property ;
    rdfs:label 'Activity Number' ;
    rdfs:comment 'Business-facing unique identifier for the activity. Used for tracking and reference in communications.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current state of the activity within its lifecycle. Tracks completion and workflow progression.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activitySubject rdf:type rdf:Property ;
    rdfs:label 'Activity Subject' ;
    rdfs:comment 'Brief summary or title of the activity. Provides quick context for the action taken.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activity Timestamp' ;
    rdfs:comment 'Date and time when the activity occurred or was logged. Primary event timestamp for chronological sequencing and SLA (Service Level Agreement) tracking.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the activity action taken within the service case. Determines workflow and required fields. [ENUM-REF-CANDIDATE: note|email|call|escalation|resolution|compensation|guest_follow_up|internal_review|manager_approval — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentName rdf:type rdf:Property ;
    rdfs:label 'Agent Name' ;
    rdfs:comment 'Full name of the agent or employee who performed the activity. Denormalized for reporting convenience.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of files or documents attached to this activity (e.g., photos, receipts, correspondence). Supports evidence tracking and documentation completeness.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Medium through which the activity or communication occurred. Supports channel preference analysis and omnichannel service tracking. [ENUM-REF-CANDIDATE: phone|email|in_person|sms|chat|social_media|mobile_app — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the compensation value. Supports multi-currency operations and financial reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Offered Flag' ;
    rdfs:comment 'Indicates whether compensation or amenity was offered to the guest during this activity. Supports compensation tracking and GRR (Guest Recovery Rate) analysis.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Category of compensation or recovery gesture offered. Populated when compensation_offered_flag is true. Supports compensation strategy analysis. [ENUM-REF-CANDIDATE: room_upgrade|discount|refund|loyalty_points|amenity|complimentary_service|future_credit — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationValue rdf:type rdf:Property ;
    rdfs:label 'Compensation Value' ;
    rdfs:comment 'Monetary value of the compensation offered. Populated when compensation_offered_flag is true. Used for service recovery cost tracking and ROI (Return on Investment) analysis.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Length of time spent on the activity in minutes. Used for agent productivity analysis and workload management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation for why the case was escalated. Populated when activity_type is escalation. Supports root cause analysis of escalation patterns.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which follow-up action should be completed. Populated when follow_up_required_flag is true. Supports task scheduling and accountability.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether additional follow-up action is needed after this activity. Used for task management and ensuring closure.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestCommunicationFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Communication Flag' ;
    rdfs:comment 'Indicates whether this activity involved direct communication with the guest. Used for tracking guest touchpoints and engagement frequency.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestSentiment rdf:type rdf:Property ;
    rdfs:label 'Guest Sentiment' ;
    rdfs:comment 'Assessed emotional tone or satisfaction level of the guest during this activity. Supports sentiment tracking and early warning for escalation risk.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Confidential notes for internal use only, not shared with the guest. Supports team collaboration and knowledge transfer.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Result or conclusion of the activity. Captures resolution status, guest response, or next steps required.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionCommitment rdf:type rdf:Property ;
    rdfs:label 'Resolution Commitment' ;
    rdfs:comment 'Specific commitment or promise made to the guest during this activity. Tracks service recovery pledges and follow-through requirements.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDeadline rdf:type rdf:Property ;
    rdfs:label 'Resolution Deadline' ;
    rdfs:comment 'Target date and time by which the committed resolution must be delivered. Used for SLA (Service Level Agreement) milestone tracking and escalation monitoring.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMilestoneFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Milestone Flag' ;
    rdfs:comment 'Indicates whether this activity represents a key SLA (Service Level Agreement) milestone (e.g., first response, resolution). Used for compliance tracking and performance measurement.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaMilestoneType rdf:type rdf:Property ;
    rdfs:label 'Sla Milestone Type' ;
    rdfs:comment 'Classification of the SLA (Service Level Agreement) milestone achieved. Populated when sla_milestone_flag is true. Supports detailed SLA (Service Level Agreement) performance analysis.' ;
    rdfs:domain ind:CaseActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Unique identifier of the activity record in the source system. Enables traceability and reconciliation with operational systems.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Unique identifier for the experience program. Primary key.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:amenityPackageCode rdf:type rdf:Property ;
    rdfs:label 'Amenity Package Code' ;
    rdfs:comment 'Reference code linking to the standard amenity package associated with this experience program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Benefits Summary' ;
    rdfs:comment 'Summary of benefits, amenities, and services included in the experience program offering.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingWindowDays rdf:type rdf:Property ;
    rdfs:label 'Booking Window Days' ;
    rdfs:comment 'Number of days in advance that guests must book to be eligible for this experience program. Null indicates no advance booking requirement.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the program cost estimate.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated cost per guest enrollment for delivering this experience program including amenities, services, and operational costs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csatTargetScore rdf:type rdf:Property ;
    rdfs:label 'Csat Target Score' ;
    rdfs:comment 'Target CSAT score that this experience program aims to achieve. CSAT is a standard satisfaction measurement.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Business rules and requirements that determine which guests qualify for enrollment in this experience program.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligiblePropertyList rdf:type rdf:Property ;
    rdfs:label 'Eligible Property List' ;
    rdfs:comment 'Comma-separated list of property codes where this experience program is available and can be offered to guests.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleRatePlans rdf:type rdf:Property ;
    rdfs:label 'Eligible Rate Plans' ;
    rdfs:comment 'Comma-separated list of rate plan codes that qualify for this experience program. Null indicates all rate plans are eligible.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleRoomTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Room Types' ;
    rdfs:comment 'Comma-separated list of room type codes that qualify for this experience program. Null indicates all room types are eligible.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Method by which guests are enrolled into the experience program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPartnerName rdf:type rdf:Property ;
    rdfs:label 'External Partner Name' ;
    rdfs:comment 'Name of external partner or vendor involved in delivering this experience program. Null if fully internal.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gssTargetScore rdf:type rdf:Property ;
    rdfs:label 'Gss Target Score' ;
    rdfs:comment 'Target GSS that this experience program aims to achieve. GSS is a standard hospitality satisfaction metric.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyTierRequirement rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Requirement' ;
    rdfs:comment 'Minimum loyalty program tier required for guest eligibility. Null indicates no loyalty tier requirement.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingChannel rdf:type rdf:Property ;
    rdfs:label 'Marketing Channel' ;
    rdfs:comment 'Primary marketing channel through which this experience program is promoted (e.g., Email, Website, Mobile App, In-Property).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLos rdf:type rdf:Property ;
    rdfs:label 'Maximum Los' ;
    rdfs:comment 'Maximum number of nights for which this experience program applies. Null indicates no maximum restriction.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumLos rdf:type rdf:Property ;
    rdfs:label 'Minimum Los' ;
    rdfs:comment 'Minimum number of nights a guest must stay to qualify for this experience program. LOS is a standard hospitality metric.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsTargetScore rdf:type rdf:Property ;
    rdfs:label 'Nps Target Score' ;
    rdfs:comment 'Target NPS score that this experience program aims to achieve or maintain. NPS is a key guest satisfaction metric.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or identifier of the business unit, department, or individual responsible for managing this experience program.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Department or division that owns and manages this experience program.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsRedemptionEligible rdf:type rdf:Property ;
    rdfs:label 'Points Redemption Eligible' ;
    rdfs:comment 'Indicates whether guests can use loyalty points to redeem or upgrade to this experience program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsRedemptionValue rdf:type rdf:Property ;
    rdfs:label 'Points Redemption Value' ;
    rdfs:comment 'Number of loyalty points required to redeem this experience program. Null if not redeemable via points.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programCategory rdf:type rdf:Property ;
    rdfs:label 'Program Category' ;
    rdfs:comment 'Broader business category grouping for the experience program used for reporting and analytics.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Unique business identifier code for the experience program used across systems and communications.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed narrative description of the experience program including objectives, benefits, and guest experience elements.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Full descriptive name of the experience program as displayed to guests and staff.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the experience program indicating availability and operational state.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the experience program type. SALT refers to Satisfaction and Loyalty Tracking programs.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Flag' ;
    rdfs:comment 'Indicates whether this experience program has direct revenue implications (e.g., upsell packages) or is purely cost-based (e.g., service recovery).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:saltProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Salt Program Flag' ;
    rdfs:comment 'Indicates whether this is a SALT (Satisfaction and Loyalty Tracking) program used for systematic guest satisfaction measurement.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceRecoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Service Recovery Flag' ;
    rdfs:comment 'Indicates whether this experience program is designed for service recovery and guest issue resolution purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetGuestSegment rdf:type rdf:Property ;
    rdfs:label 'Target Guest Segment' ;
    rdfs:comment 'Primary guest segment or persona this program is designed for (e.g., Elite Loyalty Members, Business Travelers, Families, Honeymooners).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Legal terms, conditions, and restrictions applicable to this experience program.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedCaseServiceCaseId rdf:type rdf:Property ;
    rdfs:label 'Linked Case Service Case Id' ;
    rdfs:comment 'Reference to a service recovery case if the special request is part of a guest complaint resolution or service recovery workflow. Links to Salesforce CRM case management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCase .

ind:primaryExperienceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Experience Employee Id' ;
    rdfs:comment 'Reference to the staff member assigned to fulfill the request. Links to the workforce employee record responsible for execution.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual cost incurred by the property for fulfilling the special request. Captured post-fulfillment for financial analysis and service cost management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFulfillmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Fulfillment Timestamp' ;
    rdfs:comment 'Date and time when the special request was actually completed and delivered to the guest. Used to measure fulfillment timeliness and service performance.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:advanceNoticeHours rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Hours' ;
    rdfs:comment 'Number of hours of advance notice required for this request type. Defines the minimum lead time needed for successful fulfillment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeToGuestAmount rdf:type rdf:Property ;
    rdfs:label 'Charge To Guest Amount' ;
    rdfs:comment 'Amount charged to the guest folio for the special request fulfillment. Zero if the request is complimentary or included in the rate.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Deadline Timestamp' ;
    rdfs:comment 'Target date and time by which the special request must be fulfilled. Defines the service level agreement commitment for the request.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentLocation rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Location' ;
    rdfs:comment 'Specific location within the property where the request is to be fulfilled. May reference room number, venue name, or facility area.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentNotes rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Notes' ;
    rdfs:comment 'Staff notes documenting the fulfillment process, actions taken, and any special circumstances. Provides operational context and audit trail.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestFeedbackComment rdf:type rdf:Property ;
    rdfs:label 'Guest Feedback Comment' ;
    rdfs:comment 'Free-text feedback provided by the guest regarding the special request fulfillment experience. Captures qualitative satisfaction data.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Guest Satisfaction Rating' ;
    rdfs:comment 'Guest-provided satisfaction score for the special request fulfillment. Typically on a 1-5 or 1-10 scale. Used to measure request fulfillment quality.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLoyaltyMemberRequest rdf:type rdf:Property ;
    rdfs:label 'Is Loyalty Member Request' ;
    rdfs:comment 'Indicates whether the special request was submitted by a loyalty program member. Used to track and prioritize requests from program participants.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatRequest rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Request' ;
    rdfs:comment 'Indicates whether this is a recurring request from the guest based on historical preference data. Used to identify guest patterns and preferences.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isServiceRecovery rdf:type rdf:Property ;
    rdfs:label 'Is Service Recovery' ;
    rdfs:comment 'Indicates whether the special request is part of a service recovery action to address a guest complaint or service failure. Used to track recovery effectiveness.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestAcknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the special request was acknowledged by staff. Marks the transition from pending to active processing.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestDescription rdf:type rdf:Property ;
    rdfs:label 'Request Description' ;
    rdfs:comment 'Detailed free-text description of the special request as submitted by the guest or captured by staff. Contains the full context and specifics of the guest need.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business identifier for the special request. Human-readable unique reference number used for tracking and communication with guests and staff.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSource rdf:type rdf:Property ;
    rdfs:label 'Request Source' ;
    rdfs:comment 'The channel or interface through which the special request was submitted. Tracks the origin point of the guest request. [ENUM-REF-CANDIDATE: reservation_system|guest_app|front_desk|concierge|loyalty_program|call_center|email|website|ota_channel — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the special request. Tracks the request from submission through fulfillment or closure. [ENUM-REF-CANDIDATE: pending|acknowledged|assigned|in_progress|fulfilled|partially_fulfilled|cancelled|declined|expired — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time when the special request was originally submitted by the guest or entered into the system. Principal business event timestamp for the request lifecycle.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestSubtype rdf:type rdf:Property ;
    rdfs:label 'Request Subtype' ;
    rdfs:comment 'Detailed subcategory of the request type. Provides granular classification for specific request variations within the primary type.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the special request by category. Defines the nature of the guest need or preference being requested. [ENUM-REF-CANDIDATE: room_preference|accessibility_need|dietary_requirement|celebration_setup|early_checkin|late_checkout|amenity_delivery|pillow_menu|transportation|spa_booking|childcare|pet_accommodation — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAdvanceNoticeFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Advance Notice Flag' ;
    rdfs:comment 'Indicates whether the request type requires advance notice for fulfillment. Used to manage guest expectations and operational planning.' ;
    rdfs:domain ind:ExperienceSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The unique identifier of this special request in the source operational system. Enables traceability back to the system of record.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gssScoreId rdf:type rdf:Property ;
    rdfs:label 'Gss Score Id' ;
    rdfs:comment 'Unique identifier for the GSS score measurement record.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GssScore .

ind:bottomBoxPercent rdf:type rdf:Property ;
    rdfs:label 'Bottom Box Percent' ;
    rdfs:comment 'Percentage of respondents who gave the lowest satisfaction ratings (bottom-box scores), typically 1-2 on a 5-point scale or 0-6 on a 10-point scale.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Brand identifier for the property (e.g., luxury, premium, select-service segment), used for brand-level GSS aggregation and QA reviews.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandQaReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Qa Review Flag' ;
    rdfs:comment 'Boolean indicator of whether this GSS score has been flagged for brand-level quality assurance review due to performance concerns or significant variance.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Timestamp when the GSS score was calculated and recorded in the system.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'Lower bound of the statistical confidence interval for the GSS score, typically at 95% confidence level.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'Upper bound of the statistical confidence interval for the GSS score, typically at 95% confidence level.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detractorPercent rdf:type rdf:Property ;
    rdfs:label 'Detractor Percent' ;
    rdfs:comment 'Percentage of respondents classified as detractors (score 0-6 on likelihood-to-recommend scale).' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gm Review Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this GSS score requires General Manager review and action plan due to falling below acceptable thresholds or being classified as Critical.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grrPercent rdf:type rdf:Property ;
    rdfs:label 'Grr Percent' ;
    rdfs:comment 'Guest Recovery Rate percentage for the measurement period, calculated as the percentage of service recovery cases that resulted in successful guest satisfaction restoration.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gssScoreValue rdf:type rdf:Property ;
    rdfs:label 'Gss Score Value' ;
    rdfs:comment 'The calculated GSS score value for the measurement period, typically on a 0-100 scale derived from aggregated Medallia survey responses.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement End Date' ;
    rdfs:comment 'End date of the measurement period for this GSS score.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'Frequency or granularity of the GSS measurement period (daily, weekly, monthly, quarterly, annual).' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Start Date' ;
    rdfs:comment 'Start date of the measurement period for this GSS score.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passivePercent rdf:type rdf:Property ;
    rdfs:label 'Passive Percent' ;
    rdfs:comment 'Percentage of respondents classified as passives (score 7-8 on likelihood-to-recommend scale).' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodScore rdf:type rdf:Property ;
    rdfs:label 'Prior Period Score' ;
    rdfs:comment 'GSS score value from the immediately preceding measurement period of the same type, used for sequential trend comparison.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodVariance rdf:type rdf:Property ;
    rdfs:label 'Prior Period Variance' ;
    rdfs:comment 'Variance between current GSS score and prior period score, calculated as (gss_score_value - prior_period_score).' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoterPercent rdf:type rdf:Property ;
    rdfs:label 'Promoter Percent' ;
    rdfs:comment 'Percentage of respondents classified as promoters (score 9-10 on likelihood-to-recommend scale).' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedFlag rdf:type rdf:Property ;
    rdfs:label 'Published Flag' ;
    rdfs:comment 'Boolean indicator of whether this GSS score has been published and made available to property management and brand QA teams (True if published, False if draft or under review).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Timestamp when the GSS score was published and made available to stakeholders.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code for the property, used for regional GSS benchmarking and performance comparison.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseRatePercent rdf:type rdf:Property ;
    rdfs:label 'Response Rate Percent' ;
    rdfs:comment 'Percentage of surveys that received responses, calculated as (sample_size / surveys_sent_count) * 100.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saltTargetAttainedFlag rdf:type rdf:Property ;
    rdfs:label 'Salt Target Attained Flag' ;
    rdfs:comment 'Boolean indicator of whether the GSS score met or exceeded the SALT program target (True if gss_score_value >= salt_target_score).' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:saltTargetScore rdf:type rdf:Property ;
    rdfs:label 'Salt Target Score' ;
    rdfs:comment 'Target GSS score defined by the SALT program for this property, department, and measurement period.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of survey responses included in the GSS score calculation for this measurement period.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scoreBand rdf:type rdf:Property ;
    rdfs:label 'Score Band' ;
    rdfs:comment 'Categorical classification of the GSS score into performance bands (Excellent, Good, Needs Improvement, Critical) based on brand-defined thresholds.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRecoveryCaseCount rdf:type rdf:Property ;
    rdfs:label 'Service Recovery Case Count' ;
    rdfs:comment 'Number of service recovery cases opened during the measurement period for this property and department, sourced from Salesforce CRM case management.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveysSentCount rdf:type rdf:Property ;
    rdfs:label 'Surveys Sent Count' ;
    rdfs:comment 'Total number of surveys sent to guests during the measurement period.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:topBoxPercent rdf:type rdf:Property ;
    rdfs:label 'Top Box Percent' ;
    rdfs:comment 'Percentage of respondents who gave the highest satisfaction rating (top-box score), typically 5 on a 5-point scale or 9-10 on a 10-point scale.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yoyScore rdf:type rdf:Property ;
    rdfs:label 'Yoy Score' ;
    rdfs:comment 'GSS score value from the same measurement period in the prior year, used for year-over-year comparison.' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yoyVariance rdf:type rdf:Property ;
    rdfs:label 'Yoy Variance' ;
    rdfs:comment 'Variance between current GSS score and year-over-year score, calculated as (gss_score_value - yoy_score).' ;
    rdfs:domain ind:GssScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the guest completed or exited the experience program.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the guest began participating in the experience program.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:amenityFulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amenity Fulfillment Status' ;
    rdfs:comment 'Status of amenity fulfillment associated with the experience program (not applicable, pending, in progress, completed, partially completed, failed).' ;
    rdfs:domain ind:GuestExperienceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the guest enrolled in the experience program (web, mobile app, front desk, concierge, call center, email).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the guest enrolled in the experience program.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally visible unique enrollment confirmation number provided to the guest.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'Source or trigger that led to the enrollment (guest initiated, staff recommended, loyalty offer, package inclusion, upgrade, complimentary).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Timestamp' ;
    rdfs:comment 'Precise date and time when the guest enrolled in the experience program.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feedbackReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Feedback Received Date' ;
    rdfs:comment 'Date when post-program feedback was received from the guest.' ;
    rdfs:domain ind:GuestExperienceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentProgressPercentage rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Progress Percentage' ;
    rdfs:comment 'Percentage of the experience program activities completed by the guest (0.00 to 100.00).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Number of loyalty program points earned by the guest for participating in this experience program.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Number of participants included in this enrollment (guest plus accompanying guests).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postProgramCsatScore rdf:type rdf:Property ;
    rdfs:label 'Post Program Csat Score' ;
    rdfs:comment 'Customer Satisfaction (CSAT) score provided by the guest after completing the experience program, typically on a scale of 1.00 to 5.00.' ;
    rdfs:domain ind:GuestExperienceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postProgramGssScore rdf:type rdf:Property ;
    rdfs:label 'Post Program Gss Score' ;
    rdfs:comment 'Guest Satisfaction Score (GSS) provided by the guest after completing the experience program, typically on a scale of 1.00 to 5.00 or 1.00 to 10.00.' ;
    rdfs:domain ind:GuestExperienceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postProgramNpsScore rdf:type rdf:Property ;
    rdfs:label 'Post Program Nps Score' ;
    rdfs:comment 'Net Promoter Score (NPS) provided by the guest after completing the experience program, ranging from 0 to 10.' ;
    rdfs:domain ind:GuestExperienceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Scheduled date when the experience program is set to conclude for the guest.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Scheduled date when the experience program is set to begin for the guest.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalProgramCost rdf:type rdf:Property ;
    rdfs:label 'Total Program Cost' ;
    rdfs:comment 'Total cost charged to the guest for the experience program enrollment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsSurveyId rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Id' ;
    rdfs:comment 'Foreign key linking to experience.nps_survey. Business justification: Guest feedback submissions should reference the specific NPS survey instrument used for the response. This links the feedback record to the survey definition, enabling analysis by survey version, camp' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NpsSurvey .

ind:touchpointId rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Id' ;
    rdfs:comment 'Foreign key linking to experience.touchpoint. Business justification: Guest feedback is collected at specific touchpoints in the journey (post-checkout survey, post-stay email, in-app feedback). Linking feedback to touchpoint enables touchpoint-level satisfaction analys' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Touchpoint .

ind:amenitiesRating rdf:type rdf:Property ;
    rdfs:label 'Amenities Rating' ;
    rdfs:comment 'Guest rating of property amenities including pool, fitness center, business center, and other facilities. Informs capital expenditure and FF&E decisions.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleanlinessRating rdf:type rdf:Property ;
    rdfs:label 'Cleanliness Rating' ;
    rdfs:comment 'Guest rating specific to property cleanliness standards across all areas. Essential metric for housekeeping operations and health compliance.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complaintFlag rdf:type rdf:Property ;
    rdfs:label 'Complaint Flag' ;
    rdfs:comment 'Boolean indicator whether this feedback contains a complaint requiring service recovery action. Triggers case management workflow in Salesforce CRM.' ;
    rdfs:domain ind:GuestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'Transaction-specific satisfaction rating typically on a 1-5 or 1-10 scale. Measures satisfaction with a specific interaction or service touchpoint.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedbackNumber rdf:type rdf:Property ;
    rdfs:label 'Feedback Number' ;
    rdfs:comment 'Human-readable business identifier for the feedback submission. Used for case tracking and guest communication reference.' ;
    rdfs:domain ind:GuestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fnbRating rdf:type rdf:Property ;
    rdfs:label 'Fnb Rating' ;
    rdfs:comment 'Guest rating specific to food and beverage quality, variety, and service. Key metric for F&B operations and outlet performance.' ;
    rdfs:domain ind:GuestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gssScore rdf:type rdf:Property ;
    rdfs:label 'Gss Score' ;
    rdfs:comment 'Overall guest satisfaction score typically on a 0-100 scale or 1-5 scale. Composite metric aggregating multiple satisfaction dimensions. Key performance indicator for property operations and service quality.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guestSegment rdf:type rdf:Property ;
    rdfs:label 'Guest Segment' ;
    rdfs:comment 'Business segment classification of the guest. FIT (Free Independent Traveler), MICE (Meetings Incentives Conferences Exhibitions). Used for segment-specific satisfaction analysis and targeted service improvements. [ENUM-REF-CANDIDATE: Transient|Group|Contract|Wholesale|FIT|Corporate|Leisure|MICE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-2 three-letter language code indicating the language in which the feedback was submitted. Used for multilingual sentiment analysis and regional experience tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationRating rdf:type rdf:Property ;
    rdfs:label 'Location Rating' ;
    rdfs:comment 'Guest rating of property location convenience, accessibility, and surrounding area. Influences market positioning and guest segment targeting.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsClassification rdf:type rdf:Property ;
    rdfs:label 'Nps Classification' ;
    rdfs:comment 'Categorical classification of the NPS score. Promoter (9-10) indicates strong loyalty, Passive (7-8) indicates satisfaction without enthusiasm, Detractor (0-6) indicates dissatisfaction and churn risk.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'General overall rating provided by the guest, typically on a 1-5 star scale. Used for aggregated property ratings and guest experience benchmarking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Rate plan code under which the guest booked. Used for analyzing satisfaction by rate segment and pricing strategy effectiveness.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Number of hours between survey invitation and guest response submission. Metric for survey engagement and recency of experience recall.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomRating rdf:type rdf:Property ;
    rdfs:label 'Room Rating' ;
    rdfs:comment 'Guest rating specific to room quality, cleanliness, comfort, and amenities. Key operational metric for housekeeping and room standards.' ;
    rdfs:domain ind:GuestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sentimentIndicator rdf:type rdf:Property ;
    rdfs:label 'Sentiment Indicator' ;
    rdfs:comment 'Automated or manual classification of the overall sentiment expressed in the feedback. Derived from verbatim comments and ratings through natural language processing or analyst review.' ;
    rdfs:domain ind:GuestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Numerical sentiment score typically ranging from -1.0 (very negative) to +1.0 (very positive). Generated through natural language processing of verbatim comments.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRating rdf:type rdf:Property ;
    rdfs:label 'Service Rating' ;
    rdfs:comment 'Guest rating specific to staff service quality, responsiveness, and professionalism. Critical metric for training and service excellence programs.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRecoveryRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Service Recovery Required Flag' ;
    rdfs:comment 'Boolean indicator whether this feedback requires formal service recovery intervention. Used for GRR (Guest Recovery Rate) calculation and case prioritization.' ;
    rdfs:domain ind:GuestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Completion Status' ;
    rdfs:comment 'Indicator of whether the guest completed the entire survey, partially completed it, or abandoned it. Used for survey design optimization and response quality assessment.' ;
    rdfs:domain ind:GuestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyInvitationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Invitation Sent Timestamp' ;
    rdfs:comment 'Date and time when the survey invitation was sent to the guest. Used for calculating response time and survey engagement metrics.' ;
    rdfs:domain ind:GuestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:valueRating rdf:type rdf:Property ;
    rdfs:label 'Value Rating' ;
    rdfs:comment 'Guest perception of value for money received. Critical metric for pricing strategy and revenue management decisions.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verbatimComment rdf:type rdf:Property ;
    rdfs:label 'Verbatim Comment' ;
    rdfs:comment 'Free-text comment provided by the guest describing their experience in their own words. Rich qualitative data for sentiment analysis, theme extraction, and service recovery prioritization.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wouldRecommendFlag rdf:type rdf:Property ;
    rdfs:label 'Would Recommend Flag' ;
    rdfs:comment 'Boolean indicator whether the guest explicitly stated they would recommend the property to others. Complementary metric to NPS for loyalty measurement.' ;
    rdfs:domain ind:GuestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wouldReturnFlag rdf:type rdf:Property ;
    rdfs:label 'Would Return Flag' ;
    rdfs:comment 'Boolean indicator whether the guest explicitly stated they would return to the property. Key metric for repeat business potential and guest retention forecasting.' ;
    rdfs:domain ind:GuestFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestInteractionId rdf:type rdf:Property ;
    rdfs:label 'Guest Interaction Id' ;
    rdfs:comment 'Unique identifier for each guest interaction touchpoint record. Primary key for the guest_interaction data product.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestInteraction .

ind:primaryGuestEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Guest Employee Id' ;
    rdfs:comment 'Reference to the employee who conducted the interaction. Enables staff engagement scoring and service quality attribution.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryGuestLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Guest Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the staff member or system user who last modified this interaction record.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amenityOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Amenity Offered Flag' ;
    rdfs:comment 'Boolean indicator of whether a complimentary amenity or service recovery gesture was offered during this interaction.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Initiated Flag' ;
    rdfs:comment 'Boolean indicator of whether the interaction was initiated by the guest (true) or proactively by staff (false). Distinguishes reactive vs proactive service.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Interaction Duration Minutes' ;
    rdfs:comment 'Length of the interaction in minutes. Used for staff productivity analysis and service quality assessment.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionLanguage rdf:type rdf:Property ;
    rdfs:label 'Interaction Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the primary language used during the interaction.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionLocation rdf:type rdf:Property ;
    rdfs:label 'Interaction Location' ;
    rdfs:comment 'Specific location within the property where the interaction occurred (e.g., Front Desk, Lobby, Guest Room 305, Pool Area).' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionNotes rdf:type rdf:Property ;
    rdfs:label 'Interaction Notes' ;
    rdfs:comment 'Detailed narrative notes captured by staff describing the interaction content, guest requests, and any commitments made. Confidential business information.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionNumber rdf:type rdf:Property ;
    rdfs:label 'Interaction Number' ;
    rdfs:comment 'Human-readable business identifier for the interaction, used for tracking and reference in service recovery workflows.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionOutcome rdf:type rdf:Property ;
    rdfs:label 'Interaction Outcome' ;
    rdfs:comment 'The result or disposition of the interaction at the time of logging. Indicates whether the guest need was addressed or requires follow-up.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Interaction Source System' ;
    rdfs:comment 'The operational system that originally captured this interaction record. Used for data lineage and quality assessment.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionSubject rdf:type rdf:Property ;
    rdfs:label 'Interaction Subject' ;
    rdfs:comment 'Brief summary or subject line describing the interaction topic. Used for quick reference and categorization.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The date and time when the interaction occurred in the property local timezone. Primary business event timestamp for journey sequencing and touchpoint analysis.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the interaction based on its primary purpose and nature. Enables journey mapping and touchpoint analysis. [ENUM-REF-CANDIDATE: check_in_greeting|check_out_farewell|concierge_inquiry|complaint|compliment|service_request|loyalty_recognition|proactive_outreach|room_visit|amenity_delivery|special_occasion_recognition|upsell_offer|feedback_solicitation|emergency_response|vip_welcome|other — promote to reference product]' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether this interaction is eligible for inclusion in Net Promoter Score survey sampling.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sentimentClassification rdf:type rdf:Property ;
    rdfs:label 'Sentiment Classification' ;
    rdfs:comment 'Assessed sentiment or emotional tone of the interaction, either manually classified by staff or automatically derived from text analytics.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialRequestFulfilledFlag rdf:type rdf:Property ;
    rdfs:label 'Special Request Fulfilled Flag' ;
    rdfs:comment 'Boolean indicator of whether a special request made during this interaction was successfully fulfilled.' ;
    rdfs:domain ind:GuestInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vipStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Status Flag' ;
    rdfs:comment 'Boolean indicator of whether the guest was flagged as VIP at the time of interaction. Used for personalized service tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyTemplateId rdf:type rdf:Property ;
    rdfs:label 'Survey Template Id' ;
    rdfs:comment 'Reference to the master survey template or design framework from which this survey instance was created. Supports template-based survey design and standardization.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveyTemplate .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'Identifier for the A/B test variant if this survey is part of a controlled experiment to optimize survey design, question wording, or distribution strategy (e.g., \'Control\', \'Variant_A\', \'Variant_B\'). Null if not part of an A/B test.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anonymousResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Anonymous Response Flag' ;
    rdfs:comment 'Indicates whether guest responses to this survey are collected anonymously (True) without linking to guest profiles, or are attributed to specific guests (False) for follow-up and service recovery.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'The date when this survey was last reviewed for compliance with data privacy and guest communication regulations. Null if not yet reviewed.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewed Flag' ;
    rdfs:comment 'Indicates whether this survey has been reviewed and approved for compliance with data privacy regulations (GDPR, CCPA) and guest communication standards (True) or is pending review (False).' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detractorThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Detractor Threshold Max' ;
    rdfs:comment 'The maximum NPS score (typically 6 on a 0-10 scale) for a guest response to be classified as a Detractor. Standard NPS methodology uses 0-6 as detractors.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Distribution Frequency' ;
    rdfs:comment 'The frequency at which this survey is distributed: one_time (single campaign), daily, weekly, monthly, quarterly (scheduled intervals), or event_triggered (distributed based on business events).' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Minutes' ;
    rdfs:comment 'The estimated time (in minutes) required for a guest to complete the entire survey. Used to set guest expectations and optimize response rates.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic follow-up workflows (e.g., service recovery case creation for detractors, thank-you messages for promoters) are enabled for responses to this survey (True) or disabled (False).' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Incentive Description' ;
    rdfs:comment 'Description of the incentive offered to guests for completing the survey (e.g., \'500 loyalty points\', \'Entry into monthly prize draw\', \'10% discount on next stay\'). Null if no incentive is offered.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Offered Flag' ;
    rdfs:comment 'Indicates whether an incentive (e.g., loyalty points, discount, prize entry) is offered to guests who complete this survey (True) or no incentive is provided (False).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medalliaSurveyCode rdf:type rdf:Property ;
    rdfs:label 'Medallia Survey Code' ;
    rdfs:comment 'The unique identifier for this survey in the Medallia experience analytics platform. Used for integration and data synchronization with the source system.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiLanguageEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Language Enabled Flag' ;
    rdfs:comment 'Indicates whether this survey supports multiple language options for guests (True) or is available in a single language only (False).' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passiveThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Passive Threshold Min' ;
    rdfs:comment 'The minimum NPS score (typically 7 on a 0-10 scale) required for a guest response to be classified as Passive. Standard NPS methodology uses 7-8 as passives.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programOwner rdf:type rdf:Property ;
    rdfs:label 'Program Owner' ;
    rdfs:comment 'The business unit, department, or individual responsible for managing and overseeing this survey campaign (e.g., \'Guest Experience Team\', \'Regional Operations\', \'Loyalty Program Management\').' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoterThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Promoter Threshold Min' ;
    rdfs:comment 'The minimum NPS score (typically 9 on a 0-10 scale) required for a guest response to be classified as a Promoter. Standard NPS methodology uses 9-10 as promoters.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:questionCount rdf:type rdf:Property ;
    rdfs:label 'Question Count' ;
    rdfs:comment 'The total number of questions included in this survey instrument, including the core NPS question and any follow-up or supplementary questions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseCollectionWindowHours rdf:type rdf:Property ;
    rdfs:label 'Response Collection Window Hours' ;
    rdfs:comment 'The time window (in hours) after survey distribution during which guest responses are actively collected before the survey invitation expires (e.g., 72 hours for post-checkout surveys).' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saltProgramLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Salt Program Linked Flag' ;
    rdfs:comment 'Indicates whether this survey is formally linked to the enterprise SALT (Satisfaction and Loyalty Tracking) program for strategic guest experience measurement (True) or is a standalone survey (False).' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyCode rdf:type rdf:Property ;
    rdfs:label 'Survey Code' ;
    rdfs:comment 'Unique external business identifier or code for the survey instrument used for integration and reporting (e.g., \'NPS-POST-CO-2024Q1\').' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyDescription rdf:type rdf:Property ;
    rdfs:label 'Survey Description' ;
    rdfs:comment 'Detailed description of the survey\'s purpose, objectives, and scope. Provides context for survey administrators and analysts.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyName rdf:type rdf:Property ;
    rdfs:label 'Survey Name' ;
    rdfs:comment 'Business-friendly name of the NPS survey campaign or instrument (e.g., \'Post-Checkout NPS Q1 2024\', \'Luxury Segment Satisfaction Survey\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Current lifecycle status of the survey campaign: draft (design phase), active (live and collecting responses), paused (temporarily suspended), completed (campaign ended), archived (historical record).' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the survey based on its purpose and timing: transactional (post-transaction), relationship (periodic guest sentiment), event_based (triggered by specific events), or periodic (scheduled intervals).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Version' ;
    rdfs:comment 'Version identifier for the survey instrument to track design iterations and changes over time (e.g., \'v1.0\', \'v2.1\', \'2024-Q1\'). Supports A/B testing and longitudinal analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResponseRatePercent rdf:type rdf:Property ;
    rdfs:label 'Target Response Rate Percent' ;
    rdfs:comment 'The target response rate (as a percentage) that the survey campaign aims to achieve. Used for performance monitoring and optimization (e.g., 25.00 represents 25% target response rate).' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSegment rdf:type rdf:Property ;
    rdfs:label 'Target Segment' ;
    rdfs:comment 'The guest segment or audience targeted by this survey (e.g., \'Luxury Tier Loyalty Members\', \'Business Travelers\', \'Leisure FIT Guests\', \'Group Event Attendees\'). May reference loyalty tiers, booking channels, or demographic segments.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'The business event or condition that triggers distribution of this survey to a guest: post_checkout (after guest checks out), post_stay (after reservation completion), post_event (after attending an event), post_fnb_visit (after F&B experience), post_spa_visit (after spa service), post_meeting (after MICE event), scheduled (time-based distribution). [ENUM-REF-CANDIDATE: post_checkout|post_stay|post_event|post_fnb_visit|post_spa_visit|post_meeting|scheduled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveSetFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Flag' ;
    rdfs:comment 'Indicates whether this review is part of the competitive set analysis for benchmarking. True if included in competitive reputation tracking.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'Date and time when this review record was ingested into the unified reputation management system from the external platform.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:managementResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Management Response Status' ;
    rdfs:comment 'Current status of management response to this review. Tracks service recovery workflow completion.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponseText rdf:type rdf:Property ;
    rdfs:label 'Management Response Text' ;
    rdfs:comment 'Full text of the management response posted to the review platform. Documents service recovery communication.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Management Response Timestamp' ;
    rdfs:comment 'Date and time when the management response was posted to the review platform. Tracks response time performance.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:normalizedRating rdf:type rdf:Property ;
    rdfs:label 'Normalized Rating' ;
    rdfs:comment 'Overall rating normalized to a standard 0-5 scale for cross-platform comparison and aggregation. Enables unified reputation scoring.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformNativeRating rdf:type rdf:Property ;
    rdfs:label 'Platform Native Rating' ;
    rdfs:comment 'Overall rating score as provided by the guest on the platforms native scale. Stored in original format before normalization.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformRatingScale rdf:type rdf:Property ;
    rdfs:label 'Platform Rating Scale' ;
    rdfs:comment 'The native rating scale used by the review platform (e.g., 1-5 stars, 1-10 points). Enables interpretation of platform_native_rating.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformReviewCode rdf:type rdf:Property ;
    rdfs:label 'Platform Review Code' ;
    rdfs:comment 'Unique identifier assigned by the external review platform to this review. Used for deduplication and tracking.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseAuthorName rdf:type rdf:Property ;
    rdfs:label 'Response Author Name' ;
    rdfs:comment 'Name or title of the property representative who authored the management response (e.g., General Manager, Guest Relations Manager).' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewBodyText rdf:type rdf:Property ;
    rdfs:label 'Review Body Text' ;
    rdfs:comment 'Full text content of the review written by the guest. Contains detailed feedback, experiences, and opinions.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewHelpfulnessCount rdf:type rdf:Property ;
    rdfs:label 'Review Helpfulness Count' ;
    rdfs:comment 'Number of users on the review platform who marked this review as helpful. Indicates review influence and visibility.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Review Language Code' ;
    rdfs:comment 'ISO 639-2 three-letter language code of the review text. Supports multilingual reputation management.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Review Source Url' ;
    rdfs:comment 'Direct URL link to the original review on the external platform. Enables quick access for verification and response.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTitle rdf:type rdf:Property ;
    rdfs:label 'Review Title' ;
    rdfs:comment 'Title or headline of the review as provided by the guest. Summarizes the main sentiment or topic.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewVisibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Review Visibility Status' ;
    rdfs:comment 'Current visibility status of the review on the external platform. Tracks whether review is publicly visible.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerAlias rdf:type rdf:Property ;
    rdfs:label 'Reviewer Alias' ;
    rdfs:comment 'Public username or alias of the reviewer as displayed on the review platform. May be pseudonymous.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerLocation rdf:type rdf:Property ;
    rdfs:label 'Reviewer Location' ;
    rdfs:comment 'Geographic location of the reviewer as provided by the review platform, typically city and country.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stayEndDate rdf:type rdf:Property ;
    rdfs:label 'Stay End Date' ;
    rdfs:comment 'End date of the guest stay period referenced in the review, if provided by the platform.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stayStartDate rdf:type rdf:Property ;
    rdfs:label 'Stay Start Date' ;
    rdfs:comment 'Start date of the guest stay period referenced in the review, if provided by the platform.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelerType rdf:type rdf:Property ;
    rdfs:label 'Traveler Type' ;
    rdfs:comment 'Type of traveler as indicated by the reviewer or inferred from the review. Supports segmented reputation analysis.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedStayFlag rdf:type rdf:Property ;
    rdfs:label 'Verified Stay Flag' ;
    rdfs:comment 'Indicates whether the review platform verified that the reviewer actually stayed at the property. True if verified, False otherwise.' ;
    rdfs:domain ind:OnlineReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Quality Audit Id' ;
    rdfs:comment 'Unique identifier for the quality audit record. Primary key for the quality audit entity.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amenityScore rdf:type rdf:Property ;
    rdfs:label 'Amenity Score' ;
    rdfs:comment 'Category score evaluating the quality, availability, and condition of property amenities including fitness centers, pools, business centers, and guest conveniences.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The date on which the quality audit was conducted or completed. Represents the primary business event timestamp for the audit inspection.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Free-text field capturing additional context, observations, commendations, or special circumstances noted during the audit that provide qualitative insight beyond numerical scores.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Report Url' ;
    rdfs:comment 'Web link or file path to the detailed audit report document containing full findings, deficiency descriptions, photographic evidence, and corrective action recommendations.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Flag' ;
    rdfs:comment 'Indicates whether the property met all mandatory brand standards and compliance requirements during the audit. True means full compliance achieved, false indicates brand standard violations requiring remediation.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationLevelAchieved rdf:type rdf:Property ;
    rdfs:label 'Certification Level Achieved' ;
    rdfs:comment 'The quality classification or rating level awarded based on audit results, such as Forbes 5-Star, Forbes 4-Star, AAA 5-Diamond, AAA 4-Diamond, or brand-specific tier designations. Drives market positioning and guest expectations.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'The actual date when all required corrective actions were completed and verified. Used to measure remediation cycle time and compliance with deadlines.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Status' ;
    rdfs:comment 'Current status of corrective action implementation. Not started means no work has begun, in progress indicates active remediation, completed means property reports actions done, verified means auditor confirmed completion, and overdue means deadline has passed without completion.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Critical Deficiency Count' ;
    rdfs:comment 'Number of critical or high-severity deficiencies identified that pose immediate risk to guest safety, brand reputation, or regulatory compliance. Requires urgent remediation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Total number of deficiencies, non-conformances, or findings identified during the audit. Provides a quantitative measure of quality gaps requiring corrective action.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityScore rdf:type rdf:Property ;
    rdfs:label 'Facility Score' ;
    rdfs:comment 'Category score assessing physical property condition, maintenance standards, cleanliness, and facility upkeep. Evaluates the tangible aspects of the guest experience.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fnbScore rdf:type rdf:Property ;
    rdfs:label 'Fnb Score' ;
    rdfs:comment 'Category score assessing food and beverage operations including restaurant service, menu quality, culinary execution, bar service, and dining experience standards.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmAccountabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Gm Accountability Flag' ;
    rdfs:comment 'Indicates whether the audit results are tied to General Manager performance evaluation and accountability metrics. True means GM is formally accountable for audit outcomes and corrective actions.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:housekeepingScore rdf:type rdf:Property ;
    rdfs:label 'Housekeeping Score' ;
    rdfs:comment 'Category score assessing room cleanliness, housekeeping standards, turndown service, linen quality, and overall room presentation. Critical component for guest satisfaction.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:majorDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Major Deficiency Count' ;
    rdfs:comment 'Number of major or medium-severity deficiencies identified that significantly impact guest experience or operational standards but do not pose immediate critical risk.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Minor Deficiency Count' ;
    rdfs:comment 'Number of minor or low-severity deficiencies identified that represent opportunities for improvement but do not materially impact guest experience or compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passFailDetermination rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Determination' ;
    rdfs:comment 'Final audit outcome indicating whether the property met the required quality standards. Pass means all standards met, fail indicates significant deficiencies, conditional pass requires minor corrective actions, and pending means determination is under review.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuditDate rdf:type rdf:Property ;
    rdfs:label 'Prior Audit Date' ;
    rdfs:comment 'The date of the previous quality audit of the same type conducted at this property. Used to calculate audit frequency and track historical score trends.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Prior Certification Level' ;
    rdfs:comment 'The quality classification or rating level held by the property before this audit. Used to track certification progression or regression over time.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorOverallScore rdf:type rdf:Property ;
    rdfs:label 'Prior Overall Score' ;
    rdfs:comment 'The overall quality score from the previous audit of the same type. Used to calculate score variance and track quality improvement or degradation trends over time.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Re Inspection Date' ;
    rdfs:comment 'The scheduled or actual date of the follow-up audit conducted to verify that corrective actions have been effectively implemented and quality standards are now met.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Inspection Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up audit or re-inspection is required to verify corrective action effectiveness and validate quality improvement. True means re-inspection is mandatory, false means no follow-up audit needed.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scoreVariance rdf:type rdf:Property ;
    rdfs:label 'Score Variance' ;
    rdfs:comment 'The change in overall score compared to the prior audit, calculated as current score minus prior score. Positive values indicate quality improvement, negative values indicate degradation.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceScore rdf:type rdf:Property ;
    rdfs:label 'Service Score' ;
    rdfs:comment 'Category score evaluating service quality, staff professionalism, guest interaction, and service delivery standards. Key component of overall audit assessment.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spaScore rdf:type rdf:Property ;
    rdfs:label 'Spa Score' ;
    rdfs:comment 'Category score evaluating spa and wellness facilities, treatment quality, therapist professionalism, and spa service standards. Applicable only to properties with spa amenities.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reputationAlertId rdf:type rdf:Property ;
    rdfs:label 'Reputation Alert Id' ;
    rdfs:comment 'Unique identifier for the reputation alert record. Primary key.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReputationAlert .

ind:primaryReputationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Reputation Employee Id' ;
    rdfs:comment 'Identifier of the staff member or manager assigned to investigate and resolve the alert. Links to workforce management system.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the assigned user acknowledged receipt of the alert. Used to track response time SLA compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualResponseMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Response Minutes' ;
    rdfs:comment 'Actual time in minutes from alert trigger to acknowledgment. Calculated as difference between triggered_timestamp and acknowledged_timestamp.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertNumber rdf:type rdf:Property ;
    rdfs:label 'Alert Number' ;
    rdfs:comment 'Human-readable business identifier for the alert, formatted as ALT-YYYYMMDD sequence. Used for tracking and communication.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle status of the alert. Tracks progression from initial trigger through acknowledgment, investigation, resolution, and closure.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the alert based on the triggering condition. Values: low_nps_threshold_breach (NPS score below threshold), negative_ota_review (negative review on OTA platform), repeat_complaint_pattern (multiple complaints from same guest or about same issue), gss_drop (Guest Satisfaction Score drop), csat_threshold_breach (Customer Satisfaction below threshold), social_media_escalation (negative social media mention).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the alert was assigned to a specific user for action. Null if alert has not yet been assigned.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the alert was formally closed after verification and documentation. Final lifecycle timestamp.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Primary category of the guest complaint or concern identified in the feedback. Examples: room_cleanliness, staff_service, noise, amenities, billing, food_quality. Supports root cause analysis and trend identification. [ENUM-REF-CANDIDATE: room_cleanliness|staff_service|noise|amenities|billing|food_quality|maintenance|check_in_process|check_out_process|reservation_issue|loyalty_program|parking|wifi|temperature_control|bedding_comfort|bathroom_condition — promote to reference product]' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentResponsible rdf:type rdf:Property ;
    rdfs:label 'Department Responsible' ;
    rdfs:comment 'Hotel department identified as responsible for addressing the issue that triggered the alert. Used for routing and accountability. [ENUM-REF-CANDIDATE: front_desk|housekeeping|food_and_beverage|maintenance|reservations|guest_services|management|sales|events — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated Flag' ;
    rdfs:comment 'Indicates whether the alert was escalated to senior management or corporate level due to severity or lack of timely resolution. True if escalated, false otherwise.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalated Timestamp' ;
    rdfs:comment 'Date and time when the alert was escalated. Null if alert was not escalated.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:guestContactMethod rdf:type rdf:Property ;
    rdfs:label 'Guest Contact Method' ;
    rdfs:comment 'Method used to contact the guest for service recovery. Null if guest was not contacted.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestContactedFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Contacted Flag' ;
    rdfs:comment 'Indicates whether the guest was directly contacted by management as part of the resolution process. True if contact was made, false otherwise.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestSatisfactionPostRecovery rdf:type rdf:Property ;
    rdfs:label 'Guest Satisfaction Post Recovery' ;
    rdfs:comment 'Guest satisfaction level measured after service recovery action was taken. Used to calculate Guest Recovery Rate (GRR) effectiveness.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsAwarded rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Awarded' ;
    rdfs:comment 'Number of loyalty program points awarded to the guest as part of service recovery. Null if no points were awarded.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryCostAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Cost Amount' ;
    rdfs:comment 'Monetary value of service recovery compensation provided to the guest (room credit, refund, amenity value, loyalty points cash equivalent). Used to calculate Guest Recovery Rate (GRR) cost.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Recovery Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the recovery cost amount. Examples: USD, EUR, GBP.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionActionTaken rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Taken' ;
    rdfs:comment 'Description of the corrective action or service recovery measure taken to address the alert. Examples: guest contacted and apology issued, room upgraded, refund processed, staff retraining scheduled, maintenance work order created.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the alert was marked as resolved after corrective action was completed. Used to calculate resolution time metrics.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether the alert response met the SLA target. True if actual_response_minutes <= sla_response_minutes, false otherwise.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResponseMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Response Minutes' ;
    rdfs:comment 'Target response time in minutes based on alert severity level, as defined by SALT program SLA standards. Used to measure compliance.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'Configured threshold value that was breached to trigger the alert. Represents the minimum acceptable performance level for the metric.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggeredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Triggered Timestamp' ;
    rdfs:comment 'Date and time when the alert was triggered by the Medallia alert engine based on threshold breach or pattern detection.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:varianceFromThreshold rdf:type rdf:Property ;
    rdfs:label 'Variance From Threshold' ;
    rdfs:comment 'Calculated difference between the metric value and threshold value. Negative values indicate below-threshold performance. Helps prioritize alert severity.' ;
    rdfs:domain ind:ReputationAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Assigned Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Service cases are assigned to and owned by specific departments for resolution, workload balancing, and SLA tracking. Hotels measure case resolution time by org_unit for operational performance manage' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryServiceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Employee Id' ;
    rdfs:comment 'Reference to the staff member or team currently responsible for resolving this case.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryServiceLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Service Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the staff member who last modified the service case record.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Hours' ;
    rdfs:comment 'Actual elapsed time in hours from case creation to resolution. Used for SLA compliance tracking and performance analysis.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseCategory rdf:type rdf:Property ;
    rdfs:label 'Case Category' ;
    rdfs:comment 'Primary classification of the service issue. [ENUM-REF-CANDIDATE: room_quality|service_failure|billing_dispute|amenity_issue|noise_complaint|safety_concern|cleanliness|food_beverage|maintenance|staff_behavior — promote to reference product]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDescription rdf:type rdf:Property ;
    rdfs:label 'Case Description' ;
    rdfs:comment 'Detailed narrative description of the guest complaint or service issue. Captures the full context of the problem as reported by the guest or staff.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally-visible unique case identifier displayed to guests and staff. Human-readable business identifier for tracking and reference.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseOrigin rdf:type rdf:Property ;
    rdfs:label 'Case Origin' ;
    rdfs:comment 'Channel through which the service case was initiated. Tracks the source of guest feedback or complaint.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSubcategory rdf:type rdf:Property ;
    rdfs:label 'Case Subcategory' ;
    rdfs:comment 'Detailed subcategory providing granular classification within the primary case category. Enables detailed root cause analysis.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationTotalValue rdf:type rdf:Property ;
    rdfs:label 'Compensation Total Value' ;
    rdfs:comment 'Total monetary value of all compensation provided to the guest for service recovery, including refunds, credits, upgrades, and amenities. Expressed in property local currency.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Indicates whether and to what level the case has been escalated beyond the initial assigned owner.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the case was escalated to a higher authority level. Nullable if never escalated.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Timestamp' ;
    rdfs:comment 'Date and time when the required follow-up with the guest was completed. Nullable if no follow-up was required or not yet completed.' ;
    rdfs:domain ind:Experience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grrOutcomeFlag rdf:type rdf:Property ;
    rdfs:label 'Grr Outcome Flag' ;
    rdfs:comment 'Indicates whether the guest was successfully recovered (satisfied with resolution). True if guest expressed satisfaction post-resolution, False otherwise. Used to calculate GRR KPI.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestLifetimeValueSegment rdf:type rdf:Property ;
    rdfs:label 'Guest Lifetime Value Segment' ;
    rdfs:comment 'Lifetime value segment classification of the guest at case creation. Used to prioritize high-value guest recovery efforts.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestSatisfactionPostResolution rdf:type rdf:Property ;
    rdfs:label 'Guest Satisfaction Post Resolution' ;
    rdfs:comment 'Guest satisfaction score collected after case resolution, typically on a 1-5 or 1-10 scale. Nullable if guest did not provide feedback.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsPostResolution rdf:type rdf:Property ;
    rdfs:label 'Nps Post Resolution' ;
    rdfs:comment 'Net Promoter Score collected after case resolution, on a 0-10 scale. Nullable if guest did not provide NPS feedback.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preventableFlag rdf:type rdf:Property ;
    rdfs:label 'Preventable Flag' ;
    rdfs:comment 'Indicates whether the service failure could have been prevented through better processes, training, or systems. Used for operational improvement analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the case was marked as resolved. Nullable for open cases.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Primary method used to resolve the guest service case. Tracks the recovery action category.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified underlying cause of the service failure. Used for trend analysis and process improvement initiatives.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target number of hours for case resolution based on priority level. Used to calculate SLA compliance.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialMediaMentionFlag rdf:type rdf:Property ;
    rdfs:label 'Social Media Mention Flag' ;
    rdfs:comment 'Indicates whether the guest mentioned or threatened to mention the issue on social media platforms. True if social media risk identified, False otherwise.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemCaseCode rdf:type rdf:Property ;
    rdfs:label 'Source System Case Code' ;
    rdfs:comment 'Original case identifier from the source operational system. Used for data lineage and reconciliation with source systems.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryServiceAuthorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Authorized By Employee Id' ;
    rdfs:comment 'Reference to the employee who authorized the service recovery action.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryServiceLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Service Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who last modified the service recovery action record.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryServiceCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Service Created By Employee Id' ;
    rdfs:comment 'Reference to the employee who created the service recovery action record in the system.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed description of the specific service recovery action taken, including any customization or personalization for the guest.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business-facing unique identifier for the service recovery action, used for tracking and reference in guest communications and internal reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'Level of management authorization required and obtained for this recovery action. Reflects the escalation tier based on recovery value and type.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorized Timestamp' ;
    rdfs:comment 'Date and time when the service recovery action was authorized by the responsible manager or employee.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Boolean flag indicating whether additional follow-up with the guest is required after the initial recovery action.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Timestamp' ;
    rdfs:comment 'Date and time when the service recovery action was successfully fulfilled and delivered to the guest.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:guestAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Guest Acceptance Status' ;
    rdfs:comment 'Indicates whether the guest accepted, declined, or has not yet responded to the service recovery action offer.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProactive rdf:type rdf:Property ;
    rdfs:label 'Is Proactive' ;
    rdfs:comment 'Boolean flag indicating whether the recovery action was proactively offered by the property before the guest complained (True) or was reactive in response to a complaint (False).' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'Monetary value of the service recovery action in the property\'s local currency. Represents the cost or value of the compensation extended to the guest.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postRecoveryGssScore rdf:type rdf:Property ;
    rdfs:label 'Post Recovery Gss Score' ;
    rdfs:comment 'Guest Satisfaction Score (GSS) collected after the service recovery action. Measures guest satisfaction with the recovery process and outcome.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postRecoveryNpsScore rdf:type rdf:Property ;
    rdfs:label 'Post Recovery Nps Score' ;
    rdfs:comment 'Net Promoter Score (NPS) collected from the guest after the service recovery action was delivered. Measures the impact of recovery on guest loyalty.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryActionCategory rdf:type rdf:Property ;
    rdfs:label 'Recovery Action Category' ;
    rdfs:comment 'High-level category of the recovery action: monetary compensation, non-monetary benefit, experiential enhancement, or recognition/apology.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryActionType rdf:type rdf:Property ;
    rdfs:label 'Recovery Action Type' ;
    rdfs:comment 'Type of service recovery action extended to the guest. Includes room upgrade, complimentary night, Food and Beverage (F&B) credit, loyalty points award, amenity delivery, or written apology.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryEffectivenessScore rdf:type rdf:Property ;
    rdfs:label 'Recovery Effectiveness Score' ;
    rdfs:comment 'Numerical score (1-10) indicating the effectiveness of the recovery action based on guest feedback or follow-up survey responses. Used for Guest Recovery Rate (GRR) analysis.' ;
    rdfs:domain ind:ServiceRecoveryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTouchpointId rdf:type rdf:Property ;
    rdfs:label 'Parent Touchpoint Id' ;
    rdfs:comment 'Reference to a parent touchpoint if this touchpoint is a sub-touchpoint or variant of a broader interaction (self-referential hierarchy).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Touchpoint .

ind:accessibilityCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliant Flag' ;
    rdfs:comment 'Indicates whether this touchpoint meets Americans with Disabilities Act (ADA) accessibility requirements.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'The degree of automation at this touchpoint (fully automated, semi-automated, manual, hybrid).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Required Flag' ;
    rdfs:comment 'Indicates whether this touchpoint requires compliance review for regulatory adherence (e.g., General Data Protection Regulation (GDPR), California Consumer Privacy Act (CCPA), Payment Card Industry Data Security Standard (PCI DSS)).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerInteraction rdf:type rdf:Property ;
    rdfs:label 'Cost Per Interaction' ;
    rdfs:comment 'The estimated or actual cost per guest interaction at this touchpoint, used for operational efficiency analysis.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataPrivacySensitiveFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Sensitive Flag' ;
    rdfs:comment 'Indicates whether this touchpoint involves collection or processing of privacy-sensitive guest data requiring special handling.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Default Language Code' ;
    rdfs:comment 'The default language code for this touchpoint using ISO 639-1 two-letter codes (e.g., en, es, fr, de, zh).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentOwner rdf:type rdf:Property ;
    rdfs:label 'Department Owner' ;
    rdfs:comment 'The department or functional area responsible for managing and delivering this touchpoint (e.g., Front Office, Housekeeping, Food and Beverage (F&B), Concierge, Guest Services, Revenue Management).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Feedback Collection Method' ;
    rdfs:comment 'The method used to collect guest feedback at this touchpoint (survey, direct feedback, observation, system log, social media, review platform).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestEffortScoreTarget rdf:type rdf:Property ;
    rdfs:label 'Guest Effort Score Target' ;
    rdfs:comment 'The target Guest Effort Score for this touchpoint, representing the desired ease of interaction (lower scores indicate less effort required).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guestSegmentApplicability rdf:type rdf:Property ;
    rdfs:label 'Guest Segment Applicability' ;
    rdfs:comment 'The guest segments to which this touchpoint applies (e.g., all guests, loyalty members only, VIP guests, business travelers, leisure travelers, group bookings). [ENUM-REF-CANDIDATE: all_guests|loyalty_members|vip_guests|business_travelers|leisure_travelers|group_bookings|families|couples — promote to reference product]' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionChannel rdf:type rdf:Property ;
    rdfs:label 'Interaction Channel' ;
    rdfs:comment 'The specific channel through which the touchpoint interaction occurs (e.g., email, mobile app, front desk, in-room tablet, phone, SMS, chatbot, kiosk). [ENUM-REF-CANDIDATE: email|mobile_app|web_portal|front_desk|concierge|phone|sms|chatbot|kiosk|in_room_tablet|social_media — promote to reference product]' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCsatEligible rdf:type rdf:Property ;
    rdfs:label 'Is Csat Eligible' ;
    rdfs:comment 'Indicates whether this touchpoint is eligible for Customer Satisfaction (CSAT) survey measurement.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGssEligible rdf:type rdf:Property ;
    rdfs:label 'Is Gss Eligible' ;
    rdfs:comment 'Indicates whether this touchpoint is eligible for Guest Satisfaction Score (GSS) measurement.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryTouchpoint rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Touchpoint' ;
    rdfs:comment 'Indicates whether this touchpoint is mandatory for all guests (e.g., check-in, check-out) or optional.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNpsEligible rdf:type rdf:Property ;
    rdfs:label 'Is Nps Eligible' ;
    rdfs:comment 'Indicates whether this touchpoint is eligible for Net Promoter Score (NPS) survey measurement.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journeyStage rdf:type rdf:Property ;
    rdfs:label 'Journey Stage' ;
    rdfs:comment 'The stage of the guest journey lifecycle where this touchpoint occurs (pre-arrival, arrival, in-stay, departure, post-stay).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medalliaTouchpointCode rdf:type rdf:Property ;
    rdfs:label 'Medallia Touchpoint Code' ;
    rdfs:comment 'The corresponding touchpoint identifier in the Medallia experience analytics platform for integration and feedback mapping.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiLanguageSupportedFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Language Supported Flag' ;
    rdfs:comment 'Indicates whether this touchpoint supports multiple languages for international guests.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceTouchpointCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Touchpoint Code' ;
    rdfs:comment 'The corresponding touchpoint identifier in Salesforce Customer Relationship Management (CRM) for case management and guest interaction tracking.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'The typical sequence order of this touchpoint within its journey stage, used for journey mapping and visualization.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceRecoveryTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Service Recovery Trigger Flag' ;
    rdfs:comment 'Indicates whether negative feedback or issues at this touchpoint automatically trigger service recovery workflows.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staffTrainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Staff Training Required Flag' ;
    rdfs:comment 'Indicates whether staff training is required to deliver this touchpoint effectively.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:touchpointCategory rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Category' ;
    rdfs:comment 'The category or modality of the touchpoint (digital, physical, voice, self-service, staff-assisted, automated).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointCode rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Code' ;
    rdfs:comment 'Unique business code identifying the touchpoint type (e.g., PRE_ARRIVAL_EMAIL, CHECK_IN_DESK, IN_ROOM_DINING, CHECKOUT_KIOSK).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointDescription rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Description' ;
    rdfs:comment 'Detailed description of the touchpoint, its purpose, and the guest interaction it represents.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointName rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Name' ;
    rdfs:comment 'Human-readable name of the touchpoint (e.g., Pre-Arrival Welcome Email, Front Desk Check-In, In-Room Dining Order).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointStatus rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Status' ;
    rdfs:comment 'Current operational status of the touchpoint (active, inactive, pilot, deprecated, seasonal).' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Typical Duration Minutes' ;
    rdfs:comment 'The typical or expected duration of the guest interaction at this touchpoint, measured in minutes.' ;
    rdfs:domain ind:Touchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:franchiseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Id' ;
    rdfs:comment 'Foreign key linking to property.franchise_agreement. Business justification: Franchise fee invoices (royalty, marketing, reservation fees) reference specific franchise agreements for rate validation and compliance tracking. Real AP processing verifies fees against agreement te' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FranchiseAgreement .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: Three-way match validation requires direct link from invoice to goods receipt for quantity/quality verification, critical for F&B perishables and FF&E capital purchases before payment processing.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Reference to the purchase order number that authorized this procurement. May be null for non-PO invoices.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:revenueCenterId rdf:type rdf:Property ;
    rdfs:label 'Revenue Center Id' ;
    rdfs:comment 'Foreign key linking to fnb.revenue_center. Business justification: Outlet-specific AP invoices (supplies, equipment, services) must allocate to revenue centers for departmental P&L accuracy. Enables USALI-compliant expense allocation, supports outlet-level profitabil' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueCenter .

ind:apInvoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Description' ;
    rdfs:comment 'Free-text description of the goods or services covered by this invoice. Provides business context for the procurement.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Early payment discount or negotiated discount amount applied to the invoice.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'Classification of the expense type. OpEx (Operating Expenditure) for recurring costs, CapEx (Capital Expenditure) for long-term assets, FF&E (Furniture Fixtures and Equipment) for property improvements.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month) within the fiscal year to which this invoice is assigned.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this invoice is assigned for financial reporting purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total invoice amount before taxes and adjustments. Base amount for goods or services procured.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice type. Standard invoices represent normal purchases; credit memos represent vendor credits or returns.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Flag indicating whether this is a recurring invoice (e.g., monthly utilities, annual subscriptions). True if recurring, False otherwise.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The final payable amount after applying taxes, discounts, and adjustments. This is the amount due to the vendor.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'The remaining unpaid balance on the invoice. Calculated as net_amount minus paid_amount.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'The total amount paid against this invoice to date. May be partial or full payment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The reference number or transaction ID for the payment made against this invoice (e.g., check number, ACH trace number).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The date the invoice was received by the property or corporate AP department.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match validation (PO, goods receipt, invoice). Ensures invoice accuracy and prevents duplicate payments.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Tax Number' ;
    rdfs:comment 'The tax identification number (TIN, EIN, VAT number) of the vendor. Required for 1099 reporting and tax compliance.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts payable payment transaction. Primary key.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApPayment .

ind:originalPaymentApPaymentId rdf:type rdf:Property ;
    rdfs:label 'Original Payment Ap Payment Id' ;
    rdfs:comment 'Reference to the original payment transaction if this is a reversal or correction payment.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApPayment .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Identifier for the batch payment run that generated this payment, used for grouping payments processed together.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:primaryApBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Ap Bank Account Id' ;
    rdfs:comment 'Reference to the company bank account from which this payment was disbursed.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:bankFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Bank Fee Amount' ;
    rdfs:comment 'Transaction fees charged by the bank or payment processor for executing this payment.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'Payment amount converted to the company base currency using the exchange rate for consolidated reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 code for the company base currency used for financial reporting and consolidation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Physical check number when payment method is check, used for reconciliation and audit trail.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which the payment cleared the bank and was confirmed as successfully processed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Foreign exchange rate applied when payment currency differs from the company base currency or invoice currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The accounting period date when this payment transaction was posted to the general ledger.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The final net amount disbursed to the vendor after all discounts, withholdings, and fees are applied.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The gross amount disbursed to the vendor in the payment currency before any adjustments or fees.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the payment transaction (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'Free-text description or memo providing additional context about the payment purpose or details.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Externally-known unique payment document number assigned by the payment system or payment run.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment transaction indicating its purpose or nature within the AP lifecycle.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this payment has been reversed or cancelled after initial processing.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The date on which the payment amount is debited from the company bank account and becomes effective for cash flow purposes.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Tax amount withheld from the payment as required by tax regulations, reducing the net amount paid to vendor.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Categorization of invoice age for accounts receivable aging reports and collection workflow assignment.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Ancillary Revenue Amount' ;
    rdfs:comment 'Total ancillary service charges including spa, parking, resort fees, minibar, laundry, and other guest services.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingEntityName rdf:type rdf:Property ;
    rdfs:label 'Billing Entity Name' ;
    rdfs:comment 'Legal name of the entity being billed (guest, company, agency, or OTA partner).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingEntityType rdf:type rdf:Property ;
    rdfs:label 'Billing Entity Type' ;
    rdfs:comment 'Type of entity being billed. Used for segmentation and credit policy application. [ENUM-REF-CANDIDATE: individual|corporate|travel_agency|ota|group|government|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current status of collection efforts for overdue invoices.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Outstanding' ;
    rdfs:comment 'Number of days since invoice date. Used for aging analysis and collection prioritization.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether this invoice is currently under dispute by the billing entity.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Event Revenue Amount' ;
    rdfs:comment 'Total event and meeting charges including space rental, audio-visual, and catering for Meetings, Incentives, Conferences, and Exhibitions (MICE).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fnbRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Fnb Revenue Amount' ;
    rdfs:comment 'Total food and beverage charges on this invoice from restaurants, bars, room service, and banquets.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:folioNumber rdf:type rdf:Property ;
    rdfs:label 'Folio Number' ;
    rdfs:comment 'The externally-known unique folio number assigned to this invoice in the Property Management System (PMS). Used for guest and accounting reference.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date revenue was recognized for this invoice per GAAP/IFRS revenue recognition standards (ASC 606 / IFRS 15).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'The last date of service covered by this invoice (e.g., check-out date for room charges).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'The first date of service covered by this invoice (e.g., check-in date for room charges).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date the invoice was written off if write_off_flag is true.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'Indicates whether this invoice has been written off as uncollectible bad debt.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffReason rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason' ;
    rdfs:comment 'Business justification for writing off this invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ar Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable payment transaction. Primary key.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArPayment .

ind:reversedPaymentArPaymentId rdf:type rdf:Property ;
    rdfs:label 'Reversed Payment Ar Payment Id' ;
    rdfs:comment 'Reference to the original payment that this payment reverses. Creates audit trail for payment corrections and chargebacks.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArPayment .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the payment amount that has been applied to specific AR invoices. May differ from payment amount if payment is partially applied or unapplied.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization code provided by payment processor or card issuer confirming approval of the payment transaction. Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'The name of the bank or financial institution for check, wire transfer, or ACH payments. Used for reconciliation and tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardLastFour rdf:type rdf:Property ;
    rdfs:label 'Card Last Four' ;
    rdfs:comment 'The last four digits of the payment card number. Used for payment identification while maintaining PCI DSS compliance.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'The credit or debit card brand used for the payment. Applicable only for card-based payment methods. [ENUM-REF-CANDIDATE: visa|mastercard|amex|discover|jcb|diners|unionpay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'The name of the cardholder as it appears on the payment card. Used for verification and reconciliation purposes.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'The date on which the payment was deposited to the property bank account. Used for cash flow tracking and bank reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAdvanceDeposit rdf:type rdf:Property ;
    rdfs:label 'Is Advance Deposit' ;
    rdfs:comment 'Boolean flag indicating whether this payment is an advance deposit received prior to guest arrival or service delivery. Used for revenue recognition timing.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefund rdf:type rdf:Property ;
    rdfs:label 'Is Refund' ;
    rdfs:comment 'Boolean flag indicating whether this payment represents a refund to the guest or customer. True if refund, False if collection.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'The interface or touchpoint through which the payment was received. Includes front desk, online portal, mobile app, call center, self-service kiosk, or mail.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments about the payment transaction. Used to capture special instructions, exceptions, or additional context.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'The precise date and time when the payment transaction was recorded in the system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the payment processor settled funds to the property account. Used for reconciliation with processor settlement reports.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Reference to the cashier shift during which the payment was processed. Used for shift reconciliation and cash drawer balancing.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionFee rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee' ;
    rdfs:comment 'Processing fee charged by payment processor or financial institution for the transaction. Includes credit card merchant fees, wire transfer fees, etc.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment processor or gateway. Used for tracking and reconciliation with processor settlement reports.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount that has not yet been applied to specific AR invoices. Represents credit on account or overpayment.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Unique identifier for the bank account record. Primary key.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:masterAccountBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Master Account Bank Account Id' ;
    rdfs:comment 'Reference to the master bank account for zero balance account (ZBA) cash pooling arrangements. Null if this is not a ZBA or if this is the master account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountClosedDate rdf:type rdf:Property ;
    rdfs:label 'Account Closed Date' ;
    rdfs:comment 'The date the bank account was closed, if applicable. Null for active accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Account Number Masked' ;
    rdfs:comment 'Partially masked account number for display purposes (e.g., ****1234). Used in reports and user interfaces to protect sensitive data.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Account Opened Date' ;
    rdfs:comment 'The date the bank account was originally opened with the financial institution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'Description of the primary business purpose or use case for this bank account (e.g., AP disbursements, AR collections, payroll funding, property operating account).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achEnabled rdf:type rdf:Property ;
    rdfs:label 'Ach Enabled' ;
    rdfs:comment 'Indicates whether ACH transactions (direct deposits, electronic payments) are enabled for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'The available balance for disbursements, net of holds, pending transactions, and minimum balance requirements.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'The name of the specific bank branch where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCode rdf:type rdf:Property ;
    rdfs:label 'Bank Code' ;
    rdfs:comment 'Unique identifier or code for the bank, often used in internal systems or for integration with treasury management systems.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactEmail rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Email' ;
    rdfs:comment 'The email address of the primary bank contact. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactName rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Name' ;
    rdfs:comment 'The name of the primary contact person at the bank for account inquiries and issue resolution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactPhone rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Phone' ;
    rdfs:comment 'The phone number of the primary bank contact. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The SAP company code or equivalent organizational unit to which this bank account is assigned. Used for financial consolidation and reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'The current balance of the bank account as of the last update or reconciliation. Reflects all posted transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electronicBankingEnabled rdf:type rdf:Property ;
    rdfs:label 'Electronic Banking Enabled' ;
    rdfs:comment 'Indicates whether electronic banking services (ACH, wire transfers, electronic statements) are enabled for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'The International Bank Account Number for accounts in jurisdictions that use IBAN for international transactions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestBearing rdf:type rdf:Property ;
    rdfs:label 'Interest Bearing' ;
    rdfs:comment 'Indicates whether this account earns interest on deposited funds.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The annual interest rate applied to the account balance, expressed as a decimal (e.g., 0.0250 for 2.50%). Null for non-interest-bearing accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryAccount rdf:type rdf:Property ;
    rdfs:label 'Is Primary Account' ;
    rdfs:comment 'Indicates whether this is the primary operating bank account for the property or company code. Used for default account selection in AP and AR processes.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isZeroBalanceAccount rdf:type rdf:Property ;
    rdfs:label 'Is Zero Balance Account' ;
    rdfs:comment 'Indicates whether this is a zero balance account that automatically sweeps funds to or from a master account for cash concentration.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date of the most recent bank reconciliation for this account. Critical for SOX compliance and financial controls.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementBalance rdf:type rdf:Property ;
    rdfs:label 'Last Statement Balance' ;
    rdfs:comment 'The ending balance reported on the most recent bank statement. Used as the baseline for reconciliation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'The date of the most recent bank statement received for this account. Used for reconciliation and cash flow tracking.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Required' ;
    rdfs:comment 'The minimum balance that must be maintained in the account per bank agreement or internal treasury policy.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The opening balance of the bank account at the start of the current fiscal period or reconciliation cycle.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positivePayEnabled rdf:type rdf:Property ;
    rdfs:label 'Positive Pay Enabled' ;
    rdfs:comment 'Indicates whether positive pay fraud prevention service is enabled. Positive pay matches issued checks against a list to prevent fraudulent checks from clearing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current status of the bank reconciliation process. Tracks whether the account has been reconciled, has discrepancies, or is pending review.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The ABA routing number (US) or equivalent bank routing code used for electronic funds transfers and wire transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'The SWIFT/BIC code for international wire transfers. Used for cross-border payments and multi-currency transactions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireTransferEnabled rdf:type rdf:Property ;
    rdfs:label 'Wire Transfer Enabled' ;
    rdfs:comment 'Indicates whether domestic and international wire transfers are enabled for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique identifier for the budget line item. Primary key.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to procurement.procurement_category. Business justification: Budget planning allocates spend by procurement category (F&B, housekeeping, maintenance, FF&E) for CPOR tracking, category-level variance analysis, and strategic sourcing decisions in hospitality oper' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Reference to the parent budget header to which this line item belongs.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBudget .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Labor budget lines must tie to specific positions for headcount planning, position control, and budget-to-actual variance analysis - enables finance to track budgeted vs actual headcount by position a' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:allocationDriver rdf:type rdf:Property ;
    rdfs:label 'Allocation Driver' ;
    rdfs:comment 'The driver or basis used for allocation if allocation_method is driver-based. Examples include room nights, square footage, headcount, or revenue percentage.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The method used to allocate this budget line to the cost center or profit center. Supports transparency in budget allocation logic.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level classification of the budget line. Distinguishes between revenue, operating expenses, fixed expenses, and capital expenditures per USALI standards.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetOwner rdf:type rdf:Property ;
    rdfs:label 'Budget Owner' ;
    rdfs:comment 'The name or identifier of the individual or role responsible for this budget line. Supports accountability and budget governance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'The type of budget this line belongs to. Supports multiple budget scenarios for planning and variance analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'The version identifier for this budget line. Supports multiple budget scenarios such as original budget, revised budget, forecast, or rolling forecast.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line item number within the parent budget. Used for ordering and referencing individual budget lines.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lockedFlag rdf:type rdf:Property ;
    rdfs:label 'Locked Flag' ;
    rdfs:comment 'Indicates whether this budget line is locked from further edits. True if locked, False if editable. Supports budget freeze and SOX controls.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'The budgeted monetary amount for this GL account, cost center, profit center, and fiscal period combination. Represents the planned expense or revenue target.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearActualAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Year Actual Amount' ;
    rdfs:comment 'The actual amount from the prior fiscal year for the same GL account, cost center, and fiscal period. Used for year-over-year budget comparison and trend analysis.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percent' ;
    rdfs:comment 'The acceptable variance threshold percentage for this budget line. Used to flag significant budget-vs-actual variances for management review.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Reference to a parent cost center in a hierarchical cost center structure, enabling roll-up reporting and consolidated P&L views. Null if this is a top-level cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'The total annual budgeted amount allocated to this cost center for the current fiscal year, used for variance analysis and financial control.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditTrailRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required Flag' ;
    rdfs:comment 'Indicates whether all financial transactions posted to this cost center must maintain a full audit trail for compliance and internal control purposes (True) or standard logging is sufficient (False).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Flag' ;
    rdfs:comment 'Indicates whether this cost center has a dedicated budget allocation and is subject to budget control and variance reporting (True) or operates without a formal budget (False).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'The SAP controlling area under which this cost center is managed, representing the organizational unit for internal cost accounting and management reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used to allocate shared costs or overhead to this cost center: direct assignment, activity-based costing, percentage allocation, headcount-based, or square footage-based.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed description of the cost center\'s purpose, scope, and operational responsibilities.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full business name of the cost center (e.g., Rooms Division, Food and Beverage, Spa Operations, Administration).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center: active (operational and accepting postings), inactive (temporarily not in use), suspended (blocked for new postings), or closed (permanently retired).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by its primary function: revenue-generating departments, support services, administrative functions, or overhead allocation centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCategory rdf:type rdf:Property ;
    rdfs:label 'Department Category' ;
    rdfs:comment 'High-level USALI category: Operated Departments (revenue-generating), Undistributed Operating Expenses (support), or Fixed Charges (property-level overhead).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReportingFlag rdf:type rdf:Property ;
    rdfs:label 'External Reporting Flag' ;
    rdfs:comment 'Indicates whether this cost center\'s financial results are included in external financial statements and regulatory filings (True) or used only for internal management reporting (False).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headcountAllocation rdf:type rdf:Property ;
    rdfs:label 'Headcount Allocation' ;
    rdfs:comment 'The number of full-time equivalent (FTE) employees allocated to this cost center, used for labor cost analysis and productivity metrics.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'The depth of this cost center in the organizational hierarchy (1=top-level, 2=sub-department, etc.), used for roll-up aggregation and reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborCostTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Tracking Flag' ;
    rdfs:comment 'Indicates whether labor costs (payroll, benefits, overtime) are tracked and allocated to this cost center (True) or excluded from labor cost analysis (False).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The profit center code to which this cost center\'s expenses and revenues are allocated for segment reporting and profitability analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenuePostingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether revenue transactions can be posted to this cost center (True for revenue-generating departments) or only expense postings are allowed (False for support/administrative centers).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Indicates whether this cost center is subject to SOX financial controls and audit requirements (True for publicly traded entities) or exempt (False).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usaliDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Usali Department Code' ;
    rdfs:comment 'The standard USALI departmental code aligning this cost center to the industry-standard chart of accounts for lodging P&L reporting (e.g., 10=Rooms, 20=Food, 30=Beverage, 40=Other Operated Departments, 50=Administrative & General).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Descriptive name of the budget (e.g., \'FY2024 Annual Operating Budget\', \'Q2 2024 Reforecast\').' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known unique identifier for this budget document. Used for reference in management reports and approvals.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget: draft (in preparation), submitted (awaiting approval), under review (being evaluated), approved (finalized), active (in use), closed (period ended), or superseded (replaced by newer version). [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|active|closed|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedAdr rdf:type rdf:Property ;
    rdfs:label 'Budgeted Adr' ;
    rdfs:comment 'Forecasted Average Daily Rate for the budget period. Calculated as rooms revenue divided by rooms sold. Key rooms division KPI.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedAvailableRooms rdf:type rdf:Property ;
    rdfs:label 'Budgeted Available Rooms' ;
    rdfs:comment 'Forecasted total number of room nights available for sale during the budget period. Accounts for planned renovations and out-of-order rooms.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedCovers rdf:type rdf:Property ;
    rdfs:label 'Budgeted Covers' ;
    rdfs:comment 'Forecasted total number of F&B covers (guests served) for the budget period. Key volume metric for food and beverage operations.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedCpor rdf:type rdf:Property ;
    rdfs:label 'Budgeted Cpor' ;
    rdfs:comment 'Forecasted Cost Per Occupied Room for the budget period. Calculated as total departmental expenses divided by rooms sold. Measures cost efficiency.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedEbitda rdf:type rdf:Property ;
    rdfs:label 'Budgeted Ebitda' ;
    rdfs:comment 'Forecasted EBITDA for the budget period. Represents operating profitability before financing and non-cash charges.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedEventsRevenue rdf:type rdf:Property ;
    rdfs:label 'Budgeted Events Revenue' ;
    rdfs:comment 'Forecasted total events and meetings revenue for the budget period. Includes MICE (Meetings, Incentives, Conferences, Exhibitions) revenue.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedFnbRevenue rdf:type rdf:Property ;
    rdfs:label 'Budgeted Fnb Revenue' ;
    rdfs:comment 'Forecasted total food and beverage revenue for the budget period. Includes restaurant, bar, banquet, and room service revenue.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedGop rdf:type rdf:Property ;
    rdfs:label 'Budgeted Gop' ;
    rdfs:comment 'Forecasted Gross Operating Profit for the budget period. Calculated as total revenue minus departmental expenses and undistributed operating expenses. Key profitability metric per USALI.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedGoppar rdf:type rdf:Property ;
    rdfs:label 'Budgeted Goppar' ;
    rdfs:comment 'Forecasted Gross Operating Profit Per Available Room for the budget period. Calculated as GOP divided by available rooms. Measures profitability efficiency.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedLaborExpense rdf:type rdf:Property ;
    rdfs:label 'Budgeted Labor Expense' ;
    rdfs:comment 'Forecasted total labor costs including wages, salaries, benefits, and payroll taxes for the budget period.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedNoi rdf:type rdf:Property ;
    rdfs:label 'Budgeted Noi' ;
    rdfs:comment 'Forecasted Net Operating Income for the budget period. Represents property-level profitability after all operating expenses but before debt service and taxes.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedOccupancyRate rdf:type rdf:Property ;
    rdfs:label 'Budgeted Occupancy Rate' ;
    rdfs:comment 'Forecasted occupancy rate as a percentage for the budget period. Calculated as rooms sold divided by rooms available. Key demand metric.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedOperatingExpense rdf:type rdf:Property ;
    rdfs:label 'Budgeted Operating Expense' ;
    rdfs:comment 'Forecasted total operating expenses excluding labor for the budget period. Includes utilities, supplies, maintenance, and other departmental expenses.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedOtherRevenue rdf:type rdf:Property ;
    rdfs:label 'Budgeted Other Revenue' ;
    rdfs:comment 'Forecasted revenue from other sources (spa, parking, telecommunications, etc.) for the budget period.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedRevpar rdf:type rdf:Property ;
    rdfs:label 'Budgeted Revpar' ;
    rdfs:comment 'Forecasted Revenue Per Available Room for the budget period. Calculated as rooms revenue divided by available rooms, or ADR multiplied by occupancy rate. Primary revenue performance metric.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedRoomNights rdf:type rdf:Property ;
    rdfs:label 'Budgeted Room Nights' ;
    rdfs:comment 'Forecasted total number of room nights sold for the budget period. Key volume metric for rooms division.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedRoomsRevenue rdf:type rdf:Property ;
    rdfs:label 'Budgeted Rooms Revenue' ;
    rdfs:comment 'Forecasted total rooms revenue for the budget period. Key metric for rooms division performance planning.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedTotalRevenue rdf:type rdf:Property ;
    rdfs:label 'Budgeted Total Revenue' ;
    rdfs:comment 'Forecasted total revenue across all departments for the budget period. Sum of rooms, F&B, events, and other revenue.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedTrevpar rdf:type rdf:Property ;
    rdfs:label 'Budgeted Trevpar' ;
    rdfs:comment 'Forecasted Total Revenue Per Available Room for the budget period. Calculated as total property revenue divided by available rooms. Measures total revenue productivity.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexRequestId rdf:type rdf:Property ;
    rdfs:label 'Capex Request Id' ;
    rdfs:comment 'Reference to the original CapEx request or approval that authorized the acquisition of this fixed asset.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexRequest .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized to date since the asset was placed in service.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total capitalized cost of acquiring the fixed asset, including purchase price, installation, and directly attributable costs.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the fixed asset was acquired or placed into service for accounting purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'Detailed sub-classification or category within the asset class for granular reporting and analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Classification of the fixed asset type. FF&E refers to Furniture, Fixtures, and Equipment. [ENUM-REF-CANDIDATE: building|ffe|technology_system|leasehold_improvement|land|vehicle|equipment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or description of the fixed asset.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique asset tag or identification number assigned to the fixed asset for tracking and inventory purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset indicating its operational state and accounting treatment. [ENUM-REF-CANDIDATE: active|in_service|under_construction|retired|disposed|impaired|held_for_sale — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Capex Approval Status' ;
    rdfs:comment 'Approval status of the CapEx request associated with this fixed asset acquisition.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to calculate depreciation expense for this fixed asset.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationStartDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Start Date' ;
    rdfs:comment 'Date when depreciation calculation begins for this fixed asset, typically the in-service date.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the fixed asset was disposed of, sold, retired, or otherwise removed from service.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method by which the fixed asset was disposed of or removed from the asset register.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Amount received from the sale or disposal of the fixed asset.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ffeReserveEligible rdf:type rdf:Property ;
    rdfs:label 'Ffe Reserve Eligible' ;
    rdfs:comment 'Indicates whether this asset is eligible for FF&E reserve funding, typically used for planned replacement programs.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gainLossOnDisposal rdf:type rdf:Property ;
    rdfs:label 'Gain Loss On Disposal' ;
    rdfs:comment 'Calculated gain or loss on disposal, computed as disposal proceeds minus net book value at disposal date.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator' ;
    rdfs:comment 'Flag indicating whether the asset has been tested for impairment or shows indicators of impairment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'Amount of impairment loss recognized when the recoverable amount of the asset is less than its carrying value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Insurance policy number covering this fixed asset, if separately insured.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent maintenance or service performed on the fixed asset.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Physical location or room number where the fixed asset is installed or stored within the property.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the manufacturer or brand of the fixed asset.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Model number or product code of the fixed asset as designated by the manufacturer.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the fixed asset calculated as acquisition cost minus accumulated depreciation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipReference rdf:type rdf:Property ;
    rdfs:label 'Pip Reference' ;
    rdfs:comment 'Reference to the Property Improvement Plan under which this asset was acquired or renovated, if applicable.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life, not subject to depreciation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer serial number or unique identifier for the physical asset, if applicable.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the fixed asset in years for depreciation calculation purposes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty for this fixed asset expires.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationRunId rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Id' ;
    rdfs:comment 'Identifier of the cost allocation or expense distribution run that generated this journal entry, if applicable. Null for non-allocation entries. Used to track automated allocation postings.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRun .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Foreign key linking to workforce.payroll_run. Business justification: Payroll journal entries must reference the source payroll run for audit trail, GL-to-payroll reconciliation, and SOX compliance - enables auditors to trace GL postings back to source payroll calculati' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:primaryJournalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Employee Id' ;
    rdfs:comment 'User ID or employee identifier of the person who created this journal entry in the system. Part of the SOX-compliant audit trail.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryJournalLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Journal Last Modified By User Employee Id' ;
    rdfs:comment 'User ID or employee identifier of the person who last modified this journal entry record. Part of the change tracking audit trail.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recurringEntryTemplateId rdf:type rdf:Property ;
    rdfs:label 'Recurring Entry Template Id' ;
    rdfs:comment 'Identifier of the recurring journal entry template from which this entry was generated, if applicable. Null for non-recurring entries. Used to track automated periodic postings.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecurringEntryTemplate .

ind:tertiaryJournalPostedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Journal Posted By User Employee Id' ;
    rdfs:comment 'User ID or employee identifier of the person who executed the final posting of this journal entry to the general ledger. Null if not yet posted. Part of SOX segregation of duties controls.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Additional audit trail notes or comments added by approvers, auditors, or system administrators for compliance and review purposes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexIndicator rdf:type rdf:Property ;
    rdfs:label 'Capex Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry relates to capital expenditure (CapEx) or furniture, fixtures, and equipment (FF&E) investments. True for CapEx/FF&E entries, False for operating expenditure (OpEx).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The total credit amount for this journal entry in the functional currency. Must balance with debit amount per double-entry accounting principles.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'The total debit amount for this journal entry in the functional currency. Must balance with credit amount per double-entry accounting principles.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Externally-known unique document number assigned to this journal entry for reference and audit trail purposes. Typically follows format JE followed by numeric sequence.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the journal entry by its business purpose: standard (regular postings), allocation (cost distribution), intercompany (cross-entity transactions), recurring (template-based periodic entries), accrual (period-end adjustments), reversal (correction entries).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code representing the functional currency in which this journal entry is recorded (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry represents an intercompany transaction between legal entities within the enterprise. True for intercompany entries requiring elimination in consolidated reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Intercompany Partner Code' ;
    rdfs:comment 'The company code of the intercompany partner entity for intercompany transactions. Used for intercompany reconciliation and elimination entries in consolidated financial statements.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Description' ;
    rdfs:comment 'Free-text narrative description of the business purpose and nature of this journal entry. Provides context for auditors and financial analysts.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'System timestamp when this journal entry was posted to the general ledger. Null if not yet posted. This is the system processing time, distinct from the posting_date which is the accounting date.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle state of the journal entry in the approval and posting workflow. Tracks progression from draft creation through approval to final posting in the general ledger.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceText rdf:type rdf:Property ;
    rdfs:label 'Reference Text' ;
    rdfs:comment 'Additional reference information or notes related to this journal entry, such as supporting documentation references, approval notes, or special instructions.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a previous entry. True if this is a reversal entry, False otherwise.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is True.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference number or identifier of the originating source transaction document (e.g., invoice number, payment document, POS check number) that triggered this journal entry.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax code or tax jurisdiction code applicable to this journal entry, if the entry involves tax-related postings (sales tax, VAT, occupancy tax, etc.).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code of the original transaction currency if different from functional currency. Used for foreign exchange tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for granular financial transaction analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'Line item amount converted to the corporate group reporting currency. Used for consolidated financial statements and EBITDA reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'Line item amount converted to the property or entity local currency. Used for property-level P&L and GOP calculation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'Line item amount in the original transaction currency. Supports multi-currency operations for international properties.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Assignment field for additional sorting and grouping. Used for payment clearing, reconciliation, and sub-ledger matching.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselinePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Payment Date' ;
    rdfs:comment 'Baseline date for payment terms calculation. Used for AP aging and cash flow forecasting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'Business area classification for segment reporting. Used for brand, region, or business unit financial consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'Document number that cleared this open item. Used for payment reconciliation and AR/AP management.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCode rdf:type rdf:Property ;
    rdfs:label 'Customer Code' ;
    rdfs:comment 'Customer or guest account code for AR line items. Links GL entry to customer master for receivables management.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether this line is a debit (D) or credit (C) entry. Fundamental to double-entry bookkeeping and GL balancing.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area classification for cost-of-sales and functional expense reporting per USALI standards.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the group reporting currency. Used for consolidated financial reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-text description of the line item. Provides business context for the transaction for audit and analysis purposes.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Payment terms code for AP/AR line items. Determines due date calculation and discount eligibility.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'SAP posting key that controls the account type and debit/credit behavior. Standard SAP GL posting control mechanism.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Project or work breakdown structure (WBS) element for capital projects, renovations, or PIP (Property Improvement Plan) tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyCode rdf:type rdf:Property ;
    rdfs:label 'Property Code' ;
    rdfs:comment 'Property identifier for multi-property financial consolidation. Enables property-level P&L, GOP, and NOI reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference document number (invoice, receipt, PO). Links GL entry to source operational transaction.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Segment code for IFRS segment reporting. Supports brand, geography, or service-line financial disclosure.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Trading partner or intercompany entity code. Enables intercompany elimination and consolidation for multi-entity groups.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'The USALI-defined category grouping for the account (e.g., Rooms, Food and Beverage, Other Operated Departments, Administrative and General, Sales and Marketing, Property Operations and Maintenance, Utilities, Fixed Charges). Used for departmental P&L reporting and GOP calculation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSubcategory rdf:type rdf:Property ;
    rdfs:label 'Account Subcategory' ;
    rdfs:comment 'The detailed subcategory within the USALI account category (e.g., within Food and Beverage: Restaurant Revenue, Banquet Revenue, Room Service Revenue; within Rooms: Payroll and Related, Guest Supplies, Laundry and Linen). Enables granular financial analysis.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether detailed audit trail documentation is required for all transactions posted to this account. Used for high-risk accounts, regulatory compliance, and forensic accounting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceSheetSection rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Section' ;
    rdfs:comment 'The section of the balance sheet where this account appears (current assets, non-current assets, current liabilities, non-current liabilities, equity). Determines liquidity classification and working capital calculation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashFlowClassification rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Classification' ;
    rdfs:comment 'The cash flow statement category for this account: operating activities, investing activities, or financing activities. Used for automated cash flow statement preparation per GAAP/IFRS.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account' ;
    rdfs:comment 'The account number used for consolidation at the corporate or regional level. Maps property-level accounts to standardized corporate chart of accounts for multi-property financial consolidation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'The functional area classification for financial statement presentation (e.g., Operating Revenue, Cost of Sales, Operating Expenses, Fixed Charges). Used for USALI-compliant income statement formatting and GOP calculation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeStatementSection rdf:type rdf:Property ;
    rdfs:label 'Income Statement Section' ;
    rdfs:comment 'The section of the income statement where this account appears per USALI format (e.g., Operated Departments Revenue, Operated Departments Expenses, Undistributed Operating Expenses, Fixed Charges). Supports GOP, EBITDA, and NOI calculation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the ledger account is currently active and available for transaction posting. Inactive accounts are retained for historical reporting but cannot accept new transactions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isControlAccount rdf:type rdf:Property ;
    rdfs:label 'Is Control Account' ;
    rdfs:comment 'Indicates whether this is a control account (summary account) that aggregates balances from subsidiary ledgers (e.g., Accounts Receivable control account summarizing individual guest folios). Control accounts do not accept direct postings.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this account is used for intercompany transactions between properties or legal entities within the hospitality group. Intercompany accounts are eliminated during consolidated financial statement preparation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciliationRequired rdf:type rdf:Property ;
    rdfs:label 'Is Reconciliation Required' ;
    rdfs:comment 'Indicates whether this account requires periodic reconciliation (e.g., bank accounts, accounts receivable, inventory accounts). Used for internal control and SOX compliance.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this is a statistical account used for non-monetary metrics (e.g., room nights sold, covers served, occupied room count). Statistical accounts support KPI calculation (ADR, RevPAR, GOPPAR) but do not carry monetary balances.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPostingDate rdf:type rdf:Property ;
    rdfs:label 'Last Posting Date' ;
    rdfs:comment 'The date of the most recent transaction posted to this account. Used for dormant account identification and account usage analysis.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ledgerDescription rdf:type rdf:Property ;
    rdfs:label 'Ledger Description' ;
    rdfs:comment 'Extended description of the ledger account purpose, usage guidelines, and posting rules. Provides additional context beyond the account name for accounting staff and auditors.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalBalance rdf:type rdf:Property ;
    rdfs:label 'Normal Balance' ;
    rdfs:comment 'Indicates whether the account normally carries a debit or credit balance. Assets and expenses have debit normal balances; liabilities, equity, and revenue have credit normal balances. Used for transaction validation and financial statement preparation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Block Flag' ;
    rdfs:comment 'Indicates whether direct posting to this account is blocked. Posting blocks are used for control accounts, summary accounts, or accounts under investigation. Transactions must be posted to subsidiary accounts instead.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The tax category or tax line item code associated with this account for tax reporting purposes (e.g., taxable revenue, non-taxable revenue, deductible expense, non-deductible expense). Supports automated tax return preparation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementFeeId rdf:type rdf:Property ;
    rdfs:label 'Management Fee Id' ;
    rdfs:comment 'Unique identifier for the management fee calculation record. Primary key. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:ManagementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hmaContractId rdf:type rdf:Property ;
    rdfs:label 'Hma Contract Id' ;
    rdfs:comment 'Reference to the Hotel Management Agreement contract that governs the terms and conditions of this management fee.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HmaContract .

ind:ownershipEntityId rdf:type rdf:Property ;
    rdfs:label 'Ownership Entity Id' ;
    rdfs:comment 'Reference to the property owner entity that is being charged the management fee under the Hotel Management Agreement (HMA).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OwnershipEntity .

ind:reversedFeeManagementFeeId rdf:type rdf:Property ;
    rdfs:label 'Reversed Fee Management Fee Id' ;
    rdfs:comment 'Reference to the original management fee record that this entry reverses, if applicable.' ;
    rdfs:domain ind:ManagementFee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagementFee .

ind:basisAmount rdf:type rdf:Property ;
    rdfs:label 'Basis Amount' ;
    rdfs:comment 'The actual financial amount (gross revenue, GOP, NOI, etc.) used as the calculation basis for this management fee, in the property\'s functional currency.' ;
    rdfs:domain ind:ManagementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'The financial metric used as the basis for calculating the management fee amount, as defined in the Hotel Management Agreement (HMA). [ENUM-REF-CANDIDATE: gross_revenue|total_revenue|rooms_revenue|gop|noi|ebitda|adjusted_gop|custom — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'Date when the management fee was calculated, representing the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeNumber rdf:type rdf:Property ;
    rdfs:label 'Fee Number' ;
    rdfs:comment 'Externally-known unique identifier or document number for this management fee calculation, used for owner reporting and audit trail.' ;
    rdfs:domain ind:ManagementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fee Rate Percentage' ;
    rdfs:comment 'The percentage rate applied to the calculation basis to determine the management fee amount, as specified in the Hotel Management Agreement (HMA).' ;
    rdfs:domain ind:ManagementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Fee Amount' ;
    rdfs:comment 'Final net management fee amount after all adjustments, representing the amount due to the management company.' ;
    rdfs:domain ind:ManagementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the performance period covered by this management fee calculation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the performance period covered by this management fee calculation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerDistributionId rdf:type rdf:Property ;
    rdfs:label 'Owner Distribution Id' ;
    rdfs:comment 'Unique identifier for the owner distribution record. Primary key for this entity representing a single periodic distribution calculation and payment event under a Hotel Management Agreement (HMA).' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseManagementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Management Fee Amount' ;
    rdfs:comment 'Base management fee charged by the hotel operator, typically calculated as a percentage of gross revenue per the Hotel Management Agreement. First deduction in the waterfall.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debtServiceAmount rdf:type rdf:Property ;
    rdfs:label 'Debt Service Amount' ;
    rdfs:comment 'Principal and interest payments on property-level debt obligations deducted from the distribution waterfall. Includes mortgage payments, construction loans, and other secured financing.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionAmount rdf:type rdf:Property ;
    rdfs:label 'Distribution Amount' ;
    rdfs:comment 'Final net amount distributed to the owner entity after all waterfall deductions. This is the actual payment remitted to the ownership entity.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Number' ;
    rdfs:comment 'Business identifier for this owner distribution payment. Typically follows a sequential or period-based numbering scheme for tracking and reconciliation purposes.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the owner distribution. Tracks progression from initial calculation through approval, payment execution, and final settlement. [ENUM-REF-CANDIDATE: draft|calculated|approved|pending_payment|paid|cancelled|disputed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffeReserveBalance rdf:type rdf:Property ;
    rdfs:label 'Ffe Reserve Balance' ;
    rdfs:comment 'Cumulative balance in the Furniture Fixtures and Equipment reserve fund after this period\'s contribution. Tracks funds available for capital expenditure (CapEx) projects.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ffeReserveContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Ffe Reserve Contribution Amount' ;
    rdfs:comment 'Mandatory contribution to the Furniture Fixtures and Equipment reserve fund, typically calculated as a percentage of gross revenue. Funds capital expenditure (CapEx) for property maintenance and renovation.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gopAmount rdf:type rdf:Property ;
    rdfs:label 'Gop Amount' ;
    rdfs:comment 'Gross Operating Profit calculated as gross revenue minus operating expenses and management fees. Key performance metric in hotel financial reporting and distribution calculations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue Amount' ;
    rdfs:comment 'Total gross revenue generated by the property during the distribution period. First line item in the distribution waterfall calculation, includes rooms, food and beverage (F&B), events, and ancillary revenue streams.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveManagementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Management Fee Amount' ;
    rdfs:comment 'Performance-based incentive management fee earned by the operator when property achieves specified Gross Operating Profit (GOP) or other performance thresholds defined in the Hotel Management Agreement.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurancePremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Premium Amount' ;
    rdfs:comment 'Property insurance premiums paid during the period, including general liability, property damage, business interruption, and other required coverage per the Hotel Management Agreement.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noiAmount rdf:type rdf:Property ;
    rdfs:label 'Noi Amount' ;
    rdfs:comment 'Net Operating Income calculated after all operating expenses, management fees, reserves, debt service, and other deductions. Represents the distributable income available to owners.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Other Deductions Amount' ;
    rdfs:comment 'Additional contractual deductions from the distribution waterfall not captured in standard categories. May include special assessments, brand fees, or owner-approved expenditures.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Property Tax Amount' ;
    rdfs:comment 'Real estate property taxes and assessments paid during the period. Deducted in the distribution waterfall before calculating net distributable income.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperatingExpensesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Operating Expenses Amount' ;
    rdfs:comment 'Total operating expenses incurred during the period, including departmental costs, undistributed operating expenses, and property operations and maintenance. Deducted after management fees in the waterfall.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workingCapitalReserveBalance rdf:type rdf:Property ;
    rdfs:label 'Working Capital Reserve Balance' ;
    rdfs:comment 'Cumulative balance in the working capital reserve fund maintained per Hotel Management Agreement requirements. Provides liquidity buffer for operational needs.' ;
    rdfs:domain ind:OwnerDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Foreign key reference to the parent profit center in a hierarchical profit center structure. Enables roll-up reporting for complex properties with nested profit centers (e.g., a resort with multiple F&B (Food and Beverage) outlets).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the profit center\'s physical location. Required for property-level profit centers and standalone F&B (Food and Beverage) or event venues.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, or building information.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the profit center is located.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP Controlling Area code to which this profit center is assigned. Defines the organizational boundary for internal cost and revenue accounting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the profit center\'s location. Used for multi-country consolidation and compliance with local regulatory reporting requirements.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsolidated rdf:type rdf:Property ;
    rdfs:label 'Is Consolidated' ;
    rdfs:comment 'Boolean flag indicating whether this profit center\'s financial results are included in consolidated financial statements. Used for inter-company elimination and segment reporting per IFRS/GAAP.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Boolean flag indicating whether this profit center directly generates guest-facing revenue (true) or is a support/overhead center (false). Used for GOP (Gross Operating Profit) and departmental profit analysis per USALI.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The original opening or launch date of the profit center. Used for property age analysis and lifecycle reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the profit center\'s address.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed business description of the profit center, including its purpose, services offered, and unique characteristics. Used for internal documentation and reporting context.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The full business name of the profit center (e.g., \'Grand Plaza Hotel Downtown\', \'Rooftop Bar & Lounge\', \'Convention Center Ballroom A\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center. Active centers contribute to consolidated financial statements; inactive or closed centers are excluded from operational reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by business unit type. Determines the applicable revenue and cost accounting rules per USALI departmental structure. [ENUM-REF-CANDIDATE: property|fnb_outlet|event_venue|spa|retail|parking|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomCount rdf:type rdf:Property ;
    rdfs:label 'Room Count' ;
    rdfs:comment 'Total number of guest rooms or keys available at this profit center (applicable only to property-level profit centers). Used for RevPAR (Revenue Per Available Room), GOPPAR (Gross Operating Profit Per Available Room), and occupancy calculations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity' ;
    rdfs:comment 'Maximum seating capacity for F&B (Food and Beverage) outlets or event venues. Used for revenue per seat analysis and capacity utilization reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or short name for the profit center used in reports and dashboards where space is limited.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:starRating rdf:type rdf:Property ;
    rdfs:label 'Star Rating' ;
    rdfs:comment 'Official star rating or quality classification for the profit center (e.g., 3.5, 4.0, 5.0). Used for competitive set analysis and ADR (Average Daily Rate) benchmarking per STR (Smith Travel Research) standards.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 state or province code for the profit center\'s location. Used for tax jurisdiction determination and regulatory reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction code for sales tax, VAT (Value-Added Tax), or GST (Goods and Services Tax) reporting. Used for compliance with local tax regulations and automated tax calculation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPostingId rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Id' ;
    rdfs:comment 'Unique identifier for the tax posting transaction record.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedPostingTaxPostingId rdf:type rdf:Property ;
    rdfs:label 'Reversed Posting Tax Posting Id' ;
    rdfs:comment 'Reference to the original tax posting ID that this record reverses, if applicable.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxPosting .

ind:exemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Exemption Certificate Number' ;
    rdfs:comment 'The certificate or authorization number supporting the tax exemption claim, if applicable.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionIndicator rdf:type rdf:Property ;
    rdfs:label 'Exemption Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this transaction qualifies for tax exemption.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'The date when the tax return or report was filed with the tax authority.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The tax reporting period identifier (e.g., monthly, quarterly, annually) for regulatory filing purposes.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'The reference number of the source document (e.g., folio number, invoice number, check number) that originated this tax transaction.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'The type of source document that generated this tax posting: guest folio (room charges), F&B check, event invoice, vendor invoice, adjustment, or other.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Base Amount' ;
    rdfs:comment 'The gross taxable amount upon which the tax is calculated, before tax is applied.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'The governmental jurisdiction or authority to which this tax is owed (e.g., federal, state, county, city, municipality).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The tax rate percentage applied to the tax base amount to calculate the tax amount.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'The category of tax being posted: VAT (Value Added Tax), GST (Goods and Services Tax), occupancy tax, TOT (Transient Occupancy Tax), sales tax on F&B and events, withholding tax on vendor payments, service tax, resort fee tax, or other. [ENUM-REF-CANDIDATE: VAT|GST|occupancy_tax|TOT|sales_tax|withholding_tax|service_tax|resort_fee_tax|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The actual business date when the taxable transaction occurred (e.g., guest check-out date, F&B sale date).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:banquetEventOrderId rdf:type rdf:Property ;
    rdfs:label 'Banquet Event Order Id' ;
    rdfs:comment 'Unique identifier for the banquet event order. Primary key for the BEO master record.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BanquetEventOrder .

ind:organizerMemberId rdf:type rdf:Property ;
    rdfs:label 'Organizer Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member. Business justification: Group/banquet loyalty earning: corporate meeting planners and event organizers who are loyalty members earn points on banquet F&B spend. Business process: loyalty points accrual on group revenue, plan' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:posCheckId rdf:type rdf:Property ;
    rdfs:label 'Pos Check Id' ;
    rdfs:comment 'Foreign key linking to fnb.pos_check. Business justification: Banquet events often generate POS checks for actual consumption billing (especially for bar service, upgrades, or consumption-based beverage packages). This FK links the BEO to the actual POS transact' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosCheck .

ind:actualCovers rdf:type rdf:Property ;
    rdfs:label 'Actual Covers' ;
    rdfs:comment 'Actual number of guests who attended the banquet event. Recorded post-event for reconciliation and future forecasting.' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beveragePackageType rdf:type rdf:Property ;
    rdfs:label 'Beverage Package Type' ;
    rdfs:comment 'Type of beverage service selected for the event. Determines billing method and beverage offerings. [ENUM-REF-CANDIDATE: hosted_bar|cash_bar|consumption_bar|beer_wine_only|soft_drinks_only|full_premium|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beverageRevenue rdf:type rdf:Property ;
    rdfs:label 'Beverage Revenue' ;
    rdfs:comment 'Total beverage revenue for the event. May be package-based or consumption-based depending on beverage package type.' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the banquet event was completed and the BEO was closed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dietaryRequirements rdf:type rdf:Property ;
    rdfs:label 'Dietary Requirements' ;
    rdfs:comment 'Special dietary needs and restrictions for event attendees including allergies, religious requirements, and preferences.' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTime rdf:type rdf:Property ;
    rdfs:label 'Event End Time' ;
    rdfs:comment 'Scheduled end time for the banquet event including date and time components.' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartTime rdf:type rdf:Property ;
    rdfs:label 'Event Start Time' ;
    rdfs:comment 'Scheduled start time for the banquet event including date and time components.' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the banquet event order. Tracks progression from planning through execution to completion.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodRevenue rdf:type rdf:Property ;
    rdfs:label 'Food Revenue' ;
    rdfs:comment 'Total food revenue for the event calculated from guaranteed covers and per-person food price.' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedCovers rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Covers' ;
    rdfs:comment 'Number of guests guaranteed by the client for billing purposes. Minimum number the client will be charged for regardless of actual attendance.' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:perPersonBeveragePrice rdf:type rdf:Property ;
    rdfs:label 'Per Person Beverage Price' ;
    rdfs:comment 'Beverage charge per guest for the selected beverage package. Applicable for hosted bar and package pricing models.' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perPersonFoodPrice rdf:type rdf:Property ;
    rdfs:label 'Per Person Food Price' ;
    rdfs:comment 'Food charge per guest for the selected menu package. Excludes beverage, service charge, and tax.' ;
    rdfs:domain ind:BanquetEventOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Revenue' ;
    rdfs:comment 'Total revenue for the banquet event including food, beverage, service charge, and tax. Grand total for billing.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Banquet package pricing and terms require director-level approval for contract authority and revenue protection. Links approval authority to workforce records for delegation of authority reporting and' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advanceNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Days' ;
    rdfs:comment 'Minimum number of days advance notice required to book this package. Ensures adequate time for procurement, preparation, and staffing.' ;
    rdfs:domain ind:BanquetMenuPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beverageCostPercentage rdf:type rdf:Property ;
    rdfs:label 'Beverage Cost Percentage' ;
    rdfs:comment 'Target beverage cost as a percentage of the per-person price (if beverages are included). Used for F&B (Food and Beverage) profitability analysis.' ;
    rdfs:domain ind:BanquetMenuPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beverageDurationHours rdf:type rdf:Property ;
    rdfs:label 'Beverage Duration Hours' ;
    rdfs:comment 'Number of hours of beverage service included in the package price (e.g., 2.0 for a two-hour cocktail reception). Null if beverage_inclusion is \'none\'.' ;
    rdfs:domain ind:BanquetMenuPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beverageInclusion rdf:type rdf:Property ;
    rdfs:label 'Beverage Inclusion' ;
    rdfs:comment 'Type of beverage service included in the per-person package price. \'None\' indicates beverages are charged separately. Impacts F&B (Food and Beverage) revenue allocation. [ENUM-REF-CANDIDATE: none|soft drinks|coffee and tea|beer and wine|full bar|premium bar|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BanquetMenuPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodCostPercentage rdf:type rdf:Property ;
    rdfs:label 'Food Cost Percentage' ;
    rdfs:comment 'Target food cost as a percentage of the per-person price. Used for F&B (Food and Beverage) profitability analysis and GOP (Gross Operating Profit) contribution tracking.' ;
    rdfs:domain ind:BanquetMenuPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedCourses rdf:type rdf:Property ;
    rdfs:label 'Included Courses' ;
    rdfs:comment 'Detailed description of all food courses included in the package (e.g., \'Appetizer, Salad, Entrée with Two Sides, Dessert, Bread Service\'). Used in BEO (Banquet Event Order) documentation.' ;
    rdfs:domain ind:BanquetMenuPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborHoursPerGuest rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Per Guest' ;
    rdfs:comment 'Estimated service labor hours required per guest for this package. Used for workforce scheduling and CPOR (Cost Per Occupied Room) calculations.' ;
    rdfs:domain ind:BanquetMenuPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable name of the banquet menu package (e.g., \'Executive Breakfast Buffet\', \'Gala Dinner Package\', \'Cocktail Reception Deluxe\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageNotes rdf:type rdf:Property ;
    rdfs:label 'Package Notes' ;
    rdfs:comment 'Internal notes and special instructions for event sales and catering staff regarding this package. May include preparation tips, substitution rules, or operational considerations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the banquet menu package. Only \'active\' and \'seasonal\' packages are available for booking in Delphi by Amadeus.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the banquet menu package by meal period and service style. Determines pricing structure and operational requirements.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perPersonPrice rdf:type rdf:Property ;
    rdfs:label 'Per Person Price' ;
    rdfs:comment 'Base price per person for the banquet menu package in the property\'s local currency. Used for event sales quoting and BEO (Banquet Event Order) pricing calculations.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonDescription rdf:type rdf:Property ;
    rdfs:label 'Season Description' ;
    rdfs:comment 'Description of the season or time period when this package is available (e.g., \'Holiday Season\', \'Summer Months\', \'Wedding Season\'). Null if not seasonal.' ;
    rdfs:domain ind:BanquetMenuPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalIndicator rdf:type rdf:Property ;
    rdfs:label 'Seasonal Indicator' ;
    rdfs:comment 'Indicates whether this package is offered only during specific seasons or year-round. True if seasonal, False if available year-round.' ;
    rdfs:domain ind:BanquetMenuPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:setupRequirements rdf:type rdf:Property ;
    rdfs:label 'Setup Requirements' ;
    rdfs:comment 'Detailed description of room setup, table configuration, linen, centerpieces, and equipment required for this package (e.g., \'Rounds of 10, Floor-Length Linens, Centerpieces, Stage, AV Equipment\'). Used for event operations planning.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive Flag' ;
    rdfs:comment 'Indicates whether the per-person price includes applicable taxes. True if tax-inclusive, False if taxes are added separately. Critical for accurate event quoting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Start date of the validity period for this package. Package can be booked for events on or after this date.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'End date of the validity period for this package. Package can be booked for events on or before this date. Null indicates no expiration.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountId rdf:type rdf:Property ;
    rdfs:label 'Discount Id' ;
    rdfs:comment 'Primary key for discount' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Discount .

ind:loyaltyTierId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: Tier-based F&B discounts: platinum members receive 20% dining discount, gold 15%, etc. discount.loyalty_tier_required exists as text; FK enables POS validation, automated discount application, tier be' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:applicableMenuItemScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Menu Item Scope' ;
    rdfs:comment 'Defines which menu items are eligible for this discount: all_items (any item), specific_items (named items only), menu_category (e.g., appetizers, beverages), revenue_class (e.g., food, beverage, alcohol).' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableOutletScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Outlet Scope' ;
    rdfs:comment 'Defines which F&B outlets can apply this discount: all_outlets (property-wide), specific_outlets (named outlets only), outlet_type (e.g., all restaurants, all bars).' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToServiceCharge rdf:type rdf:Property ;
    rdfs:label 'Applies To Service Charge' ;
    rdfs:comment 'Indicates whether the discount is applied before or after service charge calculation. True if discount reduces service charge base, False if applied post-service-charge. Supports gratuity calculation rules.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToTax rdf:type rdf:Property ;
    rdfs:label 'Applies To Tax' ;
    rdfs:comment 'Indicates whether the discount is applied before or after tax calculation. True if discount reduces taxable amount, False if applied post-tax. Supports tax compliance and revenue recognition.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Authorization Level Required' ;
    rdfs:comment 'Minimum staff authorization level required to apply this discount: none (no approval), server (server discretion), supervisor (shift supervisor), manager (outlet manager), director (F&B director), gm (general manager). Supports loss prevention and discount control.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinableWithOtherDiscounts rdf:type rdf:Property ;
    rdfs:label 'Combinable With Other Discounts' ;
    rdfs:comment 'Indicates whether this discount can be combined with other discounts on the same check. True if combinable, False if mutually exclusive. Supports discount stacking rules.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountCategory rdf:type rdf:Property ;
    rdfs:label 'Discount Category' ;
    rdfs:comment 'Business classification grouping discounts by purpose: promotional (marketing campaign), loyalty (program benefit), employee (staff meal), vip (guest recognition), service_recovery (guest satisfaction), group (event/MICE), seasonal (time-based offer), other. [ENUM-REF-CANDIDATE: promotional|loyalty|employee|vip|service_recovery|group|seasonal|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountCode rdf:type rdf:Property ;
    rdfs:label 'Discount Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the discount in the POS system. Used for transaction posting and reporting. Sourced from Oracle Hospitality MICROS POS discount configuration.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDescription rdf:type rdf:Property ;
    rdfs:label 'Discount Description' ;
    rdfs:comment 'Detailed description of the discount terms, conditions, and business purpose. Used for staff training and operational reference.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountName rdf:type rdf:Property ;
    rdfs:label 'Discount Name' ;
    rdfs:comment 'Business-friendly name of the discount or promotion displayed to staff and on guest receipts.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountStatus rdf:type rdf:Property ;
    rdfs:label 'Discount Status' ;
    rdfs:comment 'Current lifecycle state of the discount configuration: active (available for use), inactive (disabled), suspended (temporarily unavailable), expired (past validity period), pending_approval (awaiting authorization).' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Classification of the discount mechanism: percentage (percent off), fixed_amount (dollar/currency off), complimentary (full comp), loyalty_redemption (points-based), employee_meal (staff benefit), manager_comp (manager discretionary comp).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDiscountAmountPerCheck rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Amount Per Check' ;
    rdfs:comment 'Maximum total discount amount that can be applied to a single check, regardless of check total. Null for no cap. Supports loss prevention and discount control.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumUsagePerCheck rdf:type rdf:Property ;
    rdfs:label 'Maximum Usage Per Check' ;
    rdfs:comment 'Maximum number of times this discount can be applied to a single guest check. Null for unlimited usage. Supports discount control and loss prevention.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumUsagePerGuest rdf:type rdf:Property ;
    rdfs:label 'Maximum Usage Per Guest' ;
    rdfs:comment 'Maximum number of times a single guest (identified by loyalty account or profile) can use this discount during the validity period. Null for unlimited. Supports promotional campaign tracking.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCheckAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Check Amount' ;
    rdfs:comment 'Minimum pre-discount check total required to qualify for this discount. Null if no minimum. Supports promotional campaign rules (e.g., $50 minimum for 20% off).' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'Percentage discount applied to the check or item (e.g., 15.00 for 15% off). Applicable when discount_type is percentage. Null for non-percentage discount types.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoCodeRequired rdf:type rdf:Property ;
    rdfs:label 'Promo Code Required' ;
    rdfs:comment 'Indicates whether a promotional code must be entered by the guest or staff to activate this discount. True if promo code required, False if automatically available. Supports campaign tracking.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueClass rdf:type rdf:Property ;
    rdfs:label 'Revenue Class' ;
    rdfs:comment 'Revenue classification for reporting purposes: food, beverage, alcohol, tobacco, other. Aligns with USALI F&B departmental reporting and supports revenue analysis.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Valid Days Of Week' ;
    rdfs:comment 'Comma-separated list of days when discount is applicable (e.g., Monday,Tuesday,Wednesday or All). Supports day-of-week restrictions for promotional campaigns.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validTimeFrom rdf:type rdf:Property ;
    rdfs:label 'Valid Time From' ;
    rdfs:comment 'Start time of day when discount is applicable (HH:MM format, 24-hour). Supports daypart restrictions (e.g., happy hour, breakfast specials). Null if no time restriction.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validTimeTo rdf:type rdf:Property ;
    rdfs:label 'Valid Time To' ;
    rdfs:comment 'End time of day when discount is applicable (HH:MM format, 24-hour). Supports daypart restrictions. Null if no time restriction.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptsReservationsFlag rdf:type rdf:Property ;
    rdfs:label 'Accepts Reservations Flag' ;
    rdfs:comment 'Indicates whether the outlet accepts advance guest reservations through Property Management System (PMS), Customer Relationship Management (CRM), or third-party reservation platforms.' ;
    rdfs:domain ind:FnbOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant Flag' ;
    rdfs:comment 'Indicates whether the outlet meets ADA accessibility requirements including wheelchair access, accessible seating, and accessible restroom facilities.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageCheckTarget rdf:type rdf:Property ;
    rdfs:label 'Average Check Target' ;
    rdfs:comment 'Target average guest check amount in property base currency. Key performance indicator for revenue management and menu pricing strategy. Used in Food and Beverage (F&B) revenue contribution to Total Revenue Per Available Room (TRevPAR).' ;
    rdfs:domain ind:FnbOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beverageCostPercentageTarget rdf:type rdf:Property ;
    rdfs:label 'Beverage Cost Percentage Target' ;
    rdfs:comment 'Target beverage cost as a percentage of beverage revenue. Standard USALI metric for bar and beverage profitability. Typical range 18-24% for alcoholic beverages.' ;
    rdfs:domain ind:FnbOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cuisineCategory rdf:type rdf:Property ;
    rdfs:label 'Cuisine Category' ;
    rdfs:comment 'Primary cuisine type or culinary style offered by the outlet (e.g., \'Italian\', \'Asian Fusion\', \'American Steakhouse\', \'International Buffet\', \'Contemporary\', \'Seafood\'). Used for guest preference matching and marketing segmentation.' ;
    rdfs:domain ind:FnbOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dressCode rdf:type rdf:Property ;
    rdfs:label 'Dress Code' ;
    rdfs:comment 'Guest attire requirements for the outlet. Communicated during reservation and at property arrival. Impacts guest experience and outlet positioning.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodCostPercentageTarget rdf:type rdf:Property ;
    rdfs:label 'Food Cost Percentage Target' ;
    rdfs:comment 'Target food cost as a percentage of food revenue. Standard USALI metric for F&B profitability management. Typical range 28-35% depending on outlet type and cuisine.' ;
    rdfs:domain ind:FnbOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso22000CertificationDate rdf:type rdf:Property ;
    rdfs:label 'Iso 22000 Certification Date' ;
    rdfs:comment 'Date when ISO 22000 certification was granted or last renewed. Used for compliance tracking and audit scheduling.' ;
    rdfs:domain ind:FnbOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso22000CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 22000 Certified Flag' ;
    rdfs:comment 'Indicates whether the outlet holds ISO 22000 Food Safety Management System certification. Required for certain international brand standards and regulatory compliance in multiple jurisdictions.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso22000ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 22000 Expiry Date' ;
    rdfs:comment 'Date when current ISO 22000 certification expires. Triggers renewal workflow and compliance alerts.' ;
    rdfs:domain ind:FnbOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRenovationDate rdf:type rdf:Property ;
    rdfs:label 'Last Renovation Date' ;
    rdfs:comment 'Date of the most recent major renovation or refurbishment. Used for Furniture Fixtures and Equipment (FF&E) reserve planning and Property Improvement Plan (PIP) tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:menuLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Menu Last Updated Date' ;
    rdfs:comment 'Date when the outlet menu was last revised or updated. Used for menu lifecycle management, seasonal menu tracking, and guest communication.' ;
    rdfs:domain ind:FnbOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for Monday through Friday, formatted as time ranges (e.g., \'07:00-22:00\', \'11:30-14:30,18:00-23:00\' for split shifts). Used for labor scheduling and guest communication.' ;
    rdfs:domain ind:FnbOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for Saturday and Sunday, formatted as time ranges. May differ from weekday hours to accommodate leisure travel patterns.' ;
    rdfs:domain ind:FnbOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outletCode rdf:type rdf:Property ;
    rdfs:label 'Outlet Code' ;
    rdfs:comment 'Unique business identifier code for the outlet used in Oracle Hospitality MICROS Point of Sale (POS) and revenue reporting systems. Typically a short alphanumeric code assigned during outlet setup.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outletName rdf:type rdf:Property ;
    rdfs:label 'Outlet Name' ;
    rdfs:comment 'The official business name of the F&B outlet as displayed to guests and used in marketing materials (e.g., \'The Terrace Grill\', \'Lobby Bar\', \'In-Room Dining\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outletStatus rdf:type rdf:Property ;
    rdfs:label 'Outlet Status' ;
    rdfs:comment 'Current operational lifecycle status of the outlet. Determines availability for reservations, POS transactions, and revenue reporting inclusion.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outletType rdf:type rdf:Property ;
    rdfs:label 'Outlet Type' ;
    rdfs:comment 'Classification of the F&B outlet by operational format and service model. Determines reporting category and operational standards. [ENUM-REF-CANDIDATE: restaurant|bar|lounge|room_service|pool_bar|coffee_shop|banquet_kitchen|grab_and_go|buffet|specialty_dining|nightclub — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTerminalCode rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Code' ;
    rdfs:comment 'Primary Oracle Hospitality MICROS POS terminal identifier assigned to this outlet. Used for transaction reconciliation and system integration.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCenterCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Center Code' ;
    rdfs:comment 'USALI-compliant revenue center identifier used in General Ledger (GL) and financial reporting. Maps F&B outlet transactions to departmental Profit and Loss (P&L) statements and Gross Operating Profit (GOP) calculations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smokingPolicy rdf:type rdf:Property ;
    rdfs:label 'Smoking Policy' ;
    rdfs:comment 'Smoking policy for the outlet. Must comply with local health regulations and property standards. Communicated to guests during reservation and seating.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyInspectionId rdf:type rdf:Property ;
    rdfs:label 'Food Safety Inspection Id' ;
    rdfs:comment 'Unique identifier for the food safety inspection record. Primary key.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyInspection .

ind:responsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Health department inspections require documented manager accountability for corrective actions and regulatory compliance. Essential for OSHA/health authority reporting, performance reviews, and legal ' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:areasInspected rdf:type rdf:Property ;
    rdfs:label 'Areas Inspected' ;
    rdfs:comment 'List or description of specific areas, zones, or stations within the outlet or kitchen that were inspected (e.g., prep area, cold storage, dishwashing station, dining room).' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Compliance Flag' ;
    rdfs:comment 'Indicates whether the outlet or facility is in compliance with HACCP principles based on this inspection (True/False).' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionChecklistUsed rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Used' ;
    rdfs:comment 'Name or identifier of the standardized inspection checklist or audit protocol used during the inspection.' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'The date on which the food safety inspection was conducted.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Minutes' ;
    rdfs:comment 'Total duration of the inspection in minutes, from start to completion.' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionGrade rdf:type rdf:Property ;
    rdfs:label 'Inspection Grade' ;
    rdfs:comment 'Letter grade or categorical rating assigned based on the inspection score (e.g., A, B, C, Pass, Fail, Satisfactory, Unsatisfactory).' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Additional notes, observations, or comments recorded by the inspector during the inspection.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Business identifier or reference number assigned to this inspection for tracking and reporting purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportUrl rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Url' ;
    rdfs:comment 'URL or file path to the full inspection report document stored in the document management system.' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScore rdf:type rdf:Property ;
    rdfs:label 'Inspection Score' ;
    rdfs:comment 'Numerical score or rating assigned to the inspection, typically on a scale defined by the inspecting authority (e.g., 0-100).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionScoreScale rdf:type rdf:Property ;
    rdfs:label 'Inspection Score Scale' ;
    rdfs:comment 'Description of the scoring scale used for this inspection (e.g., \'0-100 scale\', \'A-F letter grade\', \'Pass/Fail\').' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection (scheduled, in progress, completed, failed, passed, pending corrective action).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'The category or type of inspection conducted (internal audit, health department inspection, ISO 22000 audit, HACCP review, pest control inspection, fire safety inspection, third-party audit). [ENUM-REF-CANDIDATE: internal_audit|health_department|iso_22000_audit|haccp_review|pest_control|fire_safety|third_party_audit — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'Professional certification or license number of the inspector, if applicable.' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorOrganization rdf:type rdf:Property ;
    rdfs:label 'Inspector Organization' ;
    rdfs:comment 'Name of the organization or agency the inspector represents (e.g., local health department, ISO certification body, internal audit team, pest control vendor).' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso22000ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 22000 Compliance Flag' ;
    rdfs:comment 'Indicates whether the outlet or facility is in compliance with ISO 22000 Food Safety Management System standards based on this inspection (True/False).' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date on which the inspection results and corrective action requirements were formally communicated to the responsible manager or property management.' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitNumberVerified rdf:type rdf:Property ;
    rdfs:label 'Permit Number Verified' ;
    rdfs:comment 'Health permit or food service license number that was verified or reviewed during the inspection.' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up reinspection is required to verify corrective actions (True/False).' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinspectionScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Scheduled Date' ;
    rdfs:comment 'The scheduled date for the follow-up reinspection, if required.' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationsSummary rdf:type rdf:Property ;
    rdfs:label 'Violations Summary' ;
    rdfs:comment 'Textual summary of all violations identified during the inspection, including descriptions and locations.' ;
    rdfs:domain ind:FoodSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryItemId rdf:type rdf:Property ;
    rdfs:label 'Inventory Item Id' ;
    rdfs:comment 'Primary key for inventory_item' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryItem .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Foreign key linking to procurement.material_master. Business justification: F&B inventory items map to procurement material master for standardized procurement, vendor management, cost tracking, and cross-property reporting. Core ERP integration pattern in multi-unit hospital' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:alcoholByVolumePercent rdf:type rdf:Property ;
    rdfs:label 'Alcohol By Volume Percent' ;
    rdfs:comment 'Percentage of alcohol content by volume for alcoholic beverages. Required for regulatory reporting and responsible service of alcohol programs.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alcoholFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol Flag' ;
    rdfs:comment 'Indicates whether the item contains alcohol. Used for regulatory compliance, age verification at POS, and beverage cost tracking.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether the item contains or may contain common allergens (dairy, nuts, gluten, shellfish, etc.). Required for guest safety and regulatory compliance.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenTypes rdf:type rdf:Property ;
    rdfs:label 'Allergen Types' ;
    rdfs:comment 'Comma-separated list of specific allergens present in the item (e.g., dairy, tree nuts, gluten, soy, eggs, fish, shellfish, peanuts). Used for menu labeling and guest communication.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Manufacturer or brand name of the item (e.g., Coca-Cola, Grey Goose, Sysco). Used for brand-specific reporting and guest preference tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentOnHandQuantity rdf:type rdf:Property ;
    rdfs:label 'Current On Hand Quantity' ;
    rdfs:comment 'Real-time quantity of the item currently available in inventory across all storage locations. Updated by receipts, issues, and physical counts.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glutenFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Gluten Free Flag' ;
    rdfs:comment 'Indicates whether the item is certified gluten-free or naturally contains no gluten. Critical for guests with celiac disease or gluten sensitivity.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:halalCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Halal Certified Flag' ;
    rdfs:comment 'Indicates whether the item is certified Halal. Required for properties serving Muslim guests and for menu compliance.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoFoodSafetyClassification rdf:type rdf:Property ;
    rdfs:label 'Iso Food Safety Classification' ;
    rdfs:comment 'Risk classification based on ISO 22000 food safety standards. High-risk items (e.g., raw meat, dairy) require stricter handling and monitoring.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCode rdf:type rdf:Property ;
    rdfs:label 'Item Code' ;
    rdfs:comment 'Unique business identifier for the inventory item used across Oracle Hospitality MICROS POS and central F&B stores. Typically alphanumeric SKU or internal catalog number.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemName rdf:type rdf:Property ;
    rdfs:label 'Item Name' ;
    rdfs:comment 'Full descriptive name of the inventory item as it appears in menus, recipes, and POS systems.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemSubcategory rdf:type rdf:Property ;
    rdfs:label 'Item Subcategory' ;
    rdfs:comment 'Secondary classification providing granular segmentation within the primary category (e.g., red wine, white wine, spirits under beverage-alcohol).' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kosherCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kosher Certified Flag' ;
    rdfs:comment 'Indicates whether the item is certified Kosher. Required for properties serving Jewish guests and for menu compliance.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count for this item. Used for inventory accuracy monitoring and audit compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountQuantity rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Quantity' ;
    rdfs:comment 'Quantity recorded during the most recent physical inventory count. Used for variance analysis against system on-hand quantity.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPurchaseCost rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Cost' ;
    rdfs:comment 'Unit cost from the most recent purchase order. Used for cost variance analysis and standard cost updates.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the most recent purchase order receipt for this item. Used for supplier performance tracking and inventory aging analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localSourcedFlag rdf:type rdf:Property ;
    rdfs:label 'Local Sourced Flag' ;
    rdfs:comment 'Indicates whether the item is sourced from local suppliers within a defined geographic radius. Supports farm-to-table programs and sustainability initiatives.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Flag' ;
    rdfs:comment 'Indicates whether the item is certified organic. Used for menu labeling and sustainability reporting.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'Size or quantity per package unit (e.g., 750ml bottle, 12-count case, 5kg bag). Used for ordering and yield calculations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parLevel rdf:type rdf:Property ;
    rdfs:label 'Par Level' ;
    rdfs:comment 'Target inventory quantity that should be maintained to meet operational demand without overstocking. Used for automated reorder triggers.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Minimum inventory quantity threshold that triggers a purchase requisition or reorder workflow. Calculated based on lead time and consumption rate.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredStorageTemperatureMax rdf:type rdf:Property ;
    rdfs:label 'Required Storage Temperature Max' ;
    rdfs:comment 'Maximum safe storage temperature in Celsius for temperature-controlled items. Exceeding this threshold triggers food safety alerts.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredStorageTemperatureMin rdf:type rdf:Property ;
    rdfs:label 'Required Storage Temperature Min' ;
    rdfs:comment 'Minimum safe storage temperature in Celsius for temperature-controlled items. Used for cold chain monitoring and food safety audits.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Number of days the item remains safe and usable from receipt date. Critical for perishable items and ISO 22000 food safety compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Average unit cost of the item used for inventory valuation and F&B cost calculations. Updated periodically based on purchase history and supplier pricing.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical location where the item is stored (e.g., central F&B store, outlet storeroom, walk-in cooler, dry storage, bar). Supports multi-location inventory tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Reference' ;
    rdfs:comment 'Identifier or name of the primary supplier for this item. Links to procurement vendor master for purchase order generation.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableFlag rdf:type rdf:Property ;
    rdfs:label 'Taxable Flag' ;
    rdfs:comment 'Indicates whether the item is subject to sales tax when sold through F&B outlets. Drives POS tax calculation logic.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether the item requires refrigeration or freezing to maintain safety and quality. Drives storage location assignment and handling procedures.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veganFlag rdf:type rdf:Property ;
    rdfs:label 'Vegan Flag' ;
    rdfs:comment 'Indicates whether the item contains no animal products or by-products. Used for menu labeling and dietary preference tracking.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorItemCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Code' ;
    rdfs:comment 'Suppliers unique identifier for this item. Used for purchase order line item matching and invoice reconciliation.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Percent' ;
    rdfs:comment 'Percentage of usable product after preparation and waste (e.g., 75% yield for whole fish after filleting). Used for accurate recipe costing.' ;
    rdfs:domain ind:InventoryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:menuId rdf:type rdf:Property ;
    rdfs:label 'Menu Id' ;
    rdfs:comment 'Unique identifier for the menu. Primary key.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Menu .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether the menu is currently active and available for ordering (True) or inactive (False). Used for operational control in Point of Sale (POS) systems.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beverageDescription rdf:type rdf:Property ;
    rdfs:label 'Beverage Description' ;
    rdfs:comment 'Description of included beverages for package menus (e.g., \'Unlimited coffee, tea, and soft drinks\', \'House wine and beer for 2 hours\', \'Premium open bar\').' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beverageInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Beverage Inclusion Flag' ;
    rdfs:comment 'Indicates whether beverages are included in the menu package price (True) or charged separately (False). Critical for banquet and catering packages.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:courseCount rdf:type rdf:Property ;
    rdfs:label 'Course Count' ;
    rdfs:comment 'Number of courses included in prix fixe, tasting, and banquet menus (e.g., 3-course, 5-course, 7-course).' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Detailed description of the courses included in the menu (e.g., \'Appetizer, Soup, Salad, Entrée, Dessert\'). Used in Banquet Event Order (BEO) documentation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cuisineType rdf:type rdf:Property ;
    rdfs:label 'Cuisine Type' ;
    rdfs:comment 'The culinary style or cuisine category of the menu (e.g., \'Italian\', \'French\', \'Contemporary American\', \'Asian Fusion\', \'Mediterranean\'). [ENUM-REF-CANDIDATE: italian|french|american|asian|mediterranean|latin|middle_eastern|fusion|international — promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryOptions rdf:type rdf:Property ;
    rdfs:label 'Dietary Options' ;
    rdfs:comment 'Available dietary accommodations and special menu options (e.g., \'Vegetarian, Vegan, Gluten-Free, Kosher, Halal available upon request\'). Critical for ADA (Americans with Disabilities Act) compliance and guest satisfaction.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealPeriod rdf:type rdf:Property ;
    rdfs:label 'Meal Period' ;
    rdfs:comment 'The meal period or daypart when this menu is available. [ENUM-REF-CANDIDATE: breakfast|brunch|lunch|dinner|all_day|afternoon_tea|late_night|happy_hour — promote to reference product]' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuDescription rdf:type rdf:Property ;
    rdfs:label 'Menu Description' ;
    rdfs:comment 'Detailed marketing description of the menu, its theme, culinary style, and guest experience positioning. Used in event sales materials and guest-facing communications.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuStatus rdf:type rdf:Property ;
    rdfs:label 'Menu Status' ;
    rdfs:comment 'Current lifecycle status of the menu indicating availability and operational state.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'The pricing category or tier of this menu, used for revenue management and market positioning.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printSequence rdf:type rdf:Property ;
    rdfs:label 'Print Sequence' ;
    rdfs:comment 'Display order sequence for menu presentation in Oracle Hospitality MICROS POS, printed materials, and digital menu boards.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this menu is part of a limited-time promotional campaign (True) or a standard offering (False). Used for marketing analytics and revenue management.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this is a seasonal menu (True) with limited availability based on ingredient seasonality and market demand, or a year-round menu (False).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceChargeInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Service Charge Inclusive Flag' ;
    rdfs:comment 'Indicates whether the menu price includes service charges or gratuity (True) or these are added separately (False). Important for banquet and catering pricing transparency.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipeId rdf:type rdf:Property ;
    rdfs:label 'Recipe Id' ;
    rdfs:comment 'Foreign key reference to the standardized recipe used to prepare this menu item. Links to detailed ingredient lists, preparation instructions, and cost breakdowns for kitchen operations and cost control.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recipe .

ind:alcoholContentPercent rdf:type rdf:Property ;
    rdfs:label 'Alcohol Content Percent' ;
    rdfs:comment 'The alcohol by volume (ABV) percentage for alcoholic beverages. Required for regulatory compliance and responsible service of alcohol programs.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenFlags rdf:type rdf:Property ;
    rdfs:label 'Allergen Flags' ;
    rdfs:comment 'Comma-separated list of major allergens present in the menu item (e.g., dairy, eggs, fish, shellfish, tree nuts, peanuts, wheat, soy, sesame). Critical for guest safety and regulatory compliance.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calorieCount rdf:type rdf:Property ;
    rdfs:label 'Calorie Count' ;
    rdfs:comment 'The total caloric content per standard portion. Required for nutritional disclosure compliance in many jurisdictions and increasingly expected by health-conscious guests.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'The standard cost to produce one unit of this menu item, including ingredients, labor, and direct overhead. Used for food cost percentage calculation and Gross Operating Profit (GOP) analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodSafetyClassification rdf:type rdf:Property ;
    rdfs:label 'Food Safety Classification' ;
    rdfs:comment 'Risk classification for food safety management based on ISO 22000 standards. High-risk items (e.g., raw seafood, undercooked eggs) require enhanced handling protocols and temperature monitoring.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Percent' ;
    rdfs:comment 'The gross profit margin percentage calculated as (standard_price - cost_price) / standard_price * 100. Key metric for menu engineering and profitability analysis.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAlcoholic rdf:type rdf:Property ;
    rdfs:label 'Is Alcoholic' ;
    rdfs:comment 'Indicates whether the menu item contains alcohol. Used for age verification requirements, licensing compliance, and separate revenue tracking per USALI standards.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAvailableBanquet rdf:type rdf:Property ;
    rdfs:label 'Is Available Banquet' ;
    rdfs:comment 'Indicates whether this menu item is available for banquet, catering, and group event menus. Used for Banquet Event Order (BEO) planning and MICE (Meetings Incentives Conferences Exhibitions) operations.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAvailableRoomService rdf:type rdf:Property ;
    rdfs:label 'Is Available Room Service' ;
    rdfs:comment 'Indicates whether this menu item is available for in-room dining / room service orders. Some items may be outlet-only due to preparation complexity or presentation requirements.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGlutenFree rdf:type rdf:Property ;
    rdfs:label 'Is Gluten Free' ;
    rdfs:comment 'Indicates whether the menu item is free from gluten-containing ingredients. Critical for guests with celiac disease or gluten sensitivity.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHalal rdf:type rdf:Property ;
    rdfs:label 'Is Halal' ;
    rdfs:comment 'Indicates whether the menu item meets halal dietary requirements according to Islamic law. Important for properties serving Muslim guests.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKosher rdf:type rdf:Property ;
    rdfs:label 'Is Kosher' ;
    rdfs:comment 'Indicates whether the menu item meets kosher dietary requirements according to Jewish law. Important for properties serving Jewish guests.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonal rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal' ;
    rdfs:comment 'Indicates whether this menu item is only available during specific seasons or time periods. Used for menu planning and inventory management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignatureItem rdf:type rdf:Property ;
    rdfs:label 'Is Signature Item' ;
    rdfs:comment 'Indicates whether this menu item is designated as a signature or specialty item that represents the property or outlets culinary identity. Used for marketing, menu engineering, and upselling strategies.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVegan rdf:type rdf:Property ;
    rdfs:label 'Is Vegan' ;
    rdfs:comment 'Indicates whether the menu item is suitable for vegan diets (contains no animal products or by-products). Used for dietary filtering and guest preference matching.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVegetarian rdf:type rdf:Property ;
    rdfs:label 'Is Vegetarian' ;
    rdfs:comment 'Indicates whether the menu item is suitable for vegetarian diets (contains no meat or fish but may contain dairy or eggs). Used for dietary filtering and guest preference matching.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:menuSection rdf:type rdf:Property ;
    rdfs:label 'Menu Section' ;
    rdfs:comment 'The section or grouping on the menu where this item appears (e.g., Starters, Main Courses, Desserts, Signature Cocktails, Wine List). Used for menu layout and guest navigation.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Requirement' ;
    rdfs:comment 'The minimum age required to purchase this menu item, typically applicable to alcoholic beverages. Null for items with no age restriction. Used for Point of Sale (POS) age verification prompts.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portionSize rdf:type rdf:Property ;
    rdfs:label 'Portion Size' ;
    rdfs:comment 'The standard serving size or portion measurement for the menu item (e.g., 8 oz, 250 ml, 1 piece, serves 2). Used for consistency, cost control, and nutritional disclosure.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Preparation Time Minutes' ;
    rdfs:comment 'The standard time in minutes required to prepare and serve this menu item from order placement to guest delivery. Used for kitchen workflow planning and guest expectation management.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spiceLevel rdf:type rdf:Property ;
    rdfs:label 'Spice Level' ;
    rdfs:comment 'Indicates the heat or spiciness level of the menu item. Used for guest preference matching and expectation setting.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'The standard selling price of the menu item before any discounts, promotions, or service charges. This is the base price used for revenue calculation and Average Daily Rate (ADR) contribution analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPosEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pos Employee Id' ;
    rdfs:comment 'Identifier of the server or service staff member assigned to this check. Used for tip allocation and performance tracking.' ;
    rdfs:domain ind:PosCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPosManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Pos Manager Employee Id' ;
    rdfs:comment 'Identifier of the manager who approved exceptions on this check. Null if no manager approval was required.' ;
    rdfs:domain ind:PosCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Time' ;
    rdfs:comment 'Actual time when the order was delivered to the guest room or delivery address. Used to calculate on-time delivery rate.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:businessDate rdf:type rdf:Property ;
    rdfs:label 'Business Date' ;
    rdfs:comment 'Business operating date for the check, which may differ from the calendar date for late-night operations. Used for daily revenue reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkStatus rdf:type rdf:Property ;
    rdfs:label 'Check Status' ;
    rdfs:comment 'Current lifecycle status of the check. Open: check is active and items can be added. Closed: check has been settled and payment completed. Voided: check has been cancelled. Transferred: check has been moved to another table or server. Suspended: check is temporarily on hold.' ;
    rdfs:domain ind:PosCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverCount rdf:type rdf:Property ;
    rdfs:label 'Cover Count' ;
    rdfs:comment 'Number of guests (covers) served on this check. Used to calculate check average and revenue per cover metrics.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Delivery Duration Minutes' ;
    rdfs:comment 'Time in minutes from order placement to delivery completion. Key performance indicator for room service operations.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current status of room service or delivery order fulfillment. Tracks order through kitchen preparation and delivery workflow.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:folioReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Folio Reference Number' ;
    rdfs:comment 'Reference number of the guest folio in the PMS where this check was posted. Used for reconciliation between POS and PMS systems.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Manager Approval Required' ;
    rdfs:comment 'Indicates whether this check required manager approval due to discounts, voids, or policy exceptions.' ;
    rdfs:domain ind:PosCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Date and time when the check was first opened in the POS system. Represents the start of the guest dining experience.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'Channel or interface through which the order was placed. Particularly relevant for room service and delivery orders.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Type of service channel through which the order was placed. Dine-in: guest seated at table. Bar: bar service. Room Service: in-room dining. Takeaway: guest pickup. Delivery: off-premise delivery. Poolside: pool or beach service. Banquet: event service. Catering: catered function. [ENUM-REF-CANDIDATE: dine-in|bar|room-service|takeaway|delivery|poolside|banquet|catering — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Time' ;
    rdfs:comment 'Guest-requested delivery time for room service or delivery orders. Null for dine-in and immediate service orders.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tableNumber rdf:type rdf:Property ;
    rdfs:label 'Table Number' ;
    rdfs:comment 'Table number or service location identifier where the guest was seated. Null for room service, takeaway, and delivery orders.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Amount' ;
    rdfs:comment 'Amount tendered by the guest for payment. May exceed total_amount if change is due.' ;
    rdfs:domain ind:PosCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tipAmount rdf:type rdf:Property ;
    rdfs:label 'Tip Amount' ;
    rdfs:comment 'Discretionary gratuity amount added by the guest. Used for tip pooling and server compensation tracking.' ;
    rdfs:domain ind:PosCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posCheckLineId rdf:type rdf:Property ;
    rdfs:label 'Pos Check Line Id' ;
    rdfs:comment 'Unique identifier for the POS check line item. Primary key for this transaction line entity.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosCheckLine .

ind:loyaltyPromotionId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Promotion Id' ;
    rdfs:comment 'Foreign key linking to loyalty.promotion. Business justification: Item-level loyalty promotions: "earn 3x points on breakfast items" or "bonus 500 points on wine purchases over $100". Business process: promotion qualification tracking, bonus points calculation at li' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:parentLinePosCheckLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Line Pos Check Line Id' ;
    rdfs:comment 'Reference to another line item that this line is a modifier or add-on for. Null for standalone items. Enables hierarchical line item relationships for complex orders.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosCheckLine .

ind:voidedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Voided By Employee Id' ;
    rdfs:comment 'Reference to the employee who authorized or performed the void of this line item. Used for accountability and fraud prevention.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:costOfSales rdf:type rdf:Property ;
    rdfs:label 'Cost Of Sales' ;
    rdfs:comment 'Standard recipe cost for this line item based on ingredient costs at time of sale. Used for food cost percentage calculation and gross profit analysis. Business-confidential financial data.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseNumber rdf:type rdf:Property ;
    rdfs:label 'Course Number' ;
    rdfs:comment 'Course sequence indicator for multi-course dining. Determines kitchen firing order and service timing. Common values: 1=appetizer, 2=entree, 3=dessert.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:familyGroupCode rdf:type rdf:Property ;
    rdfs:label 'Family Group Code' ;
    rdfs:comment 'Mid-level menu category classification within major group. Examples: appetizers, entrees, desserts, wine, beer, spirits. Enables detailed menu mix reporting.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInclusiveTax rdf:type rdf:Property ;
    rdfs:label 'Is Inclusive Tax' ;
    rdfs:comment 'Indicates whether tax is included in the unit price (true) or added separately (false). Varies by jurisdiction and pricing strategy.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOpenItem rdf:type rdf:Property ;
    rdfs:label 'Is Open Item' ;
    rdfs:comment 'Indicates whether this line was entered as an open-priced item where the server manually entered the price rather than selecting from menu. Used for special items and manager overrides.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential ordering of this line item within the parent check. Determines display and printing order.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineSubtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal Amount' ;
    rdfs:comment 'Extended amount for this line calculated as quantity multiplied by unit price, before discounts and taxes. Base revenue for the line item.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Final total amount for this line item including all charges, discounts, taxes, and service charges. Net revenue contribution from this line.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:majorGroupCode rdf:type rdf:Property ;
    rdfs:label 'Major Group Code' ;
    rdfs:comment 'High-level menu category classification for this item. Examples: food, beverage, alcohol, non-alcohol. Used for USALI departmental reporting and revenue mix analysis.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifierText rdf:type rdf:Property ;
    rdfs:label 'Modifier Text' ;
    rdfs:comment 'Free-form text capturing cooking instructions, preparation preferences, add-ons, substitutions, and removals for this menu item. Examples: no onions, extra cheese, well done, gluten-free bun.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Number of units of this menu item ordered on this line. Supports fractional quantities for items sold by weight or partial portions.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatNumber rdf:type rdf:Property ;
    rdfs:label 'Seat Number' ;
    rdfs:comment 'Seat position at the table for this line item. Enables per-guest ordering and split-check processing. Used in full-service restaurant operations.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sentToKitchenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent To Kitchen Timestamp' ;
    rdfs:comment 'Date and time when this line item order was transmitted to the kitchen display system or printed to kitchen printer. Marks start of preparation cycle.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:servedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Served Timestamp' ;
    rdfs:comment 'Date and time when this item was marked as served to the guest. Used for service time analysis and kitchen performance measurement.' ;
    rdfs:domain ind:PosCheckLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:voidReasonCode rdf:type rdf:Property ;
    rdfs:label 'Void Reason Code' ;
    rdfs:comment 'Code identifying the reason this line item was voided. Examples: guest changed mind, kitchen error, wrong item entered, quality issue. Required when is_voided is true.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpDetails rdf:type rdf:Property ;
    rdfs:label 'Ccp Details' ;
    rdfs:comment 'Detailed description of ISO 22000 Critical Control Points in this recipe, including monitoring procedures, critical limits, corrective actions, and verification steps. Essential for food safety compliance and audit readiness.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chefNotes rdf:type rdf:Property ;
    rdfs:label 'Chef Notes' ;
    rdfs:comment 'Additional notes, tips, or special instructions from the executive chef. May include substitution options, quality standards, or presentation variations.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookingInstructions rdf:type rdf:Property ;
    rdfs:label 'Cooking Instructions' ;
    rdfs:comment 'Specific cooking instructions including equipment, temperatures, techniques, and quality checkpoints. Supports standardization and training of kitchen staff.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cooking Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to cook or finish the recipe. Critical for kitchen capacity planning, guest wait time estimation, and service flow management.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dietaryAttributes rdf:type rdf:Property ;
    rdfs:label 'Dietary Attributes' ;
    rdfs:comment 'Dietary classifications and attributes (e.g., \'vegetarian\', \'vegan\', \'gluten-free\', \'dairy-free\', \'halal\', \'kosher\'). Supports menu filtering, guest preference matching, and inclusive dining experiences.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpHazardAnalysis rdf:type rdf:Property ;
    rdfs:label 'Haccp Hazard Analysis' ;
    rdfs:comment 'Documented hazard analysis identifying biological, chemical, and physical hazards associated with this recipe. Required for HACCP compliance and food safety management.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso22000CcpFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 22000 Ccp Flag' ;
    rdfs:comment 'Boolean flag indicating whether this recipe contains one or more ISO 22000 Critical Control Points requiring food safety monitoring and documentation.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nutritionalCalories rdf:type rdf:Property ;
    rdfs:label 'Nutritional Calories' ;
    rdfs:comment 'Total calories per standard portion. Required for menu labeling compliance in many jurisdictions and supports wellness-focused guest preferences.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nutritionalCarbohydrateGrams rdf:type rdf:Property ;
    rdfs:label 'Nutritional Carbohydrate Grams' ;
    rdfs:comment 'Total carbohydrate content in grams per standard portion. Supports dietary planning and menu labeling compliance.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutritionalFatGrams rdf:type rdf:Property ;
    rdfs:label 'Nutritional Fat Grams' ;
    rdfs:comment 'Total fat content in grams per standard portion. Required for nutritional labeling and dietary analysis.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutritionalProteinGrams rdf:type rdf:Property ;
    rdfs:label 'Nutritional Protein Grams' ;
    rdfs:comment 'Protein content in grams per standard portion. Supports nutritional transparency and wellness program requirements.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutritionalSodiumMilligrams rdf:type rdf:Property ;
    rdfs:label 'Nutritional Sodium Milligrams' ;
    rdfs:comment 'Sodium content in milligrams per standard portion. Critical for health-conscious guests and dietary restriction management.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platingInstructions rdf:type rdf:Property ;
    rdfs:label 'Plating Instructions' ;
    rdfs:comment 'Detailed instructions for plating and presentation, including garnish placement, portion arrangement, and visual standards. Ensures brand consistency and guest experience quality.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portionSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Portion Size Unit' ;
    rdfs:comment 'Unit of measure for the standard portion size (e.g., \'ounce\', \'gram\', \'milliliter\'). Ensures consistency in portioning and cost calculation.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationMethod rdf:type rdf:Property ;
    rdfs:label 'Preparation Method' ;
    rdfs:comment 'Detailed step-by-step instructions for preparing the recipe, including ingredient handling, cooking techniques, temperatures, and timing. Ensures consistency and quality across all outlets.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeCode rdf:type rdf:Property ;
    rdfs:label 'Recipe Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the recipe, used across Oracle Hospitality MICROS POS and kitchen systems for item lookup and ordering.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeName rdf:type rdf:Property ;
    rdfs:label 'Recipe Name' ;
    rdfs:comment 'Human-readable name of the recipe as it appears on menus and in kitchen systems (e.g., \'Grilled Atlantic Salmon\', \'Signature Chocolate Lava Cake\').' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeStatus rdf:type rdf:Property ;
    rdfs:label 'Recipe Status' ;
    rdfs:comment 'Current lifecycle status of the recipe. Active recipes are available for service; seasonal recipes are available during specific periods; testing recipes are in development; discontinued recipes are archived.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeType rdf:type rdf:Property ;
    rdfs:label 'Recipe Type' ;
    rdfs:comment 'Classification of the recipe by menu category or preparation type. Supports menu engineering and F&B departmental reporting per USALI standards. [ENUM-REF-CANDIDATE: appetizer|entree|dessert|beverage|side|sauce|garnish|base_prep — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeHours rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Hours' ;
    rdfs:comment 'Maximum time in hours that the prepared recipe can be safely held before service or disposal. Critical for food safety, waste management, and batch production planning.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skillLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Skill Level Required' ;
    rdfs:comment 'The culinary skill level required to execute this recipe consistently (basic, intermediate, advanced, expert). Used for staff assignment, training planning, and labor scheduling.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardBeverageCostPerPortion rdf:type rdf:Property ;
    rdfs:label 'Standard Beverage Cost Per Portion' ;
    rdfs:comment 'The calculated cost of beverage ingredients (wine, spirits, mixers) required to produce one standard portion. Applicable to beverage recipes and cocktails. Supports beverage cost percentage tracking.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardFoodCostPerPortion rdf:type rdf:Property ;
    rdfs:label 'Standard Food Cost Per Portion' ;
    rdfs:comment 'The calculated cost of ingredients required to produce one standard portion of this recipe. Foundation for menu pricing, food cost percentage analysis, and GOP calculation per USALI standards.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardPortionSize rdf:type rdf:Property ;
    rdfs:label 'Standard Portion Size' ;
    rdfs:comment 'The standard serving size per portion in the specified unit of measure. Critical for portion control, cost consistency, and nutritional labeling compliance.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageInstructions rdf:type rdf:Property ;
    rdfs:label 'Storage Instructions' ;
    rdfs:comment 'Proper storage requirements for prepared recipe or components, including temperature range, container type, and maximum hold time. Critical for food safety and quality maintenance.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRecipeCost rdf:type rdf:Property ;
    rdfs:label 'Total Recipe Cost' ;
    rdfs:comment 'The total cost to produce the full recipe yield (all portions). Calculated as sum of all ingredient costs. Used for batch costing and procurement planning.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Time Minutes' ;
    rdfs:comment 'Total time in minutes from start to finish, including preparation, cooking, and plating. Used for kitchen scheduling and service time commitments.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:comment 'The number of portions or servings this recipe produces when prepared according to standard method. Used for portion cost calculation and inventory planning.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Yield Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the recipe yield quantity (e.g., \'portion\', \'ounce\', \'liter\'). Standardizes recipe costing and inventory consumption tracking. [ENUM-REF-CANDIDATE: portion|serving|ounce|gram|liter|milliliter|piece|dozen — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeIngredientId rdf:type rdf:Property ;
    rdfs:label 'Recipe Ingredient Id' ;
    rdfs:comment 'Unique identifier for each ingredient line within a recipe. Primary key for the recipe ingredient entity.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRecipeFnbInventoryItemId rdf:type rdf:Property ;
    rdfs:label 'Primary Recipe Fnb Inventory Item Id' ;
    rdfs:comment 'Reference to the ingredient master record. Links to the ingredient catalog for standardized ingredient definitions.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryItem .

ind:allergenContribution rdf:type rdf:Property ;
    rdfs:label 'Allergen Contribution' ;
    rdfs:comment 'Comma-separated list of allergens present in this ingredient (e.g., dairy, gluten, nuts, shellfish, soy, eggs). Critical for guest safety, menu labeling, and regulatory compliance with food allergen disclosure requirements.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalControlPointFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point Flag' ;
    rdfs:comment 'Indicates whether this ingredient represents a Critical Control Point in the HACCP (Hazard Analysis and Critical Control Points) food safety plan. True if special handling, temperature control, or monitoring is required.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost for this ingredient line, calculated as quantity_required multiplied by standard_cost_per_unit. Supports recipe-level food cost aggregation.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingredientCategory rdf:type rdf:Property ;
    rdfs:label 'Ingredient Category' ;
    rdfs:comment 'Classification of the ingredient by food category. Used for food cost analysis, procurement planning, and inventory management by category. [ENUM-REF-CANDIDATE: protein|produce|dairy|dry_goods|beverage|spice|condiment|oil_fat|seafood|bakery — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientName rdf:type rdf:Property ;
    rdfs:label 'Ingredient Name' ;
    rdfs:comment 'Human-readable name of the ingredient as it appears in the recipe. May differ from master ingredient name for recipe-specific context.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localSourcingFlag rdf:type rdf:Property ;
    rdfs:label 'Local Sourcing Flag' ;
    rdfs:comment 'Indicates whether this ingredient is sourced locally (typically within 100 miles of the property). Supports sustainability initiatives and farm-to-table marketing programs.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum quantity that must be ordered from the supplier for this ingredient. Used for procurement planning and inventory optimization.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalValuePerUnit rdf:type rdf:Property ;
    rdfs:label 'Nutritional Value Per Unit' ;
    rdfs:comment 'Nutritional information for one unit of this ingredient (calories, protein, fat, carbohydrates, sodium). Stored as structured text or JSON. Supports menu nutrition labeling and dietary analysis.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certified Flag' ;
    rdfs:comment 'Indicates whether this ingredient is certified organic by a recognized certification body. Supports menu labeling and premium positioning.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preparationInstruction rdf:type rdf:Property ;
    rdfs:label 'Preparation Instruction' ;
    rdfs:comment 'Specific preparation notes for this ingredient within the recipe context (e.g., diced, julienned, blanched, room temperature). Supports kitchen execution and quality consistency.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequired rdf:type rdf:Property ;
    rdfs:label 'Quantity Required' ;
    rdfs:comment 'The amount of this ingredient required for one batch or serving of the recipe. Precision supports fractional measurements common in culinary applications.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonality Flag' ;
    rdfs:comment 'Indicates whether this ingredient has seasonal availability constraints. True if ingredient availability or cost varies significantly by season.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Per Unit' ;
    rdfs:comment 'The standard cost of one unit of this ingredient at the time of recipe creation or last update. Used for recipe cost roll-up and food cost percentage calculation. Business-confidential pricing data.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageRequirement rdf:type rdf:Property ;
    rdfs:label 'Storage Requirement' ;
    rdfs:comment 'Required storage condition for this ingredient to maintain quality and safety. Critical for inventory management and food safety compliance.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed Flag' ;
    rdfs:comment 'Indicates whether this ingredient can be substituted with an alternative ingredient without compromising recipe quality or guest expectations. True if substitution is permitted, False if ingredient is critical.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:traceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Traceability Code' ;
    rdfs:comment 'Unique code or lot number for ingredient traceability from supplier to finished dish. Required for ISO 22000 compliance and food safety incident response.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wastePercentage rdf:type rdf:Property ;
    rdfs:label 'Waste Percentage' ;
    rdfs:comment 'The expected waste percentage for this ingredient during preparation (e.g., trim loss, bones, shells). Inverse of yield percentage, used for sustainability tracking and cost accuracy.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'The usable percentage of the ingredient after preparation and waste removal (e.g., 75% for vegetables after trimming). Used for accurate cost calculation and procurement planning.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentRevenueCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Revenue Center Id' ;
    rdfs:comment 'Reference to the parent revenue center in the reporting hierarchy. Null for top-level revenue centers.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueCenter .

ind:allergenMenuAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Menu Available Flag' ;
    rdfs:comment 'Indicates whether allergen information is available for menu items in this revenue center. True if allergen menus are provided.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageCheckTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Average Check Target Amount' ;
    rdfs:comment 'Target average check amount per cover for this revenue center. Used for revenue management and performance tracking.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beverageCostTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Beverage Cost Target Percentage' ;
    rdfs:comment 'Target beverage cost percentage for this revenue center. Used for cost control and GOP analysis.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coversPerDayTarget rdf:type rdf:Property ;
    rdfs:label 'Covers Per Day Target' ;
    rdfs:comment 'Target number of covers (guests served) per day for this revenue center. Used for capacity planning and forecasting.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayPartServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Day Part Service Flag' ;
    rdfs:comment 'Primary day part(s) served by this revenue center for menu planning and revenue analysis. [ENUM-REF-CANDIDATE: breakfast|lunch|dinner|all_day|brunch|afternoon_tea|late_night — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodCostTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Food Cost Target Percentage' ;
    rdfs:comment 'Target food cost percentage for this revenue center. Used for cost control and GOP analysis.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gratuityPolicy rdf:type rdf:Property ;
    rdfs:label 'Gratuity Policy' ;
    rdfs:comment 'Gratuity policy for the revenue center. Defines how tips and service charges are handled.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCostTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Target Percentage' ;
    rdfs:comment 'Target labor cost percentage for this revenue center. Used for workforce planning and GOP analysis.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:microsRvcNumber rdf:type rdf:Property ;
    rdfs:label 'Micros Rvc Number' ;
    rdfs:comment 'Oracle Hospitality MICROS POS revenue center number. Used to map POS transactions to the revenue center.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHoursDescription rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Description' ;
    rdfs:comment 'Textual description of standard operating hours (e.g., \'Daily 6:00 AM - 10:00 PM\', \'Breakfast 6:30-10:30, Dinner 18:00-22:00\').' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posIntegrationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Pos Integration Enabled Flag' ;
    rdfs:comment 'Indicates whether this revenue center is integrated with the POS system for transaction capture. True if integrated with Oracle Hospitality MICROS POS.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Reporting Hierarchy Level' ;
    rdfs:comment 'Hierarchical level of this revenue center in the property\'s organizational structure for roll-up reporting (e.g., 1=outlet, 2=department, 3=division).' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reservation Required Flag' ;
    rdfs:comment 'Indicates whether reservations are required for this revenue center. True if reservations are mandatory, False if walk-ins are accepted.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueCenterName rdf:type rdf:Property ;
    rdfs:label 'Revenue Center Name' ;
    rdfs:comment 'Business name of the F&B revenue center (e.g., Main Dining Room, Lobby Bar, Banquet Kitchen, Room Service).' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Center Status' ;
    rdfs:comment 'Current operational status of the revenue center. Used for availability management and reporting exclusions.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomChargePostingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Room Charge Posting Enabled Flag' ;
    rdfs:comment 'Indicates whether charges from this revenue center can be posted to guest room folios. True if room charge posting is enabled.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Type of service model offered by the revenue center for operational planning and labor scheduling. [ENUM-REF-CANDIDATE: table_service|counter_service|quick_service|buffet|banquet|room_service|grab_and_go|delivery|catering — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRateGroupCode rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Group Code' ;
    rdfs:comment 'Tax rate group code applied to transactions in this revenue center. Maps to jurisdiction-specific tax rules.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usaliRevenueCenterCode rdf:type rdf:Property ;
    rdfs:label 'Usali Revenue Center Code' ;
    rdfs:comment 'Standard USALI revenue center code for financial reporting and benchmarking. Maps to USALI chart of accounts.' ;
    rdfs:domain ind:RevenueCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomServiceOrderId rdf:type rdf:Property ;
    rdfs:label 'Room Service Order Id' ;
    rdfs:comment 'Unique identifier for the room service order. Primary key.' ;
    rdfs:domain ind:RoomServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRoomEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Room Employee Id' ;
    rdfs:comment 'Reference to the staff member who delivered the order to the guest room.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deliveryCharge rdf:type rdf:Property ;
    rdfs:label 'Delivery Charge' ;
    rdfs:comment 'Fixed or variable fee charged for delivering the order to the guest room.' ;
    rdfs:domain ind:RoomServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchTime rdf:type rdf:Property ;
    rdfs:label 'Dispatch Time' ;
    rdfs:comment 'Date and time when the order left the kitchen for delivery to the guest room.' ;
    rdfs:domain ind:RoomServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gratuityAmount rdf:type rdf:Property ;
    rdfs:label 'Gratuity Amount' ;
    rdfs:comment 'Optional tip or gratuity amount added by the guest for service staff.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isVipGuest rdf:type rdf:Property ;
    rdfs:label 'Is Vip Guest' ;
    rdfs:comment 'Boolean indicator whether the order is for a VIP guest requiring special handling or priority service.' ;
    rdfs:domain ind:RoomServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Loyalty Member Number' ;
    rdfs:comment 'Guest loyalty program member number for points accrual and benefit application.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Flag' ;
    rdfs:comment 'Boolean indicator whether the order was delivered within the promised or standard delivery timeframe. Key operational KPI.' ;
    rdfs:domain ind:RoomServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business-facing order number displayed to guests and staff for tracking and reference.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the room service order tracking its progression from placement to fulfillment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Timestamp' ;
    rdfs:comment 'Date and time when the guest placed the room service order. Primary business event timestamp.' ;
    rdfs:domain ind:RoomServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preparationStartTime rdf:type rdf:Property ;
    rdfs:label 'Preparation Start Time' ;
    rdfs:comment 'Date and time when kitchen staff began preparing the order.' ;
    rdfs:domain ind:RoomServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceCharge rdf:type rdf:Property ;
    rdfs:label 'Service Charge' ;
    rdfs:comment 'Mandatory or optional service charge applied to the order, typically a percentage of subtotal.' ;
    rdfs:domain ind:RoomServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockTransactionId rdf:type rdf:Property ;
    rdfs:label 'Stock Transaction Id' ;
    rdfs:comment 'Primary key for stock_transaction' ;
    rdfs:domain ind:StockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationFnbOutletId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Fnb Outlet Id' ;
    rdfs:comment 'Identifier of the destination location (outlet or storeroom) to which the item was moved. Null for waste/spoilage transactions.' ;
    rdfs:domain ind:StockTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FnbOutlet .

ind:originalTransactionStockTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Stock Transaction Id' ;
    rdfs:comment 'Reference to the original transaction ID if this is a reversal or correction transaction. Null for original transactions.' ;
    rdfs:domain ind:StockTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockTransaction .

ind:physicalCountId rdf:type rdf:Property ;
    rdfs:label 'Physical Count Id' ;
    rdfs:comment 'Reference to the physical inventory count session that generated this adjustment transaction. Null for non-adjustment transactions.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PhysicalCount .

ind:primaryStockEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Employee Id' ;
    rdfs:comment 'Identifier of the manager who authorized or approved the transaction, particularly for waste, adjustments, and transfers.' ;
    rdfs:domain ind:StockTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourceLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Location Id' ;
    rdfs:comment 'Identifier of the source location (outlet or storeroom) from which the item was moved. Null for receipts from vendors.' ;
    rdfs:domain ind:StockTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Batch or lot number of the item for traceability and food safety compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionNotes rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Notes' ;
    rdfs:comment 'Notes describing corrective actions taken or planned in response to waste or spoilage events. Null for non-waste transactions.' ;
    rdfs:domain ind:StockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Ref' ;
    rdfs:comment 'Unique transaction identifier in the source system for traceability and reconciliation.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business-facing unique transaction number or reference code for the stock movement.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current status of the transaction: pending (awaiting approval), completed (finalized), cancelled (voided before completion), or reversed (corrected after completion).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the stock transaction occurred in the operational system.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Type of stock transaction: receipt (goods received from vendor), issue-to-outlet (storeroom to outlet), inter-outlet transfer (outlet to outlet), spoilage, over-production waste, plate waste, breakage, expired stock, physical count adjustment, end-of-day consumption, or return-to-vendor. [ENUM-REF-CANDIDATE: receipt|issue_to_outlet|inter_outlet_transfer|spoilage|over_production_waste|plate_waste|breakage|expired_stock|physical_count_adjustment|end_of_day_consumption|return_to_vendor — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCategory rdf:type rdf:Property ;
    rdfs:label 'Waste Category' ;
    rdfs:comment 'Category of waste for waste transactions: spoilage, over-production, plate waste (customer leftovers), breakage, expired stock, or other. Null for non-waste transactions.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteReason rdf:type rdf:Property ;
    rdfs:label 'Waste Reason' ;
    rdfs:comment 'Detailed reason or description for the waste event. Null for non-waste transactions.' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidTransactionId rdf:type rdf:Property ;
    rdfs:label 'Void Transaction Id' ;
    rdfs:comment 'Primary key for void_transaction' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVoidInitiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Void Initiated By Employee Id' ;
    rdfs:comment 'Reference to the employee who initiated or requested the void transaction. May be the same as the server or a different staff member.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coversCount rdf:type rdf:Property ;
    rdfs:label 'Covers Count' ;
    rdfs:comment 'Number of guests (covers) on the original check. Used for per-cover analysis and service metrics.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayPart rdf:type rdf:Property ;
    rdfs:label 'Day Part' ;
    rdfs:comment 'Meal period or day part during which the void occurred. Used for day-part performance analysis.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmployeeMeal rdf:type rdf:Property ;
    rdfs:label 'Is Employee Meal' ;
    rdfs:comment 'Flag indicating whether the voided transaction was an employee meal. Used for labor cost allocation and benefit tracking.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManagerMeal rdf:type rdf:Property ;
    rdfs:label 'Is Manager Meal' ;
    rdfs:comment 'Flag indicating whether the voided transaction was a manager meal or comp. Used for tracking complimentary costs.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalCheckNumber rdf:type rdf:Property ;
    rdfs:label 'Original Check Number' ;
    rdfs:comment 'Business identifier of the original POS check that contained the voided item or transaction. Used for cross-reference and audit trail.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Timestamp' ;
    rdfs:comment 'Date and time when the original transaction or item was posted to the check, before it was voided.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresInvestigation rdf:type rdf:Property ;
    rdfs:label 'Requires Investigation' ;
    rdfs:comment 'Flag indicating whether this void has been flagged for further investigation by loss prevention or management due to suspicious patterns or high value.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidNumber rdf:type rdf:Property ;
    rdfs:label 'Void Number' ;
    rdfs:comment 'Business identifier for the void transaction, typically system-generated sequential number or alphanumeric code used for audit trail and reference.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Void Reason Description' ;
    rdfs:comment 'Free-text explanation or additional detail provided by the staff member or manager describing why the void was necessary.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidStatus rdf:type rdf:Property ;
    rdfs:label 'Void Status' ;
    rdfs:comment 'Current lifecycle status of the void transaction in the approval and audit workflow.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidType rdf:type rdf:Property ;
    rdfs:label 'Void Type' ;
    rdfs:comment 'Classification of the void transaction indicating what was voided: individual menu item, entire check, payment tender, discount, service charge, or tax adjustment.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedAmount rdf:type rdf:Property ;
    rdfs:label 'Voided Amount' ;
    rdfs:comment 'Monetary value of the voided transaction or item, excluding tax. Represents the gross amount removed from the check.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidedQuantity rdf:type rdf:Property ;
    rdfs:label 'Voided Quantity' ;
    rdfs:comment 'Quantity of the item that was voided. Typically an integer for countable items, may be decimal for weight-based items.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidedServiceChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Voided Service Charge Amount' ;
    rdfs:comment 'Service charge or gratuity amount associated with the voided transaction that was reversed.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidedTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Voided Tax Amount' ;
    rdfs:comment 'Tax amount associated with the voided transaction or item that was reversed.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Voided Total Amount' ;
    rdfs:comment 'Total monetary value of the void including base amount, tax, and service charges. Net impact on revenue.' ;
    rdfs:domain ind:VoidTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteLogId rdf:type rdf:Property ;
    rdfs:label 'Waste Log Id' ;
    rdfs:comment 'Primary key for waste_log' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fnbInventoryItemId rdf:type rdf:Property ;
    rdfs:label 'Fnb Inventory Item Id' ;
    rdfs:comment 'Foreign key linking to fnb.inventory_item. Business justification: Waste log currently has waste_item_name and waste_item_code as strings but no FK to inventory_item master. Normalizing to inventory_item enables accurate waste cost tracking, inventory variance analys' ;
    rdfs:domain ind:Fnb ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryItem .

ind:primaryWasteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Employee Id' ;
    rdfs:comment 'Identifier of the staff member who recorded the waste event.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:foodCategory rdf:type rdf:Property ;
    rdfs:label 'Food Category' ;
    rdfs:comment 'The food category of the wasted item (protein, dairy, produce, bakery, dry goods, beverage, condiment, prepared dish) for detailed cost analysis. [ENUM-REF-CANDIDATE: protein|dairy|produce|bakery|dry_goods|beverage|condiment|prepared_dish — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthSafetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Health Safety Incident Flag' ;
    rdfs:comment 'Indicates whether the waste event was associated with a health or safety incident requiring regulatory reporting.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso22000CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 22000 Compliant Flag' ;
    rdfs:comment 'Indicates whether the waste event was handled in compliance with ISO 22000 food safety standards.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityWasted rdf:type rdf:Property ;
    rdfs:label 'Quantity Wasted' ;
    rdfs:comment 'The quantity of the item wasted, expressed in the unit of measure for the item.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordingStaffName rdf:type rdf:Property ;
    rdfs:label 'Recording Staff Name' ;
    rdfs:comment 'Name of the staff member who recorded the waste event.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Impact Flag' ;
    rdfs:comment 'Indicates whether this waste event has been flagged for sustainability impact reporting or waste reduction initiatives.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalWasteCost rdf:type rdf:Property ;
    rdfs:label 'Total Waste Cost' ;
    rdfs:comment 'The total cost of the waste event, calculated as quantity wasted multiplied by unit cost.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteDate rdf:type rdf:Property ;
    rdfs:label 'Waste Date' ;
    rdfs:comment 'The date on which the waste event was recorded, in format yyyy-MM-dd.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteStatus rdf:type rdf:Property ;
    rdfs:label 'Waste Status' ;
    rdfs:comment 'The current status of the waste log entry in the review and approval workflow (recorded, reviewed, approved, disputed, closed).' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waste Timestamp' ;
    rdfs:comment 'The precise date and time when the waste event occurred, in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wasteType rdf:type rdf:Property ;
    rdfs:label 'Waste Type' ;
    rdfs:comment 'The type of waste: food, beverage, supplies, or packaging.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wineCellarId rdf:type rdf:Property ;
    rdfs:label 'Wine Cellar Id' ;
    rdfs:comment 'Unique identifier for the wine cellar inventory record. Primary key for vintage-level wine and premium beverage tracking.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alcoholByVolumePct rdf:type rdf:Property ;
    rdfs:label 'Alcohol By Volume Pct' ;
    rdfs:comment 'Percentage of alcohol content by volume. Required for regulatory compliance and guest information.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appellation rdf:type rdf:Property ;
    rdfs:label 'Appellation' ;
    rdfs:comment 'Geographic region or appellation of origin (e.g., Napa Valley, Bordeaux, Tuscany). Indicates terroir and quality designation.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Physical storage location identifier within the wine cellar (e.g., rack number, bin code). Enables efficient retrieval and inventory management.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bottleSizeMl rdf:type rdf:Property ;
    rdfs:label 'Bottle Size Ml' ;
    rdfs:comment 'Volume of the bottle in milliliters (e.g., 750, 1500, 375). Standard bottle is 750ml.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:byTheGlassProgramFlag rdf:type rdf:Property ;
    rdfs:label 'By The Glass Program Flag' ;
    rdfs:comment 'Indicates whether this wine is available for individual glass pours. True if offered by the glass, False if bottle-only.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code of the wine\'s origin (e.g., USA, FRA, ITA, AUS).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodPairingRecommendations rdf:type rdf:Property ;
    rdfs:label 'Food Pairing Recommendations' ;
    rdfs:comment 'Suggested food pairings and menu items that complement the wine. Supports upselling and guest experience enhancement.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle status of the wine in the cellar inventory. Determines availability for ordering and wine list inclusion.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInventoryCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Inventory Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count for this wine. Supports audit trail and shrinkage analysis.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optimalDrinkingWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Optimal Drinking Window End' ;
    rdfs:comment 'Year when the wine is expected to pass its peak drinking quality. Guides inventory rotation and promotional timing.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimalDrinkingWindowStart rdf:type rdf:Property ;
    rdfs:label 'Optimal Drinking Window Start' ;
    rdfs:comment 'Year when the wine is expected to reach optimal maturity for consumption. Supports cellar aging strategy.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:producerName rdf:type rdf:Property ;
    rdfs:label 'Producer Name' ;
    rdfs:comment 'Name of the winery, vineyard, or producer who created the wine.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseCostPerBottle rdf:type rdf:Property ;
    rdfs:label 'Purchase Cost Per Bottle' ;
    rdfs:comment 'Unit cost paid to supplier per bottle. Used for inventory valuation and food cost calculations.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current number of bottles available in inventory. Updated by receipts, sales, and adjustments.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Number of bottles reserved for upcoming events, banquets, or special orders. Not available for general sale.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingSource rdf:type rdf:Property ;
    rdfs:label 'Rating Source' ;
    rdfs:comment 'Name of the publication or critic who provided the wine rating (e.g., Wine Spectator, Wine Advocate, Decanter).' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'Standard quantity to order when inventory reaches par level. Optimized for supplier minimums and storage capacity.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellingPriceBottle rdf:type rdf:Property ;
    rdfs:label 'Selling Price Bottle' ;
    rdfs:comment 'Retail price charged to guests for a full bottle. Supports revenue management and menu pricing.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellingPriceGlass rdf:type rdf:Property ;
    rdfs:label 'Selling Price Glass' ;
    rdfs:comment 'Retail price charged to guests for a single glass pour. Applicable for by-the-glass program wines.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sommelierNotes rdf:type rdf:Property ;
    rdfs:label 'Sommelier Notes' ;
    rdfs:comment 'Internal notes from the sommelier regarding optimal serving temperature, decanting requirements, aging potential, or special handling instructions.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Celsius' ;
    rdfs:comment 'Recommended storage temperature in Celsius for optimal preservation. Supports cellar climate control compliance.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the distributor or supplier from whom the wine is purchased.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tastingNotes rdf:type rdf:Property ;
    rdfs:label 'Tasting Notes' ;
    rdfs:comment 'Sommelier-curated description of the wine\'s flavor profile, aroma, body, and finish. Used for wine list descriptions and staff training.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varietal rdf:type rdf:Property ;
    rdfs:label 'Varietal' ;
    rdfs:comment 'Grape variety or blend composition (e.g., Cabernet Sauvignon, Chardonnay, Bordeaux Blend).' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'Year the grapes were harvested. Critical for vintage-level tracking and valuation. Non-vintage wines may use a standard code (e.g., 9999).' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wineListCategory rdf:type rdf:Property ;
    rdfs:label 'Wine List Category' ;
    rdfs:comment 'Classification for wine list organization and guest navigation. Supports menu design and pricing strategy.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wineName rdf:type rdf:Property ;
    rdfs:label 'Wine Name' ;
    rdfs:comment 'Full name of the wine as it appears on the label and wine list.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wineRatingScore rdf:type rdf:Property ;
    rdfs:label 'Wine Rating Score' ;
    rdfs:comment 'Professional critic rating or score (e.g., Wine Spectator, Robert Parker). Typically on a 100-point scale. Used for marketing and wine list positioning.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wineType rdf:type rdf:Property ;
    rdfs:label 'Wine Type' ;
    rdfs:comment 'Classification of wine by style and production method.' ;
    rdfs:domain ind:WineCellar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentAuditTrail rdf:type rdf:Property ;
    rdfs:label 'Consent Audit Trail' ;
    rdfs:comment 'Structured or semi-structured audit trail capturing the history of consent changes, including who made changes, when, and why. May be JSON or delimited text format.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentCaptureUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Capture Url' ;
    rdfs:comment 'The URL of the web page or application screen where the consent was captured. Helps trace back to the exact consent form version and context.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which the consent expires and must be re-confirmed. Null for consents without expiration. Some jurisdictions and internal policies require periodic re-consent.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Consent Granted Date' ;
    rdfs:comment 'The date on which the guest provided explicit consent for the specified communication type and purpose. Critical for GDPR and CCPA compliance audit trails.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentGrantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Granted Timestamp' ;
    rdfs:comment 'Precise timestamp when consent was granted, including time zone information. Provides granular audit trail for regulatory compliance.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Consent Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the consent was presented and captured. Required for demonstrating informed consent in the guest native language.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The mechanism by which consent was captured. Distinguishes between explicit opt-in (GDPR-compliant), implicit opt-in, pre-checked box (non-compliant in many jurisdictions), verbal consent, written consent, or electronic signature.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentNotes rdf:type rdf:Property ;
    rdfs:label 'Consent Notes' ;
    rdfs:comment 'Free-text notes providing additional context about the consent record. May include details about special circumstances, guest requests, or staff observations during consent capture.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentPurpose rdf:type rdf:Property ;
    rdfs:label 'Consent Purpose' ;
    rdfs:comment 'The business purpose for which the communication consent applies. Examples include marketing campaigns, promotional offers, transactional notifications, service updates, loyalty program communications, and guest satisfaction surveys.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The channel or touchpoint through which the guest provided or withdrew consent. Examples include web form, mobile app, front desk during check-in, call center, email preference link, CRM manual entry by staff, loyalty program enrollment, or booking engine. [ENUM-REF-CANDIDATE: web_form|mobile_app|front_desk|call_center|email_link|crm_manual_entry|loyalty_enrollment|booking_engine — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current status of the guest consent. Indicates whether the guest has opted in, opted out, has a pending consent request, or if consent has expired or been revoked.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTextVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Text Version' ;
    rdfs:comment 'Version identifier of the consent text or privacy policy that was presented to the guest at the time of consent. Enables audit trail of what terms the guest agreed to.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The communication channel or method for which consent is being tracked. Distinguishes between marketing email, transactional email, SMS, push notifications, postal mail, and phone calls.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentWithdrawnDate rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawn Date' ;
    rdfs:comment 'The date on which the guest withdrew or revoked their consent. Null if consent has not been withdrawn. Required for right-to-withdraw compliance under GDPR Article 7(3).' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentWithdrawnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawn Timestamp' ;
    rdfs:comment 'Precise timestamp when consent was withdrawn, including time zone information. Null if consent remains active. Critical for immediate suppression of communications.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmConsentReference rdf:type rdf:Property ;
    rdfs:label 'Crm Consent Reference' ;
    rdfs:comment 'The unique consent record identifier from the source CRM system (Salesforce). Used for traceability and reconciliation with the operational system of record.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed Timestamp' ;
    rdfs:comment 'Timestamp when the guest confirmed their consent via double opt-in mechanism (e.g., clicked email confirmation link). Null if double opt-in was not used or not yet confirmed.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doubleOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Flag' ;
    rdfs:comment 'Indicates whether the consent was confirmed through a double opt-in process (e.g., email confirmation link). True if double opt-in was completed, False otherwise. Best practice for email marketing consent.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestCountryCode rdf:type rdf:Property ;
    rdfs:label 'Guest Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the guest primary country of residence at the time consent was captured. Used to determine applicable privacy regulations.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCloudSubscriberKey rdf:type rdf:Property ;
    rdfs:label 'Marketing Cloud Subscriber Key' ;
    rdfs:comment 'The subscriber key from Salesforce Marketing Cloud or equivalent marketing automation platform. Links consent records to email marketing subscriber profiles for suppression list management.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profilingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Profiling Consent Flag' ;
    rdfs:comment 'Indicates whether the guest has consented to automated profiling and decision-making for personalized marketing and offers. Required under GDPR Article 22.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Record Active Flag' ;
    rdfs:comment 'Indicates whether this consent record is currently active and should be used for consent enforcement. False if the record has been superseded or logically deleted.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionListFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression List Flag' ;
    rdfs:comment 'Indicates whether this guest and communication type combination is currently on the suppression list (opted out or consent withdrawn). True if suppressed, False if active consent.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartySharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether the guest has consented to sharing their personal data with third-party partners (e.g., OTA partners, co-branded loyalty programs). True if consented, False otherwise.' ;
    rdfs:domain ind:CommunicationConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'The browser or application user agent string captured at the time of consent submission. Provides additional context for consent authenticity verification.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactInfoId rdf:type rdf:Property ;
    rdfs:label 'Contact Info Id' ;
    rdfs:comment 'Unique surrogate identifier for each guest contact information record in the Silver Layer lakehouse. Primary key for the contact_info data product. Sourced from Salesforce CRM and Oracle OPERA PMS guest profile modules.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line for the guest\'s mailing, billing, or home address. Includes street number and street name. Used for billing correspondence, loyalty program mailings, and address validation. Sourced from OPERA PMS and Salesforce CRM.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary street address line for the guest\'s postal address. Captures apartment number, suite, floor, building name, or other secondary address components. Optional field used when the primary address line is insufficient.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the postal address indicating its purpose: home residence, billing address for invoices and folios, mailing address for correspondence, or work/corporate address. Determines which address is used for loyalty program mailings and billing statements.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidatedDate rdf:type rdf:Property ;
    rdfs:label 'Address Validated Date' ;
    rdfs:comment 'Date on which the postal address was last validated against an authoritative address verification service. Used to determine whether re-validation is required based on data freshness policies and returned mail events.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Status of the postal address validation check performed against authoritative address databases (e.g., USPS, Royal Mail, Canada Post). Validated addresses improve direct mail deliverability and reduce returned loyalty program correspondence.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bounceReason rdf:type rdf:Property ;
    rdfs:label 'Bounce Reason' ;
    rdfs:comment 'Reason code for why a contact record has been marked as bounced or undeliverable. Hard bounces indicate permanent delivery failures (invalid email/address); soft bounces indicate temporary failures. Used to maintain list hygiene and comply with email deliverability best practices.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactChannel rdf:type rdf:Property ;
    rdfs:label 'Contact Channel' ;
    rdfs:comment 'The communication channel category this contact record represents: email, phone, postal address, social media handle, or digital messaging platform. Enables multi-channel guest communication strategy and analytics.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of this contact record. Active records are used for communications; bounced or undeliverable records indicate failed delivery attempts; suppressed records are excluded from all outbound communications per regulatory or guest request. Sourced from Salesforce CRM and OPERA PMS.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact record indicating its role relative to the guest profile. Determines which record is used for reservation confirmations, marketing communications, billing, and emergency notifications. [ENUM-REF-CANDIDATE: primary|secondary|work|home|billing|emergency — promote to reference product if additional types are required]' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date on which this contact record is scheduled for deletion or anonymization per the applicable data retention policy. Calculated based on the last guest interaction date plus the retention period defined by GDPR, CCPA, or local data protection regulations. Supports automated data lifecycle management.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates that the guest has explicitly requested no contact via this channel, regardless of opt-in status. Overrides all marketing and transactional communication flags. Must be honored immediately upon receipt per GDPR Article 21 (right to object) and CCPA.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailType rdf:type rdf:Property ;
    rdfs:label 'Email Type' ;
    rdfs:comment 'Classification of the email address indicating whether it is a personal, work/corporate, or other email account. Supports segmentation for FIT versus corporate guest communications and loyalty program targeting.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'The GDPR Article 6 lawful basis under which this contact record is processed. Required for all guest contact data belonging to EU/EEA residents. Consent is the most common basis for marketing; contract is the basis for transactional communications related to reservations.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this contact record is the designated primary contact for the guest within its channel type. Only one record per guest per channel should be flagged as primary. Used by CRS and PMS for reservation confirmations and pre-arrival communications.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether this contact record has been verified through a confirmation process (e.g., email verification link, phone OTP, address validation). Verified contacts have higher data quality confidence and are preferred for critical communications such as reservation confirmations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the guest\'s postal address in decimal degrees (WGS 84 datum). Supports geocoded feeder market analysis, drive-time radius marketing campaigns, and property proximity analytics for targeted offers.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the guest\'s postal address in decimal degrees (WGS 84 datum). Used in conjunction with latitude for geocoded feeder market analysis, proximity-based marketing, and demand origin mapping.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the guest has provided explicit consent to receive marketing communications via this contact channel. True = opted in; False = opted out or no consent given. Mandatory for GDPR and CCPA compliance. Drives suppression lists in Salesforce CRM marketing campaigns.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Date' ;
    rdfs:comment 'Date on which the guest provided explicit consent to receive marketing communications via this contact channel. Required for GDPR audit trail and consent management. Stored to demonstrate lawful basis for processing under GDPR Article 6.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingOptOutDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt Out Date' ;
    rdfs:comment 'Date on which the guest withdrew consent or opted out of marketing communications via this contact channel. Required for GDPR and CCPA compliance audit trail. Once set, this contact record must be excluded from all outbound marketing campaigns.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:messagingHandle rdf:type rdf:Property ;
    rdfs:label 'Messaging Handle' ;
    rdfs:comment 'Guest\'s account identifier or phone number on the specified digital messaging platform. Used to initiate pre-arrival, in-stay, and post-stay communications via messaging channels. Subject to GDPR and CCPA as a digital contact identifier.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messagingPlatform rdf:type rdf:Property ;
    rdfs:label 'Messaging Platform' ;
    rdfs:comment 'Digital messaging platform through which the guest can be contacted (e.g., WhatsApp, WeChat, LINE, SMS). Supports pre-arrival messaging, in-stay service requests, and post-stay follow-up communications per guest opt-in preferences.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInSource rdf:type rdf:Property ;
    rdfs:label 'Opt In Source' ;
    rdfs:comment 'The channel or touchpoint through which the guest provided their marketing or transactional communication consent. Used for consent audit trails and channel attribution analysis. [ENUM-REF-CANDIDATE: web|mobile_app|front_desk|call_center|ota|loyalty_enrollment|other — promote to reference product if additional sources are required]' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneCountryCode rdf:type rdf:Property ;
    rdfs:label 'Phone Country Code' ;
    rdfs:comment 'International dialing country code prefix for the guest phone number (e.g., +1 for USA, +44 for UK). Stored separately to support international call routing and country-level analytics. Conforms to ITU-T E.164 country code standards.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneType rdf:type rdf:Property ;
    rdfs:label 'Phone Type' ;
    rdfs:comment 'Classification of the phone number indicating whether it is a mobile, home, work, or fax number. Determines eligibility for SMS marketing communications and pre-arrival text notifications per guest opt-in preferences.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialHandle rdf:type rdf:Property ;
    rdfs:label 'Social Handle' ;
    rdfs:comment 'Guest\'s username or handle on the specified social media platform. Used for social CRM engagement, service recovery via social channels, and digital marketing personalization. Subject to GDPR and CCPA as a digital identifier.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialPlatform rdf:type rdf:Property ;
    rdfs:label 'Social Platform' ;
    rdfs:comment 'Name of the social media platform associated with the guest\'s social handle or digital identity record. Used for social CRM integration, guest experience personalization, and digital marketing channel attribution. [ENUM-REF-CANDIDATE: twitter|instagram|facebook|linkedin|wechat|line|tiktok|other — promote to reference product if additional platforms are required]' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the guest\'s postal address per ISO 3166-2 subdivision codes. Used for regional marketing segmentation, tax jurisdiction determination, and CCPA compliance scope identification.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionalOptIn rdf:type rdf:Property ;
    rdfs:label 'Transactional Opt In' ;
    rdfs:comment 'Indicates whether the guest has consented to receive transactional communications (reservation confirmations, folio receipts, check-in instructions) via this contact channel. Distinct from marketing opt-in; transactional messages may have a separate legal basis under GDPR.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verifiedDate rdf:type rdf:Property ;
    rdfs:label 'Verified Date' ;
    rdfs:comment 'Date on which this contact record was last verified through a confirmation process. Used to assess data freshness and trigger re-verification workflows when contact data exceeds the data quality policy threshold.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Account Manager Email' ;
    rdfs:comment 'Internal email address of the hotel group\'s account manager assigned to this corporate account. Used for escalation routing, contract renewal notifications, and CRM workflow automation.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerName rdf:type rdf:Property ;
    rdfs:label 'Account Manager Name' ;
    rdfs:comment 'Full name of the hotel group\'s internal account manager or sales manager responsible for managing the corporate relationship, contract renewals, and production performance.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'Target total revenue (rooms, Food and Beverage (F&B), events) expected from this corporate account in the contract year. Used for account manager performance tracking and revenue budget planning per USALI standards.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRoomNightTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Room Night Target' ;
    rdfs:comment 'Contracted or projected annual room night volume committed by the corporate client. Used for account tiering, rate negotiation leverage, and production performance tracking against actuals.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAddressCity rdf:type rdf:Property ;
    rdfs:label 'Billing Address City' ;
    rdfs:comment 'City component of the corporate client\'s billing address. Used for invoice generation, tax jurisdiction determination, and geographic segmentation reporting.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Address Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the corporate client\'s billing address. Drives tax treatment, currency defaults, and regulatory compliance requirements (GDPR for EU entities).' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutDatesPolicy rdf:type rdf:Property ;
    rdfs:label 'Blackout Dates Policy' ;
    rdfs:comment 'Description or reference code for blackout date restrictions applicable to this corporate account\'s negotiated rates. Specifies periods (e.g., peak demand, special events) when contracted rates are not available.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Full legal registered name of the corporate client organization as it appears on contracts, invoices, and billing documents.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit and billing amounts are denominated for this corporate account (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding balance permitted on the corporate account\'s direct billing (city ledger) facility in the OPERA AR module. Enforced at check-in and during reservation creation to prevent credit overexposure.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmAccountReference rdf:type rdf:Property ;
    rdfs:label 'Crm Account Reference' ;
    rdfs:comment 'External account identifier from Salesforce CRM, used to cross-reference the corporate account record with the CRM system of record for guest profiles and marketing campaigns.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyConsent rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent' ;
    rdfs:comment 'Indicates whether the corporate contact has provided consent for processing of their personal data in accordance with GDPR and CCPA requirements. Required for marketing communications and data sharing with third-party partners.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Direct Billing Enabled' ;
    rdfs:comment 'Indicates whether this corporate account is approved for direct billing (city ledger) to the hotel group. When true, eligible charges are posted to the AR account rather than requiring individual guest payment at checkout.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Percentage discount off the Best Available Rate (BAR) or rack rate granted to this corporate account under the negotiated agreement. Used by the Revenue Management System (RMS) for displacement analysis and yield optimization.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprDataSubjectRegion rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Subject Region' ;
    rdfs:comment 'Regulatory jurisdiction applicable to the corporate contact\'s personal data. Determines which privacy regulations govern data handling, retention, and subject rights requests (GDPR for EU/UK, CCPA for California).' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryNaicsCode rdf:type rdf:Property ;
    rdfs:label 'Industry Naics Code' ;
    rdfs:comment 'Six-digit NAICS code providing a more granular industry classification for the corporate client, used alongside SIC for regulatory reporting, procurement analysis, and revenue segmentation.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySicCode rdf:type rdf:Property ;
    rdfs:label 'Industry Sic Code' ;
    rdfs:comment 'Four-digit Standard Industrial Classification (SIC) code identifying the primary industry sector of the corporate client. Used for market segmentation, demand analysis, and MICE opportunity targeting.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:losMinimumNights rdf:type rdf:Property ;
    rdfs:label 'Los Minimum Nights' ;
    rdfs:comment 'Minimum Length of Stay (LOS) requirement in nights applicable to this corporate account\'s negotiated rate. A value of 1 indicates no minimum stay restriction.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Eligible' ;
    rdfs:comment 'Indicates whether individual travelers booking under this corporate account are eligible to earn loyalty program points. Some negotiated rate codes exclude loyalty accrual per program terms.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:miceEligible rdf:type rdf:Property ;
    rdfs:label 'Mice Eligible' ;
    rdfs:comment 'Indicates whether this corporate account is eligible for MICE (Meetings, Incentives, Conferences, Exhibitions) group rates and event space allocations managed through Delphi by Amadeus.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiatedRateCode rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate Code' ;
    rdfs:comment 'Primary negotiated rate code assigned to this corporate account in the Central Reservation System (CRS) and Property Management System (PMS). Used for Best Available Rate (BAR) eligibility verification and rate distribution across channels.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operaArAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Opera Ar Account Number' ;
    rdfs:comment 'Accounts Receivable account number assigned in Oracle OPERA PMS AR module, used for direct billing, city ledger management, and credit limit enforcement at the property level.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPropertyCodes rdf:type rdf:Property ;
    rdfs:label 'Preferred Property Codes' ;
    rdfs:comment 'Comma-separated list of hotel property codes (from OPERA PMS) designated as preferred properties for this corporate account. Drives rate availability, inventory allocation, and channel distribution priority.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateProgramType rdf:type rdf:Property ;
    rdfs:label 'Rate Program Type' ;
    rdfs:comment 'Type of negotiated rate program governing this corporate account. LRA (Last Room Availability) guarantees rate access even at high occupancy. NRR (Non-Refundable Rate) offers deeper discounts with cancellation restrictions. Drives Revenue Management System (RMS) displacement analysis.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Status' ;
    rdfs:comment 'Tax exemption classification for this corporate account. Government and qualifying non-profit accounts may be fully or partially exempt from occupancy and sales taxes. Drives tax posting rules in OPERA PMS and SAP S/4HANA.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificate rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate' ;
    rdfs:comment 'Official tax exemption certificate number issued by the relevant tax authority for this corporate account. Required for audit compliance when applying tax-exempt billing. Stored for SOX and USALI audit trail purposes.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Doing-business-as (DBA) or brand name of the corporate client if different from the legal registered company name. Used for correspondence and guest-facing communications.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipTier rdf:type rdf:Property ;
    rdfs:label 'Vip Tier' ;
    rdfs:comment 'VIP tier classification assigned to this corporate account based on production volume, strategic importance, and revenue contribution. Drives service recovery priority, amenity entitlements, and account manager assignment level.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupLeaderProfileId rdf:type rdf:Property ;
    rdfs:label 'Group Leader Profile Id' ;
    rdfs:comment 'Reference to the guest profile of the primary group leader or organizer responsible for the block. Sourced from OPERA PMS guest profile or Salesforce CRM contact.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:masterArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Master Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: Group blocks generate master folios for group billing in MICE operations. Sales managers need to track which AR invoice represents the master account for group charges, deposits, and attrition billing' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:accessibleRoomsRequested rdf:type rdf:Property ;
    rdfs:label 'Accessible Rooms Requested' ;
    rdfs:comment 'Number of ADA-compliant accessible rooms requested within the group block. Tracked for ADA compliance and pre-assignment planning.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrivalDate rdf:type rdf:Property ;
    rdfs:label 'Arrival Date' ;
    rdfs:comment 'The first date of the contracted room block period — the date the group is scheduled to begin checking in. Serves as EFFECTIVE_FROM for this agreement.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attritionPct rdf:type rdf:Property ;
    rdfs:label 'Attrition Pct' ;
    rdfs:comment 'Contractual minimum pickup percentage the group must achieve to avoid attrition penalties. Expressed as a percentage (e.g., 80.00 means the group must pick up at least 80% of contracted rooms). Aligns with revenue.wash_factor domain.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingMasterFolioInstructions rdf:type rdf:Property ;
    rdfs:label 'Billing Master Folio Instructions' ;
    rdfs:comment 'Free-text instructions governing how charges are routed and settled for the group block master folio (e.g., \'Room and tax to master; incidentals to individual guest folio\', \'All F&B charges to master account\'). Sourced from OPERA PMS cashiering module.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complimentaryRoomsContracted rdf:type rdf:Property ;
    rdfs:label 'Complimentary Rooms Contracted' ;
    rdfs:comment 'Number of complimentary (comp) rooms included in the group block contract, typically awarded on a ratio basis (e.g., 1 comp per 40 paid rooms). Tracked separately for revenue accounting under USALI.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedDate rdf:type rdf:Property ;
    rdfs:label 'Contracted Date' ;
    rdfs:comment 'The date on which the group block contract was formally executed and the block status moved to \'Definite\'. Represents the BUSINESS_EVENT_TIMESTAMP for the agreement lifecycle.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate Amount' ;
    rdfs:comment 'Negotiated room rate per night per room agreed in the group block contract. Expressed in the property\'s operating currency. Confidential commercial term.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedRoomNights rdf:type rdf:Property ;
    rdfs:label 'Contracted Room Nights' ;
    rdfs:comment 'Total number of room nights committed in the group block contract across all room types and all nights of the block period. Primary quantitative measure of block size.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delphiOpportunityReference rdf:type rdf:Property ;
    rdfs:label 'Delphi Opportunity Reference' ;
    rdfs:comment 'Source system identifier from Delphi by Amadeus event sales platform linking this group block to the originating sales opportunity or group proposal. Enables cross-system traceability.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureDate rdf:type rdf:Property ;
    rdfs:label 'Departure Date' ;
    rdfs:comment 'The last date of the contracted room block period — the date the group is scheduled to check out. Serves as EFFECTIVE_UNTIL for this agreement.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Received Amount' ;
    rdfs:comment 'Actual deposit amount received from the group organizer to date. Compared against deposit_required_amount to determine outstanding deposit balance.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositRequiredAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Required Amount' ;
    rdfs:comment 'Contractual deposit amount required from the group to confirm the block. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCode rdf:type rdf:Property ;
    rdfs:label 'Group Code' ;
    rdfs:comment 'Externally-known alphanumeric code used to identify the group block across systems (OPERA PMS, CRS, OTA channels). Used by guests and agents to associate individual reservations to the block. Serves as the BUSINESS_IDENTIFIER for this agreement.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'Human-readable name of the group (e.g., \'Smith Wedding Party\', \'Acme Corp Q3 Sales Conference\', \'Chicago Bulls Away Team\'). Displayed on folios, rooming lists, and internal reports.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupNotes rdf:type rdf:Property ;
    rdfs:label 'Group Notes' ;
    rdfs:comment 'Free-text operational notes and special instructions for the group block (e.g., VIP handling requirements, early check-in requests, amenity preferences, security arrangements). Sourced from OPERA PMS group block notes field.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupRateCode rdf:type rdf:Property ;
    rdfs:label 'Group Rate Code' ;
    rdfs:comment 'Rate plan code applied to individual reservations made under this group block. Links to the negotiated group rate in the revenue rate plan. Sourced from OPERA PMS and distributed via SynXis CRS.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Categorical classification of the group travel party type. Drives billing rules, rate eligibility, and operational handling. [ENUM-REF-CANDIDATE: tour|corporate|wedding|sports_team|airline_crew|government|other — promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operaBlockReference rdf:type rdf:Property ;
    rdfs:label 'Opera Block Reference' ;
    rdfs:comment 'Native block identifier from Oracle OPERA PMS Group Blocks module. Used for reconciliation and lineage tracing between the lakehouse silver layer and the operational source system.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakBlockRooms rdf:type rdf:Property ;
    rdfs:label 'Peak Block Rooms' ;
    rdfs:comment 'Maximum number of rooms blocked on any single night within the group block period. Used for capacity planning, displacement analysis, and revenue management evaluation.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repeatGroupFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Group Flag' ;
    rdfs:comment 'Indicates whether this group has stayed at the property in a prior year or period. Used for loyalty recognition, preferential rate negotiation, and retention analytics.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roomingListDueDate rdf:type rdf:Property ;
    rdfs:label 'Rooming List Due Date' ;
    rdfs:comment 'Contractual deadline by which the group organizer must submit the complete rooming list with individual guest names and room type preferences.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roomingListStatus rdf:type rdf:Property ;
    rdfs:label 'Rooming List Status' ;
    rdfs:comment 'Current status of the rooming list submission for this group block. Tracks whether the group organizer has provided individual guest names and room assignments required for pre-arrival processing.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomsPickedUp rdf:type rdf:Property ;
    rdfs:label 'Rooms Picked Up' ;
    rdfs:comment 'Current count of individual reservations made against the group block (actual pickup). Compared against contracted_room_nights to calculate pickup rate and attrition exposure.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceOfBusinessCode rdf:type rdf:Property ;
    rdfs:label 'Source Of Business Code' ;
    rdfs:comment 'Code identifying the channel or origin through which the group business was sourced (e.g., direct sales, GDS, OTA, travel agent, repeat group). Used for channel contribution analysis.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteBlockRooms rdf:type rdf:Property ;
    rdfs:label 'Suite Block Rooms' ;
    rdfs:comment 'Number of suite-category rooms included in the contracted block. Tracked separately from standard rooms for inventory management and upsell reporting.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vipFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Flag' ;
    rdfs:comment 'Indicates whether this group block has been designated as VIP, triggering elevated service protocols, dedicated concierge assignment, and executive-level attention.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:washPct rdf:type rdf:Property ;
    rdfs:label 'Wash Pct' ;
    rdfs:comment 'Estimated percentage of contracted rooms expected to be released back to general inventory based on historical pickup patterns for this group type. Used by revenue management for net block sizing and forecasting.' ;
    rdfs:domain ind:GuestGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noteAssignedStaffEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Note Assigned Staff Employee Id' ;
    rdfs:comment 'Reference to the specific staff member assigned to action or follow up on this note. Null if assigned to a department rather than an individual.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:noteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Note Employee Id' ;
    rdfs:comment 'Reference to the staff member (employee) who created the note. Enables accountability tracking and follow-up assignment.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:noteResolvedByStaffEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Note Resolved By Staff Employee Id' ;
    rdfs:comment 'Reference to the staff member who marked the note as resolved. Enables accountability and service recovery performance measurement.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'The specific hotel business date on which the note action or trace is scheduled to be executed (e.g., the date a pre-arrival amenity should be placed). Distinct from expiry_date which governs visibility.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authoringDepartment rdf:type rdf:Property ;
    rdfs:label 'Authoring Department' ;
    rdfs:comment 'The hotel department that created the note (e.g., Front Desk, Housekeeping, Food and Beverage, Concierge, Revenue Management, Security, Guest Relations). Used for departmental accountability and routing of action items. [ENUM-REF-CANDIDATE: front_desk|housekeeping|food_and_beverage|concierge|revenue_management|security|guest_relations|reservations|engineering — promote to reference product]' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionCategory rdf:type rdf:Property ;
    rdfs:label 'Data Retention Category' ;
    rdfs:comment 'Classification governing how long this note record must be retained per data governance policy. Standard follows default retention schedules; extended applies to VIP or legal-relevant notes; legal_hold prevents deletion during litigation; purge_eligible marks records ready for deletion.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOnCheckin rdf:type rdf:Property ;
    rdfs:label 'Display On Checkin' ;
    rdfs:comment 'Indicates whether this note should be automatically surfaced to front desk staff during the guest check-in process. True = display at check-in; False = do not auto-display. Supports pre-arrival briefing and service personalization.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayOnCheckout rdf:type rdf:Property ;
    rdfs:label 'Display On Checkout' ;
    rdfs:comment 'Indicates whether this note should be surfaced to front desk staff during the guest check-out process. True = display at check-out; False = do not auto-display. Useful for billing alerts or follow-up actions at departure.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayOnReservation rdf:type rdf:Property ;
    rdfs:label 'Display On Reservation' ;
    rdfs:comment 'Indicates whether this note should be surfaced to reservations agents when a new booking is made for this guest. True = display during reservation creation; False = do not auto-display. Supports proactive service planning.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the guest has provided consent for this type of personal preference data to be stored and processed under GDPR Article 6. True = consent obtained; False = consent not obtained or withdrawn. Critical for EU/EEA guest data compliance.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Indicates whether the note content is restricted to management-level staff only and should not be visible to all front-line employees. True = management-only visibility; False = visible to all authorized staff.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVipAlert rdf:type rdf:Property ;
    rdfs:label 'Is Vip Alert' ;
    rdfs:comment 'Indicates whether this note is specifically flagged as a VIP protocol alert requiring elevated service standards. True = VIP alert; False = standard note. Drives VIP pre-arrival briefing workflows.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noteCategory rdf:type rdf:Property ;
    rdfs:label 'Note Category' ;
    rdfs:comment 'Secondary classification providing finer-grained grouping within a note type (e.g., Room Preference, Dietary Restriction, Billing Alert, VIP Protocol, Housekeeping Instruction, Security Alert). Sourced from OPERA trace/alert category codes. [ENUM-REF-CANDIDATE: room_preference|dietary|billing|vip_protocol|housekeeping|security|loyalty|accessibility|transport — promote to reference product]' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteDate rdf:type rdf:Property ;
    rdfs:label 'Note Date' ;
    rdfs:comment 'The business date on which the note was created, aligned to the hotel operational date (which may differ from the calendar date for overnight shifts). Used for daily operations reporting (DOR) and pre-arrival briefing.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noteStatus rdf:type rdf:Property ;
    rdfs:label 'Note Status' ;
    rdfs:comment 'Current lifecycle state of the note. Active notes are visible and actionable; resolved notes have been actioned; expired notes have passed their expiry date; cancelled notes were voided by staff; pending notes are awaiting review or approval.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteText rdf:type rdf:Property ;
    rdfs:label 'Note Text' ;
    rdfs:comment 'Full freeform text body of the note or alert as entered by property staff. Contains the detailed narrative, instruction, or observation. Classified as confidential as it may contain sensitive guest behavioral or preference information.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteType rdf:type rdf:Property ;
    rdfs:label 'Note Type' ;
    rdfs:comment 'Classification of the note indicating its business purpose. Preference captures guest likes/dislikes; complaint records a service failure; compliment records positive feedback; alert flags an operational action required; trace is a time-bound task or follow-up; general is unclassified. [ENUM-REF-CANDIDATE: preference|complaint|compliment|alert|trace|general — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operaTraceReference rdf:type rdf:Property ;
    rdfs:label 'Opera Trace Reference' ;
    rdfs:comment 'Source system identifier for the trace or alert record as assigned by Oracle OPERA PMS. Used for reconciliation and lineage tracing back to the operational system of record.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Flag' ;
    rdfs:comment 'Indicates whether this note is marked as high priority, requiring immediate staff attention or pre-arrival action. True = high priority; False = standard priority.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this note should automatically recur on every future stay for this guest (True) or is a one-time note (False). Supports persistent preference management for repeat guests.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Defines whether the note is visible only at the originating property (property) or across all properties in the chain (chain). Chain-wide notes support cross-property service continuity for loyalty and VIP guests.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stayDateContext rdf:type rdf:Property ;
    rdfs:label 'Stay Date Context' ;
    rdfs:comment 'The specific stay date or arrival date to which this note is contextually relevant. Used for time-bound notes that apply only during a particular stay window rather than the guest\'s entire profile history.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:captureChannel rdf:type rdf:Property ;
    rdfs:label 'Capture Channel' ;
    rdfs:comment 'Channel or touchpoint through which the identity document was captured. Values: front_desk (traditional check-in), mobile_checkin (mobile app), kiosk (self-service kiosk), online_precheckin (web portal), concierge (concierge desk).' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'Date and time when the identity document information was first captured into the system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Represents the business event time of document capture.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this document record meets all regulatory compliance requirements for the jurisdiction. True if compliant, False if additional documentation or verification is required.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Guest date of birth as recorded on the identity document. Format: yyyy-MM-dd. Used for age verification and compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentScanReference rdf:type rdf:Property ;
    rdfs:label 'Document Scan Reference' ;
    rdfs:comment 'Reference identifier or file path to the scanned image or digital copy of the identity document stored in the document management system. Used for audit and compliance verification.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Document Scan Timestamp' ;
    rdfs:comment 'Date and time when the identity document was scanned or digitally captured. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fullNameOnDocument rdf:type rdf:Property ;
    rdfs:label 'Full Name On Document' ;
    rdfs:comment 'Complete legal name as printed on the identity document. Used for verification and compliance purposes to match against guest profile name.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Gender marker as recorded on the identity document. Values: M (Male), F (Female), X (Unspecified/Non-binary), U (Unknown/Not stated).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentReportStatus rdf:type rdf:Property ;
    rdfs:label 'Government Report Status' ;
    rdfs:comment 'Status of government reporting submission for this identity document. Values: not_required (no reporting obligation), pending (awaiting submission), submitted (sent to authorities), confirmed (acknowledged by authorities), failed (submission error).' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentReportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Government Report Timestamp' ;
    rdfs:comment 'Date and time when the identity document information was reported to government authorities. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Null if not yet reported or not required.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:governmentReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Government Reporting Required' ;
    rdfs:comment 'Boolean flag indicating whether this identity document record must be reported to government authorities per local regulations (e.g., police registration, immigration reporting). True if reporting is required, False otherwise.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryDocument rdf:type rdf:Property ;
    rdfs:label 'Is Primary Document' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary identity document on file for the guest. True if this is the main document used for identification, False otherwise.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the country or jurisdiction that issued the identity document.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalityCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the guests nationality as stated on the identity document.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfBirth rdf:type rdf:Property ;
    rdfs:label 'Place Of Birth' ;
    rdfs:comment 'City and country of birth as recorded on the identity document. Used for enhanced identity verification in some jurisdictions.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current verification status of the identity document. Indicates whether the document has been validated by staff or automated systems. Values: pending (awaiting verification), verified (validated and accepted), rejected (invalid or fraudulent), expired (document past expiry date), flagged (requires additional review).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Date and time when the identity document verification was completed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visaEntryType rdf:type rdf:Property ;
    rdfs:label 'Visa Entry Type' ;
    rdfs:comment 'Entry type permitted by the visa. Values: single (one entry only), multiple (multiple entries allowed), transit (transit visa). Null for non-visa documents.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaType rdf:type rdf:Property ;
    rdfs:label 'Visa Type' ;
    rdfs:comment 'Type or category of visa if the document is a visa (e.g., tourist, business, student, work). Null for non-visa documents.' ;
    rdfs:domain ind:IdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeValueId rdf:type rdf:Property ;
    rdfs:label 'Lifetime Value Id' ;
    rdfs:comment 'Unique identifier for the guest lifetime value record. Primary key.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageDailyRate rdf:type rdf:Property ;
    rdfs:label 'Average Daily Rate' ;
    rdfs:comment 'The guest\'s average daily rate across all stays, calculated as total room revenue divided by total room nights. Key pricing metric for guest segmentation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageGssScore rdf:type rdf:Property ;
    rdfs:label 'Average Gss Score' ;
    rdfs:comment 'The guest\'s average Guest Satisfaction Score across all completed satisfaction surveys. Typically measured on a 1-10 scale. Key quality metric.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLengthOfStay rdf:type rdf:Property ;
    rdfs:label 'Average Length Of Stay' ;
    rdfs:comment 'The guest\'s average length of stay in nights, calculated as total room nights divided by total stays. Indicates booking behavior pattern.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageNpsScore rdf:type rdf:Property ;
    rdfs:label 'Average Nps Score' ;
    rdfs:comment 'The guest\'s average Net Promoter Score across all completed NPS surveys. Ranges from -100.00 to 100.00. Measures guest satisfaction and advocacy.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageRevenuePerStay rdf:type rdf:Property ;
    rdfs:label 'Average Revenue Per Stay' ;
    rdfs:comment 'The guest\'s average total revenue per stay, calculated as total revenue divided by total stays. Measures spend intensity per visit.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The methodology used to calculate this LTV record: historical (cumulative actuals only), predictive (forecast-based), or hybrid (actuals plus forecast).' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Flag' ;
    rdfs:comment 'Boolean indicator (True/False) signaling whether the guest is at risk of churn based on declining engagement, negative feedback, or extended time since last stay.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Numeric score (0.0000 to 1.0000) quantifying the probability of guest churn within the next 12 months. Higher scores indicate higher churn risk.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Score (0.00 to 100.00) representing the completeness and accuracy of the underlying guest data used in this LTV calculation. Higher scores indicate higher confidence.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSinceLastStay rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Stay' ;
    rdfs:comment 'Number of days elapsed between the most recent stay date and the LTV calculation date. Recency metric used in churn risk assessment.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstStayDate rdf:type rdf:Property ;
    rdfs:label 'First Stay Date' ;
    rdfs:comment 'The date of the guest\'s first recorded stay across all properties and brands. Marks the beginning of the guest relationship lifecycle.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guestTenureDays rdf:type rdf:Property ;
    rdfs:label 'Guest Tenure Days' ;
    rdfs:comment 'Number of days between the first stay date and the LTV calculation date. Represents the total duration of the guest relationship.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyTierCode rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Code' ;
    rdfs:comment 'Current loyalty program tier of the guest (e.g., member, silver, gold, platinum, ambassador). Influenced by LTV tier and total stays.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltvScore rdf:type rdf:Property ;
    rdfs:label 'Ltv Score' ;
    rdfs:comment 'Numeric score representing the guest\'s lifetime value, calculated using a proprietary algorithm combining historical revenue, recency, frequency, and predicted future value.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ltvTier rdf:type rdf:Property ;
    rdfs:label 'Ltv Tier' ;
    rdfs:comment 'Classification tier assigned to the guest based on total revenue and engagement metrics. Drives VIP designation and loyalty program benefits.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mostRecentStayDate rdf:type rdf:Property ;
    rdfs:label 'Most Recent Stay Date' ;
    rdfs:comment 'The date of the guest\'s most recent completed stay across all properties and brands. Used to calculate recency metrics.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextStayPropensityScore rdf:type rdf:Property ;
    rdfs:label 'Next Stay Propensity Score' ;
    rdfs:comment 'Predictive score (0.0000 to 1.0000) indicating the likelihood that the guest will book another stay within the next 12 months. Generated by CRM predictive analytics.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredBrandCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Brand Code' ;
    rdfs:comment 'Code representing the brand (luxury, premium, select-service) where the guest has generated the most revenue or stays. Drives brand affinity analysis.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projected12mRevenue rdf:type rdf:Property ;
    rdfs:label 'Projected 12m Revenue' ;
    rdfs:comment 'Forecasted revenue expected from this guest over the next 12 months, calculated using predictive models based on historical patterns and propensity scores.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAncillaryRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Ancillary Revenue' ;
    rdfs:comment 'Cumulative ancillary revenue from spa, golf, parking, resort fees, and other non-room, non-F&B services purchased by this guest.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalComplaints rdf:type rdf:Property ;
    rdfs:label 'Total Complaints' ;
    rdfs:comment 'Cumulative count of formal complaints or service recovery cases logged for this guest across all properties. Impacts churn risk and service recovery prioritization.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFbRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Fb Revenue' ;
    rdfs:comment 'Cumulative food and beverage revenue generated by this guest across all properties, including restaurants, bars, room service, and banquets.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRoomRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Room Revenue' ;
    rdfs:comment 'Cumulative room revenue generated by this guest across all properties and brands, excluding taxes and fees. Primary revenue component of LTV.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStays rdf:type rdf:Property ;
    rdfs:label 'Total Stays' ;
    rdfs:comment 'Cumulative count of completed stays by this guest across all properties and brands since first stay date.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for a guest preference record in the Silver Layer lakehouse. Primary key for the preference data product within the guest domain.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Preference .

ind:stayHistoryId rdf:type rdf:Property ;
    rdfs:label 'Stay History Id' ;
    rdfs:comment 'Reference to the specific stay or reservation during which this preference was captured or last confirmed. Enables preference-to-stay linkage for analytics on preference fulfillment rates and guest satisfaction correlation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StayHistory .

ind:allergyDetail rdf:type rdf:Property ;
    rdfs:label 'Allergy Detail' ;
    rdfs:comment 'Specific description of the guest\'s food or environmental allergy (e.g., \'severe peanut allergy - anaphylactic\', \'shellfish allergy\', \'latex allergy\'). Classified as restricted health information under GDPR and CCPA. Triggers mandatory F&B and housekeeping alerts. Only populated when is_allergy = True.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityPreferences rdf:type rdf:Property ;
    rdfs:label 'Amenity Preferences' ;
    rdfs:comment 'Guest\'s stated preferences for in-room amenities and welcome items (e.g., \'extra towels\', \'foam bath products\', \'specific brand toiletries\', \'fruit basket\', \'champagne on arrival\'). Free-form text to accommodate the wide variety of amenity requests. Communicated to housekeeping and concierge for pre-arrival setup.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedTypePreference rdf:type rdf:Property ;
    rdfs:label 'Bed Type Preference' ;
    rdfs:comment 'Guest\'s stated preference for bed configuration in their room. Sourced from OPERA PMS guest profile and used during room assignment to match available inventory. Supports pre-arrival preparation and upsell opportunity identification. [ENUM-REF-CANDIDATE: king|queen|double|twin|single|rollaway|no_preference — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannelPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Channel Preference' ;
    rdfs:comment 'Guest\'s preferred channel for receiving hotel communications including pre-arrival messages, in-stay notifications, and post-stay follow-up. Drives marketing and operational communication routing in Salesforce CRM. Supports GDPR and CCPA consent management.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the guest provided consent for collection and use of this preference data. Required for GDPR and CCPA audit trails. Null if consent_given is False or consent was not explicitly recorded.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentGiven rdf:type rdf:Property ;
    rdfs:label 'Consent Given' ;
    rdfs:comment 'Indicates whether the guest has provided explicit consent for the collection and use of this preference data (True). Required for GDPR Article 7 and CCPA compliance. Preferences captured without consent must not be used for marketing personalization.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Data governance classification level for this preference record, aligned with the enterprise data classification policy. \'restricted\' for health/allergy data, \'confidential\' for personal preferences, \'internal\' for operational preferences. Drives access control and data handling policies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryRestriction rdf:type rdf:Property ;
    rdfs:label 'Dietary Restriction' ;
    rdfs:comment 'Guest\'s stated dietary restriction or special dietary requirement (e.g., \'vegetarian\', \'vegan\', \'halal\', \'kosher\', \'gluten-free\', \'lactose-free\', \'diabetic\'). Communicated to F&B operations via MICROS POS and Delphi for event catering. [ENUM-REF-CANDIDATE: vegetarian|vegan|halal|kosher|gluten_free|lactose_free|diabetic|low_sodium|nut_free|shellfish_free — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:housekeepingSchedulePreference rdf:type rdf:Property ;
    rdfs:label 'Housekeeping Schedule Preference' ;
    rdfs:comment 'Guest\'s preferred timing and frequency for housekeeping service. Communicated to the housekeeping management system to schedule room servicing. \'do_not_disturb\' and \'checkout_only\' options support sustainability programs and guest privacy preferences.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdaRequirement rdf:type rdf:Property ;
    rdfs:label 'Is Ada Requirement' ;
    rdfs:comment 'Indicates whether this preference represents an ADA-mandated accessibility accommodation (True), such as roll-in shower, hearing-accessible room, visual alert devices, or accessible room location. ADA requirements carry legal compliance obligations and must be fulfilled without substitution.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAllergy rdf:type rdf:Property ;
    rdfs:label 'Is Allergy' ;
    rdfs:comment 'Indicates whether this preference record represents a food or environmental allergy (True). Allergy records trigger mandatory F&B and housekeeping alerts and are subject to heightened fulfillment controls per ISO 22000 food safety standards.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this preference is a hard requirement that must be fulfilled (True) or a soft preference that should be accommodated when possible (False). Mandatory preferences include ADA accessibility requirements, severe food allergies, and medically necessary accommodations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Guest\'s preferred language for communications, in-room materials, and staff interactions. Stored as BCP 47 language tag (e.g., \'en\', \'fr\', \'es\', \'zh-CN\', \'de\'). Used to personalize pre-arrival communications, in-room collateral, and staff greeting protocols.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastConfirmedDate rdf:type rdf:Property ;
    rdfs:label 'Last Confirmed Date' ;
    rdfs:comment 'Date on which the guest most recently confirmed this preference remains accurate and current. Used to identify stale preferences that may need re-validation during pre-arrival contact or check-in. Supports GDPR data accuracy principle.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyTierAtCapture rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier At Capture' ;
    rdfs:comment 'The guest\'s loyalty program tier at the time this preference was captured (e.g., \'Silver\', \'Gold\', \'Platinum\', \'Diamond\'). Provides context for preference prioritization and fulfillment SLA — higher-tier guests may receive elevated preference fulfillment commitments.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newspaperPreference rdf:type rdf:Property ;
    rdfs:label 'Newspaper Preference' ;
    rdfs:comment 'Guest\'s preferred newspaper or publication for complimentary delivery (e.g., \'The Wall Street Journal\', \'The New York Times\', \'Financial Times\', \'USA Today\', \'local paper\'). Used by front desk and concierge for pre-arrival preparation and morning delivery scheduling.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pillowTypePreference rdf:type rdf:Property ;
    rdfs:label 'Pillow Type Preference' ;
    rdfs:comment 'Guest\'s stated preference for pillow type and firmness. Sourced from OPERA PMS guest profile and communicated to housekeeping for pre-arrival room preparation. Hypoallergenic pillow requests may overlap with allergy flags. [ENUM-REF-CANDIDATE: firm|soft|medium|feather|hypoallergenic|foam|no_preference — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'High-level category classifying the type of guest preference. Drives routing to the appropriate operational team (e.g., housekeeping, F&B, front desk). [ENUM-REF-CANDIDATE: room|bed|pillow|amenity|dietary|housekeeping|temperature|newspaper|accessibility|fnb|transportation|communication|loyalty|spa — promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceCode rdf:type rdf:Property ;
    rdfs:label 'Preference Code' ;
    rdfs:comment 'Standardized alphanumeric code representing the preference value as defined in the Property Management System (OPERA PMS) preference code table. Used for system-to-system integration and operational workflow routing (e.g., \'KGBED\', \'NONSM\', \'OCNVW\', \'VEGAN\').' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'Indicates how the preference was captured: \'stated\' (guest explicitly requested), \'inferred\' (derived from stay history patterns), \'observed\' (noted by staff during stay), \'crm_imported\' (sourced from Salesforce CRM), \'loyalty_profile\' (from loyalty program record), \'survey\' (from Medallia feedback), \'service_recovery\' (captured during a service recovery interaction). [ENUM-REF-CANDIDATE: stated|inferred|observed|crm_imported|loyalty_profile|survey|service_recovery — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of the preference record. \'active\' indicates the preference is valid and should be honored; \'inactive\' indicates it has been withdrawn or expired; \'pending_verification\' indicates it requires staff confirmation; \'superseded\' indicates it has been replaced by a newer preference record.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Specific type of preference within the category (e.g., \'floor_level\', \'bed_type\', \'smoking_status\', \'view_type\', \'pillow_firmness\', \'dietary_restriction\', \'allergy\', \'newspaper_title\', \'housekeeping_time\', \'room_temperature\'). Provides granular classification for operational fulfillment and personalization analytics.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The stated or inferred value of the preference (e.g., \'high floor\', \'king bed\', \'non-smoking\', \'ocean view\', \'firm pillow\', \'vegetarian\', \'gluten-free\', \'The Wall Street Journal\', \'do not disturb before 10am\', \'72°F\'). Free-form string to accommodate the wide variety of preference types.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomFloorPreference rdf:type rdf:Property ;
    rdfs:label 'Room Floor Preference' ;
    rdfs:comment 'Guest\'s stated preference for the floor level of their room assignment. Used by front desk and room assignment workflows in OPERA PMS to optimize room allocation during check-in and pre-arrival room blocking.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Room Temperature Celsius' ;
    rdfs:comment 'Guest\'s preferred room temperature setting in degrees Celsius. Used for pre-arrival room preparation and smart room automation where available. Stored in Celsius for standardization; display conversion to Fahrenheit handled at the presentation layer.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smokingPreference rdf:type rdf:Property ;
    rdfs:label 'Smoking Preference' ;
    rdfs:comment 'Guest\'s preference for smoking or non-smoking room designation. Critical for room assignment compliance and property policy adherence. Most properties are entirely non-smoking; this field captures exceptions and guest-stated preferences for reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validUntil rdf:type rdf:Property ;
    rdfs:label 'Valid Until' ;
    rdfs:comment 'Date after which this preference record expires and should no longer be honored. Null indicates the preference is open-ended with no expiry. Supports GDPR data minimisation requirements by enabling automatic expiry of time-limited preferences.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:viewTypePreference rdf:type rdf:Property ;
    rdfs:label 'View Type Preference' ;
    rdfs:comment 'Guest\'s stated preference for the type of view from their room. Used during room assignment and pre-arrival blocking to enhance guest satisfaction. Supports upsell workflows when preferred view type is available at a premium. [ENUM-REF-CANDIDATE: ocean|pool|garden|city|mountain|courtyard|no_preference — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Date from which this preference record is effective and should be honored during guest stays. Supports time-bound preferences (e.g., a temporary dietary restriction during a medical recovery period) and preference versioning.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedHandlerEmail rdf:type rdf:Property ;
    rdfs:label 'Assigned Handler Email' ;
    rdfs:comment 'Email address of the assigned handler for guest communication regarding the privacy request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedHandlerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Handler Name' ;
    rdfs:comment 'Full name of the data privacy officer or staff member assigned to process this request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise timestamp when the privacy request fulfillment was completed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmCaseReference rdf:type rdf:Property ;
    rdfs:label 'Crm Case Reference' ;
    rdfs:comment 'Reference to the associated case record in Salesforce CRM for tracking guest communications and service recovery.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataFormat rdf:type rdf:Property ;
    rdfs:label 'Data Format' ;
    rdfs:comment 'File format used for data portability or access requests when delivering guest data.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataScope rdf:type rdf:Property ;
    rdfs:label 'Data Scope' ;
    rdfs:comment 'Description of the scope of personal data covered by the request (e.g., all data, specific properties, specific date range).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'New response deadline if an extension was granted (up to additional 60 days under GDPR, 45 days under CCPA).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether a time extension was granted for complex or voluminous requests.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business justification for granting a time extension to fulfill the privacy request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestComments rdf:type rdf:Property ;
    rdfs:label 'Guest Comments' ;
    rdfs:comment 'Additional comments or context provided by the guest when submitting the privacy request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestCommunicationSentCount rdf:type rdf:Property ;
    rdfs:label 'Guest Communication Sent Count' ;
    rdfs:comment 'Number of communications sent to the guest regarding this privacy request (acknowledgments, status updates, completion notices).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalHoldReason rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Reason' ;
    rdfs:comment 'Explanation of the legal basis for maintaining data despite an erasure request (e.g., pending litigation, regulatory investigation).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordsAccessedCount rdf:type rdf:Property ;
    rdfs:label 'Records Accessed Count' ;
    rdfs:comment 'Number of data records accessed or retrieved to fulfill a right-to-access or right-to-portability request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsDeletedCount rdf:type rdf:Property ;
    rdfs:label 'Records Deleted Count' ;
    rdfs:comment 'Number of data records permanently deleted to fulfill a right-to-erasure request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsRectifiedCount rdf:type rdf:Property ;
    rdfs:label 'Records Rectified Count' ;
    rdfs:comment 'Number of data records corrected or updated to fulfill a right-to-rectification request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Primary data protection regulation governing this privacy request based on guest location and applicable law.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNotes rdf:type rdf:Property ;
    rdfs:label 'Request Notes' ;
    rdfs:comment 'Internal notes and comments regarding the processing of the privacy request, including special handling instructions or escalations.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Request Reference Number' ;
    rdfs:comment 'Externally-visible unique reference number provided to the guest for tracking their privacy request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Regulatory deadline by which the organization must respond to the privacy request (typically 30 days from submission under GDPR, 45 days under CCPA).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the guest submitted the privacy request. [ENUM-REF-CANDIDATE: web_portal|mobile_app|email|phone|in_person|postal_mail|crm_case — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemsImpacted rdf:type rdf:Property ;
    rdfs:label 'Systems Impacted' ;
    rdfs:comment 'Comma-separated list of operational systems where guest data was accessed, modified, or deleted to fulfill the request (e.g., OPERA PMS, Salesforce CRM, Medallia).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Third Party Notification Required' ;
    rdfs:comment 'Indicates whether third-party data processors or recipients must be notified of the privacy request action (e.g., erasure, rectification).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Third Party Notification Status' ;
    rdfs:comment 'Status of notifications sent to third-party data processors or recipients regarding the privacy request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Timestamp when guest identity was successfully verified for the privacy request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mergedIntoProfileId rdf:type rdf:Property ;
    rdfs:label 'Merged Into Profile Id' ;
    rdfs:comment 'When profile_status = \'merged\', this field references the survivor profile_id into which this record was consolidated. Enables audit trail of merge lineage and supports identity resolution queries across the guest domain.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:accessibilityNeeds rdf:type rdf:Property ;
    rdfs:label 'Accessibility Needs' ;
    rdfs:comment 'Free-text or coded description of the guest\'s accessibility requirements (e.g., wheelchair accessible room, roll-in shower, hearing loop, visual impairment aids). Drives ADA-compliant room assignment and service delivery. Treated as sensitive personal data.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'The guest\'s date of birth in ISO 8601 format (yyyy-MM-dd). Used for age verification, birthday recognition programs, loyalty tier benefits, and regulatory identity verification at check-in.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryOfResidenceCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Residence Code' ;
    rdfs:comment 'The guest\'s country of permanent residence as an ISO 3166-1 alpha-3 code. Distinct from nationality; used for geographic segmentation, GDPR/CCPA jurisdiction determination, and source market analytics.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Creation Property Code' ;
    rdfs:comment 'The property code (hotel/resort identifier) at which this guest profile was originally created in the PMS. Used for cross-property profile governance, data stewardship assignment, and origin analytics.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactReference rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Reference' ;
    rdfs:comment 'The native contact identifier assigned by Salesforce CRM for this guest. Enables bi-directional synchronization between the PMS golden record and the CRM guest profile for marketing, loyalty, and case management workflows.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyConsentDate rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent Date' ;
    rdfs:comment 'The date on which the guest provided or last renewed their data privacy consent. Required for GDPR and CCPA compliance audit trails, consent expiry management, and regulatory reporting.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'The primary email address for the guest used for reservation confirmations, pre-arrival communications, loyalty program notifications, and post-stay surveys via Medallia. Subject to GDPR and CCPA consent management.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Granular consent flag specifically for email marketing communications, separate from the overall marketing opt-in. Supports channel-specific consent management as required by GDPR, CCPA, and CAN-SPAM regulations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'The guest\'s legal family name (surname) as captured at check-in or profile creation. Used for identity verification, folio generation, and cross-property guest recognition.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprErasureRequested rdf:type rdf:Property ;
    rdfs:label 'Gdpr Erasure Requested' ;
    rdfs:comment 'Indicates whether the guest has submitted a GDPR Article 17 Right to Erasure (Right to be Forgotten) request. True = erasure request received and pending or in-process. Triggers data suppression workflows and prevents further marketing processing.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'The guest\'s legal given name (first name) as captured at check-in or profile creation. Used for personalized guest recognition, folios, and correspondence across all properties.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestType rdf:type rdf:Property ;
    rdfs:label 'Guest Type' ;
    rdfs:comment 'Classification of the guest by travel purpose and booking relationship: FIT (Free Independent Traveler), CORPORATE (business traveler under corporate account), GROUP (group block participant), CREW (airline/transport crew), TRAVEL_AGENT, VIP. Drives rate eligibility, service protocols, and reporting segmentation. [ENUM-REF-CANDIDATE: FIT|CORPORATE|GROUP|CREW|TRAVEL_AGENT|VIP|WHOLESALE|GOVERNMENT — promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMergeSurvivor rdf:type rdf:Property ;
    rdfs:label 'Is Merge Survivor' ;
    rdfs:comment 'Indicates whether this profile record is the surviving (golden) record following a guest profile merge operation. True = this is the authoritative survivor record; False = this is a source or non-survivor record. Critical for identity resolution and deduplication governance.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Date' ;
    rdfs:comment 'The date on which the guest enrolled in the loyalty program. Used to calculate member tenure, tier qualification windows, and anniversary recognition benefits.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'The guest\'s middle name or initial as provided. Supports full legal name matching for identity verification, passport validation, and regulatory compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'The guest\'s mobile/cell phone number in E.164 format. Used for SMS pre-arrival messaging, mobile check-in notifications, and digital key delivery.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namePrefix rdf:type rdf:Property ;
    rdfs:label 'Name Prefix' ;
    rdfs:comment 'Honorific or salutation prefix for the guest (e.g., Mr, Mrs, Dr). Used in personalized correspondence, folio headers, and VIP recognition communications. [ENUM-REF-CANDIDATE: Mr|Mrs|Ms|Miss|Dr|Prof|Sir|Rev — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameSuffix rdf:type rdf:Property ;
    rdfs:label 'Name Suffix' ;
    rdfs:comment 'Name suffix for the guest (e.g., Jr., Sr., III, PhD). Supports full legal name representation for identity documents and formal correspondence.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Country Code' ;
    rdfs:comment 'The guest\'s nationality expressed as an ISO 3166-1 alpha-3 three-letter country code (e.g., USA, GBR, DEU). Required for regulatory reporting, visa compliance, and international guest analytics.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operaProfileReference rdf:type rdf:Property ;
    rdfs:label 'Opera Profile Reference' ;
    rdfs:comment 'The native guest profile identifier assigned by Oracle OPERA Property Management System (PMS). Used for cross-system reconciliation and source-system traceability back to the PMS guest profile record.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Passport Expiry Date' ;
    rdfs:comment 'The expiration date of the guest\'s passport document. Used to validate document currency at check-in and for regulatory compliance in jurisdictions requiring valid travel document verification.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportIssuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Passport Issuing Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the authority that issued the guest\'s passport. Required for immigration compliance and international guest regulatory reporting.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'The guest\'s passport document number as presented at check-in. Required for international guest identity verification, regulatory reporting to local authorities, and compliance with immigration laws in applicable jurisdictions.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'The primary contact phone number for the guest in E.164 international format. Used for reservation confirmations, pre-arrival contact, and service recovery outreach.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredBedType rdf:type rdf:Property ;
    rdfs:label 'Preferred Bed Type' ;
    rdfs:comment 'The guest\'s preferred bed configuration for room assignment: KING, QUEEN, DOUBLE, TWIN, or SINGLE. Used during pre-arrival room blocking and at check-in to maximize guest satisfaction.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFloor rdf:type rdf:Property ;
    rdfs:label 'Preferred Floor' ;
    rdfs:comment 'The guest\'s preferred floor level or floor range for room assignment (e.g., high floor, low floor, specific floor number). Captured from guest preferences in OPERA PMS and used during pre-arrival room blocking.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'The guest\'s preferred communication language expressed as an ISO 639-1 two-letter language code (e.g., en, fr, de, zh). Drives language selection for folios, correspondence, digital communications, and on-property service delivery.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredRoomType rdf:type rdf:Property ;
    rdfs:label 'Preferred Room Type' ;
    rdfs:comment 'The guest\'s stated or historically derived preferred room type (e.g., King Deluxe, Suite, Double Queen). Stored as a room type code from the PMS room type configuration. Used by front desk for pre-arrival room assignment and upsell targeting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle state of the guest master profile: active (in use), inactive (dormant, no recent stays), merged (absorbed into a survivor record), suspended (temporarily blocked), deceased (confirmed deceased, retained for audit). Governs record visibility and processing eligibility.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Granular consent flag specifically for SMS/text message marketing communications. Supports channel-specific consent management as required by GDPR, CCPA, and TCPA (Telephone Consumer Protection Act) regulations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vipStatus rdf:type rdf:Property ;
    rdfs:label 'Vip Status' ;
    rdfs:comment 'The VIP designation level assigned to the guest in Oracle OPERA PMS, indicating the tier of elevated service protocols to apply at check-in and throughout the stay. NONE=standard guest, VIP1-VIP3=escalating VIP tiers, VVIP=highest recognition, BLACKLIST=do-not-accommodate flag.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileMergeHistoryId rdf:type rdf:Property ;
    rdfs:label 'Profile Merge History Id' ;
    rdfs:comment 'Unique identifier for the profile merge event record. Primary key for the profile merge history audit trail.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceProfileId rdf:type rdf:Property ;
    rdfs:label 'Source Profile Id' ;
    rdfs:comment 'The non-surviving guest profile identifier that was merged into the target profile. This profile is deactivated after the merge.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:targetProfileId rdf:type rdf:Property ;
    rdfs:label 'Target Profile Id' ;
    rdfs:comment 'The surviving guest profile identifier that received all data from the source profile. This becomes the golden record after merge.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:contactInfoMigratedCount rdf:type rdf:Property ;
    rdfs:label 'Contact Info Migrated Count' ;
    rdfs:comment 'The total number of contact information records (email, phone, address) that were transferred from the source profile to the target profile.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Technical error message or exception details captured if the merge operation failed or encountered issues during execution.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentRetained rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Retained' ;
    rdfs:comment 'Indicates whether marketing and data processing consent flags were preserved during the merge operation in compliance with GDPR requirements.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsTransferred rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Transferred' ;
    rdfs:comment 'The total number of loyalty program points or rewards that were consolidated from the source profile into the target profile during the merge.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchingConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Matching Confidence Score' ;
    rdfs:comment 'A numerical score (0.00 to 100.00) representing the algorithmic confidence level that the source and target profiles represent the same guest. Higher scores indicate stronger match certainty.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchingCriteria rdf:type rdf:Property ;
    rdfs:label 'Matching Criteria' ;
    rdfs:comment 'The specific data elements used to identify the profiles as duplicates, such as name+DOB, email+phone, loyalty ID, or combination of multiple attributes.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergeBatchCode rdf:type rdf:Property ;
    rdfs:label 'Merge Batch Code' ;
    rdfs:comment 'The batch identifier for bulk merge operations, grouping multiple profile merges that were executed together as part of a single data quality initiative.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergeComments rdf:type rdf:Property ;
    rdfs:label 'Merge Comments' ;
    rdfs:comment 'Free-text comments or notes entered by the operator documenting the reason for the merge, special circumstances, or additional context.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergeMethod rdf:type rdf:Property ;
    rdfs:label 'Merge Method' ;
    rdfs:comment 'The technical method or process used to execute the profile merge. Distinguishes between automated matching algorithms, manual operator review, and batch processing.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergeReason rdf:type rdf:Property ;
    rdfs:label 'Merge Reason' ;
    rdfs:comment 'The business reason or trigger that initiated the profile merge operation. Indicates whether the merge was system-detected, guest-requested, or operationally driven.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergeStatus rdf:type rdf:Property ;
    rdfs:label 'Merge Status' ;
    rdfs:comment 'The current status of the merge operation indicating whether it completed successfully, failed, is pending, or was subsequently rolled back.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Merge Timestamp' ;
    rdfs:comment 'The exact date and time when the profile merge operation was executed and committed to the system.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notesMigratedCount rdf:type rdf:Property ;
    rdfs:label 'Notes Migrated Count' ;
    rdfs:comment 'The total number of guest notes, traces, and alerts that were transferred from the source profile to the target profile during the merge operation.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorDepartment rdf:type rdf:Property ;
    rdfs:label 'Operator Department' ;
    rdfs:comment 'The organizational department or functional area of the operator who performed the merge, such as Front Desk, CRM Team, IT Data Quality, or System Automation.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'The full name of the staff member or system account that executed the merge operation for audit and accountability purposes.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferencesMigratedCount rdf:type rdf:Property ;
    rdfs:label 'Preferences Migrated Count' ;
    rdfs:comment 'The total number of guest preference records (room type, floor, amenities, etc.) that were transferred from the source profile to the target profile.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservationsMigratedCount rdf:type rdf:Property ;
    rdfs:label 'Reservations Migrated Count' ;
    rdfs:comment 'The total number of reservation records that were transferred from the source profile to the target profile during the merge operation.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rollbackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Eligible Flag' ;
    rdfs:comment 'Indicates whether this merge operation can be reversed or undone. True if rollback is technically possible, False if the merge is permanent or rollback window has expired.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rollback Expiry Date' ;
    rdfs:comment 'The date after which the merge operation can no longer be reversed. Defines the time window during which rollback is permitted per data governance policy.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:staysMigratedCount rdf:type rdf:Property ;
    rdfs:label 'Stays Migrated Count' ;
    rdfs:comment 'The total number of historical stay records that were transferred from the source profile to the target profile during the merge operation.' ;
    rdfs:domain ind:ProfileMergeHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationNotes rdf:type rdf:Property ;
    rdfs:label 'Validation Notes' ;
    rdfs:comment 'Free-text notes documenting the validation process, any issues identified, or confirmation of successful data integrity checks.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Indicates whether the merge operation has been validated for data integrity and business rule compliance after execution.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'The date and time when the merge operation was validated for data integrity and completeness.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:relationshipId rdf:type rdf:Property ;
    rdfs:label 'Relationship Id' ;
    rdfs:comment 'Unique identifier for the guest-to-guest relationship record. Primary key.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Identifier for the household or family unit to which both guests belong. Used for household-level Lifetime Value (LTV) aggregation and family recognition programs.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:relationshipCreatedByStaffEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Created By Staff Employee Id' ;
    rdfs:comment 'Identifier of the staff member who created this relationship record. Null if created through an automated process or API import.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relationshipEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Employee Id' ;
    rdfs:comment 'Identifier of the staff member who verified the relationship. Null if not yet verified or if verified through an automated process.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relationshipLastModifiedByStaffEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Last Modified By Staff Employee Id' ;
    rdfs:comment 'Identifier of the staff member who last modified this relationship record. Null if modified through an automated process.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relationshipProfileId rdf:type rdf:Property ;
    rdfs:label 'Relationship Profile Id' ;
    rdfs:comment 'Identifier of the primary guest in the relationship. The guest from whom the relationship originates.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:relationshipRelatedGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Relationship Related Guest Profile Id' ;
    rdfs:comment 'Identifier of the related guest in the relationship. The guest to whom the primary guest is related.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:billingAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Authority Flag' ;
    rdfs:comment 'Indicates whether the related guest has authority to handle billing and payment matters for the primary guest.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookingAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Booking Authority Flag' ;
    rdfs:comment 'Indicates whether the related guest has authority to make bookings on behalf of the primary guest. Used for assistant-mediated booking and corporate travel coordinator scenarios.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Flag' ;
    rdfs:comment 'Indicates whether both guests have provided consent for this relationship to be recorded and used for service personalization. Required for General Data Protection Regulation (GDPR) and California Consumer Privacy Act (CCPA) compliance.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the relationship is bidirectional (mutual, both guests recognize the relationship) or unidirectional (one-way, only the primary guest recognizes the relationship).' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Flag' ;
    rdfs:comment 'Indicates whether the related guest is designated as an emergency contact for the primary guest.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the relationship ended or is scheduled to end. Null for ongoing relationships.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether the related guest is the primary contact for the primary guest. Used for assistant-mediated booking attribution and corporate travel coordinator visibility.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the relationship. Active relationships are used for service personalization and household-level aggregation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Type of relationship between the two guests. Defines the nature of the association (e.g., spouse/partner, parent/child, executive assistant, corporate booker-to-traveler, travel companion).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharedPreferenceInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Preference Inheritance Flag' ;
    rdfs:comment 'Indicates whether preferences should be inherited or shared between the two guests. Enables family recognition programs (e.g., greeting children by name based on parent preferences).' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the relationship became effective. Used for historical tracking and lifecycle management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Verified Flag' ;
    rdfs:comment 'Indicates whether the relationship has been verified by staff or through a validation process. Unverified relationships may be self-reported or imported without confirmation.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique identifier for the guest market segment record. Primary key for both segment master definitions and individual guest-to-segment assignment records.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingGuestSegmentId rdf:type rdf:Property ;
    rdfs:label 'Marketing Guest Segment Id' ;
    rdfs:comment 'Foreign key linking to marketing.guest_segment. Business justification: Properties cross-reference booking market segments (transient, group, contract) with marketing behavioral segments (high-value leisure, business road warrior) for campaign eligibility rules, personali' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestSegment .

ind:parentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Id' ;
    rdfs:comment 'Reference to the parent segment in the hierarchy for roll-up aggregation. Null for top-level segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:primarySupersededByAssignmentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Assignment Segment Id' ;
    rdfs:comment 'Reference to the segment assignment record that supersedes this one. Used for tracking segment migration history and maintaining assignment lineage.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:adrIndexVsProperty rdf:type rdf:Property ;
    rdfs:label 'Adr Index Vs Property' ;
    rdfs:comment 'Average Daily Rate index for this segment relative to property-wide ADR. 1.0 = at property average, >1.0 = premium segment, <1.0 = discount segment. Used for segment mix optimization.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advanceBookingWindowDays rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Window Days' ;
    rdfs:comment 'Typical advance booking window in days for this segment. Used for demand forecasting and pickup analysis. Transient segments typically 0-30 days, Group segments 90-365 days.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancillaryRevenuePerStay rdf:type rdf:Property ;
    rdfs:label 'Ancillary Revenue Per Stay' ;
    rdfs:comment 'Average ancillary revenue (F&B, spa, parking, resort fees, etc.) per stay for this segment. Used for total revenue forecasting and TRevPAR optimization.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Assignment Confidence Score' ;
    rdfs:comment 'Confidence score (0.000 to 1.000) for ML-inferred segment assignments. Higher scores indicate greater model certainty. Null for rule-based and manual assignments.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when the guest was assigned to this segment. Used for tracking segment migration and guest lifecycle analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Effective Date' ;
    rdfs:comment 'Date from which this segment assignment is effective for the guest. Used for time-bound segment membership (e.g., corporate contract validity period).' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Expiry Date' ;
    rdfs:comment 'Date when this segment assignment expires for the guest. Null for indefinite assignments. Used for contract-based and time-limited segment memberships.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method used to assign the guest to this segment. Rule-based uses business rules (e.g., booking channel, rate code), ML-inferred uses machine learning models for predictive segmentation, Manual-override represents analyst or sales manager assignment, Reservation-based inherits from reservation market segment code.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text notes explaining the rationale for manual segment assignments or overrides. Used for audit trail and knowledge transfer.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason Code' ;
    rdfs:comment 'Code indicating the business reason for this segment assignment (e.g., CORP_CONTRACT, BOOKING_CHANNEL, STAY_PATTERN, SALES_OVERRIDE, LTV_TIER). Used for assignment audit and quality control.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageLosDays rdf:type rdf:Property ;
    rdfs:label 'Average Los Days' ;
    rdfs:comment 'Historical average Length of Stay in days for guests in this segment. Used for demand forecasting and inventory optimization.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionEligible rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible' ;
    rdfs:comment 'Indicates whether bookings in this segment are eligible for travel agent or OTA commission payments.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displacementAnalysisEligible rdf:type rdf:Property ;
    rdfs:label 'Displacement Analysis Eligible' ;
    rdfs:comment 'Indicates whether group bookings in this segment should undergo displacement analysis to compare group revenue against potential transient revenue. Used for group evaluation and acceptance decisions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fbAttachmentRatePct rdf:type rdf:Property ;
    rdfs:label 'Fb Attachment Rate Pct' ;
    rdfs:comment 'Percentage of guests in this segment who purchase F&B services during their stay. Used for TRevPAR analysis and ancillary revenue forecasting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyPointsEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Eligible' ;
    rdfs:comment 'Indicates whether stays booked under this segment earn loyalty program points and elite night credits.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsMultiplier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Multiplier' ;
    rdfs:comment 'Multiplier applied to base points earning for this segment. Standard is 1.0, promotional segments may have higher multipliers (e.g., 1.5x, 2.0x).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lraEligible rdf:type rdf:Property ;
    rdfs:label 'Lra Eligible' ;
    rdfs:comment 'Indicates whether this segment has Last Room Availability commitment, meaning inventory is available at the contracted rate even when the property is sold out. Typically True for top-tier corporate contracts and loyalty elite members.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateStrategyType rdf:type rdf:Property ;
    rdfs:label 'Rate Strategy Type' ;
    rdfs:comment 'Pricing strategy applicable to this segment. Dynamic uses RMS (Revenue Management System) optimization, Fixed uses BAR (Best Available Rate) or published rates, Negotiated uses contracted rates, Promotional uses discount codes, Opaque uses non-branded OTA channels.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revparContributionPct rdf:type rdf:Property ;
    rdfs:label 'Revpar Contribution Pct' ;
    rdfs:comment 'Historical percentage contribution of this segment to total property RevPAR. Sum across all segments equals 100%. Used for strategic segment mix planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'Broader business category for revenue and demand analysis. Used for RevPAR (Revenue Per Available Room) decomposition and TRevPAR (Total Revenue Per Available Room) attribution.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Full descriptive name of the market segment (e.g., Transient, Group, Corporate Negotiated, Wholesale, Complimentary, Airline Crew).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment definition. Active segments are available for assignment and reporting, Inactive segments are hidden from selection but retained for historical analysis, Deprecated segments are being phased out, Pending segments are awaiting approval.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'High-level classification of the segment type. Transient represents FIT (Free Independent Traveler) guests, Group represents MICE (Meetings Incentives Conferences Exhibitions) and leisure groups, Contract represents negotiated corporate accounts, Wholesale represents OTA (Online Travel Agency) and tour operator bookings, Complimentary represents comp stays and employee rates, Crew represents airline and travel industry staff.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usaliMappingCode rdf:type rdf:Property ;
    rdfs:label 'Usali Mapping Code' ;
    rdfs:comment 'Standard USALI account code for financial reporting and GOP (Gross Operating Profit) attribution. Ensures consistent revenue classification across properties.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Yield Management Flag' ;
    rdfs:comment 'Indicates whether this segment is subject to dynamic yield optimization and inventory controls by the RMS. True for transient and qualified segments, False for contracted and complimentary segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ancillaryRevenue rdf:type rdf:Property ;
    rdfs:label 'Ancillary Revenue' ;
    rdfs:comment 'Total ancillary charges posted to the guest folio during the stay, including spa, parking, laundry, telephone, and other non-room, non-F&B charges. Sourced from Oracle OPERA PMS. Contributes to TRevPAR and GOPPAR calculations per USALI.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingChannelCode rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Code' ;
    rdfs:comment 'Code identifying the distribution channel through which the reservation was originally made (e.g., direct_web, ota, gds, voice, walk_in, corporate_direct). Sourced from Sabre SynXis CRS channel mapping. Used for channel contribution and OTA partnership analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingDate rdf:type rdf:Property ;
    rdfs:label 'Booking Date' ;
    rdfs:comment 'Date on which the reservation was originally created (yyyy-MM-dd). Used to calculate booking lead time (days between booking_date and arrival_date), a key input for demand forecasting and pickup report analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkinTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkin Timestamp' ;
    rdfs:comment 'Exact date and time the guest completed the check-in process at the front desk or via mobile/digital check-in (yyyy-MM-ddTHH:mm:ss.SSSXXX). Sourced from Oracle OPERA PMS front desk module. Used for operational SLA tracking and guest experience analytics.' ;
    rdfs:domain ind:StayHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkout Timestamp' ;
    rdfs:comment 'Exact date and time the guest completed the checkout process (yyyy-MM-ddTHH:mm:ss.SSSXXX). Sourced from Oracle OPERA PMS cashiering module. Marks the point at which the stay record is finalized and posted to the stay history.' ;
    rdfs:domain ind:StayHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complimentaryFlag rdf:type rdf:Property ;
    rdfs:label 'Complimentary Flag' ;
    rdfs:comment 'Indicates whether the stay was provided on a complimentary (no-charge) basis (True = complimentary; False = revenue-generating stay). Sourced from Oracle OPERA PMS. Used for USALI complimentary room reporting and GOP calculation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotDisturbFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Disturb Flag' ;
    rdfs:comment 'Indicates whether the guest activated Do Not Disturb (DND) status during the stay (True = DND activated at any point; False = DND not activated). Sourced from Oracle OPERA PMS housekeeping module. Used for housekeeping scheduling and guest preference analytics.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyTierAtStay rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier At Stay' ;
    rdfs:comment 'The guest\'s loyalty program tier level at the time of the stay (e.g., Silver, Gold, Platinum, Diamond). Captured as a snapshot to preserve historical tier context for LTV analysis and personalization, independent of the guest\'s current tier. [ENUM-REF-CANDIDATE: promote to reference product as tiers vary by brand]' ;
    rdfs:domain ind:StayHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numAdults rdf:type rdf:Property ;
    rdfs:label 'Num Adults' ;
    rdfs:comment 'Count of adult guests (18 years and older) registered for the stay as recorded in Oracle OPERA PMS. Used for occupancy reporting, F&B revenue forecasting, and capacity planning.' ;
    rdfs:domain ind:StayHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numChildren rdf:type rdf:Property ;
    rdfs:label 'Num Children' ;
    rdfs:comment 'Count of child guests (under 18 years) registered for the stay as recorded in Oracle OPERA PMS. Used for family segment analytics, amenity planning, and F&B revenue forecasting.' ;
    rdfs:domain ind:StayHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Original Arrival Date' ;
    rdfs:comment 'The arrival date as originally reserved at time of booking, before any modifications. Used to measure early arrival or late arrival deviations and to support wash factor analysis in IDeaS G3 RMS.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Original Departure Date' ;
    rdfs:comment 'The departure date as originally reserved at time of booking, before any modifications. Used to identify early departure and extended stay patterns for demand forecasting and wash factor analysis in IDeaS G3 RMS.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingNights rdf:type rdf:Property ;
    rdfs:label 'Qualifying Nights' ;
    rdfs:comment 'Number of nights from this stay that count toward the guest\'s loyalty program tier qualification. May differ from los_nights if the rate plan is non-qualifying (e.g., wholesale, complimentary). Sourced from Salesforce CRM loyalty management.' ;
    rdfs:domain ind:StayHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomTypeCode rdf:type rdf:Property ;
    rdfs:label 'Room Type Code' ;
    rdfs:comment 'Standardized code identifying the room type category occupied during the stay (e.g., KING, DBLQ, SUITE, DLXK). Sourced from Oracle OPERA PMS room inventory. Used for room type mix analysis, upsell tracking, and RevPAR decomposition.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stayStatus rdf:type rdf:Property ;
    rdfs:label 'Stay Status' ;
    rdfs:comment 'Outcome status of the guest stay upon checkout processing. \'completed\' indicates normal checkout on scheduled departure date; \'early_departure\' indicates guest checked out before scheduled departure; \'extended\' indicates stay was prolonged beyond original departure date; \'no_show\' indicates reservation was not cancelled but guest never arrived; \'cancelled\' indicates reservation was cancelled post-check-in processing.' ;
    rdfs:domain ind:StayHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFolioAmount rdf:type rdf:Property ;
    rdfs:label 'Total Folio Amount' ;
    rdfs:comment 'Total amount charged to the guest folio for the entire stay, inclusive of room revenue, F&B revenue, ancillary revenue, and taxes. Represents the gross billing amount settled at checkout. Sourced from Oracle OPERA PMS cashiering module.' ;
    rdfs:domain ind:StayHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vipCode rdf:type rdf:Property ;
    rdfs:label 'Vip Code' ;
    rdfs:comment 'VIP designation code assigned to the guest for this stay in Oracle OPERA PMS (e.g., VIP1, VIP2, VVIP, CELEB). Drives special handling, amenity delivery, and management attention protocols. Null if guest has no VIP designation.' ;
    rdfs:domain ind:StayHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipDesignationId rdf:type rdf:Property ;
    rdfs:label 'Vip Designation Id' ;
    rdfs:comment 'Unique surrogate identifier for each VIP designation record in the silver layer lakehouse. Primary key for the vip_designation data product. Sourced from Oracle OPERA PMS VIP code assignments and Salesforce CRM VIP profile records.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVipEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Vip Employee Id' ;
    rdfs:comment 'Reference to the workforce employee record for the dedicated property host, butler, or guest relations manager assigned to personally manage this VIP guest\'s experience. Drives pre-arrival communication and on-property service coordination.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryVipAssignedHostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Vip Assigned Host Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryVipApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Vip Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee record of the senior leader (e.g., General Manager, Regional VP) who provided final approval for this VIP designation. May differ from designated_by_employee_id when a two-step approval workflow is required for high-tier designations.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:airportTransferRequired rdf:type rdf:Property ;
    rdfs:label 'Airport Transfer Required' ;
    rdfs:comment 'Indicates whether a complimentary or arranged airport transfer service is required for this VIP guest as part of their designation entitlements. Triggers coordination with the concierge and transportation team during pre-arrival preparation.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aliasName rdf:type rdf:Property ;
    rdfs:label 'Alias Name' ;
    rdfs:comment 'Pseudonym or alias name used for incognito check-in and reservation bookings to protect the identity of high-profile guests. Used in place of the guest\'s legal name on folios, room assignments, and staff communications when incognito_checkin is true.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityTierCode rdf:type rdf:Property ;
    rdfs:label 'Amenity Tier Code' ;
    rdfs:comment 'Code referencing the amenity entitlement package associated with this VIP level. Determines the standard amenity setup (e.g., welcome fruit basket, champagne, floral arrangement, personalized stationery) to be prepared prior to guest arrival. Sourced from OPERA PMS amenity configuration.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concurrentDesignationCount rdf:type rdf:Property ;
    rdfs:label 'Concurrent Designation Count' ;
    rdfs:comment 'Number of active VIP designations currently held by this guest across all scopes (brand and property level). Supports operational awareness that a guest may hold multiple concurrent designations (e.g., VIP3 at brand level and Celebrity at property level) and ensures all applicable protocols are honored.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designationCode rdf:type rdf:Property ;
    rdfs:label 'Designation Code' ;
    rdfs:comment 'Externally-known alphanumeric code identifying this VIP designation record, as assigned in Oracle OPERA PMS VIP code table (e.g., VIP1, VIP3, CELEB, ROYAL, OWNER). Used for cross-system reference and pre-arrival checklist triggers.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationNotes rdf:type rdf:Property ;
    rdfs:label 'Designation Notes' ;
    rdfs:comment 'Internal narrative notes providing additional context about the VIP designation, such as the relationship history, specific events that triggered the designation, or instructions for the guest relations team. Visible only to authorized staff. Sourced from Salesforce CRM case notes.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationReason rdf:type rdf:Property ;
    rdfs:label 'Designation Reason' ;
    rdfs:comment 'Business rationale for granting the VIP designation. Revenue threshold indicates the guest meets a minimum annual spend threshold. Corporate relationship indicates a key account or contracted corporate partner. Public figure, diplomatic, and celebrity reasons trigger additional privacy protocols. [ENUM-REF-CANDIDATE: revenue_threshold|corporate_relationship|public_figure|loyalty_elite|owner|board_member|celebrity|diplomatic|media|government — promote to reference product]' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationScope rdf:type rdf:Property ;
    rdfs:label 'Designation Scope' ;
    rdfs:comment 'Indicates whether the VIP designation applies across the entire brand portfolio, is restricted to a specific property, or applies to a regional cluster of properties. Drives which properties must honor the designation during pre-arrival preparation.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationStatus rdf:type rdf:Property ;
    rdfs:label 'Designation Status' ;
    rdfs:comment 'Current lifecycle state of the VIP designation record. Active designations drive pre-arrival checklists and upgrade eligibility. Suspended designations are temporarily paused. Revoked designations have been withdrawn due to policy violation or relationship change.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotDisturb rdf:type rdf:Property ;
    rdfs:label 'Do Not Disturb' ;
    rdfs:comment 'Indicates that the guest has a standing do-not-disturb preference that must be honored by housekeeping, engineering, and all operational departments unless a safety emergency arises. Overrides standard housekeeping scheduling in Oracle OPERA PMS.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmGreetingRequired rdf:type rdf:Property ;
    rdfs:label 'Gm Greeting Required' ;
    rdfs:comment 'Indicates whether the General Manager (GM) or designated senior property leader is required to personally greet this VIP guest upon arrival. Triggers a GM greeting task in the pre-arrival preparation checklist within Oracle OPERA PMS.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incognitoCheckin rdf:type rdf:Property ;
    rdfs:label 'Incognito Checkin' ;
    rdfs:comment 'Indicates that the guest requires a discreet, incognito check-in process to protect their identity and privacy. When true, the front desk must use a private check-in area, suppress the guest name from public-facing displays, and limit staff awareness of the guest\'s presence. Critical for celebrity and diplomatic guests.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastStayDate rdf:type rdf:Property ;
    rdfs:label 'Last Stay Date' ;
    rdfs:comment 'Date of the guest\'s most recent completed stay at any property under this VIP designation\'s scope. Used during annual VIP review cycles to assess continued eligibility based on recency of engagement. Sourced from Oracle OPERA PMS reservation history.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaBlackout rdf:type rdf:Property ;
    rdfs:label 'Media Blackout' ;
    rdfs:comment 'Indicates that all media inquiries, press requests, and social media references related to this guest\'s stay must be suppressed and escalated to the Director of Communications. Distinct from no_photo_policy as it governs external communications rather than on-property photography.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noPhotoPolicy rdf:type rdf:Property ;
    rdfs:label 'No Photo Policy' ;
    rdfs:comment 'Indicates that the guest has explicitly prohibited photography, video recording, or any visual documentation of their presence on property. Staff must be briefed on this restriction during pre-arrival preparation. Applies to celebrity, royalty, and diplomatic designations.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preArrivalChecklistTemplate rdf:type rdf:Property ;
    rdfs:label 'Pre Arrival Checklist Template' ;
    rdfs:comment 'Code identifying the standardized pre-arrival preparation checklist template to be activated for this VIP designation. Templates define the sequence of tasks (amenity setup, room inspection, GM briefing, transportation coordination) required before the guest\'s arrival.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold Amount' ;
    rdfs:comment 'Minimum annual revenue contribution (in USD) that qualified this guest for the VIP designation based on the revenue threshold reason. Used for annual VIP eligibility reviews and LTV (Lifetime Value) analysis. Sourced from OPERA PMS revenue history and SAP S/4HANA financial records.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the revenue_threshold_amount field. Ensures correct currency context for multi-currency properties and international guests. Defaults to USD for US-based properties.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomAssignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Room Assignment Priority' ;
    rdfs:comment 'Numeric priority rank (lower value = higher priority) used by the front desk and revenue management systems to sequence room assignment and upgrade eligibility for this VIP guest relative to other arriving guests. Integrates with IDeaS G3 RMS inventory controls.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityEscortRequired rdf:type rdf:Property ;
    rdfs:label 'Security Escort Required' ;
    rdfs:comment 'Indicates whether a dedicated security escort or personal protection detail coordination is required for this VIP guest during their stay. Triggers security briefing and coordination protocols with the property security team and any external protection services.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceRecoveryEscalationLevel rdf:type rdf:Property ;
    rdfs:label 'Service Recovery Escalation Level' ;
    rdfs:comment 'Defines the escalation path and response urgency for service recovery incidents involving this VIP guest. Immediate_gm requires the General Manager to be notified within minutes of any complaint. Drives Medallia case routing and Salesforce CRM service recovery workflows.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemVipCode rdf:type rdf:Property ;
    rdfs:label 'Source System Vip Code' ;
    rdfs:comment 'The native VIP code or identifier as stored in the originating source system (Oracle OPERA PMS or Salesforce CRM). Retained for traceability and reconciliation between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingNotes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Notes' ;
    rdfs:comment 'Free-text field capturing bespoke service instructions specific to this VIP designation, such as preferred room temperature, dietary restrictions for amenity setup, security escort requirements, or specific staff interaction protocols. Sourced from Salesforce CRM case notes and OPERA PMS profile remarks.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStaysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Total Stays In Period' ;
    rdfs:comment 'Count of completed stays by the guest within the current designation validity period (effective_from to effective_until). Used to validate continued VIP eligibility at review date and to support LTV (Lifetime Value) reporting. Sourced from Oracle OPERA PMS stay history.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upgradeEligible rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligible' ;
    rdfs:comment 'Indicates whether this VIP designation entitles the guest to complimentary room category upgrades subject to availability at check-in. When true, the front desk system surfaces upgrade options during the check-in workflow in Oracle OPERA PMS.' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vipLevel rdf:type rdf:Property ;
    rdfs:label 'Vip Level' ;
    rdfs:comment 'Tiered classification of the VIP designation indicating the service protocol level assigned to the guest. VIP1 is entry-level recognition; VIP5 is the highest standard tier. Celebrity, Royalty, Owner, and Board Member are special-class designations. [ENUM-REF-CANDIDATE: VIP1|VIP2|VIP3|VIP4|VIP5|Celebrity|Royalty|Owner|Board Member — promote to reference product]' ;
    rdfs:domain ind:VipDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendantId rdf:type rdf:Property ;
    rdfs:label 'Attendant Id' ;
    rdfs:comment 'Unique identifier for the housekeeping attendant record. Primary key for the attendant entity in the housekeeping domain.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Attendant .

ind:adaAccommodationFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Flag' ;
    rdfs:comment 'Indicates whether the attendant has an approved reasonable accommodation under the Americans with Disabilities Act. Accommodations may include modified duty assignments, assistive equipment, or adjusted productivity targets. Details of specific accommodations are maintained in confidential HR records.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attendancePoints rdf:type rdf:Property ;
    rdfs:label 'Attendance Points' ;
    rdfs:comment 'Current attendance point balance under the property\'s attendance policy. Points are typically assigned for absences, tardiness, and early departures, with progressive discipline triggered at defined thresholds. Points may expire after a rolling period (e.g., 12 months).' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendantCode rdf:type rdf:Property ;
    rdfs:label 'Attendant Code' ;
    rdfs:comment 'Business identifier for the attendant used in daily operations, room assignment sheets, and housekeeping reports. Typically a short alphanumeric code displayed on badges and mobile devices.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageCreditsPerShift rdf:type rdf:Property ;
    rdfs:label 'Average Credits Per Shift' ;
    rdfs:comment 'Rolling average of actual room credits completed per shift over the most recent evaluation period (typically 30 or 90 days). Used to track individual productivity trends and identify training needs or performance issues.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment lifecycle status of the attendant. Active attendants are available for scheduling. On-leave includes FMLA, medical, and personal leave. Seasonal workers are employed during peak periods. Probationary status applies to new hires during their initial evaluation period.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the attendant was hired into the housekeeping department. Used to calculate seniority for union section bidding, vacation accrual, and tenure-based benefits.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageSkills rdf:type rdf:Property ;
    rdfs:label 'Language Skills' ;
    rdfs:comment 'Comma-separated list of languages the attendant can speak and understand. Important for guest interaction, safety communication, and team coordination in multilingual properties. Format: ISO 639-1 language codes (e.g., en,es,fr).' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review. Most properties conduct annual or semi-annual reviews aligned with merit increase cycles.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockerNumber rdf:type rdf:Property ;
    rdfs:label 'Locker Number' ;
    rdfs:comment 'Assigned locker number in the employee locker room where the attendant stores personal belongings, uniform, and equipment during their shift.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Mobile Device Code' ;
    rdfs:comment 'Identifier of the mobile device (smartphone or tablet) assigned to the attendant for receiving room assignments, updating room status, reporting maintenance issues, and communicating with supervisors. Integrates with property management system mobile housekeeping applications.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent performance evaluation rating for the attendant. Based on quality inspections, productivity metrics, guest feedback, attendance, and adherence to standards. Used for merit increases, promotion decisions, and performance improvement plans.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Primary housekeeping role classification. Determines work assignment types, productivity benchmarks, and labor cost allocation. Room attendants clean guest rooms, turndown attendants provide evening service, house persons handle heavy cleaning and linen transport, supervisors oversee sections, inspectors perform quality checks, and public area cleaners maintain lobbies and common spaces.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionAssignment rdf:type rdf:Property ;
    rdfs:label 'Section Assignment' ;
    rdfs:comment 'Current section or floor assignment within the property. Sections are typically organized by floor, wing, or building. Section assignments may be permanent (based on seniority bidding) or rotational.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityDate rdf:type rdf:Property ;
    rdfs:label 'Seniority Date' ;
    rdfs:comment 'Date used for calculating seniority ranking within the housekeeping department. May differ from hire date due to transfers, breaks in service, or union contract provisions. Critical for section bidding rights and shift preference allocation.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftAssignment rdf:type rdf:Property ;
    rdfs:label 'Shift Assignment' ;
    rdfs:comment 'Current shift assignment for the attendant. AM shift typically covers morning checkout cleaning, PM shift handles afternoon turnovers and turndown service, night shift performs deep cleaning and public area maintenance. Split shifts cover peak periods. On-call attendants fill in for absences.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCreditsPerShift rdf:type rdf:Property ;
    rdfs:label 'Target Credits Per Shift' ;
    rdfs:comment 'Productivity benchmark expressed as the target number of room credits the attendant should complete per shift. Room credits vary by room type: standard rooms = 1.0 credit, suites = 1.5-2.0 credits, checkout rooms = 1.2 credits, stayover rooms = 0.7 credits. Used for performance evaluation and labor cost per occupied room (CPOR) calculation.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uniformSize rdf:type rdf:Property ;
    rdfs:label 'Uniform Size' ;
    rdfs:comment 'Uniform size for the attendant used for ordering and inventory management of housekeeping uniforms. Format varies by property (e.g., S/M/L/XL or numeric sizing).' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionClassification rdf:type rdf:Property ;
    rdfs:label 'Union Classification' ;
    rdfs:comment 'Union job classification code as defined in the collective bargaining agreement. Determines pay grade, work rules, and assignment restrictions. Examples include classifications for different room types, shift differentials, and specialized duties.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Union Member Flag' ;
    rdfs:comment 'Indicates whether the attendant is a member of a labor union. Determines applicability of collective bargaining agreement provisions, grievance procedures, and union-specific benefits.' ;
    rdfs:domain ind:Attendant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleaningStandardId rdf:type rdf:Property ;
    rdfs:label 'Cleaning Standard Id' ;
    rdfs:comment 'Unique identifier for the cleaning standard configuration. Primary key.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CleaningStandard .

ind:amenityItemsList rdf:type rdf:Property ;
    rdfs:label 'Amenity Items List' ;
    rdfs:comment 'Comma-separated or structured list of amenity items to be placed (e.g., shampoo, conditioner, body lotion, soap, dental kit, sewing kit, coffee pods, bottled water). Varies by brand tier and guest segment.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityPlacementInstructions rdf:type rdf:Property ;
    rdfs:label 'Amenity Placement Instructions' ;
    rdfs:comment 'Detailed instructions for amenity item placement and presentation (e.g., toiletries arrangement, towel folding style, welcome card positioning, turndown chocolate placement). Ensures brand consistency and guest experience quality.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Required Flag' ;
    rdfs:comment 'Indicates whether this standard is mandatory for brand compliance audits. True if required for franchise/brand certification. Non-compliance may result in brand penalties.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandTier rdf:type rdf:Property ;
    rdfs:label 'Brand Tier' ;
    rdfs:comment 'Brand service tier this standard applies to (luxury, premium, select_service, extended_stay, resort). Determines amenity quality, service frequency, and compliance requirements.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalProductSpecifications rdf:type rdf:Property ;
    rdfs:label 'Chemical Product Specifications' ;
    rdfs:comment 'Approved cleaning chemical products and usage instructions (e.g., all-purpose cleaner brand/dilution, glass cleaner, bathroom sanitizer, disinfectant contact time). Ensures safety compliance and brand standards.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningStandardStatus rdf:type rdf:Property ;
    rdfs:label 'Cleaning Standard Status' ;
    rdfs:comment 'Current lifecycle status of the cleaning standard: active (in use), inactive (temporarily disabled), draft (under development), archived (historical record).' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningType rdf:type rdf:Property ;
    rdfs:label 'Cleaning Type' ;
    rdfs:comment 'Type of cleaning service this standard defines: stayover (occupied room daily service), departure (checkout deep clean), deep_clean (periodic intensive cleaning), turndown (evening service), public_area (lobby/corridor/amenity spaces), refresh (quick tidy between same-day checkouts).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerExecutionEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Per Execution Estimate' ;
    rdfs:comment 'Estimated total cost in USD to execute this cleaning standard once, including labor, supplies, and equipment depreciation. Used for CPOR (Cost Per Occupied Room) budgeting and variance analysis.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Required' ;
    rdfs:comment 'List of equipment and tools required to execute this standard (e.g., vacuum cleaner, microfiber cloths, mop, caddy, UV sanitizer). Used for attendant assignment and equipment allocation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPassThresholdScore rdf:type rdf:Property ;
    rdfs:label 'Inspection Pass Threshold Score' ;
    rdfs:comment 'Minimum quality inspection score (0-100 scale) required to pass this cleaning standard. Rooms scoring below threshold require re-cleaning. Typical luxury threshold: 95+, select service: 85+.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Estimate' ;
    rdfs:comment 'Estimated labor cost in USD for this cleaning standard execution, calculated as target_time_minutes multiplied by average hourly wage. Primary component of CPOR.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linenChangeFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Linen Change Frequency Days' ;
    rdfs:comment 'Number of days between scheduled linen changes when protocol is every_n_days. Null for other protocols. Typical values: 2-3 for luxury, 3-5 for select service.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linenChangeProtocol rdf:type rdf:Property ;
    rdfs:label 'Linen Change Protocol' ;
    rdfs:comment 'Linen replacement policy for this standard: full_change (all linens replaced), on_request (guest opt-in), every_n_days (scheduled rotation), departure_only (checkout only). Impacts sustainability metrics and laundry costs.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyTierUpgradeAmenities rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Upgrade Amenities' ;
    rdfs:comment 'Additional or upgraded amenity items provided for loyalty elite and VIP guests (e.g., premium bath products, welcome fruit basket, branded robe, upgraded coffee). Null for standard guest segment.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Maximum Time Minutes' ;
    rdfs:comment 'Maximum allowable time in minutes for this cleaning standard. Exceeding this threshold triggers supervisor review and quality audit.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Time Minutes' ;
    rdfs:comment 'Minimum time allocation in minutes required to complete this cleaning standard. Used for labor scheduling, productivity tracking, and CPOR (Cost Per Occupied Room) calculation.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityInspectionCriteria rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Criteria' ;
    rdfs:comment 'Structured quality inspection checklist and scoring rubric (e.g., cleanliness score, amenity placement accuracy, linen presentation, bathroom sanitation). Used by supervisors and quality auditors to validate standard compliance.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Business identifier code for the cleaning standard (e.g., STY_LUX_SUITE, DEP_STD_KING, DEEP_PREM_DBL). Used for operational reference and system integration.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Human-readable name of the cleaning standard (e.g., Luxury Suite Stayover Service, Premium Departure Clean).' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyConsumptionEstimate rdf:type rdf:Property ;
    rdfs:label 'Supply Consumption Estimate' ;
    rdfs:comment 'Estimated quantity of consumable supplies per cleaning execution (e.g., 2 trash bags, 1 toilet paper roll, 50ml all-purpose cleaner). Used for inventory forecasting and CPOR calculation.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Supply Cost Estimate' ;
    rdfs:comment 'Estimated consumable supply cost in USD per execution (chemicals, amenities, linens, trash bags). Used for inventory budgeting and CPOR calculation.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Compliance Flag' ;
    rdfs:comment 'Indicates whether this standard meets corporate sustainability and environmental compliance requirements (e.g., eco-friendly chemicals, linen reuse program, water conservation). True if compliant.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Time Minutes' ;
    rdfs:comment 'Target time in minutes for completing this cleaning standard under normal conditions. Used for performance benchmarking and efficiency KPIs.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskChecklist rdf:type rdf:Property ;
    rdfs:label 'Task Checklist' ;
    rdfs:comment 'Structured list of required cleaning tasks in sequence (e.g., strip linens, dust surfaces, vacuum, sanitize bathroom, restock amenities). Stored as delimited text or JSON. Used to generate attendant mobile app checklists.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingModuleReference rdf:type rdf:Property ;
    rdfs:label 'Training Module Reference' ;
    rdfs:comment 'Reference to the training module or learning content that teaches this cleaning standard (e.g., LMS course ID, training video URL, SOP document number). Used for onboarding and certification.' ;
    rdfs:domain ind:CleaningStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningTaskId rdf:type rdf:Property ;
    rdfs:label 'Cleaning Task Id' ;
    rdfs:comment 'Unique identifier for the cleaning task. Primary key.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CleaningTask .

ind:hkAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Hk Assignment Id' ;
    rdfs:comment 'Foreign key linking to housekeeping.hk_assignment. Business justification: Cleaning tasks are granular work items performed within the context of a housekeeping assignment. The assignment is the work order; tasks are the line items. This link enables tracking of task-level p' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HkAssignment .

ind:hkScheduleId rdf:type rdf:Property ;
    rdfs:label 'Hk Schedule Id' ;
    rdfs:comment 'Foreign key linking to housekeeping.hk_schedule. Business justification: Cleaning tasks are performed during specific housekeeping shifts/schedules. This links operational task execution to the master schedule. Many cleaning tasks occur during one schedule (N:1). No bidire' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HkSchedule .

ind:maintenanceHandoffId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Handoff Id' ;
    rdfs:comment 'Reference to the maintenance work order generated as a result of issues discovered during this task.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceHandoff .

ind:roomAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Room Assignment Id' ;
    rdfs:comment 'Reference to the parent housekeeping room assignment that contains this task.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoomAssignment .

ind:taskCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Task Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Individual cleaning tasks drive labor cost allocation to departments. Required for USALI departmental expense reporting, labor productivity analysis (cost per credit), and operational budget tracking ' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual timestamp when the attendant completed or stopped performing this task.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual timestamp when the attendant began performing this task, captured from mobile device or PMS entry.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditWeight rdf:type rdf:Property ;
    rdfs:label 'Credit Weight' ;
    rdfs:comment 'Numeric credit value assigned to this task contributing to the attendant\'s total room credits for workload balancing and productivity tracking.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicates whether this task encountered an exception condition requiring supervisor attention or follow-up action.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes describing any exceptions, issues, or special circumstances encountered during task execution.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestPresent rdf:type rdf:Property ;
    rdfs:label 'Guest Present' ;
    rdfs:comment 'Indicates whether the guest was present in the room during task execution, affecting service approach and privacy considerations.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Request Flag' ;
    rdfs:comment 'Indicates whether this task was performed in response to a specific guest request rather than standard cleaning schedule.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether this task requires formal inspection by a supervisor or quality control team member.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Timestamp when the task was inspected and quality verified.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isQualityCheckpoint rdf:type rdf:Property ;
    rdfs:label 'Is Quality Checkpoint' ;
    rdfs:comment 'Indicates whether this task requires supervisor inspection or quality verification before the room can be released.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceRequestGenerated rdf:type rdf:Property ;
    rdfs:label 'Maintenance Request Generated' ;
    rdfs:comment 'Indicates whether this task resulted in a maintenance request being created for repair or follow-up work.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Numeric quality rating assigned to this task during inspection, typically on a scale of 1-5 or 1-10, used for attendant performance evaluation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Planned timestamp when the task should begin based on the room assignment schedule.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:skipReasonCode rdf:type rdf:Property ;
    rdfs:label 'Skip Reason Code' ;
    rdfs:comment 'Standardized code indicating why the task was skipped or not completed (e.g., REFUSE for guest refused service, UNAVAIL for item unavailable, MAINT for maintenance required, DND for do not disturb).' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Skip Reason Description' ;
    rdfs:comment 'Detailed explanation of why the task was skipped, providing context for exception reporting and service recovery.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'Target time in minutes for completing this task per the property\'s service level agreement and room turnaround time standards.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Duration Minutes' ;
    rdfs:comment 'Expected time in minutes to complete this task per the cleaning standard, used for performance benchmarking and labor planning.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyItemCode rdf:type rdf:Property ;
    rdfs:label 'Supply Item Code' ;
    rdfs:comment 'Code identifying the primary supply or consumable item used in this task (e.g., cleaning chemical, linen type, amenity SKU).' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyQuantityUsed rdf:type rdf:Property ;
    rdfs:label 'Supply Quantity Used' ;
    rdfs:comment 'Quantity of the supply item consumed during this task, used for inventory tracking and CPOR (Cost Per Occupied Room) calculation.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Supply Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the supply quantity used (e.g., each, bottle, sheet, towel, roll, ounce, liter, set). [ENUM-REF-CANDIDATE: each|bottle|sheet|towel|roll|ounce|liter|set — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCode rdf:type rdf:Property ;
    rdfs:label 'Task Code' ;
    rdfs:comment 'Standardized code identifying the type of cleaning task (e.g., BED for bed making, BATH for bathroom sanitization, VAC for vacuuming, LINEN for linen change, MINI for minibar restock, AMEN for amenity placement).' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskName rdf:type rdf:Property ;
    rdfs:label 'Task Name' ;
    rdfs:comment 'Human-readable name of the cleaning task (e.g., Bed Making, Bathroom Sanitization, Vacuuming, Linen Change, Minibar Restock, Amenity Placement).' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskPriority rdf:type rdf:Property ;
    rdfs:label 'Task Priority' ;
    rdfs:comment 'Priority level assigned to this task based on guest arrival time, room status urgency, or special requests.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSequence rdf:type rdf:Property ;
    rdfs:label 'Task Sequence' ;
    rdfs:comment 'Order in which this task should be performed within the room assignment per the cleaning standard operating procedure.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current completion status of the cleaning task within its lifecycle.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Category of the cleaning task indicating the nature of work performed.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingIndicator rdf:type rdf:Property ;
    rdfs:label 'Training Indicator' ;
    rdfs:comment 'Indicates whether this task was performed as part of attendant training or onboarding, affecting performance evaluation and quality expectations.' ;
    rdfs:domain ind:CleaningTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deepCleanPlanId rdf:type rdf:Property ;
    rdfs:label 'Deep Clean Plan Id' ;
    rdfs:comment 'Unique identifier for the deep cleaning plan record. Primary key.' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deepCleanCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Deep Clean Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Deep cleaning projects are significant labor and supply expenses requiring cost center allocation for capital vs operating expense classification, PIP compliance tracking, and departmental budget mana' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Identifier of the employee who performed the quality inspection. Null if inspection not yet performed.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryDeepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Deep Employee Id' ;
    rdfs:comment 'Identifier of the housekeeping supervisor responsible for overseeing the deep cleaning execution.' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:spaTreatmentRoomId rdf:type rdf:Property ;
    rdfs:label 'Spa Treatment Room Id' ;
    rdfs:comment 'Foreign key linking to spa.treatment_room. Business justification: Spa treatment rooms require periodic deep cleaning (grout, upholstery, equipment sanitization) beyond daily maintenance. Hotels schedule these through housekeeping deep clean rotation cycles for quali' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentRoom .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual number of labor hours spent on the deep cleaning tasks. Null if not yet completed.' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:areaName rdf:type rdf:Property ;
    rdfs:label 'Area Name' ;
    rdfs:comment 'Name or description of the public area or space being deep cleaned (e.g., lobby, pool deck, grand ballroom). Null for guest rooms.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaType rdf:type rdf:Property ;
    rdfs:label 'Area Type' ;
    rdfs:comment 'Classification of the area being deep cleaned (guest room, public area, back of house, meeting space, food and beverage outlet, fitness center).' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of the deep cleaning work completed (0.00 to 100.00). Used for tracking progress on in-progress plans.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deepCleanPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Deep Clean Plan Status' ;
    rdfs:comment 'Current status of the deep cleaning plan (scheduled, in progress, completed, cancelled, deferred, on hold).' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Estimated number of labor hours required to complete the deep cleaning tasks.' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ffeInspectionPerformed rdf:type rdf:Property ;
    rdfs:label 'Ffe Inspection Performed' ;
    rdfs:comment 'Indicates whether a Furniture Fixtures and Equipment inspection was performed as part of the deep cleaning (True/False).' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Total labor cost for the deep cleaning activity, calculated from actual labor hours and wage rates.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceIssuesIdentified rdf:type rdf:Property ;
    rdfs:label 'Maintenance Issues Identified' ;
    rdfs:comment 'Indicates whether maintenance issues were identified during the deep cleaning that require follow-up (True/False).' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Pip Compliance Flag' ;
    rdfs:comment 'Indicates whether this deep cleaning plan is part of a Property Improvement Plan compliance requirement (True/False).' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Pip Reference Code' ;
    rdfs:comment 'Reference code linking this deep cleaning plan to a specific Property Improvement Plan requirement. Null if not PIP-related.' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Business identifier or code for the deep cleaning plan, used for tracking and reporting purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Scheduled date for the deep cleaning to be performed.' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled end timestamp for the deep cleaning activity.' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled start timestamp for the deep cleaning activity.' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether a quality inspection is required after deep cleaning completion (True/False).' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rescheduledDate rdf:type rdf:Property ;
    rdfs:label 'Rescheduled Date' ;
    rdfs:comment 'New scheduled date if the deep cleaning plan was rescheduled. Null if not rescheduled.' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rotationCycle rdf:type rdf:Property ;
    rdfs:label 'Rotation Cycle' ;
    rdfs:comment 'Frequency of the deep cleaning rotation (monthly, quarterly, semi-annual, annual, bi-annual, ad-hoc).' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfWork rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Detailed description of the deep cleaning tasks to be performed (e.g., carpet shampooing, grout cleaning, upholstery treatment, Furniture Fixtures and Equipment inspection, window washing, HVAC vent cleaning).' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyCost rdf:type rdf:Property ;
    rdfs:label 'Supply Cost' ;
    rdfs:comment 'Total cost of cleaning supplies and materials consumed during the deep cleaning activity.' ;
    rdfs:domain ind:DeepCleanPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Assignment Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Housekeeping assignments must be charged to departmental cost centers for USALI labor cost tracking, budget variance analysis, and departmental P&L reporting. Essential for rooms division financial ma' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:allergyFlags rdf:type rdf:Property ;
    rdfs:label 'Allergy Flags' ;
    rdfs:comment 'Comma-separated list of guest allergy or sensitivity flags that require special cleaning products or procedures (e.g., \'fragrance-free\', \'latex-free\', \'pet dander\').' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amenityReplenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amenity Replenishment Flag' ;
    rdfs:comment 'Indicates whether guest amenities (toiletries, coffee, water, etc.) were replenished during this assignment.' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Human-readable business identifier for the housekeeping assignment, typically formatted as property-date-sequence.' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'The type of housekeeping service to be performed: stayover (occupied room refresh), departure (checkout cleaning), deep clean (thorough cleaning), turndown (evening service), VIP prep (special preparation), or inspection (quality check).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dndFlag rdf:type rdf:Property ;
    rdfs:label 'Dnd Flag' ;
    rdfs:comment 'Indicates whether the guest has activated the Do Not Disturb indicator at the time of assignment. True if DND is active; attendant should skip or defer service.' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedEndTime rdf:type rdf:Property ;
    rdfs:label 'Estimated End Time' ;
    rdfs:comment 'The planned timestamp when the attendant is expected to complete work on this assignment.' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedStartTime rdf:type rdf:Property ;
    rdfs:label 'Estimated Start Time' ;
    rdfs:comment 'The planned timestamp when the attendant is expected to begin work on this assignment.' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:guestPreferenceInstructions rdf:type rdf:Property ;
    rdfs:label 'Guest Preference Instructions' ;
    rdfs:comment 'Free-text instructions for the attendant regarding guest-specific preferences, special requests, or service notes (e.g., extra towels, hypoallergenic products, preferred pillow type).' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linenChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Linen Change Flag' ;
    rdfs:comment 'Indicates whether a full linen change (sheets, pillowcases, duvet covers) was performed during this assignment.' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceRequestDescription rdf:type rdf:Property ;
    rdfs:label 'Maintenance Request Description' ;
    rdfs:comment 'Free-text description of the maintenance issue identified by the attendant (e.g., \'leaking faucet\', \'broken lamp\', \'HVAC not cooling\').' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Request Flag' ;
    rdfs:comment 'Indicates whether the attendant identified a maintenance issue during service that requires a work order handoff to the maintenance department.' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredServiceTime rdf:type rdf:Property ;
    rdfs:label 'Preferred Service Time' ;
    rdfs:comment 'Guest-requested time window for housekeeping service (e.g., \'after 2pm\', \'morning only\'), captured from guest profile or front desk communication.' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reassignmentCount rdf:type rdf:Property ;
    rdfs:label 'Reassignment Count' ;
    rdfs:comment 'The number of times this assignment has been reassigned to a different attendant, indicating scheduling changes or workload rebalancing.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomCredits rdf:type rdf:Property ;
    rdfs:label 'Room Credits' ;
    rdfs:comment 'The number of room credits assigned to this task for productivity tracking and labor allocation. Standard departure cleaning typically equals 1.0 credit; stayovers may be 0.5; deep cleans may be 1.5-2.0.' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomStatusAfter rdf:type rdf:Property ;
    rdfs:label 'Room Status After' ;
    rdfs:comment 'The room status after the attendant completes the assignment and updates the system.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomStatusBefore rdf:type rdf:Property ;
    rdfs:label 'Room Status Before' ;
    rdfs:comment 'The room status at the time the assignment was created, before the attendant begins work.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCleaningCode rdf:type rdf:Property ;
    rdfs:label 'Special Cleaning Code' ;
    rdfs:comment 'Code indicating special cleaning protocols applied (e.g., \'COVID-19\', \'biohazard\', \'pet cleanup\', \'smoke remediation\').' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:towelChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Towel Change Flag' ;
    rdfs:comment 'Indicates whether towels were replaced during this assignment.' ;
    rdfs:domain ind:HkAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vipIndicator rdf:type rdf:Property ;
    rdfs:label 'Vip Indicator' ;
    rdfs:comment 'Indicates whether the guest is flagged as a VIP, requiring enhanced service standards, special amenities, or supervisor inspection.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryHkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Hk Employee Id' ;
    rdfs:comment 'Identifier of the user (typically housekeeping manager or supervisor) who published the schedule. Nullable if not yet published.' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scheduleCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Schedule Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Shift schedules drive labor budget allocation to cost centers. Essential for labor forecasting, budget variance analysis, CPOR (Cost Per Occupied Room) calculation, and departmental P&L accuracy.' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:tertiaryHkModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Hk Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this housekeeping schedule record.' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'The length of the scheduled break in minutes. Nullable if no break is scheduled.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakStartTime rdf:type rdf:Property ;
    rdfs:label 'Break Start Time' ;
    rdfs:comment 'The scheduled start time for the break window during the shift. Nullable if no formal break is scheduled.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consecutiveDaysWorked rdf:type rdf:Property ;
    rdfs:label 'Consecutive Days Worked' ;
    rdfs:comment 'The number of consecutive days worked by attendants assigned to this schedule, tracked for union CBA compliance (maximum consecutive days before mandatory rest).' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cporTarget rdf:type rdf:Property ;
    rdfs:label 'Cpor Target' ;
    rdfs:comment 'The target Cost Per Occupied Room for housekeeping labor and supplies for this schedule, used for performance tracking and labor planning.' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Budget Amount' ;
    rdfs:comment 'The budgeted labor cost for this shift in the property\'s operating currency, aligned to CPOR (Cost Per Occupied Room) targets.' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyForecastTier rdf:type rdf:Property ;
    rdfs:label 'Occupancy Forecast Tier' ;
    rdfs:comment 'The forecasted occupancy level tier for the schedule date, used to calibrate staffing levels (low, medium, high, peak).' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Threshold Hours' ;
    rdfs:comment 'The number of hours beyond which overtime pay applies for attendants on this shift, per union CBA or local labor law.' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount' ;
    rdfs:comment 'The number of housekeeping attendants planned to work during this shift, calibrated to occupancy forecast and room count.' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Date' ;
    rdfs:comment 'The specific date for which this housekeeping schedule is defined. Used for daily operational planning.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sectionCode rdf:type rdf:Property ;
    rdfs:label 'Section Code' ;
    rdfs:comment 'The housekeeping section or zone code assigned for this schedule (e.g., floor grouping, wing, building). Used for section-to-attendant assignment.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionCreditValue rdf:type rdf:Property ;
    rdfs:label 'Section Credit Value' ;
    rdfs:comment 'The total credit value assigned to the section, representing the workload complexity (e.g., suite rooms may have higher credit values than standard rooms).' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sectionRoomCount rdf:type rdf:Property ;
    rdfs:label 'Section Room Count' ;
    rdfs:comment 'The total number of rooms in the assigned housekeeping section.' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'The scheduled end time for the housekeeping shift on the schedule date.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'The scheduled start time for the housekeeping shift on the schedule date.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'The type of housekeeping shift being scheduled (AM morning shift, PM afternoon shift, overnight night shift, or split shift).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turndownEndTime rdf:type rdf:Property ;
    rdfs:label 'Turndown End Time' ;
    rdfs:comment 'The scheduled end time for turndown service during this shift. Nullable if turndown service is not scheduled.' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:turndownServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Turndown Service Flag' ;
    rdfs:comment 'Indicates whether turndown service is scheduled for this shift (True if turndown service is included, False otherwise).' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:turndownStartTime rdf:type rdf:Property ;
    rdfs:label 'Turndown Start Time' ;
    rdfs:comment 'The scheduled start time for turndown service during this shift. Nullable if turndown service is not scheduled.' ;
    rdfs:domain ind:HkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionId rdf:type rdf:Property ;
    rdfs:label 'Inspection Id' ;
    rdfs:comment 'Unique identifier for the quality inspection record. Primary key for the inspection entity.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:inspectionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Employee Id' ;
    rdfs:comment 'Reference to the housekeeping supervisor or quality inspector who performed the inspection. Links to workforce/employee master data.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amenityCheckFlag rdf:type rdf:Property ;
    rdfs:label 'Amenity Check Flag' ;
    rdfs:comment 'Boolean indicator whether the inspector verified that all required room amenities are present and properly stocked (toiletries, linens, coffee supplies, etc.).' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bathroomQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Bathroom Quality Flag' ;
    rdfs:comment 'Boolean indicator whether the bathroom meets cleanliness and quality standards, including fixtures, surfaces, and amenities, a critical GSS (Guest Satisfaction Score) driver.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleanlinessScore rdf:type rdf:Property ;
    rdfs:label 'Cleanliness Score' ;
    rdfs:comment 'Sub-score specifically measuring cleanliness standards (surfaces, bathroom, floors, linens), a key component of overall quality score and GSS (Guest Satisfaction Score).' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Detailed free-text description of all deficiencies and quality issues identified during the inspection, used for corrective action and training purposes.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The actual date and time when the inspector completed the room inspection, used for duration calculation and productivity tracking.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:guestArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Guest Arrival Date' ;
    rdfs:comment 'The scheduled arrival date of the next guest for this room, used to prioritize inspection urgency and ensure room readiness for check-in.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linenQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Linen Quality Flag' ;
    rdfs:comment 'Boolean indicator whether linens (sheets, towels, pillowcases) meet quality standards with no stains, tears, or wear, critical for guest satisfaction.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Issue Flag' ;
    rdfs:comment 'Boolean indicator whether maintenance issues were identified during the inspection that require handoff to the maintenance department (e.g., broken fixtures, HVAC problems, plumbing issues).' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recleanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reclean Required Flag' ;
    rdfs:comment 'Boolean indicator whether the room requires re-cleaning due to deficiencies identified during inspection. True indicates the room failed inspection and must be re-cleaned before guest occupancy.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roomReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Room Release Flag' ;
    rdfs:comment 'Boolean indicator whether the room has been formally released as inspected and made available for guest check-in. True indicates the room is ready for sale and occupancy.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roomReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Room Release Timestamp' ;
    rdfs:comment 'The precise date and time when the room was released as inspected and made available for guest occupancy, critical for RevPAR (Revenue Per Available Room) and inventory availability tracking.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Time' ;
    rdfs:comment 'The precise date and time when the inspection was scheduled to begin, enabling time-based operational coordination.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialRequestNotes rdf:type rdf:Property ;
    rdfs:label 'Special Request Notes' ;
    rdfs:comment 'Free-text notes capturing any special guest requests or room preparation requirements that the inspector must verify (e.g., hypoallergenic bedding, extra amenities, accessibility features).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The actual date and time when the inspector began the room inspection, used for duration calculation and operational analytics.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionDeficiencyId rdf:type rdf:Property ;
    rdfs:label 'Inspection Deficiency Id' ;
    rdfs:comment 'Unique identifier for the inspection deficiency record. Primary key for the inspection deficiency entity.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInspectionAssignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Assigned To Employee Id' ;
    rdfs:comment 'Reference to the specific employee assigned to resolve the deficiency. Supports individual accountability and performance tracking.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualResolutionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Time Minutes' ;
    rdfs:comment 'Actual time in minutes taken to resolve the deficiency. Enables variance analysis against estimates and supports CPOR (Cost Per Occupied Room) calculation.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blocksRoomSaleFlag rdf:type rdf:Property ;
    rdfs:label 'Blocks Room Sale Flag' ;
    rdfs:comment 'Indicates whether the deficiency prevents the room from being sold until resolved. Critical for revenue management and inventory availability.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deficiencyCategory rdf:type rdf:Property ;
    rdfs:label 'Deficiency Category' ;
    rdfs:comment 'Primary classification of the deficiency type. Categories align with housekeeping quality standards and maintenance handoff protocols.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencySequence rdf:type rdf:Property ;
    rdfs:label 'Deficiency Sequence' ;
    rdfs:comment 'Sequential line number of this deficiency within the parent inspection. Orders deficiencies for reporting and review workflows.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencySubcategory rdf:type rdf:Property ;
    rdfs:label 'Deficiency Subcategory' ;
    rdfs:comment 'Detailed subcategory within the primary deficiency category. Examples: bathroom cleanliness, HVAC malfunction, missing amenity, torn linen, wall damage, fire safety violation. Enables granular trend analysis.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedResolutionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Resolution Time Minutes' ;
    rdfs:comment 'Estimated time in minutes required to resolve the deficiency. Used for workload planning and labor cost estimation.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guestImpactingFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Impacting Flag' ;
    rdfs:comment 'Indicates whether the deficiency directly impacts guest experience or satisfaction. Used for GSS (Guest Satisfaction Score) correlation analysis.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Identified Timestamp' ;
    rdfs:comment 'Date and time when the deficiency was first identified during inspection. Business event timestamp for deficiency lifecycle tracking.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationDetail rdf:type rdf:Property ;
    rdfs:label 'Location Detail' ;
    rdfs:comment 'Specific location within the room where the deficiency was found. Examples: bathroom sink, bedroom closet, balcony door, minibar area. Enables precise corrective action.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoAttachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Url' ;
    rdfs:comment 'URL or file path to photographic evidence of the deficiency. Supports visual documentation for training, dispute resolution, and quality audits.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Taken' ;
    rdfs:comment 'Description of preventive actions implemented to avoid recurrence of this deficiency type. Supports continuous improvement programs.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringDeficiencyFlag rdf:type rdf:Property ;
    rdfs:label 'Recurring Deficiency Flag' ;
    rdfs:comment 'Indicates whether this deficiency has been identified in previous inspections of the same room. Flags systemic quality issues requiring root cause analysis.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Completed Timestamp' ;
    rdfs:comment 'Date and time when the corrective action was completed. Used to calculate actual resolution time and SLA compliance.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Resolution Cost Amount' ;
    rdfs:comment 'Direct cost incurred to resolve the deficiency, including labor, materials, and supplies. Denominated in property base currency. Supports CPOR and GOP (Gross Operating Profit) analysis.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Started Timestamp' ;
    rdfs:comment 'Date and time when corrective action was initiated. Measures response time from identification to action.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the deficiency resolution workflow. Tracks lifecycle from identification through verification and closure.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Classification of the underlying root cause of the deficiency. Supports continuous improvement and preventive action planning.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseNotes rdf:type rdf:Property ;
    rdfs:label 'Root Cause Notes' ;
    rdfs:comment 'Detailed notes on the root cause analysis performed for this deficiency. Documents findings for knowledge management and training.' ;
    rdfs:domain ind:InspectionDeficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laundryOrderId rdf:type rdf:Property ;
    rdfs:label 'Laundry Order Id' ;
    rdfs:comment 'Unique identifier for the laundry order. Primary key for the laundry order transaction.' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaundryOrder .

ind:primaryLaundrySubmittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Laundry Submitted By Employee Id' ;
    rdfs:comment 'Identifier of the housekeeping staff member who submitted the laundry order.' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:processingVendorId rdf:type rdf:Property ;
    rdfs:label 'Processing Vendor Id' ;
    rdfs:comment 'Identifier of the laundry vendor or facility processing this order. Null for on-property laundry operations.' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualReturnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Return Timestamp' ;
    rdfs:comment 'Actual date and time when the cleaned laundry was returned to the property. Null if not yet returned. Used for SLA compliance tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costPerItem rdf:type rdf:Property ;
    rdfs:label 'Cost Per Item' ;
    rdfs:comment 'Unit cost per individual laundry item processed. Applicable when pricing_method is per_item.' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerPound rdf:type rdf:Property ;
    rdfs:label 'Cost Per Pound' ;
    rdfs:comment 'Unit cost per pound of laundry processed. Applicable when pricing_method is per_pound. Used for CPOR (Cost Per Occupied Room) calculations.' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedReturnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expected Return Timestamp' ;
    rdfs:comment 'Scheduled date and time when the cleaned laundry is expected to be returned to the property. Used for linen availability planning.' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pricingMethod rdf:type rdf:Property ;
    rdfs:label 'Pricing Method' ;
    rdfs:comment 'Method used to calculate laundry processing cost: per_pound (weight-based), per_item (item count-based), flat_rate (fixed fee per order), contract (pre-negotiated rate).' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingLocation rdf:type rdf:Property ;
    rdfs:label 'Processing Location' ;
    rdfs:comment 'Indicates whether laundry is processed on-property (in-house laundry facility) or off-property (outsourced to external vendor).' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Notes' ;
    rdfs:comment 'Free-text notes from quality inspection documenting any issues, defects, or observations about the returned laundry.' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Result of quality inspection upon return: pending (awaiting inspection), passed (meets quality standards), failed (requires re-processing), not_required (inspection waived).' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemCount rdf:type rdf:Property ;
    rdfs:label 'Total Item Count' ;
    rdfs:comment 'Total number of individual laundry items included in this order across all item types.' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Total Weight Lbs' ;
    rdfs:comment 'Total weight of laundry items in this order measured in pounds. Used for weight-based pricing calculations.' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Hours' ;
    rdfs:comment 'Actual turnaround time in hours from submission to return. Calculated as the difference between actual_return_timestamp and submission_timestamp. Used for vendor SLA (Service Level Agreement) performance tracking.' ;
    rdfs:domain ind:LaundryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linenManagementId rdf:type rdf:Property ;
    rdfs:label 'Linen Management Id' ;
    rdfs:comment 'Primary key for linen_management' ;
    rdfs:domain ind:LinenManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linenCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Linen Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Linen transactions (purchases, transfers, discards) must be allocated to departmental cost centers for USALI operating expense reporting, inventory valuation, and departmental cost control of linen pr' ;
    rdfs:domain ind:LinenManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:primaryLinenPropertyId rdf:type rdf:Property ;
    rdfs:label 'Primary Linen Property Id' ;
    rdfs:comment 'Identifier of the hotel property where the linen transaction occurred.' ;
    rdfs:domain ind:LinenManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Quality condition assessment of the linen at time of transaction (new, excellent, good, fair, poor, damaged). Used for loss and shrinkage analysis.' ;
    rdfs:domain ind:LinenManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'Target location of the linen movement (e.g., Floor 5 Linen Closet, Laundry for soiled returns, Discard Bin).' ;
    rdfs:domain ind:LinenManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discardReason rdf:type rdf:Property ;
    rdfs:label 'Discard Reason' ;
    rdfs:comment 'Reason code for linen discard transactions (stained, torn, worn out, burned, lost, stolen, contaminated, expired). Used for loss and shrinkage root-cause analysis. [ENUM-REF-CANDIDATE: stained|torn|worn|burned|lost|stolen|contaminated|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LinenManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Floor or level identifier where linen was issued to or returned from. Null for central laundry transactions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parLevelAfter rdf:type rdf:Property ;
    rdfs:label 'Par Level After' ;
    rdfs:comment 'Inventory par level for this item type at the location after the transaction. Enables variance analysis.' ;
    rdfs:domain ind:LinenManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parLevelBefore rdf:type rdf:Property ;
    rdfs:label 'Par Level Before' ;
    rdfs:comment 'Inventory par level for this item type at the location before the transaction. Used for par-level compliance tracking.' ;
    rdfs:domain ind:LinenManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number for linen procurement transactions. Links to procurement system for three-way match.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Housekeeping shift during which the linen transaction occurred (AM, PM, or Night shift).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocation rdf:type rdf:Property ;
    rdfs:label 'Source Location' ;
    rdfs:comment 'Origin location of the linen movement (e.g., Central Laundry, Floor 3 Linen Closet, Property B for transfers).' ;
    rdfs:domain ind:LinenManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedBy rdf:type rdf:Property ;
    rdfs:label 'Voided By' ;
    rdfs:comment 'Identifier of the user who voided the transaction. Null if not voided.' ;
    rdfs:domain ind:LinenManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voidedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Voided Timestamp' ;
    rdfs:comment 'Date and time when the transaction was voided. Null if not voided.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lostAndFoundId rdf:type rdf:Property ;
    rdfs:label 'Lost And Found Id' ;
    rdfs:comment 'Unique identifier for the lost and found record. Primary key.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLostFinderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lost Finder Employee Id' ;
    rdfs:comment 'Identifier of the housekeeping attendant or staff member who discovered the item.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:claimDate rdf:type rdf:Property ;
    rdfs:label 'Claim Date' ;
    rdfs:comment 'Date when the item was claimed by the guest or authorized party.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Status of the claim process indicating whether the item has been claimed by a guest or remains unclaimed.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Claimant Identification Number' ;
    rdfs:comment 'Identification document number presented by the claimant for audit trail and verification.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantIdentificationType rdf:type rdf:Property ;
    rdfs:label 'Claimant Identification Type' ;
    rdfs:comment 'Type of identification document presented by the claimant for verification purposes.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantName rdf:type rdf:Property ;
    rdfs:label 'Claimant Name' ;
    rdfs:comment 'Full name of the person who claimed the item, which may differ from the original guest if authorized representative.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryLocationDetail rdf:type rdf:Property ;
    rdfs:label 'Discovery Location Detail' ;
    rdfs:comment 'Specific location details within the location type (e.g., under bed, in closet, on table) to aid in verification during claim process.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryLocationType rdf:type rdf:Property ;
    rdfs:label 'Discovery Location Type' ;
    rdfs:comment 'Type of location where the item was discovered. [ENUM-REF-CANDIDATE: guest_room|public_area|restaurant|meeting_room|fitness_center|pool|parking|lobby|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Precise date and time when the item was discovered and logged into the lost and found system.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date when the final disposition action was completed.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Disposition Notes' ;
    rdfs:comment 'Additional notes regarding the disposition action including recipient organization for donations or authority contact for turned-over items.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionType rdf:type rdf:Property ;
    rdfs:label 'Disposition Type' ;
    rdfs:comment 'Final disposition action taken for the item after the retention period or claim resolution.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Amount' ;
    rdfs:comment 'Estimated monetary value of the item in the property\'s base currency for liability and insurance purposes.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guestNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Guest Notification Date' ;
    rdfs:comment 'Date when the guest was successfully notified about the found item.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guestNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Guest Notification Method' ;
    rdfs:comment 'Communication channel used to notify the guest about the found item.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Guest Notification Status' ;
    rdfs:comment 'Status of attempts to notify the guest about the discovered item.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHighValueItem rdf:type rdf:Property ;
    rdfs:label 'Is High Value Item' ;
    rdfs:comment 'Flag indicating whether the item exceeds the property\'s high-value threshold requiring special handling and management approval.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemBrand rdf:type rdf:Property ;
    rdfs:label 'Item Brand' ;
    rdfs:comment 'Brand or manufacturer name of the item, if identifiable.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemColor rdf:type rdf:Property ;
    rdfs:label 'Item Color' ;
    rdfs:comment 'Primary color of the item for identification purposes.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemNumber rdf:type rdf:Property ;
    rdfs:label 'Item Number' ;
    rdfs:comment 'Externally-visible unique tracking number assigned to the lost and found item for guest reference and claim processing.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lostAndFoundStatus rdf:type rdf:Property ;
    rdfs:label 'Lost And Found Status' ;
    rdfs:comment 'Current lifecycle status of the lost and found item tracking its progression from discovery through final disposition. [ENUM-REF-CANDIDATE: logged|guest_notified|claimed|pending_disposition|returned_to_guest|donated|discarded|turned_over_to_authorities — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Url' ;
    rdfs:comment 'URL or file path to photograph of the item for identification and verification purposes.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSpecialHandling rdf:type rdf:Property ;
    rdfs:label 'Requires Special Handling' ;
    rdfs:comment 'Flag indicating whether the item requires special storage conditions or handling procedures (e.g., refrigeration, secure vault).' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days the item must be retained before disposition per property policy and local regulations.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shippingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Amount' ;
    rdfs:comment 'Cost charged to the guest for shipping the item to their location.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipping Tracking Number' ;
    rdfs:comment 'Carrier tracking number if the item was shipped to the guest at their request.' ;
    rdfs:domain ind:LostAndFound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Specific instructions for handling, storing, or preserving the item.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Maintenance requests must be charged to appropriate cost centers (housekeeping vs maintenance department) for interdepartmental cost allocation, chargeback processing, and accurate departmental P&L un' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:primaryMaintenanceReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Reported By Employee Id' ;
    rdfs:comment 'Identifier of the housekeeping staff member who identified and reported the maintenance issue.' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Identifier of the formal engineering work order created to track and resolve this maintenance issue, if applicable.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:adaComplianceIssue rdf:type rdf:Property ;
    rdfs:label 'Ada Compliance Issue' ;
    rdfs:comment 'Indicates whether the maintenance issue affects ADA (Americans with Disabilities Act) accessibility features or compliance (True/False).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensationOffered rdf:type rdf:Property ;
    rdfs:label 'Compensation Offered' ;
    rdfs:comment 'Indicates whether any form of compensation (room credit, upgrade, amenity) was offered to the guest due to the maintenance issue (True/False).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed narrative description of the maintenance issue as observed by housekeeping staff, including location within the room and severity indicators.' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Category of the maintenance issue identified: plumbing (leaks, drains), electrical (outlets, lighting), HVAC (Heating Ventilation and Air Conditioning - temperature control, air quality), furniture (beds, chairs, desks), fixtures (bathroom fixtures, mirrors), appliance (minibar, TV, safe), structural (walls, floors, ceilings), safety (fire alarms, locks), or other. [ENUM-REF-CANDIDATE: plumbing|electrical|hvac|furniture|fixtures|appliance|structural|safety|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Date' ;
    rdfs:comment 'Target date by which the maintenance issue is expected to be resolved, used for planning and guest communication. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ffeCategory rdf:type rdf:Property ;
    rdfs:label 'Ffe Category' ;
    rdfs:comment 'Classification of whether the maintenance issue involves FF&E (Furniture Fixtures and Equipment) assets: furniture (movable items), fixtures (installed items), equipment (operational devices), or none (building systems).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for follow-up inspection or additional work, if required. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guestImpacted rdf:type rdf:Property ;
    rdfs:label 'Guest Impacted' ;
    rdfs:comment 'Indicates whether a guest was directly impacted by the maintenance issue (True) or if the issue was identified during routine cleaning of a vacant room (False).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestNotified rdf:type rdf:Property ;
    rdfs:label 'Guest Notified' ;
    rdfs:comment 'Indicates whether the guest was notified about the maintenance issue and any impact to their stay (True/False).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoffStatus rdf:type rdf:Property ;
    rdfs:label 'Handoff Status' ;
    rdfs:comment 'Current workflow state of the maintenance handoff: pending (awaiting engineering review), acknowledged (engineering notified), assigned (technician assigned), in_progress (work underway), completed (issue resolved), cancelled (no longer needed).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoAttached rdf:type rdf:Property ;
    rdfs:label 'Photo Attached' ;
    rdfs:comment 'Indicates whether photographic documentation of the maintenance issue was captured and attached to the request (True/False).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresParts rdf:type rdf:Property ;
    rdfs:label 'Requires Parts' ;
    rdfs:comment 'Indicates whether the maintenance repair requires ordering or retrieving replacement parts (True) or can be completed with on-hand materials (False).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresVendor rdf:type rdf:Property ;
    rdfs:label 'Requires Vendor' ;
    rdfs:comment 'Indicates whether the maintenance issue requires external vendor or contractor support (True) or can be handled by in-house staff (False).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roomStatusImpact rdf:type rdf:Property ;
    rdfs:label 'Room Status Impact' ;
    rdfs:comment 'Impact of the maintenance issue on room availability: out_of_order (room cannot be sold or occupied), out_of_service (room temporarily unavailable), sellable_with_note (room can be sold with guest notification), no_impact (room remains fully available).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyHazard rdf:type rdf:Property ;
    rdfs:label 'Safety Hazard' ;
    rdfs:comment 'Indicates whether the maintenance issue poses an immediate safety hazard to guests or staff (True/False), requiring urgent attention per OSHA standards.' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceInspectionType rdf:type rdf:Property ;
    rdfs:label 'Source Inspection Type' ;
    rdfs:comment 'Type of housekeeping activity during which the maintenance issue was identified: routine_cleaning (daily service), checkout_inspection (post-departure check), quality_inspection (supervisor review), guest_complaint (guest-reported issue), preventive_maintenance (scheduled inspection).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Priority classification for the maintenance request: critical (immediate safety hazard or room unusable), high (impacts guest experience significantly), medium (noticeable but not blocking), low (cosmetic or minor).' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyApplicable rdf:type rdf:Property ;
    rdfs:label 'Warranty Applicable' ;
    rdfs:comment 'Indicates whether the defective item or system is still under manufacturer or vendor warranty (True/False).' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Work Started Timestamp' ;
    rdfs:comment 'Date and time when the assigned technician began work on the maintenance issue. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MaintenanceHandoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:publicAreaId rdf:type rdf:Property ;
    rdfs:label 'Public Area Id' ;
    rdfs:comment 'Unique identifier for the public area cleaning zone record. Primary key for the public area entity.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Area Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Public area cleaning must be allocated to cost centers for USALI departmental reporting, labor and supply cost tracking by area type, and operational budget management of common spaces.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'Unique business identifier code for the public area zone within the property (e.g., LOBBY-01, CORR-2F, ELEV-BANK-A). Used for operational reference and assignment tracking.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingSection rdf:type rdf:Property ;
    rdfs:label 'Building Section' ;
    rdfs:comment 'Building section, wing, or tower designation for multi-building or large properties (e.g., North Tower, East Wing, Main Building).' ;
    rdfs:domain ind:Housekeeping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalProductsApproved rdf:type rdf:Property ;
    rdfs:label 'Chemical Products Approved' ;
    rdfs:comment 'List of approved cleaning chemical products and disinfectants for use in this public area. Ensures brand compliance, safety, and sustainability standards.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningFrequencyTimesPerDay rdf:type rdf:Property ;
    rdfs:label 'Cleaning Frequency Times Per Day' ;
    rdfs:comment 'Number of times per day this public area is scheduled for cleaning service. Null for non-daily frequencies.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cleaningFrequencyType rdf:type rdf:Property ;
    rdfs:label 'Cleaning Frequency Type' ;
    rdfs:comment 'Standard cleaning frequency schedule for this public area. Determines staffing assignments and quality standards. [ENUM-REF-CANDIDATE: continuous|hourly|multiple_daily|daily|every_other_day|weekly|as_needed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditValue rdf:type rdf:Property ;
    rdfs:label 'Credit Value' ;
    rdfs:comment 'Housekeeping credit value assigned to this public area for workload balancing and productivity tracking. Comparable to room credits for equitable assignment distribution.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deepCleanRotationCycleDays rdf:type rdf:Property ;
    rdfs:label 'Deep Clean Rotation Cycle Days' ;
    rdfs:comment 'Number of days in the deep cleaning rotation cycle for this public area (e.g., 30, 60, 90 days). Determines frequency of intensive cleaning beyond daily service.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedMonthlyLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Monthly Labor Hours' ;
    rdfs:comment 'Estimated total labor hours per month required to maintain this public area according to cleaning frequency and standards. Used for staffing planning and labor budgeting.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMonthlySupplyCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Monthly Supply Cost' ;
    rdfs:comment 'Estimated monthly cost of cleaning supplies and consumables for this public area. Used for budget planning and variance analysis.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guestFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Facing Flag' ;
    rdfs:comment 'Indicates whether this public area is directly visible and accessible to guests (True) or is back-of-house/staff-only (False). Guest-facing areas have higher quality standards.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highTrafficFlag rdf:type rdf:Property ;
    rdfs:label 'High Traffic Flag' ;
    rdfs:comment 'Indicates whether this public area experiences high guest traffic volume requiring more frequent cleaning and inspection (True) or standard traffic (False).' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDeepCleanDate rdf:type rdf:Property ;
    rdfs:label 'Last Deep Clean Date' ;
    rdfs:comment 'Date of the most recent deep cleaning or intensive maintenance service performed for this public area. Used to schedule next deep clean cycle.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInspectionScore rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Score' ;
    rdfs:comment 'Quality score achieved in the most recent inspection of this public area. Used for trend analysis and performance tracking.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDeepCleanDate rdf:type rdf:Property ;
    rdfs:label 'Next Deep Clean Date' ;
    rdfs:comment 'Scheduled date for the next deep cleaning or intensive maintenance service for this public area. Based on rotation cycle and property standards.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Frequency' ;
    rdfs:comment 'Frequency at which formal quality inspections are conducted for this public area. High-priority guest-facing areas typically require more frequent inspection.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScoreTarget rdf:type rdf:Property ;
    rdfs:label 'Quality Score Target' ;
    rdfs:comment 'Target quality inspection score (typically 0-100 scale) that this public area must maintain. Used for performance management and brand compliance.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyHazardNotes rdf:type rdf:Property ;
    rdfs:label 'Safety Hazard Notes' ;
    rdfs:comment 'Documentation of any safety hazards or special precautions required when cleaning this public area (e.g., high-voltage equipment, slippery surfaces, confined space).' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalCloseDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Close Date' ;
    rdfs:comment 'Annual date when seasonal public area closes for off-season. Null for year-round areas.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalOpenDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Open Date' ;
    rdfs:comment 'Annual date when seasonal public area opens for guest use. Null for year-round areas.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Special Equipment Required' ;
    rdfs:comment 'List of specialized cleaning equipment required for this public area (e.g., floor scrubber, carpet extractor, high-reach duster, pressure washer). Used for resource planning and assignment.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCleaningDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Cleaning Duration Minutes' ;
    rdfs:comment 'Standard time in minutes required to complete one full cleaning cycle of this public area. Used for labor budgeting and scheduling.' ;
    rdfs:domain ind:PublicArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified Flag' ;
    rdfs:comment 'Indicates whether this public area uses green/sustainable cleaning practices and products meeting environmental certification standards (e.g., Green Seal, EcoLogo).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Supply Consumption Id' ;
    rdfs:comment 'Unique identifier for the supply consumption transaction record.' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupplyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Supply Employee Id' ;
    rdfs:comment 'Identifier of the housekeeping staff member who recorded the supply consumption.' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amenityType rdf:type rdf:Property ;
    rdfs:label 'Amenity Type' ;
    rdfs:comment 'The category of supply or amenity consumed (toiletries, coffee supplies, stationery, in-room collateral, linens, cleaning supplies).' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Amount' ;
    rdfs:comment 'The amount charged to the guest folio for this supply consumption, if applicable.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionDate rdf:type rdf:Property ;
    rdfs:label 'Consumption Date' ;
    rdfs:comment 'The calendar date on which the supply consumption occurred.' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumptionReason rdf:type rdf:Property ;
    rdfs:label 'Consumption Reason' ;
    rdfs:comment 'The business reason for the supply consumption (standard service, guest request, damage replacement, quality issue, special event).' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'The precise date and time when the supply consumption was recorded in the system.' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:guestChargedIndicator rdf:type rdf:Property ;
    rdfs:label 'Guest Charged Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the guest was charged for this supply consumption (e.g., minibar items, premium amenities).' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occupancyStatus rdf:type rdf:Property ;
    rdfs:label 'Occupancy Status' ;
    rdfs:comment 'The occupancy status of the room at the time of supply consumption (occupied, vacant, checkout, stayover).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'The quality grade classification of the supply item (premium, standard, economy, luxury).' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Quantity Consumed' ;
    rdfs:comment 'The numeric quantity of the supply item consumed during this transaction.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderTriggered rdf:type rdf:Property ;
    rdfs:label 'Reorder Triggered' ;
    rdfs:comment 'Boolean flag indicating whether this consumption event triggered an automatic reorder workflow in procurement.' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentAction rdf:type rdf:Property ;
    rdfs:label 'Replenishment Action' ;
    rdfs:comment 'The type of replenishment action taken by housekeeping staff (full restock, partial restock, no action, special request).' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Replenishment Quantity' ;
    rdfs:comment 'The quantity of the supply item replenished to the room after consumption.' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFromPar rdf:type rdf:Property ;
    rdfs:label 'Variance From Par' ;
    rdfs:comment 'The variance between actual consumption and the expected par level consumption.' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteIndicator rdf:type rdf:Property ;
    rdfs:label 'Waste Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the consumption represents waste or spoilage rather than normal usage.' ;
    rdfs:domain ind:SupplyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allotmentId rdf:type rdf:Property ;
    rdfs:label 'Allotment Id' ;
    rdfs:comment 'Unique identifier for the channel or partner allotment record. Primary key.' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'The date and time when this allotment was activated and made available for bookings. Nullable if not yet activated.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentTriggerEnabled rdf:type rdf:Property ;
    rdfs:label 'Adjustment Trigger Enabled' ;
    rdfs:comment 'Indicates whether performance-based automatic adjustment of the allotment quantity is enabled (True) or disabled (False). When enabled, the allotment quantity may be increased or decreased based on sell-through performance.' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The total number of rooms pre-allocated to the channel or partner for the specified room type and date range.' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allotmentCode rdf:type rdf:Property ;
    rdfs:label 'Allotment Code' ;
    rdfs:comment 'Unique business identifier or code for the allotment, used for tracking and reporting purposes in the Central Reservation System (CRS) and Property Management System (PMS).' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allotmentName rdf:type rdf:Property ;
    rdfs:label 'Allotment Name' ;
    rdfs:comment 'Descriptive name for the allotment (e.g., \'Expedia Summer Block\', \'Corporate XYZ Annual Contract\').' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoReleaseEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Release Enabled' ;
    rdfs:comment 'Indicates whether unsold allotment inventory is automatically released back to general inventory when the release period is reached (True) or requires manual release (False).' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'The number of rooms remaining available in this allotment (calculated as allocated_quantity minus sold_quantity).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingWindowEndDays rdf:type rdf:Property ;
    rdfs:label 'Booking Window End Days' ;
    rdfs:comment 'The maximum number of days before arrival that bookings can be made from this allotment. For example, 365 means bookings can be made up to 365 days in advance. Nullable if no maximum booking window applies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingWindowStartDays rdf:type rdf:Property ;
    rdfs:label 'Booking Window Start Days' ;
    rdfs:comment 'The minimum number of days before arrival that bookings can be made from this allotment. For example, 1 means bookings can be made starting 1 day before arrival. Nullable if no minimum booking window applies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'The commission percentage paid to the channel or partner for bookings made through this allotment. For example, 15.00 represents a 15% commission.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expired Timestamp' ;
    rdfs:comment 'The date and time when this allotment expired and was no longer available for bookings. Nullable if not yet expired.' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freesaleEnabled rdf:type rdf:Property ;
    rdfs:label 'Freesale Enabled' ;
    rdfs:comment 'Indicates whether the channel or partner can sell beyond the allocated quantity by accessing general inventory (True) or is restricted to the allocated quantity only (False). Freesale allows partners to sell from the hotel\'s available inventory without a fixed allotment limit.' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freesaleThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Freesale Threshold Quantity' ;
    rdfs:comment 'The minimum number of rooms that must remain available in general inventory before freesale access is restricted or disabled for this allotment. Nullable if freesale is not enabled.' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingLimit rdf:type rdf:Property ;
    rdfs:label 'Overbooking Limit' ;
    rdfs:comment 'The maximum number of rooms that can be overbooked for this allotment beyond the allocated quantity, used for yield optimization and revenue management. Nullable if overbooking is not permitted.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Performance Threshold Percent' ;
    rdfs:comment 'The minimum sell-through percentage required to maintain or increase the allotment quantity. For example, 80.00 means the partner must sell at least 80% of the allocated rooms to avoid reduction. Nullable if no performance threshold applies.' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soldQuantity rdf:type rdf:Property ;
    rdfs:label 'Sold Quantity' ;
    rdfs:comment 'The number of rooms from this allotment that have been sold or reserved by the channel or partner.' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Suspended Timestamp' ;
    rdfs:comment 'The date and time when this allotment was suspended or temporarily halted. Nullable if never suspended.' ;
    rdfs:domain ind:Allotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:availabilitySnapshotId rdf:type rdf:Property ;
    rdfs:label 'Availability Snapshot Id' ;
    rdfs:comment 'Unique identifier for the availability snapshot record. Primary key for this entity.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demandForecastId rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Id' ;
    rdfs:comment 'Foreign key linking to revenue.demand_forecast. Business justification: Availability snapshots capture actual rooms sold/available; demand forecasts predict future demand. Linking actuals to forecasts enables forecast accuracy measurement (MAPE calculation), model perform' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandForecast .

ind:experimentId rdf:type rdf:Property ;
    rdfs:label 'Experiment Id' ;
    rdfs:comment 'Foreign key linking to marketing.experiment. Business justification: A/B testing in hospitality involves inventory availability experiments (scarcity messaging tests, overbooking threshold optimization, dynamic availability display). Experiments must track which availa' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Experiment .

ind:closedToArrivalFlag rdf:type rdf:Property ;
    rdfs:label 'Closed To Arrival Flag' ;
    rdfs:comment 'Indicates whether new reservations are allowed to check in on this date. When true, no new arrivals are accepted, but existing multi-night stays can continue.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedToDepartureFlag rdf:type rdf:Property ;
    rdfs:label 'Closed To Departure Flag' ;
    rdfs:comment 'Indicates whether guests are allowed to check out on this date. When true, reservations must extend beyond this date to capture higher-value multi-night stays.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text notes documenting any discrepancies found during reconciliation, including root cause and resolution actions.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxLosRestriction rdf:type rdf:Property ;
    rdfs:label 'Max Los Restriction' ;
    rdfs:comment 'Maximum number of nights allowed for a reservation starting on this date. Used to prevent long stays during high-demand periods.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minLosRestriction rdf:type rdf:Property ;
    rdfs:label 'Min Los Restriction' ;
    rdfs:comment 'Minimum number of nights required for a reservation starting on this date. Used for demand management and revenue optimization.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netAvailableRooms rdf:type rdf:Property ;
    rdfs:label 'Net Available Rooms' ;
    rdfs:comment 'Net number of rooms available to sell after accounting for all deductions (OOO, OOS, house use, blocks). Calculated as total physical rooms minus all unavailable and blocked rooms.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occRate rdf:type rdf:Property ;
    rdfs:label 'Occ Rate' ;
    rdfs:comment 'Occupancy rate percentage for this room type on this date, calculated as (rooms sold + complimentary rooms) / net available rooms * 100. Key performance metric for revenue management.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomsBlockedAllotment rdf:type rdf:Property ;
    rdfs:label 'Rooms Blocked Allotment' ;
    rdfs:comment 'Number of rooms allocated to contracted allotments (OTA, wholesaler, corporate contracts) that are held but not yet sold.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsBlockedGroup rdf:type rdf:Property ;
    rdfs:label 'Rooms Blocked Group' ;
    rdfs:comment 'Number of rooms blocked for group reservations (MICE, corporate blocks) that are not yet sold but are held off general inventory.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsComplimentary rdf:type rdf:Property ;
    rdfs:label 'Rooms Complimentary' ;
    rdfs:comment 'Number of rooms occupied by complimentary guests (e.g., loyalty rewards, service recovery, VIP comps). Counted in occupancy but not in revenue.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsDayUse rdf:type rdf:Property ;
    rdfs:label 'Rooms Day Use' ;
    rdfs:comment 'Number of rooms sold for day-use only (check-in and check-out on the same day), typically for meetings or short stays.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsHouseUse rdf:type rdf:Property ;
    rdfs:label 'Rooms House Use' ;
    rdfs:comment 'Number of rooms occupied by hotel staff, contractors, or used for operational purposes (e.g., training, storage). Not available for sale.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsOutOfOrder rdf:type rdf:Property ;
    rdfs:label 'Rooms Out Of Order' ;
    rdfs:comment 'Number of rooms temporarily unavailable due to maintenance, repair, or refurbishment. These rooms are not available for sale.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsOutOfService rdf:type rdf:Property ;
    rdfs:label 'Rooms Out Of Service' ;
    rdfs:comment 'Number of rooms permanently or long-term unavailable due to major renovation, structural issues, or strategic decisions. Not available for sale.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsOverbooked rdf:type rdf:Property ;
    rdfs:label 'Rooms Overbooked' ;
    rdfs:comment 'Actual number of rooms overbooked (sold beyond physical capacity) for this room type on this date.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsSold rdf:type rdf:Property ;
    rdfs:label 'Rooms Sold' ;
    rdfs:comment 'Number of rooms sold (occupied by paying guests) for this room type on this date. Used in OCC (Occupancy Rate) calculation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The business date for which this availability snapshot is recorded. Represents the stay date, not the snapshot creation date.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The exact date and time when this availability snapshot was captured. Typically recorded during the nightly audit process.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stopSellFlag rdf:type rdf:Property ;
    rdfs:label 'Stop Sell Flag' ;
    rdfs:comment 'Indicates whether this room type is completely closed for sale on this date across all channels. When true, no new reservations are accepted.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPhysicalRooms rdf:type rdf:Property ;
    rdfs:label 'Total Physical Rooms' ;
    rdfs:comment 'Total number of physical rooms of this room type at the property, representing the maximum inventory capacity.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockPickupId rdf:type rdf:Property ;
    rdfs:label 'Block Pickup Id' ;
    rdfs:comment 'Unique identifier for the daily block pickup tracking record.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Group Evaluation Id' ;
    rdfs:comment 'Foreign key linking to revenue.group_evaluation. Business justification: Block pickup tracking measures actual performance against group evaluation forecasts. Linking enables wash factor accuracy measurement, displacement cost validation, and RMS model tuning—essential for' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupEvaluation .

ind:roomBlockId rdf:type rdf:Property ;
    rdfs:label 'Room Block Id' ;
    rdfs:comment 'Reference to the parent group room block contract for which pickup is being tracked.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoomBlock .

ind:contractedRooms rdf:type rdf:Property ;
    rdfs:label 'Contracted Rooms' ;
    rdfs:comment 'The total number of rooms committed in the original group block contract for this room type and stay date.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativePickup rdf:type rdf:Property ;
    rdfs:label 'Cumulative Pickup' ;
    rdfs:comment 'The total cumulative number of rooms picked up from the block from contract inception through the current pickup date.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToArrival rdf:type rdf:Property ;
    rdfs:label 'Days To Arrival' ;
    rdfs:comment 'The number of days remaining from the pickup date until the stay date, used to assess booking window and release timing.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displacementCost rdf:type rdf:Property ;
    rdfs:label 'Displacement Cost' ;
    rdfs:comment 'The estimated revenue opportunity cost of accepting this group block instead of selling rooms to higher-rated transient guests.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedPickup rdf:type rdf:Property ;
    rdfs:label 'Forecasted Pickup' ;
    rdfs:comment 'The revenue management systems forecasted number of rooms expected to be picked up from this block by arrival date.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLraEligible rdf:type rdf:Property ;
    rdfs:label 'Is Lra Eligible' ;
    rdfs:comment 'Indicates whether this block is eligible for Last Room Availability, meaning the group can book rooms even when the hotel is sold out.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPickup rdf:type rdf:Property ;
    rdfs:label 'Net Pickup' ;
    rdfs:comment 'The adjusted pickup count after applying wash factor, representing the expected actual occupied rooms from the block.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupDate rdf:type rdf:Property ;
    rdfs:label 'Pickup Date' ;
    rdfs:comment 'The date on which this pickup measurement was captured or calculated, representing the snapshot date for reporting.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pickupNotes rdf:type rdf:Property ;
    rdfs:label 'Pickup Notes' ;
    rdfs:comment 'Free-text notes or comments regarding pickup performance, release decisions, or special circumstances for this block and stay date.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupPaceVariance rdf:type rdf:Property ;
    rdfs:label 'Pickup Pace Variance' ;
    rdfs:comment 'The difference between current year pickup and prior year pickup at the same point in time, indicating booking pace trend.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupPercentage rdf:type rdf:Property ;
    rdfs:label 'Pickup Percentage' ;
    rdfs:comment 'The percentage of contracted rooms that have been picked up, calculated as (rooms_picked_up / contracted_rooms) * 100.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupRate rdf:type rdf:Property ;
    rdfs:label 'Pickup Rate' ;
    rdfs:comment 'The negotiated room rate (ADR) for rooms picked up from this block, used for revenue calculation and forecasting.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupRevenue rdf:type rdf:Property ;
    rdfs:label 'Pickup Revenue' ;
    rdfs:comment 'The total room revenue generated from picked-up rooms, calculated as rooms_picked_up multiplied by pickup_rate.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupVariance rdf:type rdf:Property ;
    rdfs:label 'Pickup Variance' ;
    rdfs:comment 'The difference between actual rooms picked up and contracted rooms (rooms_picked_up minus contracted_rooms), indicating over or under performance.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorYearPickup rdf:type rdf:Property ;
    rdfs:label 'Prior Year Pickup' ;
    rdfs:comment 'The number of rooms picked up for the same group or comparable group at the same point in time last year, used for pace analysis.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releasedRooms rdf:type rdf:Property ;
    rdfs:label 'Released Rooms' ;
    rdfs:comment 'The number of rooms from the block that have been released back to general inventory due to non-pickup or cutoff date passage.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingBlockRooms rdf:type rdf:Property ;
    rdfs:label 'Remaining Block Rooms' ;
    rdfs:comment 'The number of rooms still available in the block that have not yet been picked up (contracted minus picked up).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:washFactor rdf:type rdf:Property ;
    rdfs:label 'Wash Factor' ;
    rdfs:comment 'The percentage of block rooms expected to cancel or no-show, used to adjust net pickup forecasts and overbooking strategies.' ;
    rdfs:domain ind:BlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeAuditId rdf:type rdf:Property ;
    rdfs:label 'Change Audit Id' ;
    rdfs:comment 'Primary key for change_audit' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedAuditLogChangeAuditId rdf:type rdf:Property ;
    rdfs:label 'Reversed Audit Log Change Audit Id' ;
    rdfs:comment 'Reference to the original audit log entry that this entry reverses, if this is a reversal transaction.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeAudit .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Level of authority that approved the change: system (automated), property manager, revenue manager, regional director, or corporate level.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this type of change required explicit management approval per SOX internal control policies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizingUserName rdf:type rdf:Property ;
    rdfs:label 'Authorizing User Name' ;
    rdfs:comment 'Full name of the user who authorized or executed the change, for audit trail readability.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeImpactType rdf:type rdf:Property ;
    rdfs:label 'Change Impact Type' ;
    rdfs:comment 'Category of impact this change has on inventory: availability (room count changes), control (CTA/CTD/LOS/stop-sell), status (OOO/OOS), allocation (block/allotment), or pricing (rate-related).' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the change (e.g., REVENUE_OPTIMIZATION, MAINTENANCE, GROUP_BLOCK, SYSTEM_CORRECTION, NIGHT_AUDIT_ADJUSTMENT, EMERGENCY_OOO).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the change, supporting dispute resolution and audit review.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Timestamp' ;
    rdfs:comment 'Exact date and time when the inventory change was committed to the system. Primary business event timestamp for this audit log entry.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Changed Entity Reference' ;
    rdfs:comment 'Unique identifier of the specific entity that was changed (e.g., room number, block ID, allotment ID, control rule ID).' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedEntityType rdf:type rdf:Property ;
    rdfs:label 'Changed Entity Type' ;
    rdfs:comment 'Type of inventory entity that was modified: room inventory, room block, allotment, control (CTA/CTD/LOS/stop-sell/overbooking limit), availability override, out-of-order/out-of-service designation, or channel inventory mapping.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctaCtdChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Cta Ctd Change Flag' ;
    rdfs:comment 'Indicates whether this change modified CTA (Close to Arrival) or CTD (Close to Departure) restrictions, which control bookings based on arrival or departure dates.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldName rdf:type rdf:Property ;
    rdfs:label 'Field Name' ;
    rdfs:comment 'Name of the specific field or attribute that was modified (e.g., availability_count, overbooking_limit, room_status, CTA_days, stop_sell_flag).' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:losRestrictionChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Los Restriction Change Flag' ;
    rdfs:comment 'Indicates whether this change modified LOS (Length of Stay) restrictions, including minimum or maximum stay requirements.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lraChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Lra Change Flag' ;
    rdfs:comment 'Indicates whether this change affected Last Room Availability (LRA) settings, which control whether the last available room can be sold at all rate levels.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'The value of the field after the change was applied. Stored as string to accommodate various data types.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nightAuditAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Night Audit Adjustment Flag' ;
    rdfs:comment 'Indicates whether this change was made as part of the night audit process to reconcile inventory discrepancies.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overbookingLimitChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Overbooking Limit Change Flag' ;
    rdfs:comment 'Indicates whether this change modified overbooking limits, a critical control for revenue management and guest satisfaction.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousValue rdf:type rdf:Property ;
    rdfs:label 'Previous Value' ;
    rdfs:comment 'The value of the field before the change was applied. Stored as string to accommodate various data types.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Code' ;
    rdfs:comment 'Unique transaction or batch identifier from the source system that generated this change, enabling cross-system traceability.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSellChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Stop Sell Change Flag' ;
    rdfs:comment 'Indicates whether this change involved stop-sell controls, which prevent bookings for specific room types, rate plans, or channels.' ;
    rdfs:domain ind:ChangeAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelInventoryMapId rdf:type rdf:Property ;
    rdfs:label 'Channel Inventory Map Id' ;
    rdfs:comment 'Unique identifier for the channel inventory mapping record. Primary key.' ;
    rdfs:domain ind:ChannelInventoryMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryChannelEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Employee Id' ;
    rdfs:comment 'User identifier of the person or system account that created this channel inventory mapping record.' ;
    rdfs:domain ind:ChannelInventoryMap ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advanceBookingDaysMax rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Days Max' ;
    rdfs:comment 'Maximum number of days in advance that a reservation can be made through this channel for this room type. Null indicates no maximum booking window restriction.' ;
    rdfs:domain ind:ChannelInventoryMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advanceBookingDaysMin rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Days Min' ;
    rdfs:comment 'Minimum number of days in advance that a reservation must be made through this channel for this room type. Used for channel-specific booking window controls.' ;
    rdfs:domain ind:ChannelInventoryMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Channel Priority Rank' ;
    rdfs:comment 'Numeric ranking indicating the priority of this channel for inventory allocation (lower number = higher priority). Used when multiple channels compete for limited inventory.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelSellLimit rdf:type rdf:Property ;
    rdfs:label 'Channel Sell Limit' ;
    rdfs:comment 'Maximum number of rooms of this type that can be sold through this specific channel on any given date. Used for channel-level inventory allocation and overbooking controls.' ;
    rdfs:domain ind:ChannelInventoryMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Visibility Flag' ;
    rdfs:comment 'Boolean indicator of whether this room type is visible and bookable through this channel. False indicates the mapping exists but the room type is hidden from the channel.' ;
    rdfs:domain ind:ChannelInventoryMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether bookings made through this channel for this room type are eligible for commission payments to the channel partner.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stopSellOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Stop Sell Override Flag' ;
    rdfs:comment 'Boolean indicator of whether a manual stop-sell override is in effect for this channel-room type combination, preventing new bookings regardless of availability.' ;
    rdfs:domain ind:ChannelInventoryMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlId rdf:type rdf:Property ;
    rdfs:label 'Control Id' ;
    rdfs:comment 'Primary key for control' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryControlId rdf:type rdf:Property ;
    rdfs:label 'Inventory Control Id' ;
    rdfs:comment 'Unique identifier for the inventory control record. Primary key for the control entity.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryControl .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: Inventory controls (sell limits, hurdles, stop-sell flags) are tier-differentiated in luxury hospitality. Properties set different availability rules for base vs platinum members. Revenue strategy req' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:advanceBookingLimitDays rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Limit Days' ;
    rdfs:comment 'Maximum number of days in advance that bookings can be made for this stay date. Null indicates no advance booking restriction.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitiveSetAdr rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Adr' ;
    rdfs:comment 'Average Daily Rate of the competitive set (STR comp set) for comparable room types on this stay date. Used for competitive benchmarking.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlSource rdf:type rdf:Property ;
    rdfs:label 'Control Source' ;
    rdfs:comment 'Origin of this control record. RMS indicates generated by IDeaS G3 RMS; manual indicates user override; API indicates external system integration.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of this inventory control record. Active controls are enforced by PMS and CRS; inactive controls are ignored.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctaFlag rdf:type rdf:Property ;
    rdfs:label 'Cta Flag' ;
    rdfs:comment 'Indicates whether new arrivals are prohibited on this date. True means guests cannot check in on this date, but existing reservations spanning this date are allowed.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctdFlag rdf:type rdf:Property ;
    rdfs:label 'Ctd Flag' ;
    rdfs:comment 'Indicates whether departures are prohibited on this date. True means guests cannot check out on this date; used to enforce minimum stay through high-demand periods.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Date and time when this control expires and is no longer enforced. Null indicates control remains effective until explicitly superseded.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastAdr rdf:type rdf:Property ;
    rdfs:label 'Forecast Adr' ;
    rdfs:comment 'RMS-forecasted Average Daily Rate for this room type on this stay date. Expressed in property currency.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastDemand rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand' ;
    rdfs:comment 'RMS-forecasted demand (number of rooms) for this room type on this stay date. Used to inform control decisions and diagnostic analysis.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastOccPct rdf:type rdf:Property ;
    rdfs:label 'Forecast Occ Pct' ;
    rdfs:comment 'RMS-forecasted occupancy percentage for this room type on this stay date. Expressed as a percentage (e.g., 85.50 means 85.5% occupancy).' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hurdleRate rdf:type rdf:Property ;
    rdfs:label 'Hurdle Rate' ;
    rdfs:comment 'Minimum acceptable rate (ADR) below which the room type should not be sold for this date. Used by revenue management to protect yield. Expressed in property currency.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overbookingLimitAbsolute rdf:type rdf:Property ;
    rdfs:label 'Overbooking Limit Absolute' ;
    rdfs:comment 'Absolute number of rooms above physical inventory that can be sold. Alternative to percentage-based overbooking. Null if percentage method is used.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text explanation provided by the user when manually overriding RMS-generated controls. Required when override_user_id is populated.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rgiTarget rdf:type rdf:Property ;
    rdfs:label 'Rgi Target' ;
    rdfs:comment 'Target Revenue Generation Index for this stay date. RGI measures property performance relative to competitive set. Value of 100 means at-market performance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:walkRiskTolerance rdf:type rdf:Property ;
    rdfs:label 'Walk Risk Tolerance' ;
    rdfs:comment 'Revenue management tolerance for walking guests (relocating to another property due to overbooking). Higher tolerance allows more aggressive overbooking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryOverbookingPolicyId rdf:type rdf:Property ;
    rdfs:label 'Inventory Overbooking Policy Id' ;
    rdfs:comment 'Unique identifier for the overbooking policy configuration record.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInventoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Employee Id' ;
    rdfs:comment 'Reference to the user who approved this overbooking policy for activation.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryInventoryLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Inventory Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who most recently modified this overbooking policy record.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cancellationForecastRate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Forecast Rate' ;
    rdfs:comment 'The expected cancellation rate (as a percentage) for this room type during the policy period, used to justify overbooking limits.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Defines which distribution channels (direct, OTA, GDS) are subject to this overbooking policy, enabling channel-specific inventory control.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:losRestrictionMax rdf:type rdf:Property ;
    rdfs:label 'Los Restriction Max' ;
    rdfs:comment 'Maximum length of stay (in nights) allowed for reservations subject to this overbooking policy. Null indicates no maximum restriction.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:losRestrictionMin rdf:type rdf:Property ;
    rdfs:label 'Los Restriction Min' ;
    rdfs:comment 'Minimum length of stay (in nights) required for reservations subject to this overbooking policy. Null indicates no minimum restriction.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumOverbookingRooms rdf:type rdf:Property ;
    rdfs:label 'Maximum Overbooking Rooms' ;
    rdfs:comment 'The absolute maximum number of rooms that can be overbooked above physical capacity, calculated or manually set based on the overbooking limit configuration.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noShowForecastRate rdf:type rdf:Property ;
    rdfs:label 'No Show Forecast Rate' ;
    rdfs:comment 'The expected no-show rate (as a percentage) for this room type during the policy period, factored into overbooking calculations.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overbookingLimitType rdf:type rdf:Property ;
    rdfs:label 'Overbooking Limit Type' ;
    rdfs:comment 'Defines whether the overbooking limit is expressed as a percentage of physical capacity, an absolute room count, or dynamically calculated by the RMS.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overbookingLimitValue rdf:type rdf:Property ;
    rdfs:label 'Overbooking Limit Value' ;
    rdfs:comment 'The numeric value representing the maximum overbooking threshold. Interpretation depends on overbooking_limit_type (e.g., 10.00 for 10% or 5.00 for 5 rooms).' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalRoomCapacity rdf:type rdf:Property ;
    rdfs:label 'Physical Room Capacity' ;
    rdfs:comment 'The actual number of physical rooms of this room type available at the property, used as the baseline for calculating overbooking limits.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Business identifier code for the overbooking policy, used for reference in revenue management and distribution systems.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name describing the overbooking policy (e.g., \'High Season King Suite Overbooking\', \'Standard Double Overbooking\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeBufferRooms rdf:type rdf:Property ;
    rdfs:label 'Upgrade Buffer Rooms' ;
    rdfs:comment 'Number of higher-category rooms reserved as a buffer to accommodate overbooked guests through complimentary upgrades, reducing walk risk.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:walkCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Walk Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the walk cost estimate (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walkCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Walk Cost Estimate' ;
    rdfs:comment 'Estimated average cost per walked guest (including relocation, compensation, and goodwill), used in revenue optimization calculations.' ;
    rdfs:domain ind:InventoryOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:losRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Los Restriction Id' ;
    rdfs:comment 'Unique identifier for the length-of-stay restriction record. Primary key.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLosEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Los Employee Id' ;
    rdfs:comment 'User identifier of the person or system account that created this LOS restriction record.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adrThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Adr Threshold Amount' ;
    rdfs:comment 'ADR threshold amount that triggers or releases this LOS restriction. Used for rate-based restriction logic.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dayOfWeekPattern rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Pattern' ;
    rdfs:comment '7-character binary string indicating which days of the week this restriction applies to (1=applies, 0=does not apply). Format: SMTWTFS (Sunday through Saturday).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Distribution Timestamp' ;
    rdfs:comment 'Timestamp when this LOS restriction was last distributed to external channels via Sabre SynXis CRS or GDS connections.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastDemandLevel rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand Level' ;
    rdfs:comment 'Forecasted demand level that triggered this LOS restriction: low, medium, high, or very high. Used for revenue optimization analytics.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullPatternLos rdf:type rdf:Property ;
    rdfs:label 'Full Pattern Los' ;
    rdfs:comment 'Comma-separated list of exact LOS values allowed (e.g., \'3,7,14\' means only 3-night, 7-night, or 14-night stays are permitted). Null if restriction type is not full_pattern.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupBlockExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Group Block Exempt Flag' ;
    rdfs:comment 'Indicates whether group block reservations are exempt from this LOS restriction. True if group blocks bypass this restriction, false otherwise.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyTierExemptList rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Exempt List' ;
    rdfs:comment 'Comma-separated list of loyalty program tier codes that are exempt from this LOS restriction (e.g., \'PLATINUM,DIAMOND\'). Null if no loyalty exemptions apply.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Occ Threshold Percent' ;
    rdfs:comment 'Occupancy percentage threshold that triggers or releases this LOS restriction. Expressed as a percentage (e.g., 85.00 for 85%).' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Override Authority Level' ;
    rdfs:comment 'Minimum authority level required to override this LOS restriction during the reservation process: none (no override allowed), supervisor, manager, director, or general manager (GM).' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Override Reason Required Flag' ;
    rdfs:comment 'Indicates whether a documented reason is required when this LOS restriction is overridden. True if reason is mandatory, false otherwise.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionCode rdf:type rdf:Property ;
    rdfs:label 'Restriction Code' ;
    rdfs:comment 'Business code identifying this LOS restriction rule for operational reference and reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Restriction Notes' ;
    rdfs:comment 'Free-text notes providing additional context, rationale, or special instructions for this LOS restriction. Used for operational communication and audit purposes.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Strategy Code' ;
    rdfs:comment 'Code identifying the revenue management strategy or campaign that generated this LOS restriction (e.g., PEAK_DEMAND, SHOULDER_SEASON, EVENT_DRIVEN).' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revparThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Revpar Threshold Amount' ;
    rdfs:comment 'RevPAR threshold amount that triggers or releases this LOS restriction. Used for dynamic restriction management based on revenue performance.' ;
    rdfs:domain ind:LosRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfOrderId rdf:type rdf:Property ;
    rdfs:label 'Out Of Order Id' ;
    rdfs:comment 'Primary key for out_of_order' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOutEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Out Employee Id' ;
    rdfs:comment 'Identifier of the staff member who reported or logged the out-of-order condition (typically housekeeping, front desk, or maintenance staff).' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOutClosedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Out Closed By User Employee Id' ;
    rdfs:comment 'Identifier of the staff member who closed the out-of-order record and returned the room to service (typically housekeeping or maintenance supervisor).' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'Actual date when the room was returned to sellable inventory and made available for guest occupancy. Null if still out-of-order.' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Compliance Flag' ;
    rdfs:comment 'Indicates whether the out-of-order condition affects an ADA-compliant accessible room, requiring special handling for guest accommodation and compliance tracking.' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedByName rdf:type rdf:Property ;
    rdfs:label 'Closed By Name' ;
    rdfs:comment 'Name of the staff member who closed the out-of-order record and verified the room is ready for guest occupancy.' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total number of days the room was out-of-order or out-of-service, calculated from start date to actual return date. Used for RevPAR and occupancy impact analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Planned or estimated date when the room is expected to be returned to sellable inventory after repairs or maintenance are completed.' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guestImpactedFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Impacted Flag' ;
    rdfs:comment 'Indicates whether a guest reservation was impacted by this out-of-order designation (True if guest had to be relocated or reservation cancelled).' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactOnOcc rdf:type rdf:Property ;
    rdfs:label 'Impact On Occ' ;
    rdfs:comment 'Percentage point impact on property occupancy rate due to this room being out-of-order. Used for STR reporting and competitive benchmarking.' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactOnRevpar rdf:type rdf:Property ;
    rdfs:label 'Impact On Revpar' ;
    rdfs:comment 'Calculated impact on property RevPAR due to this room being out-of-order. Critical metric for revenue management and performance analysis.' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lostRevenueEstimate rdf:type rdf:Property ;
    rdfs:label 'Lost Revenue Estimate' ;
    rdfs:comment 'Estimated revenue loss due to the room being unavailable for sale during the out-of-order period. Calculated using ADR and occupancy forecasts for RevPAR impact analysis.' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oooCode rdf:type rdf:Property ;
    rdfs:label 'Ooo Code' ;
    rdfs:comment 'Standardized code representing the reason category for the room being out-of-order or out-of-service (e.g., MAINT, REPAIR, RENO, DAMAGE, INSPECT).' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oooReason rdf:type rdf:Property ;
    rdfs:label 'Ooo Reason' ;
    rdfs:comment 'Detailed textual description of the specific reason the room is out-of-order or out-of-service (e.g., plumbing leak, HVAC failure, carpet replacement, pest control treatment).' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oooStatus rdf:type rdf:Property ;
    rdfs:label 'Ooo Status' ;
    rdfs:comment 'Designation type: OOO (Out-of-Order - not counted in available inventory) or OOS (Out-of-Service - counted in inventory but not sold). Follows USALI standards for inventory accounting.' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the out-of-order record (Open - newly reported, In Progress - work underway, Completed - room returned to service, Cancelled - designation reversed).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relocationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Relocation Required Flag' ;
    rdfs:comment 'Indicates whether guest relocation to another room or property was required due to this out-of-order condition. Used for service recovery tracking.' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyConcernFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Concern Flag' ;
    rdfs:comment 'Indicates whether the out-of-order condition involves a safety or health hazard requiring immediate attention per OSHA or local safety regulations.' ;
    rdfs:domain ind:OutOfOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Reference number of the maintenance or repair work order associated with this out-of-order designation. Links to work order management system.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectingRoomId rdf:type rdf:Property ;
    rdfs:label 'Connecting Room Id' ;
    rdfs:comment 'Identifier of the adjacent room that connects to this room via connecting door. Null if no connecting room.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Room .

ind:adaAccessible rdf:type rdf:Property ;
    rdfs:label 'Ada Accessible' ;
    rdfs:comment 'Indicates whether the room meets ADA accessibility standards including wheelchair access, grab bars, visual alarms, and accessible bathroom fixtures.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balconyAvailable rdf:type rdf:Property ;
    rdfs:label 'Balcony Available' ;
    rdfs:comment 'Indicates whether the room has a private balcony or terrace. Premium feature used for rate differentiation.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bedCount rdf:type rdf:Property ;
    rdfs:label 'Bed Count' ;
    rdfs:comment 'Total number of beds in the room. Used for occupancy capacity and guest preferences.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bedType rdf:type rdf:Property ;
    rdfs:label 'Bed Type' ;
    rdfs:comment 'Primary bed configuration in the room. Critical for guest preferences and room assignment. [ENUM-REF-CANDIDATE: king|queen|double|twin|california_king|murphy|sofa_bed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Code identifying the building or tower within a multi-building property. Null for single-building properties.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectingRoomAvailable rdf:type rdf:Property ;
    rdfs:label 'Connecting Room Available' ;
    rdfs:comment 'Indicates whether this room has a connecting door to an adjacent room. Used for family bookings and group assignments.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:features rdf:type rdf:Property ;
    rdfs:label 'Features' ;
    rdfs:comment 'Comma-separated list of additional room features and amenities (e.g., minibar, safe, coffee maker, smart TV, work desk). Used for guest preference matching and marketing.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffeConditionScore rdf:type rdf:Property ;
    rdfs:label 'Ffe Condition Score' ;
    rdfs:comment 'Condition assessment score for room furniture, fixtures, and equipment on a scale of 0.00 to 5.00. Used for CapEx planning and PIP prioritization.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frontOfficeStatus rdf:type rdf:Property ;
    rdfs:label 'Front Office Status' ;
    rdfs:comment 'Current front office occupancy state. Indicates whether the room is vacant, occupied by a guest, reserved for arrival, or blocked.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:housekeepingStatus rdf:type rdf:Property ;
    rdfs:label 'Housekeeping Status' ;
    rdfs:comment 'Current housekeeping state of the room. Updated by housekeeping staff and used for room assignment and availability.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitchenetteAvailable rdf:type rdf:Property ;
    rdfs:label 'Kitchenette Available' ;
    rdfs:comment 'Indicates whether the room includes a kitchenette with cooking facilities. Common in extended-stay properties.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxOccupancy rdf:type rdf:Property ;
    rdfs:label 'Max Occupancy' ;
    rdfs:comment 'Maximum number of guests allowed in the room per fire code and property policy. Used for reservation validation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfOrderEndDate rdf:type rdf:Property ;
    rdfs:label 'Out Of Order End Date' ;
    rdfs:comment 'Expected date when the room will return to service. Used for inventory forecasting and revenue management.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outOfOrderReason rdf:type rdf:Property ;
    rdfs:label 'Out Of Order Reason' ;
    rdfs:comment 'Reason code or description for why the room is out of order. Null when room is in service. Used for maintenance tracking and OCC impact analysis.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfOrderStartDate rdf:type rdf:Property ;
    rdfs:label 'Out Of Order Start Date' ;
    rdfs:comment 'Date when the room was taken out of order. Used for revenue impact analysis and maintenance duration tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overbookingEligible rdf:type rdf:Property ;
    rdfs:label 'Overbooking Eligible' ;
    rdfs:comment 'Indicates whether this room can be included in overbooking calculations. Used by RMS for yield optimization.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smokingAllowed rdf:type rdf:Property ;
    rdfs:label 'Smoking Allowed' ;
    rdfs:comment 'Indicates whether smoking is permitted in the room. Used for guest preference matching and inventory segmentation.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewType rdf:type rdf:Property ;
    rdfs:label 'View Type' ;
    rdfs:comment 'Type of view from the room windows. Impacts rate positioning and guest satisfaction. Used for upsell opportunities. [ENUM-REF-CANDIDATE: ocean|city|mountain|garden|pool|courtyard|no_view — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wingCode rdf:type rdf:Property ;
    rdfs:label 'Wing Code' ;
    rdfs:comment 'Code identifying the wing or section within a building. Used for operational routing and guest location preferences.' ;
    rdfs:domain ind:Room ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current physical condition of the amenity as assessed during last inspection. Drives maintenance and replacement decisions.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'Sort order for displaying amenities in guest-facing interfaces and reports. Lower numbers appear first.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guestVisibleFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Visible Flag' ;
    rdfs:comment 'Indicates whether this amenity is displayed in guest-facing channels such as booking engines, mobile apps, and property websites. Used for marketing and distribution.' ;
    rdfs:domain ind:RoomAmenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the amenity was installed or placed in the room. Used for tracking asset age and planning replacement cycles.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAdaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Ada Compliant' ;
    rdfs:comment 'Indicates whether the amenity meets ADA accessibility requirements. Critical for compliance and guest accommodation matching.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEcoFriendly rdf:type rdf:Property ;
    rdfs:label 'Is Eco Friendly' ;
    rdfs:comment 'Indicates whether the amenity meets environmental sustainability standards. Used for green certification programs and guest preference matching.' ;
    rdfs:domain ind:RoomAmenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPremiumAmenity rdf:type rdf:Property ;
    rdfs:label 'Is Premium Amenity' ;
    rdfs:comment 'Indicates whether this amenity is considered a premium or luxury feature that differentiates the room type and justifies higher ADR (Average Daily Rate).' ;
    rdfs:domain ind:RoomAmenity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency Days' ;
    rdfs:comment 'Number of days between scheduled maintenance or inspection cycles for this amenity. Used for preventive maintenance scheduling.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledReplacementDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Replacement Date' ;
    rdfs:comment 'Planned date for replacing or refreshing the amenity based on lifecycle policy. Supports proactive FF&E capital planning.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tertiaryRoomModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Room Modified By User Employee Id' ;
    rdfs:comment 'Reference to the system user who last modified the room block record.' ;
    rdfs:domain ind:RoomBlock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:availableRoomNights rdf:type rdf:Property ;
    rdfs:label 'Available Room Nights' ;
    rdfs:comment 'Remaining number of room nights still available for pickup within the block.' ;
    rdfs:domain ind:RoomBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockType rdf:type rdf:Property ;
    rdfs:label 'Block Type' ;
    rdfs:comment 'Classification of the room block by purpose: group (general group travel), event (MICE events), corporate (business contracts), tour (tour operators), wedding (social events), conference (meeting-focused).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingSource rdf:type rdf:Property ;
    rdfs:label 'Booking Source' ;
    rdfs:comment 'Channel or method through which the room block was originally booked: direct (property direct), GDS (Global Distribution System), OTA (Online Travel Agency), CRS (Central Reservation System), sales_team (hotel sales), third_party (intermediary).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate Amount' ;
    rdfs:comment 'Contracted room rate amount per night for the block, expressed in property base currency.' ;
    rdfs:domain ind:RoomBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overbookingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Overbooking Allowed Flag' ;
    rdfs:comment 'Indicates whether the block allows overbooking beyond contracted room nights.' ;
    rdfs:domain ind:RoomBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Primary email address of the block owner for communication and coordination.' ;
    rdfs:domain ind:RoomBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the primary contact or decision-maker responsible for the room block on the client side.' ;
    rdfs:domain ind:RoomBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerPhone rdf:type rdf:Property ;
    rdfs:label 'Owner Phone' ;
    rdfs:comment 'Primary contact phone number of the block owner.' ;
    rdfs:domain ind:RoomBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedUpRoomNights rdf:type rdf:Property ;
    rdfs:label 'Picked Up Room Nights' ;
    rdfs:comment 'Cumulative number of room nights actually reserved and consumed from the block by guests.' ;
    rdfs:domain ind:RoomBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomStatusId rdf:type rdf:Property ;
    rdfs:label 'Room Status Id' ;
    rdfs:comment 'Primary key for room_status' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Room Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the system user (staff member) who last updated the room status.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:blockedReason rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason' ;
    rdfs:comment 'Explanation of why the room is administratively blocked from sale (e.g., VIP hold, renovation, inventory control, group block).' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Boolean flag indicating a mismatch between front desk status and housekeeping status (e.g., front desk shows vacant but housekeeping shows occupied). Requires investigation.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedCheckinDate rdf:type rdf:Property ;
    rdfs:label 'Expected Checkin Date' ;
    rdfs:comment 'The scheduled check-in date for the next arriving guest. Used for due-in planning and housekeeping prioritization.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedCheckoutDate rdf:type rdf:Property ;
    rdfs:label 'Expected Checkout Date' ;
    rdfs:comment 'The scheduled checkout date for the current guest occupying the room. Used for due-out planning.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frontDeskStatus rdf:type rdf:Property ;
    rdfs:label 'Front Desk Status' ;
    rdfs:comment 'Current operational status from the front desk perspective. Vacant: unoccupied and available; Occupied: guest currently in residence; Reserved: booked for future arrival; Due Out: guest scheduled to check out today; Due In: guest scheduled to check in today; Out of Order: room unavailable for sale.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Blocked' ;
    rdfs:comment 'Boolean flag indicating whether the room is administratively blocked from sale (e.g., for renovation, VIP hold, or inventory control).' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClean rdf:type rdf:Property ;
    rdfs:label 'Is Clean' ;
    rdfs:comment 'Boolean flag indicating whether the room has been cleaned and is ready for occupancy. True if housekeeping status is clean or inspected.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInspected rdf:type rdf:Property ;
    rdfs:label 'Is Inspected' ;
    rdfs:comment 'Boolean flag indicating whether the room has passed housekeeping quality inspection after cleaning.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOutOfOrder rdf:type rdf:Property ;
    rdfs:label 'Is Out Of Order' ;
    rdfs:comment 'Boolean flag indicating whether the room is out of order and unavailable for sale due to maintenance or other operational issues.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCleanedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Cleaned Timestamp' ;
    rdfs:comment 'Date and time when the room was last cleaned by housekeeping staff.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastInspectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Inspected Timestamp' ;
    rdfs:comment 'Date and time when the room last passed housekeeping quality inspection.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastOccupiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Occupied Timestamp' ;
    rdfs:comment 'Date and time when the room was last occupied by a guest (most recent check-in or last known occupancy).' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastVacatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Vacated Timestamp' ;
    rdfs:comment 'Date and time when the room was last vacated by a guest (most recent check-out).' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maintenanceStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Status' ;
    rdfs:comment 'Current maintenance condition of the room. Available: no maintenance issues; Minor Repair: small issues not blocking occupancy; Major Repair: significant issues requiring attention; Out of Order: room cannot be occupied; Scheduled Maintenance: planned preventive maintenance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Updated Timestamp' ;
    rdfs:comment 'Date and time when the room status was last updated in the system. Tracks the most recent status transition.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:turndownServiceStatus rdf:type rdf:Property ;
    rdfs:label 'Turndown Service Status' ;
    rdfs:comment 'Status of evening turndown service for the room. Not Requested: no turndown service scheduled; Requested: guest or property standard requires turndown; Completed: turndown service has been performed; Declined: guest declined turndown service.' ;
    rdfs:domain ind:RoomStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessibilityFeatures rdf:type rdf:Property ;
    rdfs:label 'Accessibility Features' ;
    rdfs:comment 'Comma-separated list of accessibility features available in this room type. Examples: roll-in shower, grab bars, visual alarm, hearing kit, lowered fixtures. Used for guest matching and compliance tracking.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bathroomConfiguration rdf:type rdf:Property ;
    rdfs:label 'Bathroom Configuration' ;
    rdfs:comment 'Description of bathroom setup. Examples: single full bath, 1.5 bath, dual vanity, separate tub and shower. Used for guest expectations and competitive positioning.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLevelRange rdf:type rdf:Property ;
    rdfs:label 'Floor Level Range' ;
    rdfs:comment 'Typical floor range where this room type is located. Examples: 1-5, 6-10, 15-20. Used for guest preference and accessibility planning.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConnectingEligible rdf:type rdf:Property ;
    rdfs:label 'Is Connecting Eligible' ;
    rdfs:comment 'Indicates whether this room type can be configured as a connecting room. Used for family and group booking allocation.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSuite rdf:type rdf:Property ;
    rdfs:label 'Is Suite' ;
    rdfs:comment 'Indicates whether this room type is classified as a suite with separate living and sleeping areas. Used for inventory segmentation and revenue reporting.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overbookingAllowed rdf:type rdf:Property ;
    rdfs:label 'Overbooking Allowed' ;
    rdfs:comment 'Indicates whether this room type can be overbooked as part of revenue management strategy. Used by RMS for yield optimization.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pseudoRoomFlag rdf:type rdf:Property ;
    rdfs:label 'Pseudo Room Flag' ;
    rdfs:comment 'Indicates whether this is a pseudo room type used for inventory management purposes (e.g., house use, out of order, complimentary) rather than a sellable room type. Used for inventory controls and reporting exclusions.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roomClass rdf:type rdf:Property ;
    rdfs:label 'Room Class' ;
    rdfs:comment 'High-level classification of the room type by service tier. Used for segmentation in revenue management and guest experience programs.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomFeatures rdf:type rdf:Property ;
    rdfs:label 'Room Features' ;
    rdfs:comment 'Comma-separated list of key room features and amenities. Examples: balcony, kitchenette, fireplace, whirlpool, separate shower, walk-in closet. Used for guest communication and OTA distribution.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Room Type Description' ;
    rdfs:comment 'Detailed marketing description of the room type including amenities, features, and guest experience highlights. Used for guest-facing channels and OTA distribution.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomTypeName rdf:type rdf:Property ;
    rdfs:label 'Room Type Name' ;
    rdfs:comment 'Full descriptive name of the room type as displayed to guests and staff. Examples: Deluxe King, Queen Queen Double, Junior Suite, Presidential Suite.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellableFlag rdf:type rdf:Property ;
    rdfs:label 'Sellable Flag' ;
    rdfs:comment 'Indicates whether this room type is available for sale to guests. Non-sellable types include staff rooms, maintenance rooms, and owner units.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardOccupancy rdf:type rdf:Property ;
    rdfs:label 'Standard Occupancy' ;
    rdfs:comment 'Standard number of guests for this room type used for base rate calculations. Additional guests may incur extra person charges.' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewCategory rdf:type rdf:Property ;
    rdfs:label 'View Category' ;
    rdfs:comment 'Classification of the view from the room. Impacts pricing strategy and guest satisfaction. Used in revenue management for rate differentiation. [ENUM-REF-CANDIDATE: ocean|city|mountain|garden|pool|courtyard|no_view|partial — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RoomType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualRuleId rdf:type rdf:Property ;
    rdfs:label 'Accrual Rule Id' ;
    rdfs:comment 'Unique identifier for the loyalty points accrual rule. Primary key for the accrual rule configuration entity.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccrualRule .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Accrual rules define points earning logic with significant revenue/liability impact. Creator tracking enables audit trails, version control, accountability, and performance reviews for loyalty operati' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableBrands rdf:type rdf:Property ;
    rdfs:label 'Applicable Brands' ;
    rdfs:comment 'Comma-separated list of brand codes where this rule applies (e.g., luxury, premium, select-service). Used when property_applicability is \'brand_specific\'. Null indicates all brands.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePropertyIds rdf:type rdf:Property ;
    rdfs:label 'Applicable Property Ids' ;
    rdfs:comment 'Comma-separated list of property identifiers where this rule applies. Used when property_applicability is \'property_list\'. Null indicates rule applies per property_applicability setting.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Regions' ;
    rdfs:comment 'Comma-separated list of geographic region codes where this rule applies (e.g., NORAM, EMEA, APAC, LATAM). Used when property_applicability is \'region_specific\'. Null indicates all regions.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingChannelRestriction rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Restriction' ;
    rdfs:comment 'Comma-separated list of booking channels (direct, OTA, GDS, CRS, mobile_app, call_center) eligible for this accrual rule. Used to incentivize direct bookings. Null indicates all channels are eligible.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfWeekRestriction rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Restriction' ;
    rdfs:comment 'Comma-separated list of days of week (MON, TUE, WED, THU, FRI, SAT, SUN) when this rule applies. Used for promotional rules targeting specific days. Null indicates all days are eligible.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earningBasis rdf:type rdf:Property ;
    rdfs:label 'Earning Basis' ;
    rdfs:comment 'The transaction component or activity on which points accrual is calculated: room_revenue (ADR-based), fnb_spend (Food and Beverage), spa_spend, ancillary_spend (parking, resort fees), partner_spend (co-branded partners), nights_stayed (per-night basis), qualifying_stays (per-stay basis). [ENUM-REF-CANDIDATE: room_revenue|fnb_spend|spa_spend|ancillary_spend|partner_spend|nights_stayed|qualifying_stays — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleRateCodes rdf:type rdf:Property ;
    rdfs:label 'Eligible Rate Codes' ;
    rdfs:comment 'Comma-separated list of rate codes (BAR, corporate, government, promotional) that qualify for points earning under this rule. Null or empty indicates all rate codes are eligible.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualPointsVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Points Volume' ;
    rdfs:comment 'Projected total number of loyalty points expected to be issued annually under this accrual rule. Used for program economics forecasting and liability planning.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excludedRateCodes rdf:type rdf:Property ;
    rdfs:label 'Excluded Rate Codes' ;
    rdfs:comment 'Comma-separated list of rate codes explicitly excluded from earning points under this rule (e.g., employee rates, complimentary stays, distressed inventory). Takes precedence over eligible_rate_codes.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRuleCode rdf:type rdf:Property ;
    rdfs:label 'External Rule Code' ;
    rdfs:comment 'Unique identifier for this accrual rule in the source operational system. Used for cross-system reconciliation and integration mapping.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStackable rdf:type rdf:Property ;
    rdfs:label 'Is Stackable' ;
    rdfs:comment 'Indicates whether this accrual rule can be combined with other rules for the same transaction (True) or is mutually exclusive (False). Used to control promotional stacking and program economics.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingMessage rdf:type rdf:Property ;
    rdfs:label 'Marketing Message' ;
    rdfs:comment 'Member-facing promotional message describing the earning opportunity (e.g., \'Earn 2X points on weekend stays!\'). Used in marketing campaigns and member communications.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPointsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Maximum Points Per Transaction' ;
    rdfs:comment 'Cap on the number of points that can be earned in a single transaction under this rule. Used to prevent abuse and manage program liability. Null indicates no cap.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberSegmentRestriction rdf:type rdf:Property ;
    rdfs:label 'Member Segment Restriction' ;
    rdfs:comment 'Comma-separated list of member segment codes (corporate, leisure, group, FIT) eligible for this accrual rule. Used for segment-targeted promotions. Null indicates all segments are eligible.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberTierRestriction rdf:type rdf:Property ;
    rdfs:label 'Member Tier Restriction' ;
    rdfs:comment 'Comma-separated list of loyalty tier codes (base, silver, gold, platinum, diamond) eligible for this accrual rule. Used for tier-specific promotional rules. Null indicates all tiers are eligible.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Amount' ;
    rdfs:comment 'Minimum spend threshold required for the accrual rule to apply. Transactions below this amount do not earn points under this rule. Null indicates no minimum.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsPerCurrencyUnit rdf:type rdf:Property ;
    rdfs:label 'Points Per Currency Unit' ;
    rdfs:comment 'Base rate of loyalty points earned per unit of currency spent (e.g., 10.0000 points per USD, 5.0000 points per EUR). Used as the multiplier in the points calculation engine.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programLiabilityImpact rdf:type rdf:Property ;
    rdfs:label 'Program Liability Impact' ;
    rdfs:comment 'Assessment of the financial liability impact this accrual rule has on the loyalty program\'s balance sheet: low (minimal incremental liability), medium (moderate impact), high (significant liability increase). Used for program economics monitoring.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyApplicability rdf:type rdf:Property ;
    rdfs:label 'Property Applicability' ;
    rdfs:comment 'Scope of properties where this accrual rule applies: all (entire portfolio), brand_specific (luxury/premium/select-service), property_list (specific property IDs), region_specific (geographic regions).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Short alphanumeric code used as a unique business identifier for the accrual rule in operational systems and reporting (e.g., \'ROOM_BASE\', \'FNB_ELITE\', \'SPA_PROMO\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed business description of the accrual rule, including its purpose, earning mechanics, eligibility criteria, and any special conditions. Used for documentation and business user reference.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Business-friendly name of the accrual rule for identification and reporting purposes (e.g., \'Base Room Revenue Earn\', \'Elite Tier Bonus\', \'F&B Spend Multiplier\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'Numeric priority ranking used to resolve conflicts when multiple accrual rules apply to the same transaction. Lower numbers indicate higher priority. The points calculation engine applies the highest-priority matching rule.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the accrual rule: draft (under development), active (in production), suspended (temporarily disabled), expired (past effective_end_date), retired (permanently deactivated).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the accrual rule by its business purpose: base (standard earning), bonus (additional points), promotional (limited-time campaign), tier_multiplier (elite status boost), partner (third-party earn), seasonal (time-bound recurring).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentMultiplier rdf:type rdf:Property ;
    rdfs:label 'Segment Multiplier' ;
    rdfs:comment 'Additional multiplier applied based on member segment or customer classification (e.g., corporate, leisure, group). Used for targeted earning incentives.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMultiplier rdf:type rdf:Property ;
    rdfs:label 'Tier Multiplier' ;
    rdfs:comment 'Additional multiplier applied based on member loyalty tier or elite status (e.g., 1.00 for base, 1.25 for silver, 1.50 for gold, 2.00 for platinum). Multiplies the base points calculation.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Benefit Entitlement Id' ;
    rdfs:comment 'Unique identifier for the benefit entitlement record. Primary key.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitEntitlement .

ind:primaryBenefitEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Benefit Employee Id' ;
    rdfs:comment 'The system user ID or employee ID of the person who manually granted this benefit, if applicable. Null for system-generated entitlements.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryBenefitLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Benefit Last Modified By User Employee Id' ;
    rdfs:comment 'The system user ID or employee ID of the person who last modified this benefit entitlement record.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advanceBookingRequiredDays rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Required Days' ;
    rdfs:comment 'The minimum number of days in advance that a reservation must be made to redeem this benefit. Null if no advance booking requirement exists.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether this benefit is automatically applied to eligible reservations or requires manual member selection. True if auto-applied, False if opt-in required.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitDescription rdf:type rdf:Property ;
    rdfs:label 'Benefit Description' ;
    rdfs:comment 'Detailed description of the benefit, including terms, conditions, and any restrictions or exclusions.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitName rdf:type rdf:Property ;
    rdfs:label 'Benefit Name' ;
    rdfs:comment 'Human-readable name of the benefit entitlement for display and communication purposes.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitTypeCode rdf:type rdf:Property ;
    rdfs:label 'Benefit Type Code' ;
    rdfs:comment 'The category of benefit granted to the member. Examples include complimentary breakfast, room upgrade, late checkout, lounge access, welcome amenity, or bonus points multiplier.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandRestriction rdf:type rdf:Property ;
    rdfs:label 'Brand Restriction' ;
    rdfs:comment 'The brand code if this benefit is restricted to properties within a specific brand. Null if no brand restriction applies.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinableFlag rdf:type rdf:Property ;
    rdfs:label 'Combinable Flag' ;
    rdfs:comment 'Indicates whether this benefit can be combined with other benefits or promotions during the same stay. True if combinable, False if mutually exclusive.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementSource rdf:type rdf:Property ;
    rdfs:label 'Entitlement Source' ;
    rdfs:comment 'The origin or reason for granting this benefit. Tier standard benefits are automatic based on member tier; status match benefits are granted when matching status from another program; manual grants are discretionary; promotion benefits are campaign-driven; compensation benefits are service recovery; partner benefits come from co-branded or partner integrations.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle status of the benefit entitlement. Active entitlements can be redeemed; suspended entitlements are temporarily unavailable; expired entitlements have passed their validity period; revoked entitlements have been withdrawn; pending entitlements are awaiting activation.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Granted Timestamp' ;
    rdfs:comment 'The date and time when this benefit entitlement was created or granted to the member.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumStayNights rdf:type rdf:Property ;
    rdfs:label 'Maximum Stay Nights' ;
    rdfs:comment 'The maximum length of stay (LOS) in nights for which this benefit can be applied. Null if no maximum stay restriction exists.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumStayNights rdf:type rdf:Property ;
    rdfs:label 'Minimum Stay Nights' ;
    rdfs:comment 'The minimum length of stay (LOS) in nights required to redeem this benefit. Null if no minimum stay requirement exists.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Multiplier' ;
    rdfs:comment 'The bonus points multiplier applied to eligible stays when this benefit is active. For example, 1.5 means the member earns 50% bonus points. Null if this benefit does not include a points multiplier.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyRestriction rdf:type rdf:Property ;
    rdfs:label 'Property Restriction' ;
    rdfs:comment 'Indicates whether this benefit can be redeemed at all properties, only at specific properties, within a specific brand, or within a specific geographic region.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionRestriction rdf:type rdf:Property ;
    rdfs:label 'Region Restriction' ;
    rdfs:comment 'The geographic region code if this benefit is restricted to properties within a specific region. Null if no region restriction applies.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingUsage rdf:type rdf:Property ;
    rdfs:label 'Remaining Usage' ;
    rdfs:comment 'The number of redemptions remaining for this benefit. Calculated as usage_limit minus usage_count. Null if usage is unlimited.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revokedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revoked Timestamp' ;
    rdfs:comment 'The date and time when this benefit entitlement was revoked. Null if the benefit has not been revoked.' ;
    rdfs:domain ind:BenefitEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether this benefit can be transferred to another loyalty member. True if transferable, False if non-transferable.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'The number of times this benefit has been redeemed to date. Used to track remaining usage against the usage limit.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageLimit rdf:type rdf:Property ;
    rdfs:label 'Usage Limit' ;
    rdfs:comment 'The maximum number of times this benefit can be redeemed during its validity period. Null indicates unlimited usage.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Benefit Redemption Id' ;
    rdfs:comment 'Unique identifier for the benefit redemption record. Primary key for tracking the complete lifecycle of a loyalty member benefit from entitlement through consumption or expiry.' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliveryMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Minutes' ;
    rdfs:comment 'Actual time in minutes taken to deliver the benefit from the moment of request or check-in. Used for SLA compliance measurement.' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitStatus rdf:type rdf:Property ;
    rdfs:label 'Benefit Status' ;
    rdfs:comment 'Current lifecycle status of the benefit: active (available for use), redeemed (fully consumed), expired (past validity date), cancelled (revoked), or pending (awaiting activation).' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costToPropertyAmount rdf:type rdf:Property ;
    rdfs:label 'Cost To Property Amount' ;
    rdfs:comment 'Actual cost incurred by the property to deliver this benefit. Used for GOP (Gross Operating Profit) and program ROI (Return on Investment) analysis.' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Specific location within the property where the benefit was delivered (e.g., \'Front Desk\', \'Executive Lounge\', \'Room 1205\', \'Restaurant - The Grill\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementDate rdf:type rdf:Property ;
    rdfs:label 'Entitlement Date' ;
    rdfs:comment 'Date when the benefit was granted or became available to the member.' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Standardized code indicating the type of exception: benefit unavailable, substitution provided, upgrade given, downgrade applied, partial fulfillment, or member declined benefit.' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Member Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the member acknowledged receipt of the benefit (True) or not (False). Used for service quality tracking and dispute resolution.' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monetaryValueAmount rdf:type rdf:Property ;
    rdfs:label 'Monetary Value Amount' ;
    rdfs:comment 'Estimated monetary value of the benefit in the property\'s local currency. Used for program economics tracking and LTV (Lifetime Value) calculations.' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsEquivalent rdf:type rdf:Property ;
    rdfs:label 'Points Equivalent' ;
    rdfs:comment 'Loyalty points value equivalent of this benefit. Used when members have the option to choose between benefits or points.' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionDate rdf:type rdf:Property ;
    rdfs:label 'Redemption Date' ;
    rdfs:comment 'Date when the benefit was redeemed or consumed by the member. Null if not yet redeemed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Precise date and time when the benefit was redeemed, including time zone. Used for operational tracking and SLA (Service Level Agreement) compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remainingUsageCount rdf:type rdf:Property ;
    rdfs:label 'Remaining Usage Count' ;
    rdfs:comment 'Number of redemptions still available for this benefit. Decrements with each usage. Null indicates unlimited remaining usage.' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionBenefitType rdf:type rdf:Property ;
    rdfs:label 'Substitution Benefit Type' ;
    rdfs:comment 'Type of benefit provided as a substitute when the original benefit was unavailable. Null if no substitution occurred.' ;
    rdfs:domain ind:BenefitRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateId rdf:type rdf:Property ;
    rdfs:label 'Certificate Id' ;
    rdfs:comment 'Unique identifier for the loyalty certificate or voucher. Primary key.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certificate .

ind:partnerProgramId rdf:type rdf:Property ;
    rdfs:label 'Partner Program Id' ;
    rdfs:comment 'Reference to the partner program if certificate was issued through or redeemable with a partner (e.g., airline miles certificate). Null if hotel-only certificate.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerProgram .

ind:promotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Id' ;
    rdfs:comment 'Foreign key linking to loyalty.promotion. Business justification: Certificates are often issued as part of loyalty promotions. Currently certificate has campaign_code (STRING) but no formal FK. Adding promotion_id creates a formal link to the promotion that triggere' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:advanceBookingDays rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Days' ;
    rdfs:comment 'Minimum number of days in advance that redemption must be booked. Null if no advance booking requirement.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the certificate: issued (active and available), reserved (held for pending booking), redeemed (used), expired (past validity date), voided (invalidated by system), or cancelled (invalidated by member or admin).' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Category of certificate or voucher issued. Defines the benefit type: free night award, room upgrade certificate, Food and Beverage (F&B) credit, spa voucher, airline miles certificate, or experience voucher.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faceValue rdf:type rdf:Property ;
    rdfs:label 'Face Value' ;
    rdfs:comment 'Monetary value of the certificate in the specified currency. Represents the benefit amount (e.g., dollar value of F&B credit, estimated value of free night). Zero for non-monetary certificates.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issueChannel rdf:type rdf:Property ;
    rdfs:label 'Issue Channel' ;
    rdfs:comment 'Channel through which the certificate was issued: web (loyalty website), mobile app, call center, property (front desk or guest services), email (automated fulfillment), partner portal, or admin console (manual issuance by staff). [ENUM-REF-CANDIDATE: web|mobile_app|call_center|property|email|partner_portal|admin_console — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueReason rdf:type rdf:Property ;
    rdfs:label 'Issue Reason' ;
    rdfs:comment 'Business reason for issuing the certificate: points redemption (member purchased with points), elite benefit (tier entitlement), promotion (marketing campaign), service recovery (guest complaint resolution), compensation (operational failure), partner transfer (from partner program), or campaign (targeted offer). [ENUM-REF-CANDIDATE: points_redemption|elite_benefit|promotion|service_recovery|compensation|partner_transfer|campaign — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Precise timestamp when the certificate was issued to the member, including time zone. Used for audit and operational tracking.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pointsCost rdf:type rdf:Property ;
    rdfs:label 'Points Cost' ;
    rdfs:comment 'Number of loyalty points deducted from member account to issue this certificate. Zero if certificate was issued complimentary or as compensation.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'Channel through which the certificate was redeemed. Null if not yet redeemed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierAtIssue rdf:type rdf:Property ;
    rdfs:label 'Tier At Issue' ;
    rdfs:comment 'Loyalty tier code of the member at the time the certificate was issued. Used for historical tracking and tier-specific benefit analysis.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierAtRedemption rdf:type rdf:Property ;
    rdfs:label 'Tier At Redemption' ;
    rdfs:comment 'Loyalty tier code of the member at the time the certificate was redeemed. Null if not yet redeemed.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedReason rdf:type rdf:Property ;
    rdfs:label 'Voided Reason' ;
    rdfs:comment 'Business reason for voiding the certificate (e.g., fraud detection, duplicate issuance, system error, member request). Null if not voided.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Id' ;
    rdfs:comment 'Unique identifier for the loyalty program enrollment transaction. Primary key.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLoyaltyMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Loyalty Member Id' ;
    rdfs:comment 'Reference to the guest who enrolled in the loyalty program. Links to the guest master record.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Marketing campaign or promotion code associated with the enrollment. Used for campaign performance tracking and ROI analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Submitted Flag' ;
    rdfs:comment 'Indicates whether the member submitted proof of status from the competitor program. Populated only for status match enrollments.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Email Consent Flag' ;
    rdfs:comment 'Indicates whether the member consented to receive email communications at the time of enrollment.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current status of the enrollment transaction. Tracks the lifecycle state of the enrollment record.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialTier rdf:type rdf:Property ;
    rdfs:label 'Initial Tier' ;
    rdfs:comment 'The loyalty tier assigned to the member at enrollment. Typically base tier unless status match or promotional tier granted.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Match Expiry Date' ;
    rdfs:comment 'The date when the status match tier expires and the member must requalify. Populated only for status match enrollments.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchTierGranted rdf:type rdf:Property ;
    rdfs:label 'Match Tier Granted' ;
    rdfs:comment 'The tier level granted in our program as a result of the status match. Populated only for status match enrollments.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyPolicyAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Accepted Flag' ;
    rdfs:comment 'Indicates whether the member accepted the privacy policy at enrollment. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Version' ;
    rdfs:comment 'Version number of the privacy policy that the member accepted at enrollment. Used for audit and compliance tracking.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Push Notification Consent Flag' ;
    rdfs:comment 'Indicates whether the member consented to receive mobile app push notifications at the time of enrollment.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralCode rdf:type rdf:Property ;
    rdfs:label 'Referral Code' ;
    rdfs:comment 'Referral code used by the enrolling member if they were referred by an existing member. Used for member-get-member program tracking.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requalificationRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Requalification Requirement Flag' ;
    rdfs:comment 'Indicates whether the member must meet standard tier qualification criteria to retain the matched tier after expiry. Populated only for status match enrollments.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smsConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Consent Flag' ;
    rdfs:comment 'Indicates whether the member consented to receive SMS text message communications at the time of enrollment.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceProgramName rdf:type rdf:Property ;
    rdfs:label 'Source Program Name' ;
    rdfs:comment 'Name of the competitor loyalty program from which status was matched. Populated only for status match enrollments.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTierClaimed rdf:type rdf:Property ;
    rdfs:label 'Source Tier Claimed' ;
    rdfs:comment 'The tier level the member claimed to hold in the source competitor program. Populated only for status match enrollments.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Status Match Flag' ;
    rdfs:comment 'Indicates whether this enrollment was a competitive status match acquisition from another loyalty program.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Flag' ;
    rdfs:comment 'Indicates whether the member accepted the loyalty program terms and conditions at enrollment. Required for legal compliance.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'Version number of the terms and conditions that the member accepted at enrollment. Used for audit and compliance tracking.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:welcomeBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Welcome Bonus Points' ;
    rdfs:comment 'Number of loyalty points awarded as a welcome bonus upon enrollment. Zero if no welcome bonus was offered.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsLedgerId rdf:type rdf:Property ;
    rdfs:label 'Points Ledger Id' ;
    rdfs:comment 'Reference identifier of the points ledger transaction that reversed fraudulent points. Links to points_ledger for audit trail. Null if no reversal occurred.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PointsLedger .

ind:triggeringPointsLedgerId rdf:type rdf:Property ;
    rdfs:label 'Triggering Points Ledger Id' ;
    rdfs:comment 'Foreign key linking to loyalty.points_ledger. Business justification: fraud_alert currently has triggering_transaction_id (STRING) and triggering_transaction_type (STRING). When the fraud is detected on a points transaction, adding triggering_points_ledger_id FK creates' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PointsLedger .

ind:triggeringPointsTransferId rdf:type rdf:Property ;
    rdfs:label 'Triggering Points Transfer Id' ;
    rdfs:comment 'Foreign key linking to loyalty.points_transfer. Business justification: When fraud is detected on a points transfer transaction, this FK links to the specific transfer record. Nullable and mutually exclusive with other transaction FKs. Partner transfers are a common fraud' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PointsTransfer .

ind:triggeringRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Triggering Redemption Id' ;
    rdfs:comment 'Foreign key linking to loyalty.redemption. Business justification: When fraud is detected on a redemption transaction, this FK links to the specific redemption record. Nullable and mutually exclusive with triggering_points_ledger_id. Enables direct navigation to the ' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Redemption .

ind:accountFrozenFlag rdf:type rdf:Property ;
    rdfs:label 'Account Frozen Flag' ;
    rdfs:comment 'Indicates whether the member account was frozen as a result of this fraud alert. True if account is currently frozen; false otherwise.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountFrozenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Frozen Timestamp' ;
    rdfs:comment 'Date and time when the member account was frozen due to fraud alert. Null if account was not frozen.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertSeverity rdf:type rdf:Property ;
    rdfs:label 'Alert Severity' ;
    rdfs:comment 'Severity level of the fraud alert based on potential financial impact, member risk, and program integrity threat. Critical indicates immediate action required with significant financial or reputational risk; high indicates substantial risk requiring urgent investigation; medium indicates moderate risk requiring timely review; low indicates minor risk for routine investigation.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method by which the fraudulent activity was detected. Rule-based indicates detection by predefined business rules; ML model indicates detection by machine learning algorithm; manual report indicates detection by fraud analyst review; partner notification indicates alert received from partner program; member report indicates member-initiated fraud report.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the fraudulent activity was first detected by the system or reported. Represents the business event time of fraud discovery.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:falsePositiveReason rdf:type rdf:Property ;
    rdfs:label 'False Positive Reason' ;
    rdfs:comment 'Explanation of why the fraud alert was determined to be a false positive. Documents legitimate business activity that triggered the alert. Null if alert was not classified as false positive.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geolocation Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code derived from source IP address geolocation. Used to identify suspicious cross-border activity.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Timestamp' ;
    rdfs:comment 'Date and time when investigation of the fraud alert was initiated by an analyst. Null if investigation has not yet started.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lawEnforcementCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Case Number' ;
    rdfs:comment 'Case or reference number provided by law enforcement agency if fraud was reported. Null if not reported to authorities.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified Flag' ;
    rdfs:comment 'Indicates whether law enforcement authorities were notified of the confirmed fraud. True if notification occurred; false otherwise.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberNotificationChannel rdf:type rdf:Property ;
    rdfs:label 'Member Notification Channel' ;
    rdfs:comment 'Communication channel used to notify the member of the fraud alert. Email indicates electronic mail; SMS indicates text message; phone indicates voice call; mail indicates postal mail; in_app indicates mobile application notification.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Member Notification Timestamp' ;
    rdfs:comment 'Date and time when the loyalty member was notified of the fraud alert. Null if member was not notified.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:memberNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Member Notified Flag' ;
    rdfs:comment 'Indicates whether the loyalty member was notified of the fraud alert and investigation. True if member was contacted; false otherwise.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier of the fraud detection model or rule set that generated the alert. Enables tracking of model performance and alert quality over time.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetaryValueInvolved rdf:type rdf:Property ;
    rdfs:label 'Monetary Value Involved' ;
    rdfs:comment 'Estimated monetary value of the fraudulent activity in the program\'s base currency. Calculated based on points value, cash redemptions, or other financial impact.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsAmountInvolved rdf:type rdf:Property ;
    rdfs:label 'Points Amount Involved' ;
    rdfs:comment 'Total number of loyalty points involved in the suspected or confirmed fraudulent activity. Null if fraud does not involve points movement.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsReversedAmount rdf:type rdf:Property ;
    rdfs:label 'Points Reversed Amount' ;
    rdfs:comment 'Number of loyalty points reversed or clawed back from the member account as part of fraud resolution. Null if no points reversal occurred.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryReportSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Timestamp' ;
    rdfs:comment 'Date and time when regulatory report was submitted to authorities. Null if no regulatory reporting was required or report not yet submitted.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken to resolve the fraud alert. Account freeze indicates temporary suspension of account activity; points reversal indicates fraudulent points removed from account; password reset indicates forced credential change; account closure indicates permanent account termination; no action indicates alert closed without intervention; member notification indicates member contacted regarding suspicious activity.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDeviceType rdf:type rdf:Property ;
    rdfs:label 'Source Device Type' ;
    rdfs:comment 'Type of device used for the triggering transaction or activity. Desktop indicates web browser on computer; mobile indicates smartphone; tablet indicates tablet device; API indicates programmatic access; unknown indicates device type could not be determined.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceIpAddress rdf:type rdf:Property ;
    rdfs:label 'Source Ip Address' ;
    rdfs:comment 'Internet Protocol address associated with the triggering transaction or suspicious activity. Used for fraud pattern analysis and geolocation. May be considered PII in some jurisdictions.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringTransactionType rdf:type rdf:Property ;
    rdfs:label 'Triggering Transaction Type' ;
    rdfs:comment 'Type of loyalty program transaction or activity that triggered the fraud alert. Identifies the specific action that raised suspicion.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Member acquisition costs are allocated to the enrolling property\'s cost center for departmental P&L. Marketing ROI analysis and CAC (customer acquisition cost) reporting by department require linking ' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:memberEnrollmentHotelPropertyId rdf:type rdf:Property ;
    rdfs:label 'Member Enrollment Hotel Property Id' ;
    rdfs:comment 'Foreign key reference to the property where the member enrolled in the loyalty program, if enrollment occurred at a physical location.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:memberGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Member Guest Profile Id' ;
    rdfs:comment 'FK to guest.profile.profile_id — MUST-HAVE: Loyalty member must resolve to guest identity for personalization, stay history correlation, and profile merge operations. Without this FK, loyalty benefits cannot be applied at check-in.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:memberProfileId rdf:type rdf:Property ;
    rdfs:label 'Member Profile Id' ;
    rdfs:comment 'Foreign key reference to the guest domain. Links the loyalty member to their guest profile which owns PII and stay history.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:memberPropertyId rdf:type rdf:Property ;
    rdfs:label 'Member Property Id' ;
    rdfs:comment 'Foreign key reference to the property that the member visits most frequently or has designated as their preferred location.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:accountClosureDate rdf:type rdf:Property ;
    rdfs:label 'Account Closure Date' ;
    rdfs:comment 'Date when the membership account was closed or terminated. Null for active accounts.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountClosureReason rdf:type rdf:Property ;
    rdfs:label 'Account Closure Reason' ;
    rdfs:comment 'Reason for membership account closure. Used for churn analysis and program improvement.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationOptIn rdf:type rdf:Property ;
    rdfs:label 'Communication Opt In' ;
    rdfs:comment 'Indicates whether the member has opted in to receive marketing communications and promotional offers from the loyalty program.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyPreference rdf:type rdf:Property ;
    rdfs:label 'Currency Preference' ;
    rdfs:comment 'Member\'s preferred currency for displaying points value and pricing. Three-letter ISO 4217 currency code.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Current Points Balance' ;
    rdfs:comment 'Current available points balance that can be redeemed by the member. Reflects earned points minus redeemed and expired points.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimeNights rdf:type rdf:Property ;
    rdfs:label 'Lifetime Nights' ;
    rdfs:comment 'Total number of room nights stayed by the member since enrollment. Used for tier qualification and LTV (Lifetime Value) calculation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Total cumulative points earned by the member since enrollment. Used for tier qualification and lifetime value tracking.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimeRevenue rdf:type rdf:Property ;
    rdfs:label 'Lifetime Revenue' ;
    rdfs:comment 'Total revenue generated by the member across all stays, F&B (Food and Beverage), and ancillary services since enrollment. Key LTV (Lifetime Value) metric.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeStays rdf:type rdf:Property ;
    rdfs:label 'Lifetime Stays' ;
    rdfs:comment 'Total number of completed stays by the member since enrollment. Key metric for member engagement and tier qualification.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'Externally-known unique membership identifier assigned to the loyalty program member. Used for member recognition and program transactions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the loyalty membership account. Active members can accrue and redeem points; suspended or closed accounts have restricted access.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStayDate rdf:type rdf:Property ;
    rdfs:label 'Next Stay Date' ;
    rdfs:comment 'Date of the member\'s next confirmed reservation. Used for engagement tracking and personalized offers.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Partner Sharing Consent' ;
    rdfs:comment 'Indicates whether the member has consented to share their data with loyalty program partners (airlines, car rentals, etc.) for cross-program benefits.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsExpired rdf:type rdf:Property ;
    rdfs:label 'Points Expired' ;
    rdfs:comment 'Total cumulative points that have expired due to inactivity or program rules.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Points Redeemed' ;
    rdfs:comment 'Total cumulative points redeemed by the member for rewards, upgrades, or benefits since enrollment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saltScore rdf:type rdf:Property ;
    rdfs:label 'Salt Score' ;
    rdfs:comment 'SALT (Satisfaction and Loyalty Tracking) composite score measuring member satisfaction and loyalty. Proprietary metric combining multiple engagement and satisfaction indicators.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiration Date' ;
    rdfs:comment 'Date when the member\'s current tier status expires. Used for tier renewal campaigns and retention efforts.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Date' ;
    rdfs:comment 'Date when the member qualified for their current tier. Used for tier anniversary tracking and benefit eligibility.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ytdNights rdf:type rdf:Property ;
    rdfs:label 'Ytd Nights' ;
    rdfs:comment 'Number of room nights stayed by the member in the current calendar year. Used for annual tier qualification.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ytdRevenue rdf:type rdf:Property ;
    rdfs:label 'Ytd Revenue' ;
    rdfs:comment 'Total revenue generated by the member in the current calendar year. Used for tier qualification and annual performance tracking.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdStays rdf:type rdf:Property ;
    rdfs:label 'Ytd Stays' ;
    rdfs:comment 'Number of completed stays by the member in the current calendar year. Used for annual tier qualification.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Member Preference Id' ;
    rdfs:comment 'Unique identifier for the member preference record. Primary key.' ;
    rdfs:domain ind:MemberPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'The confidence or reliability level of this preference. Stated preferences have highest confidence; inferred preferences are scored based on frequency and recency of observed behavior.' ;
    rdfs:domain ind:MemberPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastObservedDate rdf:type rdf:Property ;
    rdfs:label 'Last Observed Date' ;
    rdfs:comment 'The most recent date when this preference was observed in a stay or interaction. Used for recency scoring in confidence calculations.' ;
    rdfs:domain ind:MemberPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'The date when this preference was last modified or confirmed by the member or system. Used to track recency for confidence scoring.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'The number of times this preference has been observed in the member\'s stay history or interactions. Used to calculate confidence level for inferred preferences.' ;
    rdfs:domain ind:MemberPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this preference can be overridden by operational constraints or property-level decisions. True if override is allowed; false if preference must be honored.' ;
    rdfs:domain ind:MemberPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberSegmentId rdf:type rdf:Property ;
    rdfs:label 'Member Segment Id' ;
    rdfs:comment 'Unique identifier for the loyalty member segment definition. Primary key.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberSegment .

ind:primaryMemberEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Member Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that created this segment definition. Used for audit trail and accountability.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allowOverlapFlag rdf:type rdf:Property ;
    rdfs:label 'Allow Overlap Flag' ;
    rdfs:comment 'Indicates whether members can belong to this segment simultaneously with other segments (true) or if this segment is mutually exclusive with others (false).' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campaignEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Eligible Flag' ;
    rdfs:comment 'Indicates whether members in this segment are eligible for targeted marketing campaigns (true) or if this is an analytical-only segment (false).' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidenceThreshold rdf:type rdf:Property ;
    rdfs:label 'Confidence Threshold' ;
    rdfs:comment 'Minimum confidence score (0.0000-1.0000) required for model-driven segment assignment. Null if not model-driven. Used to control precision vs. recall trade-off.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentMemberCount rdf:type rdf:Property ;
    rdfs:label 'Current Member Count' ;
    rdfs:comment 'Actual number of members currently assigned to this segment as of the last refresh or calculation run. Updated periodically based on refresh frequency.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Engagement Score Threshold' ;
    rdfs:comment 'Minimum engagement score (0-100 scale) required for segment membership. Null if engagement score is not a criterion. Used for behavioral segmentation.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Business rules defining conditions that disqualify a member from this segment even if inclusion criteria are met (e.g., account_closure_date IS NOT NULL, communication_opt_in=false).' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Comma-separated list of country codes (ISO 3166-1 alpha-3) or region codes that limit segment membership. Empty if no geographic restriction applies.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Inclusion Criteria' ;
    rdfs:comment 'Detailed business rules and conditions that define member eligibility for this segment (e.g., tier=Platinum AND ytd_nights>=50 AND last_stay_date<=90 days). Stored as human-readable text or structured expression.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Date and time when member assignments to this segment were last recalculated and updated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumLtv rdf:type rdf:Property ;
    rdfs:label 'Maximum Ltv' ;
    rdfs:comment 'Maximum lifetime value threshold for segment membership. Null if no upper LTV bound applies. Used to define LTV bands or exclude ultra-high-value guests.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumNights rdf:type rdf:Property ;
    rdfs:label 'Maximum Nights' ;
    rdfs:comment 'Maximum number of lifetime or qualifying-period nights for segment membership. Null if no upper nights bound applies.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumLtv rdf:type rdf:Property ;
    rdfs:label 'Minimum Ltv' ;
    rdfs:comment 'Minimum lifetime value threshold required for segment membership. Null if LTV is not a criterion for this segment. Used for high-value guest targeting.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumNights rdf:type rdf:Property ;
    rdfs:label 'Minimum Nights' ;
    rdfs:comment 'Minimum number of lifetime or qualifying-period nights required for segment membership. Null if nights are not a criterion.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumStays rdf:type rdf:Property ;
    rdfs:label 'Minimum Stays' ;
    rdfs:comment 'Minimum number of lifetime or qualifying-period stays required for segment membership. Null if stays are not a criterion.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Timestamp' ;
    rdfs:comment 'Scheduled date and time for the next recalculation of member assignments to this segment. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:npsThreshold rdf:type rdf:Property ;
    rdfs:label 'Nps Threshold' ;
    rdfs:comment 'Minimum NPS score required for segment membership. Null if NPS is not a criterion. Used to segment promoters, passives, and detractors.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled Flag' ;
    rdfs:comment 'Indicates whether personalized offers and content should be generated for members in this segment (true) or if standard communications apply (false).' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predictiveModelName rdf:type rdf:Property ;
    rdfs:label 'Predictive Model Name' ;
    rdfs:comment 'Name or identifier of the machine learning or predictive model used to assign members to this segment (e.g., Churn_Risk_Model_v2, Upsell_Propensity_RF). Null if not model-driven.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyDays rdf:type rdf:Property ;
    rdfs:label 'Recency Days' ;
    rdfs:comment 'Number of days since last stay used as a criterion for segment membership (e.g., lapsed guests with no stay in last 90 days). Null if recency is not a criterion.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'How often member assignments to this segment are recalculated and updated (e.g., real-time, daily batch, weekly, monthly, quarterly, on-demand, event-driven upon specific triggers). [ENUM-REF-CANDIDATE: real_time|daily|weekly|monthly|quarterly|on_demand|event_driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saltScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Salt Score Threshold' ;
    rdfs:comment 'Minimum SALT score required for segment membership. Null if SALT score is not a criterion. Used for satisfaction-based segmentation.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed business description of the segment purpose, target audience characteristics, and intended use cases for marketing and retention campaigns.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentOwner rdf:type rdf:Property ;
    rdfs:label 'Segment Owner' ;
    rdfs:comment 'Name or identifier of the business unit, team, or individual responsible for managing this segment (e.g., Loyalty Marketing, CRM Operations, Regional Marketing EMEA).' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentationBasis rdf:type rdf:Property ;
    rdfs:label 'Segmentation Basis' ;
    rdfs:comment 'The primary methodology or dimension used to define this segment (e.g., tier-based, LTV band, RFM analysis, geographic region, behavioral patterns, engagement score, spend level, recency, frequency, predictive model, custom criteria). [ENUM-REF-CANDIDATE: tier|ltv_band|rfm|geographic|behavioral|engagement|spend|recency|frequency|predictive|custom — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Target Population Size' ;
    rdfs:comment 'Expected or target number of members that should fall into this segment based on historical data or business planning. Used for campaign sizing and resource allocation.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierRestriction rdf:type rdf:Property ;
    rdfs:label 'Tier Restriction' ;
    rdfs:comment 'Comma-separated list of loyalty tier codes that are eligible for this segment. Empty if no tier restriction applies. Used to limit segment membership by tier level.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiAuthenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Api Authentication Method' ;
    rdfs:comment 'Authentication protocol used for secure API communication with the partner system.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationEndpoint rdf:type rdf:Property ;
    rdfs:label 'Api Integration Endpoint' ;
    rdfs:comment 'URL endpoint for the partner\'s API used for real-time points transfer, balance inquiries, and transaction synchronization.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the partnership agreement expires or is scheduled for renewal. Null indicates an evergreen or indefinite agreement.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Unique identifier of the legal partnership agreement governing the loyalty program integration, revenue sharing, and operational terms.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether member data can be shared with the partner for personalization and analytics purposes, subject to privacy regulations.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earnEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Earn Eligibility Flag' ;
    rdfs:comment 'Indicates whether loyalty members can earn hotel points through partner transactions (e.g., earning hotel points on partner airline flights).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hotelToPartnerRatio rdf:type rdf:Property ;
    rdfs:label 'Hotel To Partner Ratio' ;
    rdfs:comment 'Conversion ratio for transferring hotel loyalty points to partner points (e.g., 1.5000 means 1 hotel point converts to 1.5 partner points).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Flag' ;
    rdfs:comment 'Indicates whether the partner has consented to co-marketing activities and joint promotional campaigns with the hotel loyalty program.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumTransferAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Transfer Amount' ;
    rdfs:comment 'Maximum number of points allowed for a single transfer transaction between hotel and partner programs. Null indicates no cap.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumTransferAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transfer Amount' ;
    rdfs:comment 'Minimum number of points required for a single transfer transaction between hotel and partner programs.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Email' ;
    rdfs:comment 'Email address of the primary business contact at the partner organization for operational and technical communications.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactName rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the partner organization responsible for the loyalty program integration.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Phone' ;
    rdfs:comment 'Phone number of the primary business contact at the partner organization for urgent escalations and support.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLogoUrl rdf:type rdf:Property ;
    rdfs:label 'Partner Logo Url' ;
    rdfs:comment 'URL to the partner\'s official logo image for display in loyalty program portals, mobile apps, and marketing communications.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Official business name of the external loyalty partner organization (e.g., airline, car rental company, credit card issuer, retail partner).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerProgramStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Program Status' ;
    rdfs:comment 'Current operational status of the partner program indicating whether points transfers and earning/redemption activities are enabled.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerToHotelRatio rdf:type rdf:Property ;
    rdfs:label 'Partner To Hotel Ratio' ;
    rdfs:comment 'Conversion ratio for transferring partner points to hotel loyalty points (e.g., 0.6667 means 1 partner point converts to 0.6667 hotel points).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Partner Website Url' ;
    rdfs:comment 'Official website URL of the partner organization for member reference and marketing materials.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipTier rdf:type rdf:Property ;
    rdfs:label 'Partnership Tier' ;
    rdfs:comment 'Classification of the partnership relationship indicating strategic importance and benefit levels (preferred partners receive priority marketing and enhanced transfer ratios).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Redemption Eligibility Flag' ;
    rdfs:comment 'Indicates whether loyalty members can redeem hotel points for partner rewards (e.g., redeeming hotel points for airline miles).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Percentage of transaction value or points value shared with the partner as part of the commercial agreement.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Eligibility Flag' ;
    rdfs:comment 'Indicates whether loyalty members can transfer points bidirectionally between hotel and partner programs.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferProcessingTimeHours rdf:type rdf:Property ;
    rdfs:label 'Transfer Processing Time Hours' ;
    rdfs:comment 'Expected number of hours for points transfer transactions to complete and reflect in member accounts.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsChannelId rdf:type rdf:Property ;
    rdfs:label 'Points Channel Id' ;
    rdfs:comment 'Foreign key linking to channel.channel. Business justification: Points ledger transactions must link to distribution channel for analyzing points accrual patterns by booking channel, understanding channel-specific earning behavior, and calculating true channel pro' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:redemptionId rdf:type rdf:Property ;
    rdfs:label 'Redemption Id' ;
    rdfs:comment 'Foreign key linking to loyalty.redemption. Business justification: Points ledger entries of transaction_type \'redemption\' should link to the redemption transaction that caused the points burn. Creates bidirectional navigation between ledger and redemption. Nullable (' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Redemption .

ind:redemptionRuleId rdf:type rdf:Property ;
    rdfs:label 'Redemption Rule Id' ;
    rdfs:comment 'Foreign key linking to loyalty.redemption_rule. Business justification: Points redemption/burn transactions should reference the rule that governed the redemption calculation. Enables rule-level reporting and ensures redemptions can be traced to their governing rules. Nul' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RedemptionRule .

ind:reversalReferencePointsLedgerId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Points Ledger Id' ;
    rdfs:comment 'Points ledger ID of the original transaction that this entry reverses. Null for original transactions. Creates audit trail for cancelled transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PointsLedger .

ind:activityDate rdf:type rdf:Property ;
    rdfs:label 'Activity Date' ;
    rdfs:comment 'Date when the underlying business activity occurred (e.g., stay checkout date, F&B transaction date, partner purchase date). This is the business event date, distinct from posting date.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Notes' ;
    rdfs:comment 'Free-text explanation for manual adjustments or reversals, providing context for audit and member service. Null for standard transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standardized code explaining why a manual adjustment or reversal was made (e.g., service recovery, system error correction, duplicate posting). Null for standard transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceAfterTransaction rdf:type rdf:Property ;
    rdfs:label 'Balance After Transaction' ;
    rdfs:comment 'Member\'s total points balance immediately after this transaction was posted. Provides running balance for audit and reconciliation.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseAmount rdf:type rdf:Property ;
    rdfs:label 'Base Amount' ;
    rdfs:comment 'Monetary amount in base currency that generated the points accrual (e.g., room revenue, F&B spend). Used to calculate points earned. Null for non-monetary transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isQualifying rdf:type rdf:Property ;
    rdfs:label 'Is Qualifying' ;
    rdfs:comment 'Indicates whether this transaction counts toward tier qualification or elite status progression. True for qualifying stays and spend, false for bonus points and transfers.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Partner Confirmation Number' ;
    rdfs:comment 'Confirmation or reference number provided by partner program for transfer transactions. Used for reconciliation and dispute resolution. Null for non-transfer transactions.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerProgramCode rdf:type rdf:Property ;
    rdfs:label 'Partner Program Code' ;
    rdfs:comment 'Code identifying the external partner loyalty program involved in transfer transactions (e.g., airline frequent flyer program, credit card rewards program). Null for internal transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsAmount rdf:type rdf:Property ;
    rdfs:label 'Points Amount' ;
    rdfs:comment 'Quantity of points involved in this transaction. Positive for accruals (earn, transfer_in, bonus), negative for debits (redeem, transfer_out, expire, adjust).' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceActivityType rdf:type rdf:Property ;
    rdfs:label 'Source Activity Type' ;
    rdfs:comment 'Category of business activity that generated this points transaction: stay (room revenue), fnb (Food and Beverage spend), spa (spa/wellness services), partner_purchase (external partner transaction), promotion (marketing campaign), manual (staff adjustment), transfer (partner program exchange). [ENUM-REF-CANDIDATE: stay|fnb|spa|partner_purchase|promotion|manual|transfer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierAtTransaction rdf:type rdf:Property ;
    rdfs:label 'Tier At Transaction' ;
    rdfs:comment 'Member\'s loyalty tier status at the time this transaction was posted (e.g., Silver, Gold, Platinum). Captures tier for historical analysis of earning patterns.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDirection rdf:type rdf:Property ;
    rdfs:label 'Transfer Direction' ;
    rdfs:comment 'Direction of partner transfer: inbound (points received from partner into hotel program), outbound (points sent from hotel program to partner). Null for non-transfer transactions.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Fee Amount' ;
    rdfs:comment 'Fee charged to member for partner transfer transaction, expressed in points. Null if no fee applies or for non-transfer transactions.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsTransferId rdf:type rdf:Property ;
    rdfs:label 'Points Transfer Id' ;
    rdfs:comment 'Unique identifier for the loyalty points transfer transaction. Primary key.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Api Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the partner program API integration, used for technical reconciliation and troubleshooting.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for transfer failure, if status is failed. Null if transfer succeeded.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Description' ;
    rdfs:comment 'Human-readable description of why the transfer failed, providing additional context beyond the failure code.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hotelPointsAmount rdf:type rdf:Property ;
    rdfs:label 'Hotel Points Amount' ;
    rdfs:comment 'Number of hotel loyalty points debited (outbound) or credited (inbound) in this transfer transaction.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberTierAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Member Tier At Transfer' ;
    rdfs:comment 'Loyalty program tier status of the member at the time the transfer was requested (e.g., Silver, Gold, Platinum, Diamond).' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Partner Currency Amount' ;
    rdfs:comment 'Number of partner program points or miles credited (outbound) or debited (inbound) in this transfer transaction.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerMemberAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Partner Member Account Number' ;
    rdfs:comment 'Member account number or identifier in the partner loyalty program where points were transferred to or from.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Start Timestamp' ;
    rdfs:comment 'Date and time when the system began processing the transfer request.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Processing Time Seconds' ;
    rdfs:comment 'Total time in seconds taken to process the transfer from request to completion or failure.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Code identifying the promotional campaign under which bonus points were awarded, if applicable.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Promotional Bonus Points' ;
    rdfs:comment 'Additional bonus points awarded as part of a promotional campaign for completing this transfer. Zero if no promotion applies.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestChannel rdf:type rdf:Property ;
    rdfs:label 'Request Channel' ;
    rdfs:comment 'Channel through which the member submitted the points transfer request.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSourceIpAddress rdf:type rdf:Property ;
    rdfs:label 'Request Source Ip Address' ;
    rdfs:comment 'IP address from which the transfer request originated, captured for security and fraud prevention purposes.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the member submitted the points transfer request.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when the transfer was reversed, if applicable. Null if not reversed.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Flag' ;
    rdfs:comment 'Indicates whether this transfer transaction must be reported for tax purposes based on jurisdiction and value thresholds.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Confirmation Number' ;
    rdfs:comment 'Unique alphanumeric confirmation number assigned to this points transfer transaction, used for tracking and customer service inquiries.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transfer fee amount.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current processing status of the points transfer transaction in its lifecycle.' ;
    rdfs:domain ind:PointsTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Api Integration Enabled Flag' ;
    rdfs:comment 'Indicates whether external systems can integrate with this loyalty program via API. True = API access available for partners and properties; False = manual integration only.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakageAssumptionRate rdf:type rdf:Property ;
    rdfs:label 'Breakage Assumption Rate' ;
    rdfs:comment 'Estimated percentage of earned points that will never be redeemed (e.g., 0.1500 = 15%). Used for USALI-compliant revenue recognition and liability estimation. Based on historical redemption patterns.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashPlusPointsEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cash Plus Points Enabled Flag' ;
    rdfs:comment 'Indicates whether members can combine cash and points for redemptions. True = hybrid payment allowed; False = points-only or cash-only redemptions.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant Flag' ;
    rdfs:comment 'Indicates whether this program configuration meets CCPA requirements for California resident data. True = CCPA controls implemented; False = non-California program or pending compliance.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configurationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Configuration Effective Date' ;
    rdfs:comment 'Date when this specific configuration version became effective. Used for time-based rule application and member communication of program changes.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:configurationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Configuration Expiry Date' ;
    rdfs:comment 'Date when this configuration version expires and is replaced by a new version. Null if currently active with no planned end date.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactCenterEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Center Email' ;
    rdfs:comment 'Primary email address for member inquiries and loyalty program support. Used for member communication and published on program website.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactCenterPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Center Phone' ;
    rdfs:comment 'Primary phone number for member services and loyalty program support. Used for member communication materials and website display.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Conversion Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the points-to-currency conversion rate (e.g., \'USD\', \'EUR\', \'GBP\'). Defines the monetary unit for program economics.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyName rdf:type rdf:Property ;
    rdfs:label 'Currency Name' ;
    rdfs:comment 'Name of the loyalty currency unit (e.g., \'Points\', \'Miles\', \'Credits\', \'Stars\'). This is the term displayed to members for their balance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPolicyMonths rdf:type rdf:Property ;
    rdfs:label 'Data Retention Policy Months' ;
    rdfs:comment 'Number of months member data is retained after account closure, per GDPR and CCPA requirements. After this period, PII is purged per right-to-erasure regulations.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:familyPoolingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Family Pooling Enabled Flag' ;
    rdfs:comment 'Indicates whether members can pool points with family members into a shared account. True = pooling allowed; False = pooling disabled.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether this program configuration meets GDPR requirements for EU member data. True = GDPR controls implemented; False = non-EU program or pending compliance.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:giftingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Gifting Enabled Flag' ;
    rdfs:comment 'Indicates whether members can gift points to other members. True = gifting allowed; False = gifting disabled. Subject to anti-fraud controls.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inactivityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Inactivity Period Months' ;
    rdfs:comment 'Number of months of account inactivity (no earn or redeem transactions) before points expire, if points_expiry_policy is \'inactivity_based\'. Null otherwise.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liabilityEstimationMethod rdf:type rdf:Property ;
    rdfs:label 'Liability Estimation Method' ;
    rdfs:comment 'Accounting method for estimating loyalty program liability. incremental_cost = cost to fulfill; fair_value = market value of rewards; redemption_value = points * conversion rate. Must align with USALI and ASC 606.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeStatusEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Lifetime Status Enabled Flag' ;
    rdfs:comment 'Indicates whether the program offers lifetime elite status after achieving cumulative thresholds. True = lifetime tiers available; False = annual re-qualification required.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumEarnPerStay rdf:type rdf:Property ;
    rdfs:label 'Maximum Earn Per Stay' ;
    rdfs:comment 'Maximum number of points a member can earn from a single stay, regardless of spend. Null if no cap applies. Used to manage program liability.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumRedemptionThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Redemption Threshold' ;
    rdfs:comment 'Minimum number of points required to initiate any redemption transaction. Prevents micro-redemptions and reduces operational costs.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileAppEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Mobile App Enabled Flag' ;
    rdfs:comment 'Indicates whether a dedicated mobile application is available for this loyalty program. True = mobile app available; False = web-only access.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerTransferEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Transfer Enabled Flag' ;
    rdfs:comment 'Indicates whether members can transfer points to partner programs (airlines, car rentals, etc.). True = transfers allowed; False = transfers disabled.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsExpiryPolicy rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Policy' ;
    rdfs:comment 'Rule governing when points expire. no_expiry = points never expire; inactivity_based = expire after N months of no activity; fixed_period = expire after N months from earn date; rolling_expiry = expire on a rolling window.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsPurchaseEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Points Purchase Enabled Flag' ;
    rdfs:comment 'Indicates whether members can purchase additional points with cash. True = purchase allowed; False = earn-only program. Subject to regulatory limits in some jurisdictions.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsToCurrencyConversionRate rdf:type rdf:Property ;
    rdfs:label 'Points To Currency Conversion Rate' ;
    rdfs:comment 'Exchange rate for converting loyalty points to monetary value (e.g., 0.0100 means 100 points = 1 USD). Used for redemption valuation and breakage accounting per USALI standards.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Program Launch Date' ;
    rdfs:comment 'Date when the loyalty program was originally launched. Used for program anniversary communications and historical analysis.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programTermsVersion rdf:type rdf:Property ;
    rdfs:label 'Program Terms Version' ;
    rdfs:comment 'Version identifier of the legal terms and conditions document governing this program configuration. Links to the published T&C document for member consent and compliance.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programVersion rdf:type rdf:Property ;
    rdfs:label 'Program Version' ;
    rdfs:comment 'Version identifier for the program configuration (e.g., \'2.1\', \'3.0.1\'). Incremented when program rules or economics change materially.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Program Website Url' ;
    rdfs:comment 'Primary website URL for the loyalty program where members can view terms, check balances, and redeem rewards. Used for marketing and member self-service.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programYearStartMonth rdf:type rdf:Property ;
    rdfs:label 'Program Year Start Month' ;
    rdfs:comment 'Month number (1-12) when the program year begins if tier_year_definition is \'program_year\'. Null for calendar or rolling definitions. 1=January, 12=December.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rollingExpiryWindowMonths rdf:type rdf:Property ;
    rdfs:label 'Rolling Expiry Window Months' ;
    rdfs:comment 'Number of months from earn date after which points expire, if points_expiry_policy is \'rolling_expiry\'. Null otherwise. Example: 24 means points earned on Jan 1, 2023 expire Jan 1, 2025.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statusMatchEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Status Match Enabled Flag' ;
    rdfs:comment 'Indicates whether the program offers status matching from competitor loyalty programs. True = status match campaigns allowed; False = earn-only tier qualification.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Terms Effective Date' ;
    rdfs:comment 'Date when the current program terms and conditions became effective. Used for member communication and regulatory compliance.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierRolloverEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Rollover Enabled Flag' ;
    rdfs:comment 'Indicates whether qualifying nights/stays can roll over to the next qualification period if a member exceeds their tier threshold. True = rollover allowed; False = no rollover.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierYearDefinition rdf:type rdf:Property ;
    rdfs:label 'Tier Year Definition' ;
    rdfs:comment 'Method for calculating the qualification period for tier status. Calendar = Jan 1 - Dec 31; rolling_12_month = trailing 12 months from any date; program_year = custom fiscal period.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGuestSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Guest Segment Id' ;
    rdfs:comment 'Foreign key linking to marketing.guest_segment. Business justification: Loyalty promotions target specific marketing guest segments (e.g., high-value leisure travelers, business frequent guests). Campaign design requires defining which guest segment qualifies for each loy' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestSegment .

ind:awardFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Award Fulfillment Date' ;
    rdfs:comment 'Target date by which bonus points or nights will be posted to qualifying members\' accounts after promotion completion. Used for member communication and fulfillment SLA (Service Level Agreement) tracking.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bonusNightsCredit rdf:type rdf:Property ;
    rdfs:label 'Bonus Nights Credit' ;
    rdfs:comment 'Number of bonus elite-qualifying nights awarded upon promotion completion. Used for tier progression acceleration. Null if promotion does not award night credits.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusPointsAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Points Amount' ;
    rdfs:comment 'Fixed number of bonus loyalty points awarded upon successful completion of promotion criteria. Null if bonus is not a fixed point amount (e.g., multiplier-based).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusPointsMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bonus Points Multiplier' ;
    rdfs:comment 'Multiplier applied to base points earned during the promotion period. Example: 2.0 for double points, 1.5 for 50% bonus. Null if promotion awards fixed points rather than a multiplier.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCapAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Cap Amount' ;
    rdfs:comment 'Maximum financial budget allocated for this promotion (total cost of all bonuses awarded). Promotion may be paused or closed early if budget is exhausted. Measured in base currency (typically USD).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetConsumedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Consumed Amount' ;
    rdfs:comment 'Cumulative financial cost of bonuses awarded to date under this promotion. Updated as members complete qualifying activity and bonuses are posted. Used for budget tracking and ROI (Return on Investment) analysis.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionList rdf:type rdf:Property ;
    rdfs:label 'Exclusion List' ;
    rdfs:comment 'Comma-separated list of member IDs or segments explicitly excluded from this promotion (e.g., employees, test accounts, members who opted out). Null if no exclusions apply.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend Amount' ;
    rdfs:comment 'Minimum total spend (in base currency) required to qualify for the promotion. Null if spend is not a qualifying criterion. Typically measured in USD or property local currency.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Human-readable name of the promotion displayed to members and in marketing channels. Example: \'Double Points Summer Getaway\', \'Elite Status Fast Track\'.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle state of the promotion. Values: draft (being designed), scheduled (approved, not yet live), active (currently running), paused (temporarily suspended), completed (ended successfully), cancelled (terminated early).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Classification of the promotion mechanism. Values: bonus_points_multiplier (earn extra points per dollar), double_nights (accelerate tier qualification), targeted_offer (personalized to segment), welcome_back (re-engagement), birthday_bonus (member birthday reward), spend_challenge (gamified spending goal).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Qualifying Criteria Description' ;
    rdfs:comment 'Detailed narrative of the requirements a member must meet to earn the promotion bonus. Examples: \'Complete 3 stays between June 1 and August 31\', \'Spend minimum $500 on F&B (Food and Beverage) during stay\', \'Book via mobile app using rate code MOBILE2024\'.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingPropertyList rdf:type rdf:Property ;
    rdfs:label 'Qualifying Property List' ;
    rdfs:comment 'Comma-separated list of property IDs or property codes where stays qualify for this promotion. Null or \'ALL\' if promotion applies to all properties. Example: \'PROP001,PROP045,PROP102\' or \'ALL\'.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingRateCodes rdf:type rdf:Property ;
    rdfs:label 'Qualifying Rate Codes' ;
    rdfs:comment 'Comma-separated list of rate codes (BAR - Best Available Rate, corporate codes, promotional codes) that qualify for this promotion. Null or \'ALL\' if all rate codes qualify. Example: \'BAR,CORP,PROMO2024\'.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Registration Required Flag' ;
    rdfs:comment 'Indicates whether members must explicitly register or opt-in to participate in this promotion. True = registration required before qualifying activity counts; False = automatic enrollment for eligible members.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this promotion can be combined with other active promotions. True = member can earn bonuses from multiple promotions simultaneously; False = this promotion cannot be stacked with others.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'Web link to the full legal terms and conditions document for this promotion. Displayed to members during enrollment and in promotional materials.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCompletions rdf:type rdf:Property ;
    rdfs:label 'Total Completions' ;
    rdfs:comment 'Count of members who have successfully completed all qualifying criteria and earned the promotion bonus. Used for conversion rate and campaign effectiveness analysis.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEnrollments rdf:type rdf:Property ;
    rdfs:label 'Total Enrollments' ;
    rdfs:comment 'Count of unique members who have enrolled or been auto-enrolled in this promotion. Used for campaign reach and engagement metrics.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Promotion Enrollment Id' ;
    rdfs:comment 'Unique identifier for the promotion enrollment record. Primary key.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignExecutionId rdf:type rdf:Property ;
    rdfs:label 'Campaign Execution Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign_execution. Business justification: Tracks which specific marketing campaign execution (email send, paid ad, social post) drove a member to enroll in a loyalty promotion. Critical for marketing attribution and campaign ROI measurement.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignExecution .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the promotion bonus was awarded to the member\'s account.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Award Reference Number' ;
    rdfs:comment 'Reference number or transaction ID for the bonus award, used for reconciliation and member inquiries.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardTimestamp rdf:type rdf:Property ;
    rdfs:label 'Award Timestamp' ;
    rdfs:comment 'Precise timestamp when the bonus was posted to the member\'s loyalty account.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Monetary value of the bonus awarded (e.g., account credit, voucher value).' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAwardedFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Awarded Flag' ;
    rdfs:comment 'Indicates whether the promotion bonus has been awarded to the member (True/False).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Bonus Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the bonus amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusPoints rdf:type rdf:Property ;
    rdfs:label 'Bonus Points' ;
    rdfs:comment 'Number of bonus loyalty points awarded to the member upon promotion completion.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Communication Sent Flag' ;
    rdfs:comment 'Indicates whether enrollment confirmation communication was sent to the member (True/False).' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Communication Sent Timestamp' ;
    rdfs:comment 'Timestamp when the enrollment confirmation communication was sent to the member.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentMethod rdf:type rdf:Property ;
    rdfs:label 'Enrollment Method' ;
    rdfs:comment 'Method by which the enrollment occurred (opt-in by member, auto-enrolled by system, staff-enrolled, imported from external source).' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'Date when the member opted out of the promotion, if applicable.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutReason rdf:type rdf:Property ;
    rdfs:label 'Opt Out Reason' ;
    rdfs:comment 'Reason provided by the member or system for opting out of the promotion.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressPercentage rdf:type rdf:Property ;
    rdfs:label 'Progress Percentage' ;
    rdfs:comment 'Percentage of qualifying activity completed toward the promotion threshold (0.00 to 100.00).' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressValue rdf:type rdf:Property ;
    rdfs:label 'Progress Value' ;
    rdfs:comment 'Current progress value toward the qualifying threshold (e.g., 3 nights completed out of 5 required).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingActivityType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Activity Type' ;
    rdfs:comment 'Type of activity required to complete the promotion (nights stayed, number of stays, revenue spent, points earned, transactions, referrals).' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualifying Threshold' ;
    rdfs:comment 'Target threshold value the member must achieve to complete the promotion (e.g., 5 nights, 1000 points, 500 USD revenue).' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Qualifying Threshold Unit' ;
    rdfs:comment 'Unit of measure for the qualifying threshold (nights, stays, points, currency, transactions, referrals).' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierAtEnrollment rdf:type rdf:Property ;
    rdfs:label 'Tier At Enrollment' ;
    rdfs:comment 'Loyalty tier of the member at the time of enrollment, used for tier-specific promotion eligibility and tracking.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardCatalogId rdf:type rdf:Property ;
    rdfs:label 'Reward Catalog Id' ;
    rdfs:comment 'Foreign key linking to loyalty.reward_catalog. Business justification: Redemptions of type \'reward\' should reference the catalog item being redeemed. Currently redemption has reward_description and reward_category (STRING) but no FK. Adding reward_catalog_id formalizes t' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RewardCatalog .

ind:cashAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Amount' ;
    rdfs:comment 'Cash component paid by the member for cash-and-points redemptions. Zero for pure points redemptions.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Timestamp when the redemption was confirmed and points were deducted from the member account. Nullable if still pending.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'Channel through which the reward was delivered: at property, physical mail, email, partner fulfillment, digital delivery, or in-app delivery.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'Date when the reward was delivered or service was rendered to the member. Nullable if not yet fulfilled.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monetaryEquivalentValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Equivalent Value' ;
    rdfs:comment 'Estimated monetary value of the redeemed reward in the currency specified, used for program economics and LTV (Lifetime Value) analysis.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsRefunded rdf:type rdf:Property ;
    rdfs:label 'Points Refunded' ;
    rdfs:comment 'Number of points returned to the member account due to cancellation or reversal. Zero if no refund occurred.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the redemption transaction, used for guest communication and service recovery.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the redemption: pending approval, confirmed and awaiting fulfillment, fulfilled and completed, cancelled by member or system, expired before fulfillment, or reversed due to service recovery or fraud.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionType rdf:type rdf:Property ;
    rdfs:label 'Redemption Type' ;
    rdfs:comment 'Category of reward being redeemed: free night award, room upgrade, F&B voucher, partner airline/car rental reward, merchandise, curated experience, points transfer to another member, cash plus points combination, or gift certificate. [ENUM-REF-CANDIDATE: free_night|room_upgrade|fnb_voucher|partner_reward|merchandise|experience|points_transfer|cash_and_points|gift_certificate — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Timestamp' ;
    rdfs:comment 'Timestamp when points were refunded to the member account. Nullable if no refund occurred.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the member submitted the redemption request. Business event date for analytics and reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:combinableWithPromotions rdf:type rdf:Property ;
    rdfs:label 'Combinable With Promotions' ;
    rdfs:comment 'Indicates whether this redemption rule can be combined with other promotional offers. False means this rule is exclusive.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligiblePropertyCodes rdf:type rdf:Property ;
    rdfs:label 'Eligible Property Codes' ;
    rdfs:comment 'Comma-separated list of property codes where this redemption rule is applicable. Defines geographic or brand scope.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedPropertyCodes rdf:type rdf:Property ;
    rdfs:label 'Excluded Property Codes' ;
    rdfs:comment 'Comma-separated list of property codes explicitly excluded from this redemption rule. Takes precedence over eligible properties.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lraApplicable rdf:type rdf:Property ;
    rdfs:label 'Lra Applicable' ;
    rdfs:comment 'Indicates whether this redemption rule applies under Last Room Availability conditions. True means members can redeem even when standard inventory is sold out.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumRedemptionPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemption Per Transaction' ;
    rdfs:comment 'Maximum number of points that can be redeemed in a single transaction under this rule. Cap for burn rules.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Minimum Points Balance' ;
    rdfs:comment 'Minimum loyalty points balance required in member account to be eligible for this redemption rule. Applies to burn rules only.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsRate rdf:type rdf:Property ;
    rdfs:label 'Points Rate' ;
    rdfs:comment 'For earn rules: points earned per currency unit spent (e.g., 10 points per USD). For burn rules: points required per unit of benefit (e.g., 25000 points for free night).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Redemption Rule Description' ;
    rdfs:comment 'Detailed business description of the redemption rule including terms, conditions, and member-facing explanation.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Rule Status' ;
    rdfs:comment 'Current lifecycle status of the redemption rule. Only active rules are applied by the points calculation engine.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'Method used to round calculated points values. Ensures consistent points calculation across the loyalty program.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDirection rdf:type rdf:Property ;
    rdfs:label 'Rule Direction' ;
    rdfs:comment 'Indicates whether this rule governs points earning (earn) or points redemption (burn). Core classification for the rule engine.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierMultiplierBase rdf:type rdf:Property ;
    rdfs:label 'Tier Multiplier Base' ;
    rdfs:comment 'Base tier multiplier applied to the points rate for base-tier members. Default is 1.0.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMultiplierGold rdf:type rdf:Property ;
    rdfs:label 'Tier Multiplier Gold' ;
    rdfs:comment 'Tier multiplier applied to the points rate for gold-tier members. Typically 1.5 to 2.0.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMultiplierPlatinum rdf:type rdf:Property ;
    rdfs:label 'Tier Multiplier Platinum' ;
    rdfs:comment 'Tier multiplier applied to the points rate for platinum-tier members. Typically 2.0 to 3.0.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMultiplierSilver rdf:type rdf:Property ;
    rdfs:label 'Tier Multiplier Silver' ;
    rdfs:comment 'Tier multiplier applied to the points rate for silver-tier members. Typically 1.25 to 1.5.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spaTreatmentId rdf:type rdf:Property ;
    rdfs:label 'Spa Treatment Id' ;
    rdfs:comment 'Foreign key linking to spa.treatment. Business justification: Reward catalog includes spa treatments as points redemption options. Required for spa treatment redemption processing, points pricing management, and catalog-driven spa booking integration for loyalty' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Treatment .

ind:supplierVendorId rdf:type rdf:Property ;
    rdfs:label 'Supplier Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Reward catalog items (merchandise, spa products, experience packages, gift items) are sourced from external vendors tracked in procurement. Business process: loyalty teams coordinate with procurement ' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:availabilityType rdf:type rdf:Property ;
    rdfs:label 'Availability Type' ;
    rdfs:comment 'Classification of reward availability pattern determining inventory management and member access rules.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric sequence controlling the presentation order of rewards in catalog listings and member interfaces.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibleTierBase rdf:type rdf:Property ;
    rdfs:label 'Eligible Tier Base' ;
    rdfs:comment 'Indicates whether base tier members are eligible to redeem this reward.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleTierGold rdf:type rdf:Property ;
    rdfs:label 'Eligible Tier Gold' ;
    rdfs:comment 'Indicates whether Gold tier members are eligible to redeem this reward.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleTierPlatinum rdf:type rdf:Property ;
    rdfs:label 'Eligible Tier Platinum' ;
    rdfs:comment 'Indicates whether Platinum tier members are eligible to redeem this reward.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleTierSilver rdf:type rdf:Property ;
    rdfs:label 'Eligible Tier Silver' ;
    rdfs:comment 'Indicates whether Silver tier members are eligible to redeem this reward.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featuredFlag rdf:type rdf:Property ;
    rdfs:label 'Featured Flag' ;
    rdfs:comment 'Indicates whether this reward is featured or promoted in member communications and catalog displays.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL path to the primary marketing image for the reward displayed in digital catalogs and member portals.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryCount rdf:type rdf:Property ;
    rdfs:label 'Inventory Count' ;
    rdfs:comment 'Current available quantity of the reward for redemption. Null indicates unlimited availability for always-on rewards.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryThreshold rdf:type rdf:Property ;
    rdfs:label 'Inventory Threshold' ;
    rdfs:comment 'Minimum inventory level that triggers replenishment alerts or availability status changes for limited inventory rewards.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsCostBase rdf:type rdf:Property ;
    rdfs:label 'Points Cost Base' ;
    rdfs:comment 'Base loyalty points required for redemption by standard tier members. Foundation for tier-based pricing calculations.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsCostGold rdf:type rdf:Property ;
    rdfs:label 'Points Cost Gold' ;
    rdfs:comment 'Loyalty points required for redemption by Gold tier members, reflecting enhanced tier benefits and discounts.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsCostPlatinum rdf:type rdf:Property ;
    rdfs:label 'Points Cost Platinum' ;
    rdfs:comment 'Loyalty points required for redemption by Platinum tier members, offering maximum tier discount benefits.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsCostSilver rdf:type rdf:Property ;
    rdfs:label 'Points Cost Silver' ;
    rdfs:comment 'Loyalty points required for redemption by Silver tier members, typically discounted from base tier pricing.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionValidityDays rdf:type rdf:Property ;
    rdfs:label 'Redemption Validity Days' ;
    rdfs:comment 'Number of days from issuance that a redeemed reward certificate or voucher remains valid for use before expiration.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rewardCategory rdf:type rdf:Property ;
    rdfs:label 'Reward Category' ;
    rdfs:comment 'Primary classification of the reward type determining redemption process and fulfillment workflow. [ENUM-REF-CANDIDATE: hotel_stay|room_upgrade|dining|spa|experience|merchandise|partner|travel — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardCode rdf:type rdf:Property ;
    rdfs:label 'Reward Code' ;
    rdfs:comment 'Unique business identifier code for the reward item used across systems and member communications.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardDescription rdf:type rdf:Property ;
    rdfs:label 'Reward Description' ;
    rdfs:comment 'Detailed description of the reward including benefits, usage instructions, and any special features or limitations.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardName rdf:type rdf:Property ;
    rdfs:label 'Reward Name' ;
    rdfs:comment 'Display name of the reward as presented to loyalty program members in catalogs and redemption interfaces.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardStatus rdf:type rdf:Property ;
    rdfs:label 'Reward Status' ;
    rdfs:comment 'Current lifecycle status of the reward in the catalog determining visibility and redemption availability.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardSubcategory rdf:type rdf:Property ;
    rdfs:label 'Reward Subcategory' ;
    rdfs:comment 'Secondary classification providing granular categorization within the primary reward category for enhanced filtering and reporting.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRedemptions rdf:type rdf:Property ;
    rdfs:label 'Total Redemptions' ;
    rdfs:comment 'Cumulative count of all redemptions of this reward since its introduction, used for popularity analytics and program economics.' ;
    rdfs:domain ind:RewardCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusPointsOnEnrollment rdf:type rdf:Property ;
    rdfs:label 'Bonus Points On Enrollment' ;
    rdfs:comment 'Number of bonus loyalty points awarded to a member upon first achieving this tier status.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakfastBenefitFlag rdf:type rdf:Property ;
    rdfs:label 'Breakfast Benefit Flag' ;
    rdfs:comment 'Indicates whether members at this tier receive complimentary breakfast during their stays.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorCode rdf:type rdf:Property ;
    rdfs:label 'Color Code' ;
    rdfs:comment 'Hexadecimal color code used for visual representation of the tier in digital interfaces and marketing materials (e.g., #C0C0C0 for Silver, #FFD700 for Gold).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Dedicated Support Flag' ;
    rdfs:comment 'Indicates whether members at this tier have access to a dedicated customer service line or concierge team.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downgradeGracePeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Downgrade Grace Period Months' ;
    rdfs:comment 'Number of months of grace period provided before downgrading a member who no longer meets qualification thresholds.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyCheckinHours rdf:type rdf:Property ;
    rdfs:label 'Early Checkin Hours' ;
    rdfs:comment 'Number of hours before standard check-in time that members at this tier are entitled to for early check-in (e.g., 2 for 1pm check-in when standard is 3pm).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guaranteedAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Availability Flag' ;
    rdfs:comment 'Indicates whether members at this tier have guaranteed room availability when booking within specified advance notice periods.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iconUrl rdf:type rdf:Property ;
    rdfs:label 'Icon Url' ;
    rdfs:comment 'URL or path to the icon or badge image representing this tier in digital channels.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateCheckoutHours rdf:type rdf:Property ;
    rdfs:label 'Late Checkout Hours' ;
    rdfs:comment 'Number of hours past standard checkout time that members at this tier are entitled to for late checkout (e.g., 2 for 2pm checkout when standard is 12pm).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loungeAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Flag' ;
    rdfs:comment 'Indicates whether members at this tier have complimentary access to executive lounges or club floors at participating properties.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsEarningMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Earning Multiplier' ;
    rdfs:comment 'Multiplier applied to base points earning for members at this tier (e.g., 1.5 means 50% bonus points, 2.0 means double points).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityReservationFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Reservation Flag' ;
    rdfs:comment 'Indicates whether members at this tier receive priority handling for reservations and waitlist requests.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Qualification Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the qualification spend threshold (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNightsThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Nights Threshold' ;
    rdfs:comment 'Minimum number of qualifying nights required to achieve or maintain this tier status within the qualification period.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Qualification Period Months' ;
    rdfs:comment 'Number of months over which qualification activity is measured (e.g., 12 for annual qualification, 24 for rolling two-year window).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Points Threshold' ;
    rdfs:comment 'Minimum number of loyalty points required to achieve or maintain this tier status within the qualification period.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationSpendThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Spend Threshold' ;
    rdfs:comment 'Minimum monetary spend amount required to achieve or maintain this tier status within the qualification period. Typically measured in the program\'s base currency.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationStaysThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Stays Threshold' ;
    rdfs:comment 'Minimum number of qualifying stays required to achieve or maintain this tier status within the qualification period.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomUpgradeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Room Upgrade Eligible Flag' ;
    rdfs:comment 'Indicates whether members at this tier are eligible for complimentary room upgrades at check-in (subject to availability).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the tier (e.g., SILVER, GOLD, PLATINUM, DIAMOND). Used for system integration and display.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Detailed description of the tier, including benefits summary and value proposition, used for member communications and marketing.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Numeric ranking of the tier within the program hierarchy. Lower numbers indicate entry-level tiers, higher numbers indicate elite status. Used for tier comparison and upgrade logic.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Full display name of the loyalty tier (e.g., Silver Elite, Gold Premier, Platinum Honors, Diamond Ambassador).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the tier. Active tiers are available for member assignment; inactive tiers are temporarily suspended; discontinued tiers are retired but may have legacy members.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityMonths rdf:type rdf:Property ;
    rdfs:label 'Validity Months' ;
    rdfs:comment 'Number of months that tier status remains valid once achieved, before re-qualification is required (e.g., 12 for annual renewal, 24 for two-year validity).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:welcomeAmenityFlag rdf:type rdf:Property ;
    rdfs:label 'Welcome Amenity Flag' ;
    rdfs:comment 'Indicates whether members at this tier receive a welcome amenity (e.g., fruit basket, beverage credit) upon arrival.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierHistoryId rdf:type rdf:Property ;
    rdfs:label 'Tier History Id' ;
    rdfs:comment 'Unique identifier for this tier status change record. Primary key for the tier history entity.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newTierId rdf:type rdf:Property ;
    rdfs:label 'New Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: tier_history has new_tier_code (STRING) but no FK to the tier entity. Adding new_tier_id FK formalizes the link to the tier entity for the new tier, enabling tier-level history analysis and ensuring r' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:bonusPointsAwarded rdf:type rdf:Property ;
    rdfs:label 'Bonus Points Awarded' ;
    rdfs:comment 'Number of bonus loyalty points awarded to the member as a welcome benefit or incentive for achieving this new tier status.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'Business identifier for this tier change event, used for external reference and audit tracking.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the directional nature of this tier change relative to the tier hierarchy.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentTierFlag rdf:type rdf:Property ;
    rdfs:label 'Is Current Tier Flag' ;
    rdfs:comment 'Indicates whether this tier history record represents the members current active tier status (true) or a historical tier status (false).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'The date and time when the tier change notification was sent to the member.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideApprovalCode rdf:type rdf:Property ;
    rdfs:label 'Override Approval Code' ;
    rdfs:comment 'Authorization or approval code for manual tier overrides, used for audit and compliance tracking of non-standard tier grants.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Detailed business justification provided by the approving authority for manual tier status overrides.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTierCode rdf:type rdf:Property ;
    rdfs:label 'Previous Tier Code' ;
    rdfs:comment 'The tier status code the member held immediately before this change (e.g., SILVER, GOLD, PLATINUM).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationBasis rdf:type rdf:Property ;
    rdfs:label 'Qualification Basis' ;
    rdfs:comment 'The primary metric or criteria used to determine eligibility for this tier change (nights, stays, points, spend, or combination thereof). [ENUM-REF-CANDIDATE: qualifying_nights|qualifying_stays|qualifying_points|qualifying_spend|combination|status_match|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingNightsAchieved rdf:type rdf:Property ;
    rdfs:label 'Qualifying Nights Achieved' ;
    rdfs:comment 'Total number of qualifying nights the member accumulated during the qualifying period that contributed to this tier change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Period End Date' ;
    rdfs:comment 'The end date of the measurement period during which qualifying activity was accumulated for this tier change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Period Start Date' ;
    rdfs:comment 'The start date of the measurement period during which qualifying activity was accumulated for this tier change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingPointsAchieved rdf:type rdf:Property ;
    rdfs:label 'Qualifying Points Achieved' ;
    rdfs:comment 'Total number of qualifying loyalty points the member earned during the qualifying period that contributed to this tier change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Amount' ;
    rdfs:comment 'Total monetary spend amount in the program currency that the member accumulated during the qualifying period that contributed to this tier change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingSpendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the qualifying spend amount.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingStaysAchieved rdf:type rdf:Property ;
    rdfs:label 'Qualifying Stays Achieved' ;
    rdfs:comment 'Total number of qualifying stays the member completed during the qualifying period that contributed to this tier change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rolloverNightsGranted rdf:type rdf:Property ;
    rdfs:label 'Rollover Nights Granted' ;
    rdfs:comment 'Number of qualifying nights carried forward or granted as a tier benefit to assist with future requalification.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statusMatchSourceProgram rdf:type rdf:Property ;
    rdfs:label 'Status Match Source Program' ;
    rdfs:comment 'Name of the external loyalty program from which status was matched, if this tier change resulted from a competitive status match offer.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusMatchSourceTier rdf:type rdf:Property ;
    rdfs:label 'Status Match Source Tier' ;
    rdfs:comment 'The tier level held by the member in the external program that was matched to grant this tier status.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdNightsRequired rdf:type rdf:Property ;
    rdfs:label 'Threshold Nights Required' ;
    rdfs:comment 'The minimum number of qualifying nights required to achieve or maintain the new tier status at the time of this change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdPointsRequired rdf:type rdf:Property ;
    rdfs:label 'Threshold Points Required' ;
    rdfs:comment 'The minimum number of qualifying points required to achieve or maintain the new tier status at the time of this change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdSpendRequired rdf:type rdf:Property ;
    rdfs:label 'Threshold Spend Required' ;
    rdfs:comment 'The minimum monetary spend amount required to achieve or maintain the new tier status at the time of this change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdStaysRequired rdf:type rdf:Property ;
    rdfs:label 'Threshold Stays Required' ;
    rdfs:comment 'The minimum number of qualifying stays required to achieve or maintain the new tier status at the time of this change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierExtensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Extension Granted Flag' ;
    rdfs:comment 'Indicates whether an extension of the tier expiry date was granted as part of this change (e.g., due to service recovery, pandemic policy, or loyalty gesture).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Tier Extension Months' ;
    rdfs:comment 'Number of months by which the tier expiry date was extended beyond the standard qualification period.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeredBySystem rdf:type rdf:Property ;
    rdfs:label 'Triggered By System' ;
    rdfs:comment 'Name or identifier of the system that initiated or triggered this tier change (e.g., Salesforce CRM, batch requalification job, manual override interface).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionEventId rdf:type rdf:Property ;
    rdfs:label 'Attribution Event Id' ;
    rdfs:comment 'Unique identifier for the marketing attribution event record.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttributionEvent .

ind:adPlatform rdf:type rdf:Property ;
    rdfs:label 'Ad Platform' ;
    rdfs:comment 'The advertising platform or network that served the ad or content for this touchpoint (e.g., Google Ads, Facebook Ads, Bing Ads, programmatic exchange).' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionCredit rdf:type rdf:Property ;
    rdfs:label 'Attribution Credit' ;
    rdfs:comment 'The fractional credit assigned to this touchpoint event under the selected attribution model. Values range from 0.0000 to 1.0000, where 1.0000 represents full credit.' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'The attribution model applied to this event for credit allocation (e.g., last-click, first-click, linear, time-decay, position-based multi-touch attribution).' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browser rdf:type rdf:Property ;
    rdfs:label 'Browser' ;
    rdfs:comment 'The web browser used by the guest during this touchpoint event (e.g., Chrome, Safari, Firefox, Edge).' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The marketing channel through which the guest interacted with the brand (e.g., paid search, organic search, display advertising, social media, email, direct, referral). [ENUM-REF-CANDIDATE: paid_search|organic_search|display|social_media|email|direct|referral — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Flag' ;
    rdfs:comment 'Boolean indicator of whether this touchpoint event resulted in a conversion (booking, reservation, or other defined conversion action).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionValue rdf:type rdf:Property ;
    rdfs:label 'Conversion Value' ;
    rdfs:comment 'The monetary value of the conversion attributed to this touchpoint event, if a conversion occurred. Used for ROI (Return on Investment) calculation.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cookieCode rdf:type rdf:Property ;
    rdfs:label 'Cookie Code' ;
    rdfs:comment 'Browser cookie identifier used to track anonymous guest behavior across sessions before guest identification.' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'Unique identifier for the device (mobile, tablet, desktop) used by the guest during this touchpoint interaction.' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'The source system or platform that captured and reported this attribution event (e.g., Salesforce CRM, Google Analytics, Adobe Analytics, booking engine).' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time when the guest touchpoint interaction occurred, in ISO 8601 format.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geoCity rdf:type rdf:Property ;
    rdfs:label 'Geo City' ;
    rdfs:comment 'The city derived from the IP address, providing granular geographic attribution for campaign performance analysis.' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'Three-letter ISO country code derived from the IP address, indicating the guest\'s geographic location at the time of the event.' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRegion rdf:type rdf:Property ;
    rdfs:label 'Geo Region' ;
    rdfs:comment 'The state, province, or region derived from the IP address, providing sub-country geographic attribution.' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyword rdf:type rdf:Property ;
    rdfs:label 'Keyword' ;
    rdfs:comment 'The search keyword or phrase that triggered this touchpoint event in paid or organic search campaigns.' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'The full URL of the landing page where the guest arrived during this touchpoint event.' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'The operating system of the guest device during this touchpoint event (e.g., Windows, macOS, iOS, Android).' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'The full URL of the referring page that directed the guest to this touchpoint. Used for attribution analysis when UTM parameters are not present.' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionCode rdf:type rdf:Property ;
    rdfs:label 'Session Code' ;
    rdfs:comment 'Unique identifier for the web or mobile session during which this attribution event occurred. Used to group touchpoints within a single browsing session.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToConversionHours rdf:type rdf:Property ;
    rdfs:label 'Time To Conversion Hours' ;
    rdfs:comment 'The number of hours elapsed between this touchpoint event and the eventual conversion, if a conversion occurred. Used for conversion lag analysis.' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:touchpointSequence rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Sequence' ;
    rdfs:comment 'The ordinal position of this touchpoint within the guest\'s attribution path (1 for first touch, incrementing for each subsequent touchpoint).' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:touchpointType rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Type' ;
    rdfs:comment 'The type of marketing touchpoint interaction captured in this event (e.g., ad impression, click, landing page visit, booking engine entry, offer redemption, email open).' ;
    rdfs:domain ind:AttributionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'The UTM campaign parameter identifying the specific marketing campaign name or code. Part of the standard UTM tracking taxonomy.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmContent rdf:type rdf:Property ;
    rdfs:label 'Utm Content' ;
    rdfs:comment 'The UTM content parameter used to differentiate similar content or links within the same campaign (e.g., A/B test variants). Part of the standard UTM tracking taxonomy.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'The UTM medium parameter identifying the marketing medium (e.g., cpc, email, banner, social). Part of the standard UTM tracking taxonomy.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'The UTM source parameter identifying the traffic source (e.g., google, facebook, newsletter). Part of the standard UTM tracking taxonomy.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmTerm rdf:type rdf:Property ;
    rdfs:label 'Utm Term' ;
    rdfs:comment 'The UTM term parameter identifying paid search keywords or targeting criteria. Part of the standard UTM tracking taxonomy.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Primary key for brand' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:averageDailyRateTarget rdf:type rdf:Property ;
    rdfs:label 'Average Daily Rate Target' ;
    rdfs:comment 'Target average daily rate for properties under this brand. Used for revenue management strategy and brand positioning in competitive set analysis.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Comprehensive narrative description of the brand identity, positioning, value proposition, and target guest experience. Used for marketing content and brand communications.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current operational status of the brand in the portfolio. Determines whether the brand is actively marketed and accepting new property affiliations.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicFocus rdf:type rdf:Property ;
    rdfs:label 'Geographic Focus' ;
    rdfs:comment 'Primary geographic markets or regions where the brand operates or targets expansion (e.g., North America, Europe, Asia-Pacific, Global). Informs regional marketing strategies.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestSatisfactionScoreTarget rdf:type rdf:Property ;
    rdfs:label 'Guest Satisfaction Score Target' ;
    rdfs:comment 'Target guest satisfaction score for the brand measured through post-stay surveys. Key performance indicator for brand experience quality.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guidelinesUrl rdf:type rdf:Property ;
    rdfs:label 'Guidelines Url' ;
    rdfs:comment 'URL reference to the comprehensive brand guidelines document containing visual identity standards, usage rules, and creative specifications.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFeaturedBrand rdf:type rdf:Property ;
    rdfs:label 'Is Featured Brand' ;
    rdfs:comment 'Indicates whether this brand is currently featured in primary marketing campaigns and promotional activities. Used to prioritize marketing resource allocation.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date when the brand was officially launched in the market. Used for brand anniversary campaigns and historical reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logoUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Url' ;
    rdfs:comment 'URL reference to the official brand logo asset stored in the digital asset management system. Used for marketing campaigns and content distribution.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramName rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Name' ;
    rdfs:comment 'Name of the loyalty or rewards program associated with the brand. Used in marketing campaigns promoting member benefits and enrollment.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingBudgetAnnual rdf:type rdf:Property ;
    rdfs:label 'Marketing Budget Annual' ;
    rdfs:comment 'Total annual marketing budget allocated to the brand for campaigns, advertising, content creation, and promotional activities. Used for marketing ROI analysis.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPromoterScoreTarget rdf:type rdf:Property ;
    rdfs:label 'Net Promoter Score Target' ;
    rdfs:comment 'Target net promoter score for the brand indicating guest loyalty and likelihood to recommend. Critical metric for brand health and marketing effectiveness.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCompany rdf:type rdf:Property ;
    rdfs:label 'Parent Company' ;
    rdfs:comment 'Name of the parent hospitality company or holding entity that owns and operates the brand. Used for corporate reporting and brand portfolio management.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positioningStatement rdf:type rdf:Property ;
    rdfs:label 'Positioning Statement' ;
    rdfs:comment 'Strategic statement defining how the brand differentiates itself in the market and the unique value it delivers to target guests. Foundation for all marketing messaging.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Primary Color Hex' ;
    rdfs:comment 'Primary brand color in hexadecimal format used in digital marketing assets, website design, and visual identity materials.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyCount rdf:type rdf:Property ;
    rdfs:label 'Property Count' ;
    rdfs:comment 'Total number of hotel and resort properties operating under this brand globally. Key metric for brand scale and market presence.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Secondary Color Hex' ;
    rdfs:comment 'Secondary brand color in hexadecimal format used as accent color in marketing materials and digital assets.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandleFacebook rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle Facebook' ;
    rdfs:comment 'Official Facebook page handle or username for the brand. Used for social media marketing campaigns and guest engagement tracking.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandleInstagram rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle Instagram' ;
    rdfs:comment 'Official Instagram account handle or username for the brand. Used for visual content marketing and influencer partnership campaigns.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandleLinkedin rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle Linkedin' ;
    rdfs:comment 'Official LinkedIn company page handle for the brand. Used for corporate communications, talent acquisition marketing, and B2B engagement.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandleTwitter rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle Twitter' ;
    rdfs:comment 'Official Twitter account handle or username for the brand. Used for real-time guest service, announcements, and brand conversations.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagline rdf:type rdf:Property ;
    rdfs:label 'Tagline' ;
    rdfs:comment 'Official marketing tagline or slogan associated with the brand used in advertising campaigns and promotional materials.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voice rdf:type rdf:Property ;
    rdfs:label 'Voice' ;
    rdfs:comment 'Defined tone and style of communication for the brand (e.g., sophisticated and refined, warm and welcoming, modern and energetic). Guides content creation across all marketing channels.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Primary website URL for the brand where guests can explore properties, make reservations, and access brand information.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementContractId rdf:type rdf:Property ;
    rdfs:label 'Procurement Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.procurement_contract. Business justification: Marketing campaigns operate under master service agreements or annual contracts with agencies, media vendors, platforms. Linking campaign to contract enables contract compliance verification, spend tr' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementContract .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Total amount actually spent on this campaign to date, including all invoiced and paid expenses.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandScope rdf:type rdf:Property ;
    rdfs:label 'Brand Scope' ;
    rdfs:comment 'The brand or brand portfolio this campaign is associated with (e.g., luxury, premium, select-service brand names).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPeriod rdf:type rdf:Property ;
    rdfs:label 'Budget Period' ;
    rdfs:comment 'The time period over which the campaign budget is allocated and managed (monthly, quarterly, annual, or campaign lifetime).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'Variance between planned budget and actual spend, calculated as total budget minus actual spend. Positive indicates under-budget, negative indicates over-budget.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed description of the campaign objectives, messaging, creative approach, and expected outcomes.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'The business name of the marketing campaign as recognized by marketing teams and stakeholders.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign indicating its operational state.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'The channel or medium through which the campaign is executed (e.g., email, paid search, social media, OTA co-op, direct mail). [ENUM-REF-CANDIDATE: email|paid_search|social|ota_coop|direct_mail|display|affiliate|content|influencer — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Spend Amount' ;
    rdfs:comment 'Total amount committed for this campaign through purchase orders and contracts that have not yet been invoiced or paid.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Crm Campaign Code' ;
    rdfs:comment 'The campaign identifier in Salesforce CRM used for tracking guest interactions and attribution.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Display Budget Amount' ;
    rdfs:comment 'Budget allocated specifically for display advertising (banner ads, programmatic) within this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emailBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Email Budget Amount' ;
    rdfs:comment 'Budget allocated specifically for email marketing activities within this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'The primary business goal of the campaign: guest acquisition, retention, upsell, reactivation, brand awareness, or engagement.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otherChannelBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Other Channel Budget Amount' ;
    rdfs:comment 'Budget allocated for other marketing channels not covered by specific channel budget fields.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidSearchBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Search Budget Amount' ;
    rdfs:comment 'Budget allocated specifically for paid search (SEM/PPC) activities within this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget Amount' ;
    rdfs:comment 'Budget remaining for this campaign, calculated as total budget minus actual spend and committed spend.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Social Budget Amount' ;
    rdfs:comment 'Budget allocated specifically for social media advertising and promotion within this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'Total budget allocated for this campaign across all channels and activities. Expressed in USD.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionTouchpointId rdf:type rdf:Property ;
    rdfs:label 'Execution Touchpoint Id' ;
    rdfs:comment 'Foreign key linking to experience.touchpoint. Business justification: Campaign executions are deployed at specific touchpoints in the guest journey (e.g., post-checkout email, in-room tablet message). Tracks which touchpoint triggered the marketing action, enabling touc' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Touchpoint .

ind:attributionModelType rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Type' ;
    rdfs:comment 'The attribution methodology used to assign conversion credit to this execution. Determines how revenue and conversions are attributed across the customer journey.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSize rdf:type rdf:Property ;
    rdfs:label 'Audience Size' ;
    rdfs:comment 'Total number of guests or contacts in the target audience segment for this execution. Represents the potential reach.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bounceCount rdf:type rdf:Property ;
    rdfs:label 'Bounce Count' ;
    rdfs:comment 'Number of messages that failed to deliver due to invalid addresses, full mailboxes, or other delivery issues.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelCostModel rdf:type rdf:Property ;
    rdfs:label 'Channel Cost Model' ;
    rdfs:comment 'Pricing model used for this channel execution. CPC (Cost Per Click), CPM (Cost Per Mille/Thousand Impressions), CPA (Cost Per Acquisition), flat fee, or revenue share arrangement.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionCount rdf:type rdf:Property ;
    rdfs:label 'Conversion Count' ;
    rdfs:comment 'Number of conversions or desired actions completed as a result of this execution. Examples: bookings made, loyalty enrollments, event registrations.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creativeVersion rdf:type rdf:Property ;
    rdfs:label 'Creative Version' ;
    rdfs:comment 'Version identifier for the creative assets used in this execution. Enables A/B testing and creative performance analysis.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Count' ;
    rdfs:comment 'Number of messages successfully delivered to recipients. Excludes bounces and delivery failures.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionCost rdf:type rdf:Property ;
    rdfs:label 'Execution Cost' ;
    rdfs:comment 'Total cost incurred for this specific execution instance. Includes media spend, agency fees, content production, and technology costs.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionName rdf:type rdf:Property ;
    rdfs:label 'Execution Name' ;
    rdfs:comment 'Descriptive name for this execution instance. Typically includes campaign name, channel, and wave identifier for easy recognition by marketing teams.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionNumber rdf:type rdf:Property ;
    rdfs:label 'Execution Number' ;
    rdfs:comment 'Business-readable identifier for this execution instance. Used for operational tracking and reporting. Example: CAMP-2024-Q1-EMAIL-001.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle status of this campaign execution. Tracks progression from planning through completion or failure.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'Date and time when this campaign execution was deployed or sent. The principal business event timestamp representing when the campaign reached the audience.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:invoiceReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference' ;
    rdfs:comment 'Reference number of the vendor invoice associated with this execution cost. Links to accounts payable for reconciliation.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lookbackWindowDays rdf:type rdf:Property ;
    rdfs:label 'Lookback Window Days' ;
    rdfs:comment 'Number of days after execution during which conversions are attributed to this campaign. Defines the attribution time window.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openCount rdf:type rdf:Property ;
    rdfs:label 'Open Count' ;
    rdfs:comment 'Number of unique opens or views of the campaign content. Applicable to email, push notifications, and display channels.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueAttributed rdf:type rdf:Property ;
    rdfs:label 'Revenue Attributed' ;
    rdfs:comment 'Total revenue attributed to this campaign execution based on the attribution model. Represents the financial impact of this execution.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapCostDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Sap Cost Document Reference' ;
    rdfs:comment 'Reference to the SAP S/4HANA cost accounting document that records this execution expense. Used for financial reconciliation and USALI reporting.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Timestamp' ;
    rdfs:comment 'Date and time when this execution was originally scheduled to deploy. May differ from actual execution timestamp if delays occurred.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sendCount rdf:type rdf:Property ;
    rdfs:label 'Send Count' ;
    rdfs:comment 'Total number of messages or impressions sent or served in this execution. Represents actual deployment volume.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spendCategory rdf:type rdf:Property ;
    rdfs:label 'Spend Category' ;
    rdfs:comment 'Classification of the execution spend by type. Used for budget allocation tracking and financial reporting per USALI standards.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'Email subject line or message headline used in this execution. Applicable to email and push notification channels.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingCapability rdf:type rdf:Property ;
    rdfs:label 'Tracking Capability' ;
    rdfs:comment 'Level of tracking and attribution capability available for this execution. Full tracking includes all metrics, partial tracking has limited visibility, none indicates no tracking available.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationPolicyId rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy Id' ;
    rdfs:comment 'Foreign key linking to reservation.cancellation_policy. Business justification: Promotional offers frequently specify or override cancellation policies (e.g., non-refundable flash sales, flexible cancellation promotions). Marketing teams must define which cancellation terms apply' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CancellationPolicy .

ind:bonusPointsFlat rdf:type rdf:Property ;
    rdfs:label 'Bonus Points Flat' ;
    rdfs:comment 'Flat number of bonus loyalty points awarded upon qualifying activity completion. Used for fixed-point promotional offers. Null for non-points-based offers.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelRestrictions rdf:type rdf:Property ;
    rdfs:label 'Channel Restrictions' ;
    rdfs:comment 'Comma-separated list of booking channels where this offer is valid (e.g., \'direct_web,mobile_app,call_center\'). Null or \'ALL\' indicates offer is available across all channels.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinableWithOtherOffersFlag rdf:type rdf:Property ;
    rdfs:label 'Combinable With Other Offers Flag' ;
    rdfs:comment 'Indicates whether this offer can be combined with other promotional offers in a single reservation. True allows stacking. False requires exclusive use.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'Numeric value of the discount. For percentage discounts, this is the percentage (e.g., 15.00 for 15%). For fixed amount discounts, this is the currency amount. For BAR override, this is the override rate amount.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligiblePropertyScope rdf:type rdf:Property ;
    rdfs:label 'Eligible Property Scope' ;
    rdfs:comment 'Defines the geographic or organizational scope of properties where this offer is valid. All properties indicates portfolio-wide. Brand specific limits to specific brand(s). Region specific limits to geographic region(s). Property list indicates specific property codes are defined.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleTierLevels rdf:type rdf:Property ;
    rdfs:label 'Eligible Tier Levels' ;
    rdfs:comment 'Comma-separated list of loyalty tier levels eligible for this offer (e.g., \'Silver,Gold,Platinum\'). Null or \'ALL\' indicates offer is available to all tiers including non-members.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Enrollment Required Flag' ;
    rdfs:comment 'Indicates whether guest must explicitly enroll or opt-in to this offer before redemption. True requires enrollment. False allows immediate redemption with offer code.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberExclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Member Exclusive Flag' ;
    rdfs:comment 'Indicates whether this offer is exclusively available to loyalty program members. True restricts to members only. False allows non-member access.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumSpendCurrency rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the minimum spend amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Unique alphanumeric code used by guests to redeem this promotional offer. This is the externally-known identifier used in booking channels, CRS, and PMS systems.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Detailed description of the promotional offer including terms, conditions, and guest benefits.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Marketing name of the offer displayed to guests and used in promotional materials.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle status of the promotional offer. Draft indicates offer is being configured. Active indicates offer is live and bookable. Paused indicates temporary suspension. Expired indicates validity period has ended. Cancelled indicates offer was terminated before expiration.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Classification of the promotional offer mechanism. Percentage discount applies a percentage reduction to BAR. Flat discount applies a fixed currency amount reduction. Free night provides complimentary accommodation. Room upgrade provides category enhancement. F&B credit provides food and beverage spending credit. Bonus points provides additional loyalty points. Tier accelerator provides multiplied tier qualifying activity. Partner earn provides bonus points from partner programs. Member rate provides loyalty member exclusive pricing. Birthday offer provides member birthday recognition benefit. Package deal bundles multiple benefits. [ENUM-REF-CANDIDATE: percentage_discount|flat_discount|free_night|room_upgrade|fnb_credit|bonus_points|tier_accelerator|partner_earn|member_rate|birthday_offer|package_deal — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Current count of how many times this offer has been redeemed. Incremented with each qualifying reservation or transaction.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionLimitPerGuest rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Guest' ;
    rdfs:comment 'Maximum number of times a single guest can redeem this offer. Null indicates unlimited redemptions per guest.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionLimitTotal rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Total' ;
    rdfs:comment 'Maximum total number of redemptions allowed across all guests for this offer. Used to cap offer exposure. Null indicates unlimited total redemptions.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierCreditMultiplier rdf:type rdf:Property ;
    rdfs:label 'Tier Credit Multiplier' ;
    rdfs:comment 'Multiplier applied to tier qualifying credits for tier accelerator campaigns. For example, 2.00 represents double tier credits. Null for non-tier-accelerator offers.' ;
    rdfs:domain ind:CampaignOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentId rdf:type rdf:Property ;
    rdfs:label 'Consent Id' ;
    rdfs:comment 'Primary key for consent' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationFrequencyPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Frequency Preference' ;
    rdfs:comment 'The guest preferred frequency for receiving marketing communications. Allows guests to control volume of messages even when opted in.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Description of the scope of data usage covered by this consent. Specifies what data will be used and for what marketing purposes. Free-text field for transparency.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingAgreementAccepted rdf:type rdf:Property ;
    rdfs:label 'Data Processing Agreement Accepted' ;
    rdfs:comment 'Indicates whether the guest has accepted the data processing agreement or privacy policy associated with this consent. Required for GDPR compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Indicates whether the guest confirmed their consent through a double opt-in process (e.g., clicking a confirmation link in an email). True if confirmed, false if single opt-in only. Best practice for email marketing compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInDate rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Date' ;
    rdfs:comment 'The date and time when the guest confirmed their consent via double opt-in process. Null if double opt-in was not used or not yet confirmed.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'The language in which the consent was presented to and acknowledged by the guest. Uses ISO 639-3 language codes. Required for GDPR compliance to demonstrate informed consent. [ENUM-REF-CANDIDATE: eng|spa|fra|deu|jpn|zho|ita|por|rus|ara|kor|nld|swe|dan|nor — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCommunicationDate rdf:type rdf:Property ;
    rdfs:label 'Last Communication Date' ;
    rdfs:comment 'The date of the most recent marketing communication sent to the guest under this consent. Used to track engagement and enforce quiet periods.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minorConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Minor Consent Required' ;
    rdfs:comment 'Indicates whether parental or guardian consent is required for this guest due to age restrictions under COPPA or GDPR. True if guest is a minor and special consent rules apply.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified' ;
    rdfs:comment 'Indicates whether parental or guardian consent has been verified for a minor guest. True if verified, false if not yet verified or not applicable.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceCenterUrl rdf:type rdf:Property ;
    rdfs:label 'Preference Center Url' ;
    rdfs:comment 'The URL of the preference center or web form where the guest can update their consent preferences. Supports self-service consent management.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Document Url' ;
    rdfs:comment 'URL or storage path to the archived proof of consent (e.g., screenshot of form submission, signed document, recorded call). Required for regulatory audits.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceConsentCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Consent Code' ;
    rdfs:comment 'The unique identifier of the corresponding consent record in Salesforce CRM. Enables bi-directional synchronization between lakehouse and operational CRM system.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyProcessorName rdf:type rdf:Property ;
    rdfs:label 'Third Party Processor Name' ;
    rdfs:comment 'Name of the third-party data processor or marketing platform that will process guest data under this consent (e.g., email service provider, SMS gateway). Required for GDPR transparency.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:altText rdf:type rdf:Property ;
    rdfs:label 'Alt Text' ;
    rdfs:comment 'Alternative text description of the content asset for accessibility compliance (screen readers) and Search Engine Optimization (SEO).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Externally-known unique code or SKU assigned to the content asset for cataloging and reference across marketing campaigns and brand materials.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the content asset by format and medium (e.g., image, video, banner ad, brochure, landing page copy, social media post, email template, infographic, presentation, in-property collateral). [ENUM-REF-CANDIDATE: image|video|banner_ad|brochure|landing_page|social_media_post|email_template|infographic|presentation|collateral — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Content Asset Description' ;
    rdfs:comment 'Detailed textual description of the content asset, including its purpose, visual elements, messaging, and intended use cases.' ;
    rdfs:domain ind:ContentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentTheme rdf:type rdf:Property ;
    rdfs:label 'Content Theme' ;
    rdfs:comment 'Thematic category or focus of the content asset (e.g., seasonal promotion, loyalty program, Food and Beverage (F&B), Meetings Incentives Conferences Exhibitions (MICE), destination marketing, wellness, family, business travel, romance, adventure). [ENUM-REF-CANDIDATE: seasonal|loyalty|fnb|mice|destination|wellness|family|business_travel|romance|adventure — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightHolder rdf:type rdf:Property ;
    rdfs:label 'Copyright Holder' ;
    rdfs:comment 'Name of the individual or organization that holds the copyright or intellectual property rights to the content asset.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creatorName rdf:type rdf:Property ;
    rdfs:label 'Creator Name' ;
    rdfs:comment 'Name of the individual, agency, or vendor who created or produced the content asset.' ;
    rdfs:domain ind:ContentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadCount rdf:type rdf:Property ;
    rdfs:label 'Download Count' ;
    rdfs:comment 'Number of times the content asset has been downloaded from the DAM system by marketing users or external partners.' ;
    rdfs:domain ind:ContentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Technical file format of the content asset (e.g., JPG, PNG, MP4, PDF, HTML, PSD, AI, DOCX, PPTX). [ENUM-REF-CANDIDATE: jpg|png|gif|svg|mp4|mov|pdf|html|psd|ai|docx|pptx — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the content asset file in kilobytes, used for storage management and performance optimization.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fileUrl rdf:type rdf:Property ;
    rdfs:label 'File Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) or storage path where the content asset file is hosted or stored (e.g., cloud storage bucket, CDN endpoint, internal DAM repository).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags associated with the content asset for search, discovery, and SEO optimization within the DAM system and marketing platforms.' ;
    rdfs:domain ind:ContentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localeCode rdf:type rdf:Property ;
    rdfs:label 'Locale Code' ;
    rdfs:comment 'Locale code combining language and region (e.g., en_US, en_GB, es_MX) for localized content targeting.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishEndDate rdf:type rdf:Property ;
    rdfs:label 'Publish End Date' ;
    rdfs:comment 'Date when the content asset should no longer be published or used in marketing channels, typically for time-sensitive or seasonal campaigns.' ;
    rdfs:domain ind:ContentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publishStartDate rdf:type rdf:Property ;
    rdfs:label 'Publish Start Date' ;
    rdfs:comment 'Date when the content asset becomes available for publication and use in marketing channels.' ;
    rdfs:domain ind:ContentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended audience or guest segment for this content asset (e.g., loyalty members, business travelers, families, millennials, luxury guests).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL or path to a thumbnail preview image of the content asset for quick visual identification in the DAM system.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Expiry Date' ;
    rdfs:comment 'Date when the usage rights or license for the content asset expire, after which the asset may no longer be legally used.' ;
    rdfs:domain ind:ContentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageRightsType rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Type' ;
    rdfs:comment 'Type of usage rights or licensing model for the content asset (e.g., owned, licensed, royalty-free, rights-managed, Creative Commons, public domain).' ;
    rdfs:domain ind:ContentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Experiment Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved the experiment design and launch. Typically a marketing manager or director with authority to allocate resources and traffic.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:experimentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Experiment Employee Id' ;
    rdfs:comment 'Reference to the marketing team member responsible for designing, executing, and analyzing this experiment. Accountable for experiment outcomes and learnings.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:experimentModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Experiment Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the experiment record. Supports accountability and audit trail for experiment changes.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDurationDays rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Days' ;
    rdfs:comment 'The actual number of days the experiment ran from start to end. May differ from planned duration due to early stopping or extension for statistical significance.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conclusionNotes rdf:type rdf:Property ;
    rdfs:label 'Conclusion Notes' ;
    rdfs:comment 'Detailed notes documenting the experiment results, key learnings, business implications, and recommendations for future tests or implementation. Critical for organizational learning and knowledge management.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevelPercentage rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percentage' ;
    rdfs:comment 'The confidence level required for declaring a winner, typically 95% or 99%. Represents the probability that the observed difference is not due to random chance.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Control Allocation Percentage' ;
    rdfs:comment 'Percentage of experiment traffic allocated to the control variant. Typically 50% for A/B tests but may vary for multivariate or risk-averse tests.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlVariantDescription rdf:type rdf:Property ;
    rdfs:label 'Control Variant Description' ;
    rdfs:comment 'Detailed description of the control variant (baseline) used as the comparison benchmark in the experiment. Represents the current or default experience.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Impact Amount' ;
    rdfs:comment 'The projected annual revenue or cost impact of implementing the winning variant at scale. Calculated by extrapolating lift percentage across full traffic volume and annualizing.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:experimentCode rdf:type rdf:Property ;
    rdfs:label 'Experiment Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the experiment in operational systems and reporting dashboards. Must be unique and human-readable.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentName rdf:type rdf:Property ;
    rdfs:label 'Experiment Name' ;
    rdfs:comment 'Descriptive name of the experiment that clearly communicates the test objective to stakeholders and marketing teams.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentStatus rdf:type rdf:Property ;
    rdfs:label 'Experiment Status' ;
    rdfs:comment 'Current lifecycle status of the experiment. Draft indicates planning phase, approved indicates ready to launch, running indicates active test, paused indicates temporary suspension, concluded indicates completed with results, archived indicates historical record, cancelled indicates terminated without completion. [ENUM-REF-CANDIDATE: draft|approved|running|paused|concluded|archived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentType rdf:type rdf:Property ;
    rdfs:label 'Experiment Type' ;
    rdfs:comment 'Classification of the experiment methodology. A/B tests compare two variants, multivariate tests multiple variables simultaneously, holdout tests control vs treatment groups, sequential tests run variants in sequence, and split tests divide traffic across variants.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypothesis rdf:type rdf:Property ;
    rdfs:label 'Hypothesis' ;
    rdfs:comment 'The testable hypothesis statement that defines the expected outcome of the experiment. Captures the business assumption being validated through the test.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated annual impact amount. Typically USD for global reporting but may vary by property or region.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'The date when the winning variant was implemented as the standard experience. Used to track time-to-value from experiment conclusion to full rollout.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationFlag rdf:type rdf:Property ;
    rdfs:label 'Implementation Flag' ;
    rdfs:comment 'Indicates whether the winning variant has been implemented as the new standard experience. True means the test results have been rolled out to 100% of traffic.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liftPercentage rdf:type rdf:Property ;
    rdfs:label 'Lift Percentage' ;
    rdfs:comment 'The percentage improvement of the winning variant over the control on the primary metric. Positive values indicate treatment outperformed control; negative values indicate control outperformed treatment.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pValue rdf:type rdf:Property ;
    rdfs:label 'P Value' ;
    rdfs:comment 'The probability that the observed difference between variants occurred by chance. Values below the significance threshold indicate statistically significant results.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Days' ;
    rdfs:comment 'The planned duration of the experiment in days, based on sample size calculations and business requirements. Used for resource planning and timeline management.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Metric' ;
    rdfs:comment 'The primary success metric used to evaluate experiment performance, such as conversion rate, click-through rate, booking rate, revenue per visitor, or guest satisfaction score.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeActual rdf:type rdf:Property ;
    rdfs:label 'Sample Size Actual' ;
    rdfs:comment 'The actual number of observations collected during the experiment. Used to assess whether sufficient data has been gathered for valid statistical inference.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Sample Size Target' ;
    rdfs:comment 'The target number of observations required to achieve statistical significance based on power analysis. Calculated using expected effect size, significance level, and statistical power.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryMetrics rdf:type rdf:Property ;
    rdfs:label 'Secondary Metrics' ;
    rdfs:comment 'Additional metrics tracked to understand broader impact of the experiment. May include engagement metrics, downstream conversion, average daily rate (ADR), or net promoter score (NPS). Stored as comma-separated list.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalSignificanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance Threshold' ;
    rdfs:comment 'The p-value threshold required to declare a statistically significant result. Industry standard is typically 0.05 (95% confidence) or 0.01 (99% confidence).' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testVariable rdf:type rdf:Property ;
    rdfs:label 'Test Variable' ;
    rdfs:comment 'The specific element being tested in the experiment, such as email subject line, landing page layout, offer amount, creative imagery, call-to-action text, or pricing structure.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Traffic Allocation Percentage' ;
    rdfs:comment 'Percentage of total traffic allocated to this experiment. Typically ranges from 10% to 100% depending on risk tolerance and sample size requirements.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Treatment Allocation Percentage' ;
    rdfs:comment 'Percentage of experiment traffic allocated to treatment variant(s). Sum of control and treatment allocations should equal 100% of experiment traffic.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentVariantDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Variant Description' ;
    rdfs:comment 'Detailed description of the treatment variant(s) being tested against the control. May include multiple variants separated by delimiters for multivariate tests.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winningVariant rdf:type rdf:Property ;
    rdfs:label 'Winning Variant' ;
    rdfs:comment 'The variant that achieved statistically significant superior performance on the primary metric. Set to inconclusive if no significant difference was found, or ongoing if experiment is still running.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationId rdf:type rdf:Property ;
    rdfs:label 'Cancellation Id' ;
    rdfs:comment 'Foreign key linking to reservation.cancellation. Business justification: Service recovery and win-back communications are triggered by cancellations. Marketing tracks cancellation-specific outreach for sentiment analysis, re-booking campaigns, and loyalty retention. Essent' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cancellation .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Identifier of the communication template used for this message. Links to the template library for reusable content governance.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunicationTemplate .

ind:bodyContent rdf:type rdf:Property ;
    rdfs:label 'Body Content' ;
    rdfs:comment 'The full text or HTML content of the communication message. Contains the complete message body including personalized merge fields and dynamic content.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bouncedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Bounced Timestamp' ;
    rdfs:comment 'The date and time when the communication bounced or failed delivery. Null if successfully delivered.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clicked Timestamp' ;
    rdfs:comment 'The date and time when the guest first clicked a link within the communication. Null if no clicks occurred or tracking not available.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:communicationType rdf:type rdf:Property ;
    rdfs:label 'Communication Type' ;
    rdfs:comment 'Classification of the communication content type. Promotional includes offers and campaigns; transactional includes booking confirmations and receipts; loyalty includes program updates; survey includes NPS and GSS feedback requests; event includes meeting and conference invitations; service recovery includes apology and compensation messages.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'The date and time when the guest completed the conversion action attributed to this communication. Null if no conversion occurred.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmActivityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Activity Code' ;
    rdfs:comment 'The unique activity or task identifier in Salesforce CRM that corresponds to this communication. Used for cross-system reconciliation and guest interaction history.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'The date and time when the communication was successfully delivered to the recipient\'s mail server or device. Null if delivery failed or is pending.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optInStatus rdf:type rdf:Property ;
    rdfs:label 'Opt In Status' ;
    rdfs:comment 'The guest\'s consent status for receiving this type of communication at the time of send. Opted_in indicates explicit consent; opted_out indicates withdrawal of consent; pending indicates consent requested but not confirmed; not_applicable for transactional communications that do not require opt-in.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationFields rdf:type rdf:Property ;
    rdfs:label 'Personalization Fields' ;
    rdfs:comment 'JSON or delimited string containing the dynamic merge fields and their values used to personalize this communication. Examples: guest name, loyalty tier, reservation dates, property name.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'The email address to which the communication was sent. Captured at send time to preserve historical accuracy even if the guest\'s current email changes.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPhone rdf:type rdf:Property ;
    rdfs:label 'Recipient Phone' ;
    rdfs:comment 'The phone number to which the communication was sent, applicable for SMS and WhatsApp channels. Captured at send time to preserve historical accuracy.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replyToEmail rdf:type rdf:Property ;
    rdfs:label 'Reply To Email' ;
    rdfs:comment 'The email address to which guest replies should be directed. May differ from sender email to route responses to appropriate teams.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendPriority rdf:type rdf:Property ;
    rdfs:label 'Send Priority' ;
    rdfs:comment 'The priority level assigned to this communication for send queue processing. High priority for time-sensitive transactional messages; normal for standard campaigns; low for bulk promotional sends.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderEmail rdf:type rdf:Property ;
    rdfs:label 'Sender Email' ;
    rdfs:comment 'The email address from which the communication was sent. Used for reply-to and sender identification. Must comply with CAN-SPAM sender requirements.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderName rdf:type rdf:Property ;
    rdfs:label 'Sender Name' ;
    rdfs:comment 'The display name of the sender as shown to the recipient. Examples: property name, brand name, or generic sender like \'Guest Services\' or \'Reservations Team\'.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'The date and time when the communication was sent from the marketing system. This is the principal business event timestamp for the communication lifecycle.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason why this communication was suppressed or not sent, if applicable. Examples: guest on do-not-contact list, invalid contact information, frequency cap exceeded, unsubscribed from category. Null if communication was sent.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Tracking Enabled Flag' ;
    rdfs:comment 'Boolean indicator of whether open and click tracking was enabled for this communication. True if tracking pixels and link tracking were included; False if tracking was disabled for privacy or technical reasons.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unsubscribedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unsubscribed Timestamp' ;
    rdfs:comment 'The date and time when the guest unsubscribed or opted out from this communication or communication type. Null if guest remains subscribed.' ;
    rdfs:domain ind:GuestCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Segment Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Guest segment ownership requires clear accountability for segment definition maintenance, refresh execution, and campaign targeting decisions. Marketing analysts and managers need assigned ownership f' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:campaignEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Eligibility Flag' ;
    rdfs:comment 'Indicates whether guests in this segment are eligible for marketing campaign communications (True) or excluded due to opt-out, regulatory restrictions, or business rules (False).' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:definitionCriteria rdf:type rdf:Property ;
    rdfs:label 'Definition Criteria' ;
    rdfs:comment 'Structured or free-text representation of the business rules and criteria used to assign guests to this segment (e.g., ADR > $300 AND stays >= 5 per year AND loyalty tier = Platinum).' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Size' ;
    rdfs:comment 'Approximate count of unique guests currently assigned to this segment, updated at each refresh cycle.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Date' ;
    rdfs:comment 'Date when segment membership was last recalculated and updated, enabling point-in-time segment membership queries.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyTierScope rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Scope' ;
    rdfs:comment 'Loyalty program tier(s) included in this segment definition (e.g., Platinum, Gold, Silver, or combinations). Null if loyalty tier is not a defining criterion. Distinct from loyalty tier master data — this is the marketing filter.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlModelName rdf:type rdf:Property ;
    rdfs:label 'Ml Model Name' ;
    rdfs:comment 'Name or identifier of the machine learning model used to generate this segment, if applicable. Null for rule-based or manually defined segments.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlModelVersion rdf:type rdf:Property ;
    rdfs:label 'Ml Model Version' ;
    rdfs:comment 'Version identifier of the machine learning model used to generate this segment. Null for rule-based or manually defined segments.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Date' ;
    rdfs:comment 'Scheduled date for the next segment membership recalculation cycle.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:occasionTypeScope rdf:type rdf:Property ;
    rdfs:label 'Occasion Type Scope' ;
    rdfs:comment 'Travel occasion type(s) included in this segment: business (corporate travel), leisure (vacation), MICE (Meetings Incentives Conferences Exhibitions), group (group bookings), FIT (Free Independent Traveler), or all occasions. Null if occasion type is not a defining criterion.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Name of the marketing team or business unit responsible for defining, maintaining, and using this segment (e.g., Brand Marketing, Guest Acquisition, Loyalty Marketing, Regional Marketing).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationPriority rdf:type rdf:Property ;
    rdfs:label 'Personalization Priority' ;
    rdfs:comment 'Priority level assigned to this segment for personalized guest communications and offers: high (premium personalization), medium (standard personalization), low (generic communications).' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyTierScope rdf:type rdf:Property ;
    rdfs:label 'Property Tier Scope' ;
    rdfs:comment 'Property service tier scope for this segment: luxury (high-end resorts), premium (full-service hotels), select-service (limited amenities), or all tiers. Null if property tier is not a defining criterion.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCreationMethod rdf:type rdf:Property ;
    rdfs:label 'Segment Creation Method' ;
    rdfs:comment 'Method by which this segment was created: rule-based (business rules engine), ml_model (machine learning algorithm), manual (analyst-defined), or hybrid (combination of methods).' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAdrMax rdf:type rdf:Property ;
    rdfs:label 'Target Adr Max' ;
    rdfs:comment 'Maximum Average Daily Rate threshold used in segment definition criteria for revenue-based segmentation. Null if ADR is not a defining criterion.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAdrMin rdf:type rdf:Property ;
    rdfs:label 'Target Adr Min' ;
    rdfs:comment 'Minimum Average Daily Rate threshold used in segment definition criteria for revenue-based segmentation. Null if ADR is not a defining criterion.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGssMin rdf:type rdf:Property ;
    rdfs:label 'Target Gss Min' ;
    rdfs:comment 'Minimum Guest Satisfaction Score threshold used in segment definition criteria for satisfaction-based segmentation. Null if GSS is not a defining criterion.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLtvMin rdf:type rdf:Property ;
    rdfs:label 'Target Ltv Min' ;
    rdfs:comment 'Minimum guest Lifetime Value threshold used in segment definition criteria for high-value guest identification. Null if LTV is not a defining criterion.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetNpsMin rdf:type rdf:Property ;
    rdfs:label 'Target Nps Min' ;
    rdfs:comment 'Minimum Net Promoter Score threshold used in segment definition criteria for satisfaction-based segmentation. Null if NPS is not a defining criterion.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetStayFrequencyMin rdf:type rdf:Property ;
    rdfs:label 'Target Stay Frequency Min' ;
    rdfs:comment 'Minimum number of stays per year used in segment definition criteria for frequency-based segmentation. Null if stay frequency is not a defining criterion.' ;
    rdfs:domain ind:GuestSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingCalendarId rdf:type rdf:Property ;
    rdfs:label 'Marketing Calendar Id' ;
    rdfs:comment 'Unique identifier for the marketing calendar entry. Primary key.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCalendarEntryMarketingCalendarId rdf:type rdf:Property ;
    rdfs:label 'Parent Calendar Entry Marketing Calendar Id' ;
    rdfs:comment 'Foreign key reference to the parent calendar entry if this is a recurring instance or sub-entry. Nullable for standalone entries.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingCalendar .

ind:primaryMarketingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Marketing Employee Id' ;
    rdfs:comment 'User ID of the person who approved this calendar entry. Nullable if not yet approved or approval not required.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryMarketingModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Marketing Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified this calendar entry.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCampaignCount rdf:type rdf:Property ;
    rdfs:label 'Actual Campaign Count' ;
    rdfs:comment 'Actual number of campaigns executed during this calendar window. Updated as campaigns are launched and completed.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutReason rdf:type rdf:Property ;
    rdfs:label 'Blackout Reason' ;
    rdfs:comment 'Explanation for blackout period if entry_type is blackout_period (e.g., \'System Maintenance\', \'Brand Refresh Quiet Period\', \'Competitive Event Avoidance\', \'Regulatory Restriction\').' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandMomentDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Moment Description' ;
    rdfs:comment 'Detailed description of the brand moment if entry_type is brand_moment (e.g., \'New Brand Launch\', \'Rebranding Announcement\', \'Sustainability Initiative Launch\', \'Partnership Announcement\').' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collisionRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Collision Risk Flag' ;
    rdfs:comment 'Boolean flag indicating whether this calendar entry overlaps with other high-priority entries, creating potential campaign collision or audience fatigue risk.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossFunctionalDependencies rdf:type rdf:Property ;
    rdfs:label 'Cross Functional Dependencies' ;
    rdfs:comment 'Description of dependencies on other business functions (e.g., \'Requires Revenue Management rate load\', \'Dependent on Property Renovation completion\', \'Requires IT system upgrade\').' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryCode rdf:type rdf:Property ;
    rdfs:label 'Entry Code' ;
    rdfs:comment 'Business identifier code for the calendar entry, used for cross-system reference and reporting.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryName rdf:type rdf:Property ;
    rdfs:label 'Entry Name' ;
    rdfs:comment 'Human-readable name of the marketing calendar entry (e.g., \'Summer Travel Campaign Window\', \'Q4 Holiday Blackout\', \'Brand Refresh Launch\').' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of the calendar entry: planned (initial planning stage), confirmed (approved and locked), in_flight (currently active), completed (finished), cancelled (no longer happening), postponed (delayed to future date).' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of the calendar entry: campaign_window (planned campaign execution period), tentpole_event (major seasonal or industry event), blackout_period (no marketing activity allowed), brand_moment (brand-level milestone or announcement), property_milestone (property-specific event), seasonal_promotion (recurring seasonal offer period).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCampaignCount rdf:type rdf:Property ;
    rdfs:label 'Expected Campaign Count' ;
    rdfs:comment 'Estimated number of campaigns planned to execute during this calendar window. Used for capacity planning and collision detection.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedCampaignIds rdf:type rdf:Property ;
    rdfs:label 'Linked Campaign Ids' ;
    rdfs:comment 'Comma-separated list of additional campaign IDs associated with this calendar entry. Supports multi-campaign coordination within a single calendar window.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketScope rdf:type rdf:Property ;
    rdfs:label 'Market Scope' ;
    rdfs:comment 'Geographic or market scope of the calendar entry (e.g., \'Global\', \'North America\', \'EMEA\', \'APAC\', \'USA\', \'UK\', \'Multi-Market\'). Supports regional planning and coordination.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningQuarter rdf:type rdf:Property ;
    rdfs:label 'Planning Quarter' ;
    rdfs:comment 'The fiscal quarter this entry belongs to (Q1, Q2, Q3, Q4) for quarterly marketing planning and review cycles.' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningYear rdf:type rdf:Property ;
    rdfs:label 'Planning Year' ;
    rdfs:comment 'The fiscal or calendar year this entry belongs to for annual planning cycles (e.g., 2024, 2025).' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:propertyMilestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Property Milestone Description' ;
    rdfs:comment 'Detailed description of the property milestone if entry_type is property_milestone (e.g., \'Grand Opening\', \'Renovation Completion\', \'Anniversary Celebration\', \'Award Recognition\').' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tentpoleCategory rdf:type rdf:Property ;
    rdfs:label 'Tentpole Category' ;
    rdfs:comment 'Category of tentpole event: holiday (Christmas, New Year, etc.), seasonal (summer, winter travel periods), conference (major business events), industry_event (trade shows, expos), cultural_moment (local festivals, celebrations), sporting_event (Olympics, major tournaments).' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tentpoleEventName rdf:type rdf:Property ;
    rdfs:label 'Tentpole Event Name' ;
    rdfs:comment 'Name of the tentpole event if entry_type is tentpole_event (e.g., \'Summer Travel Season\', \'Holiday Season\', \'Spring Break\', \'Major Conference\', \'Industry Trade Show\').' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityScope rdf:type rdf:Property ;
    rdfs:label 'Visibility Scope' ;
    rdfs:comment 'Access level for this calendar entry: public (visible to all stakeholders), internal (visible to marketing team), restricted (visible to specific teams), confidential (executive visibility only).' ;
    rdfs:domain ind:MarketingCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelAgentId rdf:type rdf:Property ;
    rdfs:label 'Travel Agent Id' ;
    rdfs:comment 'Reference to the travel agent or OTA partner if the offer was redeemed through an intermediary channel.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TravelAgent .

ind:attributionSource rdf:type rdf:Property ;
    rdfs:label 'Attribution Source' ;
    rdfs:comment 'The marketing attribution source that led to this offer redemption. Tracks the touchpoint that drove conversion (e.g., email campaign, social media ad, search ad).' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'The percentage discount applied if the offer type is percentage-based. Null for non-percentage offers.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalRateAmount rdf:type rdf:Property ;
    rdfs:label 'Final Rate Amount' ;
    rdfs:comment 'The final rate or price after the promotional offer discount was applied. This is the amount charged to the guest.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lengthOfStay rdf:type rdf:Property ;
    rdfs:label 'Length Of Stay' ;
    rdfs:comment 'The number of nights for the reservation associated with this offer redemption. Used for LOS restriction compliance and performance analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalRateAmount rdf:type rdf:Property ;
    rdfs:label 'Original Rate Amount' ;
    rdfs:comment 'The original rate or price before the promotional offer discount was applied. Used to calculate discount value and campaign ROI.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsEarned rdf:type rdf:Property ;
    rdfs:label 'Points Earned' ;
    rdfs:comment 'The number of loyalty points earned from this transaction after offer redemption, if the offer includes a points multiplier benefit.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promoTermsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Promo Terms Accepted Flag' ;
    rdfs:comment 'Indicates whether the guest explicitly accepted the promotional offer terms and conditions at redemption. Required for compliance and dispute resolution.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Redemption Location Latitude' ;
    rdfs:comment 'The geographic latitude coordinate where the offer was redeemed, if captured. Used for location-based campaign analysis.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Redemption Location Longitude' ;
    rdfs:comment 'The geographic longitude coordinate where the offer was redeemed, if captured. Used for location-based campaign analysis.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termsAcceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Terms Acceptance Timestamp' ;
    rdfs:comment 'The date and time when the guest accepted the promotional offer terms and conditions.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:socialPostId rdf:type rdf:Property ;
    rdfs:label 'Social Post Id' ;
    rdfs:comment 'Unique identifier for the social media post record. Primary key.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Publish Timestamp' ;
    rdfs:comment 'The actual date and time when the post was successfully published to the platform.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boostBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Boost Budget Amount' ;
    rdfs:comment 'The amount of budget allocated to boost or promote this post, in the campaign currency.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Boost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the boost budget amount.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentsCount rdf:type rdf:Property ;
    rdfs:label 'Comments Count' ;
    rdfs:comment 'Number of comments the post received.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentLanguage rdf:type rdf:Property ;
    rdfs:label 'Content Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the primary language of the post content.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentText rdf:type rdf:Property ;
    rdfs:label 'Content Text' ;
    rdfs:comment 'The text content or caption of the social media post.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletedReason rdf:type rdf:Property ;
    rdfs:label 'Deleted Reason' ;
    rdfs:comment 'Reason or explanation for why the post was deleted (e.g., policy violation, campaign ended, error correction).' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deleted Timestamp' ;
    rdfs:comment 'Date and time when the post was deleted or removed from the platform.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementCount rdf:type rdf:Property ;
    rdfs:label 'Engagement Count' ;
    rdfs:comment 'Total number of user engagements with the post (sum of likes, comments, shares, saves).' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementRate rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate' ;
    rdfs:comment 'Calculated engagement rate as a percentage (engagement_count / reach_count), stored as decimal (e.g., 0.0523 for 5.23%).' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hashtags rdf:type rdf:Property ;
    rdfs:label 'Hashtags' ;
    rdfs:comment 'Comma-separated list of hashtags included in the post for discoverability and campaign tracking.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionsCount rdf:type rdf:Property ;
    rdfs:label 'Impressions Count' ;
    rdfs:comment 'Total number of times the post was displayed to users, regardless of engagement.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBoosted rdf:type rdf:Property ;
    rdfs:label 'Is Boosted' ;
    rdfs:comment 'Indicates whether this post was promoted with paid advertising budget.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:likesCount rdf:type rdf:Property ;
    rdfs:label 'Likes Count' ;
    rdfs:comment 'Number of likes or reactions the post received.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkClicksCount rdf:type rdf:Property ;
    rdfs:label 'Link Clicks Count' ;
    rdfs:comment 'Number of clicks on any links included in the post.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metricsLastRefreshedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Metrics Last Refreshed Timestamp' ;
    rdfs:comment 'Date and time when the engagement metrics (impressions, reach, likes, etc.) were last refreshed from the social media platform API.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'The social media platform where this post was published.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postExternalCode rdf:type rdf:Property ;
    rdfs:label 'Post External Code' ;
    rdfs:comment 'The unique identifier assigned by the social media platform to this post (e.g., Instagram post ID, Facebook post ID, tweet ID).' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postStatus rdf:type rdf:Property ;
    rdfs:label 'Post Status' ;
    rdfs:comment 'Current lifecycle status of the social media post.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postType rdf:type rdf:Property ;
    rdfs:label 'Post Type' ;
    rdfs:comment 'The type or format of the social media post. [ENUM-REF-CANDIDATE: organic|paid|story|reel|carousel|video|live — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postUrl rdf:type rdf:Property ;
    rdfs:label 'Post Url' ;
    rdfs:comment 'Direct URL link to the published post on the social media platform.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachCount rdf:type rdf:Property ;
    rdfs:label 'Reach Count' ;
    rdfs:comment 'Total number of unique users who saw the post.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:savesCount rdf:type rdf:Property ;
    rdfs:label 'Saves Count' ;
    rdfs:comment 'Number of times the post was saved or bookmarked by users (platform-dependent).' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Publish Timestamp' ;
    rdfs:comment 'The date and time when the post was scheduled to be published.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sharesCount rdf:type rdf:Property ;
    rdfs:label 'Shares Count' ;
    rdfs:comment 'Number of times the post was shared or retweeted by users.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoViewsCount rdf:type rdf:Property ;
    rdfs:label 'Video Views Count' ;
    rdfs:comment 'Number of video views if the post contains video content.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyProgramId rdf:type rdf:Property ;
    rdfs:label 'Survey Program Id' ;
    rdfs:comment 'Primary key for survey_program' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveyProgram .

ind:medalliaProgramId rdf:type rdf:Property ;
    rdfs:label 'Medallia Program Id' ;
    rdfs:comment 'External system identifier for the survey program in Medallia platform. Used for API integration and response data synchronization.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:primarySurveyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Survey Employee Id' ;
    rdfs:comment 'Foreign key reference to the marketing user or team responsible for managing this survey program. Links to workforce/user management system.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySurveyModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Survey Modified By User Employee Id' ;
    rdfs:comment 'Foreign key reference to the user who last modified the survey program record. Audit trail for change accountability.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:triggerTouchpointId rdf:type rdf:Property ;
    rdfs:label 'Trigger Touchpoint Id' ;
    rdfs:comment 'Foreign key linking to experience.touchpoint. Business justification: Marketing survey programs are triggered at specific experience touchpoints (post-checkout, post-spa visit, post-dining). The touchpoint determines survey timing, content, and relevance. Critical for t' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Touchpoint .

ind:autoCaseCreationFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Case Creation Flag' ;
    rdfs:comment 'Indicates whether low-score survey responses automatically create service recovery cases in the experience domain. True = auto-create cases; False = manual review required.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'Number of days to retain individual survey response data before anonymization or deletion. Aligns with GDPR data minimization and retention policies.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary channel through which the survey is delivered to guests: email (post-stay email), SMS (text message link), in-app (mobile app notification), web (website pop-up), kiosk (property self-service terminal), qr-code (printed QR code on receipt/collateral).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCodes rdf:type rdf:Property ;
    rdfs:label 'Language Codes' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes supported by this survey (e.g., \'en,es,fr,de,zh\'). Enables multi-language guest experience.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxReminders rdf:type rdf:Property ;
    rdfs:label 'Max Reminders' ;
    rdfs:comment 'Maximum number of reminder messages to send to a non-respondent. Null if reminder_enabled_flag is False. Typically 1-2 to avoid guest fatigue.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privacyNoticeVersion rdf:type rdf:Property ;
    rdfs:label 'Privacy Notice Version' ;
    rdfs:comment 'Version identifier of the privacy notice presented to guests with this survey. Ensures GDPR/CCPA compliance and tracks consent framework changes.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderDelayHours rdf:type rdf:Property ;
    rdfs:label 'Reminder Delay Hours' ;
    rdfs:comment 'Number of hours after initial survey send to wait before sending a reminder. Null if reminder_enabled_flag is False.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reminderEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Reminder Enabled Flag' ;
    rdfs:comment 'Indicates whether automated reminder messages are sent to non-respondents. True = reminders enabled; False = no reminders.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sendDelayHours rdf:type rdf:Property ;
    rdfs:label 'Send Delay Hours' ;
    rdfs:comment 'Number of hours to wait after the trigger event before sending the survey. Allows guests time to complete their experience (e.g., 24 hours post-checkout).' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceRecoveryThresholdScore rdf:type rdf:Property ;
    rdfs:label 'Service Recovery Threshold Score' ;
    rdfs:comment 'Score threshold below which a survey response triggers an automatic service recovery case in the experience domain (e.g., NPS detractor score <= 6, GSS score < 7). Enables real-time guest recovery.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyCategory rdf:type rdf:Property ;
    rdfs:label 'Survey Category' ;
    rdfs:comment 'Measurement framework category: NPS (Net Promoter Score - likelihood to recommend), GSS (Guest Satisfaction Score - overall satisfaction rating), CSAT (Customer Satisfaction - specific touchpoint satisfaction), transactional (event-triggered feedback), relationship (periodic loyalty/engagement survey).' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyProgramStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Program Status' ;
    rdfs:comment 'Current lifecycle status of the survey program: draft (design phase, not yet launched), active (live and distributing), paused (temporarily suspended), completed (ended, no longer distributing), archived (historical record only).' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Survey Url Template' ;
    rdfs:comment 'URL template for the survey with placeholder tokens for personalization (e.g., \'https://survey.medallia.com/program/{program_id}?guest={guest_id}&res={reservation_id}\'). Used for survey link generation.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGssScore rdf:type rdf:Property ;
    rdfs:label 'Target Gss Score' ;
    rdfs:comment 'Target GSS score for the survey program (typically 0-100 or 0-10 scale). Used for goal setting and performance evaluation. Null for non-GSS surveys.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetNpsScore rdf:type rdf:Property ;
    rdfs:label 'Target Nps Score' ;
    rdfs:comment 'Target NPS score for the survey program (range -100 to +100). Used for goal setting and performance evaluation. Null for non-NPS surveys.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetResponseRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Response Rate Pct' ;
    rdfs:comment 'Target response rate percentage for the survey program (e.g., 25.00 for 25%). Used for performance tracking and optimization.' ;
    rdfs:domain ind:SurveyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingChannel rdf:type rdf:Property ;
    rdfs:label 'Booking Channel' ;
    rdfs:comment 'Channel through which the reservation was originally booked (e.g., Direct, OTA, GDS, Corporate). Used for satisfaction analysis by booking source.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutDate rdf:type rdf:Property ;
    rdfs:label 'Checkout Date' ;
    rdfs:comment 'Date when the guest checked out or completed their visit. Used to calculate survey timing and response lag.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactPermissionFlag rdf:type rdf:Property ;
    rdfs:label 'Contact Permission Flag' ;
    rdfs:comment 'Boolean flag indicating whether the guest granted permission to be contacted regarding their feedback. Required for GDPR and privacy compliance.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medalliaResponseCode rdf:type rdf:Property ;
    rdfs:label 'Medallia Response Code' ;
    rdfs:comment 'External unique identifier assigned by the Medallia survey platform for this response. Used for cross-system reconciliation and audit trails.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseChannel rdf:type rdf:Property ;
    rdfs:label 'Response Channel' ;
    rdfs:comment 'Channel through which the guest submitted the survey response (e.g., email link, SMS, mobile app, in-property kiosk).' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Status indicating whether the survey response was fully completed, partially completed, or abandoned by the guest.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Date and time when the guest submitted the survey response. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:roomType rdf:type rdf:Property ;
    rdfs:label 'Room Type' ;
    rdfs:comment 'Code representing the type of room the guest stayed in (e.g., Standard King, Deluxe Suite). Used for satisfaction analysis by room category.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyLanguage rdf:type rdf:Property ;
    rdfs:label 'Survey Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language in which the survey was presented and completed by the guest.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveySentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Sent Timestamp' ;
    rdfs:comment 'Date and time when the survey invitation was sent to the guest. Used to calculate response time and survey engagement metrics.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Spend Amount' ;
    rdfs:comment 'Total amount spent by the guest during the stay or visit, including room, F&B, and ancillary charges. Used for satisfaction-revenue correlation analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipPlanId rdf:type rdf:Property ;
    rdfs:label 'Pip Plan Id' ;
    rdfs:comment 'Reference to the PIP project if this goods receipt is part of a capital improvement initiative. Links FF&E procurement to renovation projects.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipPlan .

ind:primaryGoodsApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Approved By Employee Id' ;
    rdfs:comment 'Identifier of the manager or authorized person who approved the goods receipt for posting. Required for segregation of duties and SOX compliance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:receivingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Employee Id' ;
    rdfs:comment 'Identifier of the staff member who physically received and inspected the goods. Used for accountability and training purposes.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:batchManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Flag' ;
    rdfs:comment 'Indicates whether the received materials are tracked by batch or lot number. Essential for F&B traceability and recall management.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Shipping document number for freight shipments. Used for tracking and freight audit, especially for FF&E deliveries.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexOpexIndicator rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Indicator' ;
    rdfs:comment 'Classification of the procurement as capital expenditure (FF&E, PIP projects) or operating expenditure (supplies, consumables). Drives accounting treatment and financial reporting.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionOnReceipt rdf:type rdf:Property ;
    rdfs:label 'Condition On Receipt' ;
    rdfs:comment 'Physical condition assessment of goods upon delivery. Drives acceptance decisions, vendor performance scoring, and claims processing.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'The vendor\'s delivery note or packing slip reference number. Critical for three-way match and vendor reconciliation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date printed on the delivery note or packing slip from the vendor. Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charges Amount' ;
    rdfs:comment 'Shipping and freight costs associated with this delivery. May be capitalized into inventory cost or expensed depending on accounting policy.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'External business identifier for the goods receipt document. Unique alphanumeric code used in SAP MM for tracking and audit purposes.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt transaction. Tracks progression from draft through posting to potential reversal.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP MM movement type code indicating the nature of the inventory transaction. 101=GR for PO, 102=GR reversal, 161=GR for returns, 501=GR without PO, etc. [ENUM-REF-CANDIDATE: 101|102|103|105|161|501|502 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRejectionFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Rejection Flag' ;
    rdfs:comment 'Indicates whether any portion of the goods receipt was rejected due to quality issues. Triggers vendor notification and return processing.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The actual date when goods were physically received at the property. Used for inventory valuation and lead time analysis.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivingNotes rdf:type rdf:Property ;
    rdfs:label 'Receiving Notes' ;
    rdfs:comment 'Free-text comments from the receiving staff regarding delivery conditions, discrepancies, or other observations. Used for dispute resolution and vendor feedback.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Return Delivery Flag' ;
    rdfs:comment 'Indicates whether this goods receipt represents a return to vendor rather than an inbound delivery. Used for reverse logistics tracking.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serialNumberManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Serial Number Managed Flag' ;
    rdfs:comment 'Indicates whether the received items are tracked by individual serial numbers. Typical for FF&E assets and high-value equipment.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Code identifying the specific storeroom, warehouse, or storage area within the property where goods are placed. Examples: main kitchen, housekeeping storage, central warehouse.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuantityReceived rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Received' ;
    rdfs:comment 'Aggregate quantity of all line items received in this goods receipt transaction. Used for high-level receiving volume tracking.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Value Amount' ;
    rdfs:comment 'Total monetary value of all goods received in this transaction, in the property\'s local currency. Used for inventory valuation and financial reporting.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'Physical location at the property where goods were delivered and unloaded. Examples: loading dock, main entrance, kitchen entrance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standardized code explaining the cause of any variance between PO and GR. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMaterialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Employee Id' ;
    rdfs:comment 'Identifier of the user who created the material master record. Supports accountability and audit compliance.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'Inventory classification based on value and usage frequency. A items are high-value/high-usage requiring tight control; C items are low-value/low-usage with relaxed management. Drives inventory policy and cycle count frequency.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Standard unit in which the material is stocked, issued, and valued. Examples include EA (each), CS (case), BX (box), KG (kilogram), LT (liter), GL (gallon), DZ (dozen). Aligns with inventory and procurement transactions.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the material is classified as hazardous and requires special handling, storage, and disposal procedures per Occupational Safety and Health Administration (OSHA) regulations.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the company that manufactures or produces the material. Used for quality tracking, warranty management, and vendor performance evaluation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Unique part number assigned by the manufacturer. Enables precise identification for ordering, quality control, and warranty claims.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Full descriptive name of the material, supply, or good. Provides human-readable identification for procurement, receiving, and inventory management.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Detailed grouping of materials within a procurement category for granular spend analysis, vendor specialization, and contract management. Enables category-level reporting and sourcing strategy.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Unique alphanumeric code assigned to the material in the procurement system. External business identifier used across purchase orders, goods receipts, and inventory transactions.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material in the catalog. Active materials are available for procurement; inactive or discontinued materials are phased out; blocked materials cannot be ordered due to quality or compliance issues.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the material based on its procurement and usage purpose. Determines procurement rules, valuation methods, and inventory management policies.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Upper limit for inventory holding to prevent overstocking, minimize carrying costs, and reduce waste for perishable items.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perishableFlag rdf:type rdf:Property ;
    rdfs:label 'Perishable Flag' ;
    rdfs:comment 'Indicates whether the material has a limited shelf life and requires expiration date tracking. True for Food and Beverage (F&B) ingredients, fresh produce, and time-sensitive supplies.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Method by which the material is procured. Standard is direct purchase; consignment is vendor-owned inventory; subcontracting involves external processing; stock transfer is inter-property movement.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Purchase Unit Of Measure' ;
    rdfs:comment 'Unit in which the material is ordered from vendors. May differ from base unit (e.g., purchased in cases but stocked in each). Conversion factor to base unit is maintained separately.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether incoming goods must undergo quality inspection before acceptance. True for critical materials, Food and Beverage (F&B) ingredients, and items with quality history issues.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyStockLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Level' ;
    rdfs:comment 'Buffer inventory maintained to protect against demand variability and supply disruptions. Critical for high-usage items and materials with long lead times.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Abbreviated description of the material for use in reports, purchase orders, and mobile applications where space is limited.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required environmental conditions for storing the material to maintain quality and safety. Determines warehouse zone assignment and handling procedures.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'Tax category code for the material determining applicable sales tax, value-added tax (VAT), or goods and services tax (GST) rates. Varies by jurisdiction and material type.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMax rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max' ;
    rdfs:comment 'Maximum temperature in Celsius allowed for proper storage of temperature-sensitive materials. Exceeding this threshold may compromise quality or safety.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMin rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min' ;
    rdfs:comment 'Minimum temperature in Celsius required for proper storage of temperature-sensitive materials. Used for cold chain compliance and quality assurance.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Unique identifier for the purchase order line item. Primary key.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requisitionLineId rdf:type rdf:Property ;
    rdfs:label 'Requisition Line Id' ;
    rdfs:comment 'Reference to the originating purchase requisition line item that triggered this purchase order line. Provides traceability from demand to procurement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RequisitionLine .

ind:serviceMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Service Material Master Id' ;
    rdfs:comment 'Reference to the service master record for service-based procurement. Used when the line item represents a service rather than a physical material.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating whether this line item has been marked for deletion. When true, the line is logically deleted but retained for audit trail purposes.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The requested or confirmed delivery date for this line item. Represents when the vendor is expected to deliver the goods or complete the service.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInvoiceIndicator rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Indicator' ;
    rdfs:comment 'Flag indicating that the final invoice has been received for this line item and no further invoices are expected. Triggers line closure and prevents additional invoice postings.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'The General Ledger account code to which this line item will be posted. Determines the financial statement classification per USALI chart of accounts.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether goods receipt processing is required for this line item. When true, physical receipt must be posted before invoice can be processed.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'The cumulative quantity of goods that have been physically received and posted against this purchase order line. Used for three-way match validation between PO, goods receipt, and invoice.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'The Incoterms code defining the delivery terms and transfer of risk between buyer and seller. Determines shipping responsibility and cost allocation. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether invoice verification is required for this line item. When true, vendor invoice must be matched and verified before payment.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Quantity' ;
    rdfs:comment 'The cumulative quantity that has been invoiced by the vendor against this purchase order line. Used for three-way match validation and to track invoicing completeness.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'The current lifecycle status of this purchase order line item. Tracks progression from order placement through goods receipt, invoicing, and final closure.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'The total net value of this line item calculated as order quantity multiplied by unit price. Excludes taxes and represents the base procurement cost.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'The remaining quantity still outstanding on this purchase order line, calculated as order quantity minus goods receipt quantity. Represents unfulfilled procurement commitment.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'The quantity of material or service units ordered on this line item. Represents the total amount requested from the vendor.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage by which the vendor may over-deliver beyond the ordered quantity without requiring approval. Used for goods receipt validation.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'The property or facility code where the material will be received or the service will be performed. Represents the destination location within the hotel or resort portfolio.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity of units to which the unit price applies. For example, if price is stated per 100 units, this field would contain 100.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Brief description of the material or service being ordered on this line item. Provides human-readable context for the procurement item.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage by which the vendor may under-deliver below the ordered quantity without penalty. Used for goods receipt validation and automatic PO closure.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Material Number' ;
    rdfs:comment 'The vendors own catalog or SKU number for the material or service. Used for cross-referencing with vendor invoices and facilitating three-way match processing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'The project Work Breakdown Structure element for Capital Expenditure (CapEx) procurement tied to Property Improvement Plan (PIP) projects or renovation initiatives. Used for project-based cost tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Category Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that created this procurement category record. Supports audit trail and accountability.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:categoryModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Category Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that last modified this procurement category record. Supports change tracking and audit compliance.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent category in the hierarchical taxonomy. Null for top-level (L1) categories. Enables multi-level category drill-down for spend analytics.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:annualSpendBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Budget Amount' ;
    rdfs:comment 'Planned annual procurement spend budget (in USD) for this category across all properties or at corporate level. Used for budget variance analysis and spend forecasting.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Amount' ;
    rdfs:comment 'Maximum purchase order value (in USD) that can be approved at the defined authority level. Orders exceeding this amount require escalation to higher approval authority.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Benchmarking Enabled Flag' ;
    rdfs:comment 'Indicates whether spend in this category is benchmarked against industry standards (STR reports) or peer properties for cost optimization and competitive analysis.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Threshold Amount' ;
    rdfs:comment 'Minimum purchase order value (in USD) that triggers mandatory competitive bidding for this category. Null if no threshold applies or competitive bidding is always required.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Tracking Flag' ;
    rdfs:comment 'Indicates whether spend in this category is tracked against annual budgets with variance reporting and budget consumption alerts. True for budget-controlled categories.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the procurement category for external reference and system integration. Used in SAP S/4HANA MM module for material group classification.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the procurement category scope, including types of goods and services covered, typical use cases, and business context.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryLevel rdf:type rdf:Property ;
    rdfs:label 'Category Level' ;
    rdfs:comment 'Hierarchical level of the category in the taxonomy (1=top level such as F&B or FF&E, 2=sub-category, 3=detailed sub-category). Supports hierarchical spend rollup and analysis.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full business name of the procurement category (e.g., Food and Beverage Supplies, Housekeeping Linens, Furniture Fixtures and Equipment).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'Classification of procurement category by spend type: direct (guest-facing goods), indirect (operational supplies), capital (FF&E and CapEx), or services (contracted labor and professional services).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBidRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Bid Required Flag' ;
    rdfs:comment 'Indicates whether purchases in this category require competitive bidding process (RFP/RFQ) per procurement policy. True if competitive bidding is mandatory.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Specific regulatory or industry compliance framework applicable to this category (e.g., ISO 22000 for food safety, OSHA for workplace safety equipment, ADA for accessibility fixtures, PCI DSS for payment systems).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Compliance Required Flag' ;
    rdfs:comment 'Indicates whether purchases in this category must comply with master service agreements or corporate contracts. True if contract compliance tracking is mandatory.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cporTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Cpor Tracking Flag' ;
    rdfs:comment 'Indicates whether this category is included in CPOR (Cost Per Occupied Room) analysis for operational efficiency benchmarking. True for categories that scale with occupancy (housekeeping, guest amenities).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyProcurementAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Procurement Allowed Flag' ;
    rdfs:comment 'Indicates whether expedited emergency procurement procedures (bypassing standard approval workflows) are permitted for this category in urgent operational situations.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Managed Flag' ;
    rdfs:comment 'Indicates whether items in this category are tracked in property inventory systems with stock levels, reorder points, and inventory valuation. True for stocked items (F&B, housekeeping supplies).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumVendorCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Vendor Count' ;
    rdfs:comment 'Minimum number of qualified vendors that must be maintained for this category to ensure supply continuity and competitive pricing. Null if no minimum is defined.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Program Flag' ;
    rdfs:comment 'Indicates whether this category participates in a preferred vendor program with pre-negotiated pricing, terms, and service level agreements. True if preferred vendor relationships are established.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Required Flag' ;
    rdfs:comment 'Indicates whether vendors supplying this category must hold specific quality certifications (e.g., ISO 22000 for food safety, industry-specific quality standards).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this category is subject to specific regulatory compliance requirements (e.g., food safety regulations, fire safety codes, ADA accessibility standards for FF&E).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Procurement risk level for this category based on supply chain volatility, vendor concentration, regulatory exposure, and business impact: low (commodity items), medium (standard supplies), high (specialized equipment), critical (guest-facing or safety-critical).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy' ;
    rdfs:comment 'Procurement approach defined for this category: strategic (long-term partnerships), preferred_vendor (pre-qualified suppliers), competitive_bid (RFP/RFQ process), spot_buy (ad-hoc purchases), or contract (master service agreements).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendClassification rdf:type rdf:Property ;
    rdfs:label 'Spend Classification' ;
    rdfs:comment 'Financial classification indicating whether spend in this category is treated as operating expenditure (OpEx) or capital expenditure (CapEx) for accounting and budgeting purposes.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCriteriaFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Criteria Flag' ;
    rdfs:comment 'Indicates whether this category has defined sustainability or environmental compliance requirements for vendor selection and product sourcing (e.g., eco-friendly cleaning supplies, sustainable seafood).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Tax classification for purchases in this category: taxable (standard VAT/sales tax), exempt (tax-exempt goods), zero_rated (0% tax rate), or reverse_charge (buyer remits tax). Varies by jurisdiction.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorDiversificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Diversification Required Flag' ;
    rdfs:comment 'Indicates whether procurement policy requires multiple qualified vendors for this category to mitigate supply chain risk and ensure competitive pricing. True for high-risk or high-spend categories.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryProcurementApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Procurement Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who provided final approval for this contract. Null if contract is not yet approved.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryProcurementLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Procurement Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who last modified this contract record.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract automatically renews at expiry unless explicitly terminated. True if contract has auto-renewal clause, False if manual renewal required.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capexDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Capex Designation Flag' ;
    rdfs:comment 'Indicates whether this contract is designated for capital expenditure purchases (CapEx) such as Property Improvement Plan (PIP) projects, FF&E replacements, or major renovations. True for CapEx contracts, False for operating expenditure (OpEx) contracts.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Standard number of days from purchase order placement to goods receipt at property, as agreed in the contract Service Level Agreement (SLA).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the signed contract document stored in the enterprise document management system for legal reference and audit purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum order quantity allowed per purchase order or over contract term, if applicable. Used for contract compliance monitoring. Null if no maximum applies.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Negotiated Discount Percent' ;
    rdfs:comment 'Overall discount percentage negotiated off standard vendor pricing, applied at contract level. Used for price variance analysis and savings tracking. Null if no blanket discount applies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipProjectFlag rdf:type rdf:Property ;
    rdfs:label 'Pip Project Flag' ;
    rdfs:comment 'Indicates whether this contract is specifically tied to a Property Improvement Plan (PIP) project for property renovation or upgrade. True if PIP-related, False otherwise.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaOnTimeDeliveryPercent rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Delivery Percent' ;
    rdfs:comment 'Contractually agreed percentage of orders that must be delivered on time to meet SLA performance targets. Used for vendor performance monitoring.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaQualityAcceptancePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Quality Acceptance Percent' ;
    rdfs:comment 'Contractually agreed percentage of delivered goods that must pass quality inspection on first receipt to meet SLA performance targets.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Business reason or justification for early contract termination, such as vendor performance issues, business requirement changes, or cost optimization. Null if contract has not been terminated.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total estimated or committed monetary value of the contract over its full term, in the contract currency. Used for contract compliance monitoring and spend analytics. Null for open-ended contracts without value caps.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The date goods were actually received or services were completed. Populated upon goods receipt posting (MIGO transaction). Used for vendor performance analysis and on-time delivery metrics.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the manager or authorized signatory who approved the purchase order. Used for financial controls and SOX compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketReleaseNumber rdf:type rdf:Property ;
    rdfs:label 'Blanket Release Number' ;
    rdfs:comment 'Sequential release number for blanket purchase orders. Tracks individual call-offs against a master blanket PO. Null for non-blanket orders.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyerEmail rdf:type rdf:Property ;
    rdfs:label 'Buyer Email' ;
    rdfs:comment 'Email address of the buyer for vendor communication and order clarification.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the procurement specialist or property staff member who created the purchase order. Used for accountability and audit trail.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentReleasedAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Released Amount' ;
    rdfs:comment 'For blanket orders, the cumulative amount released to date against the total blanket commitment. Used for spend tracking and remaining commitment calculation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Completed Flag' ;
    rdfs:comment 'Boolean indicator whether all goods or services have been received and posted. True indicates receiving is complete, false indicates partial or no receipt. Used to trigger invoice matching and payment processing.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Completed Flag' ;
    rdfs:comment 'Boolean indicator whether vendor invoice has been received and matched to the purchase order. Used for three-way match validation (PO, goods receipt, invoice) and accounts payable processing.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'The date the purchase order was created and issued. Represents the business event timestamp for the procurement transaction.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known business identifier for the purchase order. Unique document number assigned by SAP MM module (transaction ME21N). Used for vendor communication and cross-system reference.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the approval and fulfillment workflow. Draft indicates initial creation, pending approval indicates routing through approval chain, approved indicates financial commitment authorized, released indicates transmitted to vendor, partially received indicates goods/services partially delivered, fully received indicates complete delivery, closed indicates financial settlement complete, cancelled indicates order voided. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|released|partially_received|fully_received|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order. Standard for one-time purchases, blanket for recurring releases against a master agreement, framework for multi-property contracts, CapEx for capital expenditure projects (FF&E, PIP), OpEx for operating expenditure (F&B supplies, housekeeping consumables), service for contracted services.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The date the vendor committed to deliver goods or complete services. Used for vendor SLA tracking and receiving schedule planning.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the property requires delivery of goods or completion of services. Used for supply chain planning and vendor performance tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Reference to the internal purchase requisition that originated this purchase order. Links operational need to procurement fulfillment.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line1' ;
    rdfs:comment 'First line of the delivery address for the property or receiving location. Typically the property name and street address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line2' ;
    rdfs:comment 'Second line of the delivery address. May include building name, department, or additional location details.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCity rdf:type rdf:Property ;
    rdfs:label 'Ship To City' ;
    rdfs:comment 'City name for the delivery address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the delivery address. Used for international shipping, customs, and tax compliance.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPostalCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Postal Code' ;
    rdfs:comment 'Postal code or ZIP code for the delivery address. Used for shipping logistics and tax calculation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToStateProvince rdf:type rdf:Property ;
    rdfs:label 'Ship To State Province' ;
    rdfs:comment 'State, province, or region for the delivery address. Used for tax jurisdiction determination.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'The mode of transportation for goods delivery. Ground for truck freight, air for expedited air freight, ocean for container shipping (FF&E imports), courier for small package delivery, vendor delivery for supplier-managed logistics, pickup for property collection from vendor location.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmountWithTax rdf:type rdf:Property ;
    rdfs:label 'Total Amount With Tax' ;
    rdfs:comment 'The total purchase order value including all taxes and fees. Represents the final financial obligation to the vendor.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorQuoteNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Quote Number' ;
    rdfs:comment 'Reference number of the vendor\'s quotation or proposal that this purchase order is based on. Used for price verification and audit trail.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Unique identifier for the purchase requisition. Primary key.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Identifier of the preferred or suggested vendor for this requisition, if specified by the requestor.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:primaryPurchaseRequestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Requestor Employee Id' ;
    rdfs:comment 'Identifier of the employee who created the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryPurchaseBuyerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Purchase Buyer Employee Id' ;
    rdfs:comment 'Identifier of the procurement specialist or buyer assigned to source and convert this requisition to a purchase order.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPurchaseFinalApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Purchase Final Approver Employee Id' ;
    rdfs:comment 'Identifier of the employee who provided the final approval before conversion to purchase order.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalChainLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Chain Level' ;
    rdfs:comment 'Current level in the approval hierarchy. Increments as requisition moves through approval workflow based on amount thresholds and organizational rules.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Available Flag' ;
    rdfs:comment 'Indicates whether sufficient budget is available in the cost center and GL account for this requisition. True if budget check passed, False if insufficient funds.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetYear rdf:type rdf:Property ;
    rdfs:label 'Budget Year' ;
    rdfs:comment 'Fiscal year against which the requisition is being charged for budget tracking and variance analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:convertedToPoFlag rdf:type rdf:Property ;
    rdfs:label 'Converted To Po Flag' ;
    rdfs:comment 'Indicates whether this requisition has been converted to one or more purchase orders. True if converted, False if still pending or cancelled.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Code' ;
    rdfs:comment 'Code identifying the specific receiving location within the property (central receiving, F&B storage, housekeeping, engineering shop, etc.).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Amount' ;
    rdfs:comment 'Estimated total value of the requisition in the property\'s functional currency. Used for budget checking and approval routing.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Number of line items (distinct materials or services) included in this requisition.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:justificationText rdf:type rdf:Property ;
    rdfs:label 'Justification Text' ;
    rdfs:comment 'Business justification provided by the requestor explaining the need for this procurement. Required for approval workflow.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the approval and procurement workflow. [ENUM-REF-CANDIDATE: Draft|Submitted|Pending Approval|Approved|Rejected|Cancelled|Converted to PO|Closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of requisition by financial treatment: OpEx (Operating Expenditure), CapEx (Capital Expenditure), PIP (Property Improvement Plan), Emergency, Stock Replenishment, or Service procurement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'Natural key or unique identifier from the source system for reconciliation and lineage tracking.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the requisition was submitted for approval workflow.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:purchaseReturnId rdf:type rdf:Property ;
    rdfs:label 'Purchase Return Id' ;
    rdfs:comment 'Unique identifier for the purchase return record. Primary key for the purchase return entity.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectorUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector User Employee Id' ;
    rdfs:comment 'Identifier of the quality inspector who performed the inspection that resulted in the return decision.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPurchaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Employee Id' ;
    rdfs:comment 'Identifier of the property staff member who initiated the return (e.g., receiving clerk, F&B manager, housekeeping supervisor).' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:apCreditPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Ap Credit Posted Flag' ;
    rdfs:comment 'Indicates whether the vendor credit has been posted to accounts payable, reducing the amount owed to vendor.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the logistics carrier handling the return shipment.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Amount' ;
    rdfs:comment 'Actual credit amount issued by vendor, which may differ from return value due to restocking fees, return shipping charges, or partial credit decisions.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoDate rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Date' ;
    rdfs:comment 'Date when vendor issued the credit memo for the returned goods.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryAdjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Adjustment Posted Flag' ;
    rdfs:comment 'Indicates whether the inventory adjustment for the return has been posted in SAP MM, reducing on-hand stock.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'SAP material master code for the item being returned. Identifies the specific product, supply, or FF&E item.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perishableItemFlag rdf:type rdf:Property ;
    rdfs:label 'Perishable Item Flag' ;
    rdfs:comment 'Indicates whether the returned item is a perishable good (critical for F&B operations). Perishable returns require expedited processing and food safety compliance documentation.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether returned goods were placed on quality hold status prior to return, preventing use in operations.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Outcome of quality inspection that triggered the return. Documents the specific quality failure or defect identified during receiving inspection.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee charged by vendor for processing the return, deducted from credit memo amount.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'Return Merchandise Authorization (RMA) number or similar authorization code provided by vendor to approve the return.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date when the return was initiated or goods were shipped back to vendor. Principal business event timestamp for the return transaction.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Return Document Number' ;
    rdfs:comment 'Business document number for the return delivery in SAP MM (movement type 122). Externally visible identifier for tracking and audit.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Quantity of material being returned to vendor, expressed in the material\'s base unit of measure.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for returning goods to vendor. Critical for vendor performance tracking and quality management.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Detailed explanation of why goods are being returned, including specific quality issues, damage details, or discrepancies identified during receiving inspection.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Shipment Tracking Number' ;
    rdfs:comment 'Carrier tracking number for the return shipment to vendor. Enables logistics tracking and proof of delivery to vendor.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost incurred for shipping goods back to vendor. May be absorbed by property or charged back to vendor depending on return reason and contract terms.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle status of the purchase return. Tracks workflow from initiation through vendor credit processing. [ENUM-REF-CANDIDATE: draft|submitted|approved|shipped|received_by_vendor|credited|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnValueAmount rdf:type rdf:Property ;
    rdfs:label 'Return Value Amount' ;
    rdfs:comment 'Total monetary value of the returned goods in the property\'s local currency. Basis for vendor credit memo and AP adjustment.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippedDate rdf:type rdf:Property ;
    rdfs:label 'Shipped Date' ;
    rdfs:comment 'Date when returned goods were shipped back to vendor.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Acknowledgement Date' ;
    rdfs:comment 'Date when vendor acknowledged receipt of the return request and agreed to accept returned goods.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorCreditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Credit Memo Number' ;
    rdfs:comment 'Reference number of the credit memo issued by vendor acknowledging the return and credit to be applied. Links return to AP credit processing.' ;
    rdfs:domain ind:PurchaseReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestForQuotationId rdf:type rdf:Property ;
    rdfs:label 'Request For Quotation Id' ;
    rdfs:comment 'Primary key for request_for_quotation' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RequestForQuotation .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Identifier of the manager or executive who approved the issuance of this RFQ.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Identifier of the vendor selected as the winner of this RFQ, if award decision has been made.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:primaryRequestEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Request Employee Id' ;
    rdfs:comment 'Identifier of the procurement professional or buyer responsible for managing this RFQ.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:awardCriteria rdf:type rdf:Property ;
    rdfs:label 'Award Criteria' ;
    rdfs:comment 'Primary basis for vendor selection and contract award. Lowest price awards to the vendor with the lowest compliant bid, best value considers price and non-price factors, technical merit prioritizes quality and capability, multi-vendor award splits the business among multiple qualified vendors.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Award Decision Date' ;
    rdfs:comment 'Date when the final vendor selection and award decision was made.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedContractValue rdf:type rdf:Property ;
    rdfs:label 'Awarded Contract Value' ;
    rdfs:comment 'Total monetary value of the contract awarded as a result of this RFQ.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Awarded Timestamp' ;
    rdfs:comment 'Timestamp when the award decision was finalized and the winning vendor was officially notified.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capexOpexFlag rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Flag' ;
    rdfs:comment 'Indicates whether this procurement is classified as Capital Expenditure (CapEx) for long-term assets and Property Improvement Plan (PIP) projects, or Operating Expenditure (OpEx) for day-to-day operational supplies and services.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration of the resulting contract in months, if the RFQ leads to a long-term supply agreement.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery End Date' ;
    rdfs:comment 'Latest date by which delivery or service completion must occur.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Start Date' ;
    rdfs:comment 'Earliest date when delivery or service commencement is required.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedAnnualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Spend Amount' ;
    rdfs:comment 'Projected total annual expenditure for the goods or services covered by this RFQ, used for vendor evaluation and contract sizing.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity' ;
    rdfs:comment 'Anticipated volume or quantity of goods or services to be procured, expressed in the unit of measure specified.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Detailed description of the criteria and methodology used to evaluate vendor responses, including weighting of price, quality, delivery, service, and other factors.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Timestamp when the RFQ was officially issued to vendors, marking the start of the response period.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:minorityVendorPreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Minority Vendor Preference Flag' ;
    rdfs:comment 'Indicates whether this RFQ includes preference or set-aside provisions for minority-owned, women-owned, or disadvantaged business enterprises.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participatingVendorCount rdf:type rdf:Property ;
    rdfs:label 'Participating Vendor Count' ;
    rdfs:comment 'Number of vendors invited to participate in this RFQ event.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'Final date by which vendors must submit their quotations or proposals.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDeadlineTime rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Time' ;
    rdfs:comment 'Precise timestamp by which vendor responses must be received, including time zone.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Response Received Count' ;
    rdfs:comment 'Number of vendor responses actually received by the response deadline.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqDescription rdf:type rdf:Property ;
    rdfs:label 'Rfq Description' ;
    rdfs:comment 'Detailed narrative description of the goods or services being sourced, including specifications, quality requirements, and any special conditions.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Business-facing unique identifier for the RFQ event, typically generated by the procurement system and shared with vendors.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ. Draft indicates preparation phase, issued means sent to vendors, open indicates active response period, closed means response deadline passed, awarded indicates vendor selection completed, cancelled indicates RFQ withdrawn.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Requirement Flag' ;
    rdfs:comment 'Indicates whether this RFQ includes mandatory sustainability, environmental, or green procurement requirements that vendors must meet.' ;
    rdfs:domain ind:RequestForQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Amount' ;
    rdfs:comment 'Total procurement spend with this vendor over the most recent 12-month period. Used for vendor segmentation, negotiation leverage analysis, and spend analytics. Expressed in the companys reporting currency.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Vendors bank account number for electronic payment remittance. Highly sensitive financial information requiring restricted access and encryption.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Nine-digit ABA routing number identifying the vendors bank for ACH and wire transfers in the United States.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Primary business classification of the vendor based on goods or services provided. Categories include Food and Beverage (F&B) supplier, housekeeping supplier, Furniture Fixtures and Equipment (FF&E) vendor, maintenance contractor, technology provider, and professional services.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or doing business as name if different from legal name. Used for operational communications and invoicing.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityCertification rdf:type rdf:Property ;
    rdfs:label 'Diversity Certification' ;
    rdfs:comment 'Diversity certification status of the vendor. Categories include Minority Business Enterprise (MBE), Women Business Enterprise (WBE), Disadvantaged Business Enterprise (DBE), Veteran Business Enterprise (VBE), LGBTQ Business Enterprise (LGBTBE), Service-Disabled Veteran-Owned Small Business (SDVOSB), HUBZone certified, or none. Used for supplier diversity reporting and corporate social responsibility initiatives. [ENUM-REF-CANDIDATE: mbe|wbe|dbe|vbe|lgbtbe|sdvosb|hubzone|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet DUNS number providing unique identification for the vendor entity. Used for credit assessment and supplier risk management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the vendors current general liability insurance certificate. Vendors must maintain valid insurance coverage to remain in active status.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Amount' ;
    rdfs:comment 'Minimum purchase order value required by the vendor for order acceptance. Orders below this threshold may incur additional fees or be rejected. Expressed in the vendors preferred currency.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the vendor was first approved and added to the procurement system. Used for vendor relationship tenure analysis and anniversary tracking.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the vendors preferred invoicing and payment currency. Examples: USD (US Dollar), EUR (Euro), GBP (British Pound).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceEmail rdf:type rdf:Property ;
    rdfs:label 'Remittance Email' ;
    rdfs:comment 'Email address for sending electronic remittance advice and payment notifications to the vendor. Used for accounts receivable communications.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Government-issued tax identification number for the vendor. In the US this is the Employer Identification Number (EIN) or Social Security Number (SSN) for sole proprietors. Required for 1099 reporting and tax compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT registration number for vendors operating in jurisdictions with value-added tax systems. Required for international procurement and tax reclaim processing.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'External business identifier for the vendor used in procurement documents and SAP S/4HANA MM module. Unique alphanumeric code assigned to each supplier.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Full legal name of the vendor or supplier organization as registered with tax authorities and used in contracts.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor in the procurement system. Active vendors can receive purchase orders; blocked vendors cannot transact pending resolution of compliance or performance issues.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Vendor relationship tier indicating strategic importance and procurement preference. Strategic vendors receive priority treatment and volume commitments; restricted vendors require special approval for purchases.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCertificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Certification Id' ;
    rdfs:comment 'Unique identifier for the vendor certification record. Primary key.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVendorVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Verified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who performed the most recent verification of this certification. Supports accountability and audit trail.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryVendorLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Vendor Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who last modified this certification record. Supports accountability and audit trail.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:brandStandardFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Flag' ;
    rdfs:comment 'Indicates whether this certification is required by brand standards or corporate policy. True if mandated by the hotel brand or corporate procurement policy.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification. Indicates whether the certification is valid and in good standing.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationSubtype rdf:type rdf:Property ;
    rdfs:label 'Certification Subtype' ;
    rdfs:comment 'Detailed subtype or specific standard within the certification type (e.g., ISO 22000, HACCP, Green Key, EarthCheck, MBE, WBE, LGBTBE). Provides granular classification.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceGateFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Gate Flag' ;
    rdfs:comment 'Indicates whether this certification is a mandatory qualification gate for vendor approval. True if the vendor cannot be approved or transact without this certification.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'Monetary coverage amount for insurance-related certifications (e.g., general liability coverage limit, workers compensation coverage). Null for non-insurance certifications.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Coverage Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the coverage amount (e.g., USD, CAD, EUR). Null for non-insurance certifications.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the organization, agency, or authority that issued the certification (e.g., ISO, local health department, insurance carrier, diversity certification council).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the scope of the certification, including specific products, services, or activities covered. Clarifies what the certification qualifies the vendor to supply.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Unique identifier for the vendor invoice record. Primary key.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date the dispute was resolved. Null if dispute is still open or if no dispute exists.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Notes' ;
    rdfs:comment 'Free-text notes describing the resolution of the dispute. Null if not applicable.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The amount in dispute, in the invoice currency. Null if not disputed.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyPaymentDiscountDate rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Date' ;
    rdfs:comment 'The last date by which payment must be made to qualify for the early payment discount. Null if not applicable.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earlyPaymentDiscountEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Eligible Flag' ;
    rdfs:comment 'Indicates whether this invoice is eligible for an early payment discount per the payment terms. True if eligible, False otherwise.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyPaymentDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Percentage' ;
    rdfs:comment 'The percentage discount available if the invoice is paid within the early payment discount period (e.g., 2.00 for 2%). Null if not applicable.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseType rdf:type rdf:Property ;
    rdfs:label 'Expense Type' ;
    rdfs:comment 'Classification of the invoice as Operating Expenditure (OpEx) or Capital Expenditure (CapEx). CapEx typically relates to Property Improvement Plan (PIP) projects and Furniture Fixtures and Equipment (FF&E).' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description or notes about the invoice, typically provided by the vendor or added by Accounts Payable (AP) staff.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Match Variance Amount' ;
    rdfs:comment 'The variance amount between the invoice and the PO/GR during three-way match, in the invoice currency. Null if matched.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Id' ;
    rdfs:comment 'Unique identifier for the vendor performance evaluation record.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Lead Time Days' ;
    rdfs:comment 'Average number of days between purchase order issuance and goods receipt during the evaluation period. Measures vendor fulfillment speed.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Contract Compliance Score' ;
    rdfs:comment 'Composite score measuring vendor adherence to contract terms including pricing, delivery terms, payment terms, and service level agreements. Scored 0-100.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRenewalRecommendation rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Recommendation' ;
    rdfs:comment 'Recommendation for contract action based on performance evaluation results. Supports contract lifecycle management decisions.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCompetitivenessRating rdf:type rdf:Property ;
    rdfs:label 'Cost Competitiveness Rating' ;
    rdfs:comment 'Rating of vendor pricing competitiveness compared to market benchmarks and alternative suppliers. Typically scored 1-5 scale.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyOrderSupportRating rdf:type rdf:Property ;
    rdfs:label 'Emergency Order Support Rating' ;
    rdfs:comment 'Rating of vendor ability to fulfill urgent or emergency purchase orders outside normal lead times. Critical for hospitality operations continuity. Typically scored 1-5 scale.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text notes and comments from the evaluator regarding vendor performance, specific issues, or improvement recommendations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period. Defines the window for performance measurement.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period. Typically monthly or quarterly evaluation cycles.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle status of the vendor performance evaluation record.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage of invoices received without pricing errors, quantity discrepancies, or other billing issues during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDiscrepanciesCount rdf:type rdf:Property ;
    rdfs:label 'Invoice Discrepancies Count' ;
    rdfs:comment 'Number of invoices with pricing errors, quantity mismatches, or other billing issues during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lateDeliveriesCount rdf:type rdf:Property ;
    rdfs:label 'Late Deliveries Count' ;
    rdfs:comment 'Number of purchase orders delivered after the requested delivery date during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage of purchase orders delivered on or before the requested delivery date during the evaluation period. Key metric for vendor reliability.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallVendorScore rdf:type rdf:Property ;
    rdfs:label 'Overall Vendor Score' ;
    rdfs:comment 'Weighted composite score combining all evaluation criteria (on-time delivery, quality, invoice accuracy, contract compliance, responsiveness). Used for vendor ranking and qualification decisions. Scored 0-100.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Compliance Flag' ;
    rdfs:comment 'Indicates whether vendor adhered to agreed payment terms and did not demand early payment or deviate from contract terms.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor has achieved preferred vendor status based on performance evaluation results. Preferred vendors receive priority consideration for new purchase orders.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualifiedVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Qualified Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor meets minimum qualification standards for continued business. Vendors failing qualification may be subject to contract review or termination.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate' ;
    rdfs:comment 'Percentage of goods receipts accepted without quality defects or rejections during the evaluation period. Measures product quality consistency.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRejectionsCount rdf:type rdf:Property ;
    rdfs:label 'Quality Rejections Count' ;
    rdfs:comment 'Number of goods receipts rejected due to quality defects during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsivenessRating rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Rating' ;
    rdfs:comment 'Subjective rating of vendor responsiveness to inquiries, issues, and urgent requests. Typically scored 1-5 scale.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPurchaseOrders rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Orders' ;
    rdfs:comment 'Total number of purchase orders issued to this vendor during the evaluation period. Provides context for performance metrics.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorQuotationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Quotation Id' ;
    rdfs:comment 'Unique identifier for the vendor quotation record. Primary key.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Award Recommendation Flag' ;
    rdfs:comment 'Indicates whether the procurement team recommends awarding the purchase order to this vendor based on quotation evaluation. True signals recommended vendor for award.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Evaluated Timestamp' ;
    rdfs:comment 'Timestamp when the quotation evaluation was completed and vendor score was finalized. Key milestone in the procurement decision timeline.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priceCompetitivenessRating rdf:type rdf:Property ;
    rdfs:label 'Price Competitiveness Rating' ;
    rdfs:comment 'Qualitative assessment of how competitive the quoted price is compared to market benchmarks and other vendor quotations for the same RFQ.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Quotation Document Url' ;
    rdfs:comment 'URL or file path to the original quotation document submitted by the vendor. Links to document management system for audit trail and reference.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationNumber rdf:type rdf:Property ;
    rdfs:label 'Quotation Number' ;
    rdfs:comment 'Business identifier for the vendor quotation. Externally visible reference number used in vendor communications and procurement documentation.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Quotation Received Date' ;
    rdfs:comment 'Date when the vendor quotation was received by the procurement team. Key timestamp for tracking vendor responsiveness and evaluation timelines.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotationStatus rdf:type rdf:Property ;
    rdfs:label 'Quotation Status' ;
    rdfs:comment 'Current lifecycle status of the vendor quotation in the procurement evaluation workflow. Tracks progression from receipt through award or rejection decision.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Quotation Valid From Date' ;
    rdfs:comment 'Start date of the quotation validity period. Defines when the quoted prices and terms become effective.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotationValidToDate rdf:type rdf:Property ;
    rdfs:label 'Quotation Valid To Date' ;
    rdfs:comment 'End date of the quotation validity period. After this date, the vendor is not obligated to honor the quoted prices and terms.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quoted Quantity' ;
    rdfs:comment 'Quantity of goods or services that the vendor is quoting for. May differ from the RFQ requested quantity if vendor proposes alternative volumes.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Quoted Total Amount' ;
    rdfs:comment 'Total amount quoted by the vendor for the entire order quantity. Calculated as unit price multiplied by quantity, may include volume discounts.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'Price per unit quoted by the vendor for the requested item or service. Base price before taxes, discounts, or additional charges.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Specification Compliance Flag' ;
    rdfs:comment 'Indicates whether the vendor quotation fully complies with the RFQ specifications. False indicates deviations or exceptions that require evaluation.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationDeviationNotes rdf:type rdf:Property ;
    rdfs:label 'Specification Deviation Notes' ;
    rdfs:comment 'Detailed description of any deviations from the RFQ specifications proposed by the vendor. Includes alternative materials, quality grades, packaging, or service levels.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the vendor contact for this quotation. Used for quotation clarifications and award notifications.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the vendor representative who submitted or is responsible for this quotation. Business contact information for quotation clarifications.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Phone number of the vendor contact for this quotation. Business contact information for urgent procurement communications.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorScore rdf:type rdf:Property ;
    rdfs:label 'Vendor Score' ;
    rdfs:comment 'Composite evaluation score assigned to this quotation based on price, quality, delivery terms, vendor performance history, and other selection criteria. Used for vendor comparison and award decisions.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Warranty or guarantee terms offered by the vendor for the quoted goods or services. Particularly relevant for FF&E and equipment procurement.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the property certification or audit record.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitFeeCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Permit Fee Currency Id' ;
    rdfs:comment 'Foreign key linking to property.currency. Business justification: Each certification permit fee is denominated in ONE currency. Normalize currency reference to master currency table. FK named permit_fee_currency_id to distinguish from potential other currency FKs. R' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the higher-level accreditation body that accredits the issuing authority or audit firm (e.g., ANSI-ASQ National Accreditation Board, UKAS). Provides additional credibility and traceability.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'Date on which the on-site audit or inspection was completed.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditSectionScores rdf:type rdf:Property ;
    rdfs:label 'Audit Section Scores' ;
    rdfs:comment 'Detailed breakdown of scores by audit section or domain (e.g., Front Desk: 92, Housekeeping: 88, F&B: 85). Stored as structured text or JSON for granular analysis.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Start Date' ;
    rdfs:comment 'Date on which the on-site audit or inspection began.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorFirm rdf:type rdf:Property ;
    rdfs:label 'Auditor Firm' ;
    rdfs:comment 'Name of the third-party audit firm or consulting company that performed the audit or certification assessment.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Overall compliance or audit score expressed as a percentage or numeric rating. Represents the property\'s performance against the certification or audit criteria.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Reference' ;
    rdfs:comment 'Reference number or identifier for the corrective action plan (CAP) developed in response to audit findings. Links to the document or system tracking remediation activities.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Permit Fee Amount' ;
    rdfs:comment 'Fee paid to the issuing authority for the certification, permit, or license. Expressed in the property\'s local currency.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reauditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Reaudit Scheduled Date' ;
    rdfs:comment 'Date on which a follow-up audit or re-inspection is scheduled to verify that corrective actions have been implemented and deficiencies resolved.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currencyId rdf:type rdf:Property ;
    rdfs:label 'Currency Id' ;
    rdfs:comment 'Unique identifier for the currency record. Primary key.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:currencyStatus rdf:type rdf:Property ;
    rdfs:label 'Currency Status' ;
    rdfs:comment 'Current operational status of the currency in the system. Active currencies are available for all transactions; inactive currencies are retained for historical reporting; deprecated currencies are being phased out; historical currencies are no longer in circulation (e.g., legacy European currencies replaced by EUR); pending currencies are configured but not yet live.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Decimal Places' ;
    rdfs:comment 'Number of decimal places used for this currency in financial calculations and display. Most currencies use 2 (e.g., USD 100.50), some use 0 (e.g., JPY 1000), and a few use 3 (e.g., BHD 10.250). Critical for accurate revenue calculations, Average Daily Rate (ADR), and Revenue Per Available Room (RevPAR) reporting.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayFormat rdf:type rdf:Property ;
    rdfs:label 'Display Format' ;
    rdfs:comment 'The standard display format for this currency including symbol placement, decimal separator, and thousands separator (e.g., $1,234.56 for USD, 1.234,56 € for EUR). Used to ensure consistent presentation across guest-facing systems, reports, and Business Intelligence (BI) dashboards.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Erp Currency Code' ;
    rdfs:comment 'The currency code or identifier used in the Enterprise Resource Planning (ERP) system, such as SAP S/4HANA. Used for financial consolidation, General Ledger (GL) posting, Accounts Payable (AP), and Accounts Receivable (AR) integration.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateSource rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Source' ;
    rdfs:comment 'The authoritative source or provider for exchange rate data for this currency (e.g., OANDA, XE.com, Bloomberg, Reuters, Central Bank). Used to ensure consistent exchange rate application across Central Reservation System (CRS), Revenue Management System (RMS), and Enterprise Resource Planning (ERP) systems.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateUpdateFrequency rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Update Frequency' ;
    rdfs:comment 'The frequency at which exchange rates are refreshed for this currency. Critical for accurate revenue recognition, dynamic pricing in Revenue Management System (RMS), and financial consolidation under International Financial Reporting Standards (IFRS) and Generally Accepted Accounting Principles (GAAP).' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Base Currency' ;
    rdfs:comment 'Indicates whether this currency is the base currency for financial consolidation and corporate reporting. Typically one currency per enterprise (e.g., USD for US-headquartered companies). Used for Gross Operating Profit (GOP), Earnings Before Interest Taxes Depreciation and Amortization (EBITDA), and consolidated financial statements under Uniform System of Accounts for the Lodging Industry (USALI).' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCryptoCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Crypto Currency' ;
    rdfs:comment 'Indicates whether this is a cryptocurrency (e.g., Bitcoin, Ethereum) rather than a traditional fiat currency. Used for special handling in payment processing, regulatory compliance, and financial reporting.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorUnit rdf:type rdf:Property ;
    rdfs:label 'Minor Unit' ;
    rdfs:comment 'The relationship between the major currency unit and its minor unit (e.g., 100 cents = 1 dollar). Defines the subdivision of the currency for precise financial calculations in Property Management System (PMS) and Point of Sale (POS) systems.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numericCode rdf:type rdf:Property ;
    rdfs:label 'Numeric Code' ;
    rdfs:comment 'Three-digit ISO 4217 numeric currency code used in systems where alphabetic codes are not practical. Provides an alternative identifier for the currency in legacy systems and international payment processing.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessingEnabled rdf:type rdf:Property ;
    rdfs:label 'Payment Processing Enabled' ;
    rdfs:comment 'Indicates whether this currency is enabled for payment processing through Point of Sale (POS) systems, online booking engines, and payment gateways. Must comply with Payment Card Industry Data Security Standard (PCI DSS) requirements.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pmsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Pms Currency Code' ;
    rdfs:comment 'The currency code or identifier used in the Property Management System (PMS), such as Oracle OPERA. May differ from ISO 4217 code in legacy systems. Used for system integration and data mapping between PMS and enterprise data warehouse.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:symbol rdf:type rdf:Property ;
    rdfs:label 'Symbol' ;
    rdfs:comment 'Standard symbol used to represent the currency (e.g., $, €, £, ¥). Used in user interfaces, reports, and guest-facing displays for quick visual recognition.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaFeatures rdf:type rdf:Property ;
    rdfs:label 'Ada Features' ;
    rdfs:comment 'Descriptive text listing specific ADA-compliant accessibility features available at the facility (e.g., \'Wheelchair ramp, pool lift, accessible restroom, braille signage\'). Supports guest accessibility requests and ADA compliance audit documentation.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRestriction rdf:type rdf:Property ;
    rdfs:label 'Age Restriction' ;
    rdfs:comment 'Age-based access restriction for the facility. Adults_only applies to facilities such as adult pools, bars, and certain spa areas; minimum_age values apply to facilities with safety or legal age requirements. Used for guest communication, liability management, and regulatory compliance.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqft rdf:type rdf:Property ;
    rdfs:label 'Area Sqft' ;
    rdfs:comment 'Total floor area of the facility measured in square feet. Used for event space marketing, FF&E (Furniture Fixtures and Equipment) planning, CapEx budgeting, and PIP documentation. Meeting and event spaces use this for per-square-foot revenue analysis.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avEquipmentAvailable rdf:type rdf:Property ;
    rdfs:label 'Av Equipment Available' ;
    rdfs:comment 'Indicates whether built-in audio-visual equipment (projectors, screens, microphones, video conferencing systems) is available in the facility. Primarily relevant for meeting rooms, ballrooms, and business centers. Used in MICE (Meetings Incentives Conferences Exhibitions) event sales and BEO configuration.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildingWing rdf:type rdf:Property ;
    rdfs:label 'Building Wing' ;
    rdfs:comment 'Named wing, tower, or zone of the property building where the facility is physically located (e.g., \'North Tower\', \'Pool Deck\', \'Conference Level\'). Supports wayfinding, housekeeping scheduling, and multi-building resort navigation.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacity rdf:type rdf:Property ;
    rdfs:label 'Capacity' ;
    rdfs:comment 'Maximum number of guests or persons the facility can accommodate simultaneously under normal operating conditions. For meeting rooms this is the maximum seating capacity; for pools it is the maximum bather load; for restaurants it is the total cover count. Used in event sales, operational scheduling, and safety compliance.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityCategory rdf:type rdf:Property ;
    rdfs:label 'Facility Category' ;
    rdfs:comment 'High-level grouping of the facility into a business category for reporting and guest-facing amenity segmentation. Recreation covers pools, gyms, and sports; food_beverage covers restaurants and bars; meetings_events covers ballrooms and conference rooms; wellness covers spas and health centers; business_services covers business centers; transportation covers parking and valet. [ENUM-REF-CANDIDATE: recreation|food_beverage|meetings_events|wellness|business_services|transportation|retail|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies the facility within the property management and channel distribution systems (e.g., POOL-01, SPA-MAIN, GYM-24H). Used in OTA feeds, PMS configuration, and guest-facing amenity display.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Human-readable display name of the facility as presented to guests and staff (e.g., \'Infinity Pool\', \'The Serenity Spa\', \'Grand Ballroom\'). Used in guest-facing amenity listings, housekeeping schedules, and event coordination.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Categorical classification of the facility by its primary function (e.g., pool, spa, fitness_center, restaurant, bar, meeting_room, ballroom, business_center, parking, recreational_area, retail_outlet). Drives amenity display grouping, operational scheduling, and ADA compliance tracking. [ENUM-REF-CANDIDATE: pool|spa|fitness_center|restaurant|bar|meeting_room|ballroom|business_center|parking|recreational_area|retail_outlet|lounge — promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is24Hour rdf:type rdf:Property ;
    rdfs:label 'Is 24 Hour' ;
    rdfs:comment 'Indicates whether the facility operates continuously 24 hours per day without a defined closing time (e.g., fitness centers, parking structures, business centers). When True, operating_hours_open and operating_hours_close are informational only.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFeeBased rdf:type rdf:Property ;
    rdfs:label 'Is Fee Based' ;
    rdfs:comment 'Indicates whether the facility charges a separate usage fee beyond the room rate (e.g., resort fee, spa access fee, parking fee). When True, the associated outlet_code links to POS revenue tracking.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReservationRequired rdf:type rdf:Property ;
    rdfs:label 'Is Reservation Required' ;
    rdfs:comment 'Indicates whether guests must make a prior reservation to use the facility (e.g., spa treatment rooms, cabanas, private dining rooms). Drives guest-facing booking prompts and operational capacity management.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Expiration date of the facility\'s operating license or permit (yyyy-MM-dd). Triggers renewal workflows to ensure continuous regulatory compliance. Critical for F&B outlets, spas, and pool facilities subject to periodic licensing.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Government-issued operating license or permit number for regulated facilities such as restaurants (food service license), bars (liquor license), spas (cosmetology license), and pools (health department permit). Required for regulatory compliance documentation.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxOccupancyPct rdf:type rdf:Property ;
    rdfs:label 'Max Occupancy Pct' ;
    rdfs:comment 'Regulatory or operational maximum occupancy threshold expressed as a percentage of total capacity (e.g., 80.00 means 80% of capacity). Used for fire safety compliance, COVID-era capacity restrictions, and operational safety management.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:naturalLight rdf:type rdf:Property ;
    rdfs:label 'Natural Light' ;
    rdfs:comment 'Indicates whether the facility has access to natural daylight through windows or skylights. A key selling attribute for meeting and event spaces, as natural light is a premium feature in MICE sales. Also relevant for wellness facilities and restaurants.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursClose rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Close' ;
    rdfs:comment 'Standard daily closing time of the facility in HH:MM (24-hour) format. For facilities operating past midnight, this may be 23:59 with a separate overnight flag. Used alongside operating_hours_open for guest-facing display and staffing.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursOpen rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Open' ;
    rdfs:comment 'Standard daily opening time of the facility in HH:MM (24-hour) format. Used for guest-facing amenity display, operational staffing schedules, and housekeeping preparation windows. For 24-hour facilities, set to 00:00.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outdoorIndoor rdf:type rdf:Property ;
    rdfs:label 'Outdoor Indoor' ;
    rdfs:comment 'Indicates whether the facility is located indoors, outdoors, or in a semi-outdoor (covered but open-air) environment. Affects seasonal availability, weather contingency planning for events, and guest-facing amenity descriptions.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyFacilityDescription rdf:type rdf:Property ;
    rdfs:label 'Property Facility Description' ;
    rdfs:comment 'Long-form marketing and operational description of the facility for use in guest-facing channels, OTA listings, and property websites. Describes the facility\'s features, ambiance, services offered, and unique selling points. Managed in Sabre SynXis CRS for channel distribution.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyFacilityStatus rdf:type rdf:Property ;
    rdfs:label 'Property Facility Status' ;
    rdfs:comment 'Current lifecycle status of the facility indicating its operational availability. Active means fully operational; seasonal means available only during defined seasonal periods; under_renovation means temporarily closed for PIP (Property Improvement Plan) works; closed means permanently decommissioned; pending_opening means approved but not yet operational.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renovationEndDate rdf:type rdf:Property ;
    rdfs:label 'Renovation End Date' ;
    rdfs:comment 'Planned or actual completion date of the most recent or current PIP (Property Improvement Plan) renovation for this facility (yyyy-MM-dd). Used for return-to-service planning, guest communication, and CapEx project closure.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renovationStartDate rdf:type rdf:Property ;
    rdfs:label 'Renovation Start Date' ;
    rdfs:comment 'Planned or actual start date of the most recent or current PIP (Property Improvement Plan) renovation for this facility (yyyy-MM-dd). Used for operational impact planning, guest communication, and CapEx project tracking in SAP S/4HANA.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renovationStatus rdf:type rdf:Property ;
    rdfs:label 'Renovation Status' ;
    rdfs:comment 'Current PIP (Property Improvement Plan) renovation status of the facility. Planned indicates approved but not yet started; in_progress indicates active construction or refurbishment; completed indicates renovation finished and facility returned to service. Supports CapEx tracking and operational impact planning.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Seating Configuration' ;
    rdfs:comment 'Default or primary seating arrangement style for the facility, particularly relevant for meeting rooms and event spaces. Theater style is rows facing a stage; banquet is round tables; boardroom is a single conference table. Used in BEO (Banquet Event Order) management and event sales in Delphi by Amadeus. [ENUM-REF-CANDIDATE: theater|classroom|banquet|reception|boardroom|u_shape|cabaret|open_plan|not_applicable — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Usage Fee Amount' ;
    rdfs:comment 'Standard per-use or per-day fee charged to guests for accessing the facility, expressed in the property\'s local currency. Applicable only when is_fee_based is True. Used for revenue forecasting and guest billing configuration in PMS.' ;
    rdfs:domain ind:PropertyFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known, human-readable contract reference number assigned by the franchisor or legal department. Used for cross-referencing with SAP S/4HANA contract management and legal document repositories. Serves as the BUSINESS_IDENTIFIER for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the contractual relationship governing the property\'s brand affiliation and operational model. Franchise: brand license with owner-operated management. Management Contract: brand operates the property on behalf of owner. Lease: brand leases the physical asset. Owner-Operated: independent ownership and operation. License: limited brand usage rights. Serves as CLASSIFICATION_OR_TYPE for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSegment rdf:type rdf:Property ;
    rdfs:label 'Brand Segment' ;
    rdfs:comment 'Market segment classification of the brand under which the property operates per STR chain scale segmentation. Drives competitive benchmarking, RevPAR analysis, and STR STAR Report peer group assignment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Version' ;
    rdfs:comment 'Version identifier of the franchisor\'s brand standards manual applicable to this agreement at time of execution. Brand standards govern FF&E specifications, service delivery, guest experience requirements, and quality assurance audit criteria.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsConnectivityRequired rdf:type rdf:Property ;
    rdfs:label 'Crs Connectivity Required' ;
    rdfs:comment 'Indicates whether the agreement mandates connectivity to the franchisor\'s CRS (Central Reservation System) for rate and inventory distribution. Aligns with Sabre SynXis CRS integration requirements.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusiveTerritory rdf:type rdf:Property ;
    rdfs:label 'Exclusive Territory' ;
    rdfs:comment 'Indicates whether the agreement grants the franchisee an exclusive geographic territory within which the franchisor agrees not to license competing properties under the same brand. Impacts competitive set analysis and new property development decisions.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'Date on which the franchise or management contract agreement was fully executed (signed by all parties). May differ from effective_date if there is a gap between signing and commencement. Used for legal document management and audit trails.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fddRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fdd Registration Number' ;
    rdfs:comment 'Registration number of the Franchise Disclosure Document (FDD) filed with applicable state regulatory authorities. Required in registration states under the FTC Franchise Rule and state franchise laws. Supports regulatory compliance tracking.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffAndEReservePct rdf:type rdf:Property ;
    rdfs:label 'Ff And E Reserve Pct' ;
    rdfs:comment 'Percentage of gross revenue required to be set aside in a FF&E (Furniture, Fixtures and Equipment) reserve fund for ongoing property maintenance and capital replacement. Mandated under most franchise and management contract agreements per USALI standards.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseeEntityName rdf:type rdf:Property ;
    rdfs:label 'Franchisee Entity Name' ;
    rdfs:comment 'Legal name of the franchisee or property owner entity entering into the franchise or management contract agreement. Used for ownership structure tracking, portfolio governance, and SAP S/4HANA vendor/partner master alignment.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the interpretation and enforcement of this agreement. Critical for cross-border portfolio legal compliance and dispute resolution.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawState rdf:type rdf:Property ;
    rdfs:label 'Governing Law State' ;
    rdfs:comment 'State or province within the governing law country whose laws apply to this agreement. Relevant for US-based agreements where state franchise disclosure laws (FDD requirements) apply.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialTermYears rdf:type rdf:Property ;
    rdfs:label 'Initial Term Years' ;
    rdfs:comment 'Duration in years of the initial franchise or management contract term as specified in the agreement. Typically ranges from 10 to 30 years for franchise agreements. Used for portfolio lifecycle planning and IFRS 16 lease accounting where applicable.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastBrandAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Brand Audit Date' ;
    rdfs:comment 'Date of the most recent brand standards quality assurance audit conducted by the franchisor at this property. Used to track compliance status and schedule next audit cycle per agreement requirements.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liquidatedDamagesAmount rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Amount' ;
    rdfs:comment 'Pre-agreed liquidated damages amount payable upon early termination of the agreement by the franchisee or property owner. Expressed in agreement currency. Critical for portfolio risk assessment and financial exposure reporting under SOX.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyFeePct rdf:type rdf:Property ;
    rdfs:label 'Loyalty Fee Pct' ;
    rdfs:comment 'Percentage of revenue from loyalty member stays payable to the franchisor for loyalty program administration, points redemption funding, and member benefits. Tracked in Salesforce CRM loyalty management and SAP S/4HANA.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementFeeBasePct rdf:type rdf:Property ;
    rdfs:label 'Management Fee Base Pct' ;
    rdfs:comment 'Base management fee as a percentage of total gross revenue payable to the management company under a management contract agreement. Applicable only when agreement_type is management_contract. Reported under USALI management fee accounting.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementFeeIncentivePct rdf:type rdf:Property ;
    rdfs:label 'Management Fee Incentive Pct' ;
    rdfs:comment 'Incentive management fee as a percentage of GOP (Gross Operating Profit) or NOI (Net Operating Income) payable to the management company when performance thresholds are exceeded. Applicable for management contract agreements. Aligns with USALI GOP reporting.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingFeePct rdf:type rdf:Property ;
    rdfs:label 'Marketing Fee Pct' ;
    rdfs:comment 'Percentage of gross room revenue payable to the franchisor\'s brand marketing fund. Covers national and global advertising, loyalty program marketing, and brand awareness campaigns. Reported under USALI franchise cost accounting.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextBrandAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Brand Audit Date' ;
    rdfs:comment 'Scheduled date for the next brand standards quality assurance audit. Supports proactive compliance management and operational readiness planning.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Pip Budget Amount' ;
    rdfs:comment 'Total approved CapEx (Capital Expenditure) budget for PIP (Property Improvement Plan) obligations under this agreement, expressed in the agreement currency. Tracked in SAP S/4HANA asset management and reported under USALI FF&E accounting.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pip Completion Date' ;
    rdfs:comment 'Contractually required completion date for all PIP (Property Improvement Plan) obligations specified in the franchise or management contract agreement. Null if pip_required is false. Tracks CapEx compliance milestones.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipRequired rdf:type rdf:Property ;
    rdfs:label 'Pip Required' ;
    rdfs:comment 'Indicates whether a PIP (Property Improvement Plan) is mandated as a condition of this franchise or management contract agreement. PIP obligations are typically triggered at agreement signing, renewal, or brand standard compliance review.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pmsSystemRequired rdf:type rdf:Property ;
    rdfs:label 'Pms System Required' ;
    rdfs:comment 'Name or code of the Property Management System (PMS) mandated by the franchisor as a brand standard technology requirement under this agreement (e.g., Oracle OPERA PMS). Supports technology compliance tracking and integration planning.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceScoreMin rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Score Min' ;
    rdfs:comment 'Minimum quality assurance (QA) inspection score the property must maintain to remain in compliance with brand standards under this agreement. Failure to meet this threshold may trigger a cure period or termination clause.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalOptionCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Count' ;
    rdfs:comment 'Number of renewal option periods available to the franchisee or property owner upon expiration of the initial term. Supports portfolio renewal pipeline management and long-term asset planning.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalTermYears rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Years' ;
    rdfs:comment 'Duration in years of each renewal option period as specified in the agreement. Combined with renewal_option_count to determine maximum potential agreement duration for portfolio planning.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservationFeePct rdf:type rdf:Property ;
    rdfs:label 'Reservation Fee Pct' ;
    rdfs:comment 'Percentage of gross room revenue or per-reservation fee payable to the franchisor for CRS (Central Reservation System) and GDS (Global Distribution System) distribution services. Aligns with Sabre SynXis CRS fee structures.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyFeePct rdf:type rdf:Property ;
    rdfs:label 'Royalty Fee Pct' ;
    rdfs:comment 'Percentage of gross room revenue payable to the franchisor as a royalty fee under the franchise agreement. Expressed as a decimal (e.g., 0.0500 = 5.00%). Core financial obligation tracked in SAP S/4HANA AP and reported under USALI franchise cost accounting.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance written notice required by either party to invoke termination of the agreement without cause. Supports legal compliance tracking and portfolio risk management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Textual description of the exclusive or protected geographic territory granted under this agreement, if applicable. May reference radius in miles/kilometers, zip codes, or defined market boundaries. Null if exclusive_territory is false.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsProfileId rdf:type rdf:Property ;
    rdfs:label 'Gds Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the GDS/CRS property profile record in the Silver layer lakehouse. Primary key for this entity. Entity role: MASTER_RESOURCE — represents a property listing/distribution profile asset managed and distributed across GDS and CRS channels.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amadeusPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Amadeus Property Code' ;
    rdfs:comment 'The property identifier specific to the Amadeus GDS network. May differ from the Sabre GDS property code. Used for Amadeus channel distribution, rate loading, and availability display to travel agents on the Amadeus platform.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTime rdf:type rdf:Property ;
    rdfs:label 'Check In Time' ;
    rdfs:comment 'The standard guest check-in time for the property in HH:MM (24-hour) format as published in GDS and OTA channel profiles. Displayed to guests and travel agents during the booking process to set arrival expectations.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkOutTime rdf:type rdf:Property ;
    rdfs:label 'Check Out Time' ;
    rdfs:comment 'The standard guest check-out time for the property in HH:MM (24-hour) format as published in GDS and OTA channel profiles. Displayed to guests and travel agents during the booking process to set departure expectations.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cityCode rdf:type rdf:Property ;
    rdfs:label 'City Code' ;
    rdfs:comment 'The IATA or GDS city/airport code associated with the property location (e.g., \'NYC\', \'LON\', \'PAR\'). Used by GDS systems to associate the property with a travel destination for search and booking purposes.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cityName rdf:type rdf:Property ;
    rdfs:label 'City Name' ;
    rdfs:comment 'The full city name of the property location as displayed in GDS and OTA channel listings. Supports geographic search and filtering in distribution channels.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'The property name as it appears in GDS and CRS search results and booking screens. This is the consumer-facing name used by travel agents and OTA partners. May differ from the legal property name or internal operating name.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelType rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Type' ;
    rdfs:comment 'Indicates the primary distribution channel scope this profile record covers. \'gds\' = GDS-only profile (Sabre/Amadeus/Galileo); \'crs\' = CRS direct booking profile; \'ota\' = OTA partner profile; \'direct\' = brand.com direct booking; \'all\' = unified profile across all channels.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'The fax number for the property as listed in GDS channel profiles. Used by travel agents and corporate accounts for reservation confirmations and group booking correspondence. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorCount rdf:type rdf:Property ;
    rdfs:label 'Floor Count' ;
    rdfs:comment 'The total number of floors in the main hotel building as published in GDS and OTA channel profiles. Used by travel agents and guests for property orientation and accessibility planning.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:galileoPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Galileo Property Code' ;
    rdfs:comment 'The property identifier specific to the Galileo/Travelport GDS network. Used for Travelport channel distribution, rate loading, and availability display to travel agents on the Galileo platform.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Gds Property Code' ;
    rdfs:comment 'The unique property identifier assigned within the GDS network (Sabre, Amadeus, Galileo/Travelport). This code is used by travel agents and OTA partners to look up and book the property across GDS channels. Sourced from Sabre SynXis CRS channel configuration.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasAirportShuttle rdf:type rdf:Property ;
    rdfs:label 'Has Airport Shuttle' ;
    rdfs:comment 'Indicates whether the property offers complimentary or paid airport shuttle service as published in GDS and OTA amenity flags. Used by travel agents and guests to filter properties by transportation amenities.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasFitnessCenter rdf:type rdf:Property ;
    rdfs:label 'Has Fitness Center' ;
    rdfs:comment 'Indicates whether the property has a fitness center or gym as published in GDS and OTA amenity flags. Used by travel agents and guests to filter properties by wellness amenities. Sourced from Sabre SynXis CRS amenity configuration.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasMeetingFacilities rdf:type rdf:Property ;
    rdfs:label 'Has Meeting Facilities' ;
    rdfs:comment 'Indicates whether the property has meeting rooms or conference facilities (MICE — Meetings, Incentives, Conferences, Exhibitions) as published in GDS and OTA amenity flags. Used by corporate travel agents and event planners to filter properties for group and event bookings.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasParking rdf:type rdf:Property ;
    rdfs:label 'Has Parking' ;
    rdfs:comment 'Indicates whether the property offers on-site parking (self-park or valet) as published in GDS and OTA amenity flags. Used by travel agents and guests to filter properties by parking availability.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPool rdf:type rdf:Property ;
    rdfs:label 'Has Pool' ;
    rdfs:comment 'Indicates whether the property has a swimming pool as published in GDS and OTA amenity flags. Used by travel agents and guests to filter properties by recreational amenities. Sourced from Sabre SynXis CRS amenity configuration.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heroImageUrl rdf:type rdf:Property ;
    rdfs:label 'Hero Image Url' ;
    rdfs:comment 'The URL of the primary hero/banner image displayed on GDS and OTA property listing pages. This is the main visual asset representing the property in channel distribution. Must be a publicly accessible HTTPS URL conforming to OTA image specification standards.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPetFriendly rdf:type rdf:Property ;
    rdfs:label 'Is Pet Friendly' ;
    rdfs:comment 'Indicates whether the property accepts pets as published in GDS and OTA amenity flags. Used by travel agents and guests to filter properties by pet policy. Sourced from Sabre SynXis CRS amenity configuration.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'The full marketing narrative for the property displayed on GDS detail screens and OTA property pages. Covers property overview, location highlights, accommodation types, dining, recreation, and meeting facilities. Supports channel distribution and OTA partnership management.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Profile Effective Date' ;
    rdfs:comment 'The date from which this GDS/CRS property profile version became active and live for distribution across GDS and OTA channels. Used for profile versioning, content audit trails, and channel distribution management.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Profile Expiry Date' ;
    rdfs:comment 'The date on which this GDS/CRS property profile version expires or is scheduled for deactivation. Nullable for open-ended active profiles. Used for profile lifecycle management and scheduled content refresh cycles.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:propertyCategory rdf:type rdf:Property ;
    rdfs:label 'Property Category' ;
    rdfs:comment 'The GDS/OTA property category classification used to filter search results. Determines how the property is categorized in GDS and OTA search interfaces. Aligned with OTA (OpenTravel Alliance) property type codes.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationEmail rdf:type rdf:Property ;
    rdfs:label 'Reservation Email' ;
    rdfs:comment 'The reservations department email address for the property as listed in GDS and OTA channel profiles. Used by travel agents and corporate accounts for booking inquiries and group reservation correspondence. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:GdsProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRoomCount rdf:type rdf:Property ;
    rdfs:label 'Total Room Count' ;
    rdfs:comment 'The total number of guest rooms and suites at the property as published in GDS and OTA channel profiles. Used by travel agents for property selection and by revenue management for inventory benchmarking. Represents the principal quantitative fact (MEASUREMENT_OR_VALUE) for this MASTER_RESOURCE.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjacentPrefunctionSpace rdf:type rdf:Property ;
    rdfs:label 'Adjacent Prefunction Space' ;
    rdfs:comment 'Indicates whether the meeting space has an adjacent pre-function or foyer area for registration, breaks, or networking.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutCapability rdf:type rdf:Property ;
    rdfs:label 'Blackout Capability' ;
    rdfs:comment 'Indicates whether the space can be fully darkened using blackout curtains or shades. Critical for presentations and AV-heavy events.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:builtinAvEquipment rdf:type rdf:Property ;
    rdfs:label 'Builtin Av Equipment' ;
    rdfs:comment 'Description of permanently installed AV equipment in the space (e.g., projector, screen, sound system, microphones, video conferencing). Comma-separated list.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cateringRequired rdf:type rdf:Property ;
    rdfs:label 'Catering Required' ;
    rdfs:comment 'Indicates whether food and beverage (F&B) catering is mandatory when booking this space. Common for ballrooms and premium spaces.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:climateControlType rdf:type rdf:Property ;
    rdfs:label 'Climate Control Type' ;
    rdfs:comment 'Type of heating, ventilation, and air conditioning (HVAC) control available (individual thermostat, shared zone control, or none).' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedWifiBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Dedicated Wifi Bandwidth Mbps' ;
    rdfs:comment 'Dedicated internet bandwidth available for the meeting space measured in Mbps. Null if shared bandwidth or not applicable.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyExitCount rdf:type rdf:Property ;
    rdfs:label 'Emergency Exit Count' ;
    rdfs:comment 'Number of emergency exits available in the meeting space. Required for fire safety compliance and event planning.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entranceWidthInches rdf:type rdf:Property ;
    rdfs:label 'Entrance Width Inches' ;
    rdfs:comment 'Width of the main entrance door measured in inches. Important for accessibility compliance and equipment load-in.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fireCapacityLimit rdf:type rdf:Property ;
    rdfs:label 'Fire Capacity Limit' ;
    rdfs:comment 'Maximum occupancy allowed by local fire safety codes and building regulations. Must not be exceeded regardless of setup style.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadingDockAccess rdf:type rdf:Property ;
    rdfs:label 'Loading Dock Access' ;
    rdfs:comment 'Indicates whether the meeting space has direct or convenient access to a loading dock for equipment and material delivery.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meetingSpaceStatus rdf:type rdf:Property ;
    rdfs:label 'Meeting Space Status' ;
    rdfs:comment 'Current operational status of the meeting space. Determines availability for booking and event planning.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCateringSpend rdf:type rdf:Property ;
    rdfs:label 'Minimum Catering Spend' ;
    rdfs:comment 'Minimum food and beverage spend required when booking this space. Null if no minimum or catering not required.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRentalHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Rental Hours' ;
    rdfs:comment 'Minimum number of hours the space must be rented for a single event. Used for revenue management and booking policies.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfSections rdf:type rdf:Property ;
    rdfs:label 'Number Of Sections' ;
    rdfs:comment 'Number of separate sections the space can be divided into when partitions are deployed. Null if space is not divisible.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rentalRateTier rdf:type rdf:Property ;
    rdfs:label 'Rental Rate Tier' ;
    rdfs:comment 'Pricing tier classification for the meeting space rental. Actual rates are managed in rate tables and vary by season, day of week, and booking terms.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Total Square Footage' ;
    rdfs:comment 'Total area of the meeting space measured in square feet. Critical for capacity planning and event layout design.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wifiAvailable rdf:type rdf:Property ;
    rdfs:label 'Wifi Available' ;
    rdfs:comment 'Indicates whether wireless internet connectivity is available in the meeting space. Essential for modern business events.' ;
    rdfs:domain ind:MeetingSpace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the ownership entity structure. REIT (Real Estate Investment Trust) for publicly traded entities like Host Hotels or Park Hotels, private equity for PE-backed funds, individual for owner-operators, joint venture for multi-party ownership, institutional investor for pension funds or insurance companies, family office for high-net-worth family investment vehicles.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentVehicleName rdf:type rdf:Property ;
    rdfs:label 'Investment Vehicle Name' ;
    rdfs:comment 'Name of the specific investment fund, REIT portfolio, or investment vehicle through which the entity holds properties. Used for portfolio segmentation and fund-level performance reporting.' ;
    rdfs:domain ind:OwnershipEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementCompanyAffiliation rdf:type rdf:Property ;
    rdfs:label 'Management Company Affiliation' ;
    rdfs:comment 'Name of the property management company or hotel management firm affiliated with or contracted by the ownership entity. Used to identify management relationships and operational oversight structures.' ;
    rdfs:domain ind:OwnershipEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipNotes rdf:type rdf:Property ;
    rdfs:label 'Ownership Notes' ;
    rdfs:comment 'Free-text field for additional ownership details, special arrangements, joint venture terms, or other contextual information relevant to the ownership entity.' ;
    rdfs:domain ind:OwnershipEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Current lifecycle status of the ownership entity within the portfolio. Active indicates current ownership, inactive for historical records, pending acquisition for entities in due diligence, divested for sold assets, under review for entities undergoing restructuring or compliance review.' ;
    rdfs:domain ind:OwnershipEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioAcquisitionValueUsd rdf:type rdf:Property ;
    rdfs:label 'Portfolio Acquisition Value Usd' ;
    rdfs:comment 'Total acquisition cost in USD for all properties owned by this entity. Aggregated value used for ROI calculations, EBITDA analysis, and investment performance tracking.' ;
    rdfs:domain ind:OwnershipEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the legal registered address for the ownership entity. Used for legal correspondence, tax filings, and franchise agreement documentation.' ;
    rdfs:domain ind:OwnershipEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the legal registered address (suite, floor, building) for the ownership entity. Optional field for additional address details.' ;
    rdfs:domain ind:OwnershipEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City of the legal registered address for the ownership entity.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the legal registered address of the ownership entity (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the legal registered address for the ownership entity.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'State or province of the legal registered address for the ownership entity. Used for state-level tax reporting and regulatory compliance.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reitComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Reit Compliance Flag' ;
    rdfs:comment 'Indicates whether the ownership entity is subject to REIT regulatory compliance requirements (e.g., income distribution rules, asset composition tests). True for entities that must comply with REIT regulations.' ;
    rdfs:domain ind:OwnershipEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Sox Compliance Required' ;
    rdfs:comment 'Indicates whether the ownership entity is subject to Sarbanes-Oxley Act financial controls and reporting requirements. True for publicly traded entities or entities with publicly traded parent companies.' ;
    rdfs:domain ind:OwnershipEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Federal tax identification number (EIN in USA) or equivalent tax identifier for the ownership entity. Used for tax reporting, franchise agreements, and financial compliance.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPropertiesOwned rdf:type rdf:Property ;
    rdfs:label 'Total Properties Owned' ;
    rdfs:comment 'Current count of properties owned by this entity within the portfolio. Used for portfolio concentration analysis and ownership diversification metrics.' ;
    rdfs:domain ind:OwnershipEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pipItemId rdf:type rdf:Property ;
    rdfs:label 'Pip Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual line-item work scope record within a Property Improvement Plan (PIP). Primary key for this entity.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipItem .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'The SAP S/4HANA fixed asset number assigned to the asset created or replaced by this PIP item upon capitalization. Links the PIP line item to the property\'s fixed asset register for depreciation scheduling and asset lifecycle management.' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Requirement Flag' ;
    rdfs:comment 'Indicates whether this PIP item is mandated by the brand franchisor as a condition of franchise agreement compliance (True) or is an ownership-initiated discretionary improvement (False). Brand-required items carry compliance deadlines and potential franchise termination risk if not completed.' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capexBudgetCode rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Code' ;
    rdfs:comment 'The SAP S/4HANA internal order or WBS (Work Breakdown Structure) element code to which this PIP item\'s costs are allocated. Enables precise CapEx budget tracking, cost center assignment, and financial reporting per USALI and SOX requirements.' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'The date by which this PIP item must be completed to satisfy brand franchisor compliance requirements. Failure to meet this deadline may result in franchise agreement penalties, brand standard deficiency notices, or franchise termination proceedings.' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractorName rdf:type rdf:Property ;
    rdfs:label 'Contractor Name' ;
    rdfs:comment 'The name of the primary contractor or vendor responsible for executing the work scope for this PIP item. Used for contractor performance tracking, lien waiver management, and procurement compliance. Sourced from SAP S/4HANA Vendor Master.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralReason rdf:type rdf:Property ;
    rdfs:label 'Deferral Reason' ;
    rdfs:comment 'Narrative explanation for why this PIP item has been deferred beyond its original scheduled completion date. Required for brand franchisor approval of deferrals and for ownership reporting on PIP execution delays. Populated only when item_status is \'deferred\'.' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Deferred Completion Date' ;
    rdfs:comment 'The revised target completion date approved by the brand franchisor for a deferred PIP item. Replaces the original scheduled_completion_date as the binding compliance deadline when a deferral has been formally granted.' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifeSafetyFlag rdf:type rdf:Property ;
    rdfs:label 'Life Safety Flag' ;
    rdfs:comment 'Indicates whether this PIP item addresses a life safety, fire code, ADA accessibility, or OSHA regulatory compliance requirement (True). Life safety items are treated as critical priority and may not be deferred without regulatory authority approval.' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:propertyArea rdf:type rdf:Property ;
    rdfs:label 'Property Area' ;
    rdfs:comment 'The physical area or zone of the property affected by this PIP line item. Drives scheduling coordination with hotel operations to minimize guest impact. [ENUM-REF-CANDIDATE: guestroom|lobby|corridor|exterior|food_and_beverage|meeting_space|fitness_center|pool|back_of_house|spa|parking|landscaping — promote to reference product]' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListNotes rdf:type rdf:Property ;
    rdfs:label 'Punch List Notes' ;
    rdfs:comment 'Free-text notes documenting outstanding deficiencies, remediation requirements, or conditional items identified during brand inspection or internal quality review. Captures specific corrective actions required before final acceptance of this PIP item.' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Date' ;
    rdfs:comment 'The planned date by which this PIP line item is expected to be fully completed and ready for inspection. Used for milestone tracking, brand compliance deadline management, and rooms-out-of-order (OOO) planning to minimize RevPAR impact.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Flag' ;
    rdfs:comment 'Indicates whether this PIP item contributes to the property\'s sustainability or energy efficiency program (True), such as LED lighting upgrades, low-flow plumbing fixtures, or HVAC efficiency improvements. Supports ESG reporting and green certification tracking.' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workType rdf:type rdf:Property ;
    rdfs:label 'Work Type' ;
    rdfs:comment 'Classification of the nature of work required for this PIP item. Distinguishes between full replacement, renovation/refresh, new installation, repair, technology upgrade, or regulatory compliance work. Drives cost estimation methodology and contractor selection.' ;
    rdfs:domain ind:PipItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Spend To Date' ;
    rdfs:comment 'Cumulative actual capital expenditure incurred on the project to date in USD, tracked for budget variance analysis.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adaComplianceIncluded rdf:type rdf:Property ;
    rdfs:label 'Ada Compliance Included' ;
    rdfs:comment 'Indicates whether the project scope includes ADA accessibility improvements or compliance upgrades.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedBudget rdf:type rdf:Property ;
    rdfs:label 'Approved Budget' ;
    rdfs:comment 'Formally approved capital budget for the project in USD, authorized by ownership or executive management.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Status' ;
    rdfs:comment 'Current status of the property\'s compliance with brand standards relative to this PIP: compliant (meets standards), non-compliant (deficiencies exist), pending-review (under brand evaluation), waived (exemption granted), or not-applicable (non-branded property).' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStandardComplianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Compliance Deadline' ;
    rdfs:comment 'Date by which the property must complete the PIP to maintain brand compliance and avoid penalties or franchise termination.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Contractor License Number' ;
    rdfs:comment 'State or local license number of the general contractor, required for regulatory compliance and vendor management.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedRoiPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Roi Percentage' ;
    rdfs:comment 'Projected return on investment percentage for the capital improvement project, calculated from expected revenue lift and cost savings against total CapEx.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ffeActualSpend rdf:type rdf:Property ;
    rdfs:label 'Ffe Actual Spend' ;
    rdfs:comment 'Actual expenditure on furniture, fixtures, and equipment to date, used for budget variance tracking.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ffeBudget rdf:type rdf:Property ;
    rdfs:label 'Ffe Budget' ;
    rdfs:comment 'Allocated budget specifically for furniture, fixtures, and equipment purchases as part of the capital improvement project, tracked separately from construction costs.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fireSafetyUpgradeIncluded rdf:type rdf:Property ;
    rdfs:label 'Fire Safety Upgrade Included' ;
    rdfs:comment 'Indicates whether the project scope includes fire safety system upgrades or compliance work.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactedAreas rdf:type rdf:Property ;
    rdfs:label 'Impacted Areas' ;
    rdfs:comment 'Comma-separated list or narrative of physical areas affected by the project, such as guest rooms, lobby, F&B outlets, meeting spaces, back-of-house, or exterior.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opexImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Opex Impact Estimate' ;
    rdfs:comment 'Estimated change in annual operating expenses (positive or negative) resulting from the capital improvement, used for ROI and payback period calculations.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paybackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Payback Period Months' ;
    rdfs:comment 'Estimated number of months required to recover the capital investment through incremental revenue and cost savings.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiration Date' ;
    rdfs:comment 'Date the construction permit expires, requiring renewal if work extends beyond this date.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitIssueDate rdf:type rdf:Property ;
    rdfs:label 'Permit Issue Date' ;
    rdfs:comment 'Date the construction permit was issued by local regulatory authorities.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Project Manager Email' ;
    rdfs:comment 'Primary email address of the project manager for communication and coordination.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerName rdf:type rdf:Property ;
    rdfs:label 'Project Manager Name' ;
    rdfs:comment 'Name of the individual responsible for managing and coordinating the capital improvement project.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Project Manager Phone' ;
    rdfs:comment 'Primary contact phone number for the project manager.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name or title of the improvement project for reporting and communication purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Project Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for the capital improvement project, used across finance, operations, and brand compliance systems.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the capital improvement project: draft (planning), approved (authorized), in-progress (active work), on-hold (temporarily suspended), completed (finished), cancelled (terminated), or waived (brand exemption granted). [ENUM-REF-CANDIDATE: draft|approved|in_progress|on_hold|completed|cancelled|waived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Discriminator for the kind of capital improvement project: brand-mandated PIP, owner-initiated renovation, infrastructure upgrade, technology upgrade, or regulatory compliance project.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Projected Completion Date' ;
    rdfs:comment 'Estimated date for project completion, used for operational planning and room inventory availability forecasting.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueDisplacementEstimate rdf:type rdf:Property ;
    rdfs:label 'Revenue Displacement Estimate' ;
    rdfs:comment 'Estimated total revenue loss in USD due to rooms out of service and operational disruption during the project, critical for financial impact analysis and GOP forecasting.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomsOutOfServiceCount rdf:type rdf:Property ;
    rdfs:label 'Rooms Out Of Service Count' ;
    rdfs:comment 'Number of guest rooms temporarily unavailable during the project execution, critical for revenue displacement forecasting and occupancy planning.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeOfWorkSummary rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Summary' ;
    rdfs:comment 'Detailed narrative description of the planned capital improvements, including areas, systems, and deliverables covered by the project.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertificationTarget rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Target' ;
    rdfs:comment 'Target environmental or sustainability certification the project aims to achieve (e.g., LEED, Green Key, EarthCheck), if applicable.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEstimatedCapex rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Capex' ;
    rdfs:comment 'Initial estimated total capital expenditure for the project in USD, used for budgeting and financial planning.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggeringEvent rdf:type rdf:Property ;
    rdfs:label 'Triggering Event' ;
    rdfs:comment 'Business event or condition that initiated the PIP or capital project, such as ownership transition, periodic brand review, guest satisfaction decline, or regulatory mandate.' ;
    rdfs:domain ind:PipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosEmail rdf:type rdf:Property ;
    rdfs:label 'Dos Email' ;
    rdfs:comment 'The business email address of the Director of Sales (DOS) for this property. Used for group lead routing, RFP notifications, and sales performance reporting distribution via Salesforce CRM and Delphi by Amadeus.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosName rdf:type rdf:Property ;
    rdfs:label 'Dos Name' ;
    rdfs:comment 'The full name of the Director of Sales (DOS) responsible for group, corporate, and MICE sales for this property. Used for Delphi by Amadeus event sales routing, Salesforce CRM account ownership, and sales performance reporting.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Number' ;
    rdfs:comment 'The unique identifier of the franchise license agreement governing the property\'s brand affiliation. Populated only when is_franchised is true. Used for franchise compliance tracking, royalty fee calculation, and brand standards audit management.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmEmail rdf:type rdf:Property ;
    rdfs:label 'Gm Email' ;
    rdfs:comment 'The business email address of the current General Manager (GM). Used for operational communications, escalation routing, and executive reporting. Classified as confidential PII as it identifies a specific individual.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmName rdf:type rdf:Property ;
    rdfs:label 'Gm Name' ;
    rdfs:comment 'The full name of the current General Manager (GM) responsible for the property\'s overall operations. Used for operational escalations, regulatory correspondence, and executive reporting. Classified confidential as an internal business contact.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFranchised rdf:type rdf:Property ;
    rdfs:label 'Is Franchised' ;
    rdfs:comment 'Indicates whether the property operates under a franchise agreement with the brand. When true, franchise fee structures, brand standards compliance, and PIP obligations apply. Drives franchise royalty reporting and brand audit scheduling.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:largestMeetingRoomSqft rdf:type rdf:Property ;
    rdfs:label 'Largest Meeting Room Sqft' ;
    rdfs:comment 'The square footage of the largest single meeting or ballroom space at the property. Used for group sales qualification, event capacity planning, and MICE marketing collateral.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operaPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Opera Property Code' ;
    rdfs:comment 'The unique alphanumeric property code assigned within Oracle OPERA PMS. This is the operational system-of-record identifier used for front desk, reservations, cashiering, and housekeeping transactions. Serves as the primary integration key between the lakehouse and OPERA.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBrandGroup rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Group' ;
    rdfs:comment 'The name of the parent hotel company or brand group that owns the brand (e.g., Hilton Worldwide, Marriott International, Hyatt Hotels Corporation). Supports portfolio-level reporting and corporate hierarchy analytics.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipStatus rdf:type rdf:Property ;
    rdfs:label 'Pip Status' ;
    rdfs:comment 'The current status of the Property Improvement Plan (PIP) for this property. PIPs are typically required at franchise renewal, ownership transfer, or brand standard updates. Drives CapEx budget planning and franchise compliance monitoring.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyName rdf:type rdf:Property ;
    rdfs:label 'Property Name' ;
    rdfs:comment 'The full official trading name of the hotel, resort, or vacation property as displayed to guests, on signage, and in all guest-facing communications. This is the authoritative display name used across all channels.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyType rdf:type rdf:Property ;
    rdfs:label 'Property Type' ;
    rdfs:comment 'The physical and operational type of the property asset. Drives applicable operating procedures, amenity expectations, and regulatory requirements. [ENUM-REF-CANDIDATE: hotel|resort|extended_stay|vacation_property|boutique|conference_center — promote to reference product]' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Revenue Manager Email' ;
    rdfs:comment 'The business email address of the Revenue Manager for this property. Used for IDeaS G3 RMS notifications, rate strategy communications, and revenue performance reporting distribution.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueManagerName rdf:type rdf:Property ;
    rdfs:label 'Revenue Manager Name' ;
    rdfs:comment 'The full name of the Revenue Manager responsible for pricing, forecasting, and inventory controls for this property. Used for IDeaS G3 RMS access provisioning, escalation routing, and revenue strategy accountability.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentClassification rdf:type rdf:Property ;
    rdfs:label 'Segment Classification' ;
    rdfs:comment 'The operational segment classification of the property indicating service level and market positioning. Used for USALI-aligned financial reporting, revenue management strategy, and portfolio segmentation. [ENUM-REF-CANDIDATE: luxury|premium|upper_upscale|upscale|select_service|extended_stay|resort — promote to reference product]' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Str Property Code' ;
    rdfs:comment 'The unique property identifier assigned by STR (Smith Travel Research) for inclusion in the STAR Report competitive benchmarking program. Required for RGI (Revenue Generation Index), MPI (Market Penetration Index), and ARI (Average Rate Index) reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synxisPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Synxis Property Code' ;
    rdfs:comment 'The property identifier assigned within Sabre SynXis CRS used for central reservations, channel management, and rate distribution. Required for reconciling CRS bookings to the property master record.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'The IANA time zone identifier for the property\'s local time zone (e.g., America/New_York, Europe/London). Critical for accurate check-in/check-out timestamp processing, night audit scheduling, and revenue management rate activation timing.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFloorCount rdf:type rdf:Property ;
    rdfs:label 'Total Floor Count' ;
    rdfs:comment 'The total number of floors in the main hotel tower or building. Used for housekeeping scheduling, elevator capacity planning, and emergency evacuation planning per local fire safety and building codes.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMeetingSpaceSqft rdf:type rdf:Property ;
    rdfs:label 'Total Meeting Space Sqft' ;
    rdfs:comment 'The total square footage of all meeting, conference, and event spaces within the property. Key metric for MICE (Meetings, Incentives, Conferences, Exhibitions) sales, group evaluation, and event revenue forecasting in Delphi by Amadeus.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSuiteCount rdf:type rdf:Property ;
    rdfs:label 'Total Suite Count' ;
    rdfs:comment 'The number of suite-category rooms within the total room inventory. Used for premium inventory management, upsell strategy, and suite-specific RevPAR reporting.' ;
    rdfs:domain ind:Property ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each node in the property organizational and operational hierarchy. Serves as the primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentNodeHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Node Hierarchy Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent node in the hierarchy tree. Null for the corporate root node. Enables recursive parent-child traversal for consolidated reporting of RevPAR, ADR, OCC, and GOP across organizational tiers.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:brandPortfolio rdf:type rdf:Property ;
    rdfs:label 'Brand Portfolio' ;
    rdfs:comment 'Name of the brand portfolio or brand family associated with this hierarchy node (e.g., \'Luxury Collection\', \'Premium Brands\', \'Select Service\'). Applicable to division and region nodes that manage a specific brand segment. Supports brand-level performance reporting and portfolio analytics.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainScale rdf:type rdf:Property ;
    rdfs:label 'Chain Scale' ;
    rdfs:comment 'STR-defined chain scale classification for this hierarchy node, indicating the service and price tier of properties within this node. Used for competitive benchmarking, STR STAR Report alignment, and brand portfolio segmentation. Values align with STR\'s standard chain scale categories.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearStartMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Start Month' ;
    rdfs:comment 'Month number (1-12) indicating the start of the fiscal year for this hierarchy node. Supports USALI-aligned financial period reporting and SAP S/4HANA fiscal year variant configuration for nodes that operate on non-calendar fiscal years.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Major geographic region classification for this hierarchy node, aligned with STR geographic hierarchy and internal management reporting structures. Used for regional KPI roll-ups and competitive benchmarking via STR STAR Reports. [ENUM-REF-CANDIDATE: Americas|EMEA|APAC|GREATER_CHINA|MEA|EUROPE|NORTH_AMERICA|LATIN_AMERICA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReportingNode rdf:type rdf:Property ;
    rdfs:label 'Is Reporting Node' ;
    rdfs:comment 'Indicates whether this hierarchy node is designated as a formal reporting node for consolidated KPI roll-ups (RevPAR, ADR, OCC, GOP). True for nodes that appear in management reporting packages; False for intermediate structural nodes used only for hierarchy traversal.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrMarketNode rdf:type rdf:Property ;
    rdfs:label 'Is Str Market Node' ;
    rdfs:comment 'Indicates whether this hierarchy node corresponds to a defined STR competitive market for benchmarking purposes. True for nodes that are directly mapped to an STR market for RGI, MPI, and ARI reporting via STR STAR Reports.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiRollupMethod rdf:type rdf:Property ;
    rdfs:label 'Kpi Rollup Method' ;
    rdfs:comment 'Method used to aggregate KPIs (RevPAR, ADR, OCC, GOP) from child nodes to this parent node. \'sum\' for absolute metrics (room revenue, GOP); \'weighted_average\' for rate-based metrics (ADR, RevPAR) weighted by available rooms; \'simple_average\' for index metrics; \'none\' for leaf nodes with no children.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementType rdf:type rdf:Property ;
    rdfs:label 'Management Type' ;
    rdfs:comment 'Operational management structure classification for this hierarchy node. \'owned\' indicates company-owned assets; \'managed\' indicates third-party owner with management contract; \'franchised\' indicates franchise agreement; \'leased\' indicates leasehold arrangement; \'joint_venture\' indicates shared ownership structure. Critical for financial consolidation and USALI reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this hierarchy node across systems (e.g., CRS, PMS, ERP). Used as the business key for cross-system integration and reporting roll-ups. Aligns with SAP S/4HANA profit center codes and Oracle OPERA PMS property codes.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeDescription rdf:type rdf:Property ;
    rdfs:label 'Node Description' ;
    rdfs:comment 'Free-text description providing additional context about this hierarchy node, including its geographic scope, strategic purpose, or operational characteristics. Used for documentation, onboarding, and BI tool tooltips.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name of the hierarchy node (e.g., \'Americas Region\', \'EMEA Division\', \'Southeast Asia Cluster\', \'Grand Hyatt New York\'). Used in management reporting, dashboards, and consolidated KPI roll-ups.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of the hierarchy node. \'active\' indicates the node is operational and included in reporting; \'inactive\' indicates it has been decommissioned; \'pending\' indicates a newly created node awaiting activation; \'dissolved\' indicates a node that has been merged or restructured out of the hierarchy.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the hierarchy node indicating its organizational level. \'corporate\' is the top-level portfolio node; \'region\' represents major geographic divisions (Americas, EMEA, APAC); \'division\' is a sub-regional grouping; \'area_office\' is a local management unit; \'cluster\' is a grouping of nearby properties; \'property\' is an individual hotel or resort asset.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Materialized full path string from the root node to this node using delimiter-separated node codes (e.g., \'CORP/AMER/USEAST/NYC-CLUSTER\'). Enables efficient subtree queries and breadcrumb navigation in BI tools without recursive joins.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Segment Code' ;
    rdfs:comment 'Internal financial reporting segment code assigned to this hierarchy node, aligned with SAP S/4HANA profit center and segment reporting structures. Used for USALI-compliant financial consolidation, EBITDA and NOI reporting, and SOX-compliant segment disclosures.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleExecutive rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive' ;
    rdfs:comment 'Name of the senior executive accountable for this hierarchy node (e.g., Regional Vice President, Area General Manager, General Manager). Used for management reporting accountability, escalation routing, and organizational governance.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleExecutiveEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive Email' ;
    rdfs:comment 'Corporate email address of the executive accountable for this hierarchy node. Used for automated reporting distribution, escalation notifications, and governance communications.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleExecutiveTitle rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive Title' ;
    rdfs:comment 'Official job title of the executive accountable for this hierarchy node (e.g., \'Senior Vice President - Americas\', \'Area General Manager - Southeast Asia\'). Supports organizational chart generation and governance documentation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restructureReason rdf:type rdf:Property ;
    rdfs:label 'Restructure Reason' ;
    rdfs:comment 'Free-text description of the business reason for any hierarchy restructuring event affecting this node (e.g., regional reorganization, brand portfolio realignment, merger, acquisition, or divestiture). Supports audit trail and change management documentation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Sap Profit Center Code' ;
    rdfs:comment 'SAP S/4HANA profit center code mapped to this hierarchy node for financial consolidation, USALI-aligned P&L reporting, and management accounting. Enables direct linkage between the property hierarchy and SAP financial reporting structures for EBITDA, NOI, and GOPPAR analysis.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strGeographicCode rdf:type rdf:Property ;
    rdfs:label 'Str Geographic Code' ;
    rdfs:comment 'STR-assigned geographic market code for this hierarchy node, used to align internal organizational hierarchy with STR competitive benchmarking markets. Enables direct mapping to STR STAR Report data for Revenue Generation Index (RGI), Market Penetration Index (MPI), and Average Rate Index (ARI) benchmarking.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strMarketName rdf:type rdf:Property ;
    rdfs:label 'Str Market Name' ;
    rdfs:comment 'Human-readable STR market name corresponding to the STR geographic code (e.g., \'New York City\', \'London\', \'Singapore\'). Used in competitive benchmarking reports and STR STAR Report alignment for RevPAR and ADR market comparisons.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaId rdf:type rdf:Property ;
    rdfs:label 'Media Id' ;
    rdfs:comment 'Unique identifier for the property media asset record. Primary key.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'Proportional relationship between width and height (e.g., 16:9, 4:3) used for responsive display optimization.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandWebsiteApproved rdf:type rdf:Property ;
    rdfs:label 'Brand Website Approved' ;
    rdfs:comment 'Flag indicating whether the media asset is approved for display on the brand.com direct booking website.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caption rdf:type rdf:Property ;
    rdfs:label 'Caption' ;
    rdfs:comment 'Marketing caption or description text displayed with the media asset on guest-facing channels.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureDate rdf:type rdf:Property ;
    rdfs:label 'Capture Date' ;
    rdfs:comment 'Date when the photo or video was originally captured, used for content freshness tracking.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdnPath rdf:type rdf:Property ;
    rdfs:label 'Cdn Path' ;
    rdfs:comment 'CDN-optimized path for fast global delivery of the media asset to OTA (Online Travel Agency) and brand.com channels.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original file name of the media asset as stored in the DAM system.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsApproved rdf:type rdf:Property ;
    rdfs:label 'Gds Approved' ;
    rdfs:comment 'Flag indicating whether the media asset is approved for syndication to GDS channels (Amadeus, Sabre, Galileo).' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHeroImage rdf:type rdf:Property ;
    rdfs:label 'Is Hero Image' ;
    rdfs:comment 'Flag indicating whether this media asset is the primary hero image for the property used in search results and main property pages.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'Date when the usage license for the media asset expires, requiring renewal or removal from channels.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Type of usage license governing how the media asset can be used and distributed.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaCategory rdf:type rdf:Property ;
    rdfs:label 'Media Category' ;
    rdfs:comment 'Functional area or space that the media asset depicts, used for organizing content by property feature. [ENUM-REF-CANDIDATE: property_exterior|lobby|guestroom|suite|pool|fitness_center|restaurant|meeting_space|spa|amenity|event_space|other — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaStatus rdf:type rdf:Property ;
    rdfs:label 'Media Status' ;
    rdfs:comment 'Current lifecycle status of the media asset in the content management workflow.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'Classification of the media asset type used for content management and channel distribution.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaApproved rdf:type rdf:Property ;
    rdfs:label 'Ota Approved' ;
    rdfs:comment 'Flag indicating whether the media asset is approved for syndication to OTA partner channels (Expedia, Booking.com, etc.).' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photographerName rdf:type rdf:Property ;
    rdfs:label 'Photographer Name' ;
    rdfs:comment 'Name of the photographer or content creator who produced the media asset, used for attribution and rights management.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionHeight rdf:type rdf:Property ;
    rdfs:label 'Resolution Height' ;
    rdfs:comment 'Height of the media asset in pixels, used for quality control and channel distribution requirements.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionWidth rdf:type rdf:Property ;
    rdfs:label 'Resolution Width' ;
    rdfs:comment 'Width of the media asset in pixels, used for quality control and channel distribution requirements.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seoKeywords rdf:type rdf:Property ;
    rdfs:label 'Seo Keywords' ;
    rdfs:comment 'Keywords associated with the media asset for search engine optimization and discoverability on brand.com and OTA platforms.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of descriptive tags for content categorization, search optimization, and channel filtering (e.g., luxury, family-friendly, beachfront).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadDate rdf:type rdf:Property ;
    rdfs:label 'Upload Date' ;
    rdfs:comment 'Date when the media asset was uploaded to the DAM (Digital Asset Management) system.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:viewCount rdf:type rdf:Property ;
    rdfs:label 'View Count' ;
    rdfs:comment 'Total number of times the media asset has been viewed across all distribution channels, used for content performance analytics.' ;
    rdfs:domain ind:Media ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alcoholServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol Service Flag' ;
    rdfs:comment 'Indicates whether the outlet is licensed to serve alcoholic beverages. True if alcohol service is permitted.' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageCheckAmount rdf:type rdf:Property ;
    rdfs:label 'Average Check Amount' ;
    rdfs:comment 'Average guest check amount for the outlet. Used for revenue forecasting and performance benchmarking. Expressed in property base currency.' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryServiceAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Service Available Flag' ;
    rdfs:comment 'Indicates whether the outlet offers delivery service to guest rooms or external locations. True if delivery is available.' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Health Permit Number' ;
    rdfs:comment 'Health department permit number for food service operations. Required for Food and Beverage (F&B) outlets.' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Liquor License Number' ;
    rdfs:comment 'Official liquor license number issued by the local regulatory authority. Required for outlets serving alcohol.' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Eligible Flag' ;
    rdfs:comment 'Indicates whether purchases at this outlet are eligible for loyalty program points accrual. True if loyalty points can be earned.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:menuUrl rdf:type rdf:Property ;
    rdfs:label 'Menu Url' ;
    rdfs:comment 'Web address where the outlet\'s current menu can be accessed. Applicable to Food and Beverage (F&B) outlets.' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileOrderingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Mobile Ordering Enabled Flag' ;
    rdfs:comment 'Indicates whether the outlet supports mobile ordering through the property\'s mobile application or third-party platforms. True if mobile ordering is available.' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the outlet. Format varies by property but typically includes days of week and time ranges (e.g., Mon-Fri 6:00 AM - 10:00 PM).' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outdoorSeatingFlag rdf:type rdf:Property ;
    rdfs:label 'Outdoor Seating Flag' ;
    rdfs:comment 'Indicates whether the outlet offers outdoor seating. True if outdoor seating is available.' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posSystemCode rdf:type rdf:Property ;
    rdfs:label 'Pos System Code' ;
    rdfs:comment 'Identifier of the Point of Sale (POS) system instance used by this outlet. Typically references Oracle Hospitality MICROS POS system configuration.' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateDiningAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Private Dining Available Flag' ;
    rdfs:comment 'Indicates whether the outlet offers private dining rooms or spaces for exclusive events. True if private dining is available.' ;
    rdfs:domain ind:PropertyOutlet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Operation Flag' ;
    rdfs:comment 'Indicates whether the outlet operates on a seasonal schedule (e.g., summer only, winter only). True if seasonal.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalCalendarId rdf:type rdf:Property ;
    rdfs:label 'Seasonal Calendar Id' ;
    rdfs:comment 'Unique identifier for the seasonal calendar entry. Primary key for the seasonal calendar product.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationRatePct rdf:type rdf:Property ;
    rdfs:label 'Cancellation Rate Pct' ;
    rdfs:comment 'Historical cancellation rate for reservations during this seasonal period expressed as a percentage. Used for overbooking strategy and revenue forecasting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateDescription rdf:type rdf:Property ;
    rdfs:label 'Climate Description' ;
    rdfs:comment 'Description of typical weather and climate conditions during this seasonal period (e.g., Warm and Sunny, Rainy Season, Snow Season, Hurricane Risk). Used for guest communication and operational planning.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveSetPosition rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Position' ;
    rdfs:comment 'Property\'s expected market position relative to its STR competitive set during this seasonal period. Values: leader (outperforming), competitive (at par), lagging (underperforming), premium (high-end positioning), value (budget positioning).' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandClassification rdf:type rdf:Property ;
    rdfs:label 'Demand Classification' ;
    rdfs:comment 'Categorization of expected demand level during this seasonal period. Drives pricing strategy, staffing models, and inventory controls. Values: peak (high demand), shoulder (moderate demand), off-peak (low demand), super-peak (exceptional demand). [ENUM-REF-CANDIDATE: peak|shoulder|off-peak|super-peak|low|moderate|high — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAdr rdf:type rdf:Property ;
    rdfs:label 'Estimated Adr' ;
    rdfs:comment 'Forecasted Average Daily Rate for this seasonal period in the property\'s local currency. Used for revenue forecasting and rate strategy validation.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedOccupancyPct rdf:type rdf:Property ;
    rdfs:label 'Estimated Occupancy Pct' ;
    rdfs:comment 'Forecasted occupancy rate for this seasonal period expressed as a percentage. Used for revenue forecasting, staffing planning, and inventory management. Based on historical performance and market trends.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedRevpar rdf:type rdf:Property ;
    rdfs:label 'Estimated Revpar' ;
    rdfs:comment 'Forecasted Revenue Per Available Room for this seasonal period in the property\'s local currency. Key performance indicator for revenue management strategy validation.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityClosures rdf:type rdf:Property ;
    rdfs:label 'Facility Closures' ;
    rdfs:comment 'Comma-separated list of facilities or outlets that are closed during this seasonal period (e.g., Outdoor Pool, Beach Bar, Tennis Courts). Used for guest communication and operational planning.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayName rdf:type rdf:Property ;
    rdfs:label 'Holiday Name' ;
    rdfs:comment 'Name of the holiday or special event if this is a holiday period (e.g., Christmas, New Year, Independence Day, Local Festival). Null if not a holiday period.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlackoutDate rdf:type rdf:Property ;
    rdfs:label 'Is Blackout Date' ;
    rdfs:comment 'Indicates whether this period is designated as a blackout date for promotional rates, loyalty redemptions, or discounted packages. Used to protect revenue during high-demand periods.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHolidayPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Period' ;
    rdfs:comment 'Flag indicating whether this seasonal period includes major holidays or special events that drive exceptional demand. Used for premium pricing and staffing adjustments.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSegmentFocus rdf:type rdf:Property ;
    rdfs:label 'Market Segment Focus' ;
    rdfs:comment 'Primary market segment(s) targeted during this seasonal period (e.g., Leisure, Business, Group, MICE, FIT). Comma-separated if multiple segments. Drives marketing and sales strategy.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLosRestriction rdf:type rdf:Property ;
    rdfs:label 'Maximum Los Restriction' ;
    rdfs:comment 'Maximum number of nights allowed for reservations during this seasonal period. Used to prevent long-stay bookings from blocking high-demand dates. Null if no maximum restriction applies.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumLosRestriction rdf:type rdf:Property ;
    rdfs:label 'Minimum Los Restriction' ;
    rdfs:comment 'Minimum number of nights required for reservations during this seasonal period. Used to optimize revenue during high-demand periods. Null if no minimum restriction applies.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noShowRatePct rdf:type rdf:Property ;
    rdfs:label 'No Show Rate Pct' ;
    rdfs:comment 'Historical no-show rate for reservations during this seasonal period expressed as a percentage. Used for overbooking strategy and revenue optimization.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingStatus rdf:type rdf:Property ;
    rdfs:label 'Operating Status' ;
    rdfs:comment 'Operational mode of the property during this seasonal period. Indicates whether full services are available or if there are seasonal closures or reduced operations.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSeasonCode rdf:type rdf:Property ;
    rdfs:label 'Rate Season Code' ;
    rdfs:comment 'Rate season identifier used by the Revenue Management System (RMS) to apply appropriate Best Available Rate (BAR) levels and dynamic pricing rules. Maps to IDeaS G3 RMS rate season configuration.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reducedOperatingHours rdf:type rdf:Property ;
    rdfs:label 'Reduced Operating Hours' ;
    rdfs:comment 'Description of any reduced operating hours for facilities or services during this seasonal period (e.g., Restaurant: Dinner Only, Spa: Weekends Only). Null if no reductions apply.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'Short alphanumeric code identifying the season (e.g., PEAK_SUM, SHOULDER_SPR, OFF_WIN). Used for rate plan mapping and operational planning.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Descriptive name of the seasonal period (e.g., Summer Peak Season, Winter Off-Peak, Holiday Super Peak). Human-readable label for reporting and communication.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonYear rdf:type rdf:Property ;
    rdfs:label 'Season Year' ;
    rdfs:comment 'Calendar year to which this seasonal period applies. Supports year-over-year comparison and multi-year planning.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalCalendarStatus rdf:type rdf:Property ;
    rdfs:label 'Seasonal Calendar Status' ;
    rdfs:comment 'Current lifecycle status of this seasonal calendar entry. Values: active (in use), draft (being planned), archived (historical), cancelled (no longer applicable).' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalHiringRequired rdf:type rdf:Property ;
    rdfs:label 'Seasonal Hiring Required' ;
    rdfs:comment 'Indicates whether additional seasonal staff hiring is required for this period. Used by HR and workforce planning teams to initiate recruitment.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialEvents rdf:type rdf:Property ;
    rdfs:label 'Special Events' ;
    rdfs:comment 'Description of major local or property-specific events occurring during this seasonal period that impact demand (e.g., Annual Music Festival, Marathon Weekend, Convention Center Trade Show). Null if no special events.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffingLevel rdf:type rdf:Property ;
    rdfs:label 'Staffing Level' ;
    rdfs:comment 'Planned staffing level for this seasonal period. Drives workforce scheduling and seasonal hiring decisions. Values: full (standard staffing), reduced (lower than standard), minimal (skeleton crew), peak-augmented (additional seasonal staff).' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yoyDemandTrend rdf:type rdf:Property ;
    rdfs:label 'Yoy Demand Trend' ;
    rdfs:comment 'Trend classification comparing this season\'s expected demand to the same period in the prior year. Used for strategic planning and market positioning. Values: increasing (demand up), stable (demand flat), decreasing (demand down), volatile (unpredictable), new-season (no historical data).' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yoyDemandVariancePct rdf:type rdf:Property ;
    rdfs:label 'Yoy Demand Variance Pct' ;
    rdfs:comment 'Percentage change in expected demand compared to the same seasonal period in the prior year. Positive values indicate growth, negative values indicate decline. Null for new seasons without historical data.' ;
    rdfs:domain ind:SeasonalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingPackageId rdf:type rdf:Property ;
    rdfs:label 'Booking Package Id' ;
    rdfs:comment 'Unique identifier for the booking package record. Primary key.' ;
    rdfs:domain ind:BookingPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationDeadline rdf:type rdf:Property ;
    rdfs:label 'Cancellation Deadline' ;
    rdfs:comment 'Date and time by which the package can be cancelled without penalty. Used for revenue management and guest communication.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:componentList rdf:type rdf:Property ;
    rdfs:label 'Component List' ;
    rdfs:comment 'Comma-separated or structured list of individual components included in the package (e.g., breakfast for 2, spa credit $100, parking, airport transfer). Used for operational fulfillment.' ;
    rdfs:domain ind:BookingPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentInstructions rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Instructions' ;
    rdfs:comment 'Operational instructions for property staff on how to deliver and track package components. May include Point of Sale (POS) codes, voucher numbers, or service delivery notes.' ;
    rdfs:domain ind:BookingPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInclusive rdf:type rdf:Property ;
    rdfs:label 'Is Inclusive' ;
    rdfs:comment 'Indicates whether the package rate is included in the room rate (true) or charged separately (false). Affects Average Daily Rate (ADR) calculation.' ;
    rdfs:domain ind:BookingPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otherRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Other Revenue Amount' ;
    rdfs:comment 'Portion of package revenue allocated to other departments (spa, golf, activities, parking, etc.) for Total Revenue Per Available Room (TRevPAR) calculation.' ;
    rdfs:domain ind:BookingPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageCategory rdf:type rdf:Property ;
    rdfs:label 'Package Category' ;
    rdfs:comment 'Classification of the package type for reporting and revenue allocation purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCostAmount rdf:type rdf:Property ;
    rdfs:label 'Package Cost Amount' ;
    rdfs:comment 'Total cost to the property for delivering the package components. Used for Gross Operating Profit (GOP) calculation.' ;
    rdfs:domain ind:BookingPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'Detailed description of the package contents, inclusions, terms, and conditions. Used for guest communication and operational fulfillment.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageRateAmount rdf:type rdf:Property ;
    rdfs:label 'Package Rate Amount' ;
    rdfs:comment 'Total monetary value of the package charged to the guest. Represents the package price component of the reservation.' ;
    rdfs:domain ind:BookingPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingRhythm rdf:type rdf:Property ;
    rdfs:label 'Posting Rhythm' ;
    rdfs:comment 'Frequency and timing rule for posting package charges to the guest folio. Determines revenue recognition timing.' ;
    rdfs:domain ind:BookingPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Allocation Method' ;
    rdfs:comment 'Method for allocating package revenue across departments (rooms, Food and Beverage (F&B), spa, etc.) per Uniform System of Accounts for the Lodging Industry (USALI) standards.' ;
    rdfs:domain ind:BookingPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomsRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Rooms Revenue Amount' ;
    rdfs:comment 'Portion of package revenue allocated to the Rooms department for Revenue Per Available Room (RevPAR) and departmental reporting.' ;
    rdfs:domain ind:BookingPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxInclusive rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive' ;
    rdfs:comment 'Indicates whether the package rate amount includes applicable taxes (true) or taxes are calculated separately (false).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookingStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Booking Status History Id' ;
    rdfs:comment 'Primary key for booking_status_history' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'For cancellation events, the specific reason code (e.g., GUEST_CANCEL, WEATHER, EMERGENCY, DUPLICATE_BOOKING, RATE_ISSUE). Null for non-cancellation events.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Notification Sent Flag' ;
    rdfs:comment 'Indicates whether an automated notification (email, SMS, push) was sent to the guest for this event. True if sent, False otherwise.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Guest Notification Timestamp' ;
    rdfs:comment 'The date and time when the guest notification was sent. Null if no notification was sent.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modificationFieldName rdf:type rdf:Property ;
    rdfs:label 'Modification Field Name' ;
    rdfs:comment 'For modification events, the specific field or attribute that was changed (e.g., arrival_date, room_type_code, rate_code, number_of_adults). Enables granular change tracking.' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationType rdf:type rdf:Property ;
    rdfs:label 'Modification Type' ;
    rdfs:comment 'For modification events, specifies the category of amendment: date_change (arrival/departure dates), room_type_change (upgrade/downgrade), rate_plan_change (rate code switch), occupancy_change (number of guests), special_request_update (preferences), guest_name_change (name correction), payment_method_change (guarantee method), package_change (package modification), add_on_change (ancillary services). Null for non-modification events. [ENUM-REF-CANDIDATE: date_change|room_type_change|rate_plan_change|occupancy_change|special_request_update|guest_name_change|payment_method_change|package_change|add_on_change — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The reservation status after this event. Represents the current state of the booking at the time of this history record. [ENUM-REF-CANDIDATE: inquiry|tentative|waitlisted|confirmed|guaranteed|modified|cancelled|no_show|checked_in|checked_out|due_in|due_out — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noShowReasonCode rdf:type rdf:Property ;
    rdfs:label 'No Show Reason Code' ;
    rdfs:comment 'For no-show events, the reason code (e.g., NO_CONTACT, FLIGHT_DELAY, GUEST_FORGOT, DUPLICATE_BOOKING). Null for non-no-show events.' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalValue rdf:type rdf:Property ;
    rdfs:label 'Original Value' ;
    rdfs:comment 'For modification events, the value of the field before the change. Stored as string to accommodate various data types. Null for non-modification events.' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Fee Amount' ;
    rdfs:comment 'For cancellation or modification events, any penalty or change fee assessed per the rate plan rules. Zero if no penalty applies.' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The reservation status immediately before this event. Null for the initial status record. Values align with Oracle OPERA PMS reservation status codes. [ENUM-REF-CANDIDATE: inquiry|tentative|waitlisted|confirmed|guaranteed|modified|cancelled|no_show|checked_in|checked_out|due_in|due_out — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Difference Amount' ;
    rdfs:comment 'For modification events, the monetary difference between the original and new rate (positive for increase, negative for decrease). Null for non-rate-change events.' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'The estimated revenue impact of this event (positive for revenue gain, negative for revenue loss). Calculated based on rate changes, cancellations, and penalties.' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaActualMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Minutes' ;
    rdfs:comment 'The actual processing time in minutes from event initiation to completion. Used to measure SLA performance.' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'The source system or interface that generated this event (e.g., OPERA_PMS for front desk, SYNXIS_CRS for central reservations, MOBILE_APP for guest self-service).' ;
    rdfs:domain ind:BookingStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Status' ;
    rdfs:comment 'Current status of the dispute resolution process (open, resolved in guest favor, resolved in property favor, or withdrawn by guest).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeChargeProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Guarantee Charge Processed Flag' ;
    rdfs:comment 'Indicates whether the guarantee charge (penalty or no-show fee) was successfully processed against the guarantee method.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guaranteeMethod rdf:type rdf:Property ;
    rdfs:label 'Guarantee Method' ;
    rdfs:comment 'Method used to guarantee the reservation (credit card, deposit, corporate guarantee, travel agent guarantee, or none). Critical for no-show charge processing.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaChargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Ota Chargeback Amount' ;
    rdfs:comment 'Monetary amount charged back to the OTA for commission recovery on this cancellation or no-show.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otaChargebackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Ota Chargeback Eligible Flag' ;
    rdfs:comment 'Indicates whether the property is eligible to charge back the commission to the OTA for this cancellation or no-show per the OTA contract terms.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable Flag' ;
    rdfs:comment 'Indicates whether a cancellation penalty or no-show fee is applicable based on the policy and timing of the event.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingChannel rdf:type rdf:Property ;
    rdfs:label 'Processing Channel' ;
    rdfs:comment 'Channel through which the cancellation or no-show was processed (PMS - Property Management System, CRS - Central Reservation System, OTA - Online Travel Agency, GDS - Global Distribution System, call center, mobile app, web). [ENUM-REF-CANDIDATE: pms|crs|ota|gds|call_center|mobile_app|web — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Monetary amount refunded to the guest after applicable penalties, in the property\'s base currency.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Eligible Flag' ;
    rdfs:comment 'Indicates whether the guest is eligible for a refund of any prepaid amounts after penalty deduction.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueLostAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Lost Amount' ;
    rdfs:comment 'Total room revenue lost due to the cancellation or no-show, calculated from the original reservation rate and length of stay.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date when the penalty charge was reversed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roomNightsLost rdf:type rdf:Property ;
    rdfs:label 'Room Nights Lost' ;
    rdfs:comment 'Number of room nights lost due to the cancellation or no-show, calculated as the difference between arrival and departure dates.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Authorized By' ;
    rdfs:comment 'Name or identifier of the manager or agent who authorized the penalty waiver.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Indicates whether the cancellation penalty or no-show fee was waived by the property.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverReasonCode rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for waiving the penalty (e.g., LOYALTY_STATUS, EMERGENCY, SERVICE_RECOVERY, MANAGER_DISCRETION).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowHours rdf:type rdf:Property ;
    rdfs:label 'Window Hours' ;
    rdfs:comment 'Number of hours before arrival that the cancellation occurred, used to evaluate penalty applicability per the cancellation policy.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allowsModification rdf:type rdf:Property ;
    rdfs:label 'Allows Modification' ;
    rdfs:comment 'Indicates whether reservations under this policy allow date or room type modifications without cancellation. False for most non-refundable policies.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToCorporateBookings rdf:type rdf:Property ;
    rdfs:label 'Applies To Corporate Bookings' ;
    rdfs:comment 'Indicates whether this policy can be applied to corporate negotiated rate bookings. Corporate accounts may have special cancellation terms.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToGroupBookings rdf:type rdf:Property ;
    rdfs:label 'Applies To Group Bookings' ;
    rdfs:comment 'Indicates whether this policy can be applied to group block reservations. Group policies often have different terms than individual FIT (Free Independent Traveler) bookings.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositDueDaysBeforeArrival rdf:type rdf:Property ;
    rdfs:label 'Deposit Due Days Before Arrival' ;
    rdfs:comment 'Number of days before arrival date by which the deposit must be received. Null indicates deposit due at time of booking.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depositPercentage rdf:type rdf:Property ;
    rdfs:label 'Deposit Percentage' ;
    rdfs:comment 'Percentage of total reservation value required as deposit when deposit_required is true. Value stored as decimal (e.g., 100.00 for full prepayment).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositRequired rdf:type rdf:Property ;
    rdfs:label 'Deposit Required' ;
    rdfs:comment 'Indicates whether an advance deposit payment is required at time of booking under this policy. Common for non-refundable and group bookings.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeCancellationWindowDays rdf:type rdf:Property ;
    rdfs:label 'Free Cancellation Window Days' ;
    rdfs:comment 'Number of days before scheduled arrival date during which a guest can cancel without penalty. Alternative to hours-based window for longer lead-time policies.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freeCancellationWindowHours rdf:type rdf:Property ;
    rdfs:label 'Free Cancellation Window Hours' ;
    rdfs:comment 'Number of hours before scheduled arrival time during which a guest can cancel without penalty. Null indicates no free cancellation window.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guaranteeRequired rdf:type rdf:Property ;
    rdfs:label 'Guarantee Required' ;
    rdfs:comment 'Indicates whether a payment guarantee (credit card, deposit, or prepayment) is required to book under this cancellation policy. Typically true for stricter policies.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestFacingSummary rdf:type rdf:Property ;
    rdfs:label 'Guest Facing Summary' ;
    rdfs:comment 'Concise, guest-friendly summary of the cancellation policy displayed during booking process. Typically 1-2 sentences highlighting key terms.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNonRefundable rdf:type rdf:Property ;
    rdfs:label 'Is Non Refundable' ;
    rdfs:comment 'Indicates whether this policy represents a non-refundable rate where no refund is provided under any circumstances. True for NRR (Non-Refundable Rate) policies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalTermsText rdf:type rdf:Property ;
    rdfs:label 'Legal Terms Text' ;
    rdfs:comment 'Full legal terms and conditions text for the cancellation policy, including jurisdiction-specific consumer protection disclosures required by GDPR, CCPA, and local regulations.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationFee rdf:type rdf:Property ;
    rdfs:label 'Modification Fee' ;
    rdfs:comment 'Fixed fee charged for modifying a reservation when allows_modification is true. Null if no modification fee applies. Currency is property base currency.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'No Show Penalty Amount' ;
    rdfs:comment 'Fixed monetary penalty charged for no-show when no_show_penalty_type is flat_fee. Currency is property base currency per USALI standards.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowPenaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'No Show Penalty Percentage' ;
    rdfs:comment 'Percentage of total reservation value charged as penalty for no-show when no_show_penalty_type is percentage_of_stay. Value stored as decimal.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowPenaltyType rdf:type rdf:Property ;
    rdfs:label 'No Show Penalty Type' ;
    rdfs:comment 'Type of penalty applied when a guest fails to arrive (no-show). May differ from standard cancellation penalty to account for lost revenue opportunity.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyNightsCount rdf:type rdf:Property ;
    rdfs:label 'Penalty Nights Count' ;
    rdfs:comment 'Number of nights charged as penalty when penalty_type is first_night or nights_based. Typically 1 for first night penalty, can be higher for stricter policies.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Penalty Percentage' ;
    rdfs:comment 'Percentage of total reservation value charged as penalty when penalty_type is percentage_of_stay. Value stored as decimal (e.g., 50.00 for 50%).' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'Type of penalty applied when cancellation occurs outside the free cancellation window. Determines how the cancellation charge is calculated.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyTier rdf:type rdf:Property ;
    rdfs:label 'Policy Tier' ;
    rdfs:comment 'Classification tier of the cancellation policy indicating the level of flexibility offered to guests. Aligned with revenue management strategy and rate plan positioning.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Seasonal Override Allowed' ;
    rdfs:comment 'Indicates whether this policy can be overridden by seasonal or event-specific cancellation rules during high-demand periods.' ;
    rdfs:domain ind:CancellationPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositLedgerId rdf:type rdf:Property ;
    rdfs:label 'Deposit Ledger Id' ;
    rdfs:comment 'Unique identifier for the deposit ledger entry. Primary key for the deposit ledger transaction record.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedToFolioDate rdf:type rdf:Property ;
    rdfs:label 'Applied To Folio Date' ;
    rdfs:comment 'The date when the deposit was applied to the guest folio. Marks the transition from advance deposit liability to revenue or accounts receivable offset.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardLastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Card Last Four Digits' ;
    rdfs:comment 'Last four digits of the payment card used for the deposit. Stored for guest reference and dispute resolution while maintaining PCI compliance.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Deposit Policy Code' ;
    rdfs:comment 'Code identifying the deposit policy applied to this reservation. Determines deposit amount, due date, and cancellation terms.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositStatus rdf:type rdf:Property ;
    rdfs:label 'Deposit Status' ;
    rdfs:comment 'Current lifecycle status of the deposit. Tracks progression from due through collection, application to folio, or refund/forfeiture.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositType rdf:type rdf:Property ;
    rdfs:label 'Deposit Type' ;
    rdfs:comment 'Classification of the deposit based on its business purpose. Determines handling rules, refund policies, and revenue recognition treatment.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forfeitureAmount rdf:type rdf:Property ;
    rdfs:label 'Forfeiture Amount' ;
    rdfs:comment 'The monetary value of the deposit that was forfeited due to cancellation policy or no-show. Recognized as revenue per cancellation terms.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forfeitureDate rdf:type rdf:Property ;
    rdfs:label 'Forfeiture Date' ;
    rdfs:comment 'The date when the deposit was forfeited. Triggers revenue recognition and updates reservation status to cancelled or no-show.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forfeitureReason rdf:type rdf:Property ;
    rdfs:label 'Forfeiture Reason' ;
    rdfs:comment 'Business reason for deposit forfeiture. Used for policy compliance tracking, revenue analysis, and guest communication.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'The date when the deposit refund was processed. Used for cash flow tracking and guest satisfaction monitoring.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Reference Number' ;
    rdfs:comment 'External reference number for the refund transaction from the payment processor. Used for refund reconciliation and audit trails.' ;
    rdfs:domain ind:DepositLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupBlockPickupId rdf:type rdf:Property ;
    rdfs:label 'Group Block Pickup Id' ;
    rdfs:comment 'Unique identifier for the group block pickup transaction. Primary key for this entity.' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Block Utilization Percentage' ;
    rdfs:comment 'Percentage of the total group block consumed at the time of this pickup. Calculated as (total_block_rooms - remaining_block_rooms) / total_block_rooms * 100.' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupAttendeeType rdf:type rdf:Property ;
    rdfs:label 'Group Attendee Type' ;
    rdfs:comment 'Classification of the attendee role within the group event. Supports rooming list segmentation and billing allocation. [ENUM-REF-CANDIDATE: attendee|speaker|organizer|exhibitor|sponsor|staff|guest — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeType rdf:type rdf:Property ;
    rdfs:label 'Guarantee Type' ;
    rdfs:comment 'Method used to guarantee the pickup reservation. Critical for no-show risk assessment and revenue assurance.' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestEmail rdf:type rdf:Property ;
    rdfs:label 'Guest Email' ;
    rdfs:comment 'Primary email address for the guest on this pickup reservation. Used for confirmation and pre-arrival communication.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestName rdf:type rdf:Property ;
    rdfs:label 'Guest Name' ;
    rdfs:comment 'Full name of the guest associated with this pickup reservation. Used for rooming list management and guest communication.' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestPhone rdf:type rdf:Property ;
    rdfs:label 'Guest Phone' ;
    rdfs:comment 'Primary contact phone number for the guest. Critical for day-of-arrival communication and service recovery.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nights rdf:type rdf:Property ;
    rdfs:label 'Nights' ;
    rdfs:comment 'Total number of room nights consumed by this pickup. Calculated as departure_date minus arrival_date. Key metric for group block utilization.' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noShowFlag rdf:type rdf:Property ;
    rdfs:label 'No Show Flag' ;
    rdfs:comment 'Indicates whether the guest failed to arrive for this pickup reservation. Critical for no-show rate tracking and revenue recovery.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickupBeforeCutoffFlag rdf:type rdf:Property ;
    rdfs:label 'Pickup Before Cutoff Flag' ;
    rdfs:comment 'Indicates whether this pickup occurred before the group block cutoff date. Used to assess on-time pickup performance.' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickupNumber rdf:type rdf:Property ;
    rdfs:label 'Pickup Number' ;
    rdfs:comment 'Business-readable identifier for the pickup transaction, typically generated by the Property Management System (PMS) or Central Reservation System (CRS).' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupStatus rdf:type rdf:Property ;
    rdfs:label 'Pickup Status' ;
    rdfs:comment 'Current lifecycle status of the pickup reservation. Tracks progression from initial booking through completion or cancellation. [ENUM-REF-CANDIDATE: confirmed|tentative|cancelled|no_show|checked_in|checked_out|waitlisted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pickup Timestamp' ;
    rdfs:comment 'Date and time when the individual reservation was booked against the group block inventory. Critical for tracking pickup velocity and cutoff date management.' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'Nightly room rate applied to this pickup reservation. Used to calculate total room revenue and compare against Best Available Rate (BAR).' ;
    rdfs:domain ind:GroupBlockPickup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketSegmentId rdf:type rdf:Property ;
    rdfs:label 'Market Segment Id' ;
    rdfs:comment 'Foreign key reference to the market segment classification for this reservation (transient, group, corporate, leisure, government, etc.). Used for revenue management segmentation and forecasting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketSegment .

ind:accessibilityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Required Flag' ;
    rdfs:comment 'Indicates whether the guest has requested an ADA-compliant accessible room. Used for room assignment and compliance with Americans with Disabilities Act requirements.' ;
    rdfs:domain ind:ReservationBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crsConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Crs Confirmation Number' ;
    rdfs:comment 'Confirmation number generated by Sabre SynXis CRS for reservations originating through the central reservation system. Used for cross-system reconciliation and channel attribution.' ;
    rdfs:domain ind:ReservationBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyCheckinRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Early Checkin Requested Flag' ;
    rdfs:comment 'Indicates whether the guest has requested early check-in (before standard check-in time). Used for operational planning and guest service recovery.' ;
    rdfs:domain ind:ReservationBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateCheckoutRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Late Checkout Requested Flag' ;
    rdfs:comment 'Indicates whether the guest has requested late check-out (after standard check-out time). Used for housekeeping scheduling and room availability management.' ;
    rdfs:domain ind:ReservationBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modification Timestamp' ;
    rdfs:comment 'Date and time of the most recent modification to this reservation (date change, rate change, guest change, etc.). Used for audit trail and change tracking.' ;
    rdfs:domain ind:ReservationBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:numberOfAdults rdf:type rdf:Property ;
    rdfs:label 'Number Of Adults' ;
    rdfs:comment 'Count of adult guests (typically age 18+) included in this reservation. Used for occupancy reporting, F&B forecasting, and compliance with fire safety regulations.' ;
    rdfs:domain ind:ReservationBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfChildren rdf:type rdf:Property ;
    rdfs:label 'Number Of Children' ;
    rdfs:comment 'Count of child guests (typically under age 18) included in this reservation. Used for amenity planning, F&B forecasting, and family-friendly service delivery.' ;
    rdfs:domain ind:ReservationBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pmsReservationCode rdf:type rdf:Property ;
    rdfs:label 'Pms Reservation Code' ;
    rdfs:comment 'Native reservation identifier from Oracle OPERA PMS. Used for operational lookups and integration with front desk, housekeeping, and cashiering modules.' ;
    rdfs:domain ind:ReservationBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Room Type Requested' ;
    rdfs:comment 'Code representing the room type requested by the guest at time of booking (e.g., KING, QUEEN, SUITE, DELUXE). May differ from actual room type assigned at check-in.' ;
    rdfs:domain ind:ReservationBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attritionClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Attrition Clause Flag' ;
    rdfs:comment 'Indicates whether the group block contract includes an attrition clause requiring minimum room pickup or penalties.' ;
    rdfs:domain ind:ReservationGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickupRoomCount rdf:type rdf:Property ;
    rdfs:label 'Pickup Room Count' ;
    rdfs:comment 'The number of rooms from the block that have been booked or picked up by the group as of the current date.' ;
    rdfs:domain ind:ReservationGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Forecast Amount' ;
    rdfs:comment 'The forecasted total revenue expected from this group block based on contracted rooms and rates.' ;
    rdfs:domain ind:ReservationGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:washScheduleDate rdf:type rdf:Property ;
    rdfs:label 'Wash Schedule Date' ;
    rdfs:comment 'The date on which the group block inventory is scheduled to be washed or adjusted based on pickup performance.' ;
    rdfs:domain ind:ReservationGroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationRatePlanId rdf:type rdf:Property ;
    rdfs:label 'Reservation Rate Plan Id' ;
    rdfs:comment 'Unique identifier for the reservation rate plan record. Primary key for this entity.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelCorporateFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Corporate Flag' ;
    rdfs:comment 'Indicates whether this rate plan is available for booking through corporate direct billing channels. Requires corporate account setup and negotiated rate agreement.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelDirectFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Direct Flag' ;
    rdfs:comment 'Indicates whether this rate plan is available for booking through direct channels (property website, call center, front desk). True for most rate plans; false for channel-exclusive rates.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelGdsFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Gds Flag' ;
    rdfs:comment 'Indicates whether this rate plan is available for booking through GDS channels (Sabre, Amadeus, Galileo, Worldspan). Typically used for corporate and travel agent bookings.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelGroupFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Group Flag' ;
    rdfs:comment 'Indicates whether this rate plan is available for group block bookings through MICE and event sales channels. Managed via Delphi by Amadeus for group inventory allocation.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelOtaFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Ota Flag' ;
    rdfs:comment 'Indicates whether this rate plan is available for booking through OTA channels (Expedia, Booking.com, etc.). Subject to rate parity agreements and channel management rules.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionableFlag rdf:type rdf:Property ;
    rdfs:label 'Commissionable Flag' ;
    rdfs:comment 'Indicates whether bookings under this rate plan are eligible for travel agent or OTA commission. True for most OTA and GDS rates; false for net rates and direct promotional rates.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guaranteeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Guarantee Required Flag' ;
    rdfs:comment 'Indicates whether a payment guarantee (credit card, deposit, or prepayment) is required at the time of booking for this rate plan. True for most rate plans; false for select corporate or group rates with direct billing arrangements.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Eligible Flag' ;
    rdfs:comment 'Indicates whether stays booked under this rate plan are eligible for loyalty program points accrual and elite benefits. True for most direct and qualified rates; false for opaque and deeply discounted rates.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumLengthOfStay rdf:type rdf:Property ;
    rdfs:label 'Maximum Length Of Stay' ;
    rdfs:comment 'Maximum number of nights allowed for a booking under this rate plan. Used to prevent long-stay bookings from blocking high-value short-stay demand. Null indicates no maximum restriction.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Member Only Flag' ;
    rdfs:comment 'Indicates whether this rate plan is exclusively available to loyalty program members. True for member-exclusive rates; false for public rates.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumLengthOfStay rdf:type rdf:Property ;
    rdfs:label 'Minimum Length Of Stay' ;
    rdfs:comment 'Minimum number of nights required for a booking under this rate plan. Used for revenue optimization during high-demand periods. Null or 1 indicates no minimum restriction.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Package Inclusion Flag' ;
    rdfs:comment 'Indicates whether this rate plan includes bundled amenities, services, or F&B components (e.g., breakfast included, spa credit, parking). True for package rates; false for room-only rates.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratePlanCategory rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Category' ;
    rdfs:comment 'High-level classification of the rate plan type for segmentation and reporting. Standard includes BAR and rack rates; corporate includes negotiated business rates; promotional includes limited-time offers; package includes bundled F&B or amenities; group includes MICE block rates; wholesale includes tour operator allotments; opaque includes non-branded OTA rates; member includes loyalty program rates; government includes public sector rates. [ENUM-REF-CANDIDATE: standard|corporate|promotional|package|group|wholesale|opaque|member|government — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Description' ;
    rdfs:comment 'Detailed business description of the rate plan, including terms, conditions, restrictions, and benefits. Used for guest communication and agent training.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Status' ;
    rdfs:comment 'Current lifecycle status of the rate plan. Active: available for booking; Inactive: not available for new bookings; Suspended: temporarily disabled; Pending: awaiting approval or activation; Expired: past effective end date.' ;
    rdfs:domain ind:ReservationRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationSpecialRequestId rdf:type rdf:Property ;
    rdfs:label 'Reservation Special Request Id' ;
    rdfs:comment 'Unique identifier for the special request record. Primary key for the reservation special request entity.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReservationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Reservation Employee Id' ;
    rdfs:comment 'Reference to the staff member assigned to fulfill the special request. Enables accountability tracking and performance measurement.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:chargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Charge Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the charge amount. Supports multi-currency operations for international properties.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCategory rdf:type rdf:Property ;
    rdfs:label 'Failure Category' ;
    rdfs:comment 'Classification of the reason for request non-fulfillment. Enables root cause analysis and operational improvement initiatives. [ENUM-REF-CANDIDATE: unavailable|capacity_constraint|policy_restriction|cost_prohibitive|timing_conflict|guest_cancelled|system_error|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Explanation of why the special request could not be fulfilled or was only partially fulfilled. Supports service recovery and guest communication.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestFeedbackText rdf:type rdf:Property ;
    rdfs:label 'Guest Feedback Text' ;
    rdfs:comment 'Free-form guest comments or feedback regarding the special request fulfillment. Captured through post-stay surveys or direct communication.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Notified Flag' ;
    rdfs:comment 'Indicates whether the guest has been notified of the fulfillment status or any issues with the special request. Tracks communication completion.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactsLoyaltyPoints rdf:type rdf:Property ;
    rdfs:label 'Impacts Loyalty Points' ;
    rdfs:comment 'Indicates whether fulfillment or non-fulfillment of this special request affects the guest loyalty program points or status. Used for loyalty program integration.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreArrival rdf:type rdf:Property ;
    rdfs:label 'Is Pre Arrival' ;
    rdfs:comment 'Indicates whether the special request was submitted before the guest arrival date. Pre-arrival requests enable proactive preparation and enhanced guest experience.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVipRequest rdf:type rdf:Property ;
    rdfs:label 'Is Vip Request' ;
    rdfs:comment 'Indicates whether the special request is associated with a VIP (Very Important Person) guest requiring elevated attention and priority handling.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Communication channel used to notify the guest about the special request status. Supports omnichannel guest communication tracking. [ENUM-REF-CANDIDATE: email|sms|phone_call|mobile_app|in_person|letter|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestCategory rdf:type rdf:Property ;
    rdfs:label 'Request Category' ;
    rdfs:comment 'High-level grouping of the request type for operational planning and resource allocation. Used for departmental workload distribution. [ENUM-REF-CANDIDATE: room_setup|service_timing|accessibility|amenity|food_beverage|transportation|special_event|general — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestCode rdf:type rdf:Property ;
    rdfs:label 'Request Code' ;
    rdfs:comment 'Standardized code identifying the type of special request in the Property Management System (PMS). Used for system processing and reporting.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestText rdf:type rdf:Property ;
    rdfs:label 'Request Text' ;
    rdfs:comment 'Free-form text description of the special request as entered by the guest or reservation agent. Captures detailed instructions and context for fulfillment.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCharge rdf:type rdf:Property ;
    rdfs:label 'Requires Charge' ;
    rdfs:comment 'Indicates whether fulfilling the special request incurs an additional charge to the guest folio. Used for revenue tracking and billing integration.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Target Fulfillment Date' ;
    rdfs:comment 'Planned date by which the special request should be fulfilled. Often aligned with guest arrival date or specific event timing.' ;
    rdfs:domain ind:ReservationSpecialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingId rdf:type rdf:Property ;
    rdfs:label 'Booking Id' ;
    rdfs:comment 'FK to reservation.booking.booking_id — MUST-HAVE: Room assignment must link to the reservation it fulfills. Core operational join for check-in, room move, and folio management workflows.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReservationBooking .

ind:connectedRoomAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Connected Room Assignment Id' ;
    rdfs:comment 'Reference to the room assignment ID of the connecting room, if applicable. Null if not part of a connecting room arrangement.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoomAssignment .

ind:tertiaryRoomLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Room Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the staff member who last modified this room assignment record. Used for accountability and audit trail.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assignment Source System' ;
    rdfs:comment 'Name of the system or channel through which the room assignment was made (e.g., OPERA PMS, Mobile Check-In, Kiosk, Front Desk Terminal).' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the room assignment. Tracks progression from initial assignment through guest departure.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Date and time when the room was assigned to the reservation. Represents the moment the assignment was committed in the PMS.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bedConfiguration rdf:type rdf:Property ;
    rdfs:label 'Bed Configuration' ;
    rdfs:comment 'Bed type and configuration in the assigned room. Critical for matching guest preferences and group requirements. [ENUM-REF-CANDIDATE: king|queen|double_queen|twin|double_twin|murphy|sofa_bed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyCheckinFlag rdf:type rdf:Property ;
    rdfs:label 'Early Checkin Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment was made to accommodate an early check-in request (arrival before standard check-in time).' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestPreferenceMatchScore rdf:type rdf:Property ;
    rdfs:label 'Guest Preference Match Score' ;
    rdfs:comment 'Calculated score (0-100) indicating how well this room assignment matches the guest\'s stated preferences (floor, view, location, amenities). Used for service quality measurement.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAccessibleRoom rdf:type rdf:Property ;
    rdfs:label 'Is Accessible Room' ;
    rdfs:comment 'Boolean flag indicating whether the assigned room meets ADA accessibility requirements. Used for compliance reporting and guest matching.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConnectingRoom rdf:type rdf:Property ;
    rdfs:label 'Is Connecting Room' ;
    rdfs:comment 'Boolean flag indicating whether this room is part of a connecting room pair or group. Used for family and group bookings.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGuestRequested rdf:type rdf:Property ;
    rdfs:label 'Is Guest Requested' ;
    rdfs:comment 'Boolean flag indicating whether the guest specifically requested this room or room type during pre-arrival or at check-in.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUpgrade rdf:type rdf:Property ;
    rdfs:label 'Is Upgrade' ;
    rdfs:comment 'Boolean flag indicating whether this assignment represents an upgrade from the originally booked room type.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Key Created Timestamp' ;
    rdfs:comment 'Date and time when the room key (physical or digital) was created for this assignment. Indicates actual guest check-in readiness.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:keyType rdf:type rdf:Property ;
    rdfs:label 'Key Type' ;
    rdfs:comment 'Type of room key issued to the guest for this assignment. Used for technology adoption tracking and guest preference analysis.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateCheckoutFlag rdf:type rdf:Property ;
    rdfs:label 'Late Checkout Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment includes a late check-out accommodation (departure after standard check-out time).' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockStatus rdf:type rdf:Property ;
    rdfs:label 'Lock Status' ;
    rdfs:comment 'Status indicating whether the room assignment is locked (cannot be changed) or unlocked (can be reassigned). Used to prevent accidental changes during check-in.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Locked Timestamp' ;
    rdfs:comment 'Date and time when the room assignment was locked. Null if assignment is not locked.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalRoomTypeCode rdf:type rdf:Property ;
    rdfs:label 'Original Room Type Code' ;
    rdfs:comment 'The room type code that was originally booked by the guest. Used to calculate upgrade value and track displacement.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousRoomNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Room Number' ;
    rdfs:comment 'The room number from which the guest was reassigned, if applicable. Null for initial assignments. Used for reassignment tracking.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reassignmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reassignment Reason Code' ;
    rdfs:comment 'Code indicating the reason for room reassignment. Null if no reassignment has occurred. Used for root cause analysis.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reassignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reassignment Timestamp' ;
    rdfs:comment 'Date and time of the most recent room reassignment. Null if no reassignment has occurred.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:roomConditionAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Room Condition At Assignment' ;
    rdfs:comment 'Housekeeping status of the room at the time of assignment. Ensures only ready rooms are assigned to arriving guests.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeCategory rdf:type rdf:Property ;
    rdfs:label 'Upgrade Category' ;
    rdfs:comment 'High-level category of the upgrade indicating whether it was complimentary, paid, loyalty-driven, or operationally necessary.' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Upgrade Reason Code' ;
    rdfs:comment 'Code indicating the reason for the room upgrade. Null if is_upgrade is false. Used for revenue management and guest satisfaction analysis. [ENUM-REF-CANDIDATE: loyalty_status|operational|paid_upgrade|service_recovery|availability|overbooking|vip|group_courtesy — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RoomAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgencyReservationTravelAgentId rdf:type rdf:Property ;
    rdfs:label 'Parent Agency Reservation Travel Agent Id' ;
    rdfs:comment 'Reference to the parent travel agency if this agent is part of a franchise, consortium, or multi-branch organization. Enables hierarchical reporting of agency performance.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TravelAgent .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Legal or trading name of the travel agency or travel management company (TMC). Primary human-readable identifier.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the travel agency business model. Retail agencies serve individual travelers, corporate TMCs manage business travel programs, OTAs operate online platforms, tour operators package travel products, consortiums are agency networks, and wholesalers distribute bulk inventory.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arcNumber rdf:type rdf:Property ;
    rdfs:label 'Arc Number' ;
    rdfs:comment 'Seven or eight-digit ARC accreditation number for US-based travel agencies. Used for commission processing and booking attribution in the North American market.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingVolumeTier rdf:type rdf:Property ;
    rdfs:label 'Booking Volume Tier' ;
    rdfs:comment 'Tiered classification based on the travel agent\'s historical booking volume or revenue contribution. Higher tiers may receive preferential commission rates, priority support, or marketing benefits.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsIdentifier rdf:type rdf:Property ;
    rdfs:label 'Gds Identifier' ;
    rdfs:comment 'Unique identifier or pseudo city code (PCC) assigned to the travel agent within the Global Distribution System (Amadeus, Sabre, Galileo, Worldspan). Used to attribute bookings originating from GDS channels.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataNumber rdf:type rdf:Property ;
    rdfs:label 'Iata Number' ;
    rdfs:comment 'Eight-digit IATA accreditation number assigned to the travel agency by the International Air Transport Association. Primary industry identifier for accredited travel agencies.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBookingDate rdf:type rdf:Property ;
    rdfs:label 'Last Booking Date' ;
    rdfs:comment 'Date of the most recent reservation created by this travel agent. Used to identify inactive agents and trigger re-engagement campaigns.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completed Date' ;
    rdfs:comment 'Date when the travel agent completed all onboarding requirements (contract signing, profile setup, training, system access). Marks readiness to begin booking.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for the travel agent\'s preferred communication language (e.g., en, es, fr, de).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Method' ;
    rdfs:comment 'Default payment instrument used by the travel agent for booking guarantees and deposits. Credit card for immediate authorization, bank transfer for wire payments, check for paper payments, direct bill for invoiced accounts, virtual card for single-use card numbers, net remit for commission offset against payment.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax identification number (TIN, EIN, VAT number) for the travel agency. Used for commission payment reporting and tax compliance.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBookingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Bookings Count' ;
    rdfs:comment 'Cumulative count of all reservations created by this travel agent since relationship inception. Used for performance reporting and tier qualification.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Generated' ;
    rdfs:comment 'Cumulative room revenue generated by all bookings attributed to this travel agent since relationship inception. Expressed in the property\'s base currency. Used for tier qualification and ROI analysis.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelAgentStatus rdf:type rdf:Property ;
    rdfs:label 'Travel Agent Status' ;
    rdfs:comment 'Current lifecycle status of the travel agent relationship. Active agents can make bookings and earn commissions. Inactive agents are temporarily disabled. Suspended agents are under review. Pending approval agents await onboarding completion. Terminated agents have ended their relationship. Blacklisted agents are permanently banned.' ;
    rdfs:domain ind:TravelAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'Username or system identifier of the user or process that last modified this travel agent record. Used for audit trail and accountability.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistId rdf:type rdf:Property ;
    rdfs:label 'Waitlist Id' ;
    rdfs:comment 'Unique identifier for the waitlist entry. Primary key.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitlistConvertedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Waitlist Converted By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that converted the waitlist entry to a reservation. Null if not yet converted.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:waitlistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Waitlist Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that created the waitlist entry.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:waitlistModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Waitlist Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that last modified the waitlist entry.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoConvertFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Convert Flag' ;
    rdfs:comment 'Boolean flag indicating whether the system should automatically convert this waitlist entry to a confirmed reservation when inventory becomes available (True) or require manual confirmation (False).' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guaranteeTypeCode rdf:type rdf:Property ;
    rdfs:label 'Guarantee Type Code' ;
    rdfs:comment 'Code indicating the guarantee method provided by the guest for the waitlisted reservation.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Guest Priority Tier' ;
    rdfs:comment 'Loyalty tier or priority classification of the guest, used to determine waitlist position and conversion priority.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'Guest\'s preferred method for receiving waitlist status updates and conversion notifications.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:position rdf:type rdf:Property ;
    rdfs:label 'Position' ;
    rdfs:comment 'Numeric position of this entry in the waitlist queue for the requested room type and dates. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Quoted Rate Amount' ;
    rdfs:comment 'The room rate amount quoted to the guest at the time of waitlist creation, in the property\'s base currency.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Requested Arrival Date' ;
    rdfs:comment 'The arrival date requested by the guest for the waitlisted reservation.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Requested Departure Date' ;
    rdfs:comment 'The departure date requested by the guest for the waitlisted reservation.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedNights rdf:type rdf:Property ;
    rdfs:label 'Requested Nights' ;
    rdfs:comment 'Number of nights requested by the guest, calculated as departure date minus arrival date.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedRoomCount rdf:type rdf:Property ;
    rdfs:label 'Requested Room Count' ;
    rdfs:comment 'Number of rooms requested by the guest on the waitlist.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedRoomTypeCode rdf:type rdf:Property ;
    rdfs:label 'Requested Room Type Code' ;
    rdfs:comment 'Code identifying the room type requested by the guest (e.g., KING, SUITE, DELUXE).' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistNumber rdf:type rdf:Property ;
    rdfs:label 'Waitlist Number' ;
    rdfs:comment 'Human-readable business identifier for the waitlist entry, typically formatted as WL followed by numeric sequence.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistStatus rdf:type rdf:Property ;
    rdfs:label 'Waitlist Status' ;
    rdfs:comment 'Current lifecycle status of the waitlist entry. Active indicates the guest is still waiting; converted means a reservation was created; expired means the requested dates have passed; cancelled means the guest withdrew; fulfilled means inventory was allocated.' ;
    rdfs:domain ind:Waitlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walkRecordId rdf:type rdf:Property ;
    rdfs:label 'Walk Record Id' ;
    rdfs:comment 'Unique identifier for the walk record transaction. Primary key.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationHotelPropertyId rdf:type rdf:Property ;
    rdfs:label 'Destination Hotel Property Id' ;
    rdfs:comment 'Reference to the alternative property where the guest was relocated. The property that accommodated the walked guest.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:primaryWalkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Walk Employee Id' ;
    rdfs:comment 'Reference to the staff member who processed the walk transaction. Used for training, quality assurance, and accountability tracking.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryWalkPropertyId rdf:type rdf:Property ;
    rdfs:label 'Primary Walk Property Id' ;
    rdfs:comment 'Reference to the property where the original reservation was made but could not be honored due to overbooking or other operational constraints.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:brandStandardComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Compliance Flag' ;
    rdfs:comment 'Indicates whether the walk was handled in compliance with brand standards for guest relocation and service recovery. Used for quality assurance and brand audit purposes.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Compensation Amount' ;
    rdfs:comment 'Monetary cash compensation provided to the guest for the walk inconvenience. Tracked separately from other compensation types for financial reporting.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complaintFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Complaint Filed Flag' ;
    rdfs:comment 'Indicates whether the guest filed a formal complaint regarding the walk event. Used for tracking service recovery effectiveness and brand reputation management.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Resolution Status' ;
    rdfs:comment 'Current status of any complaint filed by the guest. Tracks the complaint lifecycle from initial filing through final resolution.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complimentaryNightsCount rdf:type rdf:Property ;
    rdfs:label 'Complimentary Nights Count' ;
    rdfs:comment 'Number of complimentary room nights provided as compensation for the walk. Typically one night but may vary based on brand standards and guest status.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guestConsentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether explicit consent was obtained from the guest before the walk. Critical for compliance with brand standards and guest rights policies.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Guest Consent Timestamp' ;
    rdfs:comment 'Date and time when guest consent was obtained. Used for audit trail and compliance documentation.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otaNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Ota Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the OTA partner was notified of the walk event as required by contractual obligations.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otaNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ota Notification Timestamp' ;
    rdfs:comment 'Date and time when the OTA partner was notified of the walk event. Used for compliance verification and audit trail.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otaPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Ota Penalty Amount' ;
    rdfs:comment 'Monetary penalty amount charged by the OTA partner for the walk event. Tracked for financial reporting and channel cost analysis.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otaPenaltyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Ota Penalty Applicable Flag' ;
    rdfs:comment 'Indicates whether the walk event triggers a contractual penalty with the OTA partner. Used for financial accrual and channel relationship management.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providedRoomTypeCode rdf:type rdf:Property ;
    rdfs:label 'Provided Room Type Code' ;
    rdfs:comment 'The room type code that was provided at the destination property. Used to track whether the guest received a comparable, upgraded, or downgraded room.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRecoveryActionTaken rdf:type rdf:Property ;
    rdfs:label 'Service Recovery Action Taken' ;
    rdfs:comment 'Detailed description of all service recovery actions taken beyond standard compensation. May include manager apology calls, welcome amenities, special requests honored, or other personalized gestures.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCompensationValueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Compensation Value Amount' ;
    rdfs:comment 'Total monetary value of all compensation provided to the guest, including complimentary nights, transportation, cash, and estimated value of loyalty points and vouchers.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Transportation Cost Amount' ;
    rdfs:comment 'The monetary cost of transportation provided to the guest. Used for cost tracking and operational expense analysis.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportationProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Transportation Provided Flag' ;
    rdfs:comment 'Indicates whether transportation was arranged and provided to relocate the guest to the destination property.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:walkDate rdf:type rdf:Property ;
    rdfs:label 'Walk Date' ;
    rdfs:comment 'The date on which the walk event occurred. Typically corresponds to the original scheduled arrival date when the guest was informed of the relocation.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:walkReasonCode rdf:type rdf:Property ;
    rdfs:label 'Walk Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for the walk event. Common reasons include overbooking, maintenance issues, operational constraints, VIP displacement, group block conflicts, or system errors.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walkReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Walk Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the guest was walked. Provides context beyond the standardized reason code for service recovery and operational analysis.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walkTimestamp rdf:type rdf:Property ;
    rdfs:label 'Walk Timestamp' ;
    rdfs:comment 'Precise date and time when the walk event was recorded in the system. Captures the exact moment the guest was notified and the walk transaction was initiated.' ;
    rdfs:domain ind:WalkRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelContributionId rdf:type rdf:Property ;
    rdfs:label 'Channel Contribution Id' ;
    rdfs:comment 'Unique surrogate identifier for each channel contribution record in the Databricks Silver Layer. Primary key for this transactional summary entity. Entity role: TRANSACTION_HEADER — represents a discrete revenue contribution measurement event per distribution channel, property, and reporting period.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyzedFnbOutletId rdf:type rdf:Property ;
    rdfs:label 'Analyzed Fnb Outlet Id' ;
    rdfs:comment 'Foreign key linking to fnb.fnb_outlet. Business justification: Channel analysis includes F&B attachment rates by booking source (OTA guests vs direct = different outlet usage). Required for channel profitability analysis, package optimization, outlet marketing st' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FnbOutlet .

ind:loyaltyMemberSegmentId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Member Segment Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member_segment. Business justification: Channel performance analysis by loyalty segment reveals segment-specific booking behavior and channel preferences. Business process: segment-level channel effectiveness reporting for optimizing distri' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberSegment .

ind:alos rdf:type rdf:Property ;
    rdfs:label 'Alos' ;
    rdfs:comment 'Average Length of Stay (ALOS) in nights for bookings originating from this distribution channel during the reporting period. Calculated as total room nights divided by booking volume. Informs LOS (Length of Stay) restriction strategies in the RMS.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingVolume rdf:type rdf:Property ;
    rdfs:label 'Booking Volume' ;
    rdfs:comment 'Total number of confirmed reservations received through this distribution channel during the reporting period. Core metric for channel productivity analysis and OTA partnership evaluation.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelMixPct rdf:type rdf:Property ;
    rdfs:label 'Channel Mix Pct' ;
    rdfs:comment 'Percentage of total property booking volume or room nights attributable to this distribution channel during the reporting period. Measures channel contribution to overall distribution mix. Used for channel optimization strategy and OTA dependency analysis.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionStatus rdf:type rdf:Property ;
    rdfs:label 'Contribution Status' ;
    rdfs:comment 'Lifecycle status of the channel contribution record. \'draft\' indicates preliminary data; \'confirmed\' indicates validated and finalized; \'adjusted\' indicates post-close corrections applied; \'closed\' indicates period locked; \'cancelled\' indicates record voided.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerBooking rdf:type rdf:Property ;
    rdfs:label 'Cost Per Booking' ;
    rdfs:comment 'Total distribution cost per confirmed booking through this channel, including commissions, GDS transaction fees, and incremental booking costs. Also known as Cost Per Acquisition (CPA). Key metric for channel ROI analysis and OTA partnership management.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataExtractTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Extract Timestamp' ;
    rdfs:comment 'Timestamp when data was extracted from the source operational system (OPERA PMS, SynXis CRS, or IDeaS G3 RMS) for loading into the Databricks Silver Layer. Used for data freshness monitoring and SLA compliance tracking.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdsTransactionFees rdf:type rdf:Property ;
    rdfs:label 'Gds Transaction Fees' ;
    rdfs:comment 'Total GDS (Global Distribution System) per-transaction fees incurred for bookings processed through GDS channels (Sabre, Amadeus, Travelport) during the reporting period. Applicable only to GDS channel type; zero for non-GDS channels. Included in total distribution cost.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRevenue rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue' ;
    rdfs:comment 'Total gross room revenue generated through this distribution channel before deducting commissions, OTA fees, or GDS transaction fees. Represents the full rack or negotiated rate charged to guests. Used in ADR and RevPAR calculations per USALI standards.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOtaChannel rdf:type rdf:Property ;
    rdfs:label 'Is Ota Channel' ;
    rdfs:comment 'Boolean flag indicating whether this distribution channel is an Online Travel Agency (OTA) such as Expedia or Booking.com. Enables quick segmentation of OTA vs. non-OTA channels for commission cost analysis and direct booking strategy reporting.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyBookingsCount rdf:type rdf:Property ;
    rdfs:label 'Loyalty Bookings Count' ;
    rdfs:comment 'Number of bookings through this channel made by loyalty program members during the reporting period. Tracks loyalty member channel preference and supports direct booking incentive strategies to reduce OTA dependency.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netRevenue rdf:type rdf:Property ;
    rdfs:label 'Net Revenue' ;
    rdfs:comment 'Net room revenue retained by the property after deducting all channel commissions and distribution fees from gross revenue. Primary metric for evaluating true channel profitability and informing channel mix optimization decisions.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowCount rdf:type rdf:Property ;
    rdfs:label 'No Show Count' ;
    rdfs:comment 'Total number of reservations from this channel where the guest did not arrive and did not cancel. No-shows impact revenue recovery and are tracked per channel to assess booking quality and enforce no-show policies.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nrrBookingsCount rdf:type rdf:Property ;
    rdfs:label 'Nrr Bookings Count' ;
    rdfs:comment 'Number of bookings made at Non-Refundable Rate (NRR) through this channel during the reporting period. NRR bookings provide revenue certainty and reduce cancellation risk. Used to assess channel-level rate plan mix.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occupancyPct rdf:type rdf:Property ;
    rdfs:label 'Occupancy Pct' ;
    rdfs:comment 'Occupancy rate (OCC) attributable to this distribution channel, expressed as a percentage of available rooms occupied by channel-sourced bookings. Supports channel-level yield analysis and demand forecasting integration with IDeaS G3 RMS.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingGranularity rdf:type rdf:Property ;
    rdfs:label 'Reporting Granularity' ;
    rdfs:comment 'Time granularity at which this channel contribution record is aggregated. \'daily\' for day-level DOR reporting; \'weekly\' for pace analysis; \'monthly\' for USALI period reporting; \'quarterly\' for STR STAR Report benchmarking.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The last date of the reporting period (stay date range) for which channel contribution metrics are aggregated. Together with reporting_period_start_date defines the measurement window.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The first date of the reporting period (stay date range) for which channel contribution metrics are aggregated. Used to define the measurement window for ADR, RevPAR, and channel mix analysis.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueNetOfDistribution rdf:type rdf:Property ;
    rdfs:label 'Revenue Net Of Distribution' ;
    rdfs:comment 'Net revenue after deducting all distribution costs (commissions, GDS fees, OTA fees) from gross revenue. Represents the true retained revenue contribution of the channel. Supports channel profitability ranking and optimization decisions.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revpar rdf:type rdf:Property ;
    rdfs:label 'Revpar' ;
    rdfs:comment 'Revenue Per Available Room contributed by this channel, calculated as channel gross revenue divided by total available rooms for the reporting period. Core yield optimization metric per STR STAR Report and USALI standards.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rgi rdf:type rdf:Property ;
    rdfs:label 'Rgi' ;
    rdfs:comment 'Revenue Generation Index (RGI) attributable to this channel, measuring the property\'s RevPAR performance relative to the competitive set for channel-sourced bookings. RGI > 1.0 indicates above-market performance. Sourced from STR STAR Report and Infor EzRMS.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDistributionCost rdf:type rdf:Property ;
    rdfs:label 'Total Distribution Cost' ;
    rdfs:comment 'Total all-in cost of distributing inventory through this channel, including commissions, GDS transaction fees, OTA merchant model costs, and any incremental booking fees. Used to calculate net channel profitability and CPOR (Cost Per Occupied Room) by channel.' ;
    rdfs:domain ind:ChannelContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveSetId rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Id' ;
    rdfs:comment 'Primary key for competitive_set' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetitiveSet .

ind:advancePurchaseWindowDays rdf:type rdf:Property ;
    rdfs:label 'Advance Purchase Window Days' ;
    rdfs:comment 'The booking lead time window in days used for rate shopping comparisons within this competitive set (e.g., 0 = same-day, 7 = 7-day advance, 30 = 30-day advance). Ensures rate intelligence is captured at consistent booking horizons for fair ADR comparison.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ariTarget rdf:type rdf:Property ;
    rdfs:label 'Ari Target' ;
    rdfs:comment 'The Average Rate Index (ARI) target threshold for this competitive set. ARI = Property ADR / Comp Set ADR. A value above 1.00 indicates the property targets a higher ADR than the competitive set average. Drives BAR pricing strategy in IDeaS G3 RMS.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Benchmarking Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for normalizing ADR, RevPAR, and TRevPAR benchmarking metrics across all properties in the competitive set (e.g., \'USD\', \'EUR\', \'GBP\'). Ensures consistent monetary comparison in STR STAR Report analysis.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveSetName rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Name' ;
    rdfs:comment 'Human-readable name assigned to the competitive set (e.g., \'Downtown Luxury Primary Set\', \'Airport Corridor Secondary Set\'). Used in Infor EzRMS and STR STAR Report submissions to identify the grouping.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveSetStatus rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Status' ;
    rdfs:comment 'Current lifecycle status of the competitive set. \'active\' sets are used in live RMS benchmarking and STR reporting; \'inactive\' sets are suspended; \'pending_approval\' awaits revenue management sign-off; \'archived\' are historical sets retained for trend analysis.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSegmentFocus rdf:type rdf:Property ;
    rdfs:label 'Demand Segment Focus' ;
    rdfs:comment 'The primary guest demand segment this competitive set is designed to benchmark. \'transient\' focuses on FIT (Free Independent Traveler) and leisure; \'group\' focuses on MICE (Meetings, Incentives, Conferences, Exhibitions) and group blocks; \'contract\' focuses on negotiated corporate rates; \'all_segments\' covers the full mix.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'The geographic market or submarket in which the competitive set operates (e.g., \'Manhattan Midtown\', \'Chicago O\'Hare Corridor\', \'Miami Beach\'). Aligns with STR market definitions used for Market Penetration Index (MPI) calculations.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ideassCompSetCode rdf:type rdf:Property ;
    rdfs:label 'Ideass Comp Set Code' ;
    rdfs:comment 'The competitive set reference code as configured in IDeaS G3 RMS for pricing strategy alignment. Enables synchronization of comp set definitions between Infor EzRMS benchmarking and IDeaS G3 RMS dynamic pricing rules (DRR) and BAR optimization.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStrSubmitted rdf:type rdf:Property ;
    rdfs:label 'Is Str Submitted' ;
    rdfs:comment 'Indicates whether this competitive set has been formally submitted to STR (Smith Travel Research) for STAR Report benchmarking. True means the set is registered with STR and receives STAR Report data; False means it is an internal-only comp set.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'The most recent date on which the competitive set membership and parameters were reviewed by the revenue management team. Best practice requires annual or semi-annual review to ensure comp set relevance as market conditions evolve.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:losBenchmarkNights rdf:type rdf:Property ;
    rdfs:label 'Los Benchmark Nights' ;
    rdfs:comment 'The standard Length of Stay (LOS) in nights used as the basis for rate comparison within this competitive set. Typically set to 1 night for transient benchmarking. Used to normalize ADR comparisons across properties with different LOS mix.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Market Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary geographic market for this competitive set (e.g., \'USA\', \'GBR\', \'DEU\'). Used for multi-national portfolio benchmarking and currency normalization in revenue performance reporting.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRoomCount rdf:type rdf:Property ;
    rdfs:label 'Max Room Count' ;
    rdfs:comment 'Maximum number of guestrooms a competitor property may have to qualify for inclusion in this competitive set. Used alongside min_room_count to define the acceptable size range for comp set membership.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of competitor properties currently included in this competitive set. STR STAR Report typically requires a minimum of 3 and maximum of 10 competitor properties for statistically valid benchmarking. Derived from the comp set membership roster but stored here for quick reference.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minRoomCount rdf:type rdf:Property ;
    rdfs:label 'Min Room Count' ;
    rdfs:comment 'Minimum number of guestrooms a competitor property must have to qualify for inclusion in this competitive set. Ensures size comparability for RevPAR and occupancy benchmarking. Typically aligned with the subject property\'s room count range.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mpiTarget rdf:type rdf:Property ;
    rdfs:label 'Mpi Target' ;
    rdfs:comment 'The Market Penetration Index (MPI) target threshold for this competitive set. MPI = Property Occupancy Rate / Comp Set Occupancy Rate. A value above 1.00 indicates the property targets higher occupancy than the competitive set average. Used in revenue strategy planning.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBenchmarkingMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Benchmarking Metric' ;
    rdfs:comment 'The primary Key Performance Indicator (KPI) used to evaluate competitive performance for this comp set. Options include RevPAR (Revenue Per Available Room), ADR (Average Daily Rate), Occupancy Rate (OCC), TRevPAR (Total Revenue Per Available Room), or GOPPAR (Gross Operating Profit Per Available Room).' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyTypeFilter rdf:type rdf:Property ;
    rdfs:label 'Property Type Filter' ;
    rdfs:comment 'Filter defining the property service type composition of this competitive set. Ensures benchmarking is conducted against properties of comparable service level and amenity offering. Aligns with AHLA property classification standards.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateShopFrequency rdf:type rdf:Property ;
    rdfs:label 'Rate Shop Frequency' ;
    rdfs:comment 'Frequency at which competitor rates are retrieved from OTA and GDS channels for properties in this competitive set. Drives the cadence of dynamic pricing adjustments in IDeaS G3 RMS. Only applicable when rate_shopping_enabled is True.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateShoppingEnabled rdf:type rdf:Property ;
    rdfs:label 'Rate Shopping Enabled' ;
    rdfs:comment 'Indicates whether automated rate shopping (competitive rate intelligence) is active for this competitive set. When True, the RMS retrieves competitor BAR rates from OTA channels and GDS for dynamic pricing decisions. When False, only STR STAR Report data is used.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rmsCompSetReference rdf:type rdf:Property ;
    rdfs:label 'Rms Comp Set Reference' ;
    rdfs:comment 'The native competitive set identifier as stored in the Revenue Management System (Infor EzRMS or IDeaS G3 RMS). Used for cross-system reconciliation and data lineage tracing between the lakehouse Silver Layer and the operational RMS.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setType rdf:type rdf:Property ;
    rdfs:label 'Set Type' ;
    rdfs:comment 'Classification of the competitive set indicating its strategic purpose. \'primary\' is the main STR STAR Report comp set; \'secondary\' is an alternate benchmarking group; \'custom\' is an ad-hoc internal set; \'str_defined\' is a set defined by STR directly; \'internal\' is used for internal rate intelligence only.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strCompSetCode rdf:type rdf:Property ;
    rdfs:label 'Str Comp Set Code' ;
    rdfs:comment 'The unique alphanumeric code assigned by STR (Smith Travel Research) to identify this competitive set in the STAR Report system. Required for submitting and retrieving benchmarking data from STR. Maps directly to the STR comp set identifier in Infor EzRMS.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strMarketCode rdf:type rdf:Property ;
    rdfs:label 'Str Market Code' ;
    rdfs:comment 'The STR-assigned market code identifying the geographic market in which this competitive set is benchmarked. Used to retrieve market-level aggregates for MPI calculation and to align with STR STAR Report market definitions.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strReportFrequency rdf:type rdf:Property ;
    rdfs:label 'Str Report Frequency' ;
    rdfs:comment 'Frequency at which STR STAR Report data is received and processed for this competitive set. Determines the cadence of RGI, MPI, and ARI metric refreshes in the Revenue Management System.' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strSubmarketCode rdf:type rdf:Property ;
    rdfs:label 'Str Submarket Code' ;
    rdfs:comment 'The STR-assigned submarket code for more granular geographic benchmarking within a broader STR market. Used when the competitive set operates in a distinct submarket (e.g., airport vs. downtown within the same city market).' ;
    rdfs:domain ind:CompetitiveSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Str Submission Date' ;
    rdfs:comment 'The date on which this competitive set was submitted to STR for STAR Report registration. Relevant only when is_str_submitted is True. Used for audit and compliance tracking of STR data agreements.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitorRateId rdf:type rdf:Property ;
    rdfs:label 'Competitor Rate Id' ;
    rdfs:comment 'Unique surrogate identifier for each competitor rate intelligence record in the Silver Layer lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorPropertyId rdf:type rdf:Property ;
    rdfs:label 'Competitor Property Id' ;
    rdfs:comment 'Reference to the competitor property record against which this rate was shopped. Links to the competitor property master.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:shoppedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Shopped By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Revenue analysts conduct competitor rate shopping; employee attribution required for competitive intelligence workflow tracking, data quality accountability, and performance evaluation of rate shoppin' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ari rdf:type rdf:Property ;
    rdfs:label 'Ari' ;
    rdfs:comment 'Average Rate Index (ARI) calculated as Travel Hospitality\'s ADR divided by the competitive set\'s ADR for the same period. ARI > 1.0 indicates rate premium over the competitive set. Sourced from STR STAR Report or computed from shopped rates.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Availability status of the competitor room type and rate plan at the time of the shop. Indicates whether the rate was bookable (available), the room type was sold out, or the rate was closed to arrival. Used in demand and compression analysis.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelShopped rdf:type rdf:Property ;
    rdfs:label 'Channel Shopped' ;
    rdfs:comment 'The distribution channel through which the competitor rate was observed. OTA = Online Travel Agency (e.g., Expedia, Booking.com), GDS = Global Distribution System, direct = competitor brand website. Enables channel-level rate parity and competitive positioning analysis.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPropertyCode rdf:type rdf:Property ;
    rdfs:label 'Competitor Property Code' ;
    rdfs:comment 'Externally recognized alphanumeric code identifying the competitor property as defined in the competitive set configuration within Infor EzRMS or STR STAR Report. Used for benchmarking alignment.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceReference rdf:type rdf:Property ;
    rdfs:label 'Data Source Reference' ;
    rdfs:comment 'Specific URL, feed identifier, or external reference from the data source where the competitor rate was retrieved (e.g., OTA listing URL, STR report batch ID, GDS transaction ID). Supports data lineage and auditability.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'Day of the week corresponding to the stay date (MON through SUN). Pre-computed to support day-of-week rate pattern analysis and weekday vs. weekend competitive pricing strategies without requiring date function computation. [ENUM-REF-CANDIDATE: MON|TUE|WED|THU|FRI|SAT|SUN — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feesIncluded rdf:type rdf:Property ;
    rdfs:label 'Fees Included' ;
    rdfs:comment 'Indicates whether mandatory fees (resort fees, destination fees, amenity fees) are included in the shopped rate (True) or excluded (False). Affects true cost comparison for rate parity and competitive positioning analysis.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWeekend rdf:type rdf:Property ;
    rdfs:label 'Is Weekend' ;
    rdfs:comment 'Indicates whether the stay date falls on a weekend (Friday or Saturday night, True) or a weekday (False). Supports weekend vs. weekday rate positioning analysis and demand segmentation.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'STR-defined or internal market code representing the geographic market in which the competitor property operates (e.g., NYC, MIAMI, LONDON). Aligns with STR STAR Report market definitions for RGI and MPI benchmarking.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupancyAssumption rdf:type rdf:Property ;
    rdfs:label 'Occupancy Assumption' ;
    rdfs:comment 'Number of guests (occupancy) assumed when the rate was shopped (typically 1 or 2 adults). Affects rate comparability as some competitors price differently by occupancy.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ourRate rdf:type rdf:Property ;
    rdfs:label 'Our Rate' ;
    rdfs:comment 'Travel Hospitality\'s own Best Available Rate (BAR) for the equivalent room type, stay date, and channel at the time of the shop. Enables direct rate gap and rate index calculations without requiring a join to the rate plan table.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousShoppedRate rdf:type rdf:Property ;
    rdfs:label 'Previous Shopped Rate' ;
    rdfs:comment 'The competitor rate captured in the immediately preceding shop for the same property, stay date, room type, and channel. Enables rate change delta calculation and trend analysis without requiring a self-join.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertySegment rdf:type rdf:Property ;
    rdfs:label 'Property Segment' ;
    rdfs:comment 'Market segment classification of the competitor property (luxury, premium, select-service, extended stay, resort). Enables segment-level competitive benchmarking aligned with Travel Hospitality\'s own portfolio segmentation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Rate Change Indicator' ;
    rdfs:comment 'Indicates the direction of rate movement compared to the previous shop for the same competitor, stay date, room type, and channel. Supports rate velocity tracking and competitive pricing alerts in Infor EzRMS.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateDelta rdf:type rdf:Property ;
    rdfs:label 'Rate Delta' ;
    rdfs:comment 'Absolute difference between the current shopped rate and the previous shopped rate (shopped_rate minus previous_shopped_rate). Positive value indicates a rate increase; negative indicates a decrease. Supports competitive pricing alert thresholds in RMS.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateGap rdf:type rdf:Property ;
    rdfs:label 'Rate Gap' ;
    rdfs:comment 'Difference between Travel Hospitality\'s own rate and the competitor\'s shopped rate (our_rate minus shopped_rate). Positive value indicates our rate is higher than the competitor; negative indicates we are priced below. Core metric for rate positioning decisions.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateInUsd rdf:type rdf:Property ;
    rdfs:label 'Rate In Usd' ;
    rdfs:comment 'Competitor shopped rate converted to US Dollars (USD) using the exchange rate applicable at the time of the shop. Enables normalized cross-currency competitive benchmarking and global RevPAR index calculations.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Room Type Category' ;
    rdfs:comment 'Standardized room type category used for cross-competitor comparison (e.g., Standard, Deluxe, Suite, Junior Suite). Normalized from competitor-specific room type codes to enable apples-to-apples benchmarking. [ENUM-REF-CANDIDATE: standard|deluxe|superior|suite|junior_suite|executive|villa — promote to reference product]' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopDate rdf:type rdf:Property ;
    rdfs:label 'Shop Date' ;
    rdfs:comment 'The calendar date on which the competitor rate was shopped or retrieved. Used to calculate lead time and to track rate movement over time.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shopRunReference rdf:type rdf:Property ;
    rdfs:label 'Shop Run Reference' ;
    rdfs:comment 'Reference to the rate shopping run or batch session that produced this record, enabling traceability back to the originating shop event.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shopTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shop Timestamp' ;
    rdfs:comment 'Precise date and time (ISO 8601 with timezone offset) at which the competitor rate was captured during the shopping session. Enables intra-day rate movement tracking.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shoppedRate rdf:type rdf:Property ;
    rdfs:label 'Shopped Rate' ;
    rdfs:comment 'The publicly available or shopped room rate for the competitor property for the specified stay date, room type, and rate plan. Represents the gross rate as displayed on the booking channel before taxes and fees. Core input for ADR and RevPAR competitive benchmarking.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialEventFlag rdf:type rdf:Property ;
    rdfs:label 'Special Event Flag' ;
    rdfs:comment 'Indicates whether the stay date coincides with a known special event, conference, or demand driver (True) that may explain elevated competitor rates. Supports demand-adjusted competitive rate analysis.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxesIncluded rdf:type rdf:Property ;
    rdfs:label 'Taxes Included' ;
    rdfs:comment 'Indicates whether the shopped rate includes taxes and fees (True) or is a pre-tax rate (False). Critical for ensuring rate comparability across channels and geographies where tax display conventions differ.' ;
    rdfs:domain ind:CompetitorRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastedFnbOutletId rdf:type rdf:Property ;
    rdfs:label 'Forecasted Fnb Outlet Id' ;
    rdfs:comment 'Foreign key linking to fnb.fnb_outlet. Business justification: Room demand forecasts drive outlet-level staffing and inventory planning (high occupancy forecast = increase outlet labor/stock). Required for integrated labor scheduling, procurement planning, outlet' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FnbOutlet .

ind:ariForecast rdf:type rdf:Property ;
    rdfs:label 'Ari Forecast' ;
    rdfs:comment 'Forecasted Average Rate Index (ARI), representing the property\'s projected ADR relative to the competitive set\'s projected ADR. An ARI above 1.0 indicates the property is expected to achieve a rate premium over its competitive set.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingPaceIndex rdf:type rdf:Property ;
    rdfs:label 'Booking Pace Index' ;
    rdfs:comment 'Ratio of current bookings on-hand for the forecast date compared to the same point in time in the prior year or baseline period. A value above 1.0 indicates ahead-of-pace demand; below 1.0 indicates behind-pace. Used by revenue managers to assess demand trajectory.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Pct' ;
    rdfs:comment 'Statistical confidence level (e.g., 90.00, 95.00) associated with the forecast confidence interval. Indicates the probability that actual demand will fall within the lower and upper confidence bounds.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constrainedDemand rdf:type rdf:Property ;
    rdfs:label 'Constrained Demand' ;
    rdfs:comment 'The forecasted room demand (in room-nights) after applying available inventory capacity constraints. Represents the demand the property can actually accommodate. Used for occupancy projection and revenue optimization.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandSegmentMixPct rdf:type rdf:Property ;
    rdfs:label 'Demand Segment Mix Pct' ;
    rdfs:comment 'Forecasted percentage share of total demand attributed to the specific market segment in this record. For example, if the Transient segment is expected to represent 65% of total demand on the forecast date, this field holds 65.00. Populated only for market-segment-level forecasts.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAccuracyMape rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Mape' ;
    rdfs:comment 'Mean Absolute Percentage Error (MAPE) of the forecast model for this property-segment-horizon combination, based on historical back-testing. Lower values indicate higher model accuracy. Used to weight forecast confidence and flag low-accuracy forecasts for revenue manager review.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'The stay date (arrival date) for which the demand forecast values apply. Represents the future date being predicted, formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastGranularity rdf:type rdf:Property ;
    rdfs:label 'Forecast Granularity' ;
    rdfs:comment 'The dimensional level at which this forecast record is generated. \'property\' is the highest level; \'room_type_segment\' is the most granular, combining room type and market segment dimensions as supported by IDeaS G3 RMS.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Days' ;
    rdfs:comment 'Number of days from the forecast run date to the forecast date, representing how far into the future this forecast projects. For example, a forecast run on 2024-01-01 for a stay date of 2024-04-01 has a horizon of 90 days. Used to assess forecast accuracy by horizon bucket.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastModelType rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Type' ;
    rdfs:comment 'Classification of the algorithmic approach used to generate the forecast. \'time_series\' uses historical booking patterns; \'regression\' uses demand drivers; \'machine_learning\' uses ML-based models; \'hybrid\' combines multiple approaches; \'manual_override\' indicates a revenue manager manually adjusted the system forecast.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastModelVersion rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Version' ;
    rdfs:comment 'Version identifier of the demand forecasting model or algorithm used to generate this forecast record (e.g., \'IDeaS-G3-v8.2\', \'EzRMS-v5.1\'). Enables model performance tracking, A/B comparison, and audit of forecast methodology changes.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastRunReference rdf:type rdf:Property ;
    rdfs:label 'Forecast Run Reference' ;
    rdfs:comment 'Externally-known unique identifier assigned by the Revenue Management System (RMS) to the specific forecast generation run that produced this record. Enables traceability back to the originating RMS batch or on-demand run.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Forecast Run Timestamp' ;
    rdfs:comment 'The date and time when this forecast record was generated by the Revenue Management System. Represents the principal business event timestamp for this transaction, formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle state of this forecast record. \'active\' indicates the current operative forecast; \'superseded\' indicates a newer run has replaced it; \'draft\' indicates a preliminary run not yet published to pricing decisions; \'published\' indicates the forecast has been released to the Revenue Management System for pricing action; \'archived\' indicates historical retention only.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the forecast methodology or purpose. \'unconstrained\' reflects true market demand without inventory limits; \'constrained\' reflects demand limited by available inventory; \'group_evaluation\' is used for group block assessment in IDeaS G3 RMS; \'pickup\' reflects incremental booking pace; \'budget\' reflects the annual budget forecast baseline.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHoliday rdf:type rdf:Property ;
    rdfs:label 'Is Holiday' ;
    rdfs:comment 'Flag indicating whether the forecast date falls on a public or national holiday in the property\'s market. Used to apply holiday demand adjustment factors in the forecasting model.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverride rdf:type rdf:Property ;
    rdfs:label 'Is Override' ;
    rdfs:comment 'Flag indicating whether a revenue manager manually overrode the system-generated forecast values for this record. When true, the forecast reflects human judgment rather than pure algorithmic output. Used to track override frequency and assess model trust.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpecialEvent rdf:type rdf:Property ;
    rdfs:label 'Is Special Event' ;
    rdfs:comment 'Flag indicating whether the forecast date coincides with a special event (e.g., conference, concert, sporting event, public holiday) that is expected to materially impact demand. When true, the forecast may incorporate event-specific demand uplift factors.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mpiForecast rdf:type rdf:Property ;
    rdfs:label 'Mpi Forecast' ;
    rdfs:comment 'Forecasted Market Penetration Index (MPI), representing the property\'s projected occupancy share relative to the competitive set\'s projected occupancy. An MPI above 1.0 indicates the property is expected to capture more than its fair share of market demand.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedAdr rdf:type rdf:Property ;
    rdfs:label 'Projected Adr' ;
    rdfs:comment 'Forecasted Average Daily Rate (ADR) in the property\'s local currency for the forecast date. Represents the expected average revenue per occupied room. Core revenue management KPI used to drive pricing strategy.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCancellations rdf:type rdf:Property ;
    rdfs:label 'Projected Cancellations' ;
    rdfs:comment 'Forecasted number of room-nights expected to cancel from the current on-books position before the forecast date. Used to calculate net demand and inform overbooking strategy.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedNoShows rdf:type rdf:Property ;
    rdfs:label 'Projected No Shows' ;
    rdfs:comment 'Forecasted number of room-nights expected to result in no-show arrivals on the forecast date. Used alongside cancellation forecasts to calibrate overbooking levels and protect revenue.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedOccupancyPct rdf:type rdf:Property ;
    rdfs:label 'Projected Occupancy Pct' ;
    rdfs:comment 'Forecasted occupancy rate expressed as a percentage of available rooms expected to be sold on the forecast date. Calculated as constrained demand divided by total available rooms. Key input to RevPAR and yield optimization decisions.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedPickup rdf:type rdf:Property ;
    rdfs:label 'Projected Pickup' ;
    rdfs:comment 'Forecasted incremental room-nights expected to be booked between the forecast run date and the forecast date. Represents the additional demand the RMS expects to materialize beyond rooms already on books.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRevpar rdf:type rdf:Property ;
    rdfs:label 'Projected Revpar' ;
    rdfs:comment 'Forecasted Revenue Per Available Room (RevPAR) in the property\'s local currency for the forecast date. Derived as projected ADR multiplied by projected occupancy rate. Primary yield optimization metric used by Revenue Management.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRoomRevenue rdf:type rdf:Property ;
    rdfs:label 'Projected Room Revenue' ;
    rdfs:comment 'Forecasted total room revenue in the property\'s local currency for the forecast date. Calculated as projected rooms sold multiplied by projected ADR. Used for budget variance analysis and revenue strategy.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRoomsAvailable rdf:type rdf:Property ;
    rdfs:label 'Projected Rooms Available' ;
    rdfs:comment 'Forecasted number of rooms available for sale on the forecast date after accounting for out-of-order, out-of-service, and maintenance blocks. Denominator for occupancy and RevPAR calculations.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedRoomsSold rdf:type rdf:Property ;
    rdfs:label 'Projected Rooms Sold' ;
    rdfs:comment 'Forecasted number of rooms expected to be sold (occupied) on the forecast date. Used for housekeeping scheduling, staffing planning, and inventory control decisions.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rgiForecast rdf:type rdf:Property ;
    rdfs:label 'Rgi Forecast' ;
    rdfs:comment 'Forecasted Revenue Generation Index (RGI), representing the property\'s projected RevPAR relative to the competitive set\'s projected RevPAR. An RGI above 1.0 indicates the property is expected to outperform its competitive set. Sourced from STR STAR Report benchmarking data integrated into Infor EzRMS.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomsOnBooks rdf:type rdf:Property ;
    rdfs:label 'Rooms On Books' ;
    rdfs:comment 'Number of rooms already confirmed (on books) for the forecast date at the time the forecast was generated. Represents the definite demand component; the RMS adds pickup forecast to arrive at total projected demand.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialEventName rdf:type rdf:Property ;
    rdfs:label 'Special Event Name' ;
    rdfs:comment 'Name or description of the special event influencing demand on the forecast date (e.g., \'Super Bowl LIX\', \'New Year Eve\', \'City Marathon\'). Populated only when is_special_event is true.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unconstrainedDemand rdf:type rdf:Property ;
    rdfs:label 'Unconstrained Demand' ;
    rdfs:comment 'The total forecasted room demand (in room-nights) without any inventory capacity constraints applied. Represents true market demand as estimated by the RMS model. Used to identify demand compression and inform inventory control decisions.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displacementAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Displacement Analysis Id' ;
    rdfs:comment 'Unique surrogate identifier for each displacement analysis record. Primary key for the displacement_analysis data product in the revenue domain Silver layer.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'The calendar date on which the displacement analysis was performed by the Revenue Management System or revenue manager. Represents the principal business event date for this record.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Analysis Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the displacement analysis, typically generated by IDeaS G3 RMS group evaluation module (e.g., \'DISP-2024-00123\'). Used for cross-system traceability and revenue manager communication.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisStatus rdf:type rdf:Property ;
    rdfs:label 'Analysis Status' ;
    rdfs:comment 'Current workflow state of the displacement analysis record. \'draft\' indicates in-progress; \'pending_review\' awaits revenue manager sign-off; \'approved\' or \'rejected\' reflects final decision; \'superseded\' indicates a newer analysis replaced this one.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisType rdf:type rdf:Property ;
    rdfs:label 'Analysis Type' ;
    rdfs:comment 'Classification of the type of business being evaluated for displacement. Distinguishes between group room blocks, long-stay contracts, tour operator allotments, and wholesale agreements. [ENUM-REF-CANDIDATE: group_evaluation|contract_evaluation|tour_operator|wholesale|corporate_negotiated|government — promote to reference product]' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryRevenueContribution rdf:type rdf:Property ;
    rdfs:label 'Ancillary Revenue Contribution' ;
    rdfs:comment 'Estimated ancillary revenue contribution from the group if accepted, including spa, parking, audio-visual, and other non-room, non-F&B spend. Supports total spend analysis for TRevPAR (Total Revenue Per Available Room) evaluation.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelSource rdf:type rdf:Property ;
    rdfs:label 'Channel Source' ;
    rdfs:comment 'Distribution channel through which the group or contract inquiry originated (e.g., direct sales, GDS (Global Distribution System), OTA (Online Travel Agency), Delphi event sales). Informs channel cost considerations in the displacement calculation.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Free-text narrative explaining the revenue manager\'s reasoning behind the recommendation outcome, including demand conditions, competitive context, or strategic considerations not captured in quantitative fields.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacementRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Displacement Risk Level' ;
    rdfs:comment 'Categorical risk rating assigned to the displacement analysis indicating the severity of transient revenue displacement if the group is accepted. Derived from net_revenue_impact and forecast_occupancy_pct thresholds configured in IDeaS G3 RMS.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTransientAdrDisplaced rdf:type rdf:Property ;
    rdfs:label 'Estimated Transient Adr Displaced' ;
    rdfs:comment 'Estimated average per-room per-night rate that transient guests would have paid for the same rooms and dates, as forecast by IDeaS G3 RMS. Core metric for measuring revenue opportunity cost of accepting group business.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTransientRoomsDisplaced rdf:type rdf:Property ;
    rdfs:label 'Estimated Transient Rooms Displaced' ;
    rdfs:comment 'Estimated number of transient room-nights that would be displaced (lost) if the group block is accepted. Derived from IDeaS G3 RMS demand forecast for the stay period.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fbRevenueContribution rdf:type rdf:Property ;
    rdfs:label 'Fb Revenue Contribution' ;
    rdfs:comment 'Estimated Food and Beverage (F&B) revenue contribution from the group if accepted, including banquet, catering, and outlet spend. Part of the total spend analysis supporting TRevPAR-based evaluation.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastOccupancyPct rdf:type rdf:Property ;
    rdfs:label 'Forecast Occupancy Pct' ;
    rdfs:comment 'Projected occupancy percentage (OCC) for the property during the stay period at the time of analysis, as sourced from the demand forecast. Contextualizes the displacement risk — high OCC increases displacement cost.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupRoomRevenue rdf:type rdf:Property ;
    rdfs:label 'Group Room Revenue' ;
    rdfs:comment 'Total projected room revenue from the group block if accepted, calculated as proposed_group_rate × room_block_size × los_nights. Represents the revenue inflow side of the displacement equation.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPeakPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Peak Period' ;
    rdfs:comment 'Indicates whether the stay dates fall within a designated peak demand period (e.g., major events, holidays, high-season). Peak periods carry higher displacement risk and typically require higher minimum acceptable rates.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minAcceptableRate rdf:type rdf:Property ;
    rdfs:label 'Min Acceptable Rate' ;
    rdfs:comment 'The minimum per-room per-night rate at which accepting the group block would be revenue-neutral or accretive, as calculated by the displacement model. Used by sales teams as a negotiation floor.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenueImpact rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Impact' ;
    rdfs:comment 'Net revenue impact of accepting the group business, calculated as total_group_spend minus transient_room_revenue_displaced. A positive value indicates the group is accretive; negative indicates displacement loss exceeds group gain.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedGroupRate rdf:type rdf:Property ;
    rdfs:label 'Proposed Group Rate' ;
    rdfs:comment 'The proposed per-room per-night rate offered to the group or contract client. Compared against estimated transient ADR (Average Daily Rate) to determine revenue opportunity cost.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendationOutcome rdf:type rdf:Property ;
    rdfs:label 'Recommendation Outcome' ;
    rdfs:comment 'Revenue management recommendation resulting from the displacement analysis. \'accept\' indicates the group is revenue-positive; \'reject\' indicates displacement loss exceeds group value; \'accept_with_conditions\' requires rate or block size negotiation; \'defer\' awaits further demand data; \'counter_offer\' proposes alternative terms.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Timestamp when the revenue manager completed their review and recorded the final recommendation outcome. Distinct from created_timestamp and updated_timestamp; represents the business decision event time.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revparImpact rdf:type rdf:Property ;
    rdfs:label 'Revpar Impact' ;
    rdfs:comment 'Estimated change in RevPAR (Revenue Per Available Room) attributable to accepting the group block, expressed as a positive or negative dollar amount per available room. Key KPI for revenue management decision-making.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmsEvaluationReference rdf:type rdf:Property ;
    rdfs:label 'Rms Evaluation Reference' ;
    rdfs:comment 'Native evaluation or job identifier assigned by IDeaS G3 RMS when the group evaluation was executed. Enables traceability back to the source system run for audit and re-evaluation purposes.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomBlockSize rdf:type rdf:Property ;
    rdfs:label 'Room Block Size' ;
    rdfs:comment 'Total number of rooms in the proposed group or contract room block being evaluated for displacement impact. Core input to the displacement calculation.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalGroupSpend rdf:type rdf:Property ;
    rdfs:label 'Total Group Spend' ;
    rdfs:comment 'Total estimated revenue from the group across all revenue streams (rooms + F&B + ancillary). Used as the numerator in the full displacement value comparison to support TRevPAR-based decision-making.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transientRoomRevenueDisplaced rdf:type rdf:Property ;
    rdfs:label 'Transient Room Revenue Displaced' ;
    rdfs:comment 'Total estimated transient room revenue that would be lost if the group block is accepted, calculated as estimated_transient_adr_displaced × estimated_transient_rooms_displaced × los_nights. Represents the revenue opportunity cost.' ;
    rdfs:domain ind:DisplacementAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicRateRuleId rdf:type rdf:Property ;
    rdfs:label 'Dynamic Rate Rule Id' ;
    rdfs:comment 'Unique surrogate identifier for a Dynamic Rate Rule (DRR) record in the revenue management system. Primary key for this entity.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DynamicRateRule .

ind:monitoredFnbOutletId rdf:type rdf:Property ;
    rdfs:label 'Monitored Fnb Outlet Id' ;
    rdfs:comment 'Foreign key linking to fnb.fnb_outlet. Business justification: Dynamic pricing rules monitor outlet occupancy for total revenue optimization (restaurant full = adjust room+dining packages). Required for integrated revenue management systems that optimize property' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FnbOutlet .

ind:targetMemberId rdf:type rdf:Property ;
    rdfs:label 'Target Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member. Business justification: Dynamic rules can target specific high-value members for personalized pricing strategies. Business process: VIP member-specific rate rules for retention and revenue optimization, common in luxury hosp' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:adjustmentDirection rdf:type rdf:Property ;
    rdfs:label 'Adjustment Direction' ;
    rdfs:comment 'Indicates whether the Dynamic Rate Rule increases or decreases the rate when triggered. Provides explicit directional intent separate from the sign of adjustment_value to prevent ambiguity in RMS configuration.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Method by which the Dynamic Rate Rule adjusts the published rate when triggered. Percentage applies a relative increase or decrease to the current rate; absolute_amount adds or subtracts a fixed currency value; bar_offset moves the rate a fixed amount above or below the Best Available Rate (BAR); bar_multiplier applies a multiplier to the BAR.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Adjustment Value' ;
    rdfs:comment 'The magnitude of the rate adjustment applied when the Dynamic Rate Rule is triggered. Interpreted according to adjustment_type: a value of 0.10 with type \'percentage\' means a 10% rate increase; a value of 25.00 with type \'absolute_amount\' means a $25 rate increase; a value of -15.00 with type \'bar_offset\' means $15 below BAR.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advanceBookingMaxDays rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Max Days' ;
    rdfs:comment 'Maximum number of days in advance of the arrival date within which a booking must be made for this Dynamic Rate Rule to be eligible to apply. Null indicates no upper advance booking restriction.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advanceBookingMinDays rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Min Days' ;
    rdfs:comment 'Minimum number of days in advance of the arrival date that a booking must be made for this Dynamic Rate Rule to be eligible to apply. Supports advance purchase pricing strategies.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfWeekMask rdf:type rdf:Property ;
    rdfs:label 'Days Of Week Mask' ;
    rdfs:comment 'Seven-character binary string (positions 1–7 = Mon–Sun) indicating which days of the week this Dynamic Rate Rule is eligible to fire. A value of \'1111100\' means Monday through Friday only. Enables day-of-week yield optimization strategies.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTriggeredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Triggered Timestamp' ;
    rdfs:comment 'Date and time when this Dynamic Rate Rule was most recently evaluated as true and triggered an automated pricing adjustment in the RMS. Used by revenue managers to monitor rule activity and effectiveness.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:losMaxNights rdf:type rdf:Property ;
    rdfs:label 'Los Max Nights' ;
    rdfs:comment 'Maximum Length of Stay (LOS) restriction in nights beyond which this Dynamic Rate Rule does not apply. Null indicates no upper LOS restriction.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxRateCeiling rdf:type rdf:Property ;
    rdfs:label 'Max Rate Ceiling' ;
    rdfs:comment 'The highest permissible rate (in property currency) that this Dynamic Rate Rule may produce after adjustment. Acts as a pricing guardrail to prevent rates from exceeding the property\'s maximum acceptable rate cap. Sensitive pricing strategy data.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minRateFloor rdf:type rdf:Property ;
    rdfs:label 'Min Rate Floor' ;
    rdfs:comment 'The lowest permissible rate (in property currency) that this Dynamic Rate Rule may produce after adjustment. Acts as a pricing guardrail to prevent rates from falling below the property\'s minimum acceptable ADR threshold. Sensitive pricing strategy data.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupWindowDays rdf:type rdf:Property ;
    rdfs:label 'Pickup Window Days' ;
    rdfs:comment 'Number of days in the booking pickup window used to evaluate pickup velocity for pickup-based Dynamic Rate Rules. For example, a value of 7 means the rule evaluates rooms booked in the last 7 days.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmsRuleReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Rms Rule Reference Code' ;
    rdfs:comment 'Native rule identifier assigned by the source Revenue Management System (IDeaS G3 RMS or Infor EzRMS) for this Dynamic Rate Rule. Used for system-of-record traceability and reconciliation between the lakehouse Silver layer and the operational RMS.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCount rdf:type rdf:Property ;
    rdfs:label 'Trigger Count' ;
    rdfs:comment 'Cumulative number of times this Dynamic Rate Rule has been triggered and applied a pricing adjustment since its activation date. Used to assess rule utilization and yield optimization effectiveness.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerThresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Operator' ;
    rdfs:comment 'Comparison operator applied to the trigger threshold value to determine whether the rule condition is met. For example, \'greater_than\' with a threshold of 0.80 means the rule fires when OCC exceeds 80%.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Unit' ;
    rdfs:comment 'Unit of measure for the trigger threshold value. Percentage applies to OCC-based rules; room_count applies to pickup-based rules; index_value applies to competitive benchmarking rules (RGI, MPI, ARI); currency_amount applies to ADR-based triggers; nights applies to LOS-based rules.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Value' ;
    rdfs:comment 'The numeric threshold at which this Dynamic Rate Rule fires. For occupancy-based rules, this is the OCC percentage (e.g., 0.80 = 80%). For pickup-based rules, this is the number of rooms picked up within the pickup window. For competitive-based rules, this is the RGI or ARI index value.' ;
    rdfs:domain ind:DynamicRateRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBanquetEventOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Banquet Event Order Id' ;
    rdfs:comment 'Foreign key linking to fnb.banquet_event_order. Business justification: Group evaluations assess F&B revenue contribution from banquet events to offset room displacement. Required for displacement analysis, group acceptance decisions, total property profitability evaluati' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BanquetEventOrder .

ind:washFactorId rdf:type rdf:Property ;
    rdfs:label 'Wash Factor Id' ;
    rdfs:comment 'Foreign key linking to revenue.wash_factor. Business justification: Group evaluations apply wash factors from the wash_factor master table to estimate attrition. N group_evaluation records → 1 wash_factor. Note: wash_factor_pct on group_evaluation is the APPLIED value' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WashFactor .

ind:ancillaryRevenueEstimate rdf:type rdf:Property ;
    rdfs:label 'Ancillary Revenue Estimate' ;
    rdfs:comment 'Estimated ancillary revenue from the group including spa, parking, audio-visual, business center, and other non-room, non-F&B spend. Used in total spend calculation for net revenue impact assessment.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterOfferRate rdf:type rdf:Property ;
    rdfs:label 'Counter Offer Rate' ;
    rdfs:comment 'Alternative per-room per-night rate proposed by the revenue manager as a counter-offer to the group organizer when the proposed_group_rate is below the minimum_acceptable_rate. Populated only when revenue_manager_decision = \'counter_offer\'.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Decision Override Reason' ;
    rdfs:comment 'Free-text justification provided by the revenue manager when their decision overrides the RMS recommendation (e.g., strategic account relationship, future business potential, competitive displacement risk). Required when revenue_manager_decision differs from rms_recommendation.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Timestamp when the revenue manager recorded their final accept, decline, or counter-offer decision. Used for SLA tracking and decision audit trail.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:demandForecastOccupancyPct rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Occupancy Pct' ;
    rdfs:comment 'Forecasted transient Occupancy Rate (OCC) for the property during the group\'s proposed stay dates, as generated by IDeaS G3 RMS or Infor EzRMS. High forecasted occupancy increases displacement cost and raises the minimum acceptable rate.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Evaluation Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp when the group evaluation was initiated and processed by IDeaS G3 RMS. Represents the business event time, distinct from record audit timestamps.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fbRevenueEstimate rdf:type rdf:Property ;
    rdfs:label 'Fb Revenue Estimate' ;
    rdfs:comment 'Estimated Food and Beverage (F&B) revenue contribution from the group, including banquet, catering, and outlet spend. Sourced from Delphi by Amadeus event catering estimates and historical group F&B spend patterns.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:historicalWashPct rdf:type rdf:Property ;
    rdfs:label 'Historical Wash Pct' ;
    rdfs:comment 'Historical average wash percentage for this group type and property, derived from past group performance data in IDeaS G3 RMS. Serves as the baseline input before adjustments for lead time and current demand conditions.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inquiryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Inquiry Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the group booking inquiry, as generated by the Central Reservation System (CRS) or Property Management System (PMS). Used to cross-reference the evaluation with the originating inquiry across Oracle OPERA PMS and Sabre SynXis CRS.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefiniteBooking rdf:type rdf:Property ;
    rdfs:label 'Is Definite Booking' ;
    rdfs:comment 'Indicates whether the group inquiry has converted to a definite (contracted) booking following a positive revenue manager decision. True = definite booking confirmed; False = still in tentative or evaluation stage.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeBucket rdf:type rdf:Property ;
    rdfs:label 'Lead Time Bucket' ;
    rdfs:comment 'Categorical bucket representing the number of days between the group inquiry date and the proposed arrival date. Used as a parameter in wash factor modeling, as groups booked further in advance typically exhibit higher wash rates.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAcceptableRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Acceptable Rate' ;
    rdfs:comment 'The minimum per-room per-night rate recommended by IDeaS G3 RMS below which accepting the group would result in negative net revenue impact after accounting for displacement costs. This is the RMS-generated floor rate for negotiation.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakNightRooms rdf:type rdf:Property ;
    rdfs:label 'Peak Night Rooms' ;
    rdfs:comment 'Maximum number of rooms occupied on any single night within the group block. Used for capacity planning and displacement analysis at the peak demand point.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueManagerDecision rdf:type rdf:Property ;
    rdfs:label 'Revenue Manager Decision' ;
    rdfs:comment 'Final decision made by the revenue manager after reviewing the RMS recommendation and displacement analysis. May align with or override the RMS recommendation. \'pending\' indicates no decision has been recorded yet.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rgiBenchmark rdf:type rdf:Property ;
    rdfs:label 'Rgi Benchmark' ;
    rdfs:comment 'The property\'s Revenue Generation Index (RGI) from the STR STAR Report for the competitive set during the evaluation period. Used as a competitive context benchmark to assess whether accepting the group at the proposed rate is competitively rational.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmsRecommendation rdf:type rdf:Property ;
    rdfs:label 'Rms Recommendation' ;
    rdfs:comment 'Automated accept, decline, or counter-offer recommendation generated by IDeaS G3 RMS based on displacement analysis, wash factor modeling, and net revenue impact. This is the system-generated recommendation prior to revenue manager override.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transientAdrDisplaced rdf:type rdf:Property ;
    rdfs:label 'Transient Adr Displaced' ;
    rdfs:comment 'The forecasted Average Daily Rate (ADR) of the transient business that would be displaced by the group block, as estimated by IDeaS G3 RMS. Used to quantify the revenue opportunity cost of accepting the group.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transientRoomsDisplaced rdf:type rdf:Property ;
    rdfs:label 'Transient Rooms Displaced' ;
    rdfs:comment 'Estimated number of transient (individual) room nights that would be displaced if the group block is accepted, as calculated by IDeaS G3 RMS displacement analysis. Core input to the net revenue impact calculation.' ;
    rdfs:domain ind:GroupEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInventoryPropertyId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Property Id' ;
    rdfs:comment 'Reference to the property (hotel, resort, or vacation property) to which this inventory control record applies. Aligns with Oracle OPERA PMS property configuration and IDeaS G3 RMS property setup.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:updatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Updated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Revenue managers set inventory controls; tracking updater essential for override authority validation, compliance audit trails, and accountability for sell limits, hurdle rates, and overbooking decisi' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allotmentRooms rdf:type rdf:Property ;
    rdfs:label 'Allotment Rooms' ;
    rdfs:comment 'Number of rooms of this room type on the stay date allocated to contracted allotments (OTA allotments, wholesale, tour operator contracts). Managed via Sabre SynXis CRS channel management and reduces the freely-sellable transient inventory.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlRecordCode rdf:type rdf:Property ;
    rdfs:label 'Control Record Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this inventory control record as referenced in IDeaS G3 RMS and Sabre SynXis CRS. Used for cross-system reconciliation and audit traceability.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classifies the category of inventory control applied to this record. Determines how the control_value is interpreted and enforced by the Revenue Management System. [ENUM-REF-CANDIDATE: hurdle_rate|sell_limit|overbooking_level|los_restriction|cta_restriction|ctd_restriction|allotment|group_block — promote to reference product]' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlValue rdf:type rdf:Property ;
    rdfs:label 'Control Value' ;
    rdfs:comment 'The operative value for this control record as applied by the Revenue Management System. Interpretation depends on control_type: for hurdle_rate it is the minimum acceptable rate in local currency; for sell_limit it is the maximum rooms to sell; for overbooking_level it is the number of rooms above physical capacity authorized to sell.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentBar rdf:type rdf:Property ;
    rdfs:label 'Current Bar' ;
    rdfs:comment 'The current Best Available Rate (BAR) in local currency for this room type and stay date as published via Sabre SynXis CRS and channel distribution. Represents the lowest publicly available non-restricted rate and is the primary pricing signal for transient demand.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandForecastRooms rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Rooms' ;
    rdfs:comment 'IDeaS G3 RMS or Infor EzRMS demand forecast for unconstrained room demand for this room type on the stay date at the time this control record was generated. Used to contextualize the control_value against projected demand and support RevPAR optimization.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective From Timestamp' ;
    rdfs:comment 'The date and time from which this inventory control record\'s control_value and restrictions became operative in the Revenue Management System. Supports temporal validity tracking and historical rate/availability grid reconstruction.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveUntilTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Until Timestamp' ;
    rdfs:comment 'The date and time at which this inventory control record\'s control_value and restrictions ceased to be operative. Null for currently active records. Enables point-in-time historical analysis of the rate/availability grid.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groupBlockRooms rdf:type rdf:Property ;
    rdfs:label 'Group Block Rooms' ;
    rdfs:comment 'Number of rooms of this room type on the stay date allocated to group blocks (MICE, tour groups, corporate groups). Reduces the transient sell limit and is managed via Delphi by Amadeus group block management and IDeaS G3 RMS group evaluation.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastDistributedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Distributed Timestamp' ;
    rdfs:comment 'The date and time when this inventory control record\'s rate and availability state was last successfully distributed to Sabre SynXis CRS and downstream channels (OTA, GDS). Critical for SLA monitoring and channel distribution reconciliation.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRate rdf:type rdf:Property ;
    rdfs:label 'Max Rate' ;
    rdfs:comment 'The ceiling rate in local currency above which no rate plan for this room type and stay date may be sold. Used to enforce rate integrity, prevent rate gouging, and comply with local pricing regulations during high-demand periods.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minRate rdf:type rdf:Property ;
    rdfs:label 'Min Rate' ;
    rdfs:comment 'The absolute floor rate in local currency below which no rate plan for this room type and stay date may be sold, regardless of channel or negotiated agreement. Enforced as a hard constraint in the Revenue Management System and CRS.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyOnBooks rdf:type rdf:Property ;
    rdfs:label 'Occupancy On Books' ;
    rdfs:comment 'Current confirmed occupancy rate (OCC) percentage for this room type on the stay date at the time of last update, calculated as confirmed reservations divided by physical_room_count. Key input to dynamic pricing and sell limit decisions in the Revenue Management System.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfOrderRooms rdf:type rdf:Property ;
    rdfs:label 'Out Of Order Rooms' ;
    rdfs:comment 'Number of rooms of this room type on the stay date designated as out of order (OOO) due to maintenance, renovation, or FF&E replacement. These rooms are excluded from sellable inventory and occupancy calculations per USALI standards.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingAbsoluteCap rdf:type rdf:Property ;
    rdfs:label 'Overbooking Absolute Cap' ;
    rdfs:comment 'Hard ceiling on the absolute number of rooms that may be overbooked above physical capacity for this room type on the stay date, regardless of the overbooking_pct calculation. Prevents excessive walk exposure during high-demand periods.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingPct rdf:type rdf:Property ;
    rdfs:label 'Overbooking Pct' ;
    rdfs:comment 'Maximum authorized overbooking level expressed as a percentage above physical room capacity for this room type on the stay date. Defined in the overbooking policy and used by IDeaS G3 RMS to set the sell limit above physical_room_count.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalRoomCount rdf:type rdf:Property ;
    rdfs:label 'Physical Room Count' ;
    rdfs:comment 'Total number of physical rooms of this room type at the property, representing the hard capacity ceiling before overbooking allowances are applied. Used as the denominator for occupancy rate (OCC) calculations.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateAvailabilitySource rdf:type rdf:Property ;
    rdfs:label 'Rate Availability Source' ;
    rdfs:comment 'Identifies the originating system or process that set the current rate and availability state for this control record. Supports data lineage, audit, and reconciliation between IDeaS G3 RMS, Sabre SynXis CRS, and Oracle OPERA PMS.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemRecommendedValue rdf:type rdf:Property ;
    rdfs:label 'System Recommended Value' ;
    rdfs:comment 'The value recommended by the Revenue Management System (IDeaS G3 RMS or Infor EzRMS) prior to any manual override. Enables comparison between algorithmic recommendation and the applied control_value for yield optimization analysis and RMS model performance tracking.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:walkCompensationType rdf:type rdf:Property ;
    rdfs:label 'Walk Compensation Type' ;
    rdfs:comment 'Type of compensation offered to a walked guest when the walk_policy requires compensation. Governs the financial and loyalty implications of overbooking execution and is tracked for Guest Recovery Rate (GRR) and CPOR reporting.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walkPolicy rdf:type rdf:Property ;
    rdfs:label 'Walk Policy' ;
    rdfs:comment 'Defines the operational procedure to follow when a guest with a confirmed reservation cannot be accommodated due to overbooking (a \'walk\'). Determines whether the guest is walked to a partner hotel, upgraded, or compensated per AHLA guest relocation standards.' ;
    rdfs:domain ind:InventoryControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultLoyaltyTierId rdf:type rdf:Property ;
    rdfs:label 'Default Loyalty Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: Market segments map to typical loyalty tiers for segmentation alignment and forecasting. Business process: aligning revenue management segments with loyalty tier definitions for consistent guest class' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:preferredFnbOutletId rdf:type rdf:Property ;
    rdfs:label 'Preferred Fnb Outlet Id' ;
    rdfs:comment 'Foreign key linking to fnb.fnb_outlet. Business justification: Market segments have outlet preferences/restrictions (corporate guests → business center cafe, leisure → poolside bar). Required for outlet positioning strategy, menu design, targeted marketing, guest' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FnbOutlet .

ind:adaAccommodationTypical rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Typical' ;
    rdfs:comment 'Indicates whether guests in this market segment typically require ADA (Americans with Disabilities Act) accessible accommodations. Relevant for government, medical, and certain group segments. Informs room inventory allocation and accessibility compliance reporting.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:avgLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Avg Lead Time Days' ;
    rdfs:comment 'Average number of days between booking date and arrival date for this market segment. Key input for demand forecasting in IDeaS G3 RMS and Infor EzRMS. Segments with short lead times (e.g., OTA last-minute) require different yield strategies than long-lead corporate or group segments. Represents the MEASUREMENT_OR_VALUE for this resource.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgLengthOfStayNights rdf:type rdf:Property ;
    rdfs:label 'Avg Length Of Stay Nights' ;
    rdfs:comment 'Average number of nights guests in this segment stay per booking (ALOS — Average Length of Stay). Used in revenue management for LOS (Length of Stay) restriction optimization, demand forecasting, and RevPAR (Revenue Per Available Room) modeling in IDeaS G3 RMS.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationPropensity rdf:type rdf:Property ;
    rdfs:label 'Cancellation Propensity' ;
    rdfs:comment 'Qualitative classification of the historical cancellation rate tendency for this market segment. Informs overbooking strategy, no-show reserve calculations, and revenue protection policies in IDeaS G3 RMS. High-propensity segments (e.g., OTA flexible rate) require higher overbooking buffers.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAffinity rdf:type rdf:Property ;
    rdfs:label 'Channel Affinity' ;
    rdfs:comment 'Primary distribution channel through which this market segment predominantly books. Drives channel strategy, OTA (Online Travel Agency) commission management, and GDS (Global Distribution System) rate loading decisions in Sabre SynXis CRS. Used for channel mix analysis and cost-of-acquisition reporting. [ENUM-REF-CANDIDATE: direct|ota|gds|voice|group|wholesale|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionMarginTier rdf:type rdf:Property ;
    rdfs:label 'Contribution Margin Tier' ;
    rdfs:comment 'Classification of the segment\'s typical contribution margin profile relative to other segments. Reflects net revenue after channel commissions, OTA fees, GDS fees, and loyalty redemption costs. Premium tiers (e.g., direct corporate) yield higher GOP (Gross Operating Profit) than low-margin OTA or wholesale segments. Used in GOPPAR analysis.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crs Segment Code' ;
    rdfs:comment 'The segment code as configured in Sabre SynXis CRS for central reservations and channel distribution. Used for rate plan distribution, availability controls, and channel-level segment reporting. Enables cross-system segment reconciliation.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPattern rdf:type rdf:Property ;
    rdfs:label 'Demand Pattern' ;
    rdfs:comment 'Classification of the temporal demand pattern exhibited by this market segment. Corporate transient segments typically show weekday concentration; leisure segments show weekend and seasonal peaks; event-driven segments spike around MICE (Meetings Incentives Conferences Exhibitions) events. Used in Infor EzRMS demand forecasting.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDataSubjectApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Subject Applicable' ;
    rdfs:comment 'Indicates whether guest data associated with bookings in this market segment is subject to GDPR data subject rights (right to erasure, portability, access). Relevant for segments involving EU/EEA guests. Drives data retention and anonymization policies in the data lakehouse.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsEligible rdf:type rdf:Property ;
    rdfs:label 'Gds Eligible' ;
    rdfs:comment 'Indicates whether rates for this market segment are distributed through GDS (Global Distribution System) channels such as Amadeus, Sabre, and Travelport. Controls rate loading and availability display in Sabre SynXis CRS for GDS-connected travel agencies.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupBlockEligible rdf:type rdf:Property ;
    rdfs:label 'Group Block Eligible' ;
    rdfs:comment 'Indicates whether this market segment supports group room block reservations. Group-eligible segments (e.g., MICE, sports groups, tour groups) require group block management in Oracle OPERA PMS and Delphi by Amadeus for BEO (Banquet Event Order) coordination.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInternalUseOnly rdf:type rdf:Property ;
    rdfs:label 'Is Internal Use Only' ;
    rdfs:comment 'Indicates whether this market segment is for internal reporting and analytics purposes only and should not be exposed to guests, OTA partners, or external distribution channels. Internal segments (e.g., complimentary, house use, employee rate) are excluded from external rate distribution in Sabre SynXis CRS.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Eligible' ;
    rdfs:comment 'Indicates whether bookings under this market segment are eligible to earn loyalty program points and benefits. Wholesale, crew, and certain contracted segments may be excluded from loyalty accrual per program rules. Drives loyalty point calculation logic in Salesforce CRM loyalty management.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSegmentDescription rdf:type rdf:Property ;
    rdfs:label 'Market Segment Description' ;
    rdfs:comment 'Detailed narrative description of the market segment, including its defining characteristics, typical guest profile, booking behavior, and applicable rate strategies. Used for training, documentation, and business glossary alignment across revenue management, reservations, and sales teams.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegmentStatus rdf:type rdf:Property ;
    rdfs:label 'Market Segment Status' ;
    rdfs:comment 'Current lifecycle status of the market segment record. Active segments are available for rate plan assignment, reservation coding, and revenue reporting. Inactive or deprecated segments are retained for historical analysis but excluded from new bookings. Aligns with MASTER_RESOURCE LIFECYCLE_STATUS requirement.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minRateOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Min Rate Override Allowed' ;
    rdfs:comment 'Indicates whether revenue managers are permitted to override the minimum rate floor for this segment. Restricting overrides for high-value segments (e.g., LRA corporate) protects rate integrity. Configurable in IDeaS G3 RMS inventory controls and Oracle OPERA PMS rate management.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiatedRateRequired rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate Required' ;
    rdfs:comment 'Indicates whether bookings in this segment require a pre-negotiated rate agreement (e.g., corporate account rate, government per diem, airline crew contract). When true, a valid rate agreement must exist before reservations can be accepted at segment rates in Oracle OPERA PMS.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noShowPropensity rdf:type rdf:Property ;
    rdfs:label 'No Show Propensity' ;
    rdfs:comment 'Qualitative classification of the historical no-show rate tendency for this market segment. Distinct from cancellation propensity — no-shows occur without prior cancellation and have different revenue recovery implications. Used in overbooking model calibration within IDeaS G3 RMS.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaEligible rdf:type rdf:Property ;
    rdfs:label 'Ota Eligible' ;
    rdfs:comment 'Indicates whether rates for this market segment are distributed through OTA (Online Travel Agency) channels such as Expedia, Booking.com, and Hotels.com. Controls channel availability in Sabre SynXis CRS and impacts OTA commission cost tracking.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciScope rdf:type rdf:Property ;
    rdfs:label 'Pci Scope' ;
    rdfs:comment 'Indicates whether payment card data associated with bookings in this segment falls within PCI DSS scope. Segments with direct card-present or card-not-present transactions require PCI-compliant data handling. Drives data masking and tokenization requirements in the lakehouse.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pmsSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Pms Segment Code' ;
    rdfs:comment 'The segment code as configured in Oracle OPERA PMS. Used for reservation coding, folio routing, and rate plan assignment at the property level. Enables reconciliation between the enterprise data lakehouse and the operational PMS source system.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSensitivity rdf:type rdf:Property ;
    rdfs:label 'Price Sensitivity' ;
    rdfs:comment 'Classification of the segment\'s sensitivity to rate changes. Inelastic segments (e.g., airline crew, government contracted) book regardless of rate fluctuations. Highly elastic segments (e.g., leisure OTA) respond strongly to price changes. Drives DRR (Dynamic Rate Rule) configuration in IDeaS G3 RMS.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueBucket rdf:type rdf:Property ;
    rdfs:label 'Revenue Bucket' ;
    rdfs:comment 'Primary revenue category associated with this market segment for TRevPAR (Total Revenue Per Available Room) and USALI departmental reporting. Rooms-focused segments contribute primarily to rooms revenue; MICE segments contribute across rooms, F&B (Food and Beverage), and events revenue buckets.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmsSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Rms Segment Code' ;
    rdfs:comment 'The segment code as configured in IDeaS G3 RMS or Infor EzRMS. Used for demand forecasting, pricing optimization, and inventory control at the segment level. May differ from PMS segment code due to system-specific taxonomy requirements.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Str Segment Code' ;
    rdfs:comment 'The official STR (Smith Travel Research) segment code used for competitive benchmarking and STAR Report alignment. Enables mapping of internal segment definitions to the industry-standard STR taxonomy for RGI (Revenue Generation Index), MPI (Market Penetration Index), and ARI (Average Rate Index) calculations.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usaliSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Usali Segment Code' ;
    rdfs:comment 'The USALI (Uniform System of Accounts for the Lodging Industry) standardized segment code used for financial reporting and departmental P&L allocation. Ensures consistency in GOP (Gross Operating Profit), NOI (Net Operating Income), and EBITDA reporting across properties and for external financial audits under GAAP/IFRS.' ;
    rdfs:domain ind:MarketSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceActualsId rdf:type rdf:Property ;
    rdfs:label 'Performance Actuals Id' ;
    rdfs:comment 'Primary key for performance_actuals' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Reference to the fiscal calendar period (month/quarter/year) to which this performance date belongs, enabling USALI-aligned financial period reporting and variance analysis against budget.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:primaryFnbOutletId rdf:type rdf:Property ;
    rdfs:label 'Primary Fnb Outlet Id' ;
    rdfs:comment 'Foreign key linking to fnb.fnb_outlet. Business justification: Daily actuals track outlet-level F&B revenue for TRevPAR calculation and USALI reporting. Required for total property revenue reporting, GOP analysis, outlet performance attribution in consolidated fi' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FnbOutlet .

ind:reconciledByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reconciled By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Finance/revenue analysts reconcile daily actuals; employee attribution required for data quality accountability, reconciliation workflow tracking, and performance evaluation of financial reporting acc' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAdr rdf:type rdf:Property ;
    rdfs:label 'Budget Adr' ;
    rdfs:comment 'Budgeted Average Daily Rate for the performance date. Used for ADR variance analysis against actuals in the DOR, revenue management reporting, and STR STAR Report benchmarking.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetOccupancyRate rdf:type rdf:Property ;
    rdfs:label 'Budget Occupancy Rate' ;
    rdfs:comment 'Budgeted occupancy rate for the performance date as a decimal (e.g., 0.7500 = 75.00%). Used for occupancy variance analysis against actuals in the DOR and revenue management reporting.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetRoomRevenue rdf:type rdf:Property ;
    rdfs:label 'Budget Room Revenue' ;
    rdfs:comment 'Budgeted room revenue for the performance date as approved in the annual operating budget. Used for variance analysis against actual room revenue in the DOR and ownership reporting.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetTotalRevenue rdf:type rdf:Property ;
    rdfs:label 'Budget Total Revenue' ;
    rdfs:comment 'Budgeted total property revenue for the performance date as approved in the annual operating budget. Used for total revenue variance analysis in the DOR and ownership reporting.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelDirectRooms rdf:type rdf:Property ;
    rdfs:label 'Channel Direct Rooms' ;
    rdfs:comment 'Number of rooms sold through direct channels (brand website, call center, walk-in) on the performance date. Supports direct vs. indirect channel mix analysis and cost-of-acquisition reporting.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelOtaRooms rdf:type rdf:Property ;
    rdfs:label 'Channel Ota Rooms' ;
    rdfs:comment 'Number of rooms sold through Online Travel Agency (OTA) channels (e.g., Expedia, Booking.com) on the performance date. Supports channel distribution mix analysis and OTA commission cost management.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpor rdf:type rdf:Property ;
    rdfs:label 'Cpor' ;
    rdfs:comment 'Cost Per Occupied Room on the performance date, calculated as total rooms department operating expenses divided by rooms sold. Measures operational efficiency of the rooms department per USALI.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaContribution rdf:type rdf:Property ;
    rdfs:label 'Ebitda Contribution' ;
    rdfs:comment 'Property-level EBITDA contribution on the performance date, representing operating earnings before interest, taxes, depreciation, and amortization. Used for ownership reporting, asset valuation, and management contract performance measurement.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gop rdf:type rdf:Property ;
    rdfs:label 'Gop' ;
    rdfs:comment 'Gross Operating Profit on the performance date, calculated as total operated department revenue minus total operated department expenses per USALI. Key profitability metric for ownership reporting and management contracts.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goppar rdf:type rdf:Property ;
    rdfs:label 'Goppar' ;
    rdfs:comment 'Gross Operating Profit Per Available Room in the property\'s operating currency, calculated as GOP divided by rooms available. Measures overall property profitability efficiency. Core KPI for ownership reporting and management fee calculations.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Reconciled' ;
    rdfs:comment 'Indicates whether this daily performance actual record has been reconciled between Oracle OPERA PMS and SAP S/4HANA General Ledger. True = reconciled and approved for reporting; False = pending reconciliation. Supports financial close and SOX controls.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:miscellaneousIncome rdf:type rdf:Property ;
    rdfs:label 'Miscellaneous Income' ;
    rdfs:comment 'Total miscellaneous and rental income on the performance date including rentals, commissions, and other non-departmental income per USALI non-operating income classification.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpi rdf:type rdf:Property ;
    rdfs:label 'Mpi' ;
    rdfs:comment 'Market Penetration Index representing the property\'s occupancy performance relative to its competitive set, sourced from STR STAR Report. MPI > 1.0 indicates the property is capturing more than its fair share of market occupancy.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyRate rdf:type rdf:Property ;
    rdfs:label 'Occupancy Rate' ;
    rdfs:comment 'Daily occupancy rate expressed as a decimal (e.g., 0.8250 = 82.50%), calculated as rooms sold divided by rooms available. Core KPI for the STR STAR Report, DOR, and ownership reporting. Stored as a raw ratio; display layer applies percentage formatting.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherOperatedDeptRevenue rdf:type rdf:Property ;
    rdfs:label 'Other Operated Dept Revenue' ;
    rdfs:comment 'Total revenue from all other operated departments on the performance date (e.g., golf, retail, recreation, business center) excluding rooms, F&B, spa, and parking. Classified per USALI other operated departments schedule.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parkingRevenue rdf:type rdf:Property ;
    rdfs:label 'Parking Revenue' ;
    rdfs:comment 'Total parking revenue generated on the performance date from valet, self-park, and garage operations. Classified under other operated departments per USALI and included in TRevPAR.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceDate rdf:type rdf:Property ;
    rdfs:label 'Performance Date' ;
    rdfs:comment 'The calendar date (business date) for which this revenue performance actual record applies. Represents the stay date or operating day used in the Daily Operations Report (DOR) and all KPI calculations.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorYearRevpar rdf:type rdf:Property ;
    rdfs:label 'Prior Year Revpar' ;
    rdfs:comment 'RevPAR for the same calendar date in the prior year. Used for year-over-year (YOY) variance analysis in the DOR, STR STAR Report benchmarking, and ownership reporting.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomsAvailable rdf:type rdf:Property ;
    rdfs:label 'Rooms Available' ;
    rdfs:comment 'Total number of rooms available for sale on the performance date after deducting out-of-order (OOO) and out-of-service (OOS) rooms. Denominator for Occupancy Rate (OCC) and RevPAR calculations per USALI and STR STAR Report standards.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentContractRooms rdf:type rdf:Property ;
    rdfs:label 'Segment Contract Rooms' ;
    rdfs:comment 'Number of rooms sold under negotiated contract rates (airline crew, long-stay corporate contracts) on the performance date. Supports contract segment revenue analysis and channel mix reporting.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentGroupRooms rdf:type rdf:Property ;
    rdfs:label 'Segment Group Rooms' ;
    rdfs:comment 'Number of rooms sold to group accounts (MICE, corporate groups, tour groups) on the performance date. Supports group vs. transient mix analysis and group revenue contribution reporting per USALI.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentTransientRooms rdf:type rdf:Property ;
    rdfs:label 'Segment Transient Rooms' ;
    rdfs:comment 'Number of rooms sold to transient (individual/FIT) guests on the performance date. Supports segment-level revenue analysis and channel mix reporting per USALI market segmentation standards.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spaRevenue rdf:type rdf:Property ;
    rdfs:label 'Spa Revenue' ;
    rdfs:comment 'Total spa and wellness revenue generated on the performance date. Included in total property revenue and TRevPAR calculation per USALI other operated departments classification.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPropertyRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Property Revenue' ;
    rdfs:comment 'Total gross revenue across all operated departments and income streams on the performance date (rooms + F&B + spa + parking + other operated departments + miscellaneous + ancillary). Denominator basis for TRevPAR. Reconciled against SAP S/4HANA GL per USALI.' ;
    rdfs:domain ind:PerformanceActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trevpar rdf:type rdf:Property ;
    rdfs:label 'Trevpar' ;
    rdfs:comment 'Total Revenue Per Available Room in the property\'s operating currency, calculated as total property revenue divided by rooms available. Measures total revenue productivity of the property beyond rooms. Core KPI for ownership and management reporting.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupReportId rdf:type rdf:Property ;
    rdfs:label 'Pickup Report Id' ;
    rdfs:comment 'Unique surrogate identifier for each pickup report record in the Silver Layer lakehouse. Primary key for this entity. Entity role: TRANSACTION_HEADER — represents a discrete revenue management snapshot event tracking booking pace against forecast for a given stay date and property.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adrOnBooks rdf:type rdf:Property ;
    rdfs:label 'Adr On Books' ;
    rdfs:comment 'Average Daily Rate (ADR) of all rooms currently on books for the stay_date as of the report_date. Calculated as total room revenue on books divided by rooms_on_books. Core revenue performance indicator alongside occupancy pace. Expressed in the property\'s operating currency.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adrVarianceToForecast rdf:type rdf:Property ;
    rdfs:label 'Adr Variance To Forecast' ;
    rdfs:comment 'Difference between adr_on_books and forecasted_adr (adr_on_books minus forecasted_adr). Positive value indicates rate is tracking above forecast; negative value indicates rate is below forecast. Used alongside rooms_variance_to_forecast to assess overall revenue pace.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandLevel rdf:type rdf:Property ;
    rdfs:label 'Demand Level' ;
    rdfs:comment 'Revenue management system classification of expected demand intensity for the stay_date as of the report_date. Drives pricing strategy and inventory control decisions: \'distressed\' triggers promotional actions; \'peak\' triggers rate maximization and LOS (Length of Stay) restrictions.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastedAdr rdf:type rdf:Property ;
    rdfs:label 'Forecasted Adr' ;
    rdfs:comment 'Revenue management system forecast for the expected ADR (Average Daily Rate) on the stay_date, as generated by IDeaS G3 RMS or Infor EzRMS. Baseline against which adr_on_books is compared to assess rate performance vs plan.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedRevpar rdf:type rdf:Property ;
    rdfs:label 'Forecasted Revpar' ;
    rdfs:comment 'Revenue management system forecast for RevPAR (Revenue Per Available Room) on the stay_date. Baseline against which revpar_on_books is compared to assess overall revenue pace vs plan. Expressed in the property\'s operating currency.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedRooms rdf:type rdf:Property ;
    rdfs:label 'Forecasted Rooms' ;
    rdfs:comment 'Revenue management system forecast for total rooms expected to be occupied on the stay_date, as generated by IDeaS G3 RMS or Infor EzRMS at the time of this report snapshot. Baseline against which rooms_on_books pace is measured to compute variance.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:losRestrictionActive rdf:type rdf:Property ;
    rdfs:label 'Los Restriction Active' ;
    rdfs:comment 'Indicates whether a LOS (Length of Stay) restriction (minimum stay requirement) is currently active for the stay_date. LOS restrictions are a key revenue management lever applied during high-demand periods to maximize total revenue across multiple nights.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickupVelocity rdf:type rdf:Property ;
    rdfs:label 'Pickup Velocity' ;
    rdfs:comment 'Rate of new reservations being added per day for the stay_date, calculated as the incremental rooms picked up divided by the number of days elapsed in the measurement window. Expressed as rooms per day. Enables revenue managers to assess acceleration or deceleration of booking pace.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearAdr rdf:type rdf:Property ;
    rdfs:label 'Prior Year Adr' ;
    rdfs:comment 'ADR (Average Daily Rate) on books for the equivalent stay_date in the prior year, at the same lead time. Enables year-over-year rate comparison to assess whether current pricing strategy is yielding rate improvement or erosion versus the prior period.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearRoomsOnBooks rdf:type rdf:Property ;
    rdfs:label 'Prior Year Rooms On Books' ;
    rdfs:comment 'Number of rooms that were on books for the equivalent stay_date in the prior year, at the same lead time (days out). Enables year-over-year (YOY) pace comparison — a standard revenue management benchmarking technique to contextualize current booking pace against historical performance.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known business identifier for this pickup report record, typically formatted as PKP-{PropertyCode}-{StayDate}-{SequenceNumber}. Used by revenue managers to reference specific pickup snapshots in IDeaS G3 RMS and Infor EzRMS reporting. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER requirement.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle state of this pickup report record. \'draft\' indicates the snapshot is being assembled; \'published\' indicates it is available for revenue manager consumption; \'superseded\' indicates a later snapshot for the same stay_date/report_date exists; \'cancelled\' indicates the report was voided. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS requirement.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the pickup report generation cadence: \'daily\' for standard automated daily snapshots, \'weekly\' for weekly pace summaries, \'monthly\' for month-end pace reviews, or \'adhoc\' for analyst-triggered on-demand reports. Determines the reporting frequency context for pace trend analysis.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revparOnBooks rdf:type rdf:Property ;
    rdfs:label 'Revpar On Books' ;
    rdfs:comment 'Revenue Per Available Room (RevPAR) derived from current on-books position, calculated as (adr_on_books multiplied by rooms_on_books) divided by total_available_rooms. Composite pace metric combining rate and occupancy performance. Expressed in the property\'s operating currency.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomsOnBooks14d rdf:type rdf:Property ;
    rdfs:label 'Rooms On Books 14d' ;
    rdfs:comment 'Number of rooms that were on books for the stay_date when the lead time was 14 days (i.e., the snapshot captured 14 days prior to stay_date). Critical short-window pace indicator used to trigger last-minute pricing tactics and inventory controls.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsOnBooks1d rdf:type rdf:Property ;
    rdfs:label 'Rooms On Books 1d' ;
    rdfs:comment 'Number of rooms that were on books for the stay_date when the lead time was 1 day (i.e., the snapshot captured 1 day prior to stay_date). Final pre-arrival pace indicator representing near-final committed occupancy before day-of walk-ins.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsOnBooks30d rdf:type rdf:Property ;
    rdfs:label 'Rooms On Books 30d' ;
    rdfs:comment 'Number of rooms that were on books for the stay_date when the lead time was 30 days (i.e., the snapshot captured 30 days prior to stay_date). Key pace benchmark for near-term demand assessment and rate strategy adjustments.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsOnBooks60d rdf:type rdf:Property ;
    rdfs:label 'Rooms On Books 60d' ;
    rdfs:comment 'Number of rooms that were on books for the stay_date when the lead time was 60 days (i.e., the snapshot captured 60 days prior to stay_date). Standard pace benchmark used by revenue managers to assess mid-range booking momentum.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsOnBooks7d rdf:type rdf:Property ;
    rdfs:label 'Rooms On Books 7d' ;
    rdfs:comment 'Number of rooms that were on books for the stay_date when the lead time was 7 days (i.e., the snapshot captured 7 days prior to stay_date). Near-arrival pace indicator used to assess last-week demand and trigger promotional or restriction actions.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsOnBooks90d rdf:type rdf:Property ;
    rdfs:label 'Rooms On Books 90d' ;
    rdfs:comment 'Number of rooms that were on books for the stay_date when the lead time was 90 days (i.e., the snapshot captured 90 days prior to stay_date). Used as a historical pace benchmark for comparison against current rooms_on_books to measure pickup velocity over the 90-day window.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomsVarianceToForecast rdf:type rdf:Property ;
    rdfs:label 'Rooms Variance To Forecast' ;
    rdfs:comment 'Difference between rooms_on_books and forecasted_rooms (rooms_on_books minus forecasted_rooms). Positive value indicates ahead-of-pace (over-performing vs forecast); negative value indicates behind-pace (under-performing). Primary KPI for revenue manager intervention decisions.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAvailableRooms rdf:type rdf:Property ;
    rdfs:label 'Total Available Rooms' ;
    rdfs:comment 'Total number of rooms available for sale for the stay_date at the property (net of out-of-order and out-of-service rooms). Denominator for occupancy rate (OCC) calculation and RevPAR computation. Sourced from Oracle OPERA PMS inventory controls.' ;
    rdfs:domain ind:PickupReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingOverrideId rdf:type rdf:Property ;
    rdfs:label 'Pricing Override Id' ;
    rdfs:comment 'Unique surrogate identifier for each manual pricing override record in the revenue management system. Primary key for the pricing_override data product.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPricingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pricing Employee Id' ;
    rdfs:comment 'Reference to the revenue manager employee who applied or approved the pricing override. Used for accountability tracking and override frequency analysis per individual manager.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Pct' ;
    rdfs:comment 'The rate variance percentage threshold (as a decimal, e.g., 0.2000 = 20%) that triggered the approval requirement for this override. Captures the governance rule in effect at the time of submission for audit purposes.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelRestriction rdf:type rdf:Property ;
    rdfs:label 'Channel Restriction' ;
    rdfs:comment 'Specifies which distribution channels the overridden rate is published to. \'all_channels\' = no restriction; \'direct_only\' = hotel direct and brand website only; \'ota_excluded\' = all channels except Online Travel Agencies (OTA); \'gds_only\' = Global Distribution System (GDS) only; \'brand_website_only\' = brand.com only.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedToArrival rdf:type rdf:Property ;
    rdfs:label 'Closed To Arrival' ;
    rdfs:comment 'Indicates whether the overridden rate includes a Closed to Arrival (CTA) restriction, preventing new reservations with an arrival date falling within the override effective window. True = CTA restriction active; False = arrivals permitted.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedToDeparture rdf:type rdf:Property ;
    rdfs:label 'Closed To Departure' ;
    rdfs:comment 'Indicates whether the overridden rate includes a Closed to Departure (CTD) restriction, preventing check-outs on specific dates within the override window. True = CTD restriction active; False = departures permitted.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveRateReference rdf:type rdf:Property ;
    rdfs:label 'Competitive Rate Reference' ;
    rdfs:comment 'The competitor or market reference rate (in property local currency) that informed the override decision, particularly when override_reason_code is \'competitive_pressure\'. Sourced from STR STAR Report, OTA rate shopping, or RMS competitive benchmarking module.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dayOfWeekMask rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Mask' ;
    rdfs:comment 'Seven-character binary string (1=active, 0=inactive) representing the days of the week the override applies to, ordered Monday through Sunday (e.g., \'1111100\' = Mon–Fri only). Applicable when override_scope is \'day_of_week\'.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryRoomsAffected rdf:type rdf:Property ;
    rdfs:label 'Inventory Rooms Affected' ;
    rdfs:comment 'Number of room inventory units to which the pricing override applies. Null or zero indicates the override applies to all available inventory for the specified room type and date range.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBarOverride rdf:type rdf:Property ;
    rdfs:label 'Is Bar Override' ;
    rdfs:comment 'Indicates whether this override specifically targets the Best Available Rate (BAR) — the lowest publicly available rate for a given date. True = BAR is being overridden; False = override applies to a non-BAR rate plan.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideNotes rdf:type rdf:Property ;
    rdfs:label 'Override Notes' ;
    rdfs:comment 'Free-text narrative provided by the revenue manager explaining the business rationale for the override, particularly when override_reason_code is \'other\' or when additional context is required for audit purposes.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideRate rdf:type rdf:Property ;
    rdfs:label 'Override Rate' ;
    rdfs:comment 'The manually set rate (in property local currency) applied by the revenue manager, superseding the RMS-recommended rate. This is the Best Available Rate (BAR) or specific rate plan rate that will be published to distribution channels.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Standardized reason code classifying why the revenue manager overrode the system-generated rate. \'competitive_pressure\' = OTA/competitor rate response; \'group_wash\' = group block displacement adjustment; \'event_demand\' = MICE or local event surge; \'error_correction\' = RMS data or configuration error fix; \'distressed_inventory\' = last-minute unsold inventory; \'other\' = non-standard reason documented in override_notes. [ENUM-REF-CANDIDATE: competitive_pressure|group_wash|event_demand|error_correction|distressed_inventory|other — promote to reference product]' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Override Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference number assigned to the pricing override for audit trail, cross-system reconciliation, and revenue manager communication. Format: PO- followed by 6–20 alphanumeric characters.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideScope rdf:type rdf:Property ;
    rdfs:label 'Override Scope' ;
    rdfs:comment 'Defines the temporal scope of the pricing override. \'single_date\' = applies to one specific stay date; \'date_range\' = applies across a contiguous range from effective_date to expiry_date; \'day_of_week\' = applies to specific days of the week within the effective window.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideStatus rdf:type rdf:Property ;
    rdfs:label 'Override Status' ;
    rdfs:comment 'Current lifecycle state of the pricing override. \'pending\' = submitted awaiting approval; \'approved\' = authorized and scheduled; \'active\' = currently in effect; \'expired\' = past effective end date; \'reversed\' = manually cancelled or rolled back.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Variance Amount' ;
    rdfs:comment 'Absolute monetary difference between the override_rate and the rms_recommended_rate (override_rate minus rms_recommended_rate). Positive value indicates override is above RMS recommendation; negative indicates below. Used for override impact analysis.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversed Timestamp' ;
    rdfs:comment 'The date and time when the pricing override was reversed or cancelled, restoring the RMS-recommended rate. Null for overrides that have not been reversed.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rmsForecastDemandLevel rdf:type rdf:Property ;
    rdfs:label 'Rms Forecast Demand Level' ;
    rdfs:comment 'The demand level classification (low, medium, high, very_high) as forecasted by the RMS at the time the override was submitted. Provides context for evaluating whether the override was aligned with or contrary to demand signals.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmsRecommendedRate rdf:type rdf:Property ;
    rdfs:label 'Rms Recommended Rate' ;
    rdfs:comment 'The original rate (in property local currency) recommended by the automated Revenue Management System (IDeaS G3 RMS or Infor EzRMS) prior to the manual override. Baseline for override variance analysis and RMS tuning.' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmsSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Rms Source System' ;
    rdfs:comment 'Identifies the Revenue Management System (RMS) that generated the original recommended rate being overridden. \'ideas_g3\' = IDeaS G3 RMS; \'infor_ezrms\' = Infor EzRMS; \'manual\' = no RMS recommendation existed (fully manual rate entry).' ;
    rdfs:domain ind:PricingOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Rate Availability Id' ;
    rdfs:comment 'Unique surrogate identifier for each daily rate and availability snapshot record in the Silver layer lakehouse. Primary key for the rate_availability data product.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableRooms rdf:type rdf:Property ;
    rdfs:label 'Available Rooms' ;
    rdfs:comment 'Number of rooms of this room type available for sale on the snapshot date at this property. Represents net sellable inventory after deducting out-of-order, out-of-service, and already-committed rooms. Core input for OCC (Occupancy Rate) and RevPAR calculations.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:barRate rdf:type rdf:Property ;
    rdfs:label 'Bar Rate' ;
    rdfs:comment 'The Best Available Rate (BAR) for this room type, property, and stay date — the lowest publicly available non-restricted rate as determined by IDeaS G3 RMS dynamic pricing engine. BAR is the anchor rate from which other rate plans are derived and is the primary rate distributed via Sabre SynXis CRS and OTA channels.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandForecastLevel rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Level' ;
    rdfs:comment 'Demand forecast classification for the snapshot date as generated by IDeaS G3 RMS or Infor EzRMS. Drives dynamic pricing decisions and inventory restriction strategies. Levels range from very_low (deep discounting warranted) to very_high (maximum rate and stop-sell controls active).' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsRateCode rdf:type rdf:Property ;
    rdfs:label 'Gds Rate Code' ;
    rdfs:comment 'The rate code as published on GDS (Global Distribution System) platforms (Sabre, Amadeus, Travelport) via Sabre SynXis CRS. GDS rate codes follow standardized formats required for travel agent booking systems and corporate travel management programs.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:losMaximum rdf:type rdf:Property ;
    rdfs:label 'Los Maximum' ;
    rdfs:comment 'Maximum number of nights permitted under this rate plan for the snapshot date. Used to prevent long-stay bookings at promotional rates during high-demand periods. Managed in IDeaS G3 RMS as an upper LOS (Length of Stay) restriction.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:losMinimum rdf:type rdf:Property ;
    rdfs:label 'Los Minimum' ;
    rdfs:comment 'Minimum number of nights a guest must stay to qualify for this rate plan on the snapshot date. A key yield optimization restriction managed in IDeaS G3 RMS. LOS (Length of Stay) restrictions are used to maximize revenue during high-demand periods by requiring multi-night commitments.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occupancyForecastPct rdf:type rdf:Property ;
    rdfs:label 'Occupancy Forecast Pct' ;
    rdfs:comment 'Forecasted occupancy rate (OCC%) for the property on the snapshot date as projected by IDeaS G3 RMS or Infor EzRMS at the time of this snapshot. Expressed as a percentage (0.00–100.00). Used to validate pricing decisions and benchmark against STR STAR Report actuals.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otaRateCode rdf:type rdf:Property ;
    rdfs:label 'Ota Rate Code' ;
    rdfs:comment 'The rate identifier as assigned by the primary OTA (Online Travel Agency) partner (e.g., Expedia, Booking.com) for this rate plan and property combination. Used for rate parity monitoring, OTA reconciliation, and channel performance reporting.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupRooms rdf:type rdf:Property ;
    rdfs:label 'Pickup Rooms' ;
    rdfs:comment 'Number of rooms booked (picked up) for the snapshot date since the previous snapshot capture. Pickup velocity is a key revenue management signal used in IDeaS G3 RMS and Infor EzRMS to detect demand acceleration and trigger dynamic rate adjustments.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Pricing Override Flag' ;
    rdfs:comment 'Indicates whether the current rate for this snapshot was manually overridden by a revenue manager, superseding the automated recommendation from IDeaS G3 RMS or Infor EzRMS. Manual overrides are tracked for revenue strategy audit and RMS model calibration.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Pricing Override Reason' ;
    rdfs:comment 'Free-text or coded reason provided by the revenue manager when manually overriding the RMS-recommended rate. Populated only when pricing_override_flag is True. Used for revenue strategy review, RMS model improvement, and audit trail compliance.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Revenue Management System' ;
    rdfs:comment 'Identifies the Revenue Management System (RMS) that generated or last updated the pricing recommendation for this snapshot record. Supports data lineage tracking and system-of-record attribution for audit and reconciliation purposes.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'The native record identifier from the originating source system (IDeaS G3 RMS or Sabre SynXis CRS) for this rate and availability record. Enables traceability back to the system of record for reconciliation, reprocessing, and audit purposes.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSell rdf:type rdf:Property ;
    rdfs:label 'Stop Sell' ;
    rdfs:comment 'Indicates whether this room type and rate plan combination has been closed to all new bookings on the snapshot date regardless of available inventory. A hard yield management control applied in IDeaS G3 RMS to protect inventory for higher-value bookings or group blocks.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRooms rdf:type rdf:Property ;
    rdfs:label 'Total Rooms' ;
    rdfs:comment 'Total physical room count for this room type at the property on the snapshot date. Used as the denominator for occupancy rate (OCC) and RevPAR calculations. Reflects the property\'s sellable capacity before any restrictions.' ;
    rdfs:domain ind:RateAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Rate Restriction Id' ;
    rdfs:comment 'Unique surrogate identifier for each rate restriction record in the revenue management system. Primary key for the rate_restriction data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'The date and time when this rate restriction was activated and distributed to connected channels (CRS, GDS, OTA). Represents the principal business event time — when the restriction became operationally effective in the distribution ecosystem. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hurdleRateAmount rdf:type rdf:Property ;
    rdfs:label 'Hurdle Rate Amount' ;
    rdfs:comment 'Minimum acceptable rate (in the property\'s base currency) below which a booking will be rejected for this rate plan on the restricted date(s). A key RMS yield control used to protect ADR during high-demand periods. Null when restriction type is not HURDLE_RATE.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBlackout rdf:type rdf:Property ;
    rdfs:label 'Is Blackout' ;
    rdfs:comment 'Indicates whether the effective date range is designated as a blackout period, during which the rate plan is completely closed to new bookings. Commonly applied during peak demand events, holidays, or sold-out periods.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCta rdf:type rdf:Property ;
    rdfs:label 'Is Cta' ;
    rdfs:comment 'Indicates whether arrivals are blocked on the effective date(s) for this rate plan and room type. When True, guests cannot check in on the restricted date, preventing short-stay bookings that fragment inventory during high-demand periods.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCtd rdf:type rdf:Property ;
    rdfs:label 'Is Ctd' ;
    rdfs:comment 'Indicates whether departures are blocked on the effective date(s) for this rate plan and room type. When True, guests cannot check out on the restricted date, used to extend stays through high-demand nights and maximize occupancy continuity.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLoyaltyExempt rdf:type rdf:Property ;
    rdfs:label 'Is Loyalty Exempt' ;
    rdfs:comment 'Indicates whether members of the hotel\'s loyalty program are exempt from this restriction (e.g., LRA — Last Room Availability guarantee for elite members). Supports loyalty program administration and member benefit fulfillment.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAdvancePurchaseDays rdf:type rdf:Property ;
    rdfs:label 'Max Advance Purchase Days' ;
    rdfs:comment 'Maximum number of days prior to arrival within which a booking must be made to qualify for this rate plan. Defines the booking window ceiling for advance purchase restrictions, preventing bookings made too far in advance at promotional rates.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Override Allowed' ;
    rdfs:comment 'Indicates whether a revenue manager or front desk supervisor is permitted to manually override this restriction for individual bookings. When False, the restriction is hard-enforced and cannot be bypassed in the PMS or CRS.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAuthorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Override Authorization Level' ;
    rdfs:comment 'Minimum staff authorization level required to override this restriction when override_allowed is True. Ensures appropriate governance over yield control exceptions. Null when override_allowed is False.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionName rdf:type rdf:Property ;
    rdfs:label 'Restriction Name' ;
    rdfs:comment 'Human-readable name describing the rate restriction rule (e.g., \'Weekend Min 2-Night Stay\', \'Holiday CTA Block\'). Used by revenue managers and front desk staff to identify restrictions in PMS and RMS interfaces.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionReason rdf:type rdf:Property ;
    rdfs:label 'Restriction Reason' ;
    rdfs:comment 'Free-text or coded explanation for why this restriction was applied (e.g., \'Peak demand event\', \'Holiday blackout\', \'Group block protection\', \'RMS auto-recommendation\'). Supports revenue strategy documentation and post-stay performance analysis.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionScope rdf:type rdf:Property ;
    rdfs:label 'Restriction Scope' ;
    rdfs:comment 'Defines the level at which this restriction is applied: \'property\' = entire property; \'room_type\' = specific room category; \'rate_plan\' = specific rate plan only; \'channel\' = specific distribution channel (OTA, GDS, direct). Determines how broadly the restriction is enforced across inventory.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmsRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Rms Recommendation Flag' ;
    rdfs:comment 'Indicates whether this restriction was system-recommended by the RMS (True) or manually created by a revenue manager (False). Enables analysis of RMS automation adoption rates and comparison of system vs. human yield decisions.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRestrictionReference rdf:type rdf:Property ;
    rdfs:label 'Source System Restriction Reference' ;
    rdfs:comment 'The native identifier of this restriction record in the originating operational system (IDeaS G3 RMS, Sabre SynXis CRS, etc.). Enables traceability and reconciliation between the lakehouse Silver Layer and the system of record.' ;
    rdfs:domain ind:RateRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueBudgetId rdf:type rdf:Property ;
    rdfs:label 'Revenue Budget Id' ;
    rdfs:comment 'Unique surrogate identifier for each revenue budget record. Primary key for the revenue_budget data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedFnbOutletId rdf:type rdf:Property ;
    rdfs:label 'Budgeted Fnb Outlet Id' ;
    rdfs:comment 'Foreign key linking to fnb.fnb_outlet. Business justification: Revenue budgets include outlet-level F&B targets for total property budget planning. Required for USALI budget preparation, outlet performance targets, variance analysis, GOP planning at department le' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FnbOutlet .

ind:budgetedFbRevenue rdf:type rdf:Property ;
    rdfs:label 'Budgeted Fb Revenue' ;
    rdfs:comment 'Total budgeted Food and Beverage (F&B) revenue in the property\'s operating currency for the planning period. Supports TRevPAR planning and USALI departmental revenue reporting.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedOccupiedRooms rdf:type rdf:Property ;
    rdfs:label 'Budgeted Occupied Rooms' ;
    rdfs:comment 'Total number of room-nights planned to be occupied (sold) during the planning period. Derived from budgeted available rooms × target OCC, stored as a planning target for demand forecasting and group block management.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedRoomRevenue rdf:type rdf:Property ;
    rdfs:label 'Budgeted Room Revenue' ;
    rdfs:comment 'Total budgeted room revenue (in operating currency) for the planning period and market segment. The primary monetary commitment in the revenue budget, used for variance analysis against actuals in the DOR and management reporting. Classified confidential as a strategic financial target.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandForecastSource rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Source' ;
    rdfs:comment 'Identifies the system or method used to generate the demand forecast underpinning this budget: \'IDeaS_G3\' (IDeaS G3 RMS automated forecast), \'Infor_EzRMS\' (Infor EzRMS forecast), \'manual\' (revenue manager manual input), or \'hybrid\' (combination). Supports data lineage and forecast accuracy tracking.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOwnerApproved rdf:type rdf:Property ;
    rdfs:label 'Is Owner Approved' ;
    rdfs:comment 'Indicates whether this budget has received formal approval from the property owner or ownership group (True = owner-approved; False = pending or not required). Relevant for managed properties where owner sign-off is contractually required.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyTacticalActions rdf:type rdf:Property ;
    rdfs:label 'Key Tactical Actions' ;
    rdfs:comment 'Free-text description of the near-term tactical revenue actions planned for this budget period (e.g., BAR adjustments, LRA controls, OTA channel mix shifts, promotional rate activations). Captured from the revenue strategy narrative in IDeaS G3 RMS and Infor EzRMS.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonType rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Type' ;
    rdfs:comment 'Granularity of the planning horizon for this budget record: \'annual\' (full-year plan), \'quarterly\' (90-day rolling), \'monthly\' (period-level), or \'weekly\' (short-term tactical). Determines the reporting cadence for variance analysis.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'The last date of the planning horizon covered by this revenue budget (e.g., 2025-12-31 for an annual plan). Defines the effective end of the budget period.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'The first date of the planning horizon covered by this revenue budget (e.g., 2025-01-01 for an annual plan). Defines the effective start of the budget period for variance tracking against actuals.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicInitiatives rdf:type rdf:Property ;
    rdfs:label 'Strategic Initiatives' ;
    rdfs:comment 'Free-text description of longer-horizon strategic revenue initiatives included in this budget (e.g., loyalty program rate strategy, new OTA partnership, dynamic pricing rule (DRR) rollout, group business development targets). Supports owner presentations and management reporting.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyStatus rdf:type rdf:Property ;
    rdfs:label 'Strategy Status' ;
    rdfs:comment 'Current lifecycle state of this revenue budget and strategy record. \'draft\' = under preparation; \'approved\' = signed off by revenue director; \'active\' = in-period execution; \'superseded\' = replaced by a newer version; \'archived\' = closed period record.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyType rdf:type rdf:Property ;
    rdfs:label 'Strategy Type' ;
    rdfs:comment 'Classifies the revenue strategy scope covered by this budget: \'transient\' (FIT/BAR-driven room revenue), \'group\' (MICE and group block revenue), \'total_revenue\' (TRevPAR-level all-revenue planning), \'food_and_beverage\' (F&B revenue plan), \'events\' (event/conference revenue), or \'other\'. [ENUM-REF-CANDIDATE: transient|group|total_revenue|food_and_beverage|events|other — promote to reference product]' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAdr rdf:type rdf:Property ;
    rdfs:label 'Target Adr' ;
    rdfs:comment 'Budgeted Average Daily Rate (ADR) in the property\'s operating currency for the planning period. Represents the planned average revenue earned per occupied room per night. Core revenue KPI used in STR STAR Report, RGI, and MPI benchmarking.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAlos rdf:type rdf:Property ;
    rdfs:label 'Target Alos' ;
    rdfs:comment 'Budgeted Average Length of Stay (ALOS) in nights for the planning period and market segment. Supports LOS-based pricing strategy, minimum stay restrictions, and demand pattern planning in IDeaS G3 RMS.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAri rdf:type rdf:Property ;
    rdfs:label 'Target Ari' ;
    rdfs:comment 'Budgeted Average Rate Index (ARI) target, representing the property\'s planned ADR performance relative to its STR competitive set (property ADR / comp set ADR). Supports rate strategy and competitive positioning planning.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGoppar rdf:type rdf:Property ;
    rdfs:label 'Target Goppar' ;
    rdfs:comment 'Budgeted Gross Operating Profit Per Available Room (GOPPAR) in the property\'s operating currency. Represents the profitability target per available room after operating expenses, used in owner presentations and GOP governance.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMpi rdf:type rdf:Property ;
    rdfs:label 'Target Mpi' ;
    rdfs:comment 'Budgeted Market Penetration Index (MPI) target, representing the property\'s planned occupancy performance relative to its STR competitive set (property OCC / comp set OCC). Supports competitive benchmarking strategy.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetOccupancyRate rdf:type rdf:Property ;
    rdfs:label 'Target Occupancy Rate' ;
    rdfs:comment 'Budgeted occupancy rate (OCC) expressed as a percentage (0.00–100.00) for the planning period. Represents the planned proportion of available rooms expected to be sold. Core KPI input for RevPAR calculation and STR STAR Report benchmarking.' ;
    rdfs:domain ind:RevenueBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRevpar rdf:type rdf:Property ;
    rdfs:label 'Target Revpar' ;
    rdfs:comment 'Budgeted Revenue Per Available Room (RevPAR) in the property\'s operating currency for the planning period. Calculated as ADR × OCC but stored as a strategic target for direct comparison against actuals and STR competitive set benchmarks (RGI).' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRgi rdf:type rdf:Property ;
    rdfs:label 'Target Rgi' ;
    rdfs:comment 'Budgeted Revenue Generation Index (RGI) target, representing the property\'s planned RevPAR performance relative to its STR competitive set (property RevPAR / comp set RevPAR). RGI > 1.0 indicates planned market share gain.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTrevpar rdf:type rdf:Property ;
    rdfs:label 'Target Trevpar' ;
    rdfs:comment 'Budgeted Total Revenue Per Available Room (TRevPAR) in the property\'s operating currency, encompassing all revenue streams (rooms, F&B, events, spa, parking, etc.) per available room. Supports total revenue strategy planning beyond rooms-only RevPAR.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueNegotiatedRateId rdf:type rdf:Property ;
    rdfs:label 'Revenue Negotiated Rate Id' ;
    rdfs:comment 'Unique surrogate identifier for the negotiated rate agreement record in the lakehouse Silver layer. Primary key for this entity.' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includedFnbOutletId rdf:type rdf:Property ;
    rdfs:label 'Included Fnb Outlet Id' ;
    rdfs:comment 'Foreign key linking to fnb.fnb_outlet. Business justification: Corporate negotiated rates include outlet benefits (breakfast at specific outlet, lounge access). Required for contract fulfillment, benefit tracking, outlet revenue attribution, guest entitlement ver' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FnbOutlet .

ind:minimumLoyaltyTierId rdf:type rdf:Property ;
    rdfs:label 'Minimum Loyalty Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: Corporate negotiated rates often include tier-based eligibility or enhanced benefits. Business process: enforcing tier requirements for corporate rate access, common in negotiated contracts that offer' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:negotiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sales/revenue managers negotiate corporate rates; contract owner tracking required for renewal workflow management, commission attribution, and performance evaluation of negotiated rate portfolio mana' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:breakfastIncluded rdf:type rdf:Property ;
    rdfs:label 'Breakfast Included' ;
    rdfs:comment 'Indicates whether breakfast is included in the negotiated rate. Affects F&B (Food and Beverage) revenue allocation and rate value proposition reporting.' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionPct rdf:type rdf:Property ;
    rdfs:label 'Commission Pct' ;
    rdfs:comment 'Commission percentage payable to the TMC, travel agency, or consortia for reservations booked under this negotiated rate. Expressed as a percentage of the negotiated rate amount.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedRoomNights rdf:type rdf:Property ;
    rdfs:label 'Committed Room Nights' ;
    rdfs:comment 'Total number of room nights the account has committed to book under this negotiated rate agreement for the contract period. Basis for volume discount qualification and contract performance tracking.' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLra rdf:type rdf:Property ;
    rdfs:label 'Is Lra' ;
    rdfs:comment 'Indicates whether this negotiated rate carries a Last Room Availability (LRA) obligation, requiring the property to honor the contracted rate as long as any room of the applicable type remains available, regardless of demand or yield management controls.' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minNightCommitment rdf:type rdf:Property ;
    rdfs:label 'Min Night Commitment' ;
    rdfs:comment 'Minimum number of room nights the account is contractually committed to consume during the contract period. Used for volume tracking and contract compliance reporting.' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiationOwner rdf:type rdf:Property ;
    rdfs:label 'Negotiation Owner' ;
    rdfs:comment 'Name or employee identifier of the revenue manager or sales manager responsible for negotiating and managing this rate agreement. Used for accountability and performance tracking.' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateBarVariancePct rdf:type rdf:Property ;
    rdfs:label 'Rate Bar Variance Pct' ;
    rdfs:comment 'The percentage discount or premium of this negotiated rate relative to the Best Available Rate (BAR) at time of contract negotiation. Used by revenue management to assess rate competitiveness and yield impact.' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateIncludesTax rdf:type rdf:Property ;
    rdfs:label 'Rate Includes Tax' ;
    rdfs:comment 'Indicates whether the negotiated rate amount is inclusive of applicable taxes. Critical for revenue recognition, financial reporting, and guest billing accuracy.' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateLoadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rate Loaded Timestamp' ;
    rdfs:comment 'Date and time when the negotiated rate was successfully loaded into Sabre SynXis CRS and/or Oracle OPERA PMS for distribution. Null if loading has not yet occurred.' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateName rdf:type rdf:Property ;
    rdfs:label 'Rate Name' ;
    rdfs:comment 'Human-readable name describing the negotiated rate agreement, typically referencing the account or program name (e.g., \'Acme Corp 2025 Corporate Rate\'). Used in reporting and rate management dashboards.' ;
    rdfs:domain ind:RevenueNegotiatedRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the negotiated rate agreement. Controls whether the rate is bookable and distributed through CRS/GDS channels.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRateReference rdf:type rdf:Property ;
    rdfs:label 'Source System Rate Reference' ;
    rdfs:comment 'Native identifier of this negotiated rate record in the originating operational system (Oracle OPERA PMS, Sabre SynXis CRS, or Salesforce CRM). Enables traceability and reconciliation between the lakehouse and source systems.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueOverbookingPolicyId rdf:type rdf:Property ;
    rdfs:label 'Revenue Overbooking Policy Id' ;
    rdfs:comment 'Unique surrogate identifier for the overbooking policy record. Primary key for the revenue_overbooking_policy data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRevenuePropertyId rdf:type rdf:Property ;
    rdfs:label 'Primary Revenue Property Id' ;
    rdfs:comment 'Identifier of the hotel or resort property to which this overbooking policy applies. Links to the property master record in the Property domain.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:adaRoomExempt rdf:type rdf:Property ;
    rdfs:label 'Ada Room Exempt' ;
    rdfs:comment 'Indicates whether Americans with Disabilities Act (ADA) accessible rooms are excluded from the overbooking pool under this policy. True = ADA rooms are never overbooked. Required for ADA compliance.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoAdjustEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Adjust Enabled' ;
    rdfs:comment 'Indicates whether IDeaS G3 RMS or Infor EzRMS is authorized to automatically adjust the overbooking percentage within the defined min/max bounds without manual revenue manager intervention. True = dynamic auto-adjustment enabled.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationRateAssumptionPct rdf:type rdf:Property ;
    rdfs:label 'Cancellation Rate Assumption Pct' ;
    rdfs:comment 'Historical or forecast cancellation rate percentage used as the actuarial basis for setting the overbooking level. Derived from IDeaS G3 RMS or Infor EzRMS demand forecasting models and reviewed periodically by revenue management.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'Distribution channel scope to which this overbooking policy applies. \'all\' = all booking channels. \'direct\' = brand.com and direct reservations. \'ota\' = Online Travel Agency bookings. \'gds\' = Global Distribution System bookings. \'voice\' = call center. \'group\' = group block reservations.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandTier rdf:type rdf:Property ;
    rdfs:label 'Demand Tier' ;
    rdfs:comment 'Demand classification tier from the Revenue Management System that this policy is calibrated for. Aligns with IDeaS G3 RMS and Infor EzRMS demand forecasting segments to enable yield optimization by demand level.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsWalkBonus rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Walk Bonus' ;
    rdfs:comment 'Number of loyalty program bonus points awarded to walked guests as additional compensation under this policy. Integrates with Salesforce CRM Loyalty Management and the Loyalty domain for points fulfillment.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyTierExempt rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Exempt' ;
    rdfs:comment 'Comma-separated list of loyalty program tier codes (e.g., \'PLATINUM,DIAMOND\') whose members are exempt from being walked under this policy. Integrates with Salesforce CRM Loyalty Management.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minOverbookingPct rdf:type rdf:Property ;
    rdfs:label 'Min Overbooking Pct' ;
    rdfs:comment 'Minimum overbooking level as a percentage below which the revenue management system should alert or auto-adjust. Supports dynamic overbooking optimization in IDeaS G3 RMS to prevent under-selling.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowRateAssumptionPct rdf:type rdf:Property ;
    rdfs:label 'No Show Rate Assumption Pct' ;
    rdfs:comment 'Historical or forecast no-show rate percentage used as the actuarial basis for setting the overbooking level. Sourced from Oracle OPERA PMS historical data and IDeaS G3 RMS forecasting models.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overbookingCap rdf:type rdf:Property ;
    rdfs:label 'Overbooking Cap' ;
    rdfs:comment 'Maximum absolute number of rooms that may be overbooked above physical inventory, regardless of the overbooking percentage. Acts as a hard ceiling to limit walk exposure. Enforced in Oracle OPERA PMS inventory controls.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pmsRuleCode rdf:type rdf:Property ;
    rdfs:label 'Pms Rule Code' ;
    rdfs:comment 'Oracle OPERA PMS inventory control rule code corresponding to this overbooking policy. Used for reconciliation between the lakehouse and the operational PMS configuration.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNotes rdf:type rdf:Property ;
    rdfs:label 'Policy Notes' ;
    rdfs:comment 'Free-text field for revenue management team annotations, special conditions, or contextual notes about this overbooking policy (e.g., \'Applies during citywide convention periods only\', \'Reviewed post-Q3 STR STAR Report\').' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the overbooking policy by reservation segment. \'standard\' applies to general transient bookings. \'dynamic\' indicates IDeaS G3 RMS auto-adjusts levels. \'group\' applies to group blocks. \'guaranteed\' applies to guaranteed reservation types only.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanScope rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Scope' ;
    rdfs:comment 'Comma-separated list of rate plan codes (BAR, NRR, LRA, corporate, etc.) to which this overbooking policy applies. Null indicates the policy applies to all rate plans. Aligns with Sabre SynXis CRS rate distribution configuration.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled frequency at which this overbooking policy is reviewed and potentially recalibrated by the revenue management team. Supports governance and continuous optimization of overbooking levels.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmsPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Rms Policy Reference' ;
    rdfs:comment 'Native policy identifier or rule code as stored in IDeaS G3 RMS or Infor EzRMS. Enables direct cross-system traceability between the lakehouse Silver Layer record and the source RMS configuration.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipReservationExempt rdf:type rdf:Property ;
    rdfs:label 'Vip Reservation Exempt' ;
    rdfs:comment 'Indicates whether VIP-flagged reservations (loyalty elite, corporate VIP, celebrity) are excluded from walk eligibility under this policy. True = VIP reservations are protected from walk. Integrates with Salesforce CRM guest profiles.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:walkAlertThreshold rdf:type rdf:Property ;
    rdfs:label 'Walk Alert Threshold' ;
    rdfs:comment 'Number of overbooked rooms at which the system triggers an alert to the front desk and revenue management team to initiate proactive walk management. Configured in Oracle OPERA PMS.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:walkCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Walk Compensation Amount' ;
    rdfs:comment 'Monetary compensation amount authorized for walked guests under this policy, expressed in the property\'s operating currency. Applicable when walk_policy_type is \'cash_compensation\' or \'voucher\'. Governed by AHLA walk policy standards.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:walkCompensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Walk Compensation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the walk compensation amount (e.g., \'USD\', \'EUR\', \'GBP\'). Required for multi-currency property portfolios.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walkPolicyType rdf:type rdf:Property ;
    rdfs:label 'Walk Policy Type' ;
    rdfs:comment 'Type of compensation offered to guests who are walked (relocated) due to overbooking. \'comp_room\' = complimentary room at partner hotel. \'cash_compensation\' = monetary payment. \'upgrade\' = room upgrade if available. \'partner_hotel\' = relocation to contracted partner property. \'voucher\' = future stay voucher. [ENUM-REF-CANDIDATE: comp_room|cash_compensation|upgrade|partner_hotel|voucher|loyalty_points|transport_voucher — promote to reference product]' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walkTransportIncluded rdf:type rdf:Property ;
    rdfs:label 'Walk Transport Included' ;
    rdfs:comment 'Indicates whether complimentary transportation to the partner hotel is included in the walk compensation package under this policy. True = transportation is provided at property expense.' ;
    rdfs:domain ind:RevenueOverbookingPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includedMenuId rdf:type rdf:Property ;
    rdfs:label 'Included Menu Id' ;
    rdfs:comment 'Foreign key linking to fnb.menu. Business justification: Rate plans reference specific menus for included meals (breakfast menu version, dinner package menu). Required for package rate construction, menu version control, guest entitlement verification at ou' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Menu .

ind:bookingWindowCloseDate rdf:type rdf:Property ;
    rdfs:label 'Booking Window Close Date' ;
    rdfs:comment 'The last date on which new reservations can be made under this rate plan. After this date the rate plan is closed to new bookings even if the stay dates fall within the effective period.' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingWindowOpenDate rdf:type rdf:Property ;
    rdfs:label 'Booking Window Open Date' ;
    rdfs:comment 'The earliest date on which reservations can be made under this rate plan. Used to control promotional rate availability windows and prevent premature booking of seasonal or event-driven rates.' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountPct rdf:type rdf:Property ;
    rdfs:label 'Discount Pct' ;
    rdfs:comment 'Percentage discount applied to the BAR (Best Available Rate) or rack rate to derive this rate plan\'s selling price. Used for corporate negotiated rates, loyalty member rates, and promotional rates. A value of 0 indicates no discount from the reference rate.' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drrEligible rdf:type rdf:Property ;
    rdfs:label 'Drr Eligible' ;
    rdfs:comment 'Indicates whether this rate plan is subject to DRR (Dynamic Rate Rule) adjustments by the revenue management system. When true, IDeaS G3 RMS or Infor EzRMS may automatically adjust the rate based on demand forecasts, occupancy levels, and competitive benchmarking.' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyTierRequired rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Required' ;
    rdfs:comment 'Minimum loyalty program membership tier required to access this rate plan. A value of \'none\' indicates the rate is open to all guests regardless of loyalty status. Used to gate exclusive member rates.' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealPlanType rdf:type rdf:Property ;
    rdfs:label 'Meal Plan Type' ;
    rdfs:comment 'Indicates the F&B (Food and Beverage) inclusions bundled with this rate plan. Room only includes no meals; bed and breakfast includes morning meal; half board includes breakfast and dinner; full board includes all three meals; all-inclusive covers meals, beverages, and selected activities.' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCeilingAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Ceiling Amount' ;
    rdfs:comment 'The maximum rate above which this rate plan cannot be sold, used to cap pricing during peak demand periods for contracted or promotional rates. Null indicates no ceiling constraint.' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateFloorAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Floor Amount' ;
    rdfs:comment 'The minimum rate below which this rate plan cannot be sold, regardless of dynamic pricing adjustments. Protects rate integrity and brand positioning. Used by IDeaS G3 RMS as a hard constraint in yield optimization algorithms.' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateLevel rdf:type rdf:Property ;
    rdfs:label 'Rate Level' ;
    rdfs:comment 'Indicates the organizational scope at which this rate plan is defined and managed. Property-level plans apply to a single hotel; brand-level plans apply across a brand portfolio; chain-level plans apply across the entire company; global plans may span international markets.' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stayDateRestriction rdf:type rdf:Property ;
    rdfs:label 'Stay Date Restriction' ;
    rdfs:comment 'Defines any day-of-week or date-specific restrictions on when stays under this rate plan are permitted. Weekday-only and weekend-only restrictions are common for corporate and leisure rates respectively; blackout dates exclude specific high-demand periods.' ;
    rdfs:domain ind:RevenueRatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Str Benchmark Id' ;
    rdfs:comment 'Primary key for str_benchmark' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:importedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Imported By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Revenue analysts import and validate STR benchmark data; employee attribution required for data quality accountability, submission workflow tracking, and performance evaluation of competitive intellig' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:benchmarkCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which all STR STAR Report monetary benchmark values (ADR, RevPAR) are reported for this record (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkStatus rdf:type rdf:Property ;
    rdfs:label 'Benchmark Status' ;
    rdfs:comment 'The current lifecycle status of this benchmark or rate shop record. \'active\' = current valid record; \'superseded\' = replaced by a revised STR submission; \'pending_review\' = awaiting data quality validation; \'rejected\' = failed data quality checks.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compSetAdr rdf:type rdf:Property ;
    rdfs:label 'Comp Set Adr' ;
    rdfs:comment 'The aggregated Average Daily Rate (ADR) of the STR competitive set for the benchmark report period. Used to compute the ARI and assess the property\'s rate positioning relative to the market.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSetOccupancyRate rdf:type rdf:Property ;
    rdfs:label 'Comp Set Occupancy Rate' ;
    rdfs:comment 'The aggregated occupancy rate (OCC) of the STR competitive set for the benchmark report period. Used to compute the MPI and assess the property\'s demand capture relative to the market.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSetRevpar rdf:type rdf:Property ;
    rdfs:label 'Comp Set Revpar' ;
    rdfs:comment 'The aggregated RevPAR of the STR competitive set for the benchmark report period. Used to compute the RGI and assess the property\'s overall revenue performance relative to the market.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSetRoomsAvailable rdf:type rdf:Property ;
    rdfs:label 'Comp Set Rooms Available' ;
    rdfs:comment 'The total number of rooms available (supply) across all properties in the STR competitive set during the benchmark report period. Used as the denominator for comp set RevPAR and occupancy calculations.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingested Timestamp' ;
    rdfs:comment 'The timestamp when this STR benchmark or rate shop record was ingested into the silver layer lakehouse from the source data feed (STR, OTA Insight, RateGain, or Infor EzRMS). Used for data lineage, SLA monitoring, and ETL audit.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketLocationType rdf:type rdf:Property ;
    rdfs:label 'Market Location Type' ;
    rdfs:comment 'The STR-defined market location type for the subject property or competitor property (e.g., urban, suburban, airport, resort, small metro, interstate). Used to contextualize benchmark performance within the appropriate market geography.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaPlatformName rdf:type rdf:Property ;
    rdfs:label 'Ota Platform Name' ;
    rdfs:comment 'The specific OTA platform name from which the competitor rate was shopped (e.g., Expedia, Booking.com, Hotels.com, Agoda). Populated when distribution_channel = \'OTA\'. Enables OTA-level competitive rate parity analysis.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyAdr rdf:type rdf:Property ;
    rdfs:label 'Property Adr' ;
    rdfs:comment 'The subject property\'s Average Daily Rate (ADR) for the benchmark report period, expressed in the reporting currency. ADR is calculated as total room revenue divided by total rooms sold, per USALI standards.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyOccupancyRate rdf:type rdf:Property ;
    rdfs:label 'Property Occupancy Rate' ;
    rdfs:comment 'The subject property\'s occupancy rate (OCC) for the benchmark report period, expressed as a decimal fraction (e.g., 0.8250 = 82.50%). Calculated as rooms sold divided by rooms available per USALI standards.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyRevpar rdf:type rdf:Property ;
    rdfs:label 'Property Revpar' ;
    rdfs:comment 'The subject property\'s Revenue Per Available Room (RevPAR) for the benchmark report period. RevPAR = ADR × Occupancy Rate. A primary KPI for hotel revenue performance per USALI and STR standards.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyRoomsAvailable rdf:type rdf:Property ;
    rdfs:label 'Property Rooms Available' ;
    rdfs:comment 'The total number of rooms available (supply) at the subject property during the benchmark report period. Used as the denominator for RevPAR and occupancy calculations per USALI standards.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Availability Status' ;
    rdfs:comment 'The availability status of the competitor rate at the time of the rate shop observation. Indicates whether the rate was available for booking, sold out, restricted (e.g., minimum stay), on request, or not shopped for this combination.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Discriminator indicating whether this record represents an STR STAR Report benchmark index record or a granular competitor rate shopping observation. Enables partitioned querying across both data types within this unified product.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Report Period End Date' ;
    rdfs:comment 'The last date of the STR STAR Report benchmark period for which the benchmark indices and performance metrics are reported.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Report Period Start Date' ;
    rdfs:comment 'The first date of the STR STAR Report benchmark period (e.g., start of week, month, or year-to-date window) for which the benchmark indices and performance metrics are reported.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportPeriodType rdf:type rdf:Property ;
    rdfs:label 'Report Period Type' ;
    rdfs:comment 'The temporal granularity of the STR STAR Report benchmark period. Determines whether the record represents a daily, weekly, monthly, quarterly, annual, or year-to-date benchmark snapshot.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shoppedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Shopped Rate Amount' ;
    rdfs:comment 'The publicly available rate amount captured for the competitor property during the rate shopping observation, expressed in the shopped rate currency. Represents the per-night room rate for the specified stay date, room type, and rate plan.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shoppedRateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Shopped Rate Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which the shopped competitor rate amount is denominated (e.g., USD, EUR, GBP). May differ from the benchmark currency if the competitor property operates in a different market.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strReportVersion rdf:type rdf:Property ;
    rdfs:label 'Str Report Version' ;
    rdfs:comment 'The version number of the STR STAR Report data file or submission from which this benchmark record was sourced. STR may issue revised reports for the same period; this field tracks which version of the report was ingested.' ;
    rdfs:domain ind:StrBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyId rdf:type rdf:Property ;
    rdfs:label 'Strategy Id' ;
    rdfs:comment 'Primary key for strategy' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByStrategyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Strategy Id' ;
    rdfs:comment 'Reference to the newer revenue strategy record that replaced this one when status is \'superseded\'. Enables lineage tracking of strategy evolution and supports audit trail for revenue governance.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Strategy .

ind:channelFocus rdf:type rdf:Property ;
    rdfs:label 'Channel Focus' ;
    rdfs:comment 'The primary distribution channel(s) this strategy targets for demand generation (e.g., \'Direct Web\', \'GDS\', \'OTA\', \'Voice/CRS\', \'Corporate Direct\'). Informs channel mix optimization and OTA partnership management decisions. Aligns with Sabre SynXis CRS channel codes.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:horizonType rdf:type rdf:Property ;
    rdfs:label 'Horizon Type' ;
    rdfs:comment 'Categorizes the temporal scope of the strategy planning horizon. \'weekly\' for short-term tactical adjustments, \'monthly\' for rolling monthly plans, \'quarterly\' for seasonal strategies, \'annual\' for full-year budget-aligned strategies, \'event_based\' for strategies tied to specific demand events.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryControlApproach rdf:type rdf:Property ;
    rdfs:label 'Inventory Control Approach' ;
    rdfs:comment 'The approved inventory management methodology for this strategy period. \'open\' allows all bookings, \'hurdle_rate\' applies minimum rate thresholds, \'length_of_stay\' (LOS) enforces minimum/maximum stay restrictions, \'nested\' uses tiered availability controls, \'closed\' restricts availability for specific segments or channels.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'The last date of the planning period covered by this revenue strategy. Together with planning_horizon_start_date, defines the full strategy window for yield optimization and performance tracking.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'The first date of the planning period covered by this revenue strategy. Defines the beginning of the stay-date window over which the strategy governs pricing and inventory decisions.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingApproach rdf:type rdf:Property ;
    rdfs:label 'Pricing Approach' ;
    rdfs:comment 'The approved pricing methodology governing rate-setting for this strategy period. \'bar_based\' uses Best Available Rate (BAR) as the anchor, \'dynamic\' applies algorithmic Dynamic Rate Rules (DRR), \'fixed\' uses static rate plans, \'hybrid\' combines approaches, \'competitive_parity\' aligns rates to competitive set benchmarks.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMarketSegmentFocus rdf:type rdf:Property ;
    rdfs:label 'Primary Market Segment Focus' ;
    rdfs:comment 'The primary guest market segment this strategy is designed to optimize (e.g., \'Corporate Transient\', \'Leisure FIT\', \'Group MICE\', \'OTA Leisure\', \'Government\'). Aligns with market segment codes used in Oracle OPERA PMS and IDeaS G3 RMS segmentation.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmsStrategyReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Rms Strategy Reference Code' ;
    rdfs:comment 'The native strategy or scenario identifier from the source Revenue Management System (IDeaS G3 RMS or Infor EzRMS). Enables traceability back to the originating RMS record for reconciliation and system-of-record alignment.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyCode rdf:type rdf:Property ;
    rdfs:label 'Strategy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this revenue strategy record within the Revenue Management System (RMS). Used for cross-system reference and audit trail. Sourced from IDeaS G3 RMS or Infor EzRMS strategy identifiers.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyName rdf:type rdf:Property ;
    rdfs:label 'Strategy Name' ;
    rdfs:comment 'Human-readable name describing the revenue strategy (e.g., \'Q3 2025 Transient Yield Push\', \'Holiday Season Total Revenue Strategy\'). Used for identification in reporting and governance workflows.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOccupancyPct rdf:type rdf:Property ;
    rdfs:label 'Target Occupancy Pct' ;
    rdfs:comment 'The approved target Occupancy Rate (OCC) expressed as a percentage (0.00–100.00) for the strategy period. Represents the proportion of available rooms expected to be sold. Core input to RevPAR calculation and yield optimization decisions.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenueActualsId rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Actuals Id' ;
    rdfs:comment 'Unique surrogate identifier for each daily total revenue actuals record at the property level. Primary key for this Silver Layer data product.' ;
    rdfs:domain ind:TotalRevenueActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Flag' ;
    rdfs:comment 'Indicates whether this revenue actuals record contains a post-close adjustment or restatement to previously posted figures. When true, the adjustment_reason field provides context. Supports SOX audit trail requirements.' ;
    rdfs:domain ind:TotalRevenueActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complimentaryRooms rdf:type rdf:Property ;
    rdfs:label 'Complimentary Rooms' ;
    rdfs:comment 'Number of rooms occupied on a complimentary basis (zero-rated) on the stay date. Tracked separately per USALI and STR reporting standards to distinguish from revenue-generating occupied rooms.' ;
    rdfs:domain ind:TotalRevenueActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:houseUseRooms rdf:type rdf:Property ;
    rdfs:label 'House Use Rooms' ;
    rdfs:comment 'Number of rooms occupied for internal hotel use (staff, management) on the stay date. Excluded from revenue-generating occupancy per USALI and STR standards.' ;
    rdfs:domain ind:TotalRevenueActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingSegment rdf:type rdf:Property ;
    rdfs:label 'Reporting Segment' ;
    rdfs:comment 'Brand or service tier segment of the property for this revenue record (e.g., luxury, premium, select-service). Enables cross-segment revenue performance benchmarking and portfolio analytics aligned with AHLA and STR segmentation standards.' ;
    rdfs:domain ind:TotalRevenueActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomsRevenue rdf:type rdf:Property ;
    rdfs:label 'Rooms Revenue' ;
    rdfs:comment 'Total net rooms revenue for the stay date at the property, sourced from Oracle OPERA PMS cashiering. Represents the primary revenue line under USALI Rooms Department. Used as the numerator in ADR and RevPAR calculations.' ;
    rdfs:domain ind:TotalRevenueActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomsRevenueBudget rdf:type rdf:Property ;
    rdfs:label 'Rooms Revenue Budget' ;
    rdfs:comment 'Budgeted rooms revenue for the stay date as set in the annual operating plan. Enables variance analysis between actual and budgeted rooms revenue performance. Sourced from SAP S/4HANA budgeting module.' ;
    rdfs:domain ind:TotalRevenueActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperatingExpenses rdf:type rdf:Property ;
    rdfs:label 'Total Operating Expenses' ;
    rdfs:comment 'Total departmental and undistributed operating expenses for the stay date, including labor, cost of goods sold, and other direct costs across all departments. Sourced from SAP S/4HANA cost accounting. Used to derive GOP.' ;
    rdfs:domain ind:TotalRevenueActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenueBudget rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Budget' ;
    rdfs:comment 'Budgeted total revenue for the stay date across all departments as set in the annual operating plan. Enables variance analysis between actual and budgeted total revenue. Sourced from SAP S/4HANA budgeting module.' ;
    rdfs:domain ind:TotalRevenueActuals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedWashPct rdf:type rdf:Property ;
    rdfs:label 'Adjusted Wash Pct' ;
    rdfs:comment 'Revenue manager-adjusted wash factor applied to group block forecasting after applying business judgment, seasonal adjustments, or RMS recommendations on top of the historical wash percentage. This is the operative value consumed by IDeaS G3 RMS for net group pickup forecasting and transient displacement calculations.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockSizeMaxRooms rdf:type rdf:Property ;
    rdfs:label 'Block Size Max Rooms' ;
    rdfs:comment 'Maximum number of contracted group room nights that defines the upper bound of the block size tier. A null value indicates an open-ended upper bound (e.g., mega blocks with no ceiling).' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockSizeMinRooms rdf:type rdf:Property ;
    rdfs:label 'Block Size Min Rooms' ;
    rdfs:comment 'Minimum number of contracted group room nights that defines the lower bound of the block size tier for this wash factor record.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockSizeTier rdf:type rdf:Property ;
    rdfs:label 'Block Size Tier' ;
    rdfs:comment 'Categorical tier representing the size of the group room block (e.g., small: 1–10 rooms, medium: 11–50 rooms, large: 51–200 rooms, mega: 200+ rooms). Block size is a significant predictor of wash behavior; larger blocks tend to exhibit higher attrition rates.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingLeadTimeBucket rdf:type rdf:Property ;
    rdfs:label 'Booking Lead Time Bucket' ;
    rdfs:comment 'Categorical bucket representing the number of days between group block creation and the group arrival date. Lead time is a critical predictor of wash behavior; groups booked further in advance typically exhibit higher attrition rates. Used by IDeaS G3 RMS to apply the correct wash factor based on booking horizon.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displacementImpactPct rdf:type rdf:Property ;
    rdfs:label 'Displacement Impact Pct' ;
    rdfs:comment 'Estimated percentage of transient room revenue displaced by the group block after applying the wash factor. Quantifies the opportunity cost of accepting the group block versus holding inventory for transient demand. Used in group displacement analysis within IDeaS G3 RMS.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factorStatus rdf:type rdf:Property ;
    rdfs:label 'Factor Status' ;
    rdfs:comment 'Current lifecycle status of the wash factor record. Controls whether the record is actively consumed by the RMS for forecasting. \'Superseded\' indicates a newer version has replaced this record; \'pending_review\' indicates the record requires revenue manager approval before activation.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historicalObservationEndDate rdf:type rdf:Property ;
    rdfs:label 'Historical Observation End Date' ;
    rdfs:comment 'End date of the historical data window used to calculate the historical wash percentage. Together with historical_observation_start_date, defines the precise lookback period for wash factor derivation.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:historicalObservationStartDate rdf:type rdf:Property ;
    rdfs:label 'Historical Observation Start Date' ;
    rdfs:comment 'Start date of the historical data window used to calculate the historical wash percentage. Defines the lookback period for the statistical derivation of the wash factor.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isDefaultFactor rdf:type rdf:Property ;
    rdfs:label 'Is Default Factor' ;
    rdfs:comment 'Indicates whether this wash factor record serves as the default fallback when no more specific wash factor matches a group block\'s attributes (group type, lead time, block size, season). True = default factor; False = specific factor.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRmsActive rdf:type rdf:Property ;
    rdfs:label 'Is Rms Active' ;
    rdfs:comment 'Indicates whether this wash factor record is currently being consumed by the Revenue Management System (IDeaS G3 RMS or Infor EzRMS) for live group demand forecasting and transient displacement calculations. True = actively used in RMS; False = not currently applied.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeMaxDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Max Days' ;
    rdfs:comment 'Maximum number of days before arrival that defines the upper bound of the booking lead time bucket. A null value indicates an open-ended upper bound (e.g., 365+ days). Together with lead_time_min_days, precisely defines the lead time window.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadTimeMinDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Min Days' ;
    rdfs:comment 'Minimum number of days before arrival that defines the lower bound of the booking lead time bucket. Together with lead_time_max_days, precisely defines the lead time window for this wash factor record.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmsWashFactorReference rdf:type rdf:Property ;
    rdfs:label 'Rms Wash Factor Reference' ;
    rdfs:comment 'Native identifier for this wash factor record as stored in the source Revenue Management System (IDeaS G3 RMS or Infor EzRMS). Enables bidirectional traceability between the Silver layer data product and the operational RMS source system.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Seasonal classification for which this wash factor is applicable. Wash behavior varies significantly by season; peak season groups may exhibit lower attrition due to higher demand, while off-peak groups may wash more aggressively.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washFactorCode rdf:type rdf:Property ;
    rdfs:label 'Wash Factor Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this wash factor configuration within the Revenue Management System (RMS). Used as the business key for integration with IDeaS G3 RMS and Infor EzRMS.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washFactorName rdf:type rdf:Property ;
    rdfs:label 'Wash Factor Name' ;
    rdfs:comment 'Human-readable descriptive name for this wash factor configuration (e.g., \'Corporate Group 30-Day Lead Time — High Season\'). Used by revenue managers to identify and manage wash factor rules.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washPctVariance rdf:type rdf:Property ;
    rdfs:label 'Wash Pct Variance' ;
    rdfs:comment 'Difference between the adjusted wash percentage and the historical wash percentage (adjusted_wash_pct minus historical_wash_pct). Quantifies the degree of manual override applied by the revenue manager relative to historical norms. Positive values indicate a more conservative (higher attrition) assumption.' ;
    rdfs:domain ind:WashFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amenityPricingId rdf:type rdf:Property ;
    rdfs:label 'Amenity Pricing Id' ;
    rdfs:comment 'Unique identifier for the amenity pricing rule record.' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAmenityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Amenity Employee Id' ;
    rdfs:comment 'Reference to the user who approved this pricing rule for operational use.' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:productId rdf:type rdf:Property ;
    rdfs:label 'Product Id' ;
    rdfs:comment 'Reference to the retail product being priced. Null if pricing applies to treatments or services.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Product .

ind:tertiaryAmenityLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Amenity Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this pricing rule record.' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:treatmentId rdf:type rdf:Property ;
    rdfs:label 'Treatment Id' ;
    rdfs:comment 'Reference to the spa treatment, fitness class, or service being priced. Null if pricing applies to retail products or day passes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Treatment .

ind:dayOfWeekApplicability rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Applicability' ;
    rdfs:comment 'Days of the week when this pricing rule applies (e.g., MON-FRI, SAT-SUN, ALL). Enables weekday vs weekend pricing differentiation.' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftCertificateEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Certificate Eligible Flag' ;
    rdfs:comment 'Indicates whether this pricing can be purchased using gift certificates or vouchers.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gratuityIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Gratuity Included Flag' ;
    rdfs:comment 'Indicates whether gratuity is included in the pricing or added separately at point of sale.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumAdvanceBookingDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Advance Booking Days' ;
    rdfs:comment 'Maximum number of days in advance that a booking can be made under this pricing rule.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumCharge rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge' ;
    rdfs:comment 'Maximum charge cap for this pricing rule. Used to limit pricing for promotional or group rates.' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAdvanceBookingHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Advance Booking Hours' ;
    rdfs:comment 'Minimum number of hours in advance that a booking must be made to qualify for this pricing rule.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'Minimum charge amount that must be applied regardless of quantity or duration. Used for group bookings or minimum service fees.' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onlineBookingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Online Booking Enabled Flag' ;
    rdfs:comment 'Indicates whether this pricing is available for online booking through digital channels.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Package Eligible Flag' ;
    rdfs:comment 'Indicates whether this pricing can be included in package offerings and bundled deals.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the pricing tier: rack (standard published rate), member (loyalty member rate), resort_guest (in-house guest rate), day_use (non-guest rate), group (group booking rate), promotional (special offer rate), package (bundled rate), corporate (corporate account rate). [ENUM-REF-CANDIDATE: rack|member|resort_guest|day_use|group|promotional|package|corporate — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingRuleCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Rule Code' ;
    rdfs:comment 'Unique business identifier for the pricing rule, used for operational reference and reporting.' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingRuleName rdf:type rdf:Property ;
    rdfs:label 'Pricing Rule Name' ;
    rdfs:comment 'Descriptive name of the pricing rule for business user identification and reporting.' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingUnit rdf:type rdf:Property ;
    rdfs:label 'Pricing Unit' ;
    rdfs:comment 'Unit of measure for pricing: per_treatment (single service), per_hour (hourly rate), per_session (class or session), per_day (day pass), per_person (per guest), per_item (retail product), per_round (golf). [ENUM-REF-CANDIDATE: per_treatment|per_hour|per_session|per_day|per_person|per_item|per_round — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOfDayEnd rdf:type rdf:Property ;
    rdfs:label 'Time Of Day End' ;
    rdfs:comment 'End time for time-based pricing rules. Format HH:MM in 24-hour notation.' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOfDayStart rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Start' ;
    rdfs:comment 'Start time for time-based pricing rules (e.g., morning rates, evening rates). Format HH:MM in 24-hour notation.' ;
    rdfs:domain ind:AmenityPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentId rdf:type rdf:Property ;
    rdfs:label 'Appointment Id' ;
    rdfs:comment 'Unique identifier for the spa appointment booking. Primary key for the appointment entity.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appointment .

ind:appointmentGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Appointment Guest Profile Id' ;
    rdfs:comment 'FK to guest.profile.profile_id — MUST-HAVE: Spa appointments must link to guest profile for intake form pre-population, allergy alerts, preference recall, and folio posting. Core guest experience continuity requirement.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:appointmentProfileId rdf:type rdf:Property ;
    rdfs:label 'Appointment Profile Id' ;
    rdfs:comment 'Reference to the guest who booked the spa appointment. Links to the guest master data.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:therapistId rdf:type rdf:Property ;
    rdfs:label 'Therapist Id' ;
    rdfs:comment 'Reference to the spa therapist assigned to perform the treatment. Links to workforce/therapist master data. Nullable if therapist not yet assigned.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Therapist .

ind:treatmentRoomId rdf:type rdf:Property ;
    rdfs:label 'Treatment Room Id' ;
    rdfs:comment 'Reference to the specific treatment room or facility space where the appointment will take place. Links to room inventory.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentRoom .

ind:appointmentDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Date' ;
    rdfs:comment 'The calendar date on which the spa appointment is scheduled to occur. Used for day-level scheduling and reporting.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the spa appointment. Tracks progression from initial booking through completion or cancellation. Critical for operational workflow and revenue recognition. [ENUM-REF-CANDIDATE: booked|confirmed|checked-in|in-progress|completed|cancelled|no-show — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalTime rdf:type rdf:Property ;
    rdfs:label 'Arrival Time' ;
    rdfs:comment 'The actual date and time when the guest arrived at the spa facility for their appointment. Nullable if guest has not yet arrived. Used for punctuality tracking and operational efficiency.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalBookingReference rdf:type rdf:Property ;
    rdfs:label 'External Booking Reference' ;
    rdfs:comment 'External reference number from third-party booking platforms or partner systems. Nullable for direct bookings. Used for reconciliation and partner integration.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestGenderPreference rdf:type rdf:Property ;
    rdfs:label 'Guest Gender Preference' ;
    rdfs:comment 'The guest\'s preference for therapist gender. Used for therapist assignment and guest satisfaction optimization.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestNotes rdf:type rdf:Property ;
    rdfs:label 'Guest Notes' ;
    rdfs:comment 'Internal staff notes about the guest or appointment. May include service preferences, behavioral observations, or operational notes. Confidential and not shared with guest.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intakeFormCompleted rdf:type rdf:Property ;
    rdfs:label 'Intake Form Completed' ;
    rdfs:comment 'Boolean flag indicating whether the guest has completed the required health and wellness intake form prior to treatment. Required for compliance and risk management.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intakeFormCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Intake Form Completed Timestamp' ;
    rdfs:comment 'The date and time when the guest completed the intake form. Nullable if form not yet completed. Used for compliance tracking and operational readiness.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:prepaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Prepayment Amount' ;
    rdfs:comment 'The monetary amount prepaid by the guest at the time of booking, typically as a deposit or full payment. Used for revenue tracking and cancellation policy enforcement. Nullable if no prepayment required.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepaymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Prepayment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the prepayment amount. Required when prepayment_amount is populated. Supports multi-currency operations.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressurePreference rdf:type rdf:Property ;
    rdfs:label 'Pressure Preference' ;
    rdfs:comment 'The guest\'s preferred massage pressure level for treatments involving massage. Captured during booking or intake to personalize treatment delivery.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'The planned date and time when the spa appointment is scheduled to end. Calculated based on treatment duration.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialHealthNotes rdf:type rdf:Property ;
    rdfs:label 'Special Health Notes' ;
    rdfs:comment 'Free-text field capturing any health conditions, allergies, injuries, or medical considerations the guest disclosed that may affect treatment delivery. Critical for guest safety and liability management.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapistGenderPreference rdf:type rdf:Property ;
    rdfs:label 'Therapist Gender Preference' ;
    rdfs:comment 'The guest\'s stated preference for the gender of the therapist performing the treatment. Supports personalized service delivery.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentPackageId rdf:type rdf:Property ;
    rdfs:label 'Appointment Package Id' ;
    rdfs:comment 'Unique identifier for the spa appointment package booking record. Primary key.' ;
    rdfs:domain ind:AppointmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addonServicesAmount rdf:type rdf:Property ;
    rdfs:label 'Addon Services Amount' ;
    rdfs:comment 'Total amount charged for additional services added to the base package.' ;
    rdfs:domain ind:AppointmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complimentaryAmenities rdf:type rdf:Property ;
    rdfs:label 'Complimentary Amenities' ;
    rdfs:comment 'Comma-separated list of complimentary amenities included with the package (e.g., robe, slippers, refreshments, locker access).' ;
    rdfs:domain ind:AppointmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Guest Arrival Timestamp' ;
    rdfs:comment 'Date and time when the guest arrived at the spa facility to begin the package experience.' ;
    rdfs:domain ind:AppointmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of loyalty program points redeemed by the guest to pay for or discount this spa package.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Package Duration Minutes' ;
    rdfs:comment 'Total duration of the spa package in minutes, including all treatments and amenities.' ;
    rdfs:domain ind:AppointmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagePrice rdf:type rdf:Property ;
    rdfs:label 'Package Price' ;
    rdfs:comment 'Base price of the spa package before any add-ons, discounts, or taxes.' ;
    rdfs:domain ind:AppointmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentCount rdf:type rdf:Property ;
    rdfs:label 'Treatment Count' ;
    rdfs:comment 'Number of individual spa treatments included in this package.' ;
    rdfs:domain ind:AppointmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationLogId rdf:type rdf:Property ;
    rdfs:label 'Cancellation Log Id' ;
    rdfs:comment 'Unique identifier for the cancellation log record. Primary key for the cancellation audit trail.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCancellationAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Cancellation Appointment Id' ;
    rdfs:comment 'Reference to the spa appointment or class session that was cancelled. Links to the original booking record.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appointment .

ind:primaryCancellationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cancellation Employee Id' ;
    rdfs:comment 'Reference to the staff user who processed the cancellation if cancelled by staff. Null for guest-initiated or system cancellations.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appointmentScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Scheduled Date' ;
    rdfs:comment 'Original scheduled date of the cancelled appointment. Used to calculate advance notice period.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationChannel rdf:type rdf:Property ;
    rdfs:label 'Cancellation Channel' ;
    rdfs:comment 'Channel or interface through which the cancellation was submitted. Enables channel-specific cancellation analysis. [ENUM-REF-CANDIDATE: PHONE|EMAIL|MOBILE_APP|WEBSITE|IN_PERSON|PMS|SYSTEM_AUTO — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Amount' ;
    rdfs:comment 'Monetary amount of the cancellation fee charged to the guest. Null if no fee was applied.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationFeeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Applicable Flag' ;
    rdfs:comment 'Indicates whether a cancellation fee was applicable based on policy rules and cancellation timing.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cancellation fee amount.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationFeeWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Waived Flag' ;
    rdfs:comment 'Indicates whether an applicable cancellation fee was waived by staff or management as a service recovery gesture.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationNotes rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notes' ;
    rdfs:comment 'Additional free-text notes or comments recorded by staff regarding the cancellation circumstances or guest interaction.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationNumber rdf:type rdf:Property ;
    rdfs:label 'Cancellation Number' ;
    rdfs:comment 'Business-facing unique cancellation reference number used for tracking and guest communication.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the cancellation reason provided by the cancelling party.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationType rdf:type rdf:Property ;
    rdfs:label 'Cancellation Type' ;
    rdfs:comment 'Classification of the cancellation event: standard cancellation with notice, no-show without notice, or late cancellation within policy window.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledByParty rdf:type rdf:Property ;
    rdfs:label 'Cancelled By Party' ;
    rdfs:comment 'Indicates which party initiated the cancellation: guest, staff member, automated system, or property management.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeWaiverReasonCode rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason why a cancellation fee was waived. Null if fee was not waived. [ENUM-REF-CANDIDATE: LOYALTY_STATUS|MEDICAL_EMERGENCY|PROPERTY_ERROR|SERVICE_RECOVERY|MANAGER_DISCRETION|FIRST_OFFENSE|WEATHER_EVENT|OTHER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeWaiverReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Reason Description' ;
    rdfs:comment 'Detailed explanation of why the cancellation fee was waived. Null if fee was not waived.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateCancellationFlag rdf:type rdf:Property ;
    rdfs:label 'Late Cancellation Flag' ;
    rdfs:comment 'Indicates whether the cancellation occurred within the late cancellation policy window defined by the spa facility.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAppointmentValue rdf:type rdf:Property ;
    rdfs:label 'Original Appointment Value' ;
    rdfs:comment 'Total monetary value of the cancelled appointment including all treatments and services. Represents lost revenue opportunity.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebookingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Rebooking Completed Flag' ;
    rdfs:comment 'Indicates whether the guest successfully rebooked a new appointment following this cancellation.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebookingOfferExtendedFlag rdf:type rdf:Property ;
    rdfs:label 'Rebooking Offer Extended Flag' ;
    rdfs:comment 'Indicates whether the guest was offered an opportunity to rebook the cancelled appointment at time of cancellation.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Recovery Amount' ;
    rdfs:comment 'Total amount recovered through cancellation fees and rebooking. Used to calculate net revenue impact of cancellation.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:therapistNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Therapist Notified Flag' ;
    rdfs:comment 'Indicates whether the assigned therapist was notified of the appointment cancellation to enable schedule adjustment.' ;
    rdfs:domain ind:CancellationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spaClassEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Spa Class Enrollment Id' ;
    rdfs:comment 'Unique identifier for the class enrollment record. Primary key.' ;
    rdfs:domain ind:SpaClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fitnessClassSessionId rdf:type rdf:Property ;
    rdfs:label 'Fitness Class Session Id' ;
    rdfs:comment 'Reference to the scheduled fitness or wellness class session. Links to the class session schedule.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FitnessClassSession .

ind:membershipId rdf:type rdf:Property ;
    rdfs:label 'Membership Id' ;
    rdfs:comment 'Reference to the guest\'s spa or fitness membership if applicable. Null for non-member enrollments.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Membership .

ind:primarySpaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Spa Employee Id' ;
    rdfs:comment 'Reference to the system user who processed the cancellation. Null for guest self-service cancellations or non-cancelled enrollments.' ;
    rdfs:domain ind:SpaClassEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attendanceConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Attendance Confirmed Flag' ;
    rdfs:comment 'Indicates whether the guest\'s attendance was confirmed by the instructor or system. True if attended, False if no-show or not yet determined.' ;
    rdfs:domain ind:SpaClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkInMethod rdf:type rdf:Property ;
    rdfs:label 'Check In Method' ;
    rdfs:comment 'Method used by the guest to check in for the class. Null if not checked in. Used for check-in process optimization.' ;
    rdfs:domain ind:SpaClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestFeedbackComments rdf:type rdf:Property ;
    rdfs:label 'Guest Feedback Comments' ;
    rdfs:comment 'Free-text comments provided by the guest about their class experience. Null if no feedback provided. Used for service improvement.' ;
    rdfs:domain ind:SpaClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestRating rdf:type rdf:Property ;
    rdfs:label 'Guest Rating' ;
    rdfs:comment 'Rating provided by the guest for the class experience on a scale of 1-5. Null if guest has not provided feedback. Used for class quality tracking.' ;
    rdfs:domain ind:SpaClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instructorNotes rdf:type rdf:Property ;
    rdfs:label 'Instructor Notes' ;
    rdfs:comment 'Notes added by the class instructor regarding the guest\'s participation, performance, or any incidents. Null if no notes recorded.' ;
    rdfs:domain ind:SpaClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noShowFeeAmount rdf:type rdf:Property ;
    rdfs:label 'No Show Fee Amount' ;
    rdfs:comment 'Fee charged to the guest for failing to attend or cancel within the policy window. Null if no fee applies. Expressed in the property\'s local currency.' ;
    rdfs:domain ind:SpaClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowFeeWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'No Show Fee Waived Flag' ;
    rdfs:comment 'Indicates whether the no-show fee was waived by management. True if waived, False if charged. Used for service recovery tracking.' ;
    rdfs:domain ind:SpaClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitlistPosition rdf:type rdf:Property ;
    rdfs:label 'Waitlist Position' ;
    rdfs:comment 'Position in the waitlist queue if enrollment status is waitlisted. Null for non-waitlisted enrollments. Used for automated promotion when spots become available.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitlistTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waitlist Timestamp' ;
    rdfs:comment 'Date and time when the guest was placed on the waitlist. Null if never waitlisted. Used for waitlist duration analysis.' ;
    rdfs:domain ind:SpaClassEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dayPassId rdf:type rdf:Property ;
    rdfs:label 'Day Pass Id' ;
    rdfs:comment 'Unique identifier for the day pass transaction. Primary key for the day pass record.' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingChannelId rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Id' ;
    rdfs:comment 'Reference to the channel through which the day pass was booked (web, mobile app, front desk, phone, OTA).' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:fnbPosCheckId rdf:type rdf:Property ;
    rdfs:label 'Fnb Pos Check Id' ;
    rdfs:comment 'Foreign key linking to fnb.pos_check. Business justification: Day pass guests commonly purchase F&B (pool bar, spa café, healthy dining) during facility visits. Resorts track total guest spend per day pass session for upsell analysis and package design optimizat' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosCheck .

ind:adultCount rdf:type rdf:Property ;
    rdfs:label 'Adult Count' ;
    rdfs:comment 'Number of adults included in the day pass. Used for capacity planning and pricing calculation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Out Timestamp' ;
    rdfs:comment 'The actual timestamp when the guest checked out and vacated the facility. Used for operational tracking and capacity management.' ;
    rdfs:domain ind:Spa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:childCount rdf:type rdf:Property ;
    rdfs:label 'Child Count' ;
    rdfs:comment 'Number of children included in the day pass. Used for capacity planning and pricing calculation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupBookingFlag rdf:type rdf:Property ;
    rdfs:label 'Group Booking Flag' ;
    rdfs:comment 'Indicates whether this day pass is part of a group booking. Used for group sales analytics and capacity planning.' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Member Flag' ;
    rdfs:comment 'Indicates whether the guest is a member of the property loyalty program. Used for loyalty analytics and benefits application.' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageFlag rdf:type rdf:Property ;
    rdfs:label 'Package Flag' ;
    rdfs:comment 'Indicates whether this day pass is part of a larger package or bundle (e.g., spa day package with treatments).' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passDate rdf:type rdf:Property ;
    rdfs:label 'Pass Date' ;
    rdfs:comment 'The calendar date for which the day pass is valid. Represents the business event date for the pass usage.' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passNumber rdf:type rdf:Property ;
    rdfs:label 'Pass Number' ;
    rdfs:comment 'Externally visible unique alphanumeric identifier for the day pass. Used for guest reference, check-in, and operational tracking.' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Status' ;
    rdfs:comment 'Current lifecycle status of the day pass. Tracks the pass from sale through expiration or refund.' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passType rdf:type rdf:Property ;
    rdfs:label 'Pass Type' ;
    rdfs:comment 'Classification of the day pass by facility type. Determines which amenities the pass grants access to.' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromTime rdf:type rdf:Property ;
    rdfs:label 'Valid From Time' ;
    rdfs:comment 'The timestamp when the day pass becomes valid and the guest may begin using the facility.' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validToTime rdf:type rdf:Property ;
    rdfs:label 'Valid To Time' ;
    rdfs:comment 'The timestamp when the day pass expires and the guest must vacate the facility.' ;
    rdfs:domain ind:DayPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Unique identifier for the spa and fitness equipment asset. Primary key.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceVendorId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Spa equipment requires ongoing maintenance from specialized service vendors (separate from original supplier). Critical for service contract management, preventive maintenance scheduling, and vendor p' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:capacityRating rdf:type rdf:Property ;
