ind:involvedPartyName rdf:type rdf:Property ;
    rdfs:label 'Involved Party Name' ;
    rdfs:comment 'Full name of the person involved in the incident. Used when the party is not a registered guest or employee (e.g., contractor, visitor).' ;
    rdfs:domain ind:HealthSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityClaimFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Liability Claim Filed Flag' ;
    rdfs:comment 'Indicates whether a liability claim or lawsuit was filed by the injured party against the property or company.' ;
    rdfs:domain ind:HealthSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationWithinProperty rdf:type rdf:Property ;
    rdfs:label 'Location Within Property' ;
    rdfs:comment 'Specific location or area within the property where the incident occurred (e.g., lobby, pool deck, guest room 305, kitchen, parking lot).' ;
    rdfs:domain ind:HealthSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Medical Facility Name' ;
    rdfs:comment 'Name of the medical facility or hospital where treatment was provided, if applicable.' ;
    rdfs:domain ind:HealthSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalTreatmentProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Treatment Provided Flag' ;
    rdfs:comment 'Indicates whether medical treatment was provided to the injured party beyond first aid.' ;
    rdfs:domain ind:HealthSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaRecordableFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Flag' ;
    rdfs:comment 'Indicates whether the incident meets OSHA criteria for recordable work-related injuries and illnesses.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personTypeInvolved rdf:type rdf:Property ;
    rdfs:label 'Person Type Involved' ;
    rdfs:comment 'Classification of the type of person(s) involved in the incident.' ;
    rdfs:domain ind:HealthSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Name of the regulatory authority or agency that was notified (e.g., OSHA, local health department, fire department).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether the incident requires notification to regulatory authorities (OSHA, local health department, fire marshal, etc.).' ;
    rdfs:domain ind:HealthSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Name of the person who initially reported the incident.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the incident was first reported to management or the safety team.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restrictedWorkDays rdf:type rdf:Property ;
    rdfs:label 'Restricted Work Days' ;
    rdfs:comment 'Number of calendar days the employee was on restricted work duty as a result of the incident. Applicable for employee incidents only.' ;
    rdfs:domain ind:HealthSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessInformation rdf:type rdf:Property ;
    rdfs:label 'Witness Information' ;
    rdfs:comment 'Information about witnesses to the incident, including names and contact details. May contain multiple witnesses in structured or semi-structured format.' ;
    rdfs:domain ind:HealthSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompensationClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Workers Compensation Claim Flag' ;
    rdfs:comment 'Indicates whether a workers compensation claim was filed as a result of this incident.' ;
    rdfs:domain ind:HealthSafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Incident Investigation Id' ;
    rdfs:comment 'Unique identifier for the incident investigation record. Primary key.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIncidentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Incident Employee Id' ;
    rdfs:comment 'Reference to the employee or external party serving as the primary investigator responsible for conducting the investigation and compiling findings.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryIncidentUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Incident Updated By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this investigation record in the system.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level governing access to and disclosure of investigation findings. Restricted for investigations involving legal proceedings or sensitive personnel matters.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Narrative description of secondary or contributing factors that played a role in the incident but were not the primary root cause. May include environmental, procedural, or human factors.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated cost impact amount.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'Estimated total financial impact of the incident including direct costs (medical, property damage, legal) and indirect costs (lost productivity, reputation damage). Expressed in the property\'s local currency.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceCollected rdf:type rdf:Property ;
    rdfs:label 'Evidence Collected' ;
    rdfs:comment 'Summary of physical, documentary, or testimonial evidence collected during the investigation (e.g., photographs, equipment samples, witness statements, video footage, maintenance records).' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalInvestigatorFirm rdf:type rdf:Property ;
    rdfs:label 'External Investigator Firm' ;
    rdfs:comment 'Name of the external consulting firm or independent investigator engaged to conduct or support the investigation, if applicable.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCarrierName rdf:type rdf:Property ;
    rdfs:label 'Insurance Carrier Name' ;
    rdfs:comment 'Name of the insurance carrier handling the claim associated with this incident (e.g., workers compensation, general liability, property insurance).' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Reference' ;
    rdfs:comment 'Reference number for any insurance claim filed in connection with this incident. Links the investigation to the insurance claim process.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Close Date' ;
    rdfs:comment 'The date when the investigation was formally closed and all findings were finalized. Null if investigation is still open or in progress.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationMethodology rdf:type rdf:Property ;
    rdfs:label 'Investigation Methodology' ;
    rdfs:comment 'The primary investigative methodology or framework used to conduct the investigation (e.g., root cause analysis, five whys, fishbone diagram, fault tree analysis, timeline reconstruction, witness interviews). [ENUM-REF-CANDIDATE: root_cause_analysis|five_whys|fishbone|fault_tree|timeline|witness_interview|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Additional notes, observations, or context relevant to the investigation that do not fit into other structured fields.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationPriority rdf:type rdf:Property ;
    rdfs:label 'Investigation Priority' ;
    rdfs:comment 'Priority level assigned to the investigation determining resource allocation and timeline urgency.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this investigation for tracking and regulatory reporting purposes.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationReportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Investigation Report Document Reference' ;
    rdfs:comment 'Reference to the formal investigation report document stored in the document management system. Contains the full investigation findings, evidence, and recommendations.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'The date when the formal investigation was initiated and investigative activities began.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the investigation: open (initiated but not started), in_progress (actively investigating), pending_review (awaiting management or regulatory review), closed (completed and finalized), suspended (temporarily halted).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Investigation Team Members' ;
    rdfs:comment 'Comma-separated list of employee names or identifiers who are part of the investigation team supporting the lead investigator.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of the investigation based on the driving authority or purpose: internal (company-led), regulatory (mandated by OSHA or other agency), insurance (claim-related), legal (litigation-related), third_party (external consultant), or joint (multi-party).' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether a legal hold has been placed on all evidence and documentation related to this investigation due to pending or anticipated litigation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'The date when the regulatory body was formally notified of the incident and investigation. Null if no notification was required or made.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendedPreventiveMeasures rdf:type rdf:Property ;
    rdfs:label 'Recommended Preventive Measures' ;
    rdfs:comment 'Detailed recommendations for corrective and preventive actions to eliminate the root cause and prevent recurrence of similar incidents. May include policy changes, training, equipment upgrades, or procedural modifications.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBodyName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Name' ;
    rdfs:comment 'Name of the regulatory agency or body that was notified (e.g., OSHA, state health department, fire marshal, ADA compliance office).' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBodyNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Notified Flag' ;
    rdfs:comment 'Indicates whether a regulatory body (e.g., OSHA, local health department, fire marshal) was notified of the incident and investigation.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Case Number' ;
    rdfs:comment 'The case or reference number assigned by the regulatory body for tracking their review or enforcement action related to this incident.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Conducted Flag' ;
    rdfs:comment 'Indicates whether the regulatory body conducted an on-site inspection as part of their review of the incident.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Date' ;
    rdfs:comment 'The date when the regulatory body conducted their on-site inspection. Null if no inspection occurred.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseDetermination rdf:type rdf:Property ;
    rdfs:label 'Root Cause Determination' ;
    rdfs:comment 'Detailed narrative describing the identified root cause(s) of the incident based on investigation findings. This is the primary causal factor that, if eliminated, would have prevented the incident.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Overall severity rating assigned to the investigation based on the incident\'s actual and potential impact on health, safety, compliance, and business operations.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'The number of witnesses interviewed as part of the investigation.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date on which the permit application was submitted to the issuing authority. Used to track processing timelines and compliance with application deadlines.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditions rdf:type rdf:Property ;
    rdfs:label 'Conditions' ;
    rdfs:comment 'Text description of any special conditions, restrictions, or requirements attached to the permit by the issuing authority. May include operational limitations, reporting requirements, or compliance obligations.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderName rdf:type rdf:Property ;
    rdfs:label 'Holder Name' ;
    rdfs:comment 'Legal name of the entity or individual to whom the permit is issued. Must match the legal business name registered with the issuing authority.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderType rdf:type rdf:Property ;
    rdfs:label 'Holder Type' ;
    rdfs:comment 'Legal classification of the permit holder entity. Determines liability structure and regulatory reporting requirements.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Required frequency of regulatory inspections as mandated by the issuing authority. Determines inspection scheduling and compliance monitoring cadence.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the permit requires periodic inspections by the issuing authority to maintain active status. True for permits with ongoing compliance verification requirements.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the permit was officially issued by the regulatory authority. Marks the beginning of the permits validity period.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date on which the permit was most recently renewed. Used to track renewal history and compliance with periodic renewal requirements.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'The official permit or license number issued by the regulatory authority. This is the externally-known identifier used in all regulatory correspondence and inspections.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the permit. Active permits authorize operations; expired or suspended permits require immediate remediation to avoid operational shutdowns or fines.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the permit based on the regulatory domain it covers. Determines which regulatory body governs this permit and what operational activities it authorizes. [ENUM-REF-CANDIDATE: liquor_license|food_service_permit|fire_safety_certificate|building_occupancy_permit|health_department_permit|pool_spa_license|gaming_license|business_operating_license — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'Date on which a suspended permit was reinstated and operations were authorized to resume. Indicates successful remediation of suspension causes.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date by which the permit renewal application must be submitted to the issuing authority to avoid lapse in authorization. Typically precedes expiration date by 30-90 days.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Amount' ;
    rdfs:comment 'Fee amount required for permit renewal. May differ from initial permit fee based on regulatory fee schedules.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date on which the permit was permanently revoked by the issuing authority. Revocation typically requires a new application process to regain authorization.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation of why the permit was revoked. Includes serious violations, repeated non-compliance, or failure to meet statutory requirements.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date on which the permit was suspended by the issuing authority. Marks the beginning of the suspension period during which authorized operations must cease.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Explanation of why the permit was suspended, if applicable. Includes regulatory violations, non-payment of fees, or failure to meet permit conditions.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Username or identifier of the user who last updated this permit record. Used for audit trail and accountability.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Total number of violations or citations issued against this permit since its last issuance or renewal. Used to track compliance history and risk exposure.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitRenewalId rdf:type rdf:Property ;
    rdfs:label 'Permit Renewal Id' ;
    rdfs:comment 'Unique identifier for the permit renewal transaction record. Primary key for the permit renewal entity.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Renewal Coordinator Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for managing and coordinating this permit renewal process. Typically a compliance officer, property manager, or legal staff member.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date when an appeal was formally filed with the appropriate authority. Null if no appeal has been filed.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether an appeal has been filed in response to a renewal rejection or adverse conditions. True if appeal is active, False otherwise.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether this permit is eligible for automatic renewal without full re-application. True if auto-renewal is available, False if full application is required.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for internal compliance team notes, observations, and action items related to this renewal. May include lessons learned, process improvements, or coordination details.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Date' ;
    rdfs:comment 'Date when the required inspection was completed by the issuing authority. Null if no inspection is required or if inspection has not yet occurred.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Result of the regulatory inspection conducted as part of the renewal process. Determines whether renewal can proceed or if corrective actions are required.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Name of the governmental or regulatory body responsible for issuing and renewing the permit. Examples include local health departments, fire marshals, liquor control boards, or building departments.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Reference Number' ;
    rdfs:comment 'External reference number or case identifier assigned by the issuing authority to track this renewal application in their systems.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided by the issuing authority for rejecting the renewal application. Null if renewal was not rejected.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Approval Date' ;
    rdfs:comment 'Date when the renewal was officially approved by the issuing authority. Null if renewal is not yet approved or was rejected.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalConditions rdf:type rdf:Property ;
    rdfs:label 'Renewal Conditions' ;
    rdfs:comment 'Any special conditions, restrictions, or requirements attached to the renewed permit by the issuing authority. May include operational limitations, reporting obligations, or corrective action deadlines.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle Months' ;
    rdfs:comment 'Duration in months of the renewed permit period. Enables calculation of next renewal due date and proactive renewal planning.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Effective Date' ;
    rdfs:comment 'Start date of the renewed permit period. Represents when the renewed permit becomes legally binding and operational.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Expiration Date' ;
    rdfs:comment 'End date of the renewed permit period. Represents when the renewed permit will expire and require subsequent renewal.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the renewal fee amount. Enables multi-currency tracking across global property portfolio.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFeePaidFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Paid Flag' ;
    rdfs:comment 'Indicates whether the renewal fee has been paid to the issuing authority. True if paid, False if outstanding.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalFeePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Payment Date' ;
    rdfs:comment 'Date when the renewal fee was paid to the issuing authority. Null if fee has not yet been paid.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Number' ;
    rdfs:comment 'Externally-visible business identifier for this renewal transaction. May be used in correspondence with regulatory authorities and internal tracking systems.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequestDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Request Date' ;
    rdfs:comment 'Date when the renewal process was initiated internally. Represents the business event timestamp when the organization began preparing the renewal application.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current lifecycle status of the permit renewal transaction. Tracks progression from initiation through final disposition. [ENUM-REF-CANDIDATE: initiated|submitted|under_review|approved|rejected|lapsed|withdrawn|pending_payment — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Submission Date' ;
    rdfs:comment 'Date when the renewal application was formally submitted to the issuing authority or regulatory body.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportingDocumentsChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents Checklist Status' ;
    rdfs:comment 'Status of the supporting documentation required for the renewal application. Tracks whether all required certificates, inspections, and supporting materials have been gathered and verified.' ;
    rdfs:domain ind:PermitRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Policy Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created this policy record in the system.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:policyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Policy Employee Id' ;
    rdfs:comment 'Identifier of the executive or department head responsible for policy governance, maintenance, and enforcement.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:policyUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Policy Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this policy record.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded Policy Id' ;
    rdfs:comment 'Identifier of the previous policy version that this policy replaces. Null if this is the first version.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:acknowledgmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required Flag' ;
    rdfs:comment 'Indicates whether employees must formally acknowledge receipt and understanding of this policy. True if acknowledgment is mandatory.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Scope' ;
    rdfs:comment 'Organizational reach of the policy. Enterprise-wide applies to all entities; brand-specific applies to a hotel brand; property-specific applies to individual properties; regional applies to geographic regions; departmental applies to specific functions.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name and title of the executive, board, or committee that formally approved this policy for implementation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the policy owner or compliance officer for questions, clarifications, and policy-related inquiries.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the policy owner or compliance officer for urgent policy-related matters.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Document Reference Url' ;
    rdfs:comment 'URL or file path to the full policy document stored in the enterprise document management system.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Level' ;
    rdfs:comment 'Degree of compliance obligation. Mandatory policies require strict adherence with consequences for non-compliance; recommended policies are best practices; advisory policies provide guidance.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Category' ;
    rdfs:comment 'Primary classification of the policy domain. Categories include data privacy (GDPR/CCPA compliance), health and safety (OSHA, fire safety), anti-bribery (anti-corruption), code of conduct (ethics), liquor service (licensing), food safety (ISO 22000), ADA (accessibility), environmental (sustainability), and information security (PCI DSS).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Comprehensive summary of the policy purpose, scope, and key requirements. Provides context for policy application and interpretation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Business-facing unique policy identifier used for reference and communication across the organization.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle state of the policy. Draft indicates policy is being developed; active indicates policy is in force; under review indicates policy is being revised; retired indicates policy is no longer applicable; suspended indicates temporary hold.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Primary regulatory framework, statute, or industry standard that mandates or informs this policy (e.g., GDPR Article 32, OSHA 1910.38, PCI DSS 3.2.1, ISO 22000:2018).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPolicyIds rdf:type rdf:Property ;
    rdfs:label 'Related Policy Ids' ;
    rdfs:comment 'Comma-separated list of policy IDs that are related or cross-referenced by this policy for comprehensive compliance understanding.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeEntityReference rdf:type rdf:Property ;
    rdfs:label 'Scope Entity Reference' ;
    rdfs:comment 'Identifier of the specific brand, property, region, or department to which this policy applies when scope is not enterprise-wide. Null for enterprise-wide policies.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing additional granularity within the policy category (e.g., guest data protection, employee safety, vendor conduct).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Full official title of the compliance policy as approved by governance authority.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyAcknowledgmentId rdf:type rdf:Property ;
    rdfs:label 'Policy Acknowledgment Id' ;
    rdfs:comment 'Unique identifier for the policy acknowledgment record. Primary key for the policy acknowledgment transaction.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PolicyAcknowledgment .

ind:complianceTrainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Completion Id' ;
    rdfs:comment 'Reference to the e-learning or training completion record if acknowledgment was captured through training system attestation. Null for non-training acknowledgments.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceTrainingCompletion .

ind:primaryPolicyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Policy Employee Id' ;
    rdfs:comment 'Reference to the employee who acknowledged the policy. Links to the workforce employee master record.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryPolicyCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Policy Created By User Employee Id' ;
    rdfs:comment 'Reference to the user or system process that created this acknowledgment record. Typically the HR system or compliance workflow engine.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryPolicyUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Policy Updated By User Employee Id' ;
    rdfs:comment 'Reference to the user or system process that last modified this acknowledgment record. Supports audit trail and change tracking.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPolicyEscalatedToUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Policy Escalated To User Employee Id' ;
    rdfs:comment 'Reference to the manager or compliance officer to whom the overdue acknowledgment was escalated. Null if no escalation has occurred.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgmentChannel rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Channel' ;
    rdfs:comment 'The digital or physical channel through which the acknowledgment was captured. Distinguishes between self-service, facilitated, and system-driven acknowledgments.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'The date on which the employee acknowledged the policy. Represents the business event timestamp when the acknowledgment was completed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Due Date' ;
    rdfs:comment 'The deadline by which the employee was required to acknowledge the policy. Used to identify overdue acknowledgments and trigger escalations.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentMethod rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Method' ;
    rdfs:comment 'The mechanism through which the employee acknowledged the policy. Indicates whether acknowledgment was captured electronically, physically, or through training completion.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Record Number' ;
    rdfs:comment 'Business identifier for the acknowledgment transaction. Externally visible unique reference number used in audit trails and compliance reporting.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Status' ;
    rdfs:comment 'Current lifecycle status of the policy acknowledgment. Tracks whether the employee has completed, is pending, or has missed the acknowledgment requirement.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Precise date and time when the employee completed the policy acknowledgment. Used for audit trail and legal defensibility.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceOfficerNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Notes' ;
    rdfs:comment 'Free-text notes added by compliance officers regarding this acknowledgment. Used to document special circumstances, follow-up actions, or audit findings.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The department or division to which the employee belonged at the time of acknowledgment. Enables department-level compliance tracking and reporting.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'The current escalation level for overdue acknowledgments. 0 indicates no escalation, higher numbers indicate progressive escalation to management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The Internet Protocol address from which the acknowledgment was submitted. Captured for audit trail and fraud prevention purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobRoleCode rdf:type rdf:Property ;
    rdfs:label 'Job Role Code' ;
    rdfs:comment 'The job role or position code of the employee at the time of acknowledgment. Supports role-based policy assignment and compliance analysis.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Sent Date' ;
    rdfs:comment 'The date when the most recent reminder notification was sent to the employee. Null if no reminders were sent.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyVersionAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Policy Version Acknowledged' ;
    rdfs:comment 'The specific version of the policy that the employee acknowledged. Critical for demonstrating that employees acknowledged the current policy version in effect at the time.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reAcknowledgmentFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Re Acknowledgment Frequency Days' ;
    rdfs:comment 'The number of days between required re-acknowledgments. Null if re-acknowledgment is not required. Common values include 365 (annual) or 730 (biennial).' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reAcknowledgmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Acknowledgment Required Flag' ;
    rdfs:comment 'Indicates whether this policy requires periodic re-acknowledgment. True if the employee must re-acknowledge at regular intervals.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderSentCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Count' ;
    rdfs:comment 'The number of reminder notifications sent to the employee before acknowledgment was completed. Used to track engagement and escalation effectiveness.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatureImageReference rdf:type rdf:Property ;
    rdfs:label 'Signature Image Reference' ;
    rdfs:comment 'Reference to the stored digital or scanned signature image file. Null for non-signature acknowledgment methods. Points to secure document storage system.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'The date when the waiver was approved. Null if no waiver was granted.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedMemberId rdf:type rdf:Property ;
    rdfs:label 'Affected Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member. Business justification: GDPR/CCPA breaches affecting loyalty member PII (account access logs, points transaction history, tier status) require direct member reference for breach notification obligations, remediation tracking' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:communicationConsentId rdf:type rdf:Property ;
    rdfs:label 'Communication Consent Id' ;
    rdfs:comment 'Foreign key linking to guest.communication_consent. Business justification: Privacy incidents may stem from consent violations (unauthorized marketing, improper data sharing). Linking incident to specific consent record supports root cause analysis, regulatory investigation r' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunicationConsent .

ind:identityDocumentId rdf:type rdf:Property ;
    rdfs:label 'Identity Document Id' ;
    rdfs:comment 'Foreign key linking to guest.identity_document. Business justification: Data breaches exposing identity documents (passports, IDs) require tracking which specific documents were compromised for breach notification, fraud monitoring, and regulatory reporting. Essential for' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IdentityDocument .

ind:primaryPrivacyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Privacy Employee Id' ;
    rdfs:comment 'Identifier of the employee or Data Protection Officer (DPO) responsible for managing and coordinating the incident response.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:privacyRequestId rdf:type rdf:Property ;
    rdfs:label 'Privacy Request Id' ;
    rdfs:comment 'Foreign key linking to guest.privacy_request. Business justification: Privacy incidents often trigger data subject access requests (DSARs) or erasure requests. Linking incident to originating request supports incident investigation, regulatory response coordination, and' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyRequest .

ind:tertiaryPrivacyUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Privacy Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that last updated the privacy incident record.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:breachNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Required Flag' ;
    rdfs:comment 'Indicates whether regulatory breach notification to supervisory authorities is required under applicable data protection laws.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmedSubjectsAffected rdf:type rdf:Property ;
    rdfs:label 'Confirmed Subjects Affected' ;
    rdfs:comment 'Confirmed count of individual data subjects whose personal data was definitively affected by the incident after investigation.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containmentActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Containment Actions Taken' ;
    rdfs:comment 'Description of immediate containment and mitigation actions taken to stop the breach, secure systems, and prevent further unauthorized access or data loss.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategoriesAffected rdf:type rdf:Property ;
    rdfs:label 'Data Categories Affected' ;
    rdfs:comment 'Comma-separated list of data categories involved in the incident such as PII (Personally Identifiable Information), payment card data, health data, biometric data, guest preferences, loyalty account information.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Date when the privacy incident was first discovered or detected by the organization.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Discovery Method' ;
    rdfs:comment 'Method or channel through which the privacy incident was discovered or brought to the organization\'s attention.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Notification Date' ;
    rdfs:comment 'Timestamp when the Data Protection Officer was notified about the privacy incident.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dpoNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Dpo Notified Flag' ;
    rdfs:comment 'Indicates whether the organization\'s Data Protection Officer was notified about the incident.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedSubjectsAffected rdf:type rdf:Property ;
    rdfs:label 'Estimated Subjects Affected' ;
    rdfs:comment 'Estimated number of individual data subjects (guests, employees, or other persons) whose personal data was affected by the incident.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentNotes rdf:type rdf:Property ;
    rdfs:label 'Incident Notes' ;
    rdfs:comment 'Additional free-text notes, observations, or context about the privacy incident not captured in other structured fields.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the privacy incident for tracking and regulatory reporting purposes. Format: PI-YYYY-NNNNNN.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the internal investigation into the privacy incident was completed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jurisdictionsImpacted rdf:type rdf:Property ;
    rdfs:label 'Jurisdictions Impacted' ;
    rdfs:comment 'Comma-separated list of jurisdictions or regulatory regions where affected data subjects reside, determining applicable data protection laws (e.g., USA, GBR, DEU, FRA, CAN).' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselEngagedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Engaged Flag' ;
    rdfs:comment 'Indicates whether internal or external legal counsel was engaged to advise on the incident response and regulatory obligations.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:litigationFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Filed Flag' ;
    rdfs:comment 'Indicates whether civil litigation or class action lawsuits were filed by affected data subjects as a result of the incident.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Deadline' ;
    rdfs:comment 'Deadline timestamp by which the organization must notify the relevant supervisory authority about the breach (typically 72 hours from discovery under GDPR).' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryNotificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Sent Date' ;
    rdfs:comment 'Actual timestamp when notification was sent to the regulatory supervisory authority.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryPenaltyImposedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Penalty Imposed Flag' ;
    rdfs:comment 'Indicates whether a regulatory penalty or fine was imposed by a supervisory authority as a result of the incident.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Remediation Actions Taken' ;
    rdfs:comment 'Description of remediation measures implemented to address the root cause, restore security, and prevent recurrence of similar incidents.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Detailed risk assessment narrative describing the potential consequences and risks to the rights and freedoms of affected data subjects.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Assessed severity level of the privacy incident based on the nature of data affected, number of subjects, and potential harm.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Subject Notification Required Flag' ;
    rdfs:comment 'Indicates whether direct notification to affected data subjects is required under applicable data protection laws.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectNotificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Subject Notification Sent Date' ;
    rdfs:comment 'Actual timestamp when notification was sent to affected data subjects.' ;
    rdfs:domain ind:PrivacyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryRegulatoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that created this regulatory filing record.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the regulatory body formally accepted or approved the filing as complete and compliant.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or receipt number provided by the regulatory body upon successful submission of the filing.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Document Reference Code' ;
    rdfs:comment 'Reference identifier or file path to the supporting documentation, forms, or attachments associated with this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingAgentEmail rdf:type rdf:Property ;
    rdfs:label 'Filing Agent Email' ;
    rdfs:comment 'Email address of the filing agent or compliance officer responsible for this submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingAgentName rdf:type rdf:Property ;
    rdfs:label 'Filing Agent Name' ;
    rdfs:comment 'Name of the individual, department, or external consultant responsible for preparing and submitting this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingAgentPhone rdf:type rdf:Property ;
    rdfs:label 'Filing Agent Phone' ;
    rdfs:comment 'Contact phone number of the filing agent or compliance officer responsible for this submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'Detailed description of the purpose, scope, and content of this regulatory filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingMethod rdf:type rdf:Property ;
    rdfs:label 'Filing Method' ;
    rdfs:comment 'Method or channel used to submit the filing to the regulatory body (e.g., online portal, email, postal mail, fax, in-person delivery, API integration).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period End Date' ;
    rdfs:comment 'End date of the reporting or compliance period covered by this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period Start Date' ;
    rdfs:comment 'Start date of the reporting or compliance period covered by this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'External reference number or tracking identifier assigned by the regulatory body or internal compliance system for this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing. Tracks progression from draft through submission, review, and final disposition. [ENUM-REF-CANDIDATE: draft|submitted|acknowledged|accepted|rejected|under_review|pending_correction|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Category of regulatory filing. Indicates the nature of the submission such as occupancy tax filings, liquor license renewals, health department reports, OSHA 300 log submissions, GDPR supervisory authority notifications, CCPA annual reports, fire marshal reports, environmental compliance filings, ADA compliance reports, building permits, or food safety certifications. [ENUM-REF-CANDIDATE: occupancy_tax|liquor_license_renewal|health_department_report|osha_300_log|gdpr_notification|ccpa_annual_report|fire_marshal_report|environmental_compliance|ada_compliance|building_permit|food_safety_certification — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAssessedFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Assessed Flag' ;
    rdfs:comment 'Indicates whether a penalty, fine, or sanction was assessed by the regulatory body in relation to this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyPaidFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Paid Flag' ;
    rdfs:comment 'Indicates whether any assessed penalty or fine has been paid in full.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Penalty Payment Date' ;
    rdfs:comment 'Date on which the assessed penalty or fine was paid to the regulatory body.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the government agency, regulatory authority, or supervisory body to which this filing is submitted (e.g., IRS, state tax authority, health department, OSHA, fire marshal, data protection authority).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryResponseDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Date' ;
    rdfs:comment 'Date on which the regulatory body provided a formal response, feedback, or decision regarding this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryResponseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Received Flag' ;
    rdfs:comment 'Indicates whether a formal response or feedback has been received from the regulatory body regarding this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryResponseSummary rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Summary' ;
    rdfs:comment 'Summary of the regulatory bodys response, including any comments, requests for correction, or approval notes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the regulatory body rejected the filing due to errors, omissions, or non-compliance.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the filing was submitted to the regulatory body.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise date and time when the filing was submitted to the regulatory authority, including timezone information.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Unique identifier for the risk register entry. Primary key for the risk register product.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskRegister .

ind:primaryRiskOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:updatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last updated this risk register entry. Links to user or employee master data for audit trail purposes.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Actual date when the risk was closed or mitigated to an acceptable level.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controlEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness' ;
    rdfs:comment 'Assessment of how well the current control measures are functioning to mitigate the risk. Effective means controls are working as designed; partially effective means controls reduce but do not eliminate risk; ineffective means controls are not adequately addressing the risk.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasures rdf:type rdf:Property ;
    rdfs:label 'Control Measures' ;
    rdfs:comment 'Description of existing controls, policies, procedures, and mitigation actions currently in place to manage and reduce the risk.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdScore rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Score' ;
    rdfs:comment 'Residual risk score threshold above which the risk must be escalated to senior management or board level. Typically set at 15 or 20 on the 1-25 scale.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated financial impact in monetary terms if the risk materializes, including potential revenue loss, penalty costs, remediation costs, or legal settlement amounts.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial impact amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'Date when the risk was first identified and entered into the risk register.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactRating rdf:type rdf:Property ;
    rdfs:label 'Impact Rating' ;
    rdfs:comment 'Severity assessment of the risk impact if it occurs on a scale of 1 to 5, where 1 is negligible impact and 5 is catastrophic impact affecting multiple properties or enterprise reputation.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Calculated risk score before considering control measures, computed as likelihood rating multiplied by impact rating. Range is 1 to 25.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastIncidentDate rdf:type rdf:Property ;
    rdfs:label 'Last Incident Date' ;
    rdfs:comment 'Date of the most recent incident or event related to this risk.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Probability assessment of the risk occurring on a scale of 1 to 5, where 1 is rare (less than 10% probability) and 5 is almost certain (greater than 90% probability).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mitigationCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Cost Estimate' ;
    rdfs:comment 'Estimated cost in monetary terms to implement the mitigation plan and controls to reduce the risk.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Detailed action plan outlining specific steps, resources, and timeline for reducing the risk to an acceptable level.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of specific regulation, law, standard, or compliance requirement associated with this risk (e.g., GDPR Article 32, OSHA 1910.38, PCI DSS 3.2.1).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Related Incident Count' ;
    rdfs:comment 'Number of actual incidents or near-miss events that have occurred related to this risk, providing evidence of risk materialization.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualImpactRating rdf:type rdf:Property ;
    rdfs:label 'Residual Impact Rating' ;
    rdfs:comment 'Revised severity assessment after considering the effect of control measures, on a scale of 1 to 5.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood Rating' ;
    rdfs:comment 'Revised probability assessment after considering the effect of control measures, on a scale of 1 to 5.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Calculated risk score after considering control measures, computed as residual likelihood rating multiplied by residual impact rating. Range is 1 to 25.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAppetiteAlignment rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Alignment' ;
    rdfs:comment 'Assessment of whether the residual risk level aligns with the organizations stated risk appetite. Within appetite means acceptable; exceeds appetite means requires additional mitigation; below appetite means over-controlled.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Primary classification of the risk type. Regulatory includes compliance with laws and regulations; health and safety covers guest and employee safety; data privacy includes GDPR and CCPA compliance; reputational covers brand and guest satisfaction; financial covers revenue and cost risks; operational covers business process and service delivery risks.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCode rdf:type rdf:Property ;
    rdfs:label 'Risk Code' ;
    rdfs:comment 'Unique business identifier for the risk following the format AAA-9999 where AAA represents risk category prefix and 9999 is sequential number.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative description of the risk including potential causes, scenarios, and business context.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle state of the risk. Open means newly identified; in progress means mitigation actions underway; mitigated means controls have reduced risk to acceptable level; accepted means risk acknowledged and no further action planned; closed means risk no longer applicable; escalated means risk requires senior management attention.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'Secondary classification providing additional granularity within the primary risk category (e.g., fire safety, food safety, PCI DSS, ADA compliance).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Short descriptive title of the identified risk for quick reference and reporting.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Planned date by which the risk is expected to be mitigated to an acceptable level or closed.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primarySanctionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sanction Employee Id' ;
    rdfs:comment 'Identifier of the employee if the screened entity is an employee. Null for non-employee entities.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Identifier of the compliance officer or employee who manually reviewed the screening result. Null if no manual review was performed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:screenedMemberId rdf:type rdf:Property ;
    rdfs:label 'Screened Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member. Business justification: AML/sanctions screening of high-value loyalty members (large points transfers, suspicious redemption patterns, partner program transfers) requires member reference for risk assessment and regulatory r' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:businessRelationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Business Relationship Status' ;
    rdfs:comment 'Current status of the business relationship with the screened entity following the screening result: active (approved to continue), suspended (temporarily halted), terminated (permanently ended), or pending approval.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Source system or module from which the entity data was extracted for screening (e.g., OPERA PMS Guest Profiles, Salesforce CRM, SAP S/4HANA Vendor Master).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Match Confidence Score' ;
    rdfs:comment 'Numerical confidence score (0.00 to 100.00) indicating the likelihood that the screened entity matches a watchlist entry, generated by the screening system algorithm.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchDisposition rdf:type rdf:Property ;
    rdfs:label 'Match Disposition' ;
    rdfs:comment 'Final disposition status of the screening result after review: cleared (approved to proceed), escalated (sent to compliance officer), blocked (transaction/relationship prohibited), under review, or false positive.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchResult rdf:type rdf:Property ;
    rdfs:label 'Match Result' ;
    rdfs:comment 'Outcome of the screening indicating whether the entity matched any watchlist entries: no match, potential match requiring review, or confirmed match.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedEntryReference rdf:type rdf:Property ;
    rdfs:label 'Matched Entry Reference' ;
    rdfs:comment 'Reference number or identifier of the specific watchlist entry that matched or potentially matched the screened entity. Null if no match.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListName rdf:type rdf:Property ;
    rdfs:label 'Matched List Name' ;
    rdfs:comment 'Name of the specific sanctions or watchlist where a match or potential match was identified. Null if no match.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference' ;
    rdfs:comment 'Reference number or identifier of the regulatory report filed (e.g., SAR filing number). Null if no report was filed.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the manual review of the screening result was completed. Null if no manual review was performed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Detailed notes and rationale documented by the reviewer explaining the disposition decision, including any supporting evidence or justification for clearing or blocking the entity.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the compliance officer or employee who reviewed the screening result. Null if no manual review was performed.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedBySystem rdf:type rdf:Property ;
    rdfs:label 'Screened By System' ;
    rdfs:comment 'Name or identifier of the automated screening system or platform that performed the sanction check (e.g., Salesforce CRM screening module, third-party AML platform).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityName rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Name' ;
    rdfs:comment 'Full name of the individual, corporate account, vendor, or business partner being screened against sanctions and watchlists.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedEntityType rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Type' ;
    rdfs:comment 'Classification of the entity being screened: guest, corporate account, vendor, employee, business partner, or third-party.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'Date when the sanction screening was performed against regulatory watchlists.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningListsChecked rdf:type rdf:Property ;
    rdfs:label 'Screening Lists Checked' ;
    rdfs:comment 'Comma-separated list of regulatory watchlists checked during this screening event (e.g., OFAC SDN, EU Consolidated Sanctions List, UN Security Council Sanctions, INTERPOL, national lists).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningMethod rdf:type rdf:Property ;
    rdfs:label 'Screening Method' ;
    rdfs:comment 'Method used to perform the screening: automated system, manual review, or hybrid approach combining both.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this sanction screening event for audit trail and regulatory reporting purposes.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current lifecycle status of the screening record: completed (final disposition reached), in progress (screening underway), pending review (awaiting manual review), or expired (requires re-screening).' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Precise timestamp when the sanction screening was executed, including time zone information.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningTrigger rdf:type rdf:Property ;
    rdfs:label 'Screening Trigger' ;
    rdfs:comment 'Event or condition that triggered this sanction screening: new entity onboarding, periodic review, transaction threshold exceeded, regulatory watchlist update, or manual compliance request.' ;
    rdfs:domain ind:SanctionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryThirdEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Third Employee Id' ;
    rdfs:comment 'Identifier of the user who created this due diligence assessment record.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adverseMediaFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Flag' ;
    rdfs:comment 'Boolean flag indicating whether adverse media (negative news, legal issues, corruption allegations) was identified during the assessment.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adverseMediaSummary rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Summary' ;
    rdfs:comment 'Summary of adverse media findings, including sources and nature of concerns identified during screening.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'Date when the current approval expires and re-assessment is required.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessorDepartment rdf:type rdf:Property ;
    rdfs:label 'Assessor Department' ;
    rdfs:comment 'Department or business unit of the assessor (e.g., Legal, Compliance, Procurement, Risk Management).' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cybersecurityAssessmentResult rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Assessment Result' ;
    rdfs:comment 'Result of cybersecurity and data security assessment for third-parties with access to Travel Hospitality systems or guest data.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Data Processing Agreement Flag' ;
    rdfs:comment 'Boolean flag indicating whether a compliant Data Processing Agreement (DPA) is in place as required by GDPR Article 28.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataProcessorFlag rdf:type rdf:Property ;
    rdfs:label 'Data Processor Flag' ;
    rdfs:comment 'Boolean flag indicating whether the third-party acts as a data processor under GDPR Article 28, requiring specific contractual safeguards and assessments.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpaExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Dpa Execution Date' ;
    rdfs:comment 'Date when the Data Processing Agreement was executed with the third-party data processor.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDiligenceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this due diligence assessment for tracking and audit purposes.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStabilityRating rdf:type rdf:Property ;
    rdfs:label 'Financial Stability Rating' ;
    rdfs:comment 'Assessment of the third-party\'s financial stability and viability (excellent, good, fair, poor, not assessed).' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Verification Flag' ;
    rdfs:comment 'Boolean flag indicating whether required insurance coverage (liability, professional indemnity, cyber insurance) has been verified.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pepFlag rdf:type rdf:Property ;
    rdfs:label 'Pep Flag' ;
    rdfs:comment 'Boolean flag indicating whether the third-party or its principals are identified as Politically Exposed Persons (PEP), requiring enhanced due diligence.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationActions rdf:type rdf:Property ;
    rdfs:label 'Remediation Actions' ;
    rdfs:comment 'Description of specific remediation actions or corrective measures required to address identified risks or deficiencies.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Actual date when all required remediation actions were completed and verified.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether remediation actions or corrective measures are required before the third-party relationship can proceed or continue.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sanctionsListCheckResult rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Check Result' ;
    rdfs:comment 'Result of screening against international sanctions lists (OFAC, UN, EU) indicating whether the third-party or its principals appear on any sanctions list.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningResult rdf:type rdf:Property ;
    rdfs:label 'Screening Result' ;
    rdfs:comment 'Overall result of the due diligence screening (pass, fail, conditional approval, pending review).' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningCourseId rdf:type rdf:Property ;
    rdfs:label 'Learning Course Id' ;
    rdfs:comment 'Reference to the compliance training requirement that this completion record satisfies. Links to the training requirement master.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LearningCourse .

ind:loyaltyProgramConfigId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Config Id' ;
    rdfs:comment 'Foreign key linking to loyalty.program_config. Business justification: Compliance training on loyalty program rules (anti-fraud procedures, points liability accounting, tier qualification criteria) must reference which program configuration version the training covered. ' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramConfig .

ind:primaryComplianceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Employee Id' ;
    rdfs:comment 'Reference to the employee who completed the training. Links to the workforce employee master record.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryComplianceUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Compliance Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the system user or process that last modified this training completion record. Used for audit trail and change management.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Sequential number indicating which attempt this represents for the employee to complete this training requirement. First attempt is 1. Used to track retakes and learning effectiveness.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date on which the training certificate was officially issued. May differ from completion date for certifications requiring external validation. Null if no certificate issued.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate or credential number issued upon successful completion. Used for verification with regulatory bodies and external auditors. Null if no certificate issued.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Completion Record Number' ;
    rdfs:comment 'Business-facing unique identifier for the training completion record. Used for audit trails and external reporting to regulatory bodies.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Standardized code or identifier for the training course. Used for system integration and reporting consistency across properties.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseName rdf:type rdf:Property ;
    rdfs:label 'Course Name' ;
    rdfs:comment 'Full name of the compliance training course completed by the employee. Examples include Food Safety Certification, ADA Accessibility Training, Fire Safety Procedures.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the training was delivered to the employee. Online indicates e-learning; in_person indicates classroom; blended indicates combination; virtual_instructor_led indicates live remote; self_paced indicates asynchronous; on_the_job indicates practical training.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the instructor or facilitator who delivered the training. Null for self-paced or automated training. Used for quality tracking and instructor effectiveness analysis.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Code identifying the employees job role at the time of training completion. Used to track role-specific training compliance and identify training gaps by position.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether this training is mandatory for the employees role and location. True for required compliance training; false for optional professional development.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFailResult rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Result' ;
    rdfs:comment 'Outcome of the training assessment. Pass indicates successful completion; fail indicates unsuccessful attempt; incomplete indicates training started but not finished; waived indicates exemption from assessment.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment. Used to determine pass/fail result. Null if training does not have a scored assessment.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'High-level category of regulatory compliance that this training addresses. Used for compliance dashboard reporting and regulatory audit preparation by compliance domain. [ENUM-REF-CANDIDATE: health_safety|food_safety|data_privacy|accessibility|fire_safety|liquor_licensing|financial_compliance|hr_compliance|environmental|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'Number of months between required renewals for this training. Null if renewal is not required. Common values include 12, 24, 36 months depending on regulatory requirements.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this training requires periodic renewal. True for certifications that expire; false for one-time training. Used to trigger renewal workflows.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scoreAchieved rdf:type rdf:Property ;
    rdfs:label 'Score Achieved' ;
    rdfs:comment 'Numeric score or percentage achieved by the employee on the training assessment. Null if training does not include scored assessment. Range typically 0-100.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Training Cost Amount' ;
    rdfs:comment 'Total cost incurred for this training completion, including course fees, materials, instructor costs, and employee time. Used for training ROI analysis and budget tracking.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total number of hours the employee spent completing the training. Used for workforce planning, cost analysis, and regulatory reporting where contact hours are required.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the organization or vendor that provided the training. May be internal (company name) or external third-party provider. Important for audit and vendor management.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the compliance officer or manager who approved the training waiver. Null if no waiver granted. Required for audit trail.' ;
    rdfs:domain ind:ComplianceTrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWhistleblowerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Whistleblower Employee Id' ;
    rdfs:comment 'Identifier of the compliance officer or investigator assigned to review and investigate the report.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWhistleblowerLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Whistleblower Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the system user or process that last modified the whistleblower report record.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allegationCategory rdf:type rdf:Property ;
    rdfs:label 'Allegation Category' ;
    rdfs:comment 'Primary category of the allegation reported. [ENUM-REF-CANDIDATE: fraud|bribery|harassment|safety_violation|data_misuse|discrimination|retaliation|code_of_conduct_breach|theft|conflict_of_interest|environmental_violation|accounting_irregularity — promote to reference product]' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allegationDescription rdf:type rdf:Property ;
    rdfs:label 'Allegation Description' ;
    rdfs:comment 'Detailed narrative description of the allegation as reported by the whistleblower. Contains sensitive information about the reported incident.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allegationSubcategory rdf:type rdf:Property ;
    rdfs:label 'Allegation Subcategory' ;
    rdfs:comment 'Detailed subcategory or specific type of allegation within the primary category for granular classification and trend analysis.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Assigned Investigator Name' ;
    rdfs:comment 'Name of the compliance officer or investigator assigned to the case for tracking and accountability.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCommitteeNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Audit Committee Notification Date' ;
    rdfs:comment 'Date when the Audit Committee was formally notified about the whistleblower report.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCommitteeNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Committee Notified Flag' ;
    rdfs:comment 'Indicates whether the Board Audit Committee was notified about this report, typically for high-severity or financial misconduct cases (True/False).' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current status of the whistleblower case in the investigation lifecycle (received, under review, investigation opened, closed substantiated, closed unsubstantiated, closed no action required).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of corrective actions, disciplinary measures, or remediation steps taken as a result of the investigation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceLocation rdf:type rdf:Property ;
    rdfs:label 'Document Reference Location' ;
    rdfs:comment 'File path or document management system reference where supporting evidence and investigation documentation are stored.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocation rdf:type rdf:Property ;
    rdfs:label 'Incident Location' ;
    rdfs:comment 'Specific location within the property or business unit where the alleged incident occurred (department, floor, area).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationOutcome rdf:type rdf:Property ;
    rdfs:label 'Investigation Outcome' ;
    rdfs:comment 'Final outcome of the investigation (substantiated, unsubstantiated, partially substantiated, inconclusive, withdrawn by reporter).' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationSummary rdf:type rdf:Property ;
    rdfs:label 'Investigation Summary' ;
    rdfs:comment 'Executive summary of the investigation findings, actions taken, and conclusions reached. Contains sensitive investigation details.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryEscalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Escalation Required Flag' ;
    rdfs:comment 'Indicates whether the case requires escalation or reporting to external regulatory authorities (True) or can be handled internally (False).' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportChannel rdf:type rdf:Property ;
    rdfs:label 'Report Channel' ;
    rdfs:comment 'Channel through which the whistleblower report was submitted (hotline, web portal, email, in-person, mail, mobile app).' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'Date when the whistleblower report was received by the ethics hotline or compliance team. Principal business event timestamp for the report lifecycle.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Report Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the whistleblower report for tracking and case management purposes. Format: WB-YYYYMMDD-XXXXXX.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTime rdf:type rdf:Property ;
    rdfs:label 'Report Time' ;
    rdfs:comment 'Precise timestamp when the whistleblower report was submitted, including time zone information.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reporterAnonymityFlag rdf:type rdf:Property ;
    rdfs:label 'Reporter Anonymity Flag' ;
    rdfs:comment 'Indicates whether the whistleblower chose to remain anonymous (True) or provided identifying information (False).' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reporterContactMethod rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact Method' ;
    rdfs:comment 'Contact information provided by the reporter (email, phone, or callback code) for follow-up communication. Null if anonymous.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterName rdf:type rdf:Property ;
    rdfs:label 'Reporter Name' ;
    rdfs:comment 'Name of the individual who submitted the report, if not anonymous. Null if reporter chose anonymity.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterRelationship rdf:type rdf:Property ;
    rdfs:label 'Reporter Relationship' ;
    rdfs:comment 'Relationship of the reporter to the organization (employee, contractor, vendor, guest, former employee, other).' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retaliationConcernFlag rdf:type rdf:Property ;
    rdfs:label 'Retaliation Concern Flag' ;
    rdfs:comment 'Indicates whether the reporter expressed concerns about potential retaliation (True/False). Triggers additional monitoring and protection measures.' ;
    rdfs:domain ind:WhistleblowerReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date when the whistleblower report record is eligible for archival or deletion per records retention policy, typically 7 years from case closure.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attendeeId rdf:type rdf:Property ;
    rdfs:label 'Attendee Id' ;
    rdfs:comment 'Unique identifier for the event attendee record. Primary key.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Attendee .

ind:eventBookingId rdf:type rdf:Property ;
    rdfs:label 'Event Booking Id' ;
    rdfs:comment 'Reference to the parent event booking for which this attendee is registered. Links to the event booking header.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EventBooking .

ind:guestCommunicationId rdf:type rdf:Property ;
    rdfs:label 'Guest Communication Id' ;
    rdfs:comment 'Foreign key linking to marketing.guest_communication. Business justification: Event attendees receive pre-event confirmations, reminders, and post-event follow-ups via guest communication system. Essential for tracking communication delivery, engagement, and opt-out management.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestCommunication .

ind:guestFeedbackId rdf:type rdf:Property ;
    rdfs:label 'Guest Feedback Id' ;
    rdfs:comment 'Foreign key linking to experience.guest_feedback. Business justification: Event attendees provide post-event feedback surveys capturing satisfaction with meeting space, catering, service quality, and overall event experience. Properties track attendee-level NPS and CSAT sco' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestFeedback .

ind:spaAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Spa Appointment Id' ;
    rdfs:comment 'Foreign key linking to spa.appointment. Business justification: Event attendees book individual spa appointments during event stay. Critical for cross-sell revenue tracking, attendee experience management, and spa capacity planning around event dates. Real operati' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appointment .

ind:spaMembershipId rdf:type rdf:Property ;
    rdfs:label 'Spa Membership Id' ;
    rdfs:comment 'Foreign key linking to spa.membership. Business justification: Event attendees convert to spa members post-event. Key conversion funnel metric for marketing ROI analysis. Tracks which events drive membership acquisition, informing future event-spa package design ' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Membership .

ind:surveyResponseId rdf:type rdf:Property ;
    rdfs:label 'Survey Response Id' ;
    rdfs:comment 'Foreign key linking to marketing.survey_response. Business justification: Post-event satisfaction surveys are sent to attendees to measure event experience, NPS, and identify service recovery needs. Critical for event quality measurement, attendee satisfaction tracking, and' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveyResponse .

ind:accessibilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirements' ;
    rdfs:comment 'Description of any accessibility accommodations required by the attendee, such as wheelchair access, hearing assistance, visual aids, or service animal. Ensures ADA compliance.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendanceMode rdf:type rdf:Property ;
    rdfs:label 'Attendance Mode' ;
    rdfs:comment 'Mode of participation for the attendee: in-person (physical attendance), virtual (remote online participation), or hybrid (combination of both). Critical for capacity planning and platform provisioning.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badgeNumber rdf:type rdf:Property ;
    rdfs:label 'Badge Number' ;
    rdfs:comment 'Unique badge identifier assigned to the attendee for event access control and session tracking. Printed on physical badge or used as digital credential.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInStatus rdf:type rdf:Property ;
    rdfs:label 'Check In Status' ;
    rdfs:comment 'Current check-in status of the attendee at the event. Tracks whether attendee has arrived and collected their badge or credentials.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Date and time when the attendee checked in at the event registration desk or virtual platform. Null if not yet checked in.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'Date when the attendee registration was confirmed, typically after payment or approval. Null if not yet confirmed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataPrivacyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the attendee has provided explicit consent for data processing and storage in compliance with GDPR and CCPA. True if consent given, False otherwise.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dietaryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Dietary Restrictions' ;
    rdfs:comment 'Free-text description of attendee dietary requirements, allergies, or preferences for Food and Beverage (F&B) planning. Examples: vegetarian, vegan, gluten-free, kosher, halal, nut allergy.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for attendee communication, event confirmations, and virtual platform access credentials.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the emergency contact person for the attendee. Used in case of medical or safety incidents during the event.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the emergency contact person. Used for urgent communication in case of attendee emergency.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Free-text feedback comments provided by the attendee in post-event survey via Medallia. Used for service recovery and continuous improvement.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'First or given name of the event attendee as provided during registration.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Professional title or role of the attendee within their organization. Used for badge printing and attendee segmentation.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Last or family name of the event attendee as provided during registration.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Flag' ;
    rdfs:comment 'Boolean flag indicating whether the attendee has consented to receive marketing communications from the property or event organizer. True if opted in, False otherwise.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Net Promoter Score provided by the attendee in post-event survey, ranging from 0 (not likely to recommend) to 10 (extremely likely to recommend). Null if not provided.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Name of the company, institution, or organization the attendee represents. Used for badge printing and networking purposes.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment status of the registration fee. Tracks whether attendee has completed payment, is pending, or received a refund or waiver.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the attendee, used for event coordination and emergency contact.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the attendee completed their event registration. Used for early-bird pricing determination and registration pace analysis.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Registration Fee Amount' ;
    rdfs:comment 'Total registration fee charged to the attendee in the event currency. May vary based on registration type, early-bird pricing, or group discounts.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Registration Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the registration fee amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the attendee registration. Tracks progression from initial registration through confirmation, cancellation, or no-show.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Precise date and time when the attendee registration was submitted. Used for audit trail and registration sequence tracking.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Category of attendee registration indicating their role at the event. Determines access levels, pricing tier, and badge type.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Score' ;
    rdfs:comment 'Post-event satisfaction score provided by the attendee via Medallia survey. Typically on a scale of 1-10 or 1-5. Null if survey not completed.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionSelections rdf:type rdf:Property ;
    rdfs:label 'Session Selections' ;
    rdfs:comment 'Comma-separated list or JSON array of session identifiers that the attendee has pre-registered for. Used for capacity planning and personalized agenda management.' ;
    rdfs:domain ind:Attendee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Unique identifier of the attendee record in the source system. Used for reconciliation and bi-directional synchronization with Delphi by Amadeus or other event management platforms.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialRequests rdf:type rdf:Property ;
    rdfs:label 'Special Requests' ;
    rdfs:comment 'Free-text field capturing any additional special requests or notes from the attendee, such as seating preferences, networking interests, or other accommodations.' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualPlatformAccessGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Virtual Platform Access Granted Flag' ;
    rdfs:comment 'Boolean flag indicating whether the attendee has been provisioned with access credentials to the virtual event platform. True if access granted, False otherwise.' ;
    rdfs:domain ind:Attendee ;
