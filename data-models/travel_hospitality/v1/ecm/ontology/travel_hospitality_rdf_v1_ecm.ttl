    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inquiryId rdf:type rdf:Property ;
    rdfs:label 'Inquiry Id' ;
    rdfs:comment 'Unique identifier for the MICE inquiry or RFP. Primary key for the inquiry record.' ;
