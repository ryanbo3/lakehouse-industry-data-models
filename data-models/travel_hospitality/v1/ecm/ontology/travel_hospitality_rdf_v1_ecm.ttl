ind:reservationGroupBlockId rdf:type rdf:Property ;
    rdfs:label 'Reservation Group Block Id' ;
    rdfs:comment 'Foreign key linking to reservation.reservation_group_block. Business justification: MICE operations require linking event-side room block tracking to reservation system group blocks for real-time pickup monitoring, attrition calculation, and inventory reconciliation. Event coordinato' ;
