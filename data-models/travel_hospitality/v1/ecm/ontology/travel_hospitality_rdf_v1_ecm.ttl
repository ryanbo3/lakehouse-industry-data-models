    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inquiry .

ind:inquiringMemberId rdf:type rdf:Property ;
    rdfs:label 'Inquiring Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member. Business justification: Event inquiries frequently originate from loyalty members leveraging their status for group bookings. Sales teams reference member tier for pricing and concessions; loyalty members expect tier recogni' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:alternateDatesFlag rdf:type rdf:Property ;
    rdfs:label 'Alternate Dates Flag' ;
    rdfs:comment 'Indicates whether the client is flexible and willing to consider alternate dates for the event.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:avEquipmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Av Equipment Required Flag' ;
    rdfs:comment 'Indicates whether audio-visual equipment is required for the event.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:avEquipmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Av Equipment Requirements' ;
    rdfs:comment 'Detailed description of audio-visual equipment needs including projectors, screens, microphones, sound systems, and technical support.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget amounts (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:TravelHospitality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetRangeMax rdf:type rdf:Property ;
    rdfs:label 'Budget Range Max' ;
    rdfs:comment 'Maximum budget amount indicated by the prospective client for the entire event including rooms, function space, and catering.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetRangeMin rdf:type rdf:Property ;
    rdfs:label 'Budget Range Min' ;
    rdfs:comment 'Minimum budget amount indicated by the prospective client for the entire event including rooms, function space, and catering.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cateringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Catering Required Flag' ;
    rdfs:comment 'Indicates whether catering services (F&B) are required as part of the event.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
