    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Identifier of the guest involved in the incident, if applicable. Nullable for non-guest incidents.' ;
