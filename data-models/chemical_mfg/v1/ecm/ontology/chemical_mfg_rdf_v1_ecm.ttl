    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Work shift during which the batch was executed.' ;
    rdfs:domain ind:TrialBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialBatchStatus rdf:type rdf:Property ;
    rdfs:label 'Trial Batch Status' ;
    rdfs:comment 'Current lifecycle status of the trial batch.' ;
    rdfs:domain ind:TrialBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldDifferencePercent rdf:type rdf:Property ;
    rdfs:label 'Yield Difference Percent' ;
    rdfs:comment 'Difference between actual and target yield (actual – target).' ;
    rdfs:domain ind:TrialBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competingMarketSegments rdf:type rdf:Property ;
    rdfs:label 'Competing Market Segments' ;
    rdfs:comment 'Description of the end-market segments where the competitor is active and overlaps with Chemical Mfg\'s customer base (e.g., Automotive Coatings, Construction Adhesives, Electronics Encapsulants, Agricultural Crop Protection). Used for territory and segment-level competitive strategy.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Legal or commonly recognized trade name of the competitor organization (e.g., BASF SE, Dow Inc., Evonik Industries AG, Lanxess AG). Used as the primary human-readable identifier in sales negotiations and competitive positioning reports.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorStatus rdf:type rdf:Property ;
    rdfs:label 'Competitor Status' ;
    rdfs:comment 'Current lifecycle status of the competitor record: active (actively competing), inactive (no longer a competitive threat), acquired (absorbed by another entity), merged (combined with another company), dissolved (ceased operations), or monitoring (under observation for potential competitive entry).' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorType rdf:type rdf:Property ;
    rdfs:label 'Competitor Type' ;
    rdfs:comment 'Classification of the competitive relationship: direct (same product lines, same markets), indirect (substitute products or adjacent markets), potential (could enter our markets), distributor (resells competing products), or private_label (manufactures under customer brands). Drives competitive strategy prioritization.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Employee Count Estimate' ;
    rdfs:comment 'Estimated total global headcount of the competitor organization. Sourced from public filings, LinkedIn data, or industry reports. Used as a proxy for operational scale and R&D capacity in competitive assessments.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedRevenueYear rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Year' ;
    rdfs:comment 'The fiscal year (four-digit integer, e.g., 2023) to which the estimated_annual_revenue_usd figure corresponds. Ensures temporal accuracy when comparing revenue data across competitors with different fiscal year-end dates.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Scope of the competitor\'s geographic market presence: global (operations across multiple continents), regional (multi-country within a region), national (single country), local (sub-national), or unknown. Used for territory-level competitive threat assessment.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code representing the country where the competitor\'s global headquarters is registered (e.g., DEU for Germany, USA for United States, CHN for China). Used for geopolitical risk assessment and trade compliance screening.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersRegion rdf:type rdf:Property ;
    rdfs:label 'Headquarters Region' ;
    rdfs:comment 'Geographic region of the competitor\'s global headquarters used for regional competitive analysis and territory management (e.g., North America, Europe, Asia Pacific, Middle East and Africa, Latin America). [ENUM-REF-CANDIDATE: north_america|europe|asia_pacific|middle_east_africa|latin_america|greater_china — promote to reference product]' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceSource rdf:type rdf:Property ;
    rdfs:label 'Intelligence Source' ;
    rdfs:comment 'Primary source from which competitive intelligence for this record was gathered. [ENUM-REF-CANDIDATE: public_filing|industry_report|customer_feedback|sales_team|trade_show|win_loss_interview|market_research|distributor_feedback|regulatory_database — promote to reference product]' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPubliclyTraded rdf:type rdf:Property ;
    rdfs:label 'Is Publicly Traded' ;
    rdfs:comment 'Indicates whether the competitor is a publicly listed company on a recognized stock exchange. True enables linkage to public financial disclosures; False indicates private, state-owned, or subsidiary status.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the competitor holds a current ISO 14001 Environmental Management System certification. Relevant for sustainability-driven customer procurement decisions and competitive positioning in environmentally regulated markets.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the competitor holds a current ISO 9001 Quality Management System certification. Relevant for customer qualification requirements and competitive differentiation in quality-sensitive markets such as automotive and electronics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:knownStrengths rdf:type rdf:Property ;
    rdfs:label 'Known Strengths' ;
    rdfs:comment 'Narrative description of the competitor\'s recognized competitive advantages such as proprietary chemistry, manufacturing scale, regulatory approvals (REACH, TSCA), distribution network breadth, technical service capabilities, or brand equity. Informs sales battle cards and technical sales positioning.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownWeaknesses rdf:type rdf:Property ;
    rdfs:label 'Known Weaknesses' ;
    rdfs:comment 'Narrative description of the competitor\'s recognized vulnerabilities such as supply chain constraints, limited product range, regulatory non-compliance gaps, quality issues (OOS/OOT history), poor technical service, or geographic coverage gaps. Used to identify win opportunities in competitive sales situations.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCompetitiveEncounterDate rdf:type rdf:Property ;
    rdfs:label 'Last Competitive Encounter Date' ;
    rdfs:comment 'Date of the most recent sales opportunity in which this competitor was identified as a competing party. Used to assess recency of competitive activity and prioritize intelligence refresh efforts. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastIntelligenceRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Last Intelligence Refresh Date' ;
    rdfs:comment 'Date on which the competitive intelligence record was last reviewed and updated by the responsible sales or marketing team member. Used to identify stale records requiring refresh. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full registered legal name of the competitor as filed with the relevant corporate registry or regulatory authority. May differ from the trade name used commercially.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSiteCount rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Count' ;
    rdfs:comment 'Estimated number of active manufacturing facilities operated globally by the competitor. Indicates production capacity scale and geographic manufacturing footprint relevant to supply chain competitive analysis.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCompanyName rdf:type rdf:Property ;
    rdfs:label 'Parent Company Name' ;
    rdfs:comment 'Name of the ultimate parent or controlling entity if the competitor is a subsidiary or division (e.g., Covestro is a subsidiary of Bayer AG). Supports corporate hierarchy analysis and M&A tracking in competitive intelligence.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingPosture rdf:type rdf:Property ;
    rdfs:label 'Pricing Posture' ;
    rdfs:comment 'Characterization of the competitor\'s general pricing strategy relative to market: premium (above-market pricing with differentiation), parity (market-rate pricing), discount (below-market pricing), aggressive_discount (significantly below market, potentially predatory), or value_based (pricing tied to customer outcome metrics). Critical input for sales negotiation strategy and RFQ response pricing.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductLines rdf:type rdf:Property ;
    rdfs:label 'Primary Product Lines' ;
    rdfs:comment 'Comma-separated or free-text description of the competitor\'s primary product lines that directly compete with Chemical Mfg\'s portfolio (e.g., Polyurethane Dispersions, Epoxy Resins, Acrylic Monomers, Agricultural Fungicides). Supports product-level competitive mapping in Salesforce CRM opportunity management.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdInvestmentIntensity rdf:type rdf:Property ;
    rdfs:label 'Rd Investment Intensity' ;
    rdfs:comment 'Qualitative assessment of the competitor\'s R&D investment level relative to industry peers: high (>5% of revenue), medium (2-5% of revenue), low (<2% of revenue), or unknown. Indicates innovation pipeline threat and likelihood of new competing product introductions.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Status' ;
    rdfs:comment 'Status of the competitor\'s compliance with EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) regulation for their competing substances. Indicates whether competing products are REACH-registered, pre-registered, exempt, or status is unknown. Relevant for EU market competitive positioning.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCareMember rdf:type rdf:Property ;
    rdfs:label 'Responsible Care Member' ;
    rdfs:comment 'Indicates whether the competitor is a member of the American Chemistry Council (ACC) Responsible Care program or equivalent national chemical industry responsible care initiative. Membership signals commitment to EHS standards and may influence customer procurement preferences.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockTicker rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker' ;
    rdfs:comment 'Exchange-listed stock ticker symbol for publicly traded competitors (e.g., BASF.DE, DOW, EVK.DE). Used to link to financial market data for revenue benchmarking and financial health monitoring. Null for privately held competitors.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatLevel rdf:type rdf:Property ;
    rdfs:label 'Threat Level' ;
    rdfs:comment 'Sales team\'s assessed competitive threat level for this competitor: critical (major threat to core business), high (significant competitive overlap), medium (moderate overlap in select segments), low (minimal current overlap), or watch (emerging threat requiring monitoring). Drives sales resource allocation and battle card prioritization.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOpportunitiesCompeted rdf:type rdf:Property ;
    rdfs:label 'Total Opportunities Competed' ;
    rdfs:comment 'Total count of sales opportunities in Salesforce CRM where this competitor was identified as a competing party, over the trailing 12-month period. Provides the denominator context for win_rate_pct and indicates competitive encounter frequency.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tscaComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliance Status' ;
    rdfs:comment 'Assessment of the competitor\'s compliance posture with the US Toxic Substances Control Act (TSCA) for their competing chemical substances. Non-compliant or partial status may represent a competitive advantage for Chemical Mfg in US market sales negotiations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Primary public website URL of the competitor organization. Used as a reference for product catalog research, SDS/MSDS document retrieval, regulatory compliance verification, and ongoing competitive intelligence gathering.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winRatePct rdf:type rdf:Property ;
    rdfs:label 'Win Rate Pct' ;
    rdfs:comment 'Percentage of competitive sales opportunities where Chemical Mfg won against this specific competitor, calculated over the trailing 12-month period. Expressed as a decimal percentage (e.g., 62.50 = 62.5%). Sourced from Salesforce CRM closed opportunity records. Supports sales performance KPI reporting.' ;
    rdfs:domain ind:Competitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesforceAccountId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Id' ;
    rdfs:comment 'Salesforce CRM Account record identifier for this distributor. Enables cross-system traceability between the lakehouse silver layer distributor master and the Salesforce CRM system of record for opportunity and activity management.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:agreementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Effective Date' ;
    rdfs:comment 'Calendar date on which the distribution agreement becomes legally binding and commercially effective. Marks the start of authorized distribution rights and contractual obligations.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Expiry Date' ;
    rdfs:comment 'Calendar date on which the distribution agreement expires or is scheduled to terminate. Null indicates an open-ended agreement. Used for renewal tracking and compliance monitoring.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualPurchaseCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Purchase Commitment' ;
    rdfs:comment 'Contractually agreed minimum annual purchase value (in agreement currency) that the distributor commits to purchasing from Chemical Mfg. Used for rebate tier qualification and agreement compliance monitoring.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Authorized Product Categories' ;
    rdfs:comment 'Comma-separated list of product categories or chemical product lines that the distributor is contractually authorized to sell under the distribution agreement (e.g., \'Specialty Solvents,Performance Coatings,Agricultural Intermediates\'). Enforced during order processing in SAP SD.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the distribution agreement automatically renews upon expiry unless explicitly terminated. True = auto-renews; False = requires affirmative renewal action.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit and financial terms are denominated (e.g., USD, EUR, GBP). Aligns with the agreement currency for consistent financial reporting.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorCode rdf:type rdf:Property ;
    rdfs:label 'Distributor Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the distributor in SAP SD / Salesforce CRM. Used on purchase orders, invoices, and channel communications as the canonical reference code.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorStatus rdf:type rdf:Property ;
    rdfs:label 'Distributor Status' ;
    rdfs:comment 'Current lifecycle status of the distributor master record. Active = approved and trading; Suspended = temporarily blocked (e.g., compliance hold); Pending Approval = onboarding in progress; Terminated = agreement ended.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorTier rdf:type rdf:Property ;
    rdfs:label 'Distributor Tier' ;
    rdfs:comment 'Commercial tier classification of the distributor based on sales volume, strategic importance, and service level. Drives rebate eligibility, pricing tiers, and support resource allocation. Tier 1 = highest volume/strategic; Tier 3 = emerging/low volume.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorType rdf:type rdf:Property ;
    rdfs:label 'Distributor Type' ;
    rdfs:comment 'Classification of the distributor relationship type. Exclusive distributors hold sole rights in a territory; master distributors may appoint sub-distributors; agents act on behalf without taking title to goods.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsClassificationAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Ghs Classification Acknowledged' ;
    rdfs:comment 'Indicates whether the distributor has formally acknowledged receipt and understanding of GHS hazard classification and labelling requirements for all authorized product categories. Required for EHS compliance onboarding.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqKg rdf:type rdf:Property ;
    rdfs:label 'Moq Kg' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) in kilograms that the distributor must place per order under the distribution agreement. Enforced in SAP SD order entry to ensure commercial viability of each transaction.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateStructureCode rdf:type rdf:Property ;
    rdfs:label 'Rebate Structure Code' ;
    rdfs:comment 'Reference code identifying the rebate or volume incentive program applicable to this distributor as defined in the SAP SD rebate agreement. Determines the rebate calculation method, thresholds, and payout schedule.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to agreement expiry by which either party must provide written notice of non-renewal or termination. Contractually mandated and used to trigger renewal workflow alerts.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleDistributionCertified rdf:type rdf:Property ;
    rdfs:label 'Responsible Distribution Certified' ;
    rdfs:comment 'Indicates whether the distributor holds current certification under the National Association of Chemical Distributors (NACD) Responsible Distribution program, demonstrating commitment to EHS, security, and product stewardship standards.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsDistributionObligation rdf:type rdf:Property ;
    rdfs:label 'Sds Distribution Obligation' ;
    rdfs:comment 'Indicates whether the distributor is contractually and regulatory obligated to distribute Safety Data Sheets (SDS) to downstream customers per GHS/OSHA HazCom 2012 requirements. True = obligated; False = exempt (e.g., agent not taking title).' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued Tax Identification Number (TIN) or VAT registration number of the distributor legal entity. Required for invoicing, customs documentation, and tax compliance reporting.' ;
    rdfs:domain ind:Distributor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Geographic territory or market scope authorized under the distribution agreement, expressed as country codes (ISO 3166-1 alpha-3), regions, or named market segments (e.g., \'USA,CAN,MEX\' or \'EMEA-Industrial\'). Defines the boundaries of authorized distribution.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorAgreementId rdf:type rdf:Property ;
    rdfs:label 'Distributor Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for the distributor agreement record in the Chemical Mfg lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crmOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Id' ;
    rdfs:comment 'Salesforce CRM opportunity or contract record identifier that originated or is linked to this distributor agreement. Enables traceability from sales pipeline to executed agreement.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:salesOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Id' ;
    rdfs:comment 'Reference to the Chemical Mfg sales organization responsible for managing and executing this distributor agreement, as defined in SAP SD organizational structure.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrganization .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the distributor agreement. Draft: under negotiation; Active: fully executed and binding; Suspended: temporarily halted (e.g., compliance breach); Terminated: ended before natural expiry; Expired: reached end date without renewal.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementVersion rdf:type rdf:Property ;
    rdfs:label 'Agreement Version' ;
    rdfs:comment 'Sequential version number of the distributor agreement, incremented each time the agreement is formally amended (e.g., price renegotiation, territory expansion, MOQ revision). Version 1 is the original executed agreement.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Free-text description of the most recent amendment to this distributor agreement, summarizing the key changes made (e.g., \'Territory expanded to include CAN; MOQ increased to USD 500,000\'). Supports audit trail and Management of Change (MOC) documentation.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Maximum outstanding accounts receivable credit extended to the distributor under this agreement, denominated in USD. Enforced in SAP SD credit management (FD32) to control financial exposure.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving disputes arising under this distributor agreement: arbitration (binding third-party arbitration), litigation (court proceedings), mediation (non-binding third-party mediation), or negotiation (direct party negotiation).' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsTrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Ehs Training Required' ;
    rdfs:comment 'Indicates whether distributor personnel are required to complete Chemical Mfg-mandated EHS (Environment Health and Safety) training on product handling, storage, and emergency response as a condition of this agreement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Defines the breadth of exclusivity granted to the distributor within the authorized territory: full_portfolio (all Chemical Mfg products), product_category (specific product categories only), single_product (one product or SKU), or none (non-exclusive arrangement).' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern interpretation and enforcement of this distributor agreement (e.g., USA, DEU, GBR). Critical for dispute resolution and regulatory compliance.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqAnnualUsd rdf:type rdf:Property ;
    rdfs:label 'Moq Annual Usd' ;
    rdfs:comment 'Minimum annual purchase commitment in US dollars that the distributor must achieve to maintain agreement terms and qualify for contracted pricing and rebates. Failure to meet MOQ may trigger agreement renegotiation or termination. Aligns with SAP SD minimum order value configuration.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productApplicationSupport rdf:type rdf:Property ;
    rdfs:label 'Product Application Support' ;
    rdfs:comment 'Indicates whether Chemical Mfg provides technical sales and product application guidance support to the distributor under this agreement, including customer-specific formulation assistance and technical documentation.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachDownstreamReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Reach Downstream Reporting Required' ;
    rdfs:comment 'Indicates whether the distributor must fulfill REACH downstream user reporting obligations, including use notifications and exposure scenario communication, as required under ECHA REACH Regulation (EC) No 1907/2006 Title V.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebateRatePct rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate Pct' ;
    rdfs:comment 'Base rebate percentage (0.00–100.00) applied to eligible purchases under this agreement. For volume_tiered structures, this represents the base tier rate; tier thresholds are managed in the rebate schedule. Stored in SAP SD rebate agreement condition records.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateStructureType rdf:type rdf:Property ;
    rdfs:label 'Rebate Structure Type' ;
    rdfs:comment 'Classification of the rebate mechanism applicable to this distributor agreement: volume_tiered (rebate percentage increases with purchase volume tiers), flat_rate (fixed percentage on all purchases), growth_incentive (rebate tied to year-over-year growth targets), or none (no rebate applicable).' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date by which a renewal decision must be made or the agreement auto-renews. Drives CRM (Salesforce) renewal opportunity creation and account manager notifications.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleCareComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Responsible Care Compliance Required' ;
    rdfs:comment 'Indicates whether the distributor is contractually required to adhere to the ACC (American Chemistry Council) Responsible Care program standards as a condition of this distribution agreement.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'SAP S/4HANA SD contract document number (transaction VA41/VA42) corresponding to this distributor agreement. Used for cross-system reconciliation between the CRM pipeline and ERP order management.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDistributionRequired rdf:type rdf:Property ;
    rdfs:label 'Sds Distribution Required' ;
    rdfs:comment 'Indicates whether the distributor is contractually obligated to distribute Safety Data Sheets (SDS) to downstream customers for all chemical products sold under this agreement. Mandatory under GHS, REACH, and OSHA HazCom 2012 (29 CFR 1910.1200).' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date on which both parties executed (signed) the distributor agreement. May differ from effective_date when agreements are backdated or post-dated.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:territoryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code representing the primary country of the authorized distribution territory. Used for REACH downstream user reporting and EPA/TSCA jurisdictional compliance tracking.' ;
    rdfs:domain ind:DistributorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'The actual date on which the opportunity was closed (won or lost). Populated upon opportunity closure. Used for sales cycle analysis, win/loss reporting, and period attribution. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationSegment rdf:type rdf:Property ;
    rdfs:label 'Application Segment' ;
    rdfs:comment 'The end-use application or industry segment for which the chemical product is being evaluated (e.g., Automotive Coatings, Electronics Manufacturing, Construction Adhesives, Consumer Goods). Supports technical sales targeting and market segmentation analytics.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Close Probability Pct' ;
    rdfs:comment 'Estimated probability (0.00–100.00%) that this opportunity will be won, as assessed by the sales representative or derived from stage-based defaults. Used in weighted pipeline calculations and revenue forecasting models.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeReason rdf:type rdf:Property ;
    rdfs:label 'Close Reason' ;
    rdfs:comment 'Structured reason code explaining why the opportunity was won or lost. Captures the primary decision criterion at closure. Used for competitive intelligence, win/loss analysis, and sales strategy refinement. [ENUM-REF-CANDIDATE: Price|Technical Fit|Relationship|Competitor|Timeline|Budget|No Decision|Other — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedAmount rdf:type rdf:Property ;
    rdfs:label 'Closed Amount' ;
    rdfs:comment 'Actual deal value at the time of opportunity closure (won or lost). May differ from estimated_amount due to negotiation, scope changes, or competitive pricing adjustments. Used for win/loss revenue analysis and competitive intelligence.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Code' ;
    rdfs:comment 'Native opportunity identifier from Salesforce CRM (e.g., 006XXXXXXXXXXXXXXX). Used for cross-system traceability and reconciliation with the source system of record.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionCriteria rdf:type rdf:Property ;
    rdfs:label 'Decision Criteria' ;
    rdfs:comment 'Free-text or structured description of the customer\'s primary evaluation criteria for this opportunity (e.g., price, technical performance, regulatory compliance, delivery reliability, sustainability). Supports win/loss analysis and sales strategy development.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Amount' ;
    rdfs:comment 'Estimated total deal value (revenue) for this opportunity in the transaction currency. Represents the gross revenue expected if the opportunity is won. Used for pipeline valuation, quota tracking, and revenue forecasting. Aligns with SAP SD pricing and SAP FI/CO revenue planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedVolumeKg rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume Kg' ;
    rdfs:comment 'Estimated annual or deal-period volume of chemical product(s) in kilograms associated with this opportunity. Used for supply chain capacity planning, raw material procurement forecasting, and production scheduling alignment with SAP PP.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter in which the opportunity is expected to close, formatted as Q[1-4]-YYYY (e.g., Q3-2024). Used for period-based pipeline reporting, quota attainment tracking, and financial forecasting aligned with SAP FI/CO fiscal calendar.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKeyAccount rdf:type rdf:Property ;
    rdfs:label 'Is Key Account' ;
    rdfs:comment 'Indicates whether this opportunity is associated with a strategically designated key account (True) requiring executive sponsorship, dedicated account management, and priority resource allocation. Used for key account management reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWon rdf:type rdf:Property ;
    rdfs:label 'Is Won' ;
    rdfs:comment 'Boolean flag indicating whether the opportunity was closed as won (True) or lost/abandoned (False). Null if the opportunity is still open. Used for win rate calculations and pipeline conversion reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent sales activity (call, email, meeting, task) logged against this opportunity in Salesforce CRM. Used for pipeline hygiene monitoring, stale opportunity identification, and sales rep engagement tracking. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Free-text description of the immediate next action required to advance this opportunity (e.g., \'Schedule technical demo\', \'Submit COA for customer qualification\', \'Negotiate pricing terms\'). Used by sales representatives for pipeline management and CRM activity tracking.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityDescription rdf:type rdf:Property ;
    rdfs:label 'Opportunity Description' ;
    rdfs:comment 'Free-text narrative describing the opportunity context, customer requirements, technical application details, and strategic importance. Supports sales team knowledge sharing and opportunity review meetings.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Human-readable name or title of the sales opportunity, typically describing the customer, product line, and deal context (e.g., \'Acme Corp - Specialty Solvents Q3 2024\'). Used for pipeline reporting and sales team communication.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity by business development type. Distinguishes new customer acquisition from expansion of existing accounts, contract renewals, win-back of lost customers, and channel type (distributor vs. direct). [ENUM-REF-CANDIDATE: New Business|Existing Business Expansion|Renewal|Win-Back|Distributor|Direct — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCustomFormulation rdf:type rdf:Property ;
    rdfs:label 'Requires Custom Formulation' ;
    rdfs:comment 'Indicates whether this opportunity requires a customer-specific chemical formulation or product development engagement (True) versus a standard catalogue product (False). Triggers R&D and technical sales involvement when True.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSds rdf:type rdf:Property ;
    rdfs:label 'Requires Sds' ;
    rdfs:comment 'Indicates whether the customer has requested or requires a Safety Data Sheet (SDS) / Material Safety Data Sheet (MSDS) as part of the sales process. Relevant for GHS compliance and REACH regulatory submissions.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The commercial channel through which this opportunity is being pursued. Distinguishes direct sales from distributor-mediated, agent-based, e-commerce, or tender/bid processes. Used for channel performance analytics and margin analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage of the opportunity in the sales pipeline lifecycle. Drives pipeline forecasting, stage-gate reviews, and funnel conversion analytics. [ENUM-REF-CANDIDATE: Prospecting|Qualification|Needs Analysis|Proposal|Negotiation|Closed Won|Closed Lost — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCloseDate rdf:type rdf:Property ;
    rdfs:label 'Target Close Date' ;
    rdfs:comment 'Expected date by which the opportunity will be won or lost. Drives pipeline aging analysis, period-end forecasting, and sales cycle duration reporting. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualVolumeEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Estimate' ;
    rdfs:comment 'Estimated annual purchase volume for this product line, expressed in the quantity UOM. Supports long-term demand forecasting, supply chain planning, and volume-based pricing negotiations.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationEndUse rdf:type rdf:Property ;
    rdfs:label 'Application End Use' ;
    rdfs:comment 'Specific end-use application or industry segment for which the customer intends to use this chemical product (e.g., automotive coatings, agricultural formulation, electronic cleaning). Critical for REACH downstream user notifications and technical sales support.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Expected or actual date on which this product line within the opportunity is anticipated to be won or lost. Used for pipeline aging analysis and sales forecast period alignment.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveStatus rdf:type rdf:Property ;
    rdfs:label 'Competitive Status' ;
    rdfs:comment 'Describes the competitive landscape for this product line within the opportunity. Indicates whether Chemical Mfg is the sole supplier, competing against others, defending incumbent business, or attempting to displace a competitor.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmOpportunityProductCode rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Product Code' ;
    rdfs:comment 'External identifier for this opportunity-product line as recorded in Salesforce CRM (OpportunityLineItem ID). Used for cross-system reconciliation between CRM and SAP SD.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Estimated number of calendar days from order placement to delivery for this product line, used in customer negotiations and supply chain planning.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountPct rdf:type rdf:Property ;
    rdfs:label 'Discount Pct' ;
    rdfs:comment 'Percentage discount offered on the list price for this product line as part of the commercial negotiation. Supports margin analysis and pricing governance.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity' ;
    rdfs:comment 'Estimated volume or quantity of the chemical product the customer intends to purchase within the opportunity period. Used for demand forecasting and production planning.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue' ;
    rdfs:comment 'Total estimated revenue for this product line within the opportunity, calculated as estimated quantity multiplied by unit price. Represents the gross revenue potential before discounts.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstShipmentDate rdf:type rdf:Property ;
    rdfs:label 'First Shipment Date' ;
    rdfs:comment 'Anticipated date of the first product shipment if the opportunity is won. Used for production scheduling, raw material procurement planning, and customer commitment management.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formulationRequired rdf:type rdf:Property ;
    rdfs:label 'Formulation Required' ;
    rdfs:comment 'Indicates whether this opportunity product line requires a customer-specific formulation or blending service rather than a standard catalog product. Triggers engagement with R&D and formulation teams.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Published or standard list price per unit of measure for this chemical product before any negotiated discounts or customer-specific pricing adjustments.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'Minimum order quantity required for this chemical product, expressed in the quantity UOM. Communicated to the customer during opportunity negotiation to set commercial expectations.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opportunityProductStatus rdf:type rdf:Property ;
    rdfs:label 'Opportunity Product Status' ;
    rdfs:comment 'Current lifecycle status of this specific product line within the opportunity. Allows individual product lines to be won, lost, or withdrawn independently of the overall opportunity status.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityWeightedRevenue rdf:type rdf:Property ;
    rdfs:label 'Probability Weighted Revenue' ;
    rdfs:comment 'Estimated revenue for this product line adjusted by the win probability percentage. Used for pipeline valuation, sales forecasting, and revenue planning at the product level.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesStage rdf:type rdf:Property ;
    rdfs:label 'Sales Stage' ;
    rdfs:comment 'Current sales pipeline stage for this product line, which may differ from the parent opportunity stage when individual products are at different negotiation phases. [ENUM-REF-CANDIDATE: prospecting|qualification|needs_analysis|proposal|negotiation|closed_won|closed_lost — promote to reference product]' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequested rdf:type rdf:Property ;
    rdfs:label 'Sample Requested' ;
    rdfs:comment 'Indicates whether the customer has requested a product sample for evaluation or qualification testing as part of this opportunity. Triggers sample order creation in SAP SD.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapSdItemNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Item Number' ;
    rdfs:comment 'SAP SD quotation or sales order item number corresponding to this product line, used for traceability from opportunity to formal quote or order in SAP S/4HANA.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Technical Review Required' ;
    rdfs:comment 'Indicates whether this product line requires a technical review by the applications engineering or R&D team before a formal proposal can be submitted to the customer.' ;
    rdfs:domain ind:OpportunityProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tscaCompliant rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliant' ;
    rdfs:comment 'Indicates whether this chemical product is listed on the TSCA Chemical Substance Inventory and compliant for commercial sale in the United States.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:winProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Win Probability Pct' ;
    rdfs:comment 'Estimated probability (0–100%) that this specific product line will be won, which may differ from the overall opportunity win probability when the customer is evaluating multiple products independently.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name or title of the pricing agreement as referenced internally and in customer negotiations (e.g., \'FY2025 Polyethylene Supply Agreement - Acme Corp\').' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Commitment' ;
    rdfs:comment 'The total annual volume the customer has committed to purchase under this agreement, expressed in the price UOM. Used to validate volume rebate eligibility and supply planning. Corresponds to long-term supply agreement volume commitments.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Base Unit Price' ;
    rdfs:comment 'The negotiated base price per unit of measure for the primary product or grade covered by this agreement, expressed in the agreement currency. For volume-rebate agreements, this represents the list price before rebate calculation.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationFrequency rdf:type rdf:Property ;
    rdfs:label 'Escalation Frequency' ;
    rdfs:comment 'Frequency at which price escalation reviews and adjustments are performed under the escalation clause. Null if no escalation clause applies.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationIndex rdf:type rdf:Property ;
    rdfs:label 'Escalation Index' ;
    rdfs:comment 'Name or code of the external index used to calculate price escalations under the escalation clause (e.g., \'ICIS Ethylene Index\', \'US CPI\', \'Henry Hub Natural Gas\', \'Platts Benzene\'). Null if no escalation clause applies.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port associated with the Incoterms code (e.g., \'Houston, TX\' for FOB Houston). Required by Incoterms 2020 to complete the delivery term specification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of calendar days\' advance notice required by either party to terminate or not renew this pricing agreement. Critical for supply chain continuity planning and customer retention management.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceEscalationClause rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Clause' ;
    rdfs:comment 'Indicates whether the agreement contains a price escalation clause allowing periodic price adjustments based on raw material indices, energy costs, or inflation benchmarks (e.g., CPI, feedstock index). True = escalation clause present.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerQty rdf:type rdf:Property ;
    rdfs:label 'Price Per Qty' ;
    rdfs:comment 'The quantity denominator for the unit price (e.g., price per 100 KG, price per 1000 LB). Corresponds to SAP SD condition pricing quantity (KONP.KPEIN). Enables accurate per-unit price calculation when price is expressed per batch or bulk quantity.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePct rdf:type rdf:Property ;
    rdfs:label 'Rebate Pct' ;
    rdfs:comment 'Retrospective volume rebate percentage applied to the customer\'s total purchases when volume thresholds are met. Expressed as a percentage of net sales value. Applicable for volume rebate agreement types. Null for contract price agreements.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateThresholdQty rdf:type rdf:Property ;
    rdfs:label 'Rebate Threshold Qty' ;
    rdfs:comment 'Minimum cumulative purchase quantity (in volume_commitment_uom) the customer must reach within the agreement period to qualify for the rebate percentage. Used in volume rebate agreement types.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Defines how the pricing agreement is renewed at expiry. Auto Renew = automatically extends for the same term unless cancelled; Manual Renew = requires explicit renegotiation; No Renewal = single-term agreement with no renewal provision.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapConditionContractNo rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Contract No' ;
    rdfs:comment 'The SAP SD condition contract number (KONA.KNUMA_AG) that is the system-of-record identifier for this pricing agreement in SAP S/4HANA. Enables traceability back to the operational source system.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Sales territory code identifying the geographic or account-based territory to which this pricing agreement is assigned. Used for territory management, sales performance reporting, and commission calculations in Salesforce CRM.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentUom rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Uom' ;
    rdfs:comment 'Unit of measure for the annual volume commitment quantity (e.g., MT = metric ton, KG = kilogram). May differ from price UOM for large-volume chemical supply agreements. [ENUM-REF-CANDIDATE: KG|MT|LB|L|GAL|EA|BAG|DR|IBC — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Agreed Unit Price' ;
    rdfs:comment 'Negotiated price per unit of measure for the chemical product on this pricing line. Represents the base contractual price before surcharges, rebates, or volume discounts are applied.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Condition Type Code' ;
    rdfs:comment 'SAP SD pricing condition type code identifying the nature of the pricing condition on this line (e.g., PR00 for base price, ZK01 for customer-specific price, RA01 for rebate). Drives pricing determination in SAP SD.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeSpecification rdf:type rdf:Property ;
    rdfs:label 'Grade Specification' ;
    rdfs:comment 'Chemical product grade or specification qualifier for this pricing line (e.g., \'Technical Grade\', \'Reagent Grade\', \'Food Grade\', \'Pharmaceutical Grade\'). Differentiates pricing for the same base chemical at different purity or quality levels.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexAdjustmentFormula rdf:type rdf:Property ;
    rdfs:label 'Index Adjustment Formula' ;
    rdfs:comment 'Description or formula defining how the price index is applied to adjust the agreed unit price (e.g., \'Base price + 0.85 * (current month ICIS ethylene - reference ethylene price)\'). Captures the contractual price escalation mechanism.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceIndexLinked rdf:type rdf:Property ;
    rdfs:label 'Price Index Linked' ;
    rdfs:comment 'Indicates whether the agreed unit price on this line is linked to a commodity or raw material price index (e.g., ethylene cracker margin, benzene spot price, crude oil index). Common in long-term chemical supply contracts.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceIndexName rdf:type rdf:Property ;
    rdfs:label 'Price Index Name' ;
    rdfs:comment 'Name or code of the commodity or raw material price index to which this pricing line is linked (e.g., \'ICIS Ethylene NWE\', \'Platts Benzene FOB Korea\', \'WTI Crude Oil\'). Populated only when price_index_linked is true.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerQuantity rdf:type rdf:Property ;
    rdfs:label 'Price Per Quantity' ;
    rdfs:comment 'The quantity base (denominator) for the agreed unit price, indicating how many units the price applies to (e.g., price per 1 KG, price per 100 KG, price per 1000 L). Corresponds to SAP SD condition pricing unit (KPEIN).' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateBasis rdf:type rdf:Property ;
    rdfs:label 'Rebate Basis' ;
    rdfs:comment 'The calculation basis on which the rebate percentage is applied: invoice value, net sales value, volume in kilograms, or volume in metric tons. Determines how rebate accruals are computed in SAP SD.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebatePercent rdf:type rdf:Property ;
    rdfs:label 'Rebate Percent' ;
    rdfs:comment 'Percentage rebate to be credited back to the customer on purchases of this product line, typically settled periodically (monthly, quarterly, annually). Supports SAP SD rebate agreement processing.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surchargePercent rdf:type rdf:Property ;
    rdfs:label 'Surcharge Percent' ;
    rdfs:comment 'Percentage-based surcharge applied to the agreed unit price for this line. Used when the surcharge is calculated as a proportion of the base price (e.g., 2.5% raw material index surcharge).' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:takeOrPayFlag rdf:type rdf:Property ;
    rdfs:label 'Take Or Pay Flag' ;
    rdfs:comment 'Indicates whether this pricing line is subject to a take-or-pay clause, requiring the customer to purchase the committed volume or pay a penalty for the shortfall. Common in long-term chemical feedstock agreements.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tier1MinQty rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Min Qty' ;
    rdfs:comment 'Minimum order quantity threshold for the first volume break tier. Orders at or above this quantity qualify for the Tier 1 discounted unit price.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1UnitPrice rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Unit Price' ;
    rdfs:comment 'Agreed unit price applicable when the order quantity meets or exceeds the Tier 1 minimum quantity threshold. Represents the first volume discount price break.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2MinQty rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Min Qty' ;
    rdfs:comment 'Minimum order quantity threshold for the second volume break tier. Orders at or above this quantity qualify for the Tier 2 discounted unit price.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2UnitPrice rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Unit Price' ;
    rdfs:comment 'Agreed unit price applicable when the order quantity meets or exceeds the Tier 2 minimum quantity threshold. Represents the second volume discount price break.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3MinQty rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Min Qty' ;
    rdfs:comment 'Minimum order quantity threshold for the third volume break tier. Orders at or above this quantity qualify for the Tier 3 discounted unit price.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3UnitPrice rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Unit Price' ;
    rdfs:comment 'Agreed unit price applicable when the order quantity meets or exceeds the Tier 3 minimum quantity threshold. Represents the third volume discount price break.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierFlag rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Flag' ;
    rdfs:comment 'Indicates whether this pricing line has volume break tiers defined, where the unit price decreases as order quantity increases. When true, volume tier records are associated with this line.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeTierType rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Type' ;
    rdfs:comment 'Basis on which volume break tiers are calculated: by order quantity (units/weight), by order value (monetary), or by weight (metric tons). Determines how SAP SD scale pricing is evaluated.' ;
    rdfs:domain ind:PriceAgreementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Reference to the originating Request for Quotation (RFQ) that triggered this quote, enabling traceability from customer inquiry to formal offer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:convertedOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Converted Order Number' ;
    rdfs:comment 'SAP SD sales order document number created when this quotation is accepted and converted to a binding sales order, enabling end-to-end quote-to-cash traceability.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmQuoteNumber rdf:type rdf:Property ;
    rdfs:label 'Crm Quote Number' ;
    rdfs:comment 'The Salesforce CRM quote object identifier, enabling bidirectional traceability between the CRM pipeline and the SAP SD quotation document.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'Customer\'s own Purchase Order (PO) reference number provided with the RFQ or acceptance, required for invoice matching and customer accounts payable reconciliation.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingDate rdf:type rdf:Property ;
    rdfs:label 'Pricing Date' ;
    rdfs:comment 'The reference date used to determine applicable price lists, condition records, and raw material index values for pricing calculation. May differ from quote_date for forward-priced contracts.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'The business date on which the quotation was formally issued to the customer or distributor. Represents the principal real-world event date for this transaction.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle state of the quotation, tracking progression from initial draft through customer acceptance or expiry. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|expired|converted|cancelled — promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of the quotation by commercial purpose: standard customer quote, spot market offer, contract pricing, distributor channel, intercompany transfer, or product sample. [ENUM-REF-CANDIDATE: standard|spot|contract|distributor|intercompany|sample — promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Coded reason for quotation rejection or loss, populated when quote_status transitions to rejected or cancelled. Supports win/loss analysis and competitive intelligence. [ENUM-REF-CANDIDATE: price_too_high|competitor_selected|spec_mismatch|delivery_terms|no_decision|budget_cancelled — promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesDistrictCode rdf:type rdf:Property ;
    rdfs:label 'Sales District Code' ;
    rdfs:comment 'SAP SD sales district code identifying the geographic territory assignment for this quotation, used for territory management, sales performance reporting, and commission calculation.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQuotationNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Quotation Number' ;
    rdfs:comment 'The externally-known 10-digit SAP SD quotation document number used for cross-system reference and customer-facing communication.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country for chemical product delivery. Drives export control screening, REACH compliance checks, and hazardous material transport regulations.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Notes' ;
    rdfs:comment 'Free-text field capturing technical sales notes, application guidance, customer-specific formulation requirements, or special handling instructions relevant to the quoted chemical products.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Surcharge Amount' ;
    rdfs:comment 'Aggregate surcharges applied at the header level, including energy surcharges, raw material index surcharges, hazardous material handling fees, and freight surcharges.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The start date from which the quoted prices, terms, and conditions are binding and may be accepted by the customer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The expiry date after which the quoted prices and terms are no longer binding. Drives automated expiry workflows and renewal alerts.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchManaged rdf:type rdf:Property ;
    rdfs:label 'Batch Managed' ;
    rdfs:comment 'Indicates whether the chemical product on this quote line is subject to batch management and lot traceability requirements. Batch-managed products require Certificate of Analysis (COA) per lot and full GMP traceability.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributionMargin rdf:type rdf:Property ;
    rdfs:label 'Contribution Margin' ;
    rdfs:comment 'Gross contribution margin for this quote line, calculated as line net amount minus total standard cost. Expressed in the transaction currency. Enables profitability analysis at the product-grade level during the quoting process. Commercially sensitive.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) code defining the delivery obligations, risk transfer point, and cost responsibilities between seller and buyer for this quote line. Affects freight cost allocation and logistics planning. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Line Gross Amount' ;
    rdfs:comment 'Gross monetary value of this quote line before any discounts or surcharges, calculated as quantity multiplied by unit price in the transaction currency. Used as the baseline for margin and discount analysis.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNetAmount rdf:type rdf:Property ;
    rdfs:label 'Line Net Amount' ;
    rdfs:comment 'Net monetary value of this quote line after applying all discounts and surcharges (gross amount minus discounts plus surcharges) in the transaction currency. Represents the actual quoted value to the customer for this line.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smallOrderSurcharge rdf:type rdf:Property ;
    rdfs:label 'Small Order Surcharge' ;
    rdfs:comment 'Additional surcharge applied when the quoted quantity falls below the Minimum Order Quantity (MOQ) threshold for this product. Covers incremental handling and packaging costs for sub-MOQ orders.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalSpecReference rdf:type rdf:Property ;
    rdfs:label 'Technical Spec Reference' ;
    rdfs:comment 'Reference code or document number for the customer-specific or internal technical specification that the quoted product must meet. Links to product specification sheets, customer qualification documents, or internal quality standards.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesLeadId rdf:type rdf:Property ;
    rdfs:label 'Sales Lead Id' ;
    rdfs:comment 'Unique surrogate identifier for the sales lead record in the Chemical Mfg lakehouse Silver layer. Primary key generated at ingestion from Salesforce CRM Lead object.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedSalesRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Rep Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Lead assignment to a sales rep is a core process; FK supports lead conversion metrics and rep performance tracking.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Usd' ;
    rdfs:comment 'Estimated or reported annual revenue of the prospect company in US dollars. Used for lead qualification, account sizing, and prioritisation of high-value opportunities.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address of the lead contact used for digital outreach, campaign tracking, and follow-up communications. Sourced from Salesforce CRM Lead.Email field.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary telephone number for the lead contact. Used by technical sales representatives for direct outreach and qualification calls.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:converted rdf:type rdf:Property ;
    rdfs:label 'Converted' ;
    rdfs:comment 'Indicates whether this lead has been converted to a sales opportunity, account, and/or contact in Salesforce CRM. When True, the lead has progressed to the opportunity stage of the sales pipeline.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:convertedDate rdf:type rdf:Property ;
    rdfs:label 'Converted Date' ;
    rdfs:comment 'Date on which the lead was converted to a sales opportunity in Salesforce CRM. Used to calculate lead-to-opportunity conversion cycle time and pipeline velocity metrics.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when the lead record was first created in Salesforce CRM. Serves as the business event timestamp marking entry into the sales pipeline. Sourced from Salesforce CRM Lead.CreatedDate.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates whether the lead contact has opted out of all outreach communications. When True, sales and marketing activities must cease per GDPR, CCPA, and CAN-SPAM compliance requirements.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailOptOut rdf:type rdf:Property ;
    rdfs:label 'Email Opt Out' ;
    rdfs:comment 'Indicates whether the lead contact has specifically opted out of email marketing communications. Distinct from do_not_contact which covers all channels. Enforced per GDPR and CAN-SPAM Act.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Approximate number of employees at the prospect organisation. Used as a firmographic qualifier to assess company size and potential purchasing volume.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedOpportunityValueUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Opportunity Value Usd' ;
    rdfs:comment 'Sales representative\'s estimate of the potential annual contract or deal value in US dollars if the lead converts to a customer. Used for pipeline forecasting and revenue planning.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Date on which the assigned sales representative is scheduled to next contact the lead. Drives task management and ensures timely follow-up within the sales cadence.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes captured by the sales representative during lead qualification activities, including BANT (Budget, Authority, Need, Timeline) assessment observations and technical application details.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachScreeningRequired rdf:type rdf:Property ;
    rdfs:label 'Reach Screening Required' ;
    rdfs:comment 'Indicates whether the prospect\'s intended application or geography triggers a REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) compliance screening before product can be offered. Relevant for EU-based leads.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesTerritory rdf:type rdf:Property ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Geographic or account-based sales territory to which this lead is assigned (e.g., Northeast US, EMEA, APAC). Drives territory performance reporting and quota allocation.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRequested rdf:type rdf:Property ;
    rdfs:label 'Sds Requested' ;
    rdfs:comment 'Indicates whether the prospect has requested a Safety Data Sheet (SDS) for the product of interest. SDS requests are a strong qualification signal and trigger EHS documentation workflows.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tscaReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Tsca Review Required' ;
    rdfs:comment 'Indicates whether the lead\'s product interest requires a TSCA compliance review prior to commercial engagement. Applicable for US-based leads involving regulated chemical substances.' ;
    rdfs:domain ind:SalesLead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySalesRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Rep Employee Id' ;
    rdfs:comment 'Reference to the internal sales representative or account manager responsible for negotiating and managing this rebate agreement. Used for sales performance attribution and commission calculations.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:salesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Id' ;
    rdfs:comment 'Identifier of the associated Salesforce CRM opportunity or contract record that originated or tracks this rebate agreement. Enables cross-system traceability between CRM pipeline and SAP SD rebate execution.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:accrualAccountCode rdf:type rdf:Property ;
    rdfs:label 'Accrual Account Code' ;
    rdfs:comment 'General Ledger (GL) account code in SAP FI/CO to which rebate accruals are posted as a liability. Ensures correct financial reporting of variable consideration under FASB ASC 606 and SOX-compliant accrual tracking.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Amount' ;
    rdfs:comment 'Cumulative rebate liability accrued to date under this agreement based on eligible customer purchases. Updated periodically via SAP SD rebate settlement runs. Expressed in payout currency. Represents the current outstanding rebate obligation.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementNotes rdf:type rdf:Property ;
    rdfs:label 'Agreement Notes' ;
    rdfs:comment 'Free-text field capturing commercial negotiation context, special conditions, customer-specific terms, or exceptions not captured in structured fields. Used by sales and finance teams for agreement administration.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselinePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Baseline Period End' ;
    rdfs:comment 'End date of the reference period used to establish the baseline purchase volume or revenue for growth incentive rebate measurement. Together with baseline_period_start, defines the comparison window.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselinePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Start' ;
    rdfs:comment 'Start date of the reference period used to establish the baseline purchase volume or revenue against which growth performance is measured for growth incentive rebate agreements.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibleProductScope rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Scope' ;
    rdfs:comment 'Defines the breadth of products eligible for rebate accrual under this agreement. All products: entire customer portfolio; Product group: defined SAP material group; Specific SKUs: enumerated Stock Keeping Units (SKUs); Product line: a named chemical product line; Material type: SAP material type classification (e.g., FERT, HALB).' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:growthTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Growth Target Percent' ;
    rdfs:comment 'Year-over-year revenue or volume growth percentage target that the customer must achieve to qualify for growth incentive rebate tiers. Applicable only when agreement_type is growth_incentive. Expressed as a decimal percentage (e.g., 10.0000 = 10%).' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether the rebate is applied retroactively to all eligible purchases once a higher tier threshold is crossed (retroactive/step rebate), as opposed to applying only to incremental purchases above the threshold (incremental rebate). Critical for SAP SD rebate condition type configuration.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTiered rdf:type rdf:Property ;
    rdfs:label 'Is Tiered' ;
    rdfs:comment 'Indicates whether this rebate agreement uses a tiered scale structure where different rebate rates apply at different purchase volume or revenue thresholds. True: multiple tiers defined in the rebate tier child product; False: single flat rate applies.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Last Settlement Date' ;
    rdfs:comment 'Date on which the most recent rebate settlement was completed and credit memo or payment was issued to the customer. Used to track settlement history and validate settlement frequency compliance.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxRebateCapAmount rdf:type rdf:Property ;
    rdfs:label 'Max Rebate Cap Amount' ;
    rdfs:comment 'Maximum total rebate payout amount allowed under this agreement regardless of actual purchase performance. Protects Chemical Mfg from uncapped rebate liability exposure. Null if no cap applies. Expressed in payout currency.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Next Settlement Date' ;
    rdfs:comment 'Scheduled date for the next rebate settlement run for this agreement. Drives SAP SD settlement processing calendar and finance accrual review cycles.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payoutCurrency rdf:type rdf:Property ;
    rdfs:label 'Payout Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the rebate settlement is denominated and paid to the customer or distributor (e.g., USD, EUR, GBP). Supports multi-currency rebate programs for global chemical distribution.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAmountFixed rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount Fixed' ;
    rdfs:comment 'Fixed monetary rebate amount payable upon achievement of agreement conditions, used for flat-fee rebate structures (e.g., market development funds with a fixed payout). Null when the agreement uses a percentage-based rate. Expressed in the payout currency.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateRatePercent rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate Percent' ;
    rdfs:comment 'Percentage rate applied to the calculation basis to determine the rebate payout amount for a given tier. Expressed as a decimal percentage (e.g., 2.5000 = 2.5%). For tiered agreements, this represents the base or entry-level rate; tier-specific rates are captured in the rebate tier product.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapRebateAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Rebate Agreement Number' ;
    rdfs:comment 'Source system identifier for this rebate agreement in SAP SD (BO01/BO02 agreement number). Enables traceability and reconciliation between the lakehouse silver layer and the SAP S/4HANA system of record.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Threshold Basis Amount' ;
    rdfs:comment 'Minimum cumulative purchase value (in payout currency) or volume that the customer must achieve to qualify for the rebate. Represents the entry-level threshold for single-tier agreements. For multi-tier agreements, this is the lowest tier threshold.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdBasisUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Basis Unit' ;
    rdfs:comment 'Unit of measure for the rebate threshold basis amount. For revenue-based agreements, this is the ISO 4217 currency code. For volume-based agreements, this is the unit of measure (MT = metric ton, KG = kilogram, L = liter, EA = each) aligned with chemical product measurement standards. [ENUM-REF-CANDIDATE: USD|EUR|GBP|MT|KG|L|EA| — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequestId rdf:type rdf:Property ;
    rdfs:label 'Sample Request Id' ;
    rdfs:comment 'Unique system-generated identifier for the product sample request record. Primary key for the sample_request data product.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'The actual date on which the sample was physically shipped to the customer from the manufacturing site or warehouse, as recorded in SAP EWM.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationPurpose rdf:type rdf:Property ;
    rdfs:label 'Application Purpose' ;
    rdfs:comment 'Description of the intended end-use application or technical purpose for which the customer is evaluating the sample (e.g., adhesive formulation, coating binder, agricultural adjuvant, polymer additive). Critical for technical sales and R&D alignment.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFeedback rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback' ;
    rdfs:comment 'Free-text feedback provided by the customer following their evaluation of the sample, including performance observations, test results, or reasons for acceptance or rejection. Supports product development and CAPA processes.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseIndustry rdf:type rdf:Property ;
    rdfs:label 'End Use Industry' ;
    rdfs:comment 'The target industry segment in which the customer intends to use the sampled chemical product. Supports market segmentation analytics and new business development reporting. [ENUM-REF-CANDIDATE: automotive|construction|electronics|agriculture|consumer_goods|coatings|adhesives|pharmaceuticals|food_contact|other — promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedConversionValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Conversion Value' ;
    rdfs:comment 'The estimated annual revenue value (in the business\'s base currency) if the sample evaluation converts to a commercial order. Used for sales pipeline valuation and prioritization of sample requests.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationDueDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Due Date' ;
    rdfs:comment 'The agreed-upon date by which the customer is expected to complete their product evaluation and provide feedback or a qualification decision.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reachRegistered rdf:type rdf:Property ;
    rdfs:label 'Reach Registered' ;
    rdfs:comment 'Indicates whether the chemical substance in the sample is registered under the EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) regulation, required for shipment to EU customers.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestChannel rdf:type rdf:Property ;
    rdfs:label 'Request Channel' ;
    rdfs:comment 'The channel through which the sample request was submitted (e.g., web portal, email, direct sales representative, distributor, trade show). Supports channel effectiveness analysis.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the sample request workflow, from initial submission through evaluation outcome. [ENUM-REF-CANDIDATE: pending_approval|approved|in_preparation|shipped|under_evaluation|converted_to_order|rejected|cancelled — promote to reference product]' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the sample request by business purpose: new product evaluation, reformulation support, competitive product replacement, regulatory qualification, or customer-specific specification development.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'Primary street address line for the delivery destination of the sample shipment. Required for logistics planning in Oracle Transportation Management and SAP EWM outbound delivery.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'City of the sample shipment delivery destination.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetId rdf:type rdf:Property ;
    rdfs:label 'Target Id' ;
    rdfs:comment 'Primary key for target' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentivePlanId rdf:type rdf:Property ;
    rdfs:label 'Incentive Plan Id' ;
    rdfs:comment 'Reference to the incentive compensation plan under which this target is tracked. Links the sales target to the specific commission or bonus plan structure, enabling calculation of payouts based on attainment levels (floor, target, stretch). Sourced from HR/compensation management system.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IncentivePlan .

ind:actualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue Usd' ;
    rdfs:comment 'The actual realized revenue in USD for the target period, sourced from SAP SD billing documents and FI/CO revenue postings. Used to calculate revenue attainment variance against the target. Updated periodically via ERP integration.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualVolumeMt rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Mt' ;
    rdfs:comment 'The actual sales volume in metric tons (MT) realized during the target period, sourced from SAP SD delivery and billing records. Used to calculate volume attainment variance against the volume target.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentLevel rdf:type rdf:Property ;
    rdfs:label 'Assignment Level' ;
    rdfs:comment 'The organizational or commercial dimension at which this target is assigned. Sales_rep targets are individual; territory targets cover a geographic sales zone; product_line targets cover a chemical product family; business_unit targets cover a division (e.g., Agrochemicals, Specialty Chemicals); channel targets cover distributor or direct sales channels.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineYear rdf:type rdf:Property ;
    rdfs:label 'Baseline Year' ;
    rdfs:comment 'The prior fiscal year used as the baseline reference for target-setting calculations (e.g., prior year actuals used to derive growth targets). Supports year-over-year growth analysis and target justification documentation.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Floor Revenue Usd' ;
    rdfs:comment 'The minimum revenue threshold (floor) below which no incentive compensation is earned. Typically 70–80% of the base target. Used in incentive compensation calculations to define the minimum attainment level required for commission eligibility.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:growthRatePct rdf:type rdf:Property ;
    rdfs:label 'Growth Rate Pct' ;
    rdfs:comment 'The planned year-over-year or period-over-period growth rate embedded in this target, expressed as a decimal (e.g., 0.0800 = 8.00% growth). Derived from strategic planning assumptions and used to validate target reasonableness in management reviews.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRevisedDate rdf:type rdf:Property ;
    rdfs:label 'Last Revised Date' ;
    rdfs:comment 'The date on which this target was most recently revised or adjusted. Mid-year target revisions may occur due to market conditions, M&A activity, or force majeure events. Supports audit trail for target change management.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marginPct rdf:type rdf:Property ;
    rdfs:label 'Margin Pct' ;
    rdfs:comment 'The planned gross margin percentage target for the period, expressed as a decimal (e.g., 0.3250 = 32.50%). Used for profitability management and incentive compensation plans that include margin-based components. Populated when target_type is \'margin\'.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodGranularity rdf:type rdf:Property ;
    rdfs:label 'Period Granularity' ;
    rdfs:comment 'The time granularity at which this target is set and tracked. Annual targets cover a full fiscal year; quarterly targets align to SAP posting periods Q1–Q4; monthly targets align to individual SAP posting periods for detailed attainment tracking.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAttainmentPct rdf:type rdf:Property ;
    rdfs:label 'Revenue Attainment Pct' ;
    rdfs:comment 'The ratio of actual revenue to target revenue for the period, expressed as a decimal (e.g., 0.9250 = 92.50% attainment). Calculated as actual_revenue_usd / target_revenue_usd. Used for sales performance management, KPI dashboards, and incentive compensation calculations. NOTE: This is a stored attainment snapshot, not a real-time computed metric, to support point-in-time reporting and audit.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Usd' ;
    rdfs:comment 'The planned revenue target value denominated in US Dollars (USD) for the defined period. Represents the gross revenue goal before deductions. Used for EBITDA planning, COGS analysis, and sales performance management. Populated when target_type is \'revenue\' or \'margin\'.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settingMethod rdf:type rdf:Property ;
    rdfs:label 'Setting Method' ;
    rdfs:comment 'The methodology used to establish this sales target. Top_down targets are allocated from corporate/BU level; bottom_up targets are built from rep-level forecasts; negotiated targets result from manager-rep agreement; statistical targets are derived from historical trend analysis and SPC methods.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Stretch Revenue Usd' ;
    rdfs:comment 'The aspirational upper-bound revenue target (stretch goal) in USD, set above the base target to incentivize overperformance. Typically 110–120% of the base target. Used in incentive compensation plans to calculate accelerated commission rates for above-target performance.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the sales target record, used in management reporting, incentive compensation plans, and cross-system references between SAP SD and Salesforce CRM.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable descriptive name for the sales target, such as \'FY2025 Q1 Specialty Chemicals - North America\' or \'Annual Volume Target - Agrochemicals - Rep Smith\'. Used in dashboards and management reports.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle state of the sales target record. Draft targets are under review; active targets are in-period and being tracked; approved targets have passed management sign-off; closed targets have reached period end; cancelled targets were withdrawn before period start.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Classification of the sales target by the primary metric being tracked. Revenue targets are denominated in USD; volume targets in MT or kg; margin targets as gross margin percentage; new_business for new customer acquisition; account_growth for existing account expansion.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeAttainmentPct rdf:type rdf:Property ;
    rdfs:label 'Volume Attainment Pct' ;
    rdfs:comment 'The ratio of actual volume to target volume for the period, expressed as a decimal (e.g., 1.0500 = 105.00% attainment). Calculated as actual_volume_mt / target_volume_mt. Used for supply chain planning alignment and sales volume KPI reporting.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeMt rdf:type rdf:Property ;
    rdfs:label 'Volume Mt' ;
    rdfs:comment 'The planned sales volume target expressed in metric tons (MT). Used for chemical manufacturing capacity planning, raw material procurement forecasting, and supply chain management. Populated when target_type is \'volume\'. Aligns with SAP SD delivery quantity planning.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalInquiryId rdf:type rdf:Property ;
    rdfs:label 'Technical Inquiry Id' ;
    rdfs:comment 'Unique system-generated identifier for each technical inquiry record in the chemical sales domain. Serves as the primary key for this entity.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Linked Opportunity Id' ;
    rdfs:comment 'Reference to the sales opportunity in Salesforce CRM that this technical inquiry is associated with. Enables pipeline attribution and conversion tracking from technical inquiry to commercial opportunity.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:linkedQuoteId rdf:type rdf:Property ;
    rdfs:label 'Linked Quote Id' ;
    rdfs:comment 'Reference to the sales quotation generated as a result of or in conjunction with this technical inquiry. Supports pre-sales to commercial conversion tracking.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:competitorProductMentioned rdf:type rdf:Property ;
    rdfs:label 'Competitor Product Mentioned' ;
    rdfs:comment 'Indicates whether the customer referenced a competitor\'s product in the inquiry, signaling a competitive displacement or conversion opportunity. Used for competitive intelligence and sales strategy analytics.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Crm Case Number' ;
    rdfs:comment 'External case number assigned by Salesforce CRM for this technical inquiry. Used for cross-system traceability between the data lakehouse silver layer and the operational CRM system.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the first substantive technical response was delivered to the customer. Used to measure first-response SLA compliance and technical service performance KPIs. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ghsHazardClassRelevant rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Class Relevant' ;
    rdfs:comment 'Indicates whether the inquiry involves a substance with GHS hazard classification considerations, triggering mandatory SDS provision and GHS-compliant labeling guidance in the response.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inquiryDescription rdf:type rdf:Property ;
    rdfs:label 'Inquiry Description' ;
    rdfs:comment 'Full narrative description of the customer\'s technical question, application challenge, or documentation request. Captures the detailed context needed for the technical sales engineer to formulate a response.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquirySource rdf:type rdf:Property ;
    rdfs:label 'Inquiry Source' ;
    rdfs:comment 'Channel or origin through which the technical inquiry was received. Used for channel analytics and resource allocation. Values: email, web_portal, phone, trade_show, distributor, direct_sales.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquirySubject rdf:type rdf:Property ;
    rdfs:label 'Inquiry Subject' ;
    rdfs:comment 'Brief subject line or title summarizing the technical inquiry, as provided by the customer or entered by the sales engineer. Used for quick identification and search.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryType rdf:type rdf:Property ;
    rdfs:label 'Inquiry Type' ;
    rdfs:comment 'Classification of the nature of the technical inquiry. Drives routing, SLA assignment, and response workflow. Values include product application guidance, formulation recommendation, regulatory documentation (SDS/COA/REACH dossier), compatibility assessment, technical specification request, and sample request. [ENUM-REF-CANDIDATE: product_application|formulation_recommendation|regulatory_documentation|compatibility_assessment|technical_specification|sample_request — promote to reference product]' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Rd Referral Flag' ;
    rdfs:comment 'Indicates whether this technical inquiry has been referred to the R&D team for new compound development, custom formulation feasibility assessment, or advanced application engineering support.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the technical inquiry was officially received and logged in the system. This is the principal business event timestamp used for SLA measurement and response time KPI calculation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recommendedProductGrade rdf:type rdf:Property ;
    rdfs:label 'Recommended Product Grade' ;
    rdfs:comment 'Specific product grade or formulation variant recommended by the technical sales engineer in response to the customer\'s application inquiry. Supports product application engineering and upsell/cross-sell tracking.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDocType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Doc Type' ;
    rdfs:comment 'Type of regulatory or compliance document requested by the customer as part of this inquiry. Applicable when inquiry_type is regulatory_documentation. Values: SDS (Safety Data Sheet), COA (Certificate of Analysis), COC (Certificate of Compliance), REACH_dossier, TDS (Technical Data Sheet), none.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSummary rdf:type rdf:Property ;
    rdfs:label 'Response Summary' ;
    rdfs:comment 'Concise summary of the technical response provided to the customer, capturing key recommendations, product guidance, or regulatory information delivered. Supports knowledge management and future inquiry deflection.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity Kg' ;
    rdfs:comment 'Quantity of product sample requested by the customer, expressed in kilograms. Applicable when sample_requested is True. Used for sample fulfillment planning and inventory allocation.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the technical inquiry response was delivered within the agreed SLA timeframe (response_due_date). Derived at record closure and stored for KPI reporting and service quality analytics.' ;
    rdfs:domain ind:TechnicalInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent territory in the hierarchy. Enables rollup of sales performance, quota, and commission data from local to regional to global levels. Null for top-level global territories.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:primaryRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rep Employee Id' ;
    rdfs:comment 'Employee ID of the primary sales representative assigned to this territory. Links to HR/workforce records for commission calculation, performance management, and territory coverage reporting. Classified as confidential PII as it identifies an individual employee.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:territoryBackupRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Territory Backup Rep Employee Id' ;
    rdfs:comment 'Employee ID of the backup (secondary) sales representative assigned to cover this territory in the absence of the primary rep. Supports territory coverage continuity and commission split calculations.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:territoryOverlayRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Territory Overlay Rep Employee Id' ;
    rdfs:comment 'Employee ID of the overlay (specialist) sales representative assigned to this territory for technical sales support, product application guidance, or specific chemical product line expertise. Common in chemical sales for technical specialists.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:territorySalesManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Territory Sales Manager Employee Id' ;
    rdfs:comment 'Employee ID of the sales manager responsible for overseeing this territory. Used for escalation routing, performance review, and management reporting in the chemical sales organization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualQuotaUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Usd' ;
    rdfs:comment 'Annual revenue quota assigned to this territory in US Dollars. Used for sales performance measurement, commission calculation, and territory planning. Represents the revenue target the territory is expected to achieve within the fiscal year.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Code identifying the commission plan applicable to this territory. Determines how sales revenue generated within the territory is translated into commission payments for assigned representatives. Managed in SAP FI/CO and HR incentive compensation systems.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCount rdf:type rdf:Property ;
    rdfs:label 'Customer Count' ;
    rdfs:comment 'Number of active customer accounts assigned to this territory at the time of last update. Used for territory sizing, workload balancing, and sales force planning in the chemical sales organization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatHandlingRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Handling Required' ;
    rdfs:comment 'Indicates whether sales activities in this territory involve hazardous chemical products requiring special handling, DOT transport compliance, GHS labeling, or OSHA PSM considerations. Drives compliance training requirements for assigned reps.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRealignmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Realignment Date' ;
    rdfs:comment 'Date of the most recent territory realignment or restructuring event. Territory realignments in chemical sales organizations occur during annual planning cycles, mergers, or strategic pivots. Used to track territory stability and assess impact on quota attribution.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:namedAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Named Account Flag' ;
    rdfs:comment 'Indicates whether this territory is defined as a named-account territory (True) rather than a geographic or vertical territory (False). Named account territories in chemical sales are assigned to specific strategic customers regardless of geography.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the territory quota (e.g., \'USD\', \'EUR\', \'CNY\'). Supports multi-currency quota management for international chemical sales territories.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Regulated Flag' ;
    rdfs:comment 'Indicates whether this territory operates under European REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) regulation, requiring compliance documentation for chemical substances sold. Relevant for EU/EEA territories.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repAssignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Rep Assignment End Date' ;
    rdfs:comment 'Date on which the current primary sales representative assignment to this territory ends or ended. Null for currently active assignments. Supports historical assignment tracking and commission dispute resolution.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repAssignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Rep Assignment Start Date' ;
    rdfs:comment 'Date on which the current primary sales representative assignment to this territory became effective. Used for commission attribution, quota proration, and sales force alignment history tracking.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesforceTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Territory Code' ;
    rdfs:comment 'Native Salesforce CRM Territory2 object identifier (15 or 18-character Salesforce ID) for this territory. Used for cross-system reconciliation between the Databricks Silver Layer and Salesforce CRM source system.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSalesDistrictCode rdf:type rdf:Property ;
    rdfs:label 'Sap Sales District Code' ;
    rdfs:comment 'SAP SD Sales District code corresponding to this territory. The sales district is the SAP organizational unit that maps most directly to a geographic sales territory and is used in SAP order management, pricing, and reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 state or province code for sub-national geographic territories (e.g., \'US-TX\', \'DE-BY\'). Applicable for local-level territories; null for regional or global territories.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSalesRequired rdf:type rdf:Property ;
    rdfs:label 'Technical Sales Required' ;
    rdfs:comment 'Indicates whether this territory requires dedicated technical sales support (True), such as application engineers or chemists who provide product application guidance, formulation support, or SDS/COA documentation assistance to customers.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Free-text narrative description of the territory scope, coverage boundaries, special conditions, or strategic context. May include notes on key customer segments, chemical product focus areas, or competitive landscape relevant to the territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable descriptive name of the sales territory (e.g., \'Northeast Specialty Chemicals\', \'Germany Agricultural Solutions\'). Used in reporting, dashboards, and sales force communications.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory record. Active territories are currently assigned and operational; pending territories are being set up; inactive territories have been temporarily suspended; archived territories are closed and retained for historical reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of how the territory is defined and segmented. Geographic territories are defined by physical region; industry_vertical by customer industry sector; named_account by specific key accounts; product_line by chemical product category; hybrid combines multiple dimensions.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Tsca Regulated Flag' ;
    rdfs:comment 'Indicates whether this territory operates under US TSCA (Toxic Substances Control Act) regulation, requiring compliance with EPA chemical substance reporting and restriction requirements for products sold in this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each territory assignment record in the chemical sales organization. Primary key for this association entity linking a sales representative or account manager to a specific territory.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorAssignmentTerritoryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Assignment Territory Assignment Id' ;
    rdfs:comment 'Reference to the previous territory assignment record that this assignment supersedes. Enables historical tracking of territory ownership changes, succession planning, and audit trail of coverage transitions in the chemical sales organization.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerritoryAssignment .

ind:primaryTerritoryManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Territory Manager Employee Id' ;
    rdfs:comment 'Reference to the sales manager or regional director responsible for overseeing this territory assignment. Supports management hierarchy reporting, approval workflows, and escalation routing in the chemical sales organization.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTerritoryApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Territory Approved By Employee Id' ;
    rdfs:comment 'Reference to the user or manager who formally approved this territory assignment. Supports governance, audit trail, and Management of Change (MOC) compliance requirements in the chemical sales organization.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountCountTarget rdf:type rdf:Property ;
    rdfs:label 'Account Count Target' ;
    rdfs:comment 'The planned number of customer accounts the sales representative is expected to manage within this territory assignment. Used for workload balancing, territory sizing, and sales capacity planning in the chemical sales organization.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally-known business identifier for the territory assignment record, used in SAP SD and Salesforce CRM for cross-system reference and audit trail. Format: TA-YYYYMMDD-XXXX.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the territory assignment. Drives commission eligibility, quota attribution, and CRM routing logic. Active indicates the rep is currently responsible for the territory.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classifies the basis on which the territory is defined and assigned. Geographic assignments cover a physical region; account-based assignments cover named accounts; product-based assignments cover specific chemical product lines (e.g., specialty polymers, agrochemicals); channel-based assignments cover distributor or direct channels.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePct rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Pct' ;
    rdfs:comment 'The commission rate (expressed as a decimal fraction, e.g., 0.0350 = 3.50%) applicable to the sales representative for sales generated within this territory assignment. Used for incentive compensation calculation and financial accruals.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageScope rdf:type rdf:Property ;
    rdfs:label 'Coverage Scope' ;
    rdfs:comment 'Indicates the geographic or organizational breadth of the territory assignment. Supports hierarchical territory reporting and sales performance aggregation across the chemical sales organization.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAssignmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Assignment Code' ;
    rdfs:comment 'The Salesforce CRM system identifier for this territory assignment record. Enables cross-system reconciliation between the Salesforce CRM territory model and the SAP SD sales organization structure.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Effective Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter within the effective fiscal year for which this territory assignment and associated quota are applicable. Supports quarterly sales performance reporting and commission accrual calculations.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Effective Fiscal Year' ;
    rdfs:comment 'The fiscal year in which this territory assignment is active and quota-bearing. Aligns territory assignments with annual sales planning cycles, budget periods, and financial reporting requirements under SAP FI/CO.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySegmentFocus rdf:type rdf:Property ;
    rdfs:label 'Industry Segment Focus' ;
    rdfs:comment 'The target end-market industry segment (e.g., automotive, construction, electronics, consumer goods, agriculture) that this territory assignment is focused on. Supports vertical market analytics and customer acquisition strategy for chemical product sales.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCommissionEligible rdf:type rdf:Property ;
    rdfs:label 'Is Commission Eligible' ;
    rdfs:comment 'Indicates whether the sales representative is eligible to earn commission on sales generated within this territory assignment. Backup and overlay roles may have different commission eligibility rules in chemical sales organizations.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAssignment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Assignment' ;
    rdfs:comment 'Indicates whether this is the primary territory assignment for the sales representative. A representative may have multiple territory assignments; this flag identifies the principal one for reporting and commission attribution purposes.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuotaBearing rdf:type rdf:Property ;
    rdfs:label 'Is Quota Bearing' ;
    rdfs:comment 'Indicates whether a formal sales quota is assigned to this territory assignment. Overlay and backup roles may not carry independent quotas. Drives quota attainment reporting and KPI dashboards.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLineFocus rdf:type rdf:Property ;
    rdfs:label 'Product Line Focus' ;
    rdfs:comment 'Describes the specific chemical product line or portfolio segment (e.g., specialty polymers, performance coatings, agrochemicals, industrial solvents) that the sales representative is primarily responsible for within this territory. Supports product-line-level sales analytics and technical sales alignment.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'The revenue quota assigned to the sales representative for this territory during the assignment period, expressed in the functional currency. Used for sales performance measurement, KPI reporting, and incentive compensation calculations.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaCurrency rdf:type rdf:Property ;
    rdfs:label 'Quota Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the quota amount assigned to this territory (e.g., USD, EUR, GBP). Supports multi-currency chemical sales organizations operating across global markets.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriodType rdf:type rdf:Property ;
    rdfs:label 'Quota Period Type' ;
    rdfs:comment 'Defines the measurement period for the territory quota. Determines how quota attainment is calculated and reported for commission and incentive compensation purposes in the chemical sales organization.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Defines the nature of the sales representative\'s responsibility for the territory. Primary indicates full ownership; backup covers absence; overlay provides specialist support (e.g., technical sales for specialty chemicals); interim covers temporary gaps; co-primary indicates shared ownership.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdAssignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Assignment Number' ;
    rdfs:comment 'The SAP SD system identifier for the territory assignment record. Supports cross-system data lineage, reconciliation, and integration between Salesforce CRM and SAP SD for territory management in the chemical manufacturing enterprise.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossId rdf:type rdf:Property ;
    rdfs:label 'Win Loss Id' ;
    rdfs:comment 'Unique system-generated identifier for the win/loss analysis record. Primary key for this entity.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorPricePerKg rdf:type rdf:Property ;
    rdfs:label 'Competitor Price Per Kg' ;
    rdfs:comment 'The estimated or customer-disclosed unit price per kilogram offered by the winning or primary competing supplier. Classified as confidential. Critical for competitive pricing intelligence in chemical manufacturing.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorProduct rdf:type rdf:Property ;
    rdfs:label 'Competitor Product' ;
    rdfs:comment 'The specific competing chemical product, formulation, or material that was selected by the customer or displaced by Chemical Mfg. Enables product-level competitive benchmarking. Classified as confidential.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmOpportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Number' ;
    rdfs:comment 'The externally-known opportunity number from Salesforce CRM (e.g., OPP-2024-00123). Serves as the business-facing identifier for cross-system traceability between CRM and ERP.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactRole rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Role' ;
    rdfs:comment 'The role or title of the primary customer contact who provided win/loss feedback or made the purchase decision (e.g., Procurement Manager, R&D Chemist, Plant Manager, EHS Director). Identifies the decision-maker level in the customer organization. [ENUM-REF-CANDIDATE: procurement_manager|rd_chemist|plant_manager|ehs_director|technical_director|ceo|purchasing_agent|formulation_engineer — promote to reference product]' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRegion rdf:type rdf:Property ;
    rdfs:label 'Customer Region' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the customer\'s geographic region or country of operation (e.g., USA, DEU, CHN). Supports regional win/loss trend analysis and territory management.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealValueUsd rdf:type rdf:Property ;
    rdfs:label 'Deal Value Usd' ;
    rdfs:comment 'The estimated or actual total deal value in US dollars associated with the closed opportunity. Represents the annual or contract revenue at stake. Used for pipeline value analysis and win/loss financial impact reporting. Classified as confidential.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealVolumeKg rdf:type rdf:Property ;
    rdfs:label 'Deal Volume Kg' ;
    rdfs:comment 'The estimated annual or contract volume of chemical product in kilograms associated with the opportunity. Volume-based analysis is critical in chemical manufacturing for capacity planning and margin assessment. Classified as confidential.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewConducted rdf:type rdf:Property ;
    rdfs:label 'Interview Conducted' ;
    rdfs:comment 'Indicates whether a formal win/loss interview or debrief was conducted with the customer contact (True/False). Interviews provide higher-quality decision intelligence than self-reported CRM data.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewSource rdf:type rdf:Property ;
    rdfs:label 'Interview Source' ;
    rdfs:comment 'Indicates the source of the win/loss intelligence: direct customer interview, sales representative self-report, third-party market research, or inferred from available data. Affects the reliability weighting of the win/loss analysis.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCompetitiveDisplacement rdf:type rdf:Property ;
    rdfs:label 'Is Competitive Displacement' ;
    rdfs:comment 'Indicates whether this win involved displacing an incumbent competitor (True) or was a greenfield opportunity with no prior supplier (False). Distinguishes competitive wins from new market development in win/loss analysis.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewCustomer rdf:type rdf:Property ;
    rdfs:label 'Is New Customer' ;
    rdfs:comment 'Indicates whether this opportunity represented a new customer acquisition (True) or an existing customer retention/expansion deal (False). Critical for distinguishing new business wins from account growth in sales performance reporting.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opportunityCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Opportunity Created Date' ;
    rdfs:comment 'The date the sales opportunity was originally created in Salesforce CRM. Used to calculate the total sales cycle duration from opportunity creation to close.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityStageAtLoss rdf:type rdf:Property ;
    rdfs:label 'Opportunity Stage At Loss' ;
    rdfs:comment 'The CRM pipeline stage at which the opportunity was lost (e.g., prospecting, qualification, proposal, negotiation, technical evaluation). Identifies where in the sales funnel Chemical Mfg loses deals, enabling targeted process improvement. [ENUM-REF-CANDIDATE: prospecting|qualification|needs_analysis|proposal|technical_evaluation|negotiation|contract_review|closed_lost — promote to reference product]' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCompetitivenessRating rdf:type rdf:Property ;
    rdfs:label 'Price Competitiveness Rating' ;
    rdfs:comment 'Assessment of Chemical Mfg\'s pricing position relative to the winning competitor at the time of the deal. Classified as confidential due to pricing strategy sensitivity. Used to analyze price-driven win/loss patterns.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLossReason rdf:type rdf:Property ;
    rdfs:label 'Primary Loss Reason' ;
    rdfs:comment 'The principal reason cited for losing the opportunity. Common reasons in chemical manufacturing include price, product performance, technical specification mismatch, regulatory compliance gap (e.g., REACH, TSCA), competitor relationship, or delivery lead time. [ENUM-REF-CANDIDATE: price|product_performance|technical_specification|regulatory_compliance|competitor_relationship|delivery_lead_time|formulation_mismatch|credit_terms|incumbent_preference|no_decision — promote to reference product]' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWinReason rdf:type rdf:Property ;
    rdfs:label 'Primary Win Reason' ;
    rdfs:comment 'The principal reason cited for winning the opportunity. Common win reasons in chemical manufacturing include superior product performance, technical support quality, regulatory compliance advantage (e.g., GHS, REACH), pricing competitiveness, or established customer relationship. [ENUM-REF-CANDIDATE: product_performance|technical_support|price|regulatory_advantage|formulation_capability|delivery_reliability|relationship|sustainability_profile|application_expertise — promote to reference product]' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productApplication rdf:type rdf:Property ;
    rdfs:label 'Product Application' ;
    rdfs:comment 'The specific end-use application or industry segment for which the chemical product was being evaluated (e.g., automotive coating, adhesive formulation, agricultural active ingredient, electronic-grade solvent). Enables application-level win/loss analysis.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedPricePerKg rdf:type rdf:Property ;
    rdfs:label 'Quoted Price Per Kg' ;
    rdfs:comment 'The unit price per kilogram quoted by Chemical Mfg for the chemical product in this opportunity. Expressed in the deal currency. Classified as confidential. Enables price-level competitive analysis across won and lost deals.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceFactor rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Factor' ;
    rdfs:comment 'Indicates whether regulatory compliance requirements (e.g., REACH, TSCA, GHS, EPA, OSHA) were a cited factor in the customer\'s decision. Enables tracking of regulatory-driven wins and losses in the chemical industry.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesCycleDays rdf:type rdf:Property ;
    rdfs:label 'Sales Cycle Days' ;
    rdfs:comment 'The number of calendar days from opportunity creation to close date. Represents the length of the sales cycle for this deal. Used to benchmark sales efficiency and identify process improvement opportunities in technical chemical sales.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdsComplianceCited rdf:type rdf:Property ;
    rdfs:label 'Sds Compliance Cited' ;
    rdfs:comment 'Indicates whether the availability, quality, or compliance of the Safety Data Sheet (SDS/MSDS) was cited as a factor in the customer\'s decision. SDS compliance is a critical differentiator in chemical sales under GHS and OSHA HazCom standards.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilityFactor rdf:type rdf:Property ;
    rdfs:label 'Sustainability Factor' ;
    rdfs:comment 'Indicates whether sustainability, environmental profile, or ESG criteria (e.g., VOC content, HAP reduction, ISO 14001 compliance) were a cited factor in the customer\'s purchase decision. Reflects growing sustainability-driven procurement in chemical markets.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalEvaluationConducted rdf:type rdf:Property ;
    rdfs:label 'Technical Evaluation Conducted' ;
    rdfs:comment 'Indicates whether a formal technical evaluation, laboratory trial, or application testing was conducted as part of the sales process (True/False). In chemical manufacturing, technical evaluations (e.g., COA review, lab trials, LIMS-tracked testing) are a key stage in the sales cycle.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:asnId rdf:type rdf:Property ;
    rdfs:label 'Asn Id' ;
    rdfs:comment 'Unique identifier for the Advanced Shipping Notice record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asn .

ind:asnStatus rdf:type rdf:Property ;
    rdfs:label 'Asn Status' ;
    rdfs:comment 'Current lifecycle status of the ASN in the receiving workflow. [ENUM-REF-CANDIDATE: draft|transmitted|in_transit|arrived|receiving|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO standard container identification number for intermodal shipments.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Scheduled date when the shipment is expected to arrive at the receiving facility.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Time' ;
    rdfs:comment 'Precise timestamp when the shipment is scheduled to arrive at the receiving dock.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazmatPlacardCode rdf:type rdf:Property ;
    rdfs:label 'Hazmat Placard Code' ;
    rdfs:comment 'DOT hazard class placard code required for transportation (e.g., 3 for flammable liquids, 8 for corrosives).' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Total number of pallets included in the shipment for warehouse planning.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned tracking number for Less Than Truckload (LTL) shipments.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingDockLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Dock Location' ;
    rdfs:comment 'Specific dock or bay location at the receiving facility designated for unloading this shipment.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTemperatureMax rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Max' ;
    rdfs:comment 'Maximum temperature threshold allowed during transportation to maintain product integrity.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTemperatureMin rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Min' ;
    rdfs:comment 'Minimum temperature threshold required during transportation to maintain product integrity.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentMode rdf:type rdf:Property ;
    rdfs:label 'Shipment Mode' ;
    rdfs:comment 'Transportation mode used for this shipment (Less Than Truckload, Full Truckload, etc.).' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledIndicator rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Indicator' ;
    rdfs:comment 'Flag indicating whether the shipment requires temperature-controlled transportation.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Temperature Unit Of Measure' ;
    rdfs:comment 'Unit of measure for temperature values (Celsius, Fahrenheit, Kelvin).' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossWeight rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight' ;
    rdfs:comment 'Total gross weight of the entire shipment including packaging materials.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeight rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight' ;
    rdfs:comment 'Total net weight of the chemical materials excluding packaging.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolume rdf:type rdf:Property ;
    rdfs:label 'Total Volume' ;
    rdfs:comment 'Total volume of the shipment for capacity planning and storage allocation.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmitted Timestamp' ;
    rdfs:comment 'Timestamp when the ASN was transmitted by the vendor to the receiving system.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volumeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Volume Unit Of Measure' ;
    rdfs:comment 'Unit of measure for volume values (liters, gallons, cubic meters, cubic feet).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'Unit of measure for weight values (kilograms, pounds, metric tons, tons).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnLineId rdf:type rdf:Property ;
    rdfs:label 'Asn Line Id' ;
    rdfs:comment 'Unique identifier for the ASN line item. Primary key for the ASN line entity.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight including chemical material and packaging. Used for freight calculations, warehouse capacity planning, and transportation compliance.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether this material shipment requires quality inspection upon receipt before being released to inventory. Drives goods receipt workflow.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineValueAmount rdf:type rdf:Property ;
    rdfs:label 'Line Value Amount' ;
    rdfs:comment 'Monetary value of this ASN line item based on purchase order pricing. Used for goods receipt valuation and inventory accounting.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Net weight of the chemical material excluding packaging. Used for inventory valuation, yield calculations, and regulatory reporting.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Number' ;
    rdfs:comment 'Specific line item number on the purchase order that this ASN line corresponds to. Enables line-level PO-to-ASN reconciliation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdsRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Sds Revision Date' ;
    rdfs:comment 'Date when the Safety Data Sheet was last revised. Critical for ensuring compliance with current hazard communication requirements.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Quantity of material being shipped on this ASN line. Represents the actual amount dispatched by the supplier for this line item.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max Celsius' ;
    rdfs:comment 'Maximum temperature at which the chemical material can be stored without degradation. Defines upper bound for warehouse climate control.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min Celsius' ;
    rdfs:comment 'Minimum temperature at which the chemical material must be stored to maintain stability and quality. Defines lower bound for warehouse climate control.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Volume of the chemical material being shipped. Particularly important for liquid chemicals and storage capacity planning.' ;
    rdfs:domain ind:AsnLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Contract Material Master Id' ;
    rdfs:comment 'FK to rawmaterial.material_master' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:contractMaterialMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Contract Material Material Master Id' ;
    rdfs:comment 'FK to rawmaterial.material_master' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryContractMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Contract Material Master Id' ;
    rdfs:comment 'Reference to the primary chemical raw material or product covered by this contract. For multi-material contracts, this represents the primary or representative material.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the executive or manager who provided final approval for this contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the contract: draft (being prepared), pending approval (awaiting authorization), active (in force), suspended (temporarily halted), expired (validity period ended), terminated (ended early), or closed (completed and archived). [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFrequency rdf:type rdf:Property ;
    rdfs:label 'Delivery Frequency' ;
    rdfs:comment 'Planned frequency of material deliveries under this contract: daily, weekly, biweekly, monthly, quarterly, on-demand (as needed), or just-in-time (JIT synchronized with production). [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|on_demand|just_in_time — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureTerms rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Terms' ;
    rdfs:comment 'Contractual provisions defining events beyond parties control (natural disasters, war, pandemics, regulatory changes) that excuse performance obligations without penalty.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity that can be ordered per purchase order or delivery schedule line. Used to manage supplier capacity constraints.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'Quantity unit for which the price is specified (e.g., price per 1, per 100, per 1000 units). Used in SAP pricing to handle fractional pricing.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Buyer or procurement team responsible for managing this contract. Typically a three-character code in SAP MM.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'SAP organizational unit responsible for procurement activities and contract negotiation. Typically a four-character code.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitySpecification rdf:type rdf:Property ;
    rdfs:label 'Quality Specification' ;
    rdfs:comment 'Reference to quality standards, specifications, or Certificate of Analysis (COA) requirements that the supplied material must meet (e.g., purity >= 99.5%, pH 7.0-7.5, meets ASTM D1234).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months for each automatic renewal period if auto-renewal is enabled.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Total volume or quantity of material committed under this contract. Applicable for quantity contracts and scheduling agreements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days advance notice required to terminate the contract early. Protects both parties from abrupt contract cancellation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valueAmount rdf:type rdf:Property ;
    rdfs:label 'Value Amount' ;
    rdfs:comment 'Total monetary value committed under this contract. For value contracts, this is the maximum spend limit. For quantity contracts, this is the estimated total value based on contracted volumes and prices.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueCurrency rdf:type rdf:Property ;
    rdfs:label 'Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractPriceId rdf:type rdf:Property ;
    rdfs:label 'Contract Price Id' ;
    rdfs:comment 'Unique identifier for the contract price record. Primary key for the contract price entity.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: PRICING AUDIT: Price negotiations are performed by a specific employee; linking supports pricing compliance and audit trails.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplyContractId rdf:type rdf:Property ;
    rdfs:label 'Supply Contract Id' ;
    rdfs:comment 'FK to supply.contract' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:hazmatSurchargeFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Surcharge Flag' ;
    rdfs:comment 'Indicates whether this price includes or is subject to a hazardous material handling surcharge due to the chemical nature of the material.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Info Record Number' ;
    rdfs:comment 'SAP purchasing info record number that stores vendor-material pricing and procurement data. Alternative to contract-based pricing.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Date' ;
    rdfs:comment 'Date when the contract price was negotiated and agreed upon with the vendor.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceDeterminationRule rdf:type rdf:Property ;
    rdfs:label 'Price Determination Rule' ;
    rdfs:comment 'Rule or logic used to determine the final price when multiple condition records exist (e.g., most specific, lowest price, highest discount). Governs price selection in purchase orders.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingSequence rdf:type rdf:Property ;
    rdfs:label 'Pricing Sequence' ;
    rdfs:comment 'Order of application in the pricing procedure. Lower numbers are applied first. Determines the sequence of price calculations, surcharges, and discounts.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scaleQuantityFrom rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity From' ;
    rdfs:comment 'Lower bound of the quantity scale break for tiered pricing. Defines the minimum order quantity for this price tier. Null for non-scaled pricing.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleQuantityTo rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity To' ;
    rdfs:comment 'Upper bound of the quantity scale break for tiered pricing. Defines the maximum order quantity for this price tier. Null for open-ended top tier.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleType rdf:type rdf:Property ;
    rdfs:label 'Scale Type' ;
    rdfs:comment 'Type of scale pricing applied: quantity-based (volume discounts), value-based (order value thresholds), or none for flat pricing.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Primary key for goods_receipt' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiver Employee Id' ;
    rdfs:comment 'The employee identifier of the person who performed the goods receipt. Used for audit trail and accountability.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coaDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Document Number' ;
    rdfs:comment 'The document number or reference identifier of the vendor-supplied Certificate of Analysis for the received batch.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Received Flag' ;
    rdfs:comment 'Boolean indicator specifying whether the vendor-supplied Certificate of Analysis has been received and attached to the goods receipt record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage, leakage, or packaging issues observed during receipt inspection. Used for vendor claims and quality investigations.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDate rdf:type rdf:Property ;
    rdfs:label 'Gr Date' ;
    rdfs:comment 'The date on which the goods were physically received at the plant gate or warehouse dock. This is the principal business event timestamp for the receipt transaction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The unique goods receipt document number generated by the ERP system (SAP material document number). This is the business identifier for the receipt transaction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt transaction. Indicates whether the receipt is posted, pending approval, reversed, or blocked.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gr Timestamp' ;
    rdfs:comment 'The precise date and time when the goods receipt was recorded in the system, including time zone information.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingCondition rdf:type rdf:Property ;
    rdfs:label 'Packaging Condition' ;
    rdfs:comment 'Assessment of the physical condition of the packaging upon receipt. Critical for identifying damage, leaks, or contamination of chemical shipments.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Boolean indicator specifying whether the received material requires quality control inspection before release to unrestricted stock. Triggers QC workflow in LIMS.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiverName rdf:type rdf:Property ;
    rdfs:label 'Receiver Name' ;
    rdfs:comment 'The name of the warehouse or receiving dock employee who physically accepted and inspected the shipment.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Boolean indicator specifying whether the security seal was found intact upon arrival. False value triggers security investigation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureOnArrivalC rdf:type rdf:Property ;
    rdfs:label 'Temperature On Arrival C' ;
    rdfs:comment 'The measured temperature of the material shipment upon arrival at the receiving dock, recorded in degrees Celsius. Critical for temperature-sensitive chemicals and compliance with storage specifications.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'The total monetary value of the goods receipt transaction, calculated based on purchase order price and received quantity. Posted to inventory and financial accounts.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleIdentification rdf:type rdf:Property ;
    rdfs:label 'Vehicle Identification' ;
    rdfs:comment 'The truck number, container number, or other vehicle identification used for the delivery. Important for hazardous material tracking and security.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Inbound Delivery Id' ;
    rdfs:comment 'Unique identifier for the inbound delivery record. Primary key for this entity.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date the delivery arrived at the destination plant gate or receiving dock. Used for on-time delivery performance measurement.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'Actual date and time the delivery arrived at the destination plant, including time zone. Captured by gate systems or receiving personnel.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationPlantCode rdf:type rdf:Property ;
    rdfs:label 'Destination Plant Code' ;
    rdfs:comment 'Code identifying the receiving chemical manufacturing plant or facility. Corresponds to SAP plant master data.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotHazmatDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Hazmat Document Number' ;
    rdfs:comment 'DOT-required shipping document number for hazardous materials transport. Must accompany hazmat shipments and be available for inspection.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for freight cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Max C' ;
    rdfs:comment 'Maximum temperature in Celsius that must not be exceeded during transport to prevent material degradation or safety hazards.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Min C' ;
    rdfs:comment 'Minimum temperature in Celsius that must be maintained during transport to preserve material integrity. Applies to temperature-sensitive chemicals.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Date' ;
    rdfs:comment 'Planned date for the delivery to arrive at the destination plant. Used for production planning and resource allocation.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Time' ;
    rdfs:comment 'Planned date and time for the delivery to arrive at the destination plant, including time zone. Precise timing critical for dock scheduling and unloading crew coordination.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether the delivery requires temperature-controlled transport to maintain material stability and quality. Critical for temperature-sensitive chemicals.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transportEquipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Transport Equipment Number' ;
    rdfs:comment 'Identifier of the specific transport equipment used (tanker truck number, rail car number, container number). Used for tracking and safety audits.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationId rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Id' ;
    rdfs:comment 'Unique identifier for the invoice verification record. Primary key for three-way match verification in SAP MM MIRO.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Baseline date for payment terms calculation in SAP. Typically the invoice date or goods receipt date depending on payment terms configuration.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Reason why the invoice verification is blocked from payment. Common blocks include price tolerance exceeded, quantity short, or quality hold pending Certificate of Analysis (COA) review. [ENUM-REF-CANDIDATE: price_tolerance_exceeded|quantity_short|quality_hold_pending_coa|duplicate_invoice|missing_gr|missing_po|tax_code_mismatch|vendor_blocked|manual_review_required|unblocked — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Coa Review Status' ;
    rdfs:comment 'Status of the Certificate of Analysis review by Quality Control. Invoices may be blocked pending COA approval for chemical raw materials.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCharge rdf:type rdf:Property ;
    rdfs:label 'Freight Charge' ;
    rdfs:comment 'Freight or transportation charge included in the vendor invoice. Common surcharge in chemical procurement for bulk material shipments.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatHandlingFee rdf:type rdf:Property ;
    rdfs:label 'Hazmat Handling Fee' ;
    rdfs:comment 'Special handling fee for hazardous chemical materials. Charged by vendors for DOT-regulated hazmat transportation and storage compliance.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexEscalatorAmount rdf:type rdf:Property ;
    rdfs:label 'Index Escalator Amount' ;
    rdfs:comment 'Price adjustment based on commodity index escalation clauses common in chemical supply contracts. Reflects market-driven price volatility.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Total amount invoiced by the vendor before tax. Base amount for three-way match price variance calculation.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Quantity of chemical material invoiced by the vendor. Compared against PO quantity and GR quantity for variance detection.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Flag indicating whether the invoice is blocked for payment. True if blocked, False if released for payment processing.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Calculated date by which payment is due to the vendor based on invoice date and payment terms. Critical for cash flow management and vendor relationship.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReleaseBy rdf:type rdf:Property ;
    rdfs:label 'Payment Release By' ;
    rdfs:comment 'User ID or name of the person who released the invoice for payment. Audit trail for payment authorization.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Payment Release Date' ;
    rdfs:comment 'Date on which the invoice was released for payment after successful three-way match verification and block resolution.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceVariance rdf:type rdf:Property ;
    rdfs:label 'Price Variance' ;
    rdfs:comment 'Difference between invoiced price and PO price. Common in chemical procurement due to index-linked pricing, freight surcharges, and hazmat handling fees.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between invoiced quantity and goods receipt quantity. Typical with bulk liquid chemical deliveries measured by weight at receipt.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Date' ;
    rdfs:comment 'Date on which the vendor issued the invoice. Used for payment terms calculation and aging analysis.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'Invoice number provided by the chemical supplier on their invoice document. Critical for reconciliation and payment processing.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Document Number' ;
    rdfs:comment 'SAP document number assigned to the invoice verification transaction. Unique business identifier for the three-way match record.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'User ID or name of the person who performed the invoice verification. Audit trail for accountability and compliance.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Date and time when the invoice verification was completed. Tracks verification cycle time for process efficiency analysis.' ;
    rdfs:domain ind:InvoiceVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:materialInfoRecordId rdf:type rdf:Property ;
    rdfs:label 'Material Info Record Id' ;
    rdfs:comment 'Unique identifier for the material info record. Primary key for this purchasing master data entity.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgementRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required' ;
    rdfs:comment 'Indicates whether the vendor must send a formal acknowledgement confirming receipt and acceptance of purchase orders. When true, procurement tracks acknowledgement status.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementItemNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Item Number' ;
    rdfs:comment 'Specific line item within the referenced contract that covers this material. Five-digit numeric identifier linking to the contract line item.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedSource rdf:type rdf:Property ;
    rdfs:label 'Blocked Source' ;
    rdfs:comment 'Indicates whether this source is temporarily blocked from procurement. When true, no new purchase orders can be created using this material-vendor-plant combination.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfAnalysisRequired rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Required' ;
    rdfs:comment 'Indicates whether the vendor must provide a Certificate of Analysis with each shipment. Critical for chemical materials to verify composition, purity, and compliance with specifications.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedSource rdf:type rdf:Property ;
    rdfs:label 'Fixed Source' ;
    rdfs:comment 'Indicates whether this is the mandatory source for the material. When true, Material Requirements Planning (MRP) and purchase requisitions must use this vendor exclusively.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptRequired rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Required' ;
    rdfs:comment 'Indicates whether a formal goods receipt transaction must be posted in SAP MM before invoice processing. Standard requirement for physical materials.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infoRecordCategory rdf:type rdf:Property ;
    rdfs:label 'Info Record Category' ;
    rdfs:comment 'Classification of the purchasing info record type. Defines the procurement model: standard purchase, subcontracting arrangement, consignment stock, or pipeline supply for bulk chemicals.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infoRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Info Record Status' ;
    rdfs:comment 'Current lifecycle status of the purchasing info record. Determines whether this source can be used for new purchase orders and MRP planning.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptRequired rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Required' ;
    rdfs:comment 'Indicates whether invoice verification is required for purchases from this source. When true, three-way match (PO, goods receipt, invoice) is enforced.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPurchaseOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Date' ;
    rdfs:comment 'Date of the most recent purchase order created for this material-vendor-plant combination. Used to track sourcing activity and identify inactive sources.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseOrderPrice rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Price' ;
    rdfs:comment 'Most recent actual price paid for this material from this vendor. Used for price variance analysis and to track pricing trends over time.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Original manufacturer\'s part number when the vendor is a distributor. Ensures correct material identification and traceability to the chemical producer.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRelevant rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevant' ;
    rdfs:comment 'Indicates whether this source is considered during MRP runs for automatic source determination. When true, MRP will propose this vendor when generating planned orders or purchase requisitions.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPriceIndicator rdf:type rdf:Property ;
    rdfs:label 'Net Price Indicator' ;
    rdfs:comment 'Indicates whether the standard price is a net price (no further discounts apply) or a gross price (subject to additional discounts or surcharges).' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overDeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Pct' ;
    rdfs:comment 'Maximum percentage by which the vendor may exceed the ordered quantity without requiring approval. For example, 5.00 allows delivery of up to 105% of ordered quantity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyDataSheetRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Required' ;
    rdfs:comment 'Indicates whether the vendor must provide a current Safety Data Sheet (SDS) with shipments. Mandatory for hazardous chemicals to ensure safe handling and compliance with OSHA and GHS requirements.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceListRecord rdf:type rdf:Property ;
    rdfs:label 'Source List Record' ;
    rdfs:comment 'Indicates whether this info record is part of the approved vendor list (AVL). When true, this vendor is authorized to supply this material to this plant during the validity period.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Standard Order Quantity' ;
    rdfs:comment 'Recommended or typical order quantity for this material-vendor combination. Used as default value in purchase requisitions and for optimizing order economics.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Number' ;
    rdfs:comment 'Vendor\'s internal part number or catalog code for this material. Used for cross-referencing between buyer and supplier systems and for accurate order communication.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Pct' ;
    rdfs:comment 'Maximum percentage by which the vendor may deliver less than the ordered quantity without triggering a shortage alert. For example, 2.00 allows delivery of as low as 98% of ordered quantity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unlimitedOverDelivery rdf:type rdf:Property ;
    rdfs:label 'Unlimited Over Delivery' ;
    rdfs:comment 'Indicates whether the vendor is allowed to deliver any quantity above the purchase order amount without restriction. Typically used for bulk chemicals where exact quantities are difficult to control.' ;
    rdfs:domain ind:MaterialInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Flag' ;
    rdfs:comment 'Indicates whether this material requires batch management and lot tracking for quality control and traceability purposes.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationControlKey rdf:type rdf:Property ;
    rdfs:label 'Confirmation Control Key' ;
    rdfs:comment 'Code defining the type of order confirmation required from the supplier (e.g., order acknowledgment, shipping notification, delivery confirmation).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating whether this purchase order line has been marked for deletion and should be excluded from active procurement processing.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The requested or confirmed delivery date for this purchase order line item. Represents when the material is expected to arrive at the receiving location.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'Cumulative quantity of material that has been received against this purchase order line to date.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Required Flag' ;
    rdfs:comment 'Indicates whether a formal goods receipt transaction must be posted in the system before invoice processing can occur.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Quantity' ;
    rdfs:comment 'Cumulative quantity of material that has been invoiced by the supplier against this purchase order line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Required Flag' ;
    rdfs:comment 'Indicates whether an invoice must be received and verified before payment can be processed for this line item.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Total net value of this purchase order line, calculated as ordered quantity multiplied by net price, before taxes and freight.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'Remaining quantity of material still to be delivered on this purchase order line, calculated as ordered quantity minus goods receipt quantity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyProcurementPlanId rdf:type rdf:Property ;
    rdfs:label 'Supply Procurement Plan Id' ;
    rdfs:comment 'Unique identifier for the procurement plan record. Primary key for the procurement planning entity.' ;
    rdfs:domain ind:SupplyProcurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tertiarySupplyPlannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Supply Planner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:SupplyProcurementPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'The estimated or planned unit price for the material based on contract pricing, historical purchases, or market intelligence, used for budget planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatTransportFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Transport Flag' ;
    rdfs:comment 'Indicates whether the material being procured is classified as hazardous and requires special handling, documentation, and transport compliance per DOT/IATA regulations.' ;
    rdfs:domain ind:SupplyProcurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeBufferDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Buffer Days' ;
    rdfs:comment 'Additional buffer time in days added to standard lead time to account for hazmat transport delays, customs clearance, quality inspection, or supply chain variability.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:longLeadTimeFlag rdf:type rdf:Property ;
    rdfs:label 'Long Lead Time Flag' ;
    rdfs:comment 'Indicates whether the material is classified as a long lead-time specialty chemical requiring extended procurement planning horizons (typically greater than 90 days).' ;
    rdfs:domain ind:SupplyProcurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrpElement rdf:type rdf:Property ;
    rdfs:label 'Mrp Element' ;
    rdfs:comment 'Reference to the SAP MRP element (planned order, production order, or sales order) that generated this procurement requirement via MRP run (MD04/MD07).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRunDate rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Date' ;
    rdfs:comment 'The date when the MRP calculation was executed that generated this procurement plan requirement.' ;
    rdfs:domain ind:SupplyProcurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'The target date when the material is expected to be delivered to the receiving plant or warehouse location.' ;
    rdfs:domain ind:SupplyProcurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOrderDate rdf:type rdf:Property ;
    rdfs:label 'Planned Order Date' ;
    rdfs:comment 'The target date when the purchase order or procurement request should be created and released to the supplier to meet delivery requirements.' ;
    rdfs:domain ind:SupplyProcurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedProcurementQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Procurement Quantity' ;
    rdfs:comment 'The quantity of material planned to be procured in this plan record, expressed in the base unit of measure for the material.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Trigger Flag' ;
    rdfs:comment 'Indicates whether this procurement plan was triggered by safety stock replenishment logic due to inventory falling below minimum stock levels.' ;
    rdfs:domain ind:SupplyProcurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Material Flag' ;
    rdfs:comment 'Indicates whether the material has seasonal availability constraints requiring advance procurement planning and inventory build-up strategies.' ;
    rdfs:domain ind:SupplyProcurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Level' ;
    rdfs:comment 'Assessment of supply chain risk for this material based on supplier concentration, geopolitical factors, market volatility, and availability constraints.' ;
    rdfs:domain ind:SupplyProcurementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPlannedValue rdf:type rdf:Property ;
    rdfs:label 'Total Planned Value' ;
    rdfs:comment 'The total estimated monetary value of this procurement plan calculated as planned quantity multiplied by estimated unit price, used for budget allocation and spend forecasting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Buyer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: PROCUREMENT: PO creation requires a buyer employee for approval workflow and audit reporting; buyer details are already captured as name/email.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order: draft (being created), pending_approval (awaiting authorization), approved (authorized but not yet released), released (transmitted to vendor), partially_received (some goods received), fully_received (all goods received), closed (completed and archived), cancelled (voided before fulfillment). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|released|partially_received|fully_received|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type: standard (one-time purchase), blanket (release against framework agreement), contract (long-term agreement), consignment (vendor-owned inventory), subcontracting (material provided to vendor for processing), or service (non-material procurement).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Reference number of the internal purchase requisition that triggered the creation of this purchase order.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the delivery address for the purchase order shipment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'State or province of the delivery address for the purchase order shipment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for any special handling, packaging, labeling, or delivery instructions communicated to the vendor.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossValue rdf:type rdf:Property ;
    rdfs:label 'Total Gross Value' ;
    rdfs:comment 'Total gross monetary value of the purchase order including net value, taxes, freight, and all other charges.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetValue rdf:type rdf:Property ;
    rdfs:label 'Total Net Value' ;
    rdfs:comment 'Total net monetary value of the purchase order before taxes, freight, and other charges. Sum of all line item net values.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Total tax amount applicable to the purchase order, including sales tax, VAT, or other applicable taxes based on jurisdiction.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the primary vendor contact for order acknowledgment, shipping notifications, and issue resolution.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the vendor organization for this purchase order.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Unique identifier for the purchase requisition record. Primary key.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignProductionFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Production Flag' ;
    rdfs:comment 'Indicates whether this requisition is aligned with a campaign production schedule for batch manufacturing.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the requisition calculated as quantity multiplied by estimated unit price.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code for financial posting of the procurement expense.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerCode rdf:type rdf:Property ;
    rdfs:label 'Planner Code' ;
    rdfs:comment 'Code identifying the MRP planner or buyer responsible for managing procurement of this material.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poConversionStatus rdf:type rdf:Property ;
    rdfs:label 'Po Conversion Status' ;
    rdfs:comment 'Status indicating whether the requisition has been converted to one or more purchase orders.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterPhone rdf:type rdf:Property ;
    rdfs:label 'Requester Phone' ;
    rdfs:comment 'Contact phone number of the requisition requester for clarifications and follow-up.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the requisition in the approval and conversion workflow. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|partially_converted|fully_converted|cancelled|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition based on procurement scenario: standard purchase, subcontracting, consignment, stock transfer, service procurement, or third-party order.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockTrigger rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Trigger' ;
    rdfs:comment 'Indicates whether this requisition was triggered by safety stock replenishment logic in MRP.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the purchase requisition was originally created in the system.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedDate rdf:type rdf:Property ;
    rdfs:label 'Awarded Date' ;
    rdfs:comment 'Date when the RFQ was awarded to the selected supplier. Marks the transition from evaluation to contracting phase.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedPrice rdf:type rdf:Property ;
    rdfs:label 'Awarded Price' ;
    rdfs:comment 'Final negotiated unit price from the winning supplier. Confidential business data used for cost analysis and future price benchmarking.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardedSupplierCode rdf:type rdf:Property ;
    rdfs:label 'Awarded Supplier Code' ;
    rdfs:comment 'Vendor code of the supplier who was awarded the business after evaluation. Null if RFQ is not yet awarded or was cancelled.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerEmail rdf:type rdf:Property ;
    rdfs:label 'Buyer Email' ;
    rdfs:comment 'Email address of the buyer for supplier communication and clarification requests. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the procurement specialist or buyer who created and is managing this RFQ. Business reference, not direct PII.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerPhone rdf:type rdf:Property ;
    rdfs:label 'Buyer Phone' ;
    rdfs:comment 'Phone number of the buyer for urgent supplier inquiries. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPlantCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Plant Code' ;
    rdfs:comment 'Code identifying the manufacturing plant or warehouse where the material should be delivered. Links to plant master data.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Detailed criteria that will be used to evaluate and compare supplier quotations, such as price (weight 40%), lead time (20%), quality certifications (20%), payment terms (10%), supplier track record (10%). May include scoring methodology.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRequirements rdf:type rdf:Property ;
    rdfs:label 'Quality Requirements' ;
    rdfs:comment 'Quality standards and certifications required from suppliers, such as ISO 9001, GMP (Good Manufacturing Practice), REACH compliance, specific test methods, and Certificate of Analysis (COA) requirements.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Compliance Required Flag' ;
    rdfs:comment 'Indicates whether the material must comply with EU REACH regulation. True if REACH compliance documentation is mandatory, False if not applicable (e.g., non-EU supply).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'Number of quotation responses received from suppliers. Used to calculate response rate and assess market interest.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ: draft (being prepared), issued (sent to suppliers), open (accepting responses), under_evaluation (responses being reviewed), awarded (supplier selected), closed (process complete), cancelled (RFQ withdrawn). [ENUM-REF-CANDIDATE: draft|issued|open|under_evaluation|awarded|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqType rdf:type rdf:Property ;
    rdfs:label 'Rfq Type' ;
    rdfs:comment 'Classification of the RFQ based on procurement strategy: spot buy for one-time purchases, annual contract bid for long-term agreements, emergency source for urgent needs, framework agreement for multi-year supply, trial order for new supplier evaluation, bulk purchase for volume discounts.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Required Flag' ;
    rdfs:comment 'Indicates whether suppliers must provide a current Safety Data Sheet (SDS) compliant with GHS (Globally Harmonized System) standards with their quotation. True if SDS is mandatory, False if not required.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'Date and time by which suppliers must submit their quotation responses. Late submissions may be rejected or evaluated separately.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierCount rdf:type rdf:Property ;
    rdfs:label 'Supplier Count' ;
    rdfs:comment 'Number of suppliers to whom this RFQ was sent. Used to track competitive bidding scope and response rate analysis.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tscaComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliance Required Flag' ;
    rdfs:comment 'Indicates whether the material must be listed on the EPA TSCA inventory for use in the United States. True if TSCA compliance is mandatory, False if not applicable.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfqResponseId rdf:type rdf:Property ;
    rdfs:label 'Rfq Response Id' ;
    rdfs:comment 'Unique identifier for the vendor quotation response submitted in reply to a chemical raw material or service RFQ.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date when the procurement team formally accepted the quotation response and selected the vendor for award.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coaProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Provided Flag' ;
    rdfs:comment 'Indicates whether the vendor will provide a Certificate of Analysis with each shipment documenting quality test results.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cocProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Coc Provided Flag' ;
    rdfs:comment 'Indicates whether the vendor will provide a Certificate of Compliance documenting regulatory and specification adherence.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Internal procurement team notes documenting the evaluation rationale, strengths, weaknesses, and decision factors for this response.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'Composite score assigned by the procurement team during competitive bid analysis, based on price, quality, lead time, and compliance factors.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingSize rdf:type rdf:Property ;
    rdfs:label 'Packaging Size' ;
    rdfs:comment 'Size or capacity of the packaging unit (e.g., 200L drum, 1000L IBC, 25kg bag).' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Price Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the quoted price (e.g., per kilogram, per liter, per metric ton, per drum).' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'Date until which the quoted price remains valid, after which the vendor may revise pricing.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'Date from which the quoted price becomes valid and can be applied to purchase orders.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purityPercentage rdf:type rdf:Property ;
    rdfs:label 'Purity Percentage' ;
    rdfs:comment 'Guaranteed minimum purity of the chemical material expressed as a percentage (e.g., 99.5% purity).' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Quoted Lead Time Days' ;
    rdfs:comment 'Number of calendar days from purchase order placement to delivery, as committed by the vendor.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotedPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Price' ;
    rdfs:comment 'Unit price quoted by the vendor for the requested chemical raw material or service.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant Flag' ;
    rdfs:comment 'Indicates whether the vendor has confirmed that the quoted chemical material complies with EU REACH regulation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseNumber rdf:type rdf:Property ;
    rdfs:label 'Response Number' ;
    rdfs:comment 'Business identifier for the vendor quotation response, typically assigned by the vendor or procurement system.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Available Flag' ;
    rdfs:comment 'Indicates whether the vendor has confirmed availability of a current Safety Data Sheet for the quoted chemical material.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise date and time when the vendor submitted the quotation response, used for deadline compliance verification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicalComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Notes' ;
    rdfs:comment 'Vendor notes addressing technical specifications, quality standards, and compliance with RFQ requirements.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tscaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliant Flag' ;
    rdfs:comment 'Indicates whether the vendor has confirmed that the quoted chemical material is listed on the TSCA inventory for US market.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Phone number of the vendor representative for direct communication regarding this quotation response.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceListId rdf:type rdf:Property ;
    rdfs:label 'Source List Id' ;
    rdfs:comment 'Unique identifier for the source list record. Primary key.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementItem rdf:type rdf:Property ;
    rdfs:label 'Agreement Item' ;
    rdfs:comment 'The line item number within the referenced contract or scheduling agreement that applies to this material-vendor-plant combination.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avlStatus rdf:type rdf:Property ;
    rdfs:label 'Avl Status' ;
    rdfs:comment 'The current status of this vendor on the Approved Vendor List for the material-plant combination. Enforces procurement compliance and quality standards.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked Flag' ;
    rdfs:comment 'Indicates whether this source list entry is temporarily blocked from use in procurement. Used to suspend a vendor without deleting the source list record.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Fixed Source Flag' ;
    rdfs:comment 'Indicates whether this vendor is the mandatory (fixed) source for the material-plant combination. When true, procurement must use this vendor exclusively during the validity period.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterm Location' ;
    rdfs:comment 'The specific location (port, warehouse, plant) associated with the Incoterm for this source list entry. Clarifies the point of delivery or risk transfer.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Date' ;
    rdfs:comment 'The date when the vendor was last qualified or re-qualified for supplying this material. Used to track qualification currency and trigger re-qualification cycles.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrpRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevant Flag' ;
    rdfs:comment 'Indicates whether this source list entry is considered during MRP runs for automatic source determination and purchase requisition generation.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextQualificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Qualification Due Date' ;
    rdfs:comment 'The date by which the vendor must be re-qualified for this material. Supports proactive supplier management and compliance with AVL (Approved Vendor List) policies.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Order Quantity Uom' ;
    rdfs:comment 'The unit of measure for the minimum order quantity and standard ordering unit for this material from this vendor.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor is the preferred source for the material-plant combination when multiple approved sources exist. Used to guide procurement decisions.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:record rdf:type rdf:Property ;
    rdfs:label 'Record' ;
    rdfs:comment 'The sequential record number within the source list for the material-plant combination. Used for ordering and identification within SAP MM.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceListCategory rdf:type rdf:Property ;
    rdfs:label 'Source List Category' ;
    rdfs:comment 'The procurement category or special procurement type that this source list entry supports. Distinguishes between regular purchasing, subcontracting, consignment, and pipeline scenarios.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPriority rdf:type rdf:Property ;
    rdfs:label 'Vendor Priority' ;
    rdfs:comment 'The priority ranking of this vendor for the material-plant combination when multiple approved sources exist. Lower numbers indicate higher priority for automatic source determination.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingRiskId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Risk Id' ;
    rdfs:comment 'Primary key for sourcing_risk' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySourcingMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Sourcing Material Master Id' ;
    rdfs:comment 'Reference to the raw material or chemical compound affected by this supply risk. Links to material master data.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primarySourcingVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Sourcing Vendor Id' ;
    rdfs:comment 'Reference to the vendor associated with this supply risk. Links to the vendor master data in the supply domain.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:riskOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Risk Owner Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for monitoring and managing this supply risk, typically a procurement manager, supply chain planner, or category manager. Links to workforce/employee master data.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedSupplyLane rdf:type rdf:Property ;
    rdfs:label 'Affected Supply Lane' ;
    rdfs:comment 'Identification of the specific supply lane or transportation route affected by this risk (e.g., \'China-to-USA West Coast\', \'Rotterdam-to-Antwerp rail\', \'Gulf Coast LTL network\'), used for logistics disruption risk tracking.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualSpendAtRiskUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Spend At Risk Usd' ;
    rdfs:comment 'Total annual procurement spend (in USD) associated with the affected vendor or material that is exposed to this supply risk, used for financial impact assessment and prioritization.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Business Impact Description' ;
    rdfs:comment 'Detailed description of the potential business impact if the supply risk materializes, including effects on production schedules, customer commitments, revenue, market share, and strategic objectives.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this supply risk requires escalation to senior management or executive leadership due to severity, financial exposure, or strategic importance.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date when the supply risk was first identified and recorded in the risk management system, following yyyy-MM-dd format.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationActualDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actual Date' ;
    rdfs:comment 'Actual date when mitigation actions were completed and risk status changed to mitigated, following yyyy-MM-dd format. Null if mitigation is not yet complete.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Start Date' ;
    rdfs:comment 'Date when mitigation actions were initiated for this supply risk, following yyyy-MM-dd format. Null if no mitigation has been started.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Detailed description of the mitigation actions and strategies planned or implemented to reduce the likelihood or impact of the supply risk (e.g., dual-sourcing, safety stock increase, contract renegotiation, supplier development program, alternative material qualification).' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Target Date' ;
    rdfs:comment 'Target date by which mitigation actions are planned to be completed and risk reduced to acceptable levels, following yyyy-MM-dd format.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Comprehensive narrative description of the supply risk, including background, potential impact on operations, affected products or production lines, and any relevant context for stakeholders.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskExposureValueUsd rdf:type rdf:Property ;
    rdfs:label 'Risk Exposure Value Usd' ;
    rdfs:comment 'Estimated financial exposure or potential loss in USD if the risk materializes, calculated based on affected material spend, production value at risk, or revenue impact.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskIdentifier rdf:type rdf:Property ;
    rdfs:label 'Risk Identifier' ;
    rdfs:comment 'Human-readable business identifier for the supply risk record, following the pattern SRISK-NNNNNNNN for external communication and tracking.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskProbability rdf:type rdf:Property ;
    rdfs:label 'Risk Probability' ;
    rdfs:comment 'Qualitative assessment of the likelihood that the risk event will occur within the assessment time horizon. Very high (>75% probability), high (50-75%), medium (25-50%), low (10-25%), very low (<10%).' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle status of the supply risk. Open indicates newly identified and under assessment; in_mitigation indicates active mitigation actions in progress; mitigated indicates risk has been successfully reduced to acceptable levels; accepted indicates risk acknowledged but no further action planned; closed indicates risk no longer applicable or threat has passed.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'Secondary classification providing additional granularity within the primary risk category (e.g., under geopolitical: trade_embargo, sanctions, border_closure; under regulatory: REACH_authorization, TSCA_restriction, GHS_reclassification).' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Brief descriptive title summarizing the supply risk for quick identification and reporting (e.g., \'Single-source TiO2 supplier capacity constraint\', \'REACH authorization deadline for Substance X\').' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockRecommendationQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Recommendation Qty' ;
    rdfs:comment 'Recommended additional safety stock quantity (in base unit of measure) to buffer against supply disruption risk, calculated based on lead time variability, demand volatility, and risk severity.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockUom rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Uom' ;
    rdfs:comment 'Unit of measure for the safety stock recommendation quantity (e.g., KG for kilograms, L for liters, MT for metric tons, EA for each), aligned with material master base UOM.' ;
    rdfs:domain ind:SourcingRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique identifier for the delivery schedule line. Primary key for the supply delivery schedule entity.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDeliveryMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Material Master Id' ;
    rdfs:comment 'Identifier of the raw material, chemical compound, or finished product being scheduled for delivery. Links to material master data.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:schedulingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Agreement Id' ;
    rdfs:comment 'Reference to the parent scheduling agreement contract that governs this delivery schedule line. Links to the long-term supply arrangement with the chemical vendor.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyAgreement .

ind:actualDeliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Delivered Quantity' ;
    rdfs:comment 'Actual quantity of material delivered and received. Used to track delivery accuracy and calculate over-delivery or under-delivery variances.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeReceivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Received Quantity' ;
    rdfs:comment 'Total quantity of material received to date against this scheduling agreement. Used to track fulfillment progress and calculate outstanding delivery obligations.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryCategory rdf:type rdf:Property ;
    rdfs:label 'Delivery Category' ;
    rdfs:comment 'Classification of the delivery schedule line indicating the commitment level. Forecast deliveries are planning estimates, firm deliveries are binding commitments, just-in-time deliveries support lean manufacturing, blanket deliveries cover long-term agreements, and trade-off deliveries allow quantity adjustments.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Tolerance Percentage' ;
    rdfs:comment 'Acceptable percentage variance (plus or minus) from the scheduled quantity that the vendor is allowed to deliver without requiring approval. Supports flexible chemical supply chain management.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Total net value of this schedule line calculated as scheduled quantity multiplied by price per unit. Used for budget tracking and financial planning.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseStrategy rdf:type rdf:Property ;
    rdfs:label 'Release Strategy' ;
    rdfs:comment 'Method by which schedule lines are released to the vendor for fulfillment. Immediate releases are sent directly, forecast-based uses demand planning, consumption-based triggers on usage, and manual requires buyer approval.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleLineStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Status' ;
    rdfs:comment 'Current lifecycle status of the delivery schedule line. Tracks progression from initial scheduling through vendor confirmation, partial fulfillment, completion, or cancellation.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned date when the vendor is expected to deliver the material quantity to the receiving plant. Used for just-in-time manufacturing planning and production scheduling.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Confirmation Date' ;
    rdfs:comment 'Date when the vendor confirmed their ability to meet the scheduled delivery date and quantity. Critical for supply chain reliability tracking.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorConfirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Vendor Confirmed Quantity' ;
    rdfs:comment 'Quantity that the vendor has confirmed they can deliver on the scheduled date. May differ from scheduled quantity if vendor capacity constraints exist.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tollManufacturerId rdf:type rdf:Property ;
    rdfs:label 'Toll Manufacturer Id' ;
    rdfs:comment 'System-generated unique identifier for the toll manufacturer record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TollManufacturer .

ind:capacityAnnualTons rdf:type rdf:Property ;
    rdfs:label 'Capacity Annual Tons' ;
    rdfs:comment 'Maximum amount of product the manufacturer can produce per year, expressed in metric tons.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Units' ;
    rdfs:comment 'Unit of measure for the annual capacity field.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Environmental Performance Rating' ;
    rdfs:comment 'Rating of the manufacturer’s environmental compliance performance.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Global Coverage Flag' ;
    rdfs:comment 'Indicates whether the manufacturer can serve global supply locations.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Code' ;
    rdfs:comment 'Internal alphanumeric code used to reference the toll manufacturer.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerType rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Type' ;
    rdfs:comment 'Classification of the toll manufacturer relationship type.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingProcessType rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Process Type' ;
    rdfs:comment 'Primary process mode the manufacturer uses for production.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBatchSizeKg rdf:type rdf:Property ;
    rdfs:label 'Max Batch Size Kg' ;
    rdfs:comment 'Largest single batch the manufacturer can produce, expressed in kilograms.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxContinuousRateTph rdf:type rdf:Property ;
    rdfs:label 'Max Continuous Rate Tph' ;
    rdfs:comment 'Maximum continuous production rate, expressed in metric tons per hour.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfSites rdf:type rdf:Property ;
    rdfs:label 'Number Of Sites' ;
    rdfs:comment 'Count of distinct production sites operated by the manufacturer.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProductCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Product Category' ;
    rdfs:comment 'Main category of chemicals the manufacturer is qualified to produce.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovals rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approvals' ;
    rdfs:comment 'Comma-separated list of key regulatory approvals held (e.g., REACH, TSCA, FDA).' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollManufacturerStatus rdf:type rdf:Property ;
    rdfs:label 'Toll Manufacturer Status' ;
    rdfs:comment 'Current lifecycle status of the toll manufacturer record.' ;
    rdfs:domain ind:TollManufacturer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollManufacturingOrderId rdf:type rdf:Property ;
    rdfs:label 'Toll Manufacturing Order Id' ;
    rdfs:comment 'System-generated unique identifier for the toll manufacturing order.' ;
    rdfs:domain ind:TollManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateOfAnalysisProvided rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Provided' ;
    rdfs:comment 'Indicates whether a COA was supplied with the toll order.' ;
    rdfs:domain ind:TollManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Code' ;
    rdfs:comment 'Plant or site code where the finished product will be received.' ;
    rdfs:domain ind:TollManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule End Date' ;
    rdfs:comment 'Planned end date for the delivery window.' ;
    rdfs:domain ind:TollManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryScheduleStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Start Date' ;
    rdfs:comment 'Planned start date for the delivery window.' ;
    rdfs:domain ind:TollManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyDataSheetVersion rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Version' ;
    rdfs:comment 'Version identifier of the SDS provided for the material.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tollManufacturingOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Toll Manufacturing Order Status' ;
    rdfs:comment 'Current lifecycle state of the toll manufacturing order.' ;
    rdfs:domain ind:TollManufacturingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the current master supply agreement or contract with the vendor expires requiring renewal or renegotiation.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatHandlingCapable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Handling Capable' ;
    rdfs:comment 'Indicates whether the vendor has certified capabilities and infrastructure to handle, store, and transport hazardous chemical materials in compliance with DOT and OSHA regulations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the vendors corporate headquarters street address including building number and street name.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'Second line of the vendors corporate headquarters address for suite, floor, or additional location details.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City or municipality where the vendors corporate headquarters is located.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country where the vendors corporate headquarters is domiciled.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the vendors corporate headquarters address used for mail delivery and geographic classification.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region where the vendors corporate headquarters is located.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorityOwned rdf:type rdf:Property ;
    rdfs:label 'Minority Owned' ;
    rdfs:comment 'Indicates whether the vendor is certified as a minority-owned business enterprise for supplier diversity program tracking and reporting.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic vendor audit or re-qualification assessment based on audit frequency policy and risk tier.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current stage in the vendor qualification and onboarding process including documentation review, site audits, and compliance verification.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Composite performance scorecard rating (0-100 scale) based on on-time delivery, quality metrics, responsiveness, and compliance with contract terms.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleCareCertified rdf:type rdf:Property ;
    rdfs:label 'Responsible Care Certified' ;
    rdfs:comment 'Indicates whether the vendor holds Responsible Care certification from the American Chemistry Council (ACC) demonstrating commitment to environmental health and safety standards.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Number' ;
    rdfs:comment 'Unique vendor identifier in SAP S/4HANA MM (Materials Management) module used for procurement and accounts payable transactions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusiness rdf:type rdf:Property ;
    rdfs:label 'Small Business' ;
    rdfs:comment 'Indicates whether the vendor qualifies as a small business enterprise based on SBA size standards for supplier diversity and government contracting purposes.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Internal business identifier or short code used to reference the vendor in operational systems and reports.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Full legal name of the chemical supplier or raw material vendor as registered with governing authorities.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current operational status of the vendor indicating whether they are approved for procurement transactions and order placement.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Tiered classification reflecting the vendors strategic importance, performance history, and procurement preference level within the supply chain network.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:womanOwned rdf:type rdf:Property ;
    rdfs:label 'Woman Owned' ;
    rdfs:comment 'Indicates whether the vendor is certified as a woman-owned business enterprise for supplier diversity program tracking and reporting.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorAuditId rdf:type rdf:Property ;
    rdfs:label 'Vendor Audit Id' ;
    rdfs:comment 'Unique identifier for the vendor audit record. Primary key.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorDocumentId rdf:type rdf:Property ;
    rdfs:label 'Vendor Document Id' ;
    rdfs:comment 'Reference identifier or file path to the formal audit report document stored in the document management system.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorDocument .

ind:auditClosureDate rdf:type rdf:Property ;
    rdfs:label 'Audit Closure Date' ;
    rdfs:comment 'Date the audit was formally closed after all findings were addressed, CAPA verified, and follow-up activities completed.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'The date the audit fieldwork was completed. Nullable for single-day audits.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Frequency in months at which this vendor should be audited, based on risk classification and business criticality (e.g., 12, 24, 36 months).' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditLocation rdf:type rdf:Property ;
    rdfs:label 'Audit Location' ;
    rdfs:comment 'Physical location or facility where the audit was conducted (e.g., vendor plant address, city, country). For remote audits, indicates \'Remote\' or virtual platform used.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditMethod rdf:type rdf:Property ;
    rdfs:label 'Audit Method' ;
    rdfs:comment 'Method by which the audit was conducted: on_site (physical presence at vendor facility), remote (virtual/online audit), hybrid (combination of on-site and remote).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Issued Date' ;
    rdfs:comment 'Date the formal audit report was issued to the vendor and internal stakeholders.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numerical score assigned to the audit, typically on a scale of 0-100, representing the vendor\'s overall performance against audit criteria.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Audit Team Members' ;
    rdfs:comment 'Comma-separated list of additional auditor names who participated in the audit alongside the lead auditor.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Capa Approval Date' ;
    rdfs:comment 'Date the vendor\'s CAPA plan was reviewed and approved by the auditing organization. Nullable if not yet approved.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Due Date' ;
    rdfs:comment 'Target date by which the vendor must submit their CAPA plan addressing audit findings. Nullable if no CAPA is required.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Submission Date' ;
    rdfs:comment 'Actual date the vendor submitted their CAPA plan. Nullable if not yet submitted.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingsCriticalCount rdf:type rdf:Property ;
    rdfs:label 'Findings Critical Count' ;
    rdfs:comment 'Number of critical severity findings identified during the audit. Critical findings represent immediate risks to safety, compliance, or product quality requiring urgent corrective action.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsMajorCount rdf:type rdf:Property ;
    rdfs:label 'Findings Major Count' ;
    rdfs:comment 'Number of major severity findings identified during the audit. Major findings represent significant non-conformances that could impact quality, safety, or regulatory compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsMinorCount rdf:type rdf:Property ;
    rdfs:label 'Findings Minor Count' ;
    rdfs:comment 'Number of minor severity findings identified during the audit. Minor findings represent isolated non-conformances or opportunities for improvement that do not pose immediate risk.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsObservationCount rdf:type rdf:Property ;
    rdfs:label 'Findings Observation Count' ;
    rdfs:comment 'Number of observations or recommendations noted during the audit that are not formal non-conformances but represent best practice suggestions.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether a follow-up audit is required to verify implementation of corrective actions. True if follow-up audit is required, False otherwise.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completion Date' ;
    rdfs:comment 'Actual date the follow-up verification activities were completed. Nullable if not yet completed.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for conducting and reporting the audit.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallAuditRating rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Rating' ;
    rdfs:comment 'Overall assessment rating assigned to the vendor based on audit results. Determines vendor qualification status and future business relationship.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCareCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Responsible Care Compliant Flag' ;
    rdfs:comment 'Boolean flag indicating whether the vendor demonstrates compliance with the American Chemistry Council (ACC) Responsible Care program requirements. True if compliant, False otherwise.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardsAuditedAgainst rdf:type rdf:Property ;
    rdfs:label 'Standards Audited Against' ;
    rdfs:comment 'Comma-separated list of standards, regulations, or frameworks against which the vendor was audited (e.g., ISO 9001, ISO 14001, ISO 45001, OSHA PSM, GMP, REACH, Responsible Care).' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Date' ;
    rdfs:comment 'Date the vendor submitted their formal response to the audit findings. Nullable if no response received.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorResponseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Received Flag' ;
    rdfs:comment 'Boolean flag indicating whether the vendor has provided a formal response to the audit findings. True if response received, False otherwise.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByDocumentVendorDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Vendor Document Id' ;
    rdfs:comment 'Reference to the newer vendor document that supersedes this document. Null if this is the current version.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorDocument .

ind:documentHash rdf:type rdf:Property ;
    rdfs:label 'Document Hash' ;
    rdfs:comment 'SHA-256 or MD5 hash of the document file for integrity verification and duplicate detection.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLanguage rdf:type rdf:Property ;
    rdfs:label 'Document Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the primary language of the document content.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'The name of the digital file as stored in the document management system or data lake.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'The storage location or URI path where the document file is stored in the lakehouse or document repository.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'The size of the document file in kilobytes.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ghs Compliant Flag' ;
    rdfs:comment 'Indicates whether the document (typically SDS/MSDS) complies with GHS classification and labeling standards.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityCountry rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the issuing authority or certification body.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedBy rdf:type rdf:Property ;
    rdfs:label 'Received By' ;
    rdfs:comment 'Name or employee identifier of the person who received and registered the document in the system.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The date on which the document was received from the vendor and entered into the system.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewedDate rdf:type rdf:Property ;
    rdfs:label 'Reviewed Date' ;
    rdfs:comment 'The date on which the document was last reviewed by EHS, procurement, or quality assurance personnel for compliance verification.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorQualificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Qualification Id' ;
    rdfs:comment 'Unique identifier for the vendor qualification record. Primary key for the vendor qualification lifecycle.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVendorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Employee Id' ;
    rdfs:comment 'Reference to the employee assigned as lead auditor responsible for conducting the vendor qualification assessment.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditDurationDays rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Days' ;
    rdfs:comment 'Total number of days spent conducting the qualification audit including preparation, on-site/remote assessment, and reporting.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Performance Score' ;
    rdfs:comment 'Score for logistics and delivery performance including on-time delivery rate, lead time reliability, and order fulfillment accuracy.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ehsScore rdf:type rdf:Property ;
    rdfs:label 'Ehs Score' ;
    rdfs:comment 'Score for environmental, health, and safety compliance assessment including EHS management systems, incident history, and regulatory compliance.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialStabilityScore rdf:type rdf:Property ;
    rdfs:label 'Financial Stability Score' ;
    rdfs:comment 'Score for financial health assessment including credit rating, financial statements review, and business continuity risk.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid GMP (Good Manufacturing Practice) certification for pharmaceutical or food-contact chemical manufacturing.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the vendor qualification process was formally initiated.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso14001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 14001 Environmental Management System certification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 45001 Occupational Health and Safety Management System certification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 9001 Quality Management System certification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCategory rdf:type rdf:Property ;
    rdfs:label 'Material Category' ;
    rdfs:comment 'Primary chemical material category or product family that this qualification covers (e.g., solvents, polymers, catalysts, intermediates, specialty chemicals).' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScore rdf:type rdf:Property ;
    rdfs:label 'Qualification Score' ;
    rdfs:comment 'Composite numerical score representing the overall qualification assessment result, typically on a 0-100 scale based on weighted criteria.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Score for quality management system assessment including QMS (Quality Management System) certification, process controls, and product quality history.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Score' ;
    rdfs:comment 'Score for regulatory compliance assessment covering REACH (Registration Evaluation Authorization and Restriction of Chemicals), TSCA (Toxic Substances Control Act), GHS (Globally Harmonized System), and other applicable chemical regulations.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleCareMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Responsible Care Member Flag' ;
    rdfs:comment 'Indicates whether the vendor is a member of the Responsible Care program administered by the American Chemistry Council (ACC) or equivalent regional program.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Overall supply risk classification of the vendor based on criticality of materials, single-source dependency, regulatory complexity, and business impact.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorScorecardId rdf:type rdf:Property ;
    rdfs:label 'Vendor Scorecard Id' ;
    rdfs:comment 'Unique identifier for the vendor scorecard evaluation record.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Action Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal vendor improvement action plan is required based on scorecard results.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Coa Compliance Rate Pct' ;
    rdfs:comment 'Percentage of shipments accompanied by valid Certificate of Analysis documentation meeting quality specifications.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionCount rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Count' ;
    rdfs:comment 'Number of Corrective and Preventive Action (CAPA) requests issued to the vendor during the evaluation period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period for this scorecard.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period for this scorecard.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:innovationScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Score' ;
    rdfs:comment 'Score evaluating vendor contribution to product innovation, process improvements, and collaborative R&D initiatives.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeAdherencePct rdf:type rdf:Property ;
    rdfs:label 'Lead Time Adherence Pct' ;
    rdfs:comment 'Percentage of orders where the vendor met the agreed-upon lead time from purchase order issuance to delivery.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRatePct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Pct' ;
    rdfs:comment 'Percentage of purchase orders delivered on or before the requested delivery date during the evaluation period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Oos Incident Count' ;
    rdfs:comment 'Number of material receipts that failed quality testing and were found to be out of specification during the evaluation period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ootIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Oot Incident Count' ;
    rdfs:comment 'Number of material receipts showing quality parameter trends outside expected ranges during the evaluation period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Composite vendor performance score calculated across all evaluation dimensions, typically on a 0-100 scale.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Packaging Compliance Rate Pct' ;
    rdfs:comment 'Percentage of shipments meeting packaging specifications including hazmat labeling, UN packaging standards, and customer-specific requirements.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVariancePct rdf:type rdf:Property ;
    rdfs:label 'Price Variance Pct' ;
    rdfs:comment 'Average percentage variance between contracted prices and actual invoiced prices during the evaluation period. Positive values indicate overcharges, negative values indicate favorable pricing.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAccuracyRatePct rdf:type rdf:Property ;
    rdfs:label 'Quantity Accuracy Rate Pct' ;
    rdfs:comment 'Percentage of deliveries where the received quantity matched the ordered quantity within acceptable tolerance.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Reach Compliance Status' ;
    rdfs:comment 'Vendor compliance status with European REACH regulation for chemical substance registration and authorization.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Rejected Shipment Count' ;
    rdfs:comment 'Number of shipments rejected due to quality, documentation, or compliance failures during the evaluation period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleCareComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Responsible Care Compliance Rating' ;
    rdfs:comment 'Vendor compliance status with American Chemistry Council Responsible Care program standards for health, safety, and environmental performance.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Qualitative score measuring vendor responsiveness to inquiries, RFQs, technical questions, and issue resolution, typically on a 0-100 scale.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Business identifier for the vendor scorecard evaluation record.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Sds Compliance Rate Pct' ;
    rdfs:comment 'Percentage of shipments accompanied by current, GHS-compliant Safety Data Sheets.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Score' ;
    rdfs:comment 'Score evaluating vendor environmental and sustainability practices including waste reduction, emissions management, and green chemistry initiatives.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderCount rdf:type rdf:Property ;
    rdfs:label 'Total Order Count' ;
    rdfs:comment 'Total number of purchase orders issued to this vendor during the evaluation period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseValue rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Value' ;
    rdfs:comment 'Total monetary value of all purchase orders issued to this vendor during the evaluation period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when the vendor site became active in the supply chain network. Used for supplier relationship tracking and historical analysis.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'Date when the vendor site was deactivated or decommissioned. Null for currently active sites. Used for supplier lifecycle management.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the vendor site. Used for shipping, logistics planning, and regulatory reporting.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for building, suite, or unit information.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockHours rdf:type rdf:Property ;
    rdfs:label 'Dock Hours' ;
    rdfs:comment 'Operating hours for receiving and shipping at the vendor site dock. Used for delivery scheduling and ASN planning.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certificate Number' ;
    rdfs:comment 'Certificate number for the site\'s ISO 14001 certification. Used for environmental compliance verification.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001ExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Expiration Date' ;
    rdfs:comment 'Expiration date of the site\'s ISO 14001 certification. Monitored for environmental compliance and supplier sustainability programs.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso9001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certificate Number' ;
    rdfs:comment 'Certificate number for the site\'s ISO 9001 certification. Used for audit verification and supplier qualification documentation.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001ExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Expiration Date' ;
    rdfs:comment 'Expiration date of the site\'s ISO 9001 certification. Monitored for supplier compliance and re-qualification triggers.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumOrderQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Uom' ;
