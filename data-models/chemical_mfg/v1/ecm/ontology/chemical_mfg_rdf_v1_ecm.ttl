ind:simulationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Simulation Start Timestamp' ;
    rdfs:comment 'Timestamp when the simulation execution began.' ;
    rdfs:domain ind:ResearchProcessSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:simulationStatus rdf:type rdf:Property ;
    rdfs:label 'Simulation Status' ;
    rdfs:comment 'Current lifecycle status of the simulation run.' ;
    rdfs:domain ind:ResearchProcessSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thermodynamicModel rdf:type rdf:Property ;
    rdfs:label 'Thermodynamic Model' ;
    rdfs:comment 'Thermodynamic correlation or equation of state applied in the simulation.' ;
