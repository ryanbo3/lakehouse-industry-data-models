    rdfs:range xsd:string .

ind:coveredHazards rdf:type rdf:Property ;
    rdfs:label 'Covered Hazards' ;
    rdfs:comment 'Narrative list of specific chemicals, processes, or scenarios addressed by the plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Drill Completion Status' ;
    rdfs:comment 'Result of the most recent drill.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillObservations rdf:type rdf:Property ;
    rdfs:label 'Drill Observations' ;
    rdfs:comment 'Narrative observations, performance notes, and corrective actions identified during the drill.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillSchedule rdf:type rdf:Property ;
    rdfs:label 'Drill Schedule' ;
    rdfs:comment 'Planned frequency and timing of emergency response drills (e.g., quarterly, annual).' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Email' ;
    rdfs:comment 'Primary email address for the emergency coordinator.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Phone' ;
    rdfs:comment 'Primary telephone number for the emergency coordinator.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evacuationRoutesDescription rdf:type rdf:Property ;
    rdfs:label 'Evacuation Routes Description' ;
    rdfs:comment 'Detailed description of evacuation routes and assembly points.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Identifier of the facility or plant to which the plan applies.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastDrillDate rdf:type rdf:Property ;
    rdfs:label 'Last Drill Date' ;
    rdfs:comment 'Date of the most recent emergency response drill.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the plan in its lifecycle.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCategory rdf:type rdf:Property ;
    rdfs:label 'Plan Category' ;
    rdfs:comment 'Broad hazard category covered (e.g., chemical release, fire, explosion, natural disaster, environmental emergency).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'Link to the stored electronic copy of the full emergency response plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive name of the emergency response plan.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Regulatory classification of the plan as required by OSHA, EPA, or EPCRA.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version label or number for the plan (e.g., v1.2, 2023-Q2).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date the plan was submitted to the applicable regulatory agency.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Status' ;
    rdfs:comment 'Current status of required regulatory filings for the plan.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterInPlaceProcedures rdf:type rdf:Property ;
    rdfs:label 'Shelter In Place Procedures' ;
    rdfs:comment 'Procedures to be followed when shelter-in-place is required.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionEventId rdf:type rdf:Property ;
    rdfs:label 'Emission Event Id' ;
    rdfs:comment 'System-generated unique identifier for each emission event record.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Foreign key linking to maintenance.equipment. Business justification: EMISSIONS TRACKING: Emission events are typically generated by a specific piece of equipment; linking enables source-based reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:logisticsShipmentId rdf:type rdf:Property ;
    rdfs:label 'Logistics Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.shipment. Business justification: Transport Emission Tracking associates emission events with the corresponding shipment to calculate greenhouse-gas inventory for regulatory compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:causeOfRelease rdf:type rdf:Property ;
    rdfs:label 'Cause Of Release' ;
    rdfs:comment 'Primary cause that triggered the emission event.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanupStatus rdf:type rdf:Property ;
    rdfs:label 'Cleanup Status' ;
    rdfs:comment 'Status of any remediation or cleanup activities.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentSuccessFlag rdf:type rdf:Property ;
    rdfs:label 'Containment Success Flag' ;
    rdfs:comment 'Indicates whether containment measures successfully prevented further release.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicates whether the emission data passed quality checks.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityNotes rdf:type rdf:Property ;
    rdfs:label 'Data Quality Notes' ;
    rdfs:comment 'Comments on data quality issues or anomalies.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseAction rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Action' ;
    rdfs:comment 'Description of emergency response actions taken after the event.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionCategory rdf:type rdf:Property ;
    rdfs:label 'Emission Category' ;
    rdfs:comment 'Classification of emission as point source, fugitive, or accidental.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionEventStatus rdf:type rdf:Property ;
    rdfs:label 'Emission Event Status' ;
    rdfs:comment 'Current lifecycle status of the emission event record.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactor rdf:type rdf:Property ;
    rdfs:label 'Emission Factor' ;
    rdfs:comment 'Factor used to estimate emissions when direct measurement is unavailable.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactorUnit rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Unit' ;
    rdfs:comment 'Unit of the emission factor (e.g., kg/ton).' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionQuantity rdf:type rdf:Property ;
    rdfs:label 'Emission Quantity' ;
    rdfs:comment 'Measured amount of pollutant released during the event.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionUnit rdf:type rdf:Property ;
    rdfs:label 'Emission Unit' ;
    rdfs:comment 'Unit of measure for the emission quantity.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Category of the emission event such as routine monitoring, accidental release, or spill.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'State or region code where the emission source is located.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Method used to determine the emission quantity.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'How often the emission source is monitored.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseMedia rdf:type rdf:Property ;
    rdfs:label 'Release Media' ;
    rdfs:comment 'Environmental medium into which the pollutant was released.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current processing status of the regulatory report.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Report Submission Date' ;
    rdfs:comment 'Date the emission report was submitted to the regulator.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportableFlag rdf:type rdf:Property ;
    rdfs:label 'Reportable Flag' ;
    rdfs:comment 'True if the emission event meets regulatory reporting thresholds.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement' ;
    rdfs:comment 'Regulatory reporting framework applicable (e.g., EPA 40 CFR 302, TRI).' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePermitLimit rdf:type rdf:Property ;
    rdfs:label 'Source Permit Limit' ;
    rdfs:comment 'Regulatory emission limit for the source.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcePermitLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Source Permit Limit Unit' ;
    rdfs:comment 'Unit of the permit limit (e.g., kg/year).' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReference rdf:type rdf:Property ;
    rdfs:label 'Source Reference' ;
    rdfs:comment 'Identifier of the emission source (e.g., stack, vent, tank) that generated the event.' ;
    rdfs:domain ind:EmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Classification of the physical source of the emission.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDeviceId rdf:type rdf:Property ;
    rdfs:label 'Control Device Id' ;
    rdfs:comment 'Identifier of the pollution control device linked to the source (e.g., scrubber, baghouse).' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlDevice .

ind:processUnitId rdf:type rdf:Property ;
    rdfs:label 'Process Unit Id' ;
    rdfs:comment 'Identifier of the production unit or line associated with the emission source.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessUnit .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the source capacity.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Emission Limit Unit' ;
    rdfs:comment 'Unit of measure for the emission limit (e.g., kilograms per hour).' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionLimitValue rdf:type rdf:Property ;
    rdfs:label 'Emission Limit Value' ;
    rdfs:comment 'Maximum allowable emission quantity for the source per reporting period.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionMedium rdf:type rdf:Property ;
    rdfs:label 'Emission Medium' ;
    rdfs:comment 'Environmental medium to which emissions are released.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Emission Source Description' ;
    rdfs:comment 'Detailed free-text description of the emission source, its function, and any special characteristics.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAreaSource rdf:type rdf:Property ;
    rdfs:label 'Is Area Source' ;
    rdfs:comment 'True if emissions are dispersed over an area rather than a single point.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isControlled rdf:type rdf:Property ;
    rdfs:label 'Is Controlled' ;
    rdfs:comment 'Indicates whether the source has an attached emissions control device.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFugitive rdf:type rdf:Property ;
    rdfs:label 'Is Fugitive' ;
    rdfs:comment 'True if the source represents fugitive emissions (e.g., leaks, vents).' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPointSource rdf:type rdf:Property ;
    rdfs:label 'Is Point Source' ;
    rdfs:comment 'True if emissions originate from a discrete point (e.g., stack).' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReportable rdf:type rdf:Property ;
    rdfs:label 'Is Reportable' ;
    rdfs:comment 'Flag indicating if the source is subject to regulatory reporting (e.g., EPA, TRI).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMonitoringDate rdf:type rdf:Property ;
    rdfs:label 'Last Monitoring Date' ;
    rdfs:comment 'Date the most recent monitoring measurement was recorded.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Free-form description of the source location (e.g., building, floor, area).' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMonitoringDue rdf:type rdf:Property ;
    rdfs:label 'Next Monitoring Due' ;
    rdfs:comment 'Scheduled date for the next required monitoring activity.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitIssueDate rdf:type rdf:Property ;
    rdfs:label 'Permit Issue Date' ;
    rdfs:comment 'Date the emission permit was issued.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingCategory rdf:type rdf:Property ;
    rdfs:label 'Reporting Category' ;
    rdfs:comment 'Regulatory framework(s) under which the source must be reported.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCapacity rdf:type rdf:Property ;
    rdfs:label 'Source Capacity' ;
    rdfs:comment 'Maximum designed throughput or flow rate of the emission source.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCode rdf:type rdf:Property ;
    rdfs:label 'Source Code' ;
    rdfs:comment 'Business-assigned alphanumeric code uniquely identifying the emission source within the enterprise.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceGroup rdf:type rdf:Property ;
    rdfs:label 'Source Group' ;
    rdfs:comment 'Logical grouping or classification of related emission sources (e.g., boiler cluster).' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceName rdf:type rdf:Property ;
    rdfs:label 'Source Name' ;
    rdfs:comment 'Human-readable name of the emission source as used in reports and dashboards.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOperatingHoursPerYear rdf:type rdf:Property ;
    rdfs:label 'Source Operating Hours Per Year' ;
    rdfs:comment 'Total number of hours the source operates in a calendar year.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceOwner rdf:type rdf:Property ;
    rdfs:label 'Source Owner' ;
    rdfs:comment 'Organizational unit or department responsible for the emission source.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStatus rdf:type rdf:Property ;
    rdfs:label 'Source Status' ;
    rdfs:comment 'Current operational status of the emission source.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAspectId rdf:type rdf:Property ;
    rdfs:label 'Environmental Aspect Id' ;
    rdfs:comment 'System-generated unique identifier for each environmental aspect record.' ;
    rdfs:domain ind:EnvironmentalAspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementObjectiveId rdf:type rdf:Property ;
    rdfs:label 'Management Objective Id' ;
    rdfs:comment 'Foreign key linking to ehs.management_objective. Business justification: Environmental aspects are managed through ISO objectives. Adding management_objective_id to environmental_aspect connects each aspect to its governing objective.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagementObjective .

ind:aspectCategory rdf:type rdf:Property ;
    rdfs:label 'Aspect Category' ;
    rdfs:comment 'High-level classification of the aspect (air, water, soil, waste, energy, or other).' ;
    rdfs:domain ind:EnvironmentalAspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aspectCode rdf:type rdf:Property ;
    rdfs:label 'Aspect Code' ;
    rdfs:comment 'Business identifier or code used to reference the aspect in reports and systems.' ;
    rdfs:domain ind:EnvironmentalAspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aspectName rdf:type rdf:Property ;
    rdfs:label 'Aspect Name' ;
    rdfs:comment 'Human-readable name of the environmental aspect (e.g., VOC emissions from reactor venting).' ;
    rdfs:domain ind:EnvironmentalAspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aspectSubcategory rdf:type rdf:Property ;
    rdfs:label 'Aspect Subcategory' ;
    rdfs:comment 'More detailed classification within the main category (e.g., VOC, NOx for air).' ;
    rdfs:domain ind:EnvironmentalAspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasures rdf:type rdf:Property ;
    rdfs:label 'Control Measures' ;
    rdfs:comment 'Controls currently in place to mitigate the aspect (e.g., scrubbers, waste treatment).' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAspectDescription rdf:type rdf:Property ;
    rdfs:label 'Environmental Aspect Description' ;
    rdfs:comment 'Narrative description of the activity or process that generates the environmental aspect.' ;
    rdfs:domain ind:EnvironmentalAspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAspectStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Aspect Status' ;
    rdfs:comment 'Current lifecycle status of the aspect record.' ;
    rdfs:domain ind:EnvironmentalAspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpact rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact' ;
    rdfs:comment 'Description of the potential environmental impact associated with the aspect (e.g., air quality degradation, water contamination).' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Assessed Timestamp' ;
    rdfs:comment 'Date and time when the aspect was last evaluated for significance.' ;
    rdfs:domain ind:EnvironmentalAspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalRequirement rdf:type rdf:Property ;
    rdfs:label 'Legal Requirement' ;
    rdfs:comment 'Applicable legal or regulatory requirement linked to the aspect (e.g., EPA emission limit, REACH registration).' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualSignificance rdf:type rdf:Property ;
    rdfs:label 'Residual Significance' ;
    rdfs:comment 'Significance rating after accounting for existing controls.' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the aspect was retired or removed from active monitoring (if applicable).' ;
    rdfs:domain ind:EnvironmentalAspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:significanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Significance Criteria' ;
    rdfs:comment 'Criteria used to evaluate the significance of the aspect (e.g., regulatory thresholds, stakeholder concerns).' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significanceRating rdf:type rdf:Property ;
    rdfs:label 'Significance Rating' ;
    rdfs:comment 'Resulting significance rating after applying the criteria (high, medium, low).' ;
    rdfs:domain ind:Ehs ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'Regulatory or internal threshold value for the aspect (e.g., 50 ppm).' ;
    rdfs:domain ind:EnvironmentalAspect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Id' ;
    rdfs:comment 'System-generated unique identifier for each environmental monitoring record.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleId rdf:type rdf:Property ;
