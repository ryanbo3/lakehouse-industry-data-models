    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Scheduled date for the next required calibration of the instrument.' ;
