    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code of the transaction (e.g., USD, EUR).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Monetary discount available if payment is made by the discount due date.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'Last date on which the early-payment discount can be claimed.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Amount' ;
    rdfs:comment 'Monetary value currently under dispute.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'True if the customer has raised a dispute on this item.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of why the customer disputes the charge.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment is expected according to payment terms.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning step applied to the overdue item, where higher numbers indicate more severe collection actions.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total amount including tax before any discounts or write-offs.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment applied to the item.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdueDays rdf:type rdf:Property ;
    rdfs:label 'Overdue Days' ;
    rdfs:comment 'Number of days past the due date that the item remains unpaid.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partialPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Payment Flag' ;
    rdfs:comment 'True if one or more partial payments have been applied to the item.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Code that defines the payment schedule and discount eligibility (e.g., NET30, 2%10).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Date the invoice was posted to the general ledger.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units or amount represented by this line (e.g., liters, kilograms).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date the item was reconciled with a payment.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Indicates whether the open item has been matched to a payment.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax applied to the invoice line.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Code representing the tax jurisdiction and rate applied.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Paid Amount' ;
    rdfs:comment 'Cumulative sum of all payments posted against this open item.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Standard unit used for the quantity field.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the open-item record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Monetary value written off for this item.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date on which the write-off was recorded.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'True when the remaining amount has been written off as uncollectible.' ;
    rdfs:domain ind:ArOpenItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Id' ;
    rdfs:comment 'Primary key for adjustment' ;
    rdfs:domain ind:BillingAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Finance adjustment approvals are performed by specific employees; linking supports approval trail and regulatory reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:formulaChangeRequestId rdf:type rdf:Property ;
    rdfs:label 'Formula Change Request Id' ;
    rdfs:comment 'Foreign key linking to formulation.formula_change_request. Business justification: When a formula change alters product cost, a credit memo is issued; linking to the change request enables audit of price adjustments.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormulaChangeRequest .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Adjustments (credits/debits) must be recorded in a journal entry for audit trail; finance requires this link for adjustment posting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.material_master. Business justification: Quality-related credit memos: adjustments due to material defects need a link to the specific material master for audit trails and compliance investigations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Identifier of the customer to whom the adjustment applies.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:referenceInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Reference Invoice Id' ;
    rdfs:comment 'Identifier of the original invoice that is being adjusted.' ;
    rdfs:domain ind:BillingAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:relatedAdjustmentBillingAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Related Adjustment Billing Adjustment Id' ;
    rdfs:comment 'Identifier of the original adjustment that this record reverses or amends.' ;
    rdfs:domain ind:BillingAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAdjustment .

ind:safetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Id' ;
    rdfs:comment 'Foreign key linking to ehs.safety_incident. Business justification: Required: Credit memos are issued for costs arising from safety incidents; the FK ties adjustments to the originating incident for traceability.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyIncident .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Work Order Credit Memo Adjustment: adjustments (credits) are issued to correct charges generated by a specific work order.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Fiscal period (e.g., 2023Q4) to which the adjustment is posted.' ;
    rdfs:domain ind:BillingAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Business-visible document number assigned to the adjustment (e.g., CM-202300123).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Indicates whether the adjustment reduces (credit) or increases (debit) the amount owed.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Monetary amount of the adjustment before tax calculations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current approval state of the adjustment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Identifier of the user who approved the adjustment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the adjustment was approved.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingAdjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the adjustment document.' ;
    rdfs:domain ind:BillingAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional free-form notes entered by users.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Accounting cost center associated with the adjustment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date on which the adjustment becomes effective for accounting purposes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReference rdf:type rdf:Property ;
    rdfs:label 'External Reference' ;
    rdfs:comment 'Reference identifier from an external system (e.g., ERP, EDI).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method used for any associated payment or surcharge.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedBy rdf:type rdf:Property ;
    rdfs:label 'Posted By' ;
    rdfs:comment 'Identifier of the user who posted the adjustment.' ;
    rdfs:domain ind:BillingAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Exact timestamp when the adjustment was posted to the ledger.' ;
    rdfs:domain ind:BillingAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code representing the business reason for the adjustment (e.g., RETURN, PRICE_CORRECTION).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text description providing details of why the adjustment was issued.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'True if this adjustment reverses a previous adjustment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Name of the source system that originated the adjustment record (e.g., SAP_SD).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Classification of tax treatment for the adjustment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'True if the adjustment is exempt from tax.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Applicable tax rate expressed as a percentage (e.g., 7.25).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Net monetary impact of the adjustment after tax (adjustment_amount + tax_amount).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The moment the adjustment was executed (e.g., when the credit memo was posted).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'System-generated unique identifier for the billing dispute record.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Identifier of the customer who raised the dispute.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Identifier of a linked case or ticket in the customer service system.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:disputeCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Created By User Employee Id' ;
    rdfs:comment 'System user who initially created the dispute record.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disputeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Employee Id' ;
    rdfs:comment 'Identifier of the employee or team responsible for resolving the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disputeLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Last Modified By User Employee Id' ;
    rdfs:comment 'System user who performed the most recent update to the dispute record.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Any credit or debit applied during dispute resolution (e.g., discount, penalty).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Free-form text entered by the customer or agent describing the issue.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Human-readable identifier assigned to the dispute case, used in communications and tracking.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current state of the dispute within the resolution workflow.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Total monetary amount that the customer claims is incorrect.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputedInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Invoice Amount' ;
    rdfs:comment 'Total amount originally billed on the disputed invoice.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalatedToDepartment rdf:type rdf:Property ;
    rdfs:label 'Escalated To Department' ;
    rdfs:comment 'Department to which the dispute was escalated, if applicable.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the dispute has been escalated beyond the initial owner.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final amount after adjustments; the amount to be paid or refunded.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority assigned to the dispute for handling urgency.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Standardized reason why the customer is contesting the invoice.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the dispute record was first persisted in the data lake.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent modification to the dispute record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken to settle the dispute (e.g., issue credit, provide rebate).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date the dispute was closed or otherwise resolved.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Additional comments or details recorded by the resolver.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRebateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Billing Rebate Agreement Id' ;
    rdfs:comment 'System-generated unique identifier for the rebate agreement record.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingRebateAgreement .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Identifier of the underlying sales contract linked to the rebate agreement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:salesRebateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sales Rebate Agreement Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_rebate_agreement. Business justification: Links billing-side rebate contracts to sales-side rebate agreements for unified rebate accounting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesRebateAgreement .

ind:strategyId rdf:type rdf:Property ;
    rdfs:label 'Strategy Id' ;
    rdfs:comment 'Foreign key linking to pricing.pricing_strategy. Business justification: Rebate calculations follow a defined pricing strategy; linking enables accurate rebate accrual reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Strategy .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Method used to accrue rebate liability (periodic, continuous, or on invoice).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'External business identifier assigned to the rebate agreement, used in contracts and invoicing.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the rebate agreement received formal approval.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingRebateAgreementDescription rdf:type rdf:Property ;
    rdfs:label 'Billing Rebate Agreement Description' ;
    rdfs:comment 'Free-form description of the rebate agreement purpose and scope.' ;
    rdfs:domain ind:BillingRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRebateAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Rebate Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the rebate agreement.' ;
    rdfs:domain ind:BillingRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'Metric used to calculate the rebate amount (revenue, volume, or product group).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'List of regulatory frameworks (e.g., REACH, GHS, EPA) that the rebate must satisfy. [ENUM-REF-CANDIDATE: REACH|GHS|EPA|OSHA|ISO_9001|ISO_14001|ISO_45001|TSCA|FASB|SOX — promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date when the rebate agreement becomes binding.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date when the rebate agreement expires or is terminated (null for open-ended).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether the rebate is exclusive to the customer (true) or can be combined with other incentives (false).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier who performed the most recent update to the rebate agreement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Additional internal comments or observations related to the agreement.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productGroupCode rdf:type rdf:Property ;
    rdfs:label 'Product Group Code' ;
    rdfs:comment 'Code identifying the product group(s) to which the rebate applies.' ;
    rdfs:domain ind:BillingRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Monetary value of the rebate calculated for the current period.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateCapAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Cap Amount' ;
    rdfs:comment 'Maximum monetary amount payable under the rebate agreement for a given period.' ;
    rdfs:domain ind:BillingRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateRate rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate' ;
    rdfs:comment 'Percentage or factor applied to the calculation basis to determine rebate value.' ;
    rdfs:domain ind:BillingRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateType rdf:type rdf:Property ;
    rdfs:label 'Rebate Type' ;
    rdfs:comment 'Classification of the rebate (e.g., volume, growth, loyalty, market share).' ;
    rdfs:domain ind:BillingRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Three-letter country or region code where the rebate is valid.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueThreshold rdf:type rdf:Property ;
    rdfs:label 'Revenue Threshold' ;
    rdfs:comment 'Minimum revenue amount required to trigger the rebate.' ;
    rdfs:domain ind:BillingRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'How often rebate amounts are settled with the customer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tieredScaleDescription rdf:type rdf:Property ;
    rdfs:label 'Tiered Scale Description' ;
    rdfs:comment 'Textual or JSON representation of tiered rebate rates based on thresholds.' ;
    rdfs:domain ind:BillingRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeThreshold rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold' ;
    rdfs:comment 'Minimum volume (e.g., metric tons) required to trigger the rebate.' ;
    rdfs:domain ind:BillingRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier who initially created the rebate agreement record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingScheduleId rdf:type rdf:Property ;
    rdfs:label 'Billing Schedule Id' ;
    rdfs:comment 'Unique identifier for the billing schedule record.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chemicalProductId rdf:type rdf:Property ;
    rdfs:label 'Chemical Product Id' ;
    rdfs:comment 'Identifier of the product or service covered by the billing schedule.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalProduct .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Schedule creation is owned by a finance employee; audit logs require the creator employee for governance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_term. Business justification: Billing schedules reference payment terms; adding a payment_term_id FK formalizes this relationship and allows joins to retrieve term details.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:priceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Price Agreement Id' ;
    rdfs:comment 'Foreign key linking to sales.price_agreement. Business justification: Derives billing frequency and amounts from the governing price agreement, used in contract billing execution.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceAgreement .

ind:rdProjectId rdf:type rdf:Property ;
    rdfs:label 'Rd Project Id' ;
    rdfs:comment 'Foreign key linking to research.project. Business justification: Project-based billing schedules are tied to R&D project milestones for accurate invoicing and schedule tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date when the most recent amendment was applied.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number of contract amendments affecting this schedule.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Amount' ;
    rdfs:comment 'Planned monetary amount to be invoiced for each billing event.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'Three-letter currency code of the billing amount.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Regular interval at which billing events are generated.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingInterval rdf:type rdf:Property ;
    rdfs:label 'Billing Interval' ;
    rdfs:comment 'Number of frequency units between successive billings (e.g., every 2 months).' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the billing schedule.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Percentage discount applied to the billing amount before tax.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date of the final planned billing event.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixedAmountFlag rdf:type rdf:Property ;
    rdfs:label 'Fixed Amount Flag' ;
    rdfs:comment 'Indicates if the billing amount is a fixed value (true) or variable (false).' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMilestoneBased rdf:type rdf:Property ;
    rdfs:label 'Is Milestone Based' ;
    rdfs:comment 'True if billing is driven by achievement of defined milestones.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastBillingDate rdf:type rdf:Property ;
    rdfs:label 'Last Billing Date' ;
    rdfs:comment 'Date when the most recent billing was executed.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Textual description of the milestone tied to billing.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestonePercentage rdf:type rdf:Property ;
    rdfs:label 'Milestone Percentage' ;
    rdfs:comment 'Portion of the total contract value associated with this milestone.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'Date of the upcoming billing occurrence.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment condition governing when payment is due.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentageOfContract rdf:type rdf:Property ;
    rdfs:label 'Percentage Of Contract' ;
    rdfs:comment 'Portion of the total contract value represented by this schedule (e.g., 10.00 for 10%).' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Method used to recognize revenue for the scheduled billing.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Descriptive name of the billing schedule for easy identification.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Indicates whether the schedule is based on regular periods or specific milestones.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date of the first planned billing event.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Included Flag' ;
    rdfs:comment 'Indicates whether tax is already included in the billing amount.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variableAmountFlag rdf:type rdf:Property ;
    rdfs:label 'Variable Amount Flag' ;
    rdfs:comment 'Indicates if the billing amount can vary based on usage or other factors.' ;
    rdfs:domain ind:BillingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningNoticeId rdf:type rdf:Property ;
    rdfs:label 'Dunning Notice Id' ;
    rdfs:comment 'Unique identifier for the dunning notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementId rdf:type rdf:Property ;
    rdfs:label 'Settlement Id' ;
    rdfs:comment 'Identifier linking to settlement transaction if payment reconciled.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Settlement .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Identifier of the processing batch that generated the notice.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Method used to deliver the notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Review Flag' ;
    rdfs:comment 'Indicates if the notice triggered a credit limit review.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date the dunning notice was generated and sent.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningNoticeStatus rdf:type rdf:Property ;
    rdfs:label 'Dunning Notice Status' ;
    rdfs:comment 'Lifecycle status of the notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningNumber rdf:type rdf:Property ;
    rdfs:label 'Dunning Number' ;
    rdfs:comment 'System-generated sequential number for the dunning notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the notice was escalated to next level.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'Calculated interest charge applied.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Applicable interest rate applied to overdue amount.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Flag indicating if the notice was generated automatically.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Sent Date' ;
    rdfs:comment 'Date of the most recent reminder sent to the customer.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Escalation Flag' ;
    rdfs:comment 'Indicates if the notice has been escalated to legal action.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oldestOverdueItemDate rdf:type rdf:Property ;
    rdfs:label 'Oldest Overdue Item Date' ;
    rdfs:comment 'Date of the earliest overdue invoice item included in the notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Received Amount' ;
    rdfs:comment 'Amount received against this notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when payment was received for this notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Additional penalty fees applied.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current response status from the customer.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'Sum of overdue amount, interest, and penalties.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOverdueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Overdue Amount' ;
    rdfs:comment 'Aggregate amount overdue at time of notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyBillingId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Billing Id' ;
    rdfs:comment 'Unique surrogate key for each intercompany billing record.' ;
    rdfs:domain ind:IntercompanyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interplantSupplyPlanId rdf:type rdf:Property ;
    rdfs:label 'Interplant Supply Plan Id' ;
    rdfs:comment 'Foreign key linking to planning.interplant_supply_plan. Business justification: Needed to tie intercompany billing records to the interplant supply plan that scheduled the material transfer, supporting transfer-pricing compliance and inventory reconciliation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterplantSupplyPlan .

ind:receivingPartyId rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Id' ;
    rdfs:comment 'Surrogate key of the receiving legal entity in the master party table.' ;
    rdfs:domain ind:IntercompanyBilling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:sendingPartyId rdf:type rdf:Property ;
    rdfs:label 'Sending Party Id' ;
    rdfs:comment 'Surrogate key of the sending legal entity in the master party table.' ;
    rdfs:domain ind:IntercompanyBilling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:transferPriceId rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.transfer_price. Business justification: Inter-company billing is based on a pre-agreed transfer price; tax and compliance reports require the transfer_price reference.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferPrice .

ind:amountGross rdf:type rdf:Property ;
    rdfs:label 'Amount Gross' ;
    rdfs:comment 'Total amount before tax, discount, and net adjustments.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountNet rdf:type rdf:Property ;
    rdfs:label 'Amount Net' ;
    rdfs:comment 'Final amount after tax and discount, the amount payable.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User identifier of the person who created the billing record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Ic Elimination Flag' ;
    rdfs:comment 'Indicates whether the transaction is eliminated in consolidated financial statements.' ;
    rdfs:domain ind:IntercompanyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User identifier of the person who last modified the billing record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialServiceDescription rdf:type rdf:Property ;
    rdfs:label 'Material Service Description' ;
    rdfs:comment 'Textual description of the material or service transferred between entities.' ;
    rdfs:domain ind:IntercompanyBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of payment for the invoice.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit' ;
    rdfs:comment 'Price per unit of the transferred material or service before taxes and discounts.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Internal profit center linked to the transaction.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateSettlementFlag rdf:type rdf:Property ;
