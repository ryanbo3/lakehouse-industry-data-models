    rdfs:range xsd:string .

ind:incomingInspectionId rdf:type rdf:Property ;
    rdfs:label 'Incoming Inspection Id' ;
    rdfs:comment 'Surrogate primary key for the incoming inspection record.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capapTriggered rdf:type rdf:Property ;
    rdfs:label 'Capap Triggered' ;
    rdfs:comment 'Indicates if a CAPA workflow was triggered due to rejection.' ;
