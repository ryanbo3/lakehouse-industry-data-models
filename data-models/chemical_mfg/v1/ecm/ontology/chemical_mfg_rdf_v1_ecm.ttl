ind:associatedExperimentLabExperimentId rdf:type rdf:Property ;
    rdfs:label 'Associated Experiment Lab Experiment Id' ;
    rdfs:comment 'Identifier of the experiment or trial batch linked to the sample.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabExperiment .

ind:analysisResults rdf:type rdf:Property ;
    rdfs:label 'Analysis Results' ;
    rdfs:comment 'Free-text field capturing key analytical findings for the sample.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastStatusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Status Change Timestamp' ;
    rdfs:comment 'Timestamp when the sample status last changed.' ;
