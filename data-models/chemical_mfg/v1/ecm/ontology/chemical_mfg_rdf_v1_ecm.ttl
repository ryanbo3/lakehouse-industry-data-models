    rdfs:comment 'Indicates whether the change affects a process covered under OSHA PSM regulations (29 CFR 1910.119), requiring enhanced review and documentation.' ;
    rdfs:domain ind:AssetChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pssrCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pssr Completion Date' ;
    rdfs:comment 'Date when the PSSR was completed and the equipment or process was cleared for startup.' ;
    rdfs:domain ind:AssetChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pssrRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pssr Required Flag' ;
    rdfs:comment 'Indicates whether a Pre-Startup Safety Review is required before the modified equipment or process can be returned to service, as mandated by OSHA PSM for covered processes.' ;
    rdfs:domain ind:AssetChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided when the MOC request is rejected, including specific concerns or deficiencies that must be addressed.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Method' ;
    rdfs:comment 'Type of risk assessment methodology applied: Process Hazard Analysis, Hazard and Operability Study, What-If Analysis, Failure Mode and Effects Analysis, Layer of Protection Analysis, or not required.' ;
    rdfs:domain ind:AssetChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Required Flag' ;
    rdfs:comment 'Indicates whether a formal risk assessment (PHA, HAZOP, or similar) is required for this change based on its scope and potential impact.' ;
    rdfs:domain ind:AssetChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Description' ;
    rdfs:comment 'Detailed description of potential safety impacts including hazards introduced, hazards eliminated, and mitigation measures required.' ;
    rdfs:domain ind:AssetChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopUpdateCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Sop Update Completion Date' ;
    rdfs:comment 'Date when all required SOP revisions were completed and approved.' ;
    rdfs:domain ind:AssetChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sopUpdateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sop Update Required Flag' ;
    rdfs:comment 'Indicates whether existing SOPs must be revised to reflect the implemented change.' ;
    rdfs:domain ind:AssetChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Training Completion Status' ;
    rdfs:comment 'Current status of required employee training activities associated with the MOC implementation.' ;
    rdfs:domain ind:AssetChangeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether employee training is required as a result of the change to procedures, equipment operation, or safety protocols.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakdownEventId rdf:type rdf:Property ;
    rdfs:label 'Breakdown Event Id' ;
    rdfs:comment 'Unique identifier for the breakdown event record. Primary key for the breakdown event entity.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannerGroupId rdf:type rdf:Property ;
    rdfs:label 'Planner Group Id' ;
    rdfs:comment 'Foreign key linking to maintenance.planner_group. Business justification: Breakdown event is managed by a planner group; replace string with FK.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlannerGroup .

ind:pmNotificationId rdf:type rdf:Property ;
    rdfs:label 'Pm Notification Id' ;
    rdfs:comment 'Reference to the PM notification that reported this breakdown event. Links to the maintenance notification system.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Notification .

ind:affectedProductionUnit rdf:type rdf:Property ;
    rdfs:label 'Affected Production Unit' ;
    rdfs:comment 'Identifier of the production unit, process line, or manufacturing cell that was impacted by the equipment breakdown.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakdownDurationHours rdf:type rdf:Property ;
    rdfs:label 'Breakdown Duration Hours' ;
    rdfs:comment 'Total elapsed time in hours from breakdown start to restoration. Used for Mean Time To Repair (MTTR) calculation and downtime analysis.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakdownEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breakdown End Timestamp' ;
    rdfs:comment 'Precise date and time when the equipment was restored to operational status following the breakdown event.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breakdownNumber rdf:type rdf:Property ;
    rdfs:label 'Breakdown Number' ;
    rdfs:comment 'Business identifier for the breakdown event, typically auto-generated or manually assigned for tracking and reporting purposes.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakdownStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breakdown Start Timestamp' ;
    rdfs:comment 'Precise date and time when the equipment breakdown or failure was first detected or occurred. Critical for MTBF and MTTR calculations.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breakdownStatus rdf:type rdf:Property ;
    rdfs:label 'Breakdown Status' ;
    rdfs:comment 'Current lifecycle status of the breakdown event indicating progression from detection through resolution.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageCode rdf:type rdf:Property ;
    rdfs:label 'Damage Code' ;
    rdfs:comment 'Standardized code classifying the type of damage observed on the equipment, such as crack, deformation, erosion, or contamination.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsIncidentNumber rdf:type rdf:Property ;
    rdfs:label 'Ehs Incident Number' ;
    rdfs:comment 'Reference number of the associated EHS incident report if the breakdown event had safety or environmental implications.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Release Flag' ;
    rdfs:comment 'Indicator of whether the breakdown event resulted in an unplanned release of chemicals or hazardous materials to the environment.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost' ;
    rdfs:comment 'Estimated total cost to repair or restore the equipment following the breakdown event, including labor, materials, and contractor costs.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureCauseCode rdf:type rdf:Property ;
    rdfs:label 'Failure Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the breakdown, such as wear, corrosion, operator error, design defect, or inadequate maintenance.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Cause Description' ;
    rdfs:comment 'Detailed narrative explanation of the root cause analysis findings for the breakdown event. Supports RCI (Root Cause Investigation) documentation.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Description of how the equipment failed, such as mechanical fracture, electrical short, seal leak, bearing seizure, or control system fault. Supports failure mode and effects analysis (FMEA).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Detailed narrative description of the breakdown event, including symptoms, observations, and contextual information.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malfunctionStartIndicator rdf:type rdf:Property ;
    rdfs:label 'Malfunction Start Indicator' ;
    rdfs:comment 'Flag indicating whether this breakdown event marks the initial onset of a malfunction or is a continuation of a previous issue.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mocRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Moc Required Flag' ;
    rdfs:comment 'Indicator of whether corrective actions for this breakdown require a formal Management of Change process due to process safety implications.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority classification for the breakdown event response, determining urgency of corrective action and resource allocation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionImpactSeverity rdf:type rdf:Property ;
    rdfs:label 'Production Impact Severity' ;
    rdfs:comment 'Categorical assessment of the severity of production impact caused by the breakdown, ranging from critical plant shutdown to minimal disruption.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLossQuantity rdf:type rdf:Property ;
    rdfs:label 'Production Loss Quantity' ;
    rdfs:comment 'Quantified amount of production output lost due to the breakdown event, measured in the unit of measure specified.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionLossUom rdf:type rdf:Property ;
    rdfs:label 'Production Loss Uom' ;
    rdfs:comment 'Unit of measure for the production loss quantity, such as kilograms, liters, tons, or batch count.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psmCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Psm Critical Flag' ;
    rdfs:comment 'Indicator of whether the breakdown event involved PSM-covered equipment requiring mechanical integrity documentation and regulatory reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rciNumber rdf:type rdf:Property ;
    rdfs:label 'Rci Number' ;
    rdfs:comment 'Reference number of the formal root cause investigation conducted for this breakdown event.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rciRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rci Required Flag' ;
    rdfs:comment 'Indicator of whether the breakdown event severity or recurrence pattern requires a formal root cause investigation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the breakdown event was formally reported into the maintenance management system.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Elapsed time in hours from breakdown detection to initiation of corrective action. Key metric for maintenance responsiveness.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restorationMethod rdf:type rdf:Property ;
    rdfs:label 'Restoration Method' ;
    rdfs:comment 'Method used to restore equipment to operational status, such as on-site repair, component replacement, temporary fix, or operational workaround.' ;
    rdfs:domain ind:BreakdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Brief summary description of the breakdown event for quick identification and reporting purposes.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationRecordId rdf:type rdf:Property ;
    rdfs:label 'Calibration Record Id' ;
    rdfs:comment 'Unique identifier for the calibration record. Primary key for the calibration record entity.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationProcedureId rdf:type rdf:Property ;
    rdfs:label 'Calibration Procedure Id' ;
    rdfs:comment 'Reference to the Standard Operating Procedure (SOP) or work instruction used for this calibration. Links to documented calibration method.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationProcedure .

ind:calibrationStandardId rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard Id' ;
    rdfs:comment 'Identifier of the reference standard or master instrument used for calibration. Ensures traceability to national or international standards.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationStandard .

ind:primaryCalibrationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Calibration Employee Id' ;
    rdfs:comment 'Reference to the technician or calibration specialist who performed the calibration. Required for accountability and competency tracking.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Reference to the quality assurance reviewer who verified and approved the calibration record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accuracySpecification rdf:type rdf:Property ;
    rdfs:label 'Accuracy Specification' ;
    rdfs:comment 'Manufacturer or regulatory accuracy requirement for the instrument (e.g., ±0.5%, ±2 degC). Used to determine tolerance limits.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Performed Flag' ;
    rdfs:comment 'Indicates whether the instrument required adjustment or recalibration to bring it within tolerance.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:asFoundValue rdf:type rdf:Property ;
    rdfs:label 'As Found Value' ;
    rdfs:comment 'Measured value of the instrument before calibration adjustment. Documents initial condition and drift since last calibration.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asLeftValue rdf:type rdf:Property ;
    rdfs:label 'As Left Value' ;
    rdfs:comment 'Measured value of the instrument after calibration adjustment. Documents final calibrated state.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Number' ;
    rdfs:comment 'Unique certificate number issued for this calibration event. External business identifier for traceability and audit purposes.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationCost rdf:type rdf:Property ;
    rdfs:label 'Calibration Cost' ;
    rdfs:comment 'Total cost of calibration activity including labor, materials, and external service fees. Supports maintenance budget tracking.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date when the calibration was performed. Principal business event timestamp for this calibration record.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'Next scheduled calibration date based on calibration interval. Used for preventive maintenance scheduling and compliance tracking.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Interval Days' ;
    rdfs:comment 'Standard calibration frequency in days (e.g., 365 for annual, 180 for semi-annual). Determines next due date calculation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationPointsTested rdf:type rdf:Property ;
    rdfs:label 'Calibration Points Tested' ;
    rdfs:comment 'Number of measurement points tested during calibration (e.g., 5-point calibration across instrument range).' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationStandardCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard Certificate Number' ;
    rdfs:comment 'Certificate number of the reference standard used, providing traceability to NIST or equivalent national metrology institute.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current lifecycle status of the calibration record: scheduled (planned but not started), in-progress (calibration underway), passed (within tolerance), failed (out of tolerance), conditional (marginal pass with restrictions), cancelled (calibration not performed), overdue (past due date). [ENUM-REF-CANDIDATE: scheduled|in-progress|passed|failed|conditional|cancelled|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationType rdf:type rdf:Property ;
    rdfs:label 'Calibration Type' ;
    rdfs:comment 'Classification of calibration method: in-house (performed by internal technicians), external (third-party calibration lab), vendor (OEM calibration service), field (on-site calibration), laboratory (off-site lab calibration).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalHumidity rdf:type rdf:Property ;
    rdfs:label 'Environmental Humidity' ;
    rdfs:comment 'Relative humidity percentage during calibration. Environmental condition documentation required for measurement traceability.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalTemperature rdf:type rdf:Property ;
    rdfs:label 'Environmental Temperature' ;
    rdfs:comment 'Ambient temperature during calibration in degrees Celsius. Environmental condition documentation required for measurement traceability.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Regulated Flag' ;
    rdfs:comment 'Indicates whether this calibration is subject to Good Manufacturing Practice (GMP) requirements for pharmaceutical or food-contact chemical production.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfToleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Tolerance Flag' ;
    rdfs:comment 'Indicates whether the as-found condition was outside acceptable tolerance limits, triggering investigation and potential product impact assessment.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Calibration result: pass (within tolerance), fail (out of tolerance), conditional (marginal but acceptable with restrictions).' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psmCriticalInstrumentFlag rdf:type rdf:Property ;
    rdfs:label 'Psm Critical Instrument Flag' ;
    rdfs:comment 'Indicates whether this instrument is designated as PSM-critical under OSHA 1910.119 mechanical integrity requirements, requiring enhanced calibration documentation and frequency.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicianCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Number' ;
    rdfs:comment 'Certification or qualification number of the technician performing calibration, demonstrating competency for this calibration type.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Lower Limit' ;
    rdfs:comment 'Minimum acceptable value for calibration pass criteria. Defines lower bound of acceptable measurement range.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Upper Limit' ;
    rdfs:comment 'Maximum acceptable value for calibration pass criteria. Defines upper bound of acceptable measurement range.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorLabAccreditation rdf:type rdf:Property ;
    rdfs:label 'Vendor Lab Accreditation' ;
    rdfs:comment 'Accreditation body and certificate number for external calibration laboratory (e.g., A2LA, ANAB, UKAS). Ensures vendor competency.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogCodeId rdf:type rdf:Property ;
    rdfs:label 'Catalog Code Id' ;
    rdfs:comment 'Primary key for catalog_code' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:api689Reference rdf:type rdf:Property ;
    rdfs:label 'Api 689 Reference' ;
    rdfs:comment 'Cross-reference to API 689 (Collection and Exchange of Reliability and Maintenance Data for Equipment) standard. Used for alignment with American Petroleum Institute reliability standards.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Trigger Flag' ;
    rdfs:comment 'Indicates whether this catalog code automatically triggers a CAPA (Corrective and Preventive Action) workflow for quality management and continuous improvement. Aligns with GMP (Good Manufacturing Practice) and ISO 9001 requirements.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catalogCodeCode rdf:type rdf:Property ;
    rdfs:label 'Catalog Code Code' ;
    rdfs:comment 'The unique alphanumeric code within the catalog type and code group. This is the actual code value used in PM (Plant Maintenance) notifications and work orders for structured failure analysis. Example: CORR for corrosion, WEAR for wear, FRAC for fracture.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Catalog Code Status' ;
    rdfs:comment 'Current lifecycle status of the catalog code. Active codes are available for use in maintenance transactions. Deprecated codes are retained for historical reporting but not available for new entries.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogType rdf:type rdf:Property ;
    rdfs:label 'Catalog Type' ;
    rdfs:comment 'The type of catalog this code belongs to: damage codes (what failed), cause codes (why it failed), activity codes (what was done), object part codes (which component), or symptom codes (how failure manifested). Aligns with SAP PM catalog profile structure.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeGroup rdf:type rdf:Property ;
    rdfs:label 'Code Group' ;
    rdfs:comment 'Hierarchical grouping identifier for the catalog code. Enables multi-level classification and rollup reporting. For example, mechanical failures, electrical failures, instrumentation failures. Corresponds to SAP PM code group.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeLongText rdf:type rdf:Property ;
    rdfs:label 'Code Long Text' ;
    rdfs:comment 'Detailed description of the catalog code providing full definition, usage guidance, and examples. Used for training and reference documentation.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeShortText rdf:type rdf:Property ;
    rdfs:label 'Code Short Text' ;
    rdfs:comment 'Brief description of the catalog code, typically 20-40 characters. Used in dropdown lists and compact displays in maintenance transactions.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Ehs Reportable Flag' ;
    rdfs:comment 'Indicates whether failures coded with this catalog entry require EHS (Environment Health and Safety) incident reporting to regulatory authorities (EPA, OSHA, ECHA).' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentClass rdf:type rdf:Property ;
    rdfs:label 'Equipment Class' ;
    rdfs:comment 'The equipment class or category this catalog code is applicable to (e.g., rotating equipment, static equipment, instrumentation, electrical, piping). Enables filtering of relevant codes by equipment type.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Hours' ;
    rdfs:comment 'Typical equipment downtime duration in hours associated with this failure mode or activity code. Used for production impact planning and scheduling.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso14224Reference rdf:type rdf:Property ;
    rdfs:label 'Iso 14224 Reference' ;
    rdfs:comment 'Cross-reference to ISO 14224 (Petroleum, petrochemical and natural gas industries - Collection and exchange of reliability and maintenance data for equipment) failure mode taxonomy. Enables benchmarking against industry standards.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for the catalog code text. Supports multi-language catalog maintenance for global operations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'The most recent date this catalog code was used in a maintenance transaction. Used to identify obsolete codes for catalog cleanup.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mocTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Moc Trigger Flag' ;
    rdfs:comment 'Indicates whether this failure mode or activity code automatically triggers a MOC (Management of Change) workflow for process equipment changes. Required for PSM mechanical integrity compliance.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID of the person who last modified this catalog code entry. Used for audit trail and change tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCodeGroup rdf:type rdf:Property ;
    rdfs:label 'Parent Code Group' ;
    rdfs:comment 'Reference to the parent code group in the hierarchical catalog structure. Enables multi-level rollup and drill-down analysis. Null for top-level groups.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantSection rdf:type rdf:Property ;
    rdfs:label 'Plant Section' ;
    rdfs:comment 'The plant section or process area this catalog code is primarily used in (e.g., reactor area, distillation, packaging, utilities). Supports location-specific failure analysis.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityIndicator rdf:type rdf:Property ;
    rdfs:label 'Priority Indicator' ;
    rdfs:comment 'Default priority level associated with this catalog code. Used to auto-populate priority on PM notifications when this code is selected. Critical codes trigger immediate response.' ;
    rdfs:domain ind:CatalogCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortSequence rdf:type rdf:Property ;
    rdfs:label 'Sort Sequence' ;
    rdfs:comment 'Display order sequence number for this catalog code within its code group. Controls the presentation order in dropdown lists and reports.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'The number of times this catalog code has been used in PM notifications and work orders. Used for Pareto analysis of failure modes and catalog optimization.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Assigns a sales rep to each sold equipment; used in after-sales support KPIs and regional sales performance dashboards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'SAP FI-AA fixed asset number linked to this equipment for financial accounting, depreciation calculation, and CapEx tracking. Bridges the maintenance and finance domains.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical asset tag or nameplate number affixed to the equipment in the field. Used for physical identification during inspections, maintenance activities, and fixed asset accounting reconciliation.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationRequired rdf:type rdf:Property ;
    rdfs:label 'Calibration Required' ;
    rdfs:comment 'Indicates whether this equipment (typically instrumentation) requires periodic calibration to maintain measurement accuracy and regulatory compliance. True=calibration program applies; False=not applicable.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Principal rated capacity or throughput of the equipment (e.g., volumetric capacity for vessels in m³, flow rate for pumps in m³/hr, heat duty for heat exchangers in kW). The unit is specified in capacity_unit.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date the equipment was formally commissioned and accepted into operational service following installation, pre-commissioning checks, and startup testing. Distinct from installation date.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constructionYear rdf:type rdf:Property ;
    rdfs:label 'Construction Year' ;
    rdfs:comment 'Year in which the equipment was manufactured or constructed. Used for age-based risk assessment, remaining useful life estimation, and regulatory inspection scheduling.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:corrosionAllowanceMm rdf:type rdf:Property ;
    rdfs:label 'Corrosion Allowance Mm' ;
    rdfs:comment 'Designed corrosion allowance in millimeters added to the minimum required wall thickness to account for expected corrosion over the equipment\'s design life. Used in fitness-for-service assessments and remaining life calculations.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalityClass rdf:type rdf:Property ;
    rdfs:label 'Criticality Class' ;
    rdfs:comment 'Equipment criticality ranking used to prioritize maintenance resources and inspection frequency. A=Safety-critical/production-critical (highest priority, PSM-covered); B=Important but has redundancy or workaround; C=Non-critical/low impact on safety or production.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date the equipment was permanently removed from service and decommissioned. Null for active equipment. Required for fixed asset retirement accounting and regulatory closure documentation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Design Pressure Kpa' ;
    rdfs:comment 'Maximum allowable working pressure (MAWP) for which the equipment was designed, expressed in kilopascals (kPa). Critical nameplate data for pressure vessel inspection, relief valve sizing, and PSM mechanical integrity documentation.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Design Temperature C' ;
    rdfs:comment 'Maximum allowable design temperature for which the equipment was designed, expressed in degrees Celsius. Used for material of construction verification, thermal stress analysis, and PSM mechanical integrity records.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'SAP PM equipment category code classifying the asset type: M=Mechanical, E=Electrical, I=Instrumentation, P=Piping, V=Vessel/Reactor. Drives maintenance planning strategy and inspection requirements. [ENUM-REF-CANDIDATE: M|E|I|P|V|C|R — promote to reference product]' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable descriptive name or short description of the equipment asset (e.g., \'Reactor Feed Pump\', \'Distillation Column Overhead Condenser\'). Corresponds to SAP PM equipment description field.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Status' ;
    rdfs:comment 'Current operational lifecycle status of the equipment asset. Active=in normal service; Inactive=installed but not in service; Decommissioned=permanently removed from service; Standby=available as backup; Under_Maintenance=currently undergoing planned or corrective maintenance.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Area Classification' ;
    rdfs:comment 'Electrical area classification of the location where this equipment is installed, per NEC/IEC standards. Determines requirements for explosion-proof or intrinsically safe electrical equipment. Zone 0/1/2 per IEC 60079; Division 1/2 per NEC Article 500.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Interval Months' ;
    rdfs:comment 'Required inspection frequency in months as determined by regulatory requirements, risk-based inspection (RBI) analysis, or manufacturer recommendations. Used to auto-calculate next_inspection_date.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date the equipment was physically installed at its current functional location. Marks the start of the equipment\'s operational lifecycle at this site for maintenance history and warranty tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insulationType rdf:type rdf:Property ;
    rdfs:label 'Insulation Type' ;
    rdfs:comment 'Type of thermal or acoustic insulation applied to the equipment (e.g., mineral wool, calcium silicate, cellular glass, none). Relevant for corrosion under insulation (CUI) inspection programs and energy efficiency assessments.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePlannerGroup rdf:type rdf:Property ;
    rdfs:label 'Maintenance Planner Group' ;
    rdfs:comment 'SAP PM planner group code responsible for planning and scheduling maintenance activities for this equipment. Determines which maintenance team owns the equipment\'s work order planning.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Assigned maintenance strategy for this equipment asset: Time_Based=fixed interval preventive maintenance; Condition_Based=maintenance triggered by condition monitoring thresholds; Predictive=data-driven prediction of failure; Run_To_Failure=no planned maintenance; Reliability_Centered=RCM-derived strategy.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM). Used for spare parts sourcing, warranty claims, and technical support escalation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Date' ;
    rdfs:comment 'Date by which the next calibration of this instrument or measurement device must be completed to maintain traceability and compliance. Null if calibration_required is False.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Date of the next mandatory regulatory or internal inspection due for this equipment. Drives inspection scheduling for PSM mechanical integrity, API 510/570/653 inspections, and insurance surveys.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Operating Pressure Kpa' ;
    rdfs:comment 'Normal operating pressure of the equipment under standard process conditions, expressed in kilopascals (kPa). Used for process monitoring, deviation detection, and SPC control limit setting.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature C' ;
    rdfs:comment 'Normal operating temperature of the equipment under standard process conditions, expressed in degrees Celsius. Used for process monitoring, heat balance calculations, and corrosion rate estimation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piTagReference rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Reference' ;
    rdfs:comment 'Aveva PI System historian tag name or tag pattern associated with this equipment for real-time process data retrieval (e.g., temperature, pressure, flow readings). Enables linkage between equipment master data and real-time operational data.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pidTag rdf:type rdf:Property ;
    rdfs:label 'Pid Tag' ;
    rdfs:comment 'The P&ID tag number identifying this equipment on process engineering drawings (e.g., P-101A, E-201, V-301). Used for cross-referencing with Piping and Instrumentation Diagrams, HAZOP studies, and PSM documentation.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenter rdf:type rdf:Property ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'SAP PM work center responsible for executing maintenance activities on this equipment (e.g., MECH-01, ELEC-02, INST-03). Drives labor scheduling, capacity planning, and cost center assignment.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'Criticality classification of the functional location using the SAP PM ABC indicator. \'A\' = critical (production-critical, safety-critical), \'B\' = important (significant impact), \'C\' = non-critical (minimal impact). Drives maintenance prioritization, spare parts stocking, and OEE improvement focus. Corresponds to SAP PM IFLOT-ABCKZ.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingOrAreaCode rdf:type rdf:Property ;
    rdfs:label 'Building Or Area Code' ;
    rdfs:comment 'Physical building, bay, or plant area code where the functional location is situated. Used for maintenance crew routing, emergency response, and facility management. Complements the hierarchical floc_code with a physical location reference.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogProfileCode rdf:type rdf:Property ;
    rdfs:label 'Catalog Profile Code' ;
    rdfs:comment 'SAP PM catalog profile assigned to this functional location, defining the damage codes, cause codes, and activity codes available for maintenance notifications and work orders. Ensures standardized failure coding for reliability analysis and CAPA workflows. Corresponds to SAP PM IFLOT-RBNR.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionMaterial rdf:type rdf:Property ;
    rdfs:label 'Construction Material' ;
    rdfs:comment 'Primary material of construction for the functional location (e.g., \'Carbon Steel A516-70\', \'316L Stainless Steel\', \'Hastelloy C-276\', \'FRP\'). Critical for corrosion management, inspection planning, and chemical compatibility assessment under REACH and PSM requirements.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flocCode rdf:type rdf:Property ;
    rdfs:label 'Floc Code' ;
    rdfs:comment 'The externally-known alphanumeric code uniquely identifying the functional location within the plant hierarchy, as maintained in SAP PM (IFLOT-TPLNR). Follows the plant-unit-area-system-subsystem naming convention (e.g., CH01-RX-001-P-001). This is the business identifier used on work orders, P&IDs, and maintenance records.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorOrElevation rdf:type rdf:Property ;
    rdfs:label 'Floor Or Elevation' ;
    rdfs:comment 'Floor level or elevation reference (e.g., \'Grade Level\', \'EL +12.5m\', \'Mezzanine Level 2\') for the functional location within a building or structure. Supports maintenance crew navigation and emergency response planning.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationCategory rdf:type rdf:Property ;
    rdfs:label 'Functional Location Category' ;
    rdfs:comment 'Broad equipment category grouping for the functional location. Used for maintenance strategy segmentation, PSM mechanical integrity scope definition, and EHS compliance reporting. Aligns with ISO 14224 taxonomy. [ENUM-REF-CANDIDATE: process_equipment|utility_equipment|instrumentation|electrical|civil_structural|safety_system|environmental_control — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Functional Location Description' ;
    rdfs:comment 'Human-readable description of the functional location, describing its physical or logical purpose within the plant (e.g., \'Reactor Feed Pump — Unit 3 Ethylene Plant\'). Corresponds to SAP PM IFLOT-PLTXT.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoLatitude rdf:type rdf:Property ;
    rdfs:label 'Geo Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the functional location in decimal degrees (WGS84). Enables spatial analytics, emergency response planning, and integration with plant GIS systems for asset location visualization.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoLongitude rdf:type rdf:Property ;
    rdfs:label 'Geo Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the functional location in decimal degrees (WGS84). Enables spatial analytics, emergency response planning, and integration with plant GIS systems for asset location visualization.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionClass rdf:type rdf:Property ;
    rdfs:label 'Inspection Class' ;
    rdfs:comment 'Inspection methodology classification for this functional location. \'RBI\' (Risk-Based Inspection) applies to pressure equipment per API 580/581; \'fixed_interval\' for time-based statutory inspections; \'condition_based\' for CBM programs; \'run_to_failure\' for non-critical assets. Drives inspection planning and regulatory compliance.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this functional location record in the source system (SAP PM). Supports change tracking, data lineage, and master data governance audit requirements.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linearAssetFlag rdf:type rdf:Property ;
    rdfs:label 'Linear Asset Flag' ;
    rdfs:comment 'Indicates whether this functional location represents a linear asset (e.g., pipeline, cable tray, conveyor) as opposed to a point asset. Linear assets require linear reference measurement for inspection and maintenance location identification.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy Code' ;
    rdfs:comment 'SAP PM maintenance strategy assigned to this functional location, defining the preventive maintenance cycle (e.g., time-based, condition-based, predictive). Drives automatic generation of maintenance orders and inspection plans. Corresponds to SAP PM IFLOT-MSTRAT.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectType rdf:type rdf:Property ;
    rdfs:label 'Object Type' ;
    rdfs:comment 'SAP PM object type code classifying the functional location by equipment category (e.g., reactor, pump, heat exchanger, vessel, compressor, instrumentation). Drives maintenance strategy assignment and spare parts planning. Corresponds to SAP PM IFLOT-EQART. [ENUM-REF-CANDIDATE: reactor|pump|heat_exchanger|vessel|compressor|instrumentation|piping|column|tank|filter — promote to reference product]' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentFlocCode rdf:type rdf:Property ;
    rdfs:label 'Parent Floc Code' ;
    rdfs:comment 'The floc_code of the immediate parent node in the functional location hierarchy. Enables recursive traversal of the plant topology from plant down to sub-system level. Null for top-level plant nodes. Corresponds to SAP PM IFLOT-TPLMA.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pidReference rdf:type rdf:Property ;
    rdfs:label 'Pid Reference' ;
    rdfs:comment 'Reference number or drawing identifier of the P&ID document on which this functional location appears. Critical for PSM mechanical integrity, MOC workflows, and HAZOP studies. Enables traceability between the physical asset hierarchy and engineering drawings.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerGroupCode rdf:type rdf:Property ;
    rdfs:label 'Planner Group Code' ;
    rdfs:comment 'SAP PM planner group responsible for planning and scheduling maintenance activities at this functional location. Used for workload distribution, capacity planning, and maintenance KPI reporting. Corresponds to SAP PM IFLOT-INGRP.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureRatingBar rdf:type rdf:Property ;
    rdfs:label 'Pressure Rating Bar' ;
    rdfs:comment 'Maximum allowable working pressure (MAWP) for the functional location in bar units. Used for mechanical integrity assessments, inspection planning, and PSM compliance. Applies primarily to pressure vessels, reactors, and piping systems.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sortField rdf:type rdf:Property ;
    rdfs:label 'Sort Field' ;
    rdfs:comment 'Alphanumeric sort field used for grouping and filtering functional locations in maintenance reports and work order lists. Typically encodes plant area, equipment class, or operational unit for reporting convenience. Corresponds to SAP PM IFLOT-EQFNR.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRatingC rdf:type rdf:Property ;
    rdfs:label 'Temperature Rating C' ;
    rdfs:comment 'Maximum allowable design temperature for the functional location in degrees Celsius. Used for material selection validation, mechanical integrity assessments, and process safety compliance.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionRoundId rdf:type rdf:Property ;
    rdfs:label 'Inspection Round Id' ;
    rdfs:comment 'Unique identifier for the inspection round record. Primary key for the inspection round entity.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checklistTemplateId rdf:type rdf:Property ;
    rdfs:label 'Checklist Template Id' ;
    rdfs:comment 'Reference to the structured checklist template used during this inspection round. Defines the inspection points, parameters, and acceptance criteria.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChecklistTemplate .

ind:followUpWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Follow Up Work Order Id' ;
    rdfs:comment 'Reference to the primary maintenance work order created to address findings from this inspection round. Links inspection findings to corrective maintenance actions.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:primaryInspectionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Employee Id' ;
    rdfs:comment 'Reference to the user or employee who performed the inspection round. Links to workforce/employee master data.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Reference to the predefined inspection route or path that defines the sequence of equipment and checkpoints to be inspected during this round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionRoute .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Date and time when the inspection round was completed. Used to calculate inspection duration and verify compliance with scheduled intervals.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether the inspection round results require formal approval by a supervisor, engineer, or regulatory authority before being finalized.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceDueDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Due Date' ;
    rdfs:comment 'Regulatory or statutory deadline by which this inspection must be completed to maintain compliance. Overdue inspections may result in regulatory violations or insurance coverage issues.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deviationsFoundCount rdf:type rdf:Property ;
    rdfs:label 'Deviations Found Count' ;
    rdfs:comment 'Number of deviations, anomalies, or out-of-specification conditions identified during the inspection round. Triggers follow-up actions and work orders.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:highestSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Severity Level' ;
    rdfs:comment 'The most severe classification level among all deviations found during the inspection round. Critical findings require immediate action; high findings require urgent attention; medium and low findings are tracked for planned maintenance.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Inspection Findings Summary' ;
    rdfs:comment 'High-level summary text describing the overall findings, observations, and conclusions from the inspection round. Provides executive-level overview of inspection results.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Interval Days' ;
    rdfs:comment 'Defined interval in days between successive inspection rounds for this equipment or route. Based on regulatory requirements, manufacturer recommendations, or risk-based inspection methodology.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectorNotes rdf:type rdf:Property ;
    rdfs:label 'Inspector Notes' ;
    rdfs:comment 'Free-form text field for inspector comments, observations, and contextual information not captured in structured checklist fields. Provides qualitative insights and situational context.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorQualificationCode rdf:type rdf:Property ;
    rdfs:label 'Inspector Qualification Code' ;
    rdfs:comment 'Code representing the qualification or certification level of the inspector performing the round. Ensures inspections are performed by appropriately trained personnel per OSHA PSM and API requirements.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Carrier Code' ;
    rdfs:comment 'Code identifying the insurance carrier for whom this inspection is performed or to whom results must be reported.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Inspection Flag' ;
    rdfs:comment 'Indicates whether this inspection round is required by or performed for insurance carrier compliance. Insurance carriers often mandate periodic inspections of pressure vessels, boilers, and critical equipment.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mocReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Moc Reference Number' ;
    rdfs:comment 'Reference number of the MOC workflow initiated as a result of this inspection round findings. Links inspection to change management process.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Date' ;
    rdfs:comment 'Calculated date for the next inspection round based on the inspection interval and completion date of this round. Used for forward planning and scheduling.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:psmMechanicalIntegrityFlag rdf:type rdf:Property ;
    rdfs:label 'Psm Mechanical Integrity Flag' ;
    rdfs:comment 'Indicates whether this inspection round is part of the PSM mechanical integrity program required by OSHA for process equipment handling highly hazardous chemicals.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRequirementCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Code' ;
    rdfs:comment 'Code identifying the specific regulatory or statutory requirement that mandates this inspection (e.g., OSHA PSM, API 510, API 570, API 653, insurance carrier requirement, local jurisdiction code).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundNumber rdf:type rdf:Property ;
    rdfs:label 'Round Number' ;
    rdfs:comment 'Business identifier for the inspection round. Externally visible unique number used for tracking and reference in maintenance systems and compliance documentation.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundType rdf:type rdf:Property ;
    rdfs:label 'Round Type' ;
    rdfs:comment 'Classification of the inspection round activity. Operator rounds are routine operational checks; predictive inspections use condition monitoring; statutory/regulatory inspections meet legal requirements; PSM mechanical integrity inspections support Process Safety Management programs; safety device inspections verify critical safety equipment.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether this inspection round covers safety-critical equipment or systems that are subject to Process Safety Management (PSM) mechanical integrity requirements.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned date when the inspection round is scheduled to be performed. Used for planning and resource allocation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCheckpointsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Checkpoints Completed' ;
    rdfs:comment 'Actual number of inspection checkpoints completed during the round. Used to track inspection progress and completeness.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCheckpointsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Checkpoints Planned' ;
    rdfs:comment 'Total number of inspection checkpoints or measurement points planned for this round based on the route and checklist definition.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workOrderGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Work Order Generated Flag' ;
    rdfs:comment 'Indicates whether one or more maintenance work orders were automatically generated as a result of deviations or findings from this inspection round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementPointId rdf:type rdf:Property ;
    rdfs:label 'Measurement Point Id' ;
    rdfs:comment 'Unique identifier for the measurement point record. Primary key.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementPoint .

ind:marketPriceIndexId rdf:type rdf:Property ;
    rdfs:label 'Market Price Index Id' ;
    rdfs:comment 'Foreign key linking to pricing.market_price_index. Business justification: Raw-material measurement points are tied to market price indices for dynamic cost adjustments in pricing calculations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketPriceIndex .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the measurement point was activated and monitoring began. Used for historical analysis and compliance documentation.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Planned interval in days between calibration activities for this measurement point. Supports compliance with ISO 9001 and GMP requirements.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Required Flag' ;
    rdfs:comment 'Indicates whether this measurement point requires periodic calibration to maintain accuracy and compliance with quality and safety standards.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:characteristicCode rdf:type rdf:Property ;
    rdfs:label 'Characteristic Code' ;
    rdfs:comment 'Code identifying the physical characteristic being measured (e.g., vibration, temperature, pressure, flow rate, pH, operating hours). Aligns with plant instrumentation standards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicDescription rdf:type rdf:Property ;
    rdfs:label 'Characteristic Description' ;
    rdfs:comment 'Human-readable description of the characteristic being measured at this point.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterOverflowValue rdf:type rdf:Property ;
    rdfs:label 'Counter Overflow Value' ;
    rdfs:comment 'Maximum value at which a counter-type measurement point resets to zero. Used for cumulative counters such as operating hours or cycle counts.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalityCode rdf:type rdf:Property ;
    rdfs:label 'Criticality Code' ;
    rdfs:comment 'Classification of the measurement points importance to safety, environmental compliance, product quality, or equipment reliability. Drives prioritization of monitoring and maintenance activities.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'System or method by which measurement readings are captured: manual entry, Distributed Control System (DCS), Supervisory Control and Data Acquisition (SCADA), Laboratory Information Management System (LIMS), or process historian.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Decimal Places' ;
    rdfs:comment 'Number of decimal places to which measurement values should be recorded and displayed, ensuring precision consistency.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historianTag rdf:type rdf:Property ;
    rdfs:label 'Historian Tag' ;
    rdfs:comment 'Tag identifier in the process historian system (e.g., Aveva PI System) that stores time-series data for this measurement point. Enables integration with real-time process data.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date when the measurement point or associated instrument was last calibrated. Used to track calibration compliance and schedule next calibration.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReadingDate rdf:type rdf:Property ;
    rdfs:label 'Last Reading Date' ;
    rdfs:comment 'Date when the most recent measurement reading was recorded for this point. Used to track compliance with reading schedules.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReadingValue rdf:type rdf:Property ;
    rdfs:label 'Last Reading Value' ;
    rdfs:comment 'The most recent measurement value recorded at this point. Provides current state for condition monitoring and trend analysis.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerAlarmLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Alarm Limit' ;
    rdfs:comment 'Lower critical threshold that triggers an alarm and may require immediate maintenance action or equipment shutdown per Process Safety Management (PSM) requirements.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerWarningLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Warning Limit' ;
    rdfs:comment 'Lower threshold value that triggers a warning alert when measurement falls below this level. Part of condition-based maintenance strategy.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPointStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Point Status' ;
    rdfs:comment 'Current lifecycle status of the measurement point. Active points are monitored per schedule; inactive or decommissioned points are no longer in use.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPosition rdf:type rdf:Property ;
    rdfs:label 'Measurement Position' ;
    rdfs:comment 'Specific physical location or position on the equipment where the measurement is taken (e.g., bearing housing north side, inlet flange, discharge line). References Piping and Instrumentation Diagram (P&ID) tag.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next calibration activity based on calibration frequency. Critical for maintaining measurement accuracy and regulatory compliance.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReadingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reading Due Date' ;
    rdfs:comment 'Scheduled date for the next measurement reading based on the reading frequency. Used for work order generation and compliance tracking.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Oee Relevant Flag' ;
    rdfs:comment 'Indicates whether this measurement point contributes to Overall Equipment Effectiveness (OEE) calculations, such as operating hours, cycle counts, or production rates.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointCategory rdf:type rdf:Property ;
    rdfs:label 'Point Category' ;
    rdfs:comment 'Classification of the measurement point type: counter (cumulative readings such as operating hours) or measurement (instantaneous readings such as temperature or pressure).' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointDescription rdf:type rdf:Property ;
    rdfs:label 'Point Description' ;
    rdfs:comment 'Detailed textual description of the measurement point, including its physical location on the equipment and what is being measured.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointNumber rdf:type rdf:Property ;
    rdfs:label 'Point Number' ;
    rdfs:comment 'Business identifier for the measurement point, typically alphanumeric code used in operations and maintenance documentation.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Reading Frequency Days' ;
    rdfs:comment 'Planned interval in days between successive readings of this measurement point. Supports preventive and condition-based maintenance scheduling.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensorType rdf:type rdf:Property ;
    rdfs:label 'Sensor Type' ;
    rdfs:comment 'Type of sensor or instrument used to capture the measurement (e.g., thermocouple, pressure transmitter, vibration sensor, flow meter, pH probe).' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagNumber rdf:type rdf:Property ;
    rdfs:label 'Tag Number' ;
    rdfs:comment 'Unique tag identifier from the Piping and Instrumentation Diagram (P&ID) for the instrument or sensor associated with this measurement point. Aligns with ISA standards.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperAlarmLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Alarm Limit' ;
    rdfs:comment 'Upper critical threshold that triggers an alarm and may require immediate maintenance action or equipment shutdown per Process Safety Management (PSM) requirements.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperWarningLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Warning Limit' ;
    rdfs:comment 'Upper threshold value that triggers a warning alert when measurement exceeds this level. Part of condition-based maintenance strategy.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementReadingId rdf:type rdf:Property ;
    rdfs:label 'Measurement Reading Id' ;
    rdfs:comment 'Unique identifier for the measurement reading record. Primary key for the measurement reading entity.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationId rdf:type rdf:Property ;
    rdfs:label 'Notification Id' ;
    rdfs:comment 'Reference to the maintenance notification that was automatically generated when this reading violated threshold limits. Supports condition-based maintenance triggering.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Notification .

ind:pmPlanId rdf:type rdf:Property ;
    rdfs:label 'Pm Plan Id' ;
    rdfs:comment 'Reference to the preventive maintenance plan that scheduled this measurement reading. Links measurement data to planned maintenance strategies.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PmPlan .

ind:annotation rdf:type rdf:Property ;
    rdfs:label 'Annotation' ;
    rdfs:comment 'Free-text notes or comments entered by the reader or reviewer regarding the measurement reading. Used to document unusual conditions, context, or corrective actions taken.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterOverflowFlag rdf:type rdf:Property ;
    rdfs:label 'Counter Overflow Flag' ;
    rdfs:comment 'Boolean indicator that is true when a counter reading has rolled over or reset. Used to maintain accurate cumulative totals across counter resets.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterReadingFlag rdf:type rdf:Property ;
    rdfs:label 'Counter Reading Flag' ;
    rdfs:comment 'Boolean indicator that is true when this reading represents a cumulative counter value (such as operating hours, cycle count, production volume) rather than an instantaneous measurement.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationFromTarget rdf:type rdf:Property ;
    rdfs:label 'Deviation From Target' ;
    rdfs:comment 'The calculated difference between the measured value and the target value. Positive values indicate readings above target, negative values indicate readings below target. Used for trend analysis and condition monitoring.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Deviation Percentage' ;
    rdfs:comment 'The percentage deviation of the measured value from the target value. Calculated as (measured_value - target_value) / target_value * 100. Enables normalized comparison across different measurement points.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual numeric value captured by the measurement reading. Represents the observed quantity such as temperature, pressure, flow rate, vibration, pH, or counter reading.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Measurement Characteristic' ;
    rdfs:comment 'The physical or operational characteristic being measured. Examples include temperature, pressure, vibration, flow rate, pH, conductivity, viscosity, level, speed, power consumption.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Document Number' ;
    rdfs:comment 'External business identifier for the measurement document. Used for traceability and cross-system reference.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCode rdf:type rdf:Property ;
    rdfs:label 'Quality Code' ;
    rdfs:comment 'Data quality indicator for the measurement reading. Good indicates reliable data, bad indicates known error, uncertain indicates possible error, substituted indicates estimated value, questionable indicates requires review.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingDate rdf:type rdf:Property ;
    rdfs:label 'Reading Date' ;
    rdfs:comment 'Calendar date when the measurement reading was taken. Used for day-level aggregation and reporting.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readingStatus rdf:type rdf:Property ;
    rdfs:label 'Reading Status' ;
    rdfs:comment 'Current validation status of the measurement reading. Indicates whether the reading has been reviewed, approved, or flagged for quality issues.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'Date and time when the measurement reading was actually captured in the field or by the sensor. Represents the real-world event time of the observation.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readingType rdf:type rdf:Property ;
    rdfs:label 'Reading Type' ;
    rdfs:comment 'Classification of how the reading was obtained. Actual indicates direct measurement, estimated indicates interpolated or approximated value, calculated indicates derived from other readings, manual indicates human-entered, automatic indicates sensor-captured.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Threshold Violation Flag' ;
    rdfs:comment 'Boolean indicator that is true when the measured value falls outside the defined warning or alarm limits. Used to trigger maintenance notifications and condition-based maintenance workflows.' ;
    rdfs:domain ind:MeasurementReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationActivityCodeMaintenanceCatalogCatalogCodeId rdf:type rdf:Property ;
    rdfs:label 'Notification Activity Code Maintenance Catalog Catalog Code Id' ;
    rdfs:comment 'Reference to the catalog code describing the corrective activity or repair action required (e.g., replace seal, recalibrate instrument, clean filter).' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogCode .

ind:notificationCatalogCodeId rdf:type rdf:Property ;
    rdfs:label 'Notification Catalog Code Id' ;
    rdfs:comment 'Reference to the catalog code describing the type of damage or defect observed (e.g., corrosion, wear, leakage, electrical failure). Supports Pareto analysis of failure modes.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogCode .

ind:notificationCauseCodeMaintenanceCatalogCatalogCodeId rdf:type rdf:Property ;
    rdfs:label 'Notification Cause Code Maintenance Catalog Catalog Code Id' ;
    rdfs:comment 'Reference to the catalog code identifying the root cause of the failure (e.g., material fatigue, operator error, design flaw, inadequate maintenance). Critical for Root Cause Investigation (RCI) and Corrective and Preventive Action (CAPA) workflows.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogCode .

ind:breakdownIndicator rdf:type rdf:Property ;
    rdfs:label 'Breakdown Indicator' ;
    rdfs:comment 'Flag indicating whether this notification represents a complete equipment breakdown (true) or a partial malfunction/defect (false). Critical for MTBF and reliability analysis.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Cross-reference to the CAPA workflow document if a formal corrective action plan was created.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Capa Required Indicator' ;
    rdfs:comment 'Flag indicating whether the notification requires a formal Corrective and Preventive Action (CAPA) workflow to prevent recurrence.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:malfunctionStartDate rdf:type rdf:Property ;
    rdfs:label 'Malfunction Start Date' ;
    rdfs:comment 'Date when the defect or malfunction was first observed, which may differ from the reported date if discovered retrospectively.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:malfunctionStartTime rdf:type rdf:Property ;
    rdfs:label 'Malfunction Start Time' ;
    rdfs:comment 'Time of day when the malfunction started, in HH:MM format. Used in conjunction with malfunction_start_date for precise event timing.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mocRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Moc Required Indicator' ;
    rdfs:comment 'Flag indicating whether the corrective action requires a formal Management of Change (MOC) review due to process equipment modification or operating parameter change. Critical for PSM compliance.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Externally visible business identifier for the maintenance notification, typically a 10-12 digit system-generated number used for tracking and communication.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the notification: outstanding (newly created), in_progress (under investigation or work order created), completed (resolved), cancelled (no action required).' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Classification of the notification: M1 (Malfunction/Breakdown), M2 (Activity Request), M3 (Inspection Finding), M4 (Other). Determines workflow and priority handling.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionImpactIndicator rdf:type rdf:Property ;
    rdfs:label 'Production Impact Indicator' ;
    rdfs:comment 'Flag indicating whether the malfunction or breakdown caused a production stoppage or throughput reduction (true) or had no production impact (false).' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rciRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Rci Required Indicator' ;
    rdfs:comment 'Flag indicating whether the failure severity or recurrence pattern requires a formal Root Cause Investigation (RCI) or Root Cause Analysis (RCA).' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the notification was created in the system. Used for response time analysis and notification aging reports.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredEndDate rdf:type rdf:Property ;
    rdfs:label 'Required End Date' ;
    rdfs:comment 'Target date by which the issue must be resolved to avoid production impact or regulatory non-compliance.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredStartDate rdf:type rdf:Property ;
    rdfs:label 'Required Start Date' ;
    rdfs:comment 'Target date by which corrective action or work order execution should begin, based on priority and production schedule impact.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyIndicator rdf:type rdf:Property ;
    rdfs:label 'Safety Indicator' ;
    rdfs:comment 'Flag indicating whether the notification involves a safety hazard, near-miss, or condition that could lead to injury or environmental release. Triggers Process Safety Management (PSM) review.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Work Order Created Date' ;
    rdfs:comment 'Date when the work order was created in response to this notification. Used to calculate notification-to-work-order response time.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitToWorkId rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Id' ;
    rdfs:comment 'Unique identifier for the permit to work record. Primary key for the permit to work entity.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alt5PermitAttendantUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Permit Attendant User Employee Id' ;
    rdfs:comment 'Reference to the person assigned as confined space attendant who remains outside the space to monitor entrants and initiate rescue if needed.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alt5PermitClosedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Permit Closed By User Employee Id' ;
    rdfs:comment 'Reference to the authorized person who closed the permit after verifying work completion and area safety.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPermitEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Permit Employee Id' ;
    rdfs:comment 'Reference to the authorized person who issued and approved the permit. Must be a qualified individual with authority to authorize work in hazardous areas.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryPermitSafetyOfficerUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Permit Safety Officer User Employee Id' ;
    rdfs:comment 'Reference to the Environment Health and Safety (EHS) officer who reviewed and approved the permit from a safety compliance perspective.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryPermitFireWatchUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Permit Fire Watch User Employee Id' ;
    rdfs:comment 'Reference to the person assigned as fire watch for hot work operations. Must be trained in fire prevention and emergency response.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPermitAreaAuthorityUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Permit Area Authority User Employee Id' ;
    rdfs:comment 'Reference to the operations supervisor or area owner who has authority over the work location and must approve work in their area.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the permit was formally closed after work completion and area inspection confirmed safe conditions restored.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closureConfirmation rdf:type rdf:Property ;
    rdfs:label 'Closure Confirmation' ;
    rdfs:comment 'Documentation confirming that all work is complete, all tools and materials removed, all isolations restored, area cleaned, and safe conditions verified before permit closure.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confinedSpaceEntryFlag rdf:type rdf:Property ;
    rdfs:label 'Confined Space Entry Flag' ;
    rdfs:comment 'Indicates whether the work involves entry into a permit-required confined space as defined by OSHA 1910.146. Triggers additional safety requirements.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireWatchRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fire Watch Required Flag' ;
    rdfs:comment 'Indicates whether a dedicated fire watch person must be present during hot work operations to monitor for ignition and respond to fire emergencies.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gasTestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gas Test Required Flag' ;
    rdfs:comment 'Indicates whether atmospheric testing for oxygen, flammable gases, and toxic gases is required before and during the work.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gasTestResults rdf:type rdf:Property ;
    rdfs:label 'Gas Test Results' ;
    rdfs:comment 'Results of atmospheric testing including oxygen percentage, lower explosive limit (LEL) readings, and toxic gas concentrations. Recorded before work begins and at specified intervals.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardIdentification rdf:type rdf:Property ;
    rdfs:label 'Hazard Identification' ;
    rdfs:comment 'Comprehensive identification of all hazards present in the work area including chemical, physical, biological, and process hazards. Critical for risk assessment and control measures.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationRequirements rdf:type rdf:Property ;
    rdfs:label 'Isolation Requirements' ;
    rdfs:comment 'Specific isolation and lockout/tagout requirements for the work including electrical isolation, mechanical isolation, line blanking, and energy isolation procedures.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when the permit was officially issued and approved by the issuing authority.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lelPercent rdf:type rdf:Property ;
    rdfs:label 'Lel Percent' ;
    rdfs:comment 'Measured flammable gas concentration as percentage of lower explosive limit. Must be below threshold (typically <10% LEL) for hot work authorization.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxygenLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Oxygen Level Percent' ;
    rdfs:comment 'Measured oxygen concentration in the work area atmosphere expressed as percentage. Must be within safe range (typically 19.5% to 23.5%) for entry.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the permit to work. Tracks the permit from initial request through closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescuePlan rdf:type rdf:Property ;
    rdfs:label 'Rescue Plan' ;
    rdfs:comment 'Documented rescue and emergency response plan for confined space entry or other high-risk work. Includes rescue equipment, procedures, and emergency contacts.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Shutdown Required Flag' ;
    rdfs:comment 'Indicates whether the work requires a process unit shutdown or can be performed during normal operations.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialPrecautions rdf:type rdf:Property ;
    rdfs:label 'Special Precautions' ;
    rdfs:comment 'Additional safety precautions, restrictions, or conditions specific to this permit beyond standard requirements. May include weather restrictions, simultaneous operations restrictions, or special monitoring requirements.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toxicGasPpm rdf:type rdf:Property ;
    rdfs:label 'Toxic Gas Ppm' ;
    rdfs:comment 'Measured concentration of toxic gases in parts per million. Must be below permissible exposure limits for the specific chemicals present.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valid From Timestamp' ;
    rdfs:comment 'Date and time when the permit becomes effective and work is authorized to begin. Marks the start of the permits validity period.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validUntilTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valid Until Timestamp' ;
    rdfs:comment 'Date and time when the permit expires and work must cease. Permits typically have limited duration (e.g., 8 hours, 12 hours, or one shift) and must be renewed if work continues.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workDescription rdf:type rdf:Property ;
    rdfs:label 'Work Description' ;
    rdfs:comment 'Detailed description of the maintenance or construction activity to be performed under this permit. Includes scope, methods, and expected outcomes.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceStrategyId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy Id' ;
    rdfs:comment 'Reference to the maintenance strategy defining cycle packages and intervals (e.g., 3-month inspection, 6-month service, 12-month overhaul, 5-year major turnaround). Used for strategy_plan type.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Strategy .

ind:rbiAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Rbi Assessment Id' ;
    rdfs:comment 'Reference to the RBI assessment that optimized the inspection interval for this PM plan based on probability of failure and consequence of failure analysis. Supports API 580/581 RBI methodology.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RbiAssessment .

ind:taskListId rdf:type rdf:Property ;
    rdfs:label 'Task List Id' ;
    rdfs:comment 'Reference to the task list (general maintenance task list, equipment task list, functional location task list) defining the standardized work procedures, operations, materials, and labor for this PM plan.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaskList .

ind:autoGenerateWorkOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generate Work Order Flag' ;
    rdfs:comment 'Indicates whether the system automatically generates work orders when maintenance calls are created, or whether manual planner review and approval is required before work order creation.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Call Horizon Days' ;
    rdfs:comment 'Number of days in advance that the system generates maintenance call objects (schedule lines) before the planned date. Enables proactive work order creation and resource planning.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterReadingAtLastMaintenance rdf:type rdf:Property ;
    rdfs:label 'Counter Reading At Last Maintenance' ;
    rdfs:comment 'Performance counter value (operating hours, production cycles, runtime hours) recorded at the time of last maintenance completion. Used for counter-based scheduling.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterThresholdForNextMaintenance rdf:type rdf:Property ;
    rdfs:label 'Counter Threshold For Next Maintenance' ;
    rdfs:comment 'Performance counter value that triggers the next maintenance call for counter-based plans (e.g., next PM at 10,000 operating hours).' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleLength rdf:type rdf:Property ;
    rdfs:label 'Cycle Length' ;
    rdfs:comment 'Numeric value defining the interval between maintenance activities in the specified cycle_unit (e.g., 90 days, 500 operating hours, 1000 production cycles).' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleUnit rdf:type rdf:Property ;
    rdfs:label 'Cycle Unit' ;
    rdfs:comment 'Unit of measure for the maintenance cycle interval: day, week, month, year (time-based), operating_hour, runtime_hour (performance-based), production_cycle, batch_count (counter-based). [ENUM-REF-CANDIDATE: day|week|month|year|operating_hour|production_cycle|batch_count|runtime_hour — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Code' ;
    rdfs:comment 'Code identifying the regulatory inspection requirement driving this PM plan (API 510 pressure vessel inspection, API 570 piping inspection, API 653 tank inspection, ASME boiler inspection, PSM mechanical integrity inspection). Links to compliance frameworks.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Flag' ;
    rdfs:comment 'Indicates whether this PM plan is mandated by insurance carrier requirements for boilers, pressure vessels, or other insured equipment. Compliance affects insurance coverage.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date when the last preventive maintenance activity was completed under this plan. Used to calculate the next scheduled maintenance date based on cycle length.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the PM plan: active (generating calls), inactive (not generating calls), suspended (temporarily paused), completed (end date reached), cancelled (permanently terminated).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Pm Plan Description' ;
    rdfs:comment 'Detailed textual description of the PM plan purpose, scope, and maintenance objectives. Includes equipment context, maintenance rationale, and special instructions.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingIndicator rdf:type rdf:Property ;
    rdfs:label 'Scheduling Indicator' ;
    rdfs:comment 'Defines how the PM plan generates maintenance calls: time_based (calendar intervals), performance_based (operating hours, cycles, production volume), condition_based (sensor thresholds, inspection findings), fixed_date (specific calendar dates), annual (yearly recurrence), seasonal (tied to production seasons or weather).' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingToleranceAfterDays rdf:type rdf:Property ;
    rdfs:label 'Scheduling Tolerance After Days' ;
    rdfs:comment 'Number of days after the planned date that maintenance can be performed without resetting the cycle counter. Provides flexibility for delayed execution.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schedulingToleranceBeforeDays rdf:type rdf:Property ;
    rdfs:label 'Scheduling Tolerance Before Days' ;
    rdfs:comment 'Number of days before the planned date that maintenance can be performed without resetting the cycle counter. Provides flexibility for early execution.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Flag' ;
    rdfs:comment 'Indicates whether the PM plan schedule is adjusted for seasonal production patterns (e.g., agricultural chemical production peaks, winter shutdown periods, summer turnaround windows).' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalAdjustmentMonths rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Months' ;
    rdfs:comment 'Comma-separated list of month numbers (1-12) when seasonal adjustments apply to the PM schedule. Used in conjunction with seasonal_adjustment_flag.' ;
    rdfs:domain ind:PmPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCallId rdf:type rdf:Property ;
    rdfs:label 'Schedule Call Id' ;
    rdfs:comment 'Primary key for schedule_call' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Generation Timestamp' ;
    rdfs:comment 'Timestamp when this schedule call item was automatically generated by the maintenance planning system.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callNumber rdf:type rdf:Property ;
    rdfs:label 'Call Number' ;
    rdfs:comment 'Business identifier for the scheduled maintenance call, typically a sequential number within the maintenance plan.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callObjectType rdf:type rdf:Property ;
    rdfs:label 'Call Object Type' ;
    rdfs:comment 'Type of technical object that this maintenance call is scheduled for.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callStatus rdf:type rdf:Property ;
    rdfs:label 'Call Status' ;
    rdfs:comment 'Current lifecycle status of the scheduled maintenance call item.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterReadingAtCall rdf:type rdf:Property ;
    rdfs:label 'Counter Reading At Call' ;
    rdfs:comment 'The equipment counter reading (operating hours, cycles, production volume) at the time this maintenance call was generated, for performance-based maintenance scheduling.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Counter Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the counter reading (hours, cycles, kilometers, batches, etc.).' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cycle Number' ;
    rdfs:comment 'Sequential cycle number within the maintenance plan, indicating which iteration of the recurring maintenance this call represents.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of days this maintenance call is overdue beyond the tolerance window. Null or zero if not overdue.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Estimated time in hours required to complete the scheduled maintenance activity.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOverdue rdf:type rdf:Property ;
    rdfs:label 'Is Overdue' ;
    rdfs:comment 'Boolean flag indicating whether this scheduled maintenance call is past its due date and tolerance window.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceActivityType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Activity Type' ;
    rdfs:comment 'Classification of the maintenance activity to be performed (inspection, lubrication, calibration, overhaul, cleaning, etc.).' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceDaysEarly rdf:type rdf:Property ;
    rdfs:label 'Tolerance Days Early' ;
    rdfs:comment 'Number of days before the scheduled date that the maintenance can be performed and still be considered on-time.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceDaysLate rdf:type rdf:Property ;
    rdfs:label 'Tolerance Days Late' ;
    rdfs:comment 'Number of days after the scheduled date that the maintenance can be performed before being considered overdue.' ;
    rdfs:domain ind:ScheduleCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:craftSkillRequired rdf:type rdf:Property ;
    rdfs:label 'Craft Skill Required' ;
    rdfs:comment 'Skill or qualification code required for personnel performing the operation.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentClassification rdf:type rdf:Property ;
    rdfs:label 'Equipment Classification' ;
    rdfs:comment 'Classification of equipment for which the task list is applicable (e.g., reactor, pump).' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Monetary estimate of labor cost for the task list.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Total labor hours estimated for the entire task list.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalLocationCode rdf:type rdf:Property ;
    rdfs:label 'Functional Location Code' ;
    rdfs:comment 'Code of the functional location scope when type is functional_location.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Template' ;
    rdfs:comment 'True if the record represents a reusable template (always true for task_list).' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Timestamp of the most recent work order generation from this task list.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lockoutTagoutRequired rdf:type rdf:Property ;
    rdfs:label 'Lockout Tagout Required' ;
    rdfs:comment 'Indicates whether lockout/tagout procedures are mandatory for the operation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialRequirements rdf:type rdf:Property ;
    rdfs:label 'Material Requirements' ;
    rdfs:comment 'List of materials and quantities needed for the operation.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationDescription rdf:type rdf:Property ;
    rdfs:label 'Operation Description' ;
    rdfs:comment 'Detailed description of the work to be performed in this step.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationStepNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Step Number' ;
    rdfs:comment 'Sequential number of the operation within the task list.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'Estimated labor time required for the operation.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHoursUnit rdf:type rdf:Property ;
    rdfs:label 'Planned Hours Unit' ;
    rdfs:comment 'Unit of measure for planned hours.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPrecautions rdf:type rdf:Property ;
    rdfs:label 'Safety Precautions' ;
    rdfs:comment 'Safety instructions, PPE, and lockout/tagout notes for the operation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCategory rdf:type rdf:Property ;
    rdfs:label 'Task Category' ;
    rdfs:comment 'High-level category of maintenance activity the task list supports.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskListCode rdf:type rdf:Property ;
    rdfs:label 'Task List Code' ;
    rdfs:comment 'Business identifier or code (e.g., PLKO) used in SAP PM to reference the task list.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskListDescription rdf:type rdf:Property ;
    rdfs:label 'Task List Description' ;
    rdfs:comment 'Detailed free-text description of the purpose and scope of the task list.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskListName rdf:type rdf:Property ;
    rdfs:label 'Task List Name' ;
    rdfs:comment 'Human-readable name of the task list used by planners and technicians.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskListStatus rdf:type rdf:Property ;
    rdfs:label 'Task List Status' ;
    rdfs:comment 'Current lifecycle status of the task list.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskListType rdf:type rdf:Property ;
    rdfs:label 'Task List Type' ;
    rdfs:comment 'Classification of the task list: equipment-specific, functional-location-specific, or general.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolRequirements rdf:type rdf:Property ;
    rdfs:label 'Tool Requirements' ;
    rdfs:comment 'List of tools or equipment required to complete the operation.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual total duration of the maintenance work in hours, calculated from start to completion timestamps. Used for performance analysis and future work estimation.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'Actual total cost of internal labor based on confirmed hours and standard or actual labor rates. Used for maintenance cost accounting and variance analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual total labor hours consumed across all crafts and operations, confirmed through time confirmations. Used for cost accounting and productivity analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Actual Material Cost' ;
    rdfs:comment 'Actual total cost of spare parts, materials, and consumables consumed during work order execution, based on goods issue transactions and purchase order receipts.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Detailed notes recorded by the maintenance crew upon work completion, documenting work performed, parts replaced, test results, and any deviations from planned scope.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of the corrective action taken to address the root cause and prevent recurrence. Part of the Corrective and Preventive Action (CAPA) process.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Hours' ;
    rdfs:comment 'Actual duration in hours that the equipment or process unit was offline due to this maintenance work. Used for Overall Equipment Effectiveness (OEE) calculation and production loss analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeRequired rdf:type rdf:Property ;
    rdfs:label 'Downtime Required' ;
    rdfs:comment 'Indicates whether this maintenance work requires taking the equipment or process unit offline. True for intrusive maintenance; false for online maintenance activities.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Material Cost' ;
    rdfs:comment 'Planned total cost of spare parts, materials, and consumables required for this work order. Used for budget planning and work order approval.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalServiceCost rdf:type rdf:Property ;
    rdfs:label 'External Service Cost' ;
    rdfs:comment 'Total cost of external contractor services, third-party vendors, or specialized service providers engaged for this work order. Includes service labor, equipment rental, and contractor-supplied materials.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longText rdf:type rdf:Property ;
    rdfs:label 'Long Text' ;
    rdfs:comment 'Detailed instructions, technical notes, safety precautions, and procedural guidance for executing the maintenance work. May include references to Standard Operating Procedures (SOP), Process and Instrumentation Diagrams (P&ID), or special tools required.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkNumber rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Number' ;
    rdfs:comment 'Reference number of the safety permit authorizing this maintenance work, required for work in hazardous areas, confined spaces, hot work, or energized equipment per Process Safety Management (PSM) requirements.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date when maintenance work is scheduled to be completed. Used for outage planning and production restart coordination.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when maintenance work is scheduled to begin. Used for capacity planning and coordination with production schedules.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total actual cost of the work order including internal labor, materials, and external services. Used for maintenance cost reporting and asset lifecycle cost analysis.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Work Order Description' ;
    rdfs:comment 'Short text description of the maintenance work to be performed, summarizing the scope and nature of the activity for quick identification and communication.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally visible business identifier for the work order, typically system-generated and used for tracking and communication across maintenance teams and external service providers.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle status of the work order tracking progression from creation through execution to closure. Released status indicates work is approved and ready for execution; completed indicates work is finished but administrative closure pending. [ENUM-REF-CANDIDATE: created|released|in_progress|on_hold|completed|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the maintenance work order indicating the nature of the maintenance activity: planned maintenance, corrective repair, preventive maintenance schedule, predictive maintenance based on condition monitoring, emergency breakdown response, or capital project work.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the maintenance activity being performed (e.g., mechanical repair, electrical work, instrumentation calibration, inspection). Used for cost allocation and capacity planning.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Date and time when work on the operation was completed, as recorded in the final time confirmation.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualWorkDuration rdf:type rdf:Property ;
    rdfs:label 'Actual Work Duration' ;
    rdfs:comment 'Actual labor hours spent on the operation as recorded through time confirmations. Used for performance analysis and variance reporting.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualWorkUnit rdf:type rdf:Property ;
    rdfs:label 'Actual Work Unit' ;
    rdfs:comment 'Unit of measure for actual work duration. H=hours, MIN=minutes, D=days.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationKey rdf:type rdf:Property ;
    rdfs:label 'Calculation Key' ;
    rdfs:comment 'Key that determines how operation duration is calculated based on work quantity and standard values. Used for automatic time calculation in preventive maintenance.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Confirmation Required Flag' ;
    rdfs:comment 'Indicates whether time confirmation is required for this operation. True if the operation must be confirmed with actual hours and completion status.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlKey rdf:type rdf:Property ;
    rdfs:label 'Control Key' ;
    rdfs:comment 'Control key that determines the operation type and scheduling parameters (e.g., PM01 for internal processing, PM02 for external service, PM03 for inspection). Defines whether the operation requires confirmation, external processing, or automatic goods issue.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earliestFinishDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Finish Date' ;
    rdfs:comment 'Earliest date the operation can be completed based on earliest start date and planned duration.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earliestStartDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Start Date' ;
    rdfs:comment 'Earliest date the operation can begin based on scheduling constraints, predecessor operations, and resource availability.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalOperationFlag rdf:type rdf:Property ;
    rdfs:label 'External Operation Flag' ;
    rdfs:comment 'Indicates whether this operation is performed by an external service provider rather than internal maintenance staff. True for subcontracted work.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Final Confirmation Flag' ;
    rdfs:comment 'Indicates whether the operation has received its final confirmation and no further time bookings are expected. True when operation is complete.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latestFinishDate rdf:type rdf:Property ;
    rdfs:label 'Latest Finish Date' ;
    rdfs:comment 'Latest date the operation must be completed to meet the work order required end date.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latestStartDate rdf:type rdf:Property ;
    rdfs:label 'Latest Start Date' ;
    rdfs:comment 'Latest date the operation must start to meet the work order required end date without delaying subsequent operations.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfCapacities rdf:type rdf:Property ;
    rdfs:label 'Number Of Capacities' ;
    rdfs:comment 'Number of people or capacity units required to perform the operation simultaneously. Used for resource leveling and scheduling.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationLongText rdf:type rdf:Property ;
    rdfs:label 'Operation Long Text' ;
    rdfs:comment 'Detailed description of the operation including step-by-step instructions, safety precautions, and technical specifications required to complete the task.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'Sequential operation number within the work order, typically a 4-digit numeric code (e.g., 0010, 0020, 0030) that defines the execution sequence.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationShortText rdf:type rdf:Property ;
    rdfs:label 'Operation Short Text' ;
    rdfs:comment 'Brief description of the operation task, summarizing the work to be performed (e.g., \'Replace pump seal\', \'Calibrate pressure transmitter\').' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedWorkDuration rdf:type rdf:Property ;
    rdfs:label 'Planned Work Duration' ;
    rdfs:comment 'Planned labor hours required to complete the operation, excluding setup time. Used for capacity planning and scheduling.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedWorkUnit rdf:type rdf:Property ;
    rdfs:label 'Planned Work Unit' ;
    rdfs:comment 'Unit of measure for planned work duration. H=hours, MIN=minutes, D=days.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTime rdf:type rdf:Property ;
    rdfs:label 'Setup Time' ;
    rdfs:comment 'Time required to prepare tools, equipment, and work area before the actual maintenance work can begin. Measured in the same unit as work duration.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTextKey rdf:type rdf:Property ;
    rdfs:label 'Standard Text Key' ;
    rdfs:comment 'Reference to standard text templates containing predefined operation instructions, safety procedures, or technical specifications that apply to this operation.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemStatus rdf:type rdf:Property ;
    rdfs:label 'System Status' ;
    rdfs:comment 'Current system-controlled status of the operation in its lifecycle. System status is automatically set by SAP PM based on business transactions and controls which actions are allowed.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownTime rdf:type rdf:Property ;
    rdfs:label 'Teardown Time' ;
    rdfs:comment 'Time required to clean up, restore the work area, and return tools after operation completion. Measured in the same unit as work duration.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:userStatus rdf:type rdf:Property ;
    rdfs:label 'User Status' ;
    rdfs:comment 'User-defined status that provides additional business-specific status information beyond system status. Configurable per business requirements.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workQuantity rdf:type rdf:Property ;
    rdfs:label 'Work Quantity' ;
    rdfs:comment 'Quantity of work to be performed, expressed in operation-specific units (e.g., number of valves to inspect, meters of pipe to replace, number of calibrations).' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Work Quantity Unit' ;
    rdfs:comment 'Unit of measure for work quantity (e.g., EA=each, M=meter, KG=kilogram). ISO unit codes.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Id' ;
    rdfs:comment 'Unique identifier for the blanket order agreement.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Category of the blanket order agreement defining pricing model.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Status' ;
    rdfs:comment 'Current lifecycle status of the blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callOffFrequency rdf:type rdf:Property ;
    rdfs:label 'Call Off Frequency' ;
    rdfs:comment 'Expected frequency of call-off orders under the agreement.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractVersion rdf:type rdf:Property ;
    rdfs:label 'Contract Version' ;
    rdfs:comment 'Version identifier of the blanket order contract.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCallOffQty rdf:type rdf:Property ;
    rdfs:label 'Minimum Call Off Qty' ;
    rdfs:comment 'Minimum quantity required for each call-off.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Pricing tier applicable based on volume thresholds.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateThresholdVolume rdf:type rdf:Property ;
    rdfs:label 'Rebate Threshold Volume' ;
    rdfs:comment 'Volume threshold at which rebate applies.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'Approval number from regulatory body for the product under this agreement.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'Remaining volume available for call-offs.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Renewal option for the blanket order after expiry.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason for termination if the agreement is terminated.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCallOffs rdf:type rdf:Property ;
    rdfs:label 'Total Call Offs' ;
    rdfs:comment 'Number of call-off orders released to date.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCommittedVolume rdf:type rdf:Property ;
    rdfs:label 'Total Committed Volume' ;
    rdfs:comment 'Total volume of product committed under the blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure for the committed volume.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Milestone Id' ;
    rdfs:comment 'Primary key for fulfillment_milestone' ;
    rdfs:domain ind:FulfillmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'Date on which the milestone was actually completed.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceDocumentAttached rdf:type rdf:Property ;
    rdfs:label 'Compliance Document Attached' ;
    rdfs:comment 'Indicates whether required regulatory documents (e.g., SDS, COA) are attached to the milestone record.' ;
    rdfs:domain ind:FulfillmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'Current status of customs clearance for cross-border shipments.' ;
    rdfs:domain ind:FulfillmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current state of the milestone indicating whether it is pending, completed, delayed, or cancelled.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Category of the fulfillment step (e.g., order confirmed, production scheduled, batch released, goods issued, in transit, delivered).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Date originally scheduled for the milestone to be achieved.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proofOfDeliveryReceived rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Received' ;
    rdfs:comment 'True when a signed proof of delivery (POD) has been captured for the shipment.' ;
    rdfs:domain ind:FulfillmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Internal team, department, or external partner accountable for executing the milestone.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Difference in days between planned_date and actual_date (positive = delay, negative = early).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlingInstructionId rdf:type rdf:Property ;
    rdfs:label 'Handling Instruction Id' ;
    rdfs:comment 'Primary key for handling_instruction' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableCasNumber rdf:type rdf:Property ;
    rdfs:label 'Applicable Cas Number' ;
    rdfs:comment 'Chemical Abstracts Service number identifying the chemical substance.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProductCode rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Code' ;
    rdfs:comment 'Product code (SKU) to which this handling instruction applies.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegion rdf:type rdf:Property ;
    rdfs:label 'Applicable Region' ;
    rdfs:comment 'Three-letter country code indicating the geographic region where the instruction applies.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierRestriction rdf:type rdf:Property ;
    rdfs:label 'Carrier Restriction' ;
    rdfs:comment 'Allowed transportation modes for the product.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Document Reference' ;
    rdfs:comment 'Identifier of the regulatory document (e.g., SOP, MSDS) that mandates this instruction.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Email' ;
    rdfs:comment 'Email address for emergency communications.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Handling Fee Amount' ;
    rdfs:comment 'Monetary charge associated with the special handling.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Handling Fee Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the handling fee.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingInstructionStatus rdf:type rdf:Property ;
    rdfs:label 'Handling Instruction Status' ;
    rdfs:comment 'Current lifecycle status of the instruction.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCode rdf:type rdf:Property ;
    rdfs:label 'Hazard Code' ;
    rdfs:comment 'UN identification number for the hazardous material.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialClass rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Class' ;
    rdfs:comment 'Hazard class of the material (limited to primary six classes; additional classes may be added via reference table).' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Max Percent' ;
    rdfs:comment 'Highest allowable relative humidity level.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityMinPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Min Percent' ;
    rdfs:comment 'Lowest allowable relative humidity level.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inertAtmosphereRequired rdf:type rdf:Property ;
    rdfs:label 'Inert Atmosphere Required' ;
    rdfs:comment 'Indicates whether an inert gas environment is mandatory.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instructionCode rdf:type rdf:Property ;
    rdfs:label 'Instruction Code' ;
    rdfs:comment 'Business code used to reference the instruction in ERP and logistics systems.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionName rdf:type rdf:Property ;
    rdfs:label 'Instruction Name' ;
    rdfs:comment 'Human-readable name describing the handling instruction.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionType rdf:type rdf:Property ;
    rdfs:label 'Instruction Type' ;
    rdfs:comment 'Category of the instruction indicating the primary handling requirement.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingRequirement rdf:type rdf:Property ;
    rdfs:label 'Labeling Requirement' ;
    rdfs:comment 'Labeling details such as hazard symbols, temperature icons, or carrier marks.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingRequirement rdf:type rdf:Property ;
    rdfs:label 'Packaging Requirement' ;
    rdfs:comment 'Specific packaging needed (e.g., double-walled, UN-rated container).' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureVesselRequired rdf:type rdf:Property ;
    rdfs:label 'Pressure Vessel Required' ;
    rdfs:comment 'Indicates whether transport must use a pressure-rated vessel.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Regulatory framework that drives the handling requirement.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationRequirement rdf:type rdf:Property ;
    rdfs:label 'Segregation Requirement' ;
    rdfs:comment 'Instructions to keep the product separate from incompatible chemicals.' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialEquipmentNeeded rdf:type rdf:Property ;
    rdfs:label 'Special Equipment Needed' ;
    rdfs:comment 'Equipment required for handling (e.g., forklift, crane, ventilated pallet).' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationRequirement rdf:type rdf:Property ;
    rdfs:label 'Storage Location Requirement' ;
    rdfs:comment 'Specific storage location constraints (e.g., refrigerated warehouse, ventilated area).' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlMethod rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Method' ;
    rdfs:comment 'Method used to maintain temperature (e.g., refrigerated, heated, ambient).' ;
    rdfs:domain ind:HandlingInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productHoldId rdf:type rdf:Property ;
    rdfs:label 'Product Hold Id' ;
    rdfs:comment 'Primary key for hold' ;
    rdfs:domain ind:ProductHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Placed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory holds require identifying the employee who placed the hold for accountability and reporting.' ;
    rdfs:domain ind:ProductHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:isRegulatoryCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Compliant' ;
    rdfs:comment 'Indicates whether the hold satisfies all applicable regulatory requirements.' ;
    rdfs:domain ind:ProductHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Placed Timestamp' ;
    rdfs:comment 'Date and time when the hold was initially placed on the order.' ;
    rdfs:domain ind:ProductHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseAuthorization rdf:type rdf:Property ;
    rdfs:label 'Release Authorization' ;
    rdfs:comment 'Identifier of the person or system that authorized the hold release.' ;
    rdfs:domain ind:ProductHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryId rdf:type rdf:Property ;
    rdfs:label 'Inquiry Id' ;
    rdfs:comment 'Primary key for inquiry' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inquiryCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inquiry Created By User Employee Id' ;
    rdfs:comment 'User identifier of the person who created the inquiry record.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inquiryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inquiry Employee Id' ;
    rdfs:comment 'Identifier of the sales representative assigned to the inquiry.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inquiryLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inquiry Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified the inquiry record.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deliveryDateRequired rdf:type rdf:Property ;
    rdfs:label 'Delivery Date Required' ;
    rdfs:comment 'Date by which the customer expects the product to be delivered.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Address where the product is to be delivered.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Price Amount' ;
    rdfs:comment 'Requested gross price before any discounts or adjustments.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inquiryStatus rdf:type rdf:Property ;
    rdfs:label 'Inquiry Status' ;
    rdfs:comment 'Current processing state of the inquiry.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inquiry Timestamp' ;
    rdfs:comment 'Date and time when the inquiry was initially created/submitted.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Net Price Amount' ;
    rdfs:comment 'Final price after discounts, representing the amount the customer expects to pay.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Flag' ;
    rdfs:comment 'Priority level assigned to the inquiry for internal processing.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCasNumber rdf:type rdf:Property ;
    rdfs:label 'Product Cas Number' ;
    rdfs:comment 'Standard CAS number identifying the chemical substance requested.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Amount of product the customer wishes to purchase.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which the supplier is expected to respond to the inquiry.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'External reference number assigned to the RFQ for customer and internal tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the inquiry was received.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecAttachmentReference rdf:type rdf:Property ;
    rdfs:label 'Technical Spec Attachment Reference' ;
    rdfs:comment 'Reference to a stored technical specification attachment.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Date until which the quoted prices remain valid.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Date from which the quoted prices are valid.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotRecordId rdf:type rdf:Property ;
    rdfs:label 'Lot Record Id' ;
    rdfs:comment 'Foreign key linking to rawmaterial.lot_record. Business justification: Supports Traceability & Recall Management by linking each order line to the specific lot record of the shipped material.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotRecord .

ind:opportunityProductId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Product Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity_product. Business justification: Links each order line to the opportunity product that generated it, supporting win-loss and forecasting reports.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpportunityProduct .

ind:specialHandlingInstructionId rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instruction Id' ;
    rdfs:comment 'Foreign key linking to order.handling_instruction. Business justification: Line items reference handling instructions; moving to a FK normalizes data and removes the free-text column.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandlingInstruction .

ind:batchDeterminationFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Determination Flag' ;
    rdfs:comment 'Indicates whether batch allocation is required for this line (True) or not (False).' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'Date-time when the line record was first created in the system.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ehsHazardStatement rdf:type rdf:Property ;
    rdfs:label 'Ehs Hazard Statement' ;
    rdfs:comment 'Standard GHS hazard statement associated with the material.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsPrecautionaryStatement rdf:type rdf:Property ;
    rdfs:label 'Ehs Precautionary Statement' ;
    rdfs:comment 'Standard GHS precautionary statement for safe handling.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Compliant' ;
    rdfs:comment 'True if the product is manufactured under Good Manufacturing Practice standards.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Update Timestamp' ;
    rdfs:comment 'Date-time of the most recent modification to the line record.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineComment rdf:type rdf:Property ;
    rdfs:label 'Line Comment' ;
    rdfs:comment 'Free-form comment entered by order entry personnel.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Net price multiplied by confirmed quantity before tax.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Material Gl Account Code' ;
    rdfs:comment 'GL account used for revenue recognition of this material.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSdsUrl rdf:type rdf:Property ;
    rdfs:label 'Material Sds Url' ;
    rdfs:comment 'Link to the electronic Safety Data Sheet for the material.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqEnforcedFlag rdf:type rdf:Property ;
    rdfs:label 'Moq Enforced Flag' ;
    rdfs:comment 'True when the line must meet the customer\'s minimum order quantity requirement.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Net price per unit before taxes and discounts, in the order currency.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity requested by the customer, expressed in the unit of measure.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialDeliveryAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Delivery Allowed Flag' ;
    rdfs:comment 'True if the line can be split across multiple deliveries.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingCondition rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition' ;
    rdfs:comment 'Code representing the pricing condition applied (e.g., discount, surcharge).' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Flag' ;
    rdfs:comment 'True if the product must be stored or transported at a controlled temperature.' ;
    rdfs:domain ind:LineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributorId rdf:type rdf:Property ;
    rdfs:label 'Distributor Id' ;
    rdfs:comment 'Foreign key linking to sales.distributor. Business justification: Links orders placed through a distributor; required for distributor performance and rebate calculations.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Distributor .

ind:forecastVersionId rdf:type rdf:Property ;
    rdfs:label 'Forecast Version Id' ;
    rdfs:comment 'Foreign key linking to planning.forecast_version. Business justification: Order Planning Audit uses the forecast version that drove demand planning for the sales order, required for regulatory reporting and demand accuracy analysis.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForecastVersion .

ind:mrpRunId rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Id' ;
    rdfs:comment 'Foreign key linking to planning.mrp_run. Business justification: MRP Run linkage records which MRP execution generated the plan for a sales order, needed for traceability and performance KPI reporting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrpRun .

ind:patentFilingId rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Id' ;
    rdfs:comment 'Foreign key linking to research.patent_filing. Business justification: Patent Royalty Tracking requires linking each order to the patent filing that protects the sold chemical for royalty accounting.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentFiling .

ind:primaryFormulaId rdf:type rdf:Property ;
    rdfs:label 'Primary Formula Id' ;
    rdfs:comment 'Foreign key linking to formulation.formula. Business justification: Required for Order master reporting: the primary formula defining the product family is stored on the sales order to support profitability analysis and regulatory traceability.' ;
    rdfs:domain ind:ProductOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formula .

ind:productOrderSiteId rdf:type rdf:Property ;
    rdfs:label 'Product Order Site Id' ;
    rdfs:comment 'Reference to the address used for invoicing.' ;
    rdfs:domain ind:ProductOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:proposalId rdf:type rdf:Property ;
    rdfs:label 'Proposal Id' ;
    rdfs:comment 'Foreign key linking to pricing.pricing_proposal. Business justification: REQUIRED: Special pricing proposals are attached to orders; linking enables proposal acceptance tracking and profitability review.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Proposal .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Assigns each order to a sales territory for regional sales reporting and quota tracking.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:sdsId rdf:type rdf:Property ;
    rdfs:label 'Sds Id' ;
    rdfs:comment 'Reference to the attached Safety Data Sheet or regulatory compliance document.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sds .

ind:shippingAddressSiteId rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Site Id' ;
    rdfs:comment 'Reference to the destination address for delivery.' ;
    rdfs:domain ind:ProductOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:sopCycleId rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle Id' ;
    rdfs:comment 'Foreign key linking to planning.sop_cycle. Business justification: SOP Cycle assignment links a sales order to the Sales & Operations Planning cycle used for its demand-supply balancing, required for cycle performance metrics.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SopCycle .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Channel through which the product is sold (e.g., wholesale, retail).' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'Business division responsible for the product line.' ;
    rdfs:domain ind:ProductOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBackorder rdf:type rdf:Property ;
    rdfs:label 'Is Backorder' ;
    rdfs:comment 'True when any line items are pending due to stock shortage.' ;
    rdfs:domain ind:ProductOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSplit rdf:type rdf:Property ;
    rdfs:label 'Is Split' ;
    rdfs:comment 'True when the order is fulfilled in multiple shipments.' ;
    rdfs:domain ind:ProductOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineCount rdf:type rdf:Property ;
    rdfs:label 'Line Count' ;
    rdfs:comment 'Number of distinct line items on the order.' ;
    rdfs:domain ind:ProductOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

