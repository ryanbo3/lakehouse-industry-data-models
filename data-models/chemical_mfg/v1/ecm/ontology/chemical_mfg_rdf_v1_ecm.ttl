    rdfs:comment 'Categorization of the R&D effort.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Review Status' ;
    rdfs:comment 'Result of internal safety and hazard assessments.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorOrganization rdf:type rdf:Property ;
    rdfs:label 'Sponsor Organization' ;
    rdfs:comment 'Internal or external organization sponsoring the project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageGateDate rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Date' ;
    rdfs:comment 'Date of the most recent stage-gate review.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageGateStatus rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Status' ;
    rdfs:comment 'Current stage-gate decision point for the project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCriteria rdf:type rdf:Property ;
    rdfs:label 'Success Criteria' ;
    rdfs:comment 'Specific measurable criteria used to judge project success.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Technology Readiness Level' ;
    rdfs:comment 'Standardized TRL rating (1-9) indicating maturity of the technology.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rdStabilityStudyId rdf:type rdf:Property ;
    rdfs:label 'Rd Stability Study Id' ;
    rdfs:comment 'System-generated unique identifier for the stability study record.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceCriteriaAssayPercent rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Assay Percent' ;
    rdfs:comment 'Minimum acceptable assay potency percentage for the product to pass the study.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptanceCriteriaColor rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Color' ;
    rdfs:comment 'Qualitative color change tolerance for the product.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceCriteriaParticulatePpm rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Particulate Ppm' ;
    rdfs:comment 'Maximum permissible particulate count expressed in parts per million.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptanceCriteriaPh rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Ph' ;
    rdfs:comment 'Acceptable pH range limit for the product during the study.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptanceCriteriaViscosityCp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Viscosity Cp' ;
    rdfs:comment 'Maximum allowable viscosity (centipoise) for the product to be considered stable.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityStatus rdf:type rdf:Property ;
    rdfs:label 'Data Quality Status' ;
    rdfs:comment 'Overall quality assessment of the study data.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOosFlag rdf:type rdf:Property ;
    rdfs:label 'Is Oos Flag' ;
    rdfs:comment 'Indicates whether any measured parameter fell outside the predefined acceptance criteria.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOotFlag rdf:type rdf:Property ;
    rdfs:label 'Is Oot Flag' ;
    rdfs:comment 'Indicates whether observed trends deviate from expected stability patterns.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lightExposureLux rdf:type rdf:Property ;
    rdfs:label 'Light Exposure Lux' ;
    rdfs:comment 'Illuminance level applied for photostability studies, measured in lux.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rdStabilityStudyStatus rdf:type rdf:Property ;
    rdfs:label 'Rd Stability Study Status' ;
    rdfs:comment 'Current lifecycle status of the stability study.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Protocol Reference' ;
    rdfs:comment 'Identifier or document reference for the regulatory protocol governing the study (e.g., ICH Q1A, EPA guideline).' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Sampling Interval Months' ;
    rdfs:comment 'Interval between scheduled sampling timepoints, expressed in months.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Description' ;
    rdfs:comment 'Narrative description of the storage conditions (e.g., sealed, protected from light).' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Study Duration Months' ;
    rdfs:comment 'Total planned duration of the stability study expressed in months.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testHumidityPercent rdf:type rdf:Property ;
    rdfs:label 'Test Humidity Percent' ;
    rdfs:comment 'Controlled relative humidity level for the study environment, expressed as a percentage.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Test Temperature C' ;
    rdfs:comment 'Controlled temperature at which the sample is stored during the study, expressed in degrees Celsius.' ;
    rdfs:domain ind:RdStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:associatedFormulationExperimentalFormulationId rdf:type rdf:Property ;
    rdfs:label 'Associated Formulation Experimental Formulation Id' ;
    rdfs:comment 'Reference to the formulation entity that this simulation evaluates.' ;
    rdfs:domain ind:ResearchProcessSimulation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExperimentalFormulation .

ind:associatedProcedure rdf:type rdf:Property ;
    rdfs:label 'Associated Procedure' ;
    rdfs:comment 'Name or identifier of the laboratory synthesis procedure linked to this simulation.' ;
    rdfs:domain ind:ResearchProcessSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalCostEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Capital Cost Estimate Usd' ;
    rdfs:comment 'Preliminary capital expenditure estimate for implementing the simulated process, expressed in US dollars.' ;
    rdfs:domain ind:ResearchProcessSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionMwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Mwh' ;
    rdfs:comment 'Total energy consumption of the simulated process in megawatt-hours.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feasibilityOutcome rdf:type rdf:Property ;
    rdfs:label 'Feasibility Outcome' ;
    rdfs:comment 'Result of the scale-up feasibility assessment.' ;
    rdfs:domain ind:ResearchProcessSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazopFindings rdf:type rdf:Property ;
    rdfs:label 'Hazop Findings' ;
    rdfs:comment 'Key findings from HAZOP or PHA analyses related to the simulated process.' ;
    rdfs:domain ind:ResearchProcessSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedScaleUpChallenges rdf:type rdf:Property ;
    rdfs:label 'Identified Scale Up Challenges' ;
    rdfs:comment 'Narrative description of heat, mass, mixing, or safety challenges identified for scale-up.' ;
    rdfs:domain ind:ResearchProcessSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelTool rdf:type rdf:Property ;
    rdfs:label 'Model Tool' ;
    rdfs:comment 'Software tool used to build and run the simulation.' ;
    rdfs:domain ind:ResearchProcessSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processUnitsModeled rdf:type rdf:Property ;
    rdfs:label 'Process Units Modeled' ;
    rdfs:comment 'List of major process units (reactor, separator, heat exchanger, etc.) represented in the model.' ;
