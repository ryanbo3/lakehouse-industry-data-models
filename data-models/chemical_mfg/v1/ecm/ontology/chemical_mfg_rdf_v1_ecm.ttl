    rdfs:comment 'Category of chemical reaction performed.' ;
    rdfs:domain ind:SynthesisProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteGeneratedKg rdf:type rdf:Property ;
    rdfs:label 'Waste Generated Kg' ;
