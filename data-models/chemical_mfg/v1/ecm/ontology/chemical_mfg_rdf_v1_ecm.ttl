    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Lab Instrument Id' ;
    rdfs:comment 'Unique identifier of the laboratory instrument that was calibrated.' ;
    rdfs:domain ind:ChemicalMfg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabInstrument .

ind:performedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Performed By Employee Id' ;
