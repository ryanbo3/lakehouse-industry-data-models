    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionVersion rdf:type rdf:Property ;
    rdfs:label 'Inspection Version' ;
    rdfs:comment 'Version number of the inspection record for concurrency control.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Category indicating why the lot was created: incoming goods receipt, in-process production, scheduled periodic inspection, or customer return.' ;
